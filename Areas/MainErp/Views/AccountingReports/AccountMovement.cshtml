@model MyERP.Areas.MainErp.ViewModels.Reports.AccountMovementReportViewModel
@{
    Layout = "~/Areas/MainErp/Views/Shared/_MainErpLayout.cshtml";
    ViewBag.Title = "Account Movement";
}
<section class="main-erp-panel">
    <div class="main-erp-title-row">
        <div>
            <h3>حركة حساب خلال فترة</h3>
            <p>تقرير قراءة فقط. الرصيد المتحرك يمثل صافي حركة الفترة حتى اعتماد قواعد الرصيد الافتتاحي.</p>
        </div>
        <span class="main-erp-badge">Read-only</span>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Warning))
    {
        <div class="main-erp-warning">@Model.Warning</div>
    }

    @using (Html.BeginForm("AccountMovement", "AccountingReports", new { area = "MainErp" }, FormMethod.Get, new { @class = "main-erp-filter" }))
    {
        <input type="date" name="fromDate" value="@(Model.FromDate.HasValue ? Model.FromDate.Value.ToString("yyyy-MM-dd") : string.Empty)" title="من تاريخ" />
        <input type="date" name="toDate" value="@(Model.ToDate.HasValue ? Model.ToDate.Value.ToString("yyyy-MM-dd") : string.Empty)" title="إلى تاريخ" />
        <input type="text" name="accountCode" value="@Model.AccountCode" placeholder="الحساب" required="required" />
        <input type="number" name="branchId" value="@Model.BranchId" placeholder="الفرع" />
        <button type="submit">عرض التقرير</button>
    }

    @if (!string.IsNullOrWhiteSpace(Model.AccountName))
    {
        <p class="main-erp-muted">الحساب: <strong>@Model.AccountCode</strong> - @Model.AccountName</p>
    }

    <table class="main-erp-table">
        <thead>
            <tr>
                <th>التاريخ</th>
                <th>رقم القيد</th>
                <th>البيان</th>
                <th>مدين</th>
                <th>دائن</th>
                <th>صافي حركة الفترة</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Model.Rows)
            {
                <tr>
                    <td>@(row.NoteDate.HasValue ? row.NoteDate.Value.ToString("dd/MM/yyyy") : "")</td>
                    <td>@row.NoteSerial</td>
                    <td>@row.Description</td>
                    <td>@row.Debit.ToString("N2")</td>
                    <td>@row.Credit.ToString("N2")</td>
                    <td>@row.RunningMovement.ToString("N2")</td>
                </tr>
            }
            @if (Model.Rows.Count == 0)
            {
                <tr><td colspan="6">لا توجد بيانات للعرض.</td></tr>
            }
        </tbody>
        <tfoot>
            <tr>
                <th colspan="3">الإجمالي</th>
                <th>@Model.TotalDebit.ToString("N2")</th>
                <th>@Model.TotalCredit.ToString("N2")</th>
                <th>@Model.PeriodMovement.ToString("N2")</th>
            </tr>
        </tfoot>
    </table>
</section>
