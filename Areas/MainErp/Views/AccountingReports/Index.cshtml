@{
    Func<string, string> T = MyERP.Areas.MainErp.Infrastructure.Localization.MainErpLocalizationService.T;
    Layout = "~/Areas/MainErp/Views/Shared/_MainErpLayout.cshtml";
    ViewBag.Title = T("AccountingReports");
}
<section class="main-erp-panel">
    <div class="main-erp-title-row">
        <div>
            <h3>@T("AccountingReports")</h3>
            <p>@T("ActualPostingDisabled")</p>
        </div>
        <span class="main-erp-badge">@T("ReadOnly")</span>
    </div>

    <div class="main-erp-report-tiles">
        <a href="@Url.Action("JournalEntries", "AccountingReports", new { area = "MainErp" })">
            <span></span><strong>@T("JournalEntries")</strong><small>@T("ReadOnly")</small>
        </a>
        <a href="@Url.Action("AccountMovement", "AccountingReports", new { area = "MainErp" })">
            <span></span><strong>@T("AccountMovement")</strong><small>@T("ReadOnly")</small>
        </a>
        <a class="is-disabled"><span></span><strong>Trial Balance</strong><small>@T("ActualPostingDisabled")</small></a>
        <a class="is-disabled"><span></span><strong>Account Statement</strong><small>@T("ActualPostingDisabled")</small></a>
    </div>

    <div class="main-erp-form-grid">
        <label><span>@T("FromDate")</span><input type="date" /></label>
        <label><span>@T("ToDate")</span><input type="date" /></label>
        <label><span>@T("Branch")</span><input type="text" placeholder="@T("AllBranches")" /></label>
        <label><span>@T("Account")</span><input type="text" /></label>
    </div>
</section>
