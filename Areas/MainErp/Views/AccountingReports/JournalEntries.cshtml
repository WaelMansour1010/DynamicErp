@model MyERP.Areas.MainErp.ViewModels.Reports.JournalEntriesReportViewModel
@using MyERP.Areas.MainErp.Infrastructure.Localization
@{
    Layout = "~/Areas/MainErp/Views/Shared/_MainErpLayout.cshtml";
    Func<string, string> T = MainErpLocalizationService.T;
    ViewBag.Title = T("JournalEntries");
}

<section class="main-erp-panel">
    <div class="main-erp-title-row">
        <div>
            <h3>@T("JournalEntries")</h3>
            <p>@T("JournalEntriesReportIntro")</p>
        </div>
        <span class="main-erp-badge">@T("ReadOnly")</span>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Warning))
    {
        <div class="main-erp-warning">@Model.Warning</div>
    }

    @using (Html.BeginForm("JournalEntries", "AccountingReports", new { area = "MainErp" }, FormMethod.Get, new { @class = "main-erp-filter" }))
    {
        <input type="date" name="fromDate" value="@(Model.FromDate.HasValue ? Model.FromDate.Value.ToString("yyyy-MM-dd") : string.Empty)" title="@T("FromDate")" />
        <input type="date" name="toDate" value="@(Model.ToDate.HasValue ? Model.ToDate.Value.ToString("yyyy-MM-dd") : string.Empty)" title="@T("ToDate")" />
        <input type="number" name="branchId" value="@Model.BranchId" placeholder="@T("Branch")" />
        <input type="text" name="accountCode" value="@Model.AccountCode" placeholder="@T("Account")" />
        <input type="number" name="noteType" value="@Model.NoteType" placeholder="@T("NoteType")" />
        <button type="submit">@T("ReportRun")</button>
    }

    <table class="main-erp-table">
        <thead>
            <tr>
                <th>@T("Date")</th>
                <th>@T("NoteSerial")</th>
                <th>@T("NoteType")</th>
                <th>@T("Account")</th>
                <th>@T("Debit")</th>
                <th>@T("Credit")</th>
                <th>@T("Branch")</th>
                <th>@T("User")</th>
                <th>@T("Description")</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Model.Rows)
            {
                <tr>
                    <td>@(row.NoteDate.HasValue ? row.NoteDate.Value.ToString("dd/MM/yyyy") : "")</td>
                    <td>@row.NoteSerial</td>
                    <td>@row.NoteType</td>
                    <td>@(string.IsNullOrWhiteSpace(row.AccountDisplay) ? T("AccountNotFound") : row.AccountDisplay)</td>
                    <td>@row.Debit.ToString("N2")</td>
                    <td>@row.Credit.ToString("N2")</td>
                    <td>@row.BranchName</td>
                    <td>@row.UserName</td>
                    <td>@row.Description</td>
                </tr>
            }
            @if (Model.Rows.Count == 0)
            {
                <tr><td colspan="9">@T("NoRows")</td></tr>
            }
        </tbody>
        <tfoot>
            <tr>
                <th colspan="4">@T("Totals")</th>
                <th>@Model.TotalDebit.ToString("N2")</th>
                <th>@Model.TotalCredit.ToString("N2")</th>
                <th colspan="3">@T("PeriodMovement"): @((Model.TotalDebit - Model.TotalCredit).ToString("N2"))</th>
            </tr>
        </tfoot>
    </table>
</section>
