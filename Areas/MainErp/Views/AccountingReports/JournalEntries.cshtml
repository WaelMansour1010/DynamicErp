@model MyERP.Areas.MainErp.ViewModels.Reports.JournalEntriesReportViewModel
@{
    Layout = "~/Areas/MainErp/Views/Shared/_MainErpLayout.cshtml";
    ViewBag.Title = "Journal Entries Report";
}
<section class="main-erp-panel">
    <div class="main-erp-title-row">
        <div>
            <h3>تقرير القيود اليومية خلال فترة</h3>
            <p>تقرير قراءة فقط من القيود العامة.</p>
        </div>
        <span class="main-erp-badge">Read-only</span>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Warning))
    {
        <div class="main-erp-warning">@Model.Warning</div>
    }

    @using (Html.BeginForm("JournalEntries", "AccountingReports", new { area = "MainErp" }, FormMethod.Get, new { @class = "main-erp-filter" }))
    {
        <input type="date" name="fromDate" value="@(Model.FromDate.HasValue ? Model.FromDate.Value.ToString("yyyy-MM-dd") : string.Empty)" title="من تاريخ" />
        <input type="date" name="toDate" value="@(Model.ToDate.HasValue ? Model.ToDate.Value.ToString("yyyy-MM-dd") : string.Empty)" title="إلى تاريخ" />
        <input type="number" name="branchId" value="@Model.BranchId" placeholder="الفرع" />
        <input type="text" name="accountCode" value="@Model.AccountCode" placeholder="الحساب" />
        <input type="number" name="noteType" value="@Model.NoteType" placeholder="نوع القيد" />
        <button type="submit">عرض التقرير</button>
    }

    <table class="main-erp-table">
        <thead>
            <tr>
                <th>التاريخ</th>
                <th>رقم القيد</th>
                <th>نوع القيد</th>
                <th>الحساب</th>
                <th>مدين</th>
                <th>دائن</th>
                <th>الفرع</th>
                <th>المستخدم</th>
                <th>البيان</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Model.Rows)
            {
                <tr>
                    <td>@(row.NoteDate.HasValue ? row.NoteDate.Value.ToString("dd/MM/yyyy") : "")</td>
                    <td>@row.NoteSerial</td>
                    <td>@row.NoteType</td>
                    <td><strong>@row.AccountCode</strong><br /><small>@row.AccountName</small></td>
                    <td>@row.Debit.ToString("N2")</td>
                    <td>@row.Credit.ToString("N2")</td>
                    <td>@row.BranchName</td>
                    <td>@row.UserName</td>
                    <td>@row.Description</td>
                </tr>
            }
            @if (Model.Rows.Count == 0)
            {
                <tr><td colspan="9">لا توجد بيانات للعرض.</td></tr>
            }
        </tbody>
        <tfoot>
            <tr>
                <th colspan="4">الإجمالي</th>
                <th>@Model.TotalDebit.ToString("N2")</th>
                <th>@Model.TotalCredit.ToString("N2")</th>
                <th colspan="3">صافي الحركة: @((Model.TotalDebit - Model.TotalCredit).ToString("N2"))</th>
            </tr>
        </tfoot>
    </table>
</section>
