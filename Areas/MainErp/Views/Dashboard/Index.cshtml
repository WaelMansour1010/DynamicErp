@{
    Func<string, string> T = MyERP.Areas.MainErp.Infrastructure.Localization.MainErpLocalizationService.T;
    Layout = "~/Areas/MainErp/Views/Shared/_MainErpLayout.cshtml";
    ViewBag.Title = T("Dashboard");
    ViewBag.ActiveScreen = "dashboard";
}

<section id="mainErpDashboardPanel" class="pos-admin-dashboard main-erp-dashboard-panel">
    <div class="pos-panel executive-hero-panel main-erp-executive-hero">
        <div class="panel-heading">
            <div>
                <h2>@T("Dashboard")</h2>
                <span>@T("ActualPostingDisabled")</span>
            </div>
            <button type="button" class="link-action" id="mainErpRefreshDashboardBtn">@T("Search")</button>
        </div>

        <div class="dashboard-period-toggle" id="mainErpPeriodToggle" role="radiogroup" aria-label="@T("Dashboard")">
            <label><input type="radio" name="mainErpPeriodType" value="daily" checked /> Daily</label>
            <label><input type="radio" name="mainErpPeriodType" value="weekly" /> Weekly</label>
            <label><input type="radio" name="mainErpPeriodType" value="monthly" /> Monthly</label>
            <label><input type="radio" name="mainErpPeriodType" value="yearly" /> Yearly</label>
            <label><input type="radio" name="mainErpPeriodType" value="custom" /> Custom</label>
        </div>

        <div class="pos-grid four-cols reports-filter-grid dashboard-filter-grid">
            <label class="dashboard-date-filter">@T("FromDate")<input type="date" id="mainErpFromDate" value="@DateTime.Today.ToString("yyyy-MM-dd")" disabled /></label>
            <label class="dashboard-date-filter">@T("ToDate")<input type="date" id="mainErpToDate" value="@DateTime.Today.ToString("yyyy-MM-dd")" disabled /></label>
            <label>@T("Branch")<select id="mainErpBranchId"><option value="">@T("AllBranches")</option></select></label>
            <label>@T("Reports")<select id="mainErpDashboardScope"><option value="">@T("MainErp")</option><option value="accounting">@T("Accounting")</option><option value="sales">@T("Sales")</option><option value="lc">@T("LettersOfCredit")</option></select></label>
        </div>
    </div>

    <div id="mainErpDashboardMessage" class="pos-validation main-erp-dashboard-message">@T("ActualPostingDisabled")</div>

    <div class="admin-kpi-grid main-erp-kpi-grid">
        <a class="admin-kpi-card main-erp-kpi-card" href="@Url.Action("SalesSummary", "SalesReports", new { area = "MainErp" })"><span class="kpi-label">@T("Sales")</span><strong>@T("SalesSummary")</strong><small>@T("ReadOnly")</small></a>
        <a class="admin-kpi-card main-erp-kpi-card" href="@Url.Action("Index", "AccountingReports", new { area = "MainErp" })"><span class="kpi-label">@T("Accounting")</span><strong>@T("AccountingReports")</strong><small>@T("ReadOnly")</small></a>
        <a class="admin-kpi-card main-erp-kpi-card" href="@Url.Action("Index", "Purchases", new { area = "MainErp" })"><span class="kpi-label">@T("Purchases")</span><strong>@T("Purchases")</strong><small>@T("ActualPostingDisabled")</small></a>
        <a class="admin-kpi-card main-erp-kpi-card" href="@Url.Action("Index", "StockTransfers", new { area = "MainErp" })"><span class="kpi-label">@T("Inventory")</span><strong>@T("StockTransfers")</strong><small>@T("ActualPostingDisabled")</small></a>
        <a class="admin-kpi-card main-erp-kpi-card" href="@Url.Action("Index", "ProjectExtracts", new { area = "MainErp" })"><span class="kpi-label">@T("Projects")</span><strong>@T("ProjectExtracts")</strong><small>@T("ReadOnly")</small></a>
        <a class="admin-kpi-card main-erp-kpi-card" href="@Url.Action("Index", "LC", new { area = "MainErp" })"><span class="kpi-label">@T("LettersOfCredit")</span><strong>@T("LcScreen")</strong><small>@T("ReadOnly")</small></a>
    </div>

    <div class="admin-dashboard-grid main-erp-dashboard-grid">
        <section class="pos-panel"><div class="panel-heading"><h2>@T("Reports")</h2></div><div class="dashboard-chart-wrap"><canvas id="mainErpModulesChart"></canvas></div></section>
        <section class="pos-panel"><div class="panel-heading"><h2>@T("Branch")</h2></div><div class="dashboard-chart-wrap"><canvas id="mainErpBranchesChart"></canvas></div></section>
    </div>
</section>

@section scripts {
<script>
(function () {
    function makeChart(id, config) {
        var canvas = document.getElementById(id);
        if (!canvas || typeof Chart === "undefined") { return; }
        return new Chart(canvas.getContext("2d"), config);
    }
    makeChart("mainErpModulesChart", { type: "doughnut", data: { labels: ["@T("Accounting")", "@T("Sales")", "@T("Purchases")", "@T("Inventory")", "@T("Projects")", "@T("LettersOfCredit")"], datasets: [{ data: [22,18,14,12,17,17], backgroundColor: ["#2563eb","#059669","#d97706","#7c3aed","#0f766e","#b91c1c"] }] }, options: { responsive: true, maintainAspectRatio: false, legend: { position: "bottom" } } });
    makeChart("mainErpBranchesChart", { type: "bar", data: { labels: ["A", "B", "C"], datasets: [{ data: [82, 74, 69], backgroundColor: "#2563eb" }] }, options: { responsive: true, maintainAspectRatio: false, legend: { display: false }, scales: { yAxes: [{ ticks: { beginAtZero: true } }] } } });
})();
</script>
}
