@model MyERP.Areas.MainErp.ViewModels.DatabaseMigration.DatabaseMigrationDashboardViewModel
@using System.Globalization
@{
    Layout = "~/Areas/MainErp/Views/Shared/_MainErpLayout.cshtml";
    var inv = CultureInfo.InvariantCulture;
    var lastRun = Model.LastRunResult;
    var uiError = TempData["DatabaseMigration.Error"] as string;
}
<link href="@Url.Content("~/Areas/MainErp/Content/database-migration-manager.css?v=20260509-db-migration")" rel="stylesheet" />
<section class="dbm-page" dir="rtl">
    <div class="dbm-header">
        <div>
            <span class="dbm-kicker">Database Update Manager</span>
            <h2>ادارة تحديثات قاعدة البيانات</h2>
            <p>قاعدة البيانات: <strong>@Model.DatabaseName</strong> | السيرفر: <strong>@Model.ServerName</strong> | البيئة: <strong>@Model.EnvironmentName</strong></p>
        </div>
        <div class="dbm-status"><strong>@Model.Status</strong><small>اخر تحديث: @(Model.LastAppliedOn.HasValue ? Model.LastAppliedOn.Value.ToString("yyyy-MM-dd HH:mm", inv) : "لا يوجد")</small></div>
    </div>
    @if (!String.IsNullOrWhiteSpace(uiError)) { <div class="dbm-alert dbm-alert-danger">@uiError</div> }
    <div class="dbm-summary-grid"><div>Applied migrations<strong>@Model.AppliedCount</strong></div><div>Pending migrations<strong>@Model.PendingCount</strong></div><div>Failed migrations<strong>@Model.FailedCount</strong></div><div>Hash mismatch warnings<strong>@Model.HashMismatchCount</strong></div><div>Last applied date<strong>@(Model.LastAppliedOn.HasValue ? Model.LastAppliedOn.Value.ToString("yyyy-MM-dd", inv) : "-")</strong></div></div>
    <div class="dbm-actions">
        @using (Html.BeginForm("DryRun", "DatabaseMigration", new { area = "MainErp" }, FormMethod.Post)) { @Html.AntiForgeryToken()<button class="dbm-btn" type="submit">فحص بدون تنفيذ</button> }
        <a class="dbm-btn" href="@Url.Action("ExportReport", "DatabaseMigration", new { area = "MainErp" })">تصدير التقرير</a>
        <input class="dbm-search" type="search" placeholder="بحث في الجداول" data-dbm-search />
    </div>
    @if (lastRun != null) { <section class="dbm-run-result"><h3>نتيجة اخر تشغيل: @lastRun.Mode - @lastRun.Status</h3><p>Pending: @lastRun.TotalScripts | Applied: @lastRun.AppliedCount | Failed: @lastRun.FailedCount | Warnings: @lastRun.WarningCount</p>@foreach (var d in lastRun.Applied.Concat(lastRun.Failed)) { <span class="dbm-chip">@d.ScriptName - @d.Status @d.ErrorMessage</span> }@foreach (var m in lastRun.HashMismatches) { <span class="dbm-chip dbm-danger">Hash mismatch - @m.ScriptName</span> }</section> }
    <div class="dbm-tabs" data-dbm-tabs><button type="button" class="is-active" data-tab="pending">Pending Updates</button><button type="button" data-tab="history">Applied History</button><button type="button" data-tab="failed">Failed / Errors</button><button type="button" data-tab="settings">Settings / Sources</button><button type="button" data-tab="log">Execution Log</button></div>
    <section class="dbm-tab-panel is-active" data-tab-panel="pending">
        @using (Html.BeginForm("ApplySelected", "DatabaseMigration", new { area = "MainErp" }, FormMethod.Post, new { id = "dbmApplySelectedForm" })) {
            @Html.AntiForgeryToken()
            <div class="dbm-panel-head"><h3>التحديثات المنتظرة</h3><label><input type="checkbox" name="StopOnError" value="true" checked /> ايقاف عند اول خطأ</label><input name="ReleaseNo" placeholder="Release No" /><input name="ConfirmText" placeholder="اكتب APPLY للتأكيد" /><button class="dbm-btn dbm-danger" data-confirm-apply>Apply Selected</button></div>
            <div class="dbm-table-wrap"><table class="dbm-table"><thead><tr><th><input type="checkbox" data-select-all /></th><th>No</th><th>Script</th><th>Module</th><th>Path</th><th>Hash</th><th>File Date</th><th>Type</th><th>Safe</th><th>Dependencies</th><th>Status</th><th>Preview</th></tr></thead><tbody>
            @foreach (var item in Model.Pending.Concat(Model.HashMismatches)) {
                <tr class="@(item.HasHashMismatch ? "dbm-danger-row" : "")"><td>@if(!item.HasHashMismatch){<input type="checkbox" name="ScriptKeys" value="@item.ScriptKey" />}</td><td>@(item.MigrationNumber.HasValue ? item.MigrationNumber.Value.ToString("0000") : "-")</td><td>@item.ScriptName</td><td>@item.ModuleName</td><td class="dbm-path">@item.ScriptPath</td><td class="dbm-hash">@item.ScriptHash</td><td>@item.LastModifiedOn.ToString("yyyy-MM-dd HH:mm", inv)</td><td>@item.UpdateType</td><td>@(item.SafeToRerun ? "Yes" : "No")</td><td>@item.Dependencies</td><td>@(item.HasHashMismatch ? "Hash mismatch" : item.ValidationStatus)</td><td><a href="@Url.Action("PreviewScript", "DatabaseMigration", new { area = "MainErp", id = item.ScriptKey })">Preview</a></td></tr>
            }
            </tbody></table></div>
        }
        @using (Html.BeginForm("ApplyAll", "DatabaseMigration", new { area = "MainErp" }, FormMethod.Post, new { @class = "dbm-apply-all" })) { @Html.AntiForgeryToken()<input type="hidden" name="StopOnError" value="true" /><input name="ReleaseNo" placeholder="Release No" /><input name="ConfirmText" placeholder="اكتب APPLY للتأكيد" /><button class="dbm-btn dbm-danger" data-confirm-apply>Apply All Pending</button> }
    </section>
    <section class="dbm-tab-panel" data-tab-panel="history"><div class="dbm-table-wrap"><table class="dbm-table"><thead><tr><th>ScriptName</th><th>ModuleName</th><th>AppliedOn</th><th>AppliedBy</th><th>MachineName</th><th>DatabaseName</th><th>DurationMs</th><th>Success</th><th>ErrorMessage</th><th>ScriptHash</th></tr></thead><tbody>@foreach (var h in Model.AppliedHistory) { <tr><td>@h.ScriptName</td><td>@h.ModuleName</td><td>@h.AppliedOn.ToString("yyyy-MM-dd HH:mm:ss", inv)</td><td>@h.AppliedBy</td><td>@h.MachineName</td><td>@h.DatabaseName</td><td>@h.DurationMs</td><td>@h.Success</td><td>@h.ErrorMessage</td><td class="dbm-hash">@h.ScriptHash</td></tr> }</tbody></table></div></section>
    <section class="dbm-tab-panel" data-tab-panel="failed"><div class="dbm-table-wrap"><table class="dbm-table"><thead><tr><th>ScriptName</th><th>ModuleName</th><th>AppliedOn</th><th>AppliedBy</th><th>DurationMs</th><th>ErrorMessage</th><th>ScriptHash</th></tr></thead><tbody>@foreach (var h in Model.FailedHistory) { <tr class="dbm-danger-row"><td>@h.ScriptName</td><td>@h.ModuleName</td><td>@h.AppliedOn.ToString("yyyy-MM-dd HH:mm:ss", inv)</td><td>@h.AppliedBy</td><td>@h.DurationMs</td><td>@h.ErrorMessage</td><td class="dbm-hash">@h.ScriptHash</td></tr> }</tbody></table></div></section>
    <section class="dbm-tab-panel" data-tab-panel="settings"><div class="dbm-table-wrap"><table class="dbm-table"><thead><tr><th>Configured folder</th><th>Resolved folder</th><th>Exists</th><th>SQL files</th></tr></thead><tbody>@foreach (var s in Model.Sources) { <tr><td>@s.ConfiguredPath</td><td class="dbm-path">@s.ResolvedPath</td><td>@s.Exists</td><td>@s.SqlFileCount</td></tr> }</tbody></table></div><div class="dbm-alert">مصادر السكريبتات للقراءة فقط من Web.config.</div></section>
    <section class="dbm-tab-panel" data-tab-panel="log"><div class="dbm-table-wrap"><table class="dbm-table"><thead><tr><th>RunId</th><th>StartedAt</th><th>FinishedAt</th><th>StartedBy</th><th>Database</th><th>Server</th><th>Mode</th><th>Status</th><th>Total</th><th>Applied</th><th>Failed</th><th>Warnings</th><th>Script results</th></tr></thead><tbody>@foreach (var r in Model.Runs) { <tr><td>@r.RunId</td><td>@r.StartedAt.ToString("yyyy-MM-dd HH:mm:ss", inv)</td><td>@(r.FinishedAt.HasValue ? r.FinishedAt.Value.ToString("yyyy-MM-dd HH:mm:ss", inv) : "-")</td><td>@r.StartedBy</td><td>@r.DatabaseName</td><td>@r.ServerName</td><td>@r.Mode</td><td>@r.Status</td><td>@r.TotalScripts</td><td>@r.AppliedCount</td><td>@r.FailedCount</td><td>@r.WarningCount</td><td>@foreach (var d in r.Details) { <span class="dbm-chip">@d.ScriptName - @d.Status</span> }</td></tr> }</tbody></table></div></section>
</section>
@section scripts { <script>(function(){var root=document.querySelector(".dbm-page");if(!root)return;root.querySelectorAll("[data-dbm-tabs] button").forEach(function(b){b.onclick=function(){var t=b.getAttribute("data-tab");root.querySelectorAll("[data-dbm-tabs] button").forEach(function(x){x.classList.remove("is-active")});root.querySelectorAll("[data-tab-panel]").forEach(function(x){x.classList.remove("is-active")});b.classList.add("is-active");root.querySelector('[data-tab-panel="'+t+'"]').classList.add("is-active")}});root.querySelectorAll("[data-select-all]").forEach(function(c){c.onchange=function(){root.querySelectorAll('input[name="ScriptKeys"]').forEach(function(x){x.checked=c.checked})}});root.querySelectorAll("[data-confirm-apply]").forEach(function(b){b.onclick=function(e){var f=b.closest("form"),i=f.querySelector('input[name="ConfirmText"]');if(!i||i.value!=="APPLY"){e.preventDefault();alert("يجب كتابة APPLY للتأكيد.");return}if(!confirm("سيتم تطبيق تحديثات على قاعدة البيانات. تأكد من وجود Backup."))e.preventDefault()}});var s=root.querySelector("[data-dbm-search]");if(s)s.oninput=function(){var q=s.value.toLowerCase();root.querySelectorAll(".dbm-table tbody tr").forEach(function(r){r.style.display=r.innerText.toLowerCase().indexOf(q)>=0?"":"none"})}})();</script> }
