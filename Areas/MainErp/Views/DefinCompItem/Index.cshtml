@model MyERP.Areas.MainErp.ViewModels.DefinCompItem.DefinCompItemIndexViewModel
@{
    Layout = "~/Areas/MainErp/Views/Shared/_MainErpLayout.cshtml";
    ViewBag.Title = "سند التجميع";

    var canAdd = Model != null && Model.Permissions != null && Model.Permissions.CanAdd;
    var canEdit = Model != null && Model.Permissions != null && Model.Permissions.CanEdit;
    var canDelete = Model != null && Model.Permissions != null && Model.Permissions.CanDelete;
    var canPrint = Model != null && Model.Permissions != null && Model.Permissions.CanPrint;
    var selected = Model.Selected ?? new MyERP.Areas.MainErp.ViewModels.DefinCompItem.DefinCompItemDetailsViewModel();

    var outputGroups = (selected.OutputGroups != null && selected.OutputGroups.Count > 0)
        ? selected.OutputGroups
        : selected.Outputs.Select(o => new MyERP.Areas.MainErp.ViewModels.DefinCompItem.DefinCompItemOutputGroupViewModel
        {
            Id = o.Id,
            ItemId = o.ItemId,
            ItemCode = o.ItemCode,
            ItemName = o.ItemName,
            UnitId = o.UnitId,
            UnitName = o.UnitName,
            Qty = o.Qty,
            Cost = o.Cost,
            Price = o.Price,
            Total = o.Total,
            TransactionId4 = o.TransactionId4,
            NoteSerial14 = o.NoteSerial14,
            LineId = o.LineId,
            QtyBySmallUnit = o.QtyBySmallUnit,
            Remark = o.Remark,
            Components = new List<MyERP.Areas.MainErp.ViewModels.DefinCompItem.DefinCompItemComponentLineViewModel>()
        }).ToList();
}

<section class="main-erp-panel main-erp-premium-workspace defin-comp-item-page" dir="rtl" id="definCompPage"
         data-lookup-items-url="@Url.Action("LookupItems", "DefinCompItem", new { area = "MainErp" })"
         data-lookup-units-url="@Url.Action("LookupUnits", "DefinCompItem", new { area = "MainErp" })"
         data-save-url="@Url.Action("Save", "DefinCompItem", new { area = "MainErp" })"
         data-rebuild-url="@Url.Action("Rebuild", "DefinCompItem", new { area = "MainErp" })"
         data-delete-url="@Url.Action("Delete", "DefinCompItem", new { area = "MainErp" })"
         data-details-url="@Url.Action("Details", "DefinCompItem", new { area = "MainErp" })">

    <header class="main-erp-cockpit-header">
        <div>
            <span class="main-erp-kicker">سندات التشغيل</span>
            <h2>سند التجميع</h2>
            <p>إنشاء سند يجمع بين: صرف مكونات + إضافة أصناف مجمعة منتجة في نفس التاريخ.</p>
        </div>
        <div class="main-erp-header-actions">
            <button type="button" class="main-erp-inline-action" id="definCompNewBtn" @(canAdd ? "" : "disabled")>جديد</button>
            <button type="button" class="main-erp-inline-action" id="definCompSaveBtn" @((canAdd || canEdit) ? "" : "disabled")>حفظ</button>
            <button type="button" class="main-erp-inline-action is-secondary" id="definCompRebuildBtn" @(canEdit ? "" : "disabled")>إعادة إنشاء</button>
            <button type="button" class="main-erp-inline-action is-danger" id="definCompDeleteBtn" @(canDelete ? "" : "disabled")>حذف</button>
            @if (canPrint)
            {
                <button type="button" class="main-erp-inline-action is-secondary" id="definCompPrintBtn" disabled>طباعة</button>
            }
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(Model.Message))
    {
        <div class="main-erp-warning">@Model.Message</div>
    }

    @Html.AntiForgeryToken()

    <div id="definCompStatus" class="defin-comp-status" role="status" aria-live="polite" hidden></div>

    <div class="defin-comp-layout">
        <aside class="main-erp-premium-search defin-comp-search-card">
            <div class="main-erp-search-head">
                <span>الوصول السريع</span>
                <h3>سندات التجميع</h3>
            </div>
            <form method="get" action="@Url.Action("Index", "DefinCompItem", new { area = "MainErp" })" class="main-erp-filter-bar">
                <label>البحث
                    <input type="text" name="searchText" value="@Model.SearchText" placeholder="رقم السند / ملاحظات / منتج" />
                </label>
                <label>من التاريخ (ميلادي)
                    <input type="date" name="fromDate" value="@(Model.FromDate.HasValue ? Model.FromDate.Value.ToString("yyyy-MM-dd") : string.Empty)" />
                </label>
                <label>إلى التاريخ (ميلادي)
                    <input type="date" name="toDate" value="@(Model.ToDate.HasValue ? Model.ToDate.Value.ToString("yyyy-MM-dd") : string.Empty)" />
                </label>
                <label>الفرع
                    <select name="branchId">
                        <option value="">الكل</option>
                        @foreach (var branch in Model.Branches)
                        {
                            <option value="@branch.Id" @(Model.BranchId.HasValue && Model.BranchId.Value.ToString() == branch.Id ? "selected" : string.Empty)>@branch.Text</option>
                        }
                    </select>
                </label>
                <label>المخزن
                    <select name="storeId">
                        <option value="">الكل</option>
                        @foreach (var store in Model.Stores)
                        {
                            <option value="@store.Id" @(Model.StoreId.HasValue && Model.StoreId.Value.ToString() == store.Id ? "selected" : string.Empty)>@store.Text</option>
                        }
                    </select>
                </label>
                <button type="submit">بحث</button>
            </form>

            <div class="main-erp-table-wrap defin-comp-results">
                <table class="main-erp-table">
                    <thead>
                        <tr>
                            <th>رقم السند</th>
                            <th>التاريخ</th>
                            <th>الفرع</th>
                            <th>المخزن</th>
                            <th>الإجمالي</th>
                            <th>الإجراء</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Results)
                        {
                            <tr data-id="@row.Id">
                                <td>@row.MaxNo</td>
                                <td>@(row.RecordDate.HasValue ? row.RecordDate.Value.ToString("yyyy-MM-dd") : string.Empty)</td>
                                <td>@row.BranchName</td>
                                <td>@row.StoreName</td>
                                <td>@String.Format("{0:n2}", row.TotalWithVat)</td>
                                <td><button type="button" class="main-erp-link-btn js-load-defin-item" data-id="@row.Id">تحميل</button></td>
                            </tr>
                        }
                        @if (Model.Results.Count == 0)
                        {
                            <tr>
                                <td colspan="6" class="main-erp-empty">لا توجد نتائج.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </aside>

        <main class="defin-comp-editor-stage">
            <section class="main-erp-premium-card">
                <div class="defin-comp-summary-grid">
                    <article class="defin-comp-summary-card">
                        <span>إجمالي تكلفة المكونات</span>
                        <strong id="componentCostTotal">@String.Format("{0:n2}", selected.ComponentCostTotal)</strong>
                        <small>ريال</small>
                    </article>
                    <article class="defin-comp-summary-card">
                        <span>إجمالي تكلفة المنتجات</span>
                        <strong id="outputCostTotal">@String.Format("{0:n2}", selected.OutputCostTotal)</strong>
                        <small>ريال</small>
                    </article>
                    <article class="defin-comp-summary-card">
                        <span>الفرق</span>
                        <strong id="differenceTotal">@String.Format("{0:n2}", selected.Difference)</strong>
                        <small>ريال</small>
                    </article>
                    <article class="defin-comp-summary-card">
                        <span>عدد الأصناف</span>
                        <strong id="itemsCountTotal">0</strong>
                        <small>منتج نهائي</small>
                    </article>
                    <article class="defin-comp-summary-card">
                        <span>عدد المكونات</span>
                        <strong id="componentCount">0</strong>
                        <small>مكون</small>
                    </article>
                </div>

                <div class="defin-comp-linked-strip">
                    <article class="defin-comp-linked-card issue">
                        <span>سند الصرف</span>
                        <strong id="linkedIssueId">@((selected.TransactionId1.HasValue && selected.TransactionId1.Value > 0) ? selected.TransactionId1.Value.ToString() : "—")</strong>
                        <small id="linkedIssueTotal">@String.Format("{0:n2}", selected.ComponentCostTotal)</small>
                    </article>
                    <article class="defin-comp-linked-card receipt">
                        <span>سند الإضافة</span>
                        <strong id="linkedReceiptId">@((selected.TransactionId2.HasValue && selected.TransactionId2.Value > 0) ? selected.TransactionId2.Value.ToString() : "—")</strong>
                        <small id="linkedReceiptTotal">@String.Format("{0:n2}", selected.OutputCostTotal)</small>
                    </article>
                </div>

                <div class="main-erp-form-grid defin-comp-form-grid">
                    <input type="hidden" id="definCompId" value="@selected.Id" />
                    <input type="hidden" id="definCompMode" value="@(selected.Id > 0 ? "E" : "N")" />
                    <input type="hidden" id="componentQtyTotal" value="0" />
                    <input type="hidden" id="outputQtyTotal" value="0" />

                    <label>رقم السند
                        <input type="text" id="maxNo" value="@selected.MaxNo" />
                    </label>
                    <label>تاريخ السند (ميلادي)
                        <input type="date" id="recordDate" value="@(selected.RecordDate.HasValue ? selected.RecordDate.Value.ToString("yyyy-MM-dd") : DateTime.Today.ToString("yyyy-MM-dd"))" />
                    </label>
                    <label>البيان
                        <input type="text" id="maxName" value="@selected.MaxName" placeholder="وصف مختصر" />
                    </label>
                    <label>ملاحظات
                        <input type="text" id="maxNameExtra" value="@selected.MaxName" />
                    </label>
                    <label>أمر الطلب
                        <input type="text" id="orderNo" value="@selected.OrderNo" />
                    </label>
                    <label>الفرع
                        <select id="branchId">
                            <option value="">اختر الفرع</option>
                            @foreach (var branch in Model.Branches)
                            {
                                <option value="@branch.Id" @(selected.BranchId.HasValue && selected.BranchId.Value.ToString() == branch.Id ? "selected" : string.Empty)>@branch.Text</option>
                            }
                        </select>
                    </label>
                    <label>المخزن
                        <select id="storeId">
                            <option value="">اختر المخزن</option>
                            @foreach (var store in Model.Stores)
                            {
                                <option value="@store.Id" @(selected.StoreId.HasValue && selected.StoreId.Value.ToString() == store.Id ? "selected" : string.Empty)>@store.Text</option>
                            }
                        </select>
                    </label>
                    <label>المخزن البديل 1
                        <select id="storeId2">
                            <option value="">—</option>
                            @foreach (var store in Model.Stores)
                            {
                                <option value="@store.Id" @(selected.StoreId2.HasValue && selected.StoreId2.Value.ToString() == store.Id ? "selected" : string.Empty)>@store.Text</option>
                            }
                        </select>
                    </label>
                    <label>المخزن البديل 2
                        <select id="storeId3">
                            <option value="">—</option>
                            @foreach (var store in Model.Stores)
                            {
                                <option value="@store.Id" @(selected.StoreId3.HasValue && selected.StoreId3.Value.ToString() == store.Id ? "selected" : string.Empty)>@store.Text</option>
                            }
                        </select>
                    </label>
                </div>

                <div class="defin-comp-hidden-fields">
                    <input type="hidden" id="cusId" value="@(selected.CusId.HasValue ? selected.CusId.Value.ToString() : string.Empty)" />
                    <input type="hidden" id="groupId" value="@(selected.GroupId.HasValue ? selected.GroupId.Value.ToString() : string.Empty)" />
                    <input type="hidden" id="paymentType" value="@(selected.PaymentType.HasValue ? selected.PaymentType.Value.ToString() : string.Empty)" />
                    <input type="hidden" id="empId" value="@(selected.EmpId.HasValue ? selected.EmpId.Value.ToString() : string.Empty)" />
                    <input type="hidden" id="boxId" value="@(selected.BoxId.HasValue ? selected.BoxId.Value.ToString() : string.Empty)" />
                    <input type="hidden" id="period" value="@(selected.Period.HasValue ? selected.Period.Value.ToString() : string.Empty)" />
                    <input type="hidden" id="qty1" value="@selected.Qty1" />
                    <input type="hidden" id="price" value="@selected.Price" />
                    <input type="hidden" id="totalAdd" value="@selected.TotalAdd" />
                    <input type="hidden" id="totalDisc" value="@selected.TotalDisc" />
                    <input type="hidden" id="net" value="@selected.Net" />
                    <input type="hidden" id="totalWithVat" value="@selected.TotalWithVat" />
                    <input type="hidden" id="vat2" value="@selected.Vat2" />
                </div>
            </section>

            <section class="main-erp-premium-card defin-comp-product-workflow">
                <div class="main-erp-section-header">
                    <h4>Workflow المنتج النهائي والمكونات</h4>
                    <span class="defin-comp-flow-badge">منتج نهائي ← مكونات ← تكلفة ← أثر مخزني</span>
                </div>
                <div class="defin-comp-product-cards" id="outputProductCards">
                    @if (outputGroups != null && outputGroups.Count > 0)
                    {
                        foreach (var product in outputGroups)
                        {
                            var components = product.Components ?? new List<MyERP.Areas.MainErp.ViewModels.DefinCompItem.DefinCompItemComponentLineViewModel>();
                            var componentCost = components.Sum(x => Convert.ToDecimal(x.Total.GetValueOrDefault()));
                            var outputTotal = Convert.ToDecimal(product.Total.GetValueOrDefault());
                            var productDiff = outputTotal - componentCost;
                            <article class="defin-comp-product-card" data-line-id="@(product.LineId.GetValueOrDefault(0))">
                                <header>
                                    <span>منتج نهائي</span>
                                    <strong>@(String.IsNullOrWhiteSpace(product.ItemName) ? "منتج غير محدد" : product.ItemName)</strong>
                                    <small>@product.ItemCode · @product.UnitName</small>
                                </header>
                                <div class="defin-comp-mini-flow">
                                    <b>خامات</b><i></i><b>تشغيل</b><i></i><b>إضافة مخزنية</b>
                                </div>
                                <dl>
                                    <dt>الكمية</dt><dd>@String.Format("{0:n2}", product.Qty)</dd>
                                    <dt>تكلفة المكونات</dt><dd>@componentCost.ToString("N2")</dd>
                                    <dt>تكلفة المنتج</dt><dd>@String.Format("{0:n2}", product.Total)</dd>
                                    <dt>فرق التكلفة</dt><dd class="@(Math.Abs(productDiff) > 0.01m ? "is-warning" : "is-ok")">@productDiff.ToString("N2")</dd>
                                </dl>
                                <details>
                                    <summary>مكونات المنتج (@components.Count)</summary>
                                    @if (components.Count == 0)
                                    {
                                        <p class="main-erp-empty">لا توجد مكونات مرتبطة بهذا المنتج.</p>
                                    }
                                    else
                                    {
                                        <ul>
                                            @foreach (var component in components)
                                            {
                                                <li><span>@component.ItemName</span><strong>@String.Format("{0:n2}", component.Qty) @component.UnitName</strong><b>@String.Format("{0:n2}", component.Total)</b></li>
                                            }
                                        </ul>
                                    }
                                </details>
                            </article>
                        }
                    }
                    else
                    {
                        <div class="main-erp-empty">أضف منتجاً نهائياً ليظهر تحليل التكلفة والمكونات هنا.</div>
                    }
                </div>
            </section>

            <section class="main-erp-premium-card">
                <div class="main-erp-section-header">
                    <h4>الأصناف النهائية</h4>
                    <button type="button" class="main-erp-inline-action is-secondary" id="addOutputRowBtn">إضافة صنف نهائي</button>
                </div>
                <div class="main-erp-table-wrap">
                    <table class="main-erp-table defin-comp-lines-table" id="outputsTable">
                        <thead>
                            <tr>
                                <th>الصنف المنتج</th>
                                <th>الوحدة</th>
                                <th>الكمية</th>
                                <th>تكلفة الوحدة</th>
                                <th>الإجمالي</th>
                                <th>ملاحظات</th>
                                <th>إجراء</th>
                            </tr>
                        </thead>
                        <tbody id="outputsTbody">
                            @if (outputGroups != null && outputGroups.Count > 0)
                            {
                                foreach (var row in outputGroups)
                                {
                                    <tr class="defin-comp-line defin-comp-output-row" data-kind="output" data-line-id="@(row.LineId.GetValueOrDefault(0))">
                                        <td><input type="text" class="item-text" value="@row.ItemName" data-item-id="@(row.ItemId.HasValue ? row.ItemId.Value.ToString() : string.Empty)" placeholder="اختر المنتج النهائي" /></td>
                                        <td>
                                            <select class="unit-id">
                                                <option value="">اختر الوحدة</option>
                                                @if (row.UnitId.HasValue)
                                                {
                                                    <option value="@row.UnitId.Value" selected="selected">@row.UnitName</option>
                                                }
                                            </select>
                                        </td>
                                        <td><input type="number" min="0.01" step="0.01" class="qty" value="@(row.Qty.HasValue ? row.Qty.Value.ToString("0.#####") : string.Empty)" /></td>
                                        <td><input type="number" step="0.01" class="line-cost" value="@(row.Cost.HasValue ? row.Cost.Value.ToString("0.#####") : "0")" readonly="readonly" /></td>
                                        <td><input type="number" step="0.01" class="line-total" value="@(row.Total.HasValue ? row.Total.Value.ToString("0.#####") : "0")" readonly="readonly" /></td>
                                        <td><input type="text" class="remark" value="@row.Remark" /></td>
                                        <td><button type="button" class="main-erp-link-btn js-remove-output">حذف</button></td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr class="defin-comp-empty-row"><td colspan="7">لا يوجد أصناف نهائية. أضف صنفاً أولاً.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>

            <section class="main-erp-premium-card">
                <div class="main-erp-section-header">
                    <h4>مكونات الصنف المختار: <span id="selectedOutputTitle">اختر صنفاً نهائياً لعرض المكونات</span></h4>
                    <button type="button" class="main-erp-inline-action is-secondary" id="addComponentRowBtn">إضافة مكون</button>
                </div>
                <div class="main-erp-table-wrap">
                    <table class="main-erp-table defin-comp-lines-table" id="componentsTable">
                        <thead>
                            <tr>
                                <th>الصنف</th>
                                <th>الوحدة</th>
                                <th>الكمية</th>
                                <th>التكلفة</th>
                                <th>الإجمالي</th>
                                <th>ملاحظات</th>
                                <th>إجراء</th>
                            </tr>
                        </thead>
                        <tbody id="componentsTbody">
                            @if (outputGroups != null && outputGroups.Count > 0)
                            {
                                foreach (var group in outputGroups)
                                {
                                    var components = group.Components ?? new List<MyERP.Areas.MainErp.ViewModels.DefinCompItem.DefinCompItemComponentLineViewModel>();
                                    var isFirst = true;
                                    foreach (var row in components)
                                    {
                                        var hidden = isFirst ? string.Empty : "is-hidden-row";
                                        isFirst = false;
                                        <tr class="defin-comp-line defin-comp-component-row @hidden" data-kind="component" data-line-id="@(row.LineId.GetValueOrDefault(group.LineId.GetValueOrDefault(0)))">
                                            <td><input type="text" class="item-text" value="@row.ItemName" data-item-id="@(row.ItemId.HasValue ? row.ItemId.Value.ToString() : string.Empty)" placeholder="اختر المكوّن" /></td>
                                            <td>
                                                <select class="unit-id">
                                                    <option value="">اختر الوحدة</option>
                                                    @if (row.UnitId.HasValue)
                                                    {
                                                        <option value="@row.UnitId.Value" selected="selected">@row.UnitName</option>
                                                    }
                                                </select>
                                            </td>
                                            <td><input type="number" min="0.01" step="0.01" class="qty" value="@(row.Qty.HasValue ? row.Qty.Value.ToString("0.#####") : string.Empty)" /></td>
                                            <td><input type="number" step="0.01" class="cost" value="@(row.Cost.HasValue ? row.Cost.Value.ToString("0.#####") : "0")" /></td>
                                            <td><input type="number" step="0.01" class="line-total" value="@(row.Total.HasValue ? row.Total.Value.ToString("0.#####") : "0")" readonly="readonly" /></td>
                                            <td><input type="text" class="remark" value="@row.Remark" /></td>
                                            <td><button type="button" class="main-erp-link-btn js-remove-line">حذف</button></td>
                                        </tr>
                                    }
                                }
                                if (!outputGroups.Any(g => g.Components != null && g.Components.Any()))
                                {
                                    <tr class="defin-comp-empty-row"><td colspan="7">اختر صنفاً نهائياً لعرض المكونات.</td></tr>
                                }
                            }
                            else
                            {
                                <tr class="defin-comp-empty-row"><td colspan="7">اختر صنفاً نهائياً لعرض المكونات.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>

            <section class="main-erp-premium-card">
                <div class="main-erp-section-header">
                    <h4>القيود والعمليات المرتبطة</h4>
                </div>
                <div class="main-erp-table-wrap">
                    <table class="main-erp-table">
                        <thead>
                            <tr>
                                <th>نوع القيود</th>
                                <th>رقم القيد</th>
                                <th>التاريخ</th>
                                <th>الإجمالي</th>
                                <th>مرجع</th>
                            </tr>
                        </thead>
                        <tbody id="linkedTransactionsBody">
                            @if (selected.LinkedTransactions == null || selected.LinkedTransactions.Count == 0)
                            {
                                <tr><td colspan="5" class="main-erp-empty">لا يوجد قيود مرتبطة.</td></tr>
                            }
                            else
                            {
                                foreach (var tx in selected.LinkedTransactions)
                                {
                                    <tr>
                                        <td>@tx.TransactionType</td>
                                        <td>@tx.TransactionId</td>
                                        <td>@(tx.TransactionDate.HasValue ? tx.TransactionDate.Value.ToString("yyyy-MM-dd") : string.Empty)</td>
                                        <td>@String.Format("{0:n2}", tx.Total)</td>
                                        <td>@tx.NoteSerial1</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        </main>
    </div>

    <template id="outputLineTemplate">
        <tr class="defin-comp-line defin-comp-output-row" data-kind="output" data-line-id="0">
            <td><input type="text" class="item-text" data-item-id="" placeholder="اختر المنتج النهائي" /></td>
            <td><select class="unit-id"><option value="">اختر الوحدة</option></select></td>
            <td><input type="number" min="0.01" step="0.01" class="qty" value="1" /></td>
            <td><input type="number" step="0.01" class="line-cost" value="0" readonly="readonly" /></td>
            <td><input type="number" step="0.01" class="line-total" value="0" readonly="readonly" /></td>
            <td><input type="text" class="remark" value="" /></td>
            <td><button type="button" class="main-erp-link-btn js-remove-output">حذف</button></td>
        </tr>
    </template>

    <template id="componentLineTemplate">
        <tr class="defin-comp-line defin-comp-component-row" data-kind="component" data-line-id="0">
