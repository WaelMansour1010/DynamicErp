@model MyERP.Areas.MainErp.ViewModels.Items.ItemsIndexViewModel
@using System.Linq
@using System.Web.Routing
@{
    Layout = "~/Areas/MainErp/Views/Shared/_MainErpLayout.cshtml";
    ViewBag.Title = "الأصناف";
    var canAdd = Model != null && Model.Permissions != null && Model.Permissions.CanAdd;
    var canEdit = Model != null && Model.Permissions != null && Model.Permissions.CanEdit;
    var canDelete = Model != null && Model.Permissions != null && Model.Permissions.CanDelete;
    var selected = Model.Selected ?? new MyERP.Areas.MainErp.ViewModels.Items.ItemDetailsViewModel();
    var isPosHosted = Model != null && Model.IsPosHosted;
    var itemRoute = new RouteValueDictionary { { "area", "MainErp" } };
    if (isPosHosted)
    {
        itemRoute["fromPos"] = "1";
        itemRoute["host"] = "pos";
    }
    var posRouteInfo = isPosHosted ? "1" : "0";
}

<link href="~/Areas/MainErp/Content/items.css?v=20260518-pos-items" rel="stylesheet" />

<section class="main-erp-panel items-page" dir="rtl" id="itemsPage"
         data-pos-hosted="@posRouteInfo"
         data-save-url="@Url.Action("Save", "Items", itemRoute)"
         data-details-url="@Url.Action("Details", "Items", itemRoute)"
         data-image-url="@Url.Action("Image", "Items", itemRoute)"
         data-delete-url="@Url.Action("Delete", "Items", itemRoute)"
         data-group-details-url="@Url.Action("GroupDetails", "Items", itemRoute)"
         data-group-save-url="@Url.Action("SaveGroup", "Items", itemRoute)"
         data-group-delete-url="@Url.Action("DeleteGroup", "Items", itemRoute)">
    <header class="main-erp-cockpit-header">
        <div>
            <span class="main-erp-kicker">بطاقة الصنف</span>
            <h2>الأصناف</h2>
            <p>بيانات الصنف الأساسية والبيانات الأخرى ووحدات الصنف في واجهة تشغيلية منظمة للبحث والحفظ والمراجعة.</p>
        </div>
        <div class="main-erp-header-actions">
            <button type="button" class="main-erp-inline-action" id="itemNewBtn" @(canAdd ? "" : "disabled")><i class="fas fa-plus"></i> جديد</button>
            <button type="button" class="main-erp-inline-action" id="itemSaveBtn" @((canAdd || canEdit) ? "" : "disabled")><i class="fas fa-save"></i> حفظ</button>
            <button type="button" class="main-erp-inline-action is-danger" id="itemDeleteBtn" @(canDelete ? "" : "disabled")><i class="fas fa-trash"></i> حذف</button>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(Model.Message))
    {
        <div class="main-erp-warning">@Model.Message</div>
    }

    <div id="itemStatus" class="items-status" role="status" aria-live="polite" hidden></div>

    <section class="items-summary-strip" aria-label="Item summary">
        <article><span>الصنف الحالي</span><strong>@(String.IsNullOrWhiteSpace(selected.Name) ? "غير محدد" : selected.Name)</strong><small>@(String.IsNullOrWhiteSpace(selected.Code) ? "كود جديد" : selected.Code)</small></article>
        <article><span>المجموعة</span><strong>@(selected.GroupId.HasValue ? selected.GroupId.Value.ToString() : "-")</strong><small>تصنيف وتشجير</small></article>
        <article><span>الوحدات</span><strong>@selected.Units.Count</strong><small>وحدة / سعر / باركود</small></article>
        <article><span>السعر</span><strong>@String.Format("{0:n2}", selected.SalePrice)</strong><small>بيع افتراضي</small></article>
    </section>

    <div class="items-layout">
        <aside class="main-erp-premium-search items-search-card">
            <div class="main-erp-search-head">
                <span>الوصول السريع</span>
                <h3>بحث الأصناف</h3>
            </div>
            <form method="get" action="@Url.Action("Index", "Items", new { area = "MainErp" })" class="main-erp-filter-bar">
                <label>بحث
                    <input type="text" name="searchText" value="@Model.SearchText" placeholder="الكود / الاسم / الباركود" />
                </label>
                <label>المجموعة
                    <select name="groupId">
                        <option value="">الكل</option>
                        @foreach (var group in Model.Groups)
                        {
                            <option value="@group.Id" @(Model.GroupId.HasValue && Model.GroupId.Value.ToString() == group.Id ? "selected" : "")>@group.Text</option>
                        }
                    </select>
                </label>
                <button type="submit"><i class="fas fa-search"></i> بحث</button>
            </form>

            <div class="items-tree-card">
                <div class="items-tree-head">
                    <span>عرض شجري حسب المجموعة</span>
                    <a href="@Url.Action("Index", "Items", new { area = "MainErp", searchText = Model.SearchText })">كل الأصناف</a>
                </div>
                <div class="items-tree-list">
                    @foreach (var group in Model.GroupTree.Where(g => !g.ParentId.HasValue || !Model.GroupTree.Any(x => x.Id == g.ParentId.Value)))
                    {
                        var level1 = Model.GroupTree.Where(x => x.ParentId.HasValue && x.ParentId.Value == group.Id).ToList();
                        <a class="items-tree-row @(Model.GroupId.HasValue && Model.GroupId.Value == group.Id ? "active" : "")" style="--tree-level:0" href="@Url.Action("Index", "Items", new { area = "MainErp", groupId = group.Id, searchText = Model.SearchText })">
                            <span class="items-tree-name">@group.Name</span>
                            <span class="items-tree-count">@group.ItemsCount</span>
                        </a>
                        foreach (var child in level1)
                        {
                            var level2 = Model.GroupTree.Where(x => x.ParentId.HasValue && x.ParentId.Value == child.Id).ToList();
                            <a class="items-tree-row @(Model.GroupId.HasValue && Model.GroupId.Value == child.Id ? "active" : "")" style="--tree-level:1" href="@Url.Action("Index", "Items", new { area = "MainErp", groupId = child.Id, searchText = Model.SearchText })">
                                <span class="items-tree-name">@child.Name</span>
                                <span class="items-tree-count">@child.ItemsCount</span>
                            </a>
                            foreach (var grandChild in level2)
                            {
                                <a class="items-tree-row @(Model.GroupId.HasValue && Model.GroupId.Value == grandChild.Id ? "active" : "")" style="--tree-level:2" href="@Url.Action("Index", "Items", new { area = "MainErp", groupId = grandChild.Id, searchText = Model.SearchText })">
                                    <span class="items-tree-name">@grandChild.Name</span>
                                    <span class="items-tree-count">@grandChild.ItemsCount</span>
                                </a>
                            }
                        }
                    }
                </div>
            </div>

            <div class="main-erp-table-wrap items-results">
                <table class="main-erp-table">
                    <thead>
                        <tr>
                            <th>الكود</th>
                            <th>اسم الصنف</th>
                            <th>الوحدة</th>
                            <th>السعر</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Results)
                        {
                            <tr data-id="@row.Id">
                                <td>@row.Code</td>
                                <td>@row.Name</td>
                                <td>@row.DefaultUnitName</td>
                                <td>@String.Format("{0:n2}", row.SalePrice)</td>
                                <td><button type="button" class="main-erp-link-btn js-load-item" data-id="@row.Id">تحميل</button></td>
                            </tr>
                        }
                        @if (Model.Results.Count == 0)
                        {
                            <tr><td colspan="5" class="main-erp-empty">لا توجد نتائج.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </aside>

        <main class="items-editor-stage">
            <nav class="items-tabs" aria-label="Item sections">
                <button type="button" class="active" data-target="#itemMainSection">البيانات الأساسية</button>
                <button type="button" data-target="#itemUnitsSection">الوحدات والأسعار</button>
                <button type="button" data-target="#itemBarcodeSection">الباركود</button>
                <button type="button" data-target="#itemInventorySection">المخزون</button>
                <button type="button" data-target="#itemSalePurchaseSection">إعدادات البيع/الشراء</button>
                @if (isPosHosted)
                {
                    <button type="button" data-target="#itemPosCommissionSection">عمولات POS</button>
                }
                <button type="button" data-target="#itemNotesSection">ملاحظات/إضافي</button>
                <button type="button" data-target="#itemGroupsSection">المجموعات</button>
            </nav>

            <section class="main-erp-premium-card items-section" id="itemMainSection">
                <div class="erp-section-title"><h2>بيانات الصنف</h2></div>
                <div class="main-erp-form-grid items-form-grid">
                    <input type="hidden" id="itemId" value="@selected.Id" />
                    <label>كود الصنف
                        <input type="text" id="itemCode" value="@selected.Code" placeholder="يولد تلقائيا عند تركه فارغا" />
                    </label>
                    <label>اسم الصنف عربي
                        <input type="text" id="itemName" value="@selected.Name" required />
                    </label>
                    <label>اسم الصنف إنجليزي
                        <input type="text" id="itemNameEn" value="@selected.NameEn" />
                    </label>
                    <label>المجموعة
                        <select id="itemGroupId" required>
                            <option value="">اختر المجموعة</option>
                            @foreach (var group in Model.Groups)
                            {
                                <option value="@group.Id" @(selected.GroupId.HasValue && selected.GroupId.Value.ToString() == group.Id ? "selected" : "")>@group.Text</option>
                            }
                        </select>
                    </label>
                    <label>نوع الصنف
                        <select id="itemType" required>
                            <option value="">اختر النوع</option>
                            <option value="1" @(selected.ItemType == 1 ? "selected" : "")>مخزني</option>
                            <option value="2" @(selected.ItemType == 2 ? "selected" : "")>مجمع</option>
                            <option value="3" @(selected.ItemType == 3 ? "selected" : "")>خدمة</option>
                        </select>
                    </label>
                </div>
            </section>

            <section class="main-erp-premium-card items-section" id="itemUnitsSection">
                <div class="erp-section-title">
                    <h2>الوحدات والأسعار</h2>
                    <button type="button" class="main-erp-inline-action is-secondary" id="addUnitBtn"><i class="fas fa-plus"></i> وحدة</button>
                </div>
                <div class="items-price-grid" id="itemSalePurchaseSection">
                    <label>سعر الشراء
                        <input type="number" step="0.0001" min="0" id="purchasePrice" value="@selected.PurchasePrice" />
                    </label>
                    <label>سعر البيع
                        <input type="number" step="0.0001" min="0" id="salePrice" value="@selected.SalePrice" />
                    </label>
                    <label>سعر العميل
                        <input type="number" step="0.0001" min="0" id="customerPrice" value="@selected.CustomerPrice" />
                    </label>
                    <label>سعر التاجر
                        <input type="number" step="0.0001" min="0" id="dealerPrice" value="@selected.DealerPrice" />
                    </label>
                    <label>التكلفة
                        <input type="number" step="0.0001" min="0" id="costPrice" value="@selected.CostPrice" />
                    </label>
                </div>
                <div class="main-erp-table-wrap">
                    <table class="main-erp-table items-units-table">
                        <thead>
                            <tr>
                                <th>افتراضي</th>
                                <th>الوحدة</th>
                                <th>المعامل</th>
                                <th>سعر البيع</th>
                                <th>سعر الشراء</th>
                                <th>أقل سعر</th>
                                <th>باركود</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="itemUnitsBody">
                            @foreach (var unit in selected.Units)
                            {
                                <tr>
                                    <td><input type="radio" name="defaultUnit" class="unit-default" @(unit.IsDefault ? "checked" : "") /></td>
                                    <td>
                                        <select class="unit-id">
                                            <option value="">اختر</option>
                                            @foreach (var lookup in Model.Units)
                                            {
                                                <option value="@lookup.Id" @(unit.UnitId.HasValue && unit.UnitId.Value.ToString() == lookup.Id ? "selected" : "")>@lookup.Text</option>
                                            }
                                        </select>
                                    </td>
                                    <td><input type="number" step="0.0001" min="0.0001" class="unit-factor" value="@unit.UnitFactor" /></td>
                                    <td><input type="number" step="0.0001" min="0" class="unit-sale" value="@unit.SalePrice" /></td>
                                    <td><input type="number" step="0.0001" min="0" class="unit-purchase" value="@unit.PurchasePrice" /></td>
                                    <td><input type="number" step="0.0001" min="0" class="unit-min-sale" value="@unit.MinSellingPrice" /></td>
                                    <td><input type="text" class="unit-barcode" value="@unit.Barcode" /></td>
                                    <td><button type="button" class="main-erp-link-btn js-remove-unit">حذف</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>

            <section class="main-erp-premium-card items-section" id="itemOtherSection">
                <div class="erp-section-title"><h2>الباركود والمخزون والملاحظات</h2></div>
                <div class="main-erp-form-grid items-form-grid">
                    <label id="itemBarcodeSection">الباركود الرئيسي
                        <input type="text" id="itemBarcode" value="@selected.Barcode" />
                    </label>
                    <label>Part No
                        <input type="text" id="partNo" value="@selected.PartNo" />
                    </label>
                    <label>Catalog No
                        <input type="text" id="catalogNo" value="@selected.CatalogNo" />
                    </label>
                    <label>Factory No
                        <input type="text" id="factoryNo" value="@selected.FactoryNo" />
                    </label>
                    <label id="itemInventorySection">حد الطلب
                        <input type="number" step="1" min="0" id="requestLimit" value="@selected.RequestLimit" />
                    </label>
                    <label>أقل كمية
                        <input type="number" step="0.0001" min="0" id="minQty" value="@selected.MinQty" />
                    </label>
                    <label>أكبر كمية
                        <input type="number" step="0.0001" min="0" id="maxQty" value="@selected.MaxQty" />
                    </label>
                    <label>اسم مختصر
                        <input type="text" id="shortName" value="@selected.ShortName" />
                    </label>
                    <label>مكان التخزين
                        <input type="text" id="binLocation" value="@selected.BinLocation" />
                    </label>
                    <label class="items-check"><input type="checkbox" id="haveSerial" @(selected.HaveSerial ? "checked" : "") /> له سيريال</label>
                    <label class="items-check"><input type="checkbox" id="haveGuarantee" @(selected.HaveGuarantee ? "checked" : "") /> له ضمان</label>
                    <label>مدة الضمان
                        <input type="number" step="1" min="0" id="guaranteeValue" value="@selected.GuaranteeValue" />
                    </label>
                    <label>نوع الضمان
                        <select id="guaranteeType">
                            <option value="">بدون</option>
                            <option value="1" @(selected.GuaranteeType == 1 ? "selected" : "")>يوم</option>
                            <option value="2" @(selected.GuaranteeType == 2 ? "selected" : "")>شهر</option>
                            <option value="3" @(selected.GuaranteeType == 3 ? "selected" : "")>سنة</option>
                        </select>
                    </label>
                    <label class="items-wide" id="itemNotesSection">ملاحظات
                        <textarea id="itemNotes" rows="3">@selected.Notes</textarea>
                    </label>
                </div>
            </section>

            @if (isPosHosted)
            {
                <section class="main-erp-premium-card items-section items-pos-commission-section" id="itemPosCommissionSection">
                    <div class="erp-section-title">
                        <h2>افتراضات عمولات POS</h2>
                        <button type="button" class="main-erp-inline-action is-secondary" id="addCashRangeBtn"><i class="fas fa-plus"></i> نطاق عمولة</button>
                    </div>
                    <div class="items-pos-premium-grid">
                        <aside class="items-product-media-card">
                            <div class="items-product-image-frame">
                                <img id="itemImagePreview" alt="صورة الصنف" @(selected.HasImage && selected.Id > 0 ? "src=\"" + Url.Action("Image", "Items", new { area = "MainErp", id = selected.Id, fromPos = "1", host = "pos" }) + "\"" : "") />
                                <div class="items-image-placeholder" id="itemImagePlaceholder">
                                    <i class="fas fa-image"></i>
                                    <span>صورة المنتج</span>
                                </div>
                            </div>
                            <div class="items-product-media-copy">
                                <strong id="imageItemName">@(String.IsNullOrWhiteSpace(selected.Name) ? "صنف جديد" : selected.Name)</strong>
                                <small id="imageItemCode">@(String.IsNullOrWhiteSpace(selected.Code) ? "بدون كود" : selected.Code)</small>
                            </div>
                            <input type="file" id="itemImageFile" accept="image/*" hidden />
                            <input type="hidden" id="itemImageBase64" value="" />
                            <input type="hidden" id="removeItemImage" value="0" />
                            <div class="items-image-actions">
                                <button type="button" class="main-erp-inline-action is-secondary" id="changeItemImageBtn"><i class="fas fa-upload"></i> تغيير</button>
                                <button type="button" class="main-erp-inline-action is-danger" id="removeItemImageBtn"><i class="fas fa-trash"></i> حذف</button>
                            </div>
                        </aside>
                        <div class="items-pos-commission-workspace">
                            <section class="items-commission-panel">
                                <div class="items-panel-head"><span>القواعد الافتراضية</span><strong>البيع والشراء</strong></div>
                                <div class="items-commission-layout">
                                    <label>المورد الافتراضي للسطر
                                        <select id="defaultSupplierId">
                                            <option value="">بدون افتراضي</option>
                                            @foreach (var supplier in Model.Suppliers)
                                            {
                                                <option value="@supplier.Id" @(selected.DefaultSupplierId.HasValue && selected.DefaultSupplierId.Value.ToString() == supplier.Id ? "selected" : "")>@supplier.Text</option>
                                            }
                                        </select>
                                    </label>
                                    <label>نسبة عمولة البيع %<input type="number" step="0.01" min="0" id="percentVisa" value="@selected.PercentVisa" /></label>
                                    <label>أقل عمولة بيع<input type="number" step="0.01" min="0" id="minVisa" value="@selected.MinVisa" /></label>
                                    <label>أقصى عمولة بيع<input type="number" step="0.01" min="0" id="maxVisa" value="@selected.MaxVisa" /></label>
                                    <label>نسبة عمولة الشراء / Cash Out %<input type="number" step="0.01" min="0" id="percentVisaPur" value="@selected.PercentVisaPur" /></label>
                                    <label>أقل عمولة شراء<input type="number" step="0.01" min="0" id="minVisaPur" value="@selected.MinVisaPur" /></label>
                                    <label>أقصى عمولة شراء<input type="number" step="0.01" min="0" id="maxVisaPur" value="@selected.MaxVisaPur" /></label>
                                </div>
                            </section>
                            <section class="items-commission-panel">
                                <div class="items-panel-head"><span>تشغيل POS</span><strong>خصائص الصنف</strong></div>
                                <div class="items-toggle-grid">
                                    <label class="items-toggle-card"><input type="checkbox" id="chkLot" @(selected.ChkLot ? "checked" : "") /><span>خدمات كيشني</span><small>يعامل كخدمة تشغيل داخل POS</small></label>
                                    <label class="items-toggle-card"><input type="checkbox" id="otherItems" @(selected.OtherItems ? "checked" : "") /><span>أصناف أخرى</span><small>تصنيف خاص للفواتير السريعة</small></label>
                                    <label class="items-toggle-card"><input type="checkbox" id="installmentService" @(selected.InstallmentService ? "checked" : "") /><span>خدمة تقسيط</span><small>يرتبط بحسابات التقسيط</small></label>
                                    <label class="items-toggle-card"><input type="checkbox" id="trafficViolations" @(selected.TrafficViolations ? "checked" : "") /><span>مخالفات</span><small>خدمات المخالفات والمعاملات</small></label>
                                    <label class="items-toggle-card"><input type="checkbox" id="isNotShowAlarm" @(selected.IsNotShowAlarm ? "checked" : "") /><span>لا يظهر في التنبيهات</span><small>إخفاء الصنف من تنبيهات النظام</small></label>
                                    <label class="items-toggle-card"><input type="checkbox" id="isPriceIsPerview" @(selected.IsPriceIsPerview ? "checked" : "") /><span>العمولة نسبة</span><small>قراءة النطاق كسعر نسبي</small></label>
                                    <label class="items-toggle-card"><input type="checkbox" id="isPriceIsLenthW" @(selected.IsPriceIsLenthW ? "checked" : "") /><span>السعر حسب العرض والطول</span><small>نفس خيار شاشة VB6</small></label>
                                </div>
                            </section>
                            <section class="items-commission-panel items-range-panel">
                                <div class="items-panel-head"><span>tblItemsCash</span><strong>نطاقات العمولة حسب مبلغ الفاتورة</strong></div>
                                <div class="main-erp-table-wrap">
                                    <table class="main-erp-table items-ranges-table">
                                        <thead><tr><th>من</th><th>إلى</th><th>المبلغ / العمولة</th><th>التكلفة</th><th>Cash Back</th><th></th></tr></thead>
                                        <tbody id="cashRangesBody">
                                            @foreach (var range in selected.CashCommissionRanges)
                                            {
                                                <tr>
                                                    <td><input type="number" step="0.01" min="0" class="cash-from" value="@range.FromPrice" /></td>
                                                    <td><input type="number" step="0.01" min="0" class="cash-to" value="@range.ToPrice" /></td>
                                                    <td><input type="number" step="0.01" min="0" class="cash-price" value="@range.Price" /></td>
                                                    <td><input type="number" step="0.01" min="0" class="cash-cost" value="@range.Cost" /></td>
                                                    <td><input type="number" step="0.01" min="0" class="cash-back" value="@range.CashBack" /></td>
                                                    <td><button type="button" class="main-erp-link-btn js-remove-cash-range">حذف</button></td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </section>
                        </div>
                    </div>
                </section>
            }
            <section class="main-erp-premium-card items-section" id="itemGroupsSection">
                <div class="erp-section-title">
                    <h2>مجموعات الأصناف</h2>
                    <div>
                        <button type="button" class="main-erp-inline-action is-secondary" id="groupNewBtn"><i class="fas fa-plus"></i> مجموعة</button>
                        <button type="button" class="main-erp-inline-action" id="groupSaveBtn"><i class="fas fa-save"></i> حفظ المجموعة</button>
                        <button type="button" class="main-erp-inline-action is-danger" id="groupDeleteBtn"><i class="fas fa-trash"></i> حذف</button>
                    </div>
                </div>
                <div class="items-groups-layout">
                    <div class="main-erp-table-wrap">
                        <table class="main-erp-table items-groups-table">
                            <thead>
                                <tr>
                                    <th>الكود</th>
                                    <th>المجموعة</th>
                                    <th>الأب</th>
                                    <th>أصناف</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var group in Model.GroupTree)
                                {
                                    <tr data-id="@group.Id">
                                        <td>@group.Code</td>
                                        <td>@group.Name</td>
                                        <td>@group.ParentName</td>
                                        <td>@group.ItemsCount</td>
                                        <td><button type="button" class="main-erp-link-btn js-load-group" data-id="@group.Id">تحميل</button></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="items-group-editor">
                        <div class="main-erp-form-grid items-form-grid">
                            <input type="hidden" id="groupId" value="" />
                            <label>كود المجموعة
                                <input type="text" id="groupCode" placeholder="يولد من كود الأب عند تركه فارغا" />
                            </label>
                            <label>اسم المجموعة عربي
                                <input type="text" id="groupName" />
                            </label>
                            <label>اسم المجموعة إنجليزي
                                <input type="text" id="groupNameEn" />
                            </label>
                            <label>المجموعة الرئيسية
                                <select id="groupParentId">
                                    <option value="1">مجموعة الأصناف</option>
                                    @foreach (var group in Model.GroupTree)
                                    {
                                        <option value="@group.Id">@group.Code - @group.Name</option>
                                    }
                                </select>
                            </label>
                            <label>Fullcode
                                <input type="text" id="groupFullCode" />
                            </label>
                            <label class="items-check"><input type="checkbox" id="groupIsLast" /> مجموعة نهائية</label>
                            <label class="items-check"><input type="checkbox" id="groupIsMaterial" /> خامات</label>
                            <label class="items-check"><input type="checkbox" id="groupPos" /> ظهور تشغيلي</label>
                            <label class="items-check"><input type="checkbox" id="groupProducer" /> منتجة</label>
                            <label class="items-check"><input type="checkbox" id="groupAdditions" /> إضافات</label>
                            <label class="items-check"><input type="checkbox" id="groupHoldingMaterials" /> Holding Materials</label>
                            <label class="items-check"><input type="checkbox" id="groupSeparate" /> منفصلة</label>
                            <label class="items-check"><input type="checkbox" id="groupTransfer" /> تحويل</label>
                            <label class="items-check"><input type="checkbox" id="groupShowCover" /> إظهار الغلاف</label>
                            <label class="items-check"><input type="checkbox" id="groupTaxExempt" /> معفي ضريبيا</label>
                        </div>
                    </div>
                </div>
            </section>
        </main>
    </div>
</section>

<template id="unitRowTemplate">
    <tr>
        <td><input type="radio" name="defaultUnit" class="unit-default" /></td>
        <td>
            <select class="unit-id">
                <option value="">اختر</option>
                @foreach (var lookup in Model.Units)
                {
                    <option value="@lookup.Id">@lookup.Text</option>
                }
            </select>
        </td>
        <td><input type="number" step="0.0001" min="0.0001" class="unit-factor" value="1" /></td>
        <td><input type="number" step="0.0001" min="0" class="unit-sale" value="0" /></td>
        <td><input type="number" step="0.0001" min="0" class="unit-purchase" value="0" /></td>
        <td><input type="number" step="0.0001" min="0" class="unit-min-sale" value="0" /></td>
        <td><input type="text" class="unit-barcode" /></td>
        <td><button type="button" class="main-erp-link-btn js-remove-unit">حذف</button></td>
    </tr>
</template>

<template id="cashRangeRowTemplate">
    <tr>
        <td><input type="number" step="0.01" min="0" class="cash-from" value="0" /></td>
        <td><input type="number" step="0.01" min="0" class="cash-to" value="0" /></td>
        <td><input type="number" step="0.01" min="0" class="cash-price" value="0" /></td>
        <td><input type="number" step="0.01" min="0" class="cash-cost" value="0" /></td>
        <td><input type="number" step="0.01" min="0" class="cash-back" value="0" /></td>
        <td><button type="button" class="main-erp-link-btn js-remove-cash-range">حذف</button></td>
    </tr>
</template>

@section scripts {
    <script src="~/Areas/MainErp/Scripts/items.js?v=20260518-pos-items"></script>
}

