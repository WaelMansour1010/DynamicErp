@model MyERP.Areas.MainErp.ViewModels.LC.LCIndexViewModel
@using MyERP.Areas.MainErp.Infrastructure.Localization
@{
    Layout = "~/Areas/MainErp/Views/Shared/_MainErpLayout.cshtml";
    Func<string, string> T = MainErpLocalizationService.T;
    ViewBag.Title = T("LettersOfCredit");
    ViewBag.ActiveScreen = "lc";

    var d = Model.SelectedDetails;
    var readOnlyMessage = Convert.ToString(TempData["MainErpLcReadOnlyMessage"]);
    var canEditLc = ViewBag.CanEditLc == true;
    var canPostLc = ViewBag.CanPostLc == true;
    var canPostHeaderLc = ViewBag.CanPostHeaderLc == true;
    var canPostGridsLc = ViewBag.CanPostGridsLc == true;
    var canRebuildLc = ViewBag.CanRebuildLc == true;
    var canDeleteLc = ViewBag.CanDeleteLc == true;
    var canReportLc = ViewBag.CanReportLc == true;
    var totalDebit = 0m;
    var totalCredit = 0m;
    var affectedAccounts = new System.Collections.Generic.HashSet<string>();
    var missingAccounts = 0;
    var marginRows = 0;
    var openingBalanceType = T("NoRows");

    if (d != null)
    {
        foreach (var line in d.VoucherLines)
        {
            totalDebit += line.Debit;
            totalCredit += line.Credit;
            if (!string.IsNullOrWhiteSpace(line.AccountDisplay))
            {
                affectedAccounts.Add(line.AccountDisplay);
            }
        }

        foreach (var account in d.AccountLinks)
        {
            if (string.IsNullOrWhiteSpace(account.AccountDisplay) || !string.IsNullOrWhiteSpace(account.Warning))
            {
                missingAccounts++;
            }
        }

        foreach (var grid in d.GridSections)
        {
            marginRows += grid.Rows.Count;
        }

        openingBalanceType = !d.OpenBalanceType.HasValue
            ? T("NoRows")
            : d.OpenBalanceType.Value == 0 ? T("Debit") : d.OpenBalanceType.Value == 1 ? T("Credit") : T("NoRows");
    }
}

<section class="main-erp-premium-workspace main-erp-lc-screen">
    <aside class="main-erp-premium-search">
        <div class="main-erp-search-head">
            <span>@T("RealMigratedFromVb6")</span>
            <h3>@T("LettersOfCredit")</h3>
        </div>

        @using (Html.BeginForm("Index", "LC", FormMethod.Get, new { area = "MainErp", id = "lcSearchForm", @class = "main-erp-filter main-erp-filter-stacked" }))
        {
            <label><span>@T("LcNumber")</span><input name="searchText" value="@Model.SearchText" placeholder="LCNO / Name" /></label>
            <label>
                <span>@T("Bank")</span>
                @Html.DropDownList("bankId", new SelectList(Model.Banks, "Value", "Text", Model.BankId), "-- " + T("Bank") + " --")
            </label>
            <label>
                <span>@T("Supplier")</span>
                @Html.DropDownList("vendorId", new SelectList(Model.Vendors, "Value", "Text", Model.VendorId), "-- " + T("Supplier") + " --")
            </label>
            <label>
                <span>@T("Branch")</span>
                @Html.DropDownList("branchId", new SelectList(Model.Branches, "Value", "Text", Model.BranchId), "-- " + T("Branch") + " --")
            </label>
            <button type="submit">@T("Search")</button>
        }

        <div class="main-erp-result-rail">
            @if (Model.Items.Count == 0)
            {
                <div class="main-erp-empty">@T("NoRows")</div>
            }
            else
            {
                foreach (var item in Model.Items)
                {
                    var isSelected = Model.SelectedId == item.TblLCID;
                    <a class="main-erp-result-card @(isSelected ? "is-selected" : "")" href="@Url.Action("Open", "LC", new { area = "MainErp", id = item.TblLCID })">
                        <span class="main-erp-result-code">@item.LCNO</span>
                        <strong>@item.Name</strong>
                        <small>@item.BankName</small>
                        <b>@String.Format("{0:n2}", item.Value)</b>
                    </a>
                }
            }
        </div>
    </aside>

    <main class="main-erp-premium-stage">
        @if (TempData["MainErpSuccess"] != null)
        {
            <div class="main-erp-ok">@TempData["MainErpSuccess"]</div>
        }
        @if (TempData["MainErpWarning"] != null)
        {
            <div class="main-erp-warning">@TempData["MainErpWarning"]</div>
        }
        @if (!string.IsNullOrWhiteSpace(readOnlyMessage))
        {
            <div class="main-erp-warning">@readOnlyMessage</div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.Warning))
        {
            <div class="main-erp-warning">@Model.Warning</div>
        }
        @if (d != null)
        {
            foreach (var warning in d.Warnings)
            {
                <div class="main-erp-warning">@warning</div>
            }
        }

        @if (d == null)
        {
            <section class="main-erp-premium-empty">
                <h2>@T("LettersOfCredit")</h2>
                <p>@T("LcReadOnlyIntro")</p>
                <button type="submit" form="lcSearchForm">@T("Search")</button>
            </section>
        }
        else
        {
            <header class="main-erp-cockpit-header">
                <div>
                    <span class="main-erp-kicker">@T("LcScreen")</span>
                    <h2>@d.LCNO</h2>
                    <p>@d.VendorName · @d.BankName · @d.CurrencyName</p>
                </div>
                <div class="main-erp-header-actions">
                    <span class="main-erp-status-pill @(d.Locked == true || d.CloseDate.HasValue ? "is-closed" : "is-active")">
                        @(d.Locked == true || d.CloseDate.HasValue ? T("Closed") : T("Active"))
                    </span>
                    @if (canEditLc)
                    {
                        <a href="@Url.Action("New", "LC", new { area = "MainErp" })">@T("New")</a>
                    }
                    <a href="@Url.Action("Open", "LC", new { area = "MainErp", id = d.TblLCID })">@T("Open")</a>
                    <a href="@Url.Action("Edit", "LC", new { area = "MainErp", id = d.TblLCID })">تعديل / حفظ</a>
                    @if (canPostLc)
                    {
                        using (Html.BeginForm("CreateVoucher", "LC", new { area = "MainErp", id = d.TblLCID }, FormMethod.Post, new { style = "display:inline" }))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit" class="lc-post-action" data-confirm="سيتم إنشاء قيد فتح الاعتماد الفعلي إذا لم يكن موجودًا. هل تريد المتابعة؟">إنشاء قيد الفتح</button>
                        }
                        using (Html.BeginForm("CreateOpenExpenseVoucher", "LC", new { area = "MainErp", id = d.TblLCID }, FormMethod.Post, new { style = "display:inline" }))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit" class="lc-post-action" data-confirm="سيتم إنشاء قيد مصاريف فتح الاعتماد الفعلي إذا لم يكن موجودًا. هل تريد المتابعة؟">إنشاء قيد المصاريف</button>
                        }
                        using (Html.BeginForm("CloseLc", "LC", new { area = "MainErp", id = d.TblLCID }, FormMethod.Post, new { style = "display:inline" }))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit" class="lc-post-action" data-confirm="إغلاق الاعتماد سينشئ قيد الإغلاق ويعلّم الاعتماد كمغلق. هل تريد المتابعة؟">إغلاق الاعتماد</button>
                        }
                        using (Html.BeginForm("CreateOpeningBalanceVoucher", "LC", new { area = "MainErp", id = d.TblLCID }, FormMethod.Post, new { style = "display:inline" }))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit" class="lc-post-action" data-confirm="سيتم ترحيل الرصيد الافتتاحي على Notes1 و DOUBLE_ENTREY_VOUCHERS1. هل تريد المتابعة؟">ترحيل الرصيد الافتتاحي</button>
                        }
                        using (Html.BeginForm("CreateGridVouchers", "LC", new { area = "MainErp", id = d.TblLCID }, FormMethod.Post, new { style = "display:inline" }))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit" class="lc-post-action" data-confirm="سيتم إنشاء قيود جريدات الاعتماد الناقصة فقط بدون حذف أو إعادة بناء القيود الموجودة. هل تريد المتابعة؟">إنشاء قيود الجريدات</button>
                        }
                    }
                    else
                    {
                        <button type="button" class="lc-disabled-action">قيود الاعتماد غير متاحة لصلاحيتك</button>
                    }
                </div>
            </header>

            <section class="main-erp-summary-grid main-erp-sticky-summary">
                <article><span>@T("Value")</span><strong>@String.Format("{0:n2}", d.Value)</strong><small>@d.CurrencyName</small></article>
                <article><span>@T("MarginPayments")</span><strong>@marginRows</strong><small>@T("GeneratedAccountingRows")</small></article>
                <article><span>@T("OpeningBalance")</span><strong>@String.Format("{0:n2}", d.OpenBalance)</strong><small>@openingBalanceType</small></article>
                <article class="@(missingAccounts > 0 ? "is-warning" : "is-ok")"><span>@T("AccountHealth")</span><strong>@missingAccounts</strong><small>@T("MissingAccounts")</small></article>
                <article><span>@T("AccountingImpact")</span><strong>@d.VoucherLines.Count</strong><small>@T("GeneratedAccountingRows")</small></article>
                <article class="@((totalDebit - totalCredit) == 0 ? "is-ok" : "is-warning")"><span>@T("Difference")</span><strong>@String.Format("{0:n2}", totalDebit - totalCredit)</strong><small>@((totalDebit - totalCredit) == 0 ? T("Balanced") : T("Unbalanced"))</small></article>
            </section>

            <section class="lc-control-zone">
                <article class="lc-control-card is-rebuild">
                    <div>
                        <span>إعادة بناء القيود</span>
                        <strong>عملية محمية بتأكيد</strong>
                        <p>تحذف القيود الأساسية الحالية لهذا الاعتماد ثم تعيد إنشاء قيود الفتح والمصاريف والرصيد الافتتاحي حسب بيانات الاعتماد الحالية. قيود الجريدات لها زر مستقل ينشئ الناقص فقط ولا يعيد بناء الموجود.</p>
                    </div>
                    @using (Html.BeginForm("RebuildVouchers", "LC", new { area = "MainErp", id = d.TblLCID }, FormMethod.Post, new { @class = "lc-confirm-form" }))
                    {
                        @Html.AntiForgeryToken()
                        <input name="confirmationText" placeholder="@("REBUILD-LC-" + d.TblLCID)" autocomplete="off" />
                        <button type="submit" class="lc-danger-action" data-confirm="هذه العملية ستحذف وتعيد إنشاء قيود الاعتماد الأساسية. استخدمها فقط على قاعدة اختبار أو بعد مراجعة Audit.">إعادة بناء القيود</button>
                    }
                </article>
                <article class="lc-control-card is-rebuild">
                    <div>
                        <span>إعادة بناء قيود الجريدات</span>
                        <strong>لا يلمس قيود الهيدر الأساسية</strong>
                        <p>يحذف Notes والقيود المرتبطة بصفوف TBLLCHistory / TBLLCMargin / TBLLCMargin2 / tblLCOpenB فقط، ثم يعيد إنشاء قيود الجريدات حسب الصفوف الحالية. استخدمه بعد مراجعة Audit وعلى قاعدة اختبار.</p>
                    </div>
                    @using (Html.BeginForm("RebuildGridVouchers", "LC", new { area = "MainErp", id = d.TblLCID }, FormMethod.Post, new { @class = "lc-confirm-form" }))
                    {
                        @Html.AntiForgeryToken()
                        <input name="confirmationText" placeholder="@("REBUILD-LC-GRIDS-" + d.TblLCID)" autocomplete="off" />
                        <button type="submit" class="lc-danger-action" data-confirm="سيتم حذف وإعادة إنشاء قيود الجريدات فقط، بدون لمس قيود الهيدر الأساسية. هل تريد المتابعة؟">إعادة بناء قيود الجريدات</button>
                    }
                </article>
                <article class="lc-control-card is-delete">
                    <div>
                        <span>حذف الاعتماد</span>
                        <strong>حذف كامل محمي</strong>
                        <p>يحذف الاعتماد، الجريدات، Notes/Notes1، القيود العادية والافتتاحية، والحسابات المنشأة له. متاح الآن لأن Eng قاعدة اختبار.</p>
                    </div>
                    @using (Html.BeginForm("Delete", "LC", new { area = "MainErp", id = d.TblLCID }, FormMethod.Post, new { @class = "lc-confirm-form" }))
                    {
                        @Html.AntiForgeryToken()
                        <input name="confirmationText" placeholder="@("DELETE-LC-" + d.TblLCID)" autocomplete="off" />
                        <button type="submit" class="lc-danger-action" data-confirm="هذه العملية ستحذف الاعتماد والقيود والجريدات المرتبطة به نهائيًا من قاعدة الاختبار.">حذف الاعتماد</button>
                    }
                </article>
            </section>

            <div class="main-erp-tab-shell" data-main-erp-tabs>
                <nav class="main-erp-tab-rail">
                    <button type="button" class="is-active" data-tab-target="lc-basic">@T("LcHeader")</button>
                    <button type="button" data-tab-target="lc-accounts">@T("LcAccounts")</button>
                    <button type="button" data-tab-target="lc-accounting">@T("AccountingTimeline")</button>
                    <button type="button" data-tab-target="lc-margin">@T("MarginPayments")</button>
                    <button type="button" data-tab-target="lc-opening">@T("OpeningBalance")</button>
                    <button type="button" data-tab-target="lc-history">@T("OperationHistory")</button>
                    <button type="button" data-tab-target="lc-reports">@T("ReportsAndAttachments")</button>
                </nav>

                <section id="lc-basic" class="main-erp-tab-pane is-active">
                    <div class="main-erp-section-grid">
                        <article class="main-erp-premium-card">
                            <h4>@T("LcHeader")</h4>
                            <dl class="main-erp-rich-details">
                                <dt>@T("LcNumber")</dt><dd>@d.LCNO</dd>
                                <dt>@T("Supplier")</dt><dd>@d.VendorName</dd>
                                <dt>@T("Projects")</dt><dd>@d.ProjectName</dd>
                                <dt>@T("Branch")</dt><dd>@d.BranchID</dd>
                                <dt>@T("FromDate")</dt><dd>@String.Format("{0:yyyy-MM-dd}", d.FromDate)</dd>
                                <dt>@T("ToDate")</dt><dd>@String.Format("{0:yyyy-MM-dd}", d.ToDate)</dd>
                            </dl>
                        </article>
                        <article class="main-erp-premium-card">
                            <h4>@T("LcBankCurrencyValues")</h4>
                            <dl class="main-erp-rich-details">
                                <dt>@T("Bank")</dt><dd>@d.BankName</dd>
                                <dt>@T("Currency")</dt><dd>@d.CurrencyName</dd>
                                <dt>@T("Value")</dt><dd>@String.Format("{0:n2}", d.Value)</dd>
                                <dt>@T("Open")</dt><dd>@String.Format("{0:n2}", d.OpenValue)</dd>
                                <dt>@T("Date")</dt><dd>@String.Format("{0:yyyy-MM-dd}", d.ChequeDueDate)</dd>
                            </dl>
                        </article>
                    </div>
                    <article class="main-erp-premium-card">
                        <h4>@T("Description")</h4>
                        <p class="main-erp-notes-box">@d.Remarks</p>
                    </article>
                </section>

                <section id="lc-accounts" class="main-erp-tab-pane" hidden>
                    <div class="main-erp-account-map">
                        @foreach (var account in d.AccountLinks)
                        {
                            <article class="main-erp-account-card @(string.IsNullOrWhiteSpace(account.Warning) ? "is-ok" : "is-warning")">
                                <span>@account.Role</span>
                                <strong>@(string.IsNullOrWhiteSpace(account.AccountDisplay) ? T("AccountNotFound") : account.AccountDisplay)</strong>
                                <small>@T("ParentAccount"): @(string.IsNullOrWhiteSpace(account.ParentAccountDisplay) ? T("AccountNotFound") : account.ParentAccountDisplay)</small>
                                <p>@(string.IsNullOrWhiteSpace(account.Warning) ? T("MiniAccountPreview") : account.Warning)</p>
                            </article>
                        }
                    </div>
                </section>

                <section id="lc-accounting" class="main-erp-tab-pane" hidden>
                    <div class="main-erp-accounting-kpis">
                        <article><span>@T("Debit")</span><strong>@totalDebit.ToString("N2")</strong></article>
                        <article><span>@T("Credit")</span><strong>@totalCredit.ToString("N2")</strong></article>
                        <article><span>@T("AffectedAccounts")</span><strong>@affectedAccounts.Count</strong></article>
                        <article><span>@T("VoucherLines")</span><strong>@d.VoucherLines.Count</strong></article>
                    </div>
                    <div class="main-erp-voucher-timeline">
                        @if (d.LinkedNotes.Count == 0)
                        {
                            <div class="main-erp-empty">@T("NoRows")</div>
                        }
                        else
                        {
                            foreach (var note in d.LinkedNotes)
                            {
                                var noteDebit = 0m;
                                var noteCredit = 0m;
                                foreach (var line in d.VoucherLines)
                                {
                                    if (line.NoteId == note.NoteID)
                                    {
                                        noteDebit += line.Debit;
                                        noteCredit += line.Credit;
                                    }
                                }
                                <details class="main-erp-voucher-card">
                                    <summary>
                                        <span>@note.SourceTable</span>
                                        <strong>@note.NoteSerial</strong>
                                        <b class="@((noteDebit - noteCredit) == 0 ? "is-ok" : "is-warning")">@((noteDebit - noteCredit) == 0 ? T("Balanced") : T("Unbalanced"))</b>
                                        <a href="@Url.Action("DetailsByNote", "JournalEntries", new { area = "MainErp", noteId = note.NoteID })">@T("OpenVoucher")</a>
                                    </summary>
                                    <div class="main-erp-voucher-body">
                                        <div class="main-erp-voucher-totals">
                                            <span>@T("Date"): @String.Format("{0:yyyy-MM-dd}", note.NoteDate)</span>
                                            <span>@T("Debit"): @noteDebit.ToString("N2")</span>
                                            <span>@T("Credit"): @noteCredit.ToString("N2")</span>
                                            <span>@T("Difference"): @((noteDebit - noteCredit).ToString("N2"))</span>
                                        </div>
                                        <table class="main-erp-table">
                                            <thead><tr><th>@T("Account")</th><th>@T("Debit")</th><th>@T("Credit")</th><th>@T("Description")</th></tr></thead>
                                            <tbody>
                                                @foreach (var line in d.VoucherLines)
                                                {
                                                    if (line.NoteId == note.NoteID)
                                                    {
                                                        <tr>
                                                            <td>@(string.IsNullOrWhiteSpace(line.AccountDisplay) ? T("AccountNotFound") : line.AccountDisplay)</td>
                                                            <td>@line.Debit.ToString("N2")</td>
                                                            <td>@line.Credit.ToString("N2")</td>
                                                            <td>@line.Description</td>
                                                        </tr>
                                                    }
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </details>
                            }
                        }
                    </div>
                </section>

                <section id="lc-margin" class="main-erp-tab-pane" hidden>
                    <div class="main-erp-vb6-grid-shell main-erp-premium-grids">
                        @foreach (var grid in d.GridSections)
                        {
                            <article>
                                <header>
                                    <strong>@grid.Title</strong>
                                    <small>@grid.SourceTable</small>
                                </header>
                                <p class="main-erp-muted">@grid.Behavior</p>
                                @if (!string.IsNullOrWhiteSpace(grid.Warning))
                                {
                                    <div class="main-erp-warning">@grid.Warning</div>
                                }
                                <div class="main-erp-table-wrap">
                                    <table class="main-erp-table">
                                        <thead>
                                            <tr>
                                                @foreach (var column in grid.Columns)
                                                {
                                                    <th>@column</th>
                                                }
                                                <th>@T("Voucher")</th>
                                                @if (canDeleteLc)
                                                {
                                                    <th>إجراء آمن</th>
                                                }
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (grid.Rows.Count == 0)
                                            {
                                                <tr><td colspan="@(grid.Columns.Count + (canDeleteLc ? 2 : 1))">@T("NoRows")</td></tr>
                                            }
                                            else
                                            {
                                                foreach (var row in grid.Rows)
                                                {
                                                    <tr>
                                                        @foreach (var column in grid.Columns)
                                                        {
                                                            <td>@row.Values[column]</td>
                                                        }
                                                        <td>
                                                            @if (row.NoteId.HasValue)
                                                            {
                                                                <a href="@Url.Action("DetailsByNote", "JournalEntries", new { area = "MainErp", noteId = row.NoteId.Value })">@T("OpenVoucher")</a>
                                                            }
                                                            else
                                                            {
                                                                <span>@T("NoVisibleNoteId")</span>
                                                            }
                                                        </td>
                                                        @if (canDeleteLc)
                                                        {
                                                            <td>
                                                                @if (row.RowId.HasValue)
                                                                {
                                                                    using (Html.BeginForm("DeleteGridRow", "LC", new { area = "MainErp", id = d.TblLCID }, FormMethod.Post, new { @class = "lc-inline-delete-grid" }))
                                                                    {
                                                                        @Html.AntiForgeryToken()
                                                                        <input type="hidden" name="sourceTable" value="@grid.SourceTable" />
                                                                        <input type="hidden" name="rowId" value="@row.RowId.Value" />
                                                                        <input name="confirmationText" placeholder="@("DELETE-LC-GRID-" + d.TblLCID + "-" + grid.SourceTable + "-" + row.RowId.Value)" autocomplete="off" />
                                                                        <button type="submit" class="lc-danger-action lc-grid-delete-action" data-confirm="سيتم حذف هذا الصف فقط وتنظيف Notes والقيود المرتبطة به فقط. لن يتم لمس القيود الأساسية للاعتماد.">حذف الصف</button>
                                                                    }
                                                                }
                                                            </td>
                                                        }
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </article>
                        }
                    </div>
                </section>

                <section id="lc-opening" class="main-erp-tab-pane" hidden>
                    <div class="main-erp-section-grid">
                        <article class="main-erp-premium-card">
                            <h4>@T("OpeningBalance")</h4>
                            <div class="main-erp-big-number">@String.Format("{0:n2}", d.OpenBalance)</div>
                            <p>@openingBalanceType</p>
                        </article>
                        <article class="main-erp-premium-card">
                            <h4>@T("OpenVoucher")</h4>
                            <dl class="main-erp-rich-details">
                                <dt>NoteID</dt><dd>@d.NoteIDOpen</dd>
                                <dt>@T("NoteSerial")</dt><dd>@d.NoteSerialOpen</dd>
                                <dt>@T("Voucher")</dt><dd>@String.Format("{0:n0}", d.OpeningBalanceVoucherId)</dd>
                            </dl>
                        </article>
                    </div>
                </section>

                <section id="lc-history" class="main-erp-tab-pane" hidden>
                    <div class="main-erp-summary-grid">
                        <article><span>عمليات مسجلة</span><strong>@d.AuditEntries.Count</strong><small>Audit</small></article>
                        <article><span>@T("AccountingImpact")</span><strong>@d.LinkedNotes.Count @T("Note")</strong><small>@d.VoucherLines.Count @T("GeneratedAccountingRows")</small></article>
                        <article><span>@T("MarginPayments")</span><strong>@marginRows @T("Details")</strong><small>Grid rows</small></article>
                    </div>
                    <div class="main-erp-activity-feed">
                        @if (d.AuditEntries.Count == 0)
                        {
                            <article>
                                <span>Audit</span>
                                <strong>لا توجد عمليات مسجلة لهذا الاعتماد</strong>
                                <small>قد يكون جدول MainErp_AuditLog غير مطبق على قاعدة الاختبار الحالية.</small>
                            </article>
                        }
                        else
                        {
                            foreach (var audit in d.AuditEntries)
                            {
                                <article>
                                    <span>@audit.OperationName</span>
                                    <strong>@(!string.IsNullOrWhiteSpace(audit.Message) ? audit.Message : audit.EntityName + " #" + audit.EntityKey)</strong>
                                    <small>
                                        @String.Format("{0:yyyy-MM-dd HH:mm}", audit.CreatedAt)
                                        @if (!string.IsNullOrWhiteSpace(audit.UserName))
                                        {
                                            @: · @audit.UserName
                                        }
                                        else if (audit.UserId.HasValue)
                                        {
                                            @: · User @audit.UserId
                                        }
                                    </small>
                                    @if (!string.IsNullOrWhiteSpace(audit.BeforeSnapshot) || !string.IsNullOrWhiteSpace(audit.AfterSnapshot))
                                    {
                                        <details>
                                            <summary>Before / After</summary>
                                            @if (!string.IsNullOrWhiteSpace(audit.BeforeSnapshot))
                                            {
                                                <pre>@audit.BeforeSnapshot</pre>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(audit.AfterSnapshot))
                                            {
                                                <pre>@audit.AfterSnapshot</pre>
                                            }
                                        </details>
                                    }
                                </article>
                            }
                        }
                    </div>
                </section>

                <section id="lc-reports" class="main-erp-tab-pane" hidden>
                    <div class="main-erp-report-tiles">
                        @if (canReportLc)
                        {
                            <a href="@Url.Action("Report", "LC", new { area = "MainErp", id = d.TblLCID })"><span>@T("Reports")</span><strong>@T("LettersOfCredit")</strong><small>Web report - read only</small></a>
                        }
                        else
                        {
                            <a class="is-disabled"><span>@T("Reports")</span><strong>@T("LettersOfCredit")</strong><small>@T("DisabledReadOnlyMessage")</small></a>
                        }
                        <a class="is-disabled"><span>@T("ReportsAndAttachments")</span><strong>@T("PreviewVoucher")</strong><small>@T("WorkflowReadOnly")</small></a>
                    </div>
                </section>
            </div>
        }
    </main>
</section>

<script>
    (function () {
        var root = document.querySelector("[data-main-erp-tabs]");
        if (root) {
            var buttons = root.querySelectorAll("[data-tab-target]");
            for (var i = 0; i < buttons.length; i++) {
                buttons[i].addEventListener("click", function () {
                    for (var b = 0; b < buttons.length; b++) {
                        buttons[b].classList.remove("is-active");
                    }
                    var panes = root.querySelectorAll(".main-erp-tab-pane");
                    for (var p = 0; p < panes.length; p++) {
                        panes[p].hidden = true;
                        panes[p].classList.remove("is-active");
                    }
                    this.classList.add("is-active");
                    var target = document.getElementById(this.getAttribute("data-tab-target"));
                    if (target) {
                        target.hidden = false;
                        target.classList.add("is-active");
                    }
                });
            }
        }

        var disabledButtons = document.querySelectorAll(".main-erp-lc-screen .is-disabled-action");
        for (var i = 0; i < disabledButtons.length; i++) {
            disabledButtons[i].addEventListener("click", function () {
                alert("@T("DisabledReadOnlyMessage")");
            });
        }

        var postButtons = document.querySelectorAll(".main-erp-lc-screen .lc-post-action");
        for (var j = 0; j < postButtons.length; j++) {
            postButtons[j].addEventListener("click", function (event) {
                var message = this.getAttribute("data-confirm");
                if (message && !confirm(message)) {
                    event.preventDefault();
                }
            });
        }

        var dangerButtons = document.querySelectorAll(".main-erp-lc-screen .lc-danger-action");
        for (var d = 0; d < dangerButtons.length; d++) {
            dangerButtons[d].addEventListener("click", function (event) {
                var message = this.getAttribute("data-confirm");
                if (message && !confirm(message)) {
                    event.preventDefault();
                }
            });
        }
    })();
</script>
