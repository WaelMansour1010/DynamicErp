@model MyERP.Areas.MainErp.ViewModels.LC.LCDetailsViewModel
@using MyERP.Areas.MainErp.Infrastructure.Localization
@{
    Layout = "~/Areas/MainErp/Views/Shared/_MainErpLayout.cshtml";
    Func<string, string> T = MainErpLocalizationService.T;
    ViewBag.Title = "تقرير الاعتماد المستندي";

    var totalDebit = 0m;
    var totalCredit = 0m;
    foreach (var line in Model.VoucherLines)
    {
        totalDebit += line.Debit;
        totalCredit += line.Credit;
    }
}

<section class="main-erp-report-page lc-report-page">
    <header class="main-erp-cockpit-header">
        <div>
            <span class="main-erp-kicker">Web Report - Read Only</span>
            <h2>تقرير الاعتماد المستندي</h2>
            <p>@Model.LCNO - @Model.VendorName</p>
        </div>
        <div class="main-erp-header-actions">
            <a href="@Url.Action("Index", "LC", new { area = "MainErp", selectedId = Model.TblLCID })">رجوع للاعتماد</a>
            <button type="button" onclick="window.print()">طباعة</button>
        </div>
    </header>

    <section class="main-erp-summary-grid main-erp-sticky-summary">
        <article><span>رقم الاعتماد</span><strong>@Model.LCNO</strong><small>@Model.TblLCID</small></article>
        <article><span>البنك</span><strong>@Model.BankName</strong><small>@Model.CurrencyName</small></article>
        <article><span>القيمة</span><strong>@String.Format("{0:n2}", Model.Value)</strong><small>@Model.CurrencyName</small></article>
        <article><span>الرصيد الافتتاحي</span><strong>@String.Format("{0:n2}", Model.OpenBalance)</strong><small>Opening</small></article>
        <article class="@((totalDebit - totalCredit) == 0 ? "is-ok" : "is-warning")"><span>إجمالي القيود</span><strong>@totalDebit.ToString("N2") / @totalCredit.ToString("N2")</strong><small>فرق @((totalDebit - totalCredit).ToString("N2"))</small></article>
        <article><span>عدد القيود</span><strong>@Model.LinkedNotes.Count</strong><small>@Model.VoucherLines.Count سطر</small></article>
    </section>

    <div class="main-erp-section-grid">
        <article class="main-erp-premium-card">
            <h4>بيانات الاعتماد</h4>
            <dl class="main-erp-rich-details">
                <dt>المورد</dt><dd>@Model.VendorName</dd>
                <dt>الفرع</dt><dd>@Model.BranchID</dd>
                <dt>من تاريخ</dt><dd>@String.Format("{0:yyyy-MM-dd}", Model.FromDate)</dd>
                <dt>إلى تاريخ</dt><dd>@String.Format("{0:yyyy-MM-dd}", Model.ToDate)</dd>
                <dt>تاريخ الإغلاق</dt><dd>@String.Format("{0:yyyy-MM-dd}", Model.CloseDate)</dd>
                <dt>ملاحظات</dt><dd>@Model.Remarks</dd>
            </dl>
        </article>

        <article class="main-erp-premium-card">
            <h4>الحسابات المرتبطة</h4>
            <div class="main-erp-account-map">
                @foreach (var account in Model.AccountLinks)
                {
                    <article class="main-erp-account-card @(string.IsNullOrWhiteSpace(account.Warning) ? "is-ok" : "is-warning")">
                        <span>@account.Role</span>
                        <strong>@account.AccountDisplay</strong>
                        <small>@account.ParentAccountDisplay</small>
                    </article>
                }
            </div>
        </article>
    </div>

    <article class="main-erp-premium-card">
        <h4>ملخص القيود المحاسبية</h4>
        <table class="main-erp-table">
            <thead>
                <tr>
                    <th>المصدر</th>
                    <th>رقم القيد</th>
                    <th>التاريخ</th>
                    <th>القيمة</th>
                    <th>فتح</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var note in Model.LinkedNotes)
                {
                    <tr>
                        <td>@note.SourceTable</td>
                        <td>@note.NoteSerial</td>
                        <td>@String.Format("{0:yyyy-MM-dd}", note.NoteDate)</td>
                        <td>@String.Format("{0:n2}", note.NoteValue)</td>
                        <td><a href="@Url.Action("DetailsByNote", "JournalEntries", new { area = "MainErp", noteId = note.NoteID })">فتح القيد</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </article>
</section>
