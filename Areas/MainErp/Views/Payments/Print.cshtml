@model MyERP.Areas.MainErp.ViewModels.Payments.PaymentVoucherDetailsViewModel
@{
    Layout = null;
    var h = Model.Header;
    var title = h.ReportName;
    if (string.IsNullOrWhiteSpace(title)) { title = "سند"; }
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>@title @h.NoteSerial</title>
    <style>
        body{font-family:Tahoma,Arial,sans-serif;color:#111827;margin:24px}
        .print-shell{border:1px solid #111827;padding:22px}
        header{display:flex;justify-content:space-between;border-bottom:2px solid #111827;padding-bottom:14px;margin-bottom:18px}
        h1{font-size:24px;margin:0}.muted{color:#64748b}.grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin:16px 0}
        .box{border:1px solid #cbd5e1;padding:10px;min-height:54px}.box span{display:block;color:#64748b;font-size:12px}
        table{width:100%;border-collapse:collapse;margin-top:18px}th,td{border:1px solid #cbd5e1;padding:8px;text-align:right}th{background:#f1f5f9}
        .total{font-weight:bold}.signatures{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:54px}.sig{border-top:1px solid #111827;padding-top:8px;text-align:center}
        @@media print{button{display:none}body{margin:0}.print-shell{border:0}}
    </style>
</head>
<body>
    <button onclick="window.print()">طباعة</button>
    <section class="print-shell">
        <header><div><h1>@title</h1><div class="muted">@h.ReportName</div></div><div><strong>رقم: @h.NoteSerial</strong><br />@((h.NoteDate.HasValue ? h.NoteDate.Value.ToString("dd/MM/yyyy") : ""))</div></header>
        <div class="grid">
            <div class="box"><span>الطرف</span>@h.PartyDisplay</div>
            <div class="box"><span>حساب الطرف</span>@h.AccountDisplay</div>
            <div class="box"><span>الخزنة / البنك</span>@(string.IsNullOrWhiteSpace(h.CashboxDisplay) ? h.BankDisplay : h.CashboxDisplay)</div>
            <div class="box"><span>المبلغ</span>@h.Amount.ToString("N2")</div>
            <div class="box"><span>الضريبة</span>@h.Vat.ToString("N2")</div>
            <div class="box"><span>الإجمالي</span>@h.Total.ToString("N2")</div>
        </div>
        <div class="box"><span>البيان</span>@h.Remark</div>
        <table>
            <thead><tr><th>الحساب</th><th>مدين</th><th>دائن</th><th>البيان</th></tr></thead>
            <tbody>
            @foreach (var line in Model.AccountingEntries)
            {
                <tr><td>@line.AccountDisplay</td><td>@line.Debit.ToString("N2")</td><td>@line.Credit.ToString("N2")</td><td>@line.Description</td></tr>
            }
            <tr class="total"><td>الإجمالي</td><td>@Model.DebitTotal.ToString("N2")</td><td>@Model.CreditTotal.ToString("N2")</td><td></td></tr>
            </tbody>
        </table>
        <div class="signatures"><div class="sig">المستلم</div><div class="sig">المحاسب</div><div class="sig">الاعتماد</div></div>
    </section>
</body>
</html>
