@model MyERP.Areas.MainErp.ViewModels.ProjectExtracts.ProjectExtractDetailsViewModel
@{
    Layout = "~/Areas/MainErp/Views/Shared/_MainErpLayout.cshtml";
    ViewBag.Title = "مستخلص مشروع";
    var voucherBalanced = Math.Abs(Model.VoucherBalanceDifference) < 0.01m;
    Func<decimal?, string> money = v => String.Format("{0:n2}", v ?? 0m);
    Func<double?, string> moneyDouble = v => String.Format("{0:n2}", v ?? 0d);
    Func<decimal?, string> percent = v => String.Format("{0:n1}%", v ?? 0m);
    var completionPercent = Model.DetailLines.Count == 0
        ? Convert.ToDecimal(Math.Min(100d, Math.Abs(Model.Results.GetValueOrDefault())))
        : Math.Min(100m, Math.Max(0m, Model.DetailLines.Average(x => x.TotalPercent ?? x.CurrPercent ?? 0m)));
    var billedPercent = Model.Total.GetValueOrDefault() == 0 ? 0m : Math.Min(100m, Math.Round((Model.DetailFinalTotal / Model.Total.GetValueOrDefault()) * 100m, 1));
    var collectedPercent = Model.DetailFinalTotal == 0 ? 0m : Math.Min(100m, Math.Round((Model.AdvancePaidTotal / Model.DetailFinalTotal) * 100m, 1));
    var retentionTotal = Convert.ToDecimal(Model.PerformanceBond.GetValueOrDefault()) + Model.DetailLines.Sum(x => x.PerformanceLineDiscount ?? 0m);
    var netPayable = Convert.ToDecimal(Model.NetValue.GetValueOrDefault());
}

<section class="main-erp-panel project-extract-workspace" dir="rtl">
    <div class="main-erp-title-row">
        <div>
            <h3>مركز التحكم المالي للمستخلص</h3>
            <p>قراءة فعلية من `project_billl` و `project_bill_details` مع الدفعات المقدمة والقيود المحاسبية المرتبطة، بهدف مراجعة المستخلص ماليًا وتشغيليًا من شاشة واحدة.</p>
        </div>
        <div class="main-erp-actions">
            <a class="main-erp-button" href="@Url.Action("Report", "ProjectExtracts", new { area = "MainErp", id = Model.Id })">تقرير المستخلص</a>
            <a class="main-erp-button" href="@Url.Action("Index", "ProjectExtracts", new { area = "MainErp" })">رجوع للقائمة</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Warning))
    {
        <div class="main-erp-warning">@Model.Warning</div>
    }

    <section class="erp-project-dashboard">
        <div class="erp-project-hero">
            <span>Project Financial Dashboard</span>
            <h2>@(String.IsNullOrWhiteSpace(Model.ProjectName) ? "مستخلص غير محدد" : Model.ProjectName)</h2>
            <p>@Model.CustomerName · @Model.ProjectFullCode · @String.Format("{0:yyyy-MM-dd}", Model.BillDate)</p>
            <div class="erp-project-progress">
                <i style="width:@((int)Math.Min(100m, completionPercent))%"></i>
            </div>
        </div>
        <aside class="erp-side-summary">
            <h4>حالة المشروع خلال 5 ثوان</h4>
            <dl>
                <dt>قيمة المستخلص</dt><dd>@money(Model.Total)</dd>
                <dt>نسبة الإنجاز</dt><dd>@completionPercent.ToString("N1")%</dd>
                <dt>المفوتر فعليًا</dt><dd>@billedPercent.ToString("N1")%</dd>
                <dt>المحصل / الدفعات</dt><dd>@collectedPercent.ToString("N1")%</dd>
                <dt>المحتجزات</dt><dd>@retentionTotal.ToString("N2")</dd>
                <dt>صافي المستحق</dt><dd class="@(netPayable < 0 ? "is-danger" : "")">@netPayable.ToString("N2")</dd>
            </dl>
        </aside>
    </section>

    <section class="erp-insight-layout project-analytics-strip">
        <div class="erp-insight-main">
            <article class="erp-finance-meter">
                <span>المنفذ</span>
                <strong>@completionPercent.ToString("N1")%</strong>
                <div class="erp-meter is-success"><i style="width:@((int)Math.Min(100m, completionPercent))%"></i></div>
                <small>من نسب البنود الحالية/الإجمالية.</small>
            </article>
            <article class="erp-finance-meter">
                <span>المفوتر</span>
                <strong>@billedPercent.ToString("N1")%</strong>
                <div class="erp-meter"><i style="width:@((int)Math.Min(100m, billedPercent))%"></i></div>
                <small>صافي البنود النهائية إلى قيمة المستخلص.</small>
            </article>
            <article class="erp-finance-meter">
                <span>المحصل</span>
                <strong>@collectedPercent.ToString("N1")%</strong>
                <div class="erp-meter @(collectedPercent < 50m ? "is-warning" : "is-success")"><i style="width:@((int)Math.Min(100m, collectedPercent))%"></i></div>
                <small>@(collectedPercent < 50m ? "تنبيه متابعة تحصيل" : "تحصيل جيد")</small>
            </article>
        </div>
    </section>

    <div class="main-erp-cockpit-header">
        <div>
            <span class="main-erp-eyebrow">Project Extract</span>
            <h2>@(String.IsNullOrWhiteSpace(Model.ProjectName) ? "مستخلص غير محدد" : Model.ProjectName)</h2>
            <p>@Model.ProjectFullCode</p>
        </div>
        <div class="main-erp-status-stack">
            <span class="main-erp-badge">قراءة آمنة</span>
            <span class="main-erp-badge @(voucherBalanced ? "is-success" : "is-danger")">@(voucherBalanced ? "القيد متوازن" : "يوجد فرق قيود")</span>
        </div>
    </div>

    <div class="main-erp-kpi-grid">
        <div class="main-erp-kpi-card">
            <span>رقم المستخلص</span>
            <strong>@Model.Id</strong>
            <small>@Model.NoteSerial</small>
        </div>
        <div class="main-erp-kpi-card">
            <span>تاريخ المستخلص</span>
            <strong>@String.Format("{0:yyyy-MM-dd}", Model.BillDate)</strong>
            <small>@Model.ManualNo</small>
        </div>
        <div class="main-erp-kpi-card">
            <span>قيمة المستخلص</span>
            <strong>@String.Format("{0:n2}", Model.Total ?? 0m)</strong>
            <small>الصافي @moneyDouble(Model.NetValue)</small>
        </div>
        <div class="main-erp-kpi-card">
            <span>الضريبة</span>
            <strong>@moneyDouble(Model.VatValue)</strong>
            <small>قبل الضريبة @moneyDouble(Model.PreVat)</small>
        </div>
        <div class="main-erp-kpi-card">
            <span>بنود التنفيذ</span>
            <strong>@Model.DetailLineCount</strong>
            <small>إجمالي الحالي @money(Model.DetailCurrentValueTotal)</small>
        </div>
        <div class="main-erp-kpi-card">
            <span>الدفعات المقدمة</span>
            <strong>@Model.AdvancePayments.Count</strong>
            <small>مسدد @money(Model.AdvancePaidTotal)</small>
        </div>
    </div>

    <section class="erp-workflow-strip project-extract-approval-flow" aria-label="Project extract approval flow">
        <article class="is-done"><span>1</span><strong>بيانات المستخلص</strong></article>
        <article class="@(Model.DetailLines.Count > 0 ? "is-done" : "is-current")"><span>2</span><strong>بنود التنفيذ</strong></article>
        <article class="@(Model.DetailLines.Count > 0 ? "is-done" : "")"><span>3</span><strong>الخصومات والضريبة</strong></article>
        <article class="@(voucherBalanced ? "is-done" : "is-current")"><span>4</span><strong>مراجعة القيد</strong></article>
        <article class="@(voucherBalanced && Model.NoteId.HasValue ? "is-done" : "")"><span>5</span><strong>اعتماد/تقرير</strong></article>
        <article><span>6</span><strong>إقفال تشغيلي</strong></article>
    </section>

    <section class="main-erp-tabs">
        <h4>&#1578;&#1578;&#1576;&#1593; &#1605;&#1575;&#1604;&#1610; &#1604;&#1604;&#1605;&#1587;&#1578;&#1582;&#1604;&#1589;</h4>
        <div class="main-erp-kpi-grid">
            <div class="main-erp-kpi-card"><span>Source document</span><strong>Project Extract @Model.Id</strong><small>Note @Model.NoteId / @Model.NoteSerial</small></div>
            <div class="main-erp-kpi-card"><span>Customer / project</span><strong>@Model.CustomerName</strong><small>@Model.ProjectName</small></div>
            <div class="main-erp-kpi-card"><span>Accounting effect</span><strong>@Model.VoucherLines.Count lines</strong><small>Dr @money(Model.VoucherDebitTotal) / Cr @money(Model.VoucherCreditTotal)</small></div>
            <div class="main-erp-kpi-card"><span>Review status</span><strong>@(voucherBalanced ? "Balanced" : "Needs finance review")</strong><small>Diff @money(Model.VoucherBalanceDifference)</small></div>
        </div>
        <p class="main-erp-muted">This trace keeps the financial reviewer on one path: extract header, line details, deductions/VAT/retention, advance payments, and the linked accounting voucher.</p>
    </section>

    <div class="main-erp-tabs premium-tabs">
        <section>
            <h4>ملخص المستخلص</h4>
            <div class="main-erp-two-column">
                <dl class="main-erp-details">
                    <dt>العميل / الطرف</dt><dd>@Model.CustomerName</dd>
                    <dt>الفرع</dt><dd>@Model.BranchNo</dd>
                    <dt>NoteID</dt><dd>@Model.NoteId</dd>
                    <dt>الإجمالي</dt><dd>@String.Format("{0:n2}", Model.Total ?? 0m)</dd>
                    <dt>النتيجة</dt><dd>@moneyDouble(Model.Results)</dd>
                    <dt>الصافي</dt><dd>@moneyDouble(Model.NetValue)</dd>
                    <dt>استقطاع ضمان الأعمال</dt><dd>@moneyDouble(Model.PerformanceBond)</dd>
                    <dt>دفعة مقدمة</dt><dd>@moneyDouble(Model.AdvancedPayment)</dd>
                </dl>
                <dl class="main-erp-details">
                    <dt>حساب الإيراد</dt><dd>@Model.RevenueAccount</dd>
                    <dt>حساب تحت التنفيذ</dt><dd>@Model.AccountUnderImplementation</dd>
                    <dt>حساب العميل النهائي</dt><dd>@Model.EndUserAccount</dd>
                    <dt>حساب مقاول الباطن</dt><dd>@Model.SubUserAccount</dd>
                    <dt>حساب الضريبة</dt><dd>@Model.VatAccountCode</dd>
                </dl>
            </div>
        </section>

        <section>
            <h4>بنود المستخلص</h4>
            <div class="main-erp-grid-toolbar">
                <span>عدد البنود: <strong>@Model.DetailLineCount</strong></span>
                <span>إجمالي الحالي: <strong>@money(Model.DetailCurrentValueTotal)</strong></span>
                <span>إجمالي الضريبة: <strong>@money(Model.DetailVatTotal)</strong></span>
                <span>الإجمالي النهائي: <strong>@money(Model.DetailFinalTotal)</strong></span>
            </div>

            @if (Model.DetailLines.Count == 0)
            {
                <div class="main-erp-empty">لا توجد بنود مسجلة لهذا المستخلص</div>
            }
            else
            {
                <div class="main-erp-table-wrap">
                    <table class="main-erp-table project-lines-table">
                        <thead>
                            <tr>
                                <th>البند</th>
                                <th>كود البند</th>
                                <th>الوحدة</th>
                                <th>الكمية الأصلية</th>
                                <th>السعر</th>
                                <th>التكلفة</th>
                                <th>السابق كمية</th>
                                <th>السابق قيمة</th>
                                <th>الحالي كمية</th>
                                <th>الحالي قيمة</th>
                                <th>الإجمالي كمية</th>
                                <th>الإجمالي قيمة</th>
                                <th>نسبة الإنجاز</th>
                                <th>الخصم</th>
                                <th>الصافي قبل الضريبة</th>
                                <th>الضريبة</th>
                                <th>الصافي شامل الضريبة</th>
                                <th>الاستقطاع</th>
                                <th>النهائي</th>
                                <th>الحساب</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var line in Model.DetailLines)
                            {
                                var progress = Math.Min(100m, Math.Max(0m, line.TotalPercent ?? line.CurrPercent ?? 0m));
                                <tr>
                                    <td class="main-erp-strong">@line.Item</td>
                                    <td>@line.FullCode</td>
                                    <td>@line.Unit</td>
                                    <td>@money(line.Quantity)</td>
                                    <td>@money(line.Price)</td>
                                    <td>@money(line.Cost)</td>
                                    <td>@money(line.PreQuantity)</td>
                                    <td>@money(line.PreValue)</td>
                                    <td>@money(line.CurrQuantity)</td>
                                    <td>@money(line.CurrValue)</td>
                                    <td>@money(line.TotalQuantity)</td>
                                    <td>@money(line.TotalValue)</td>
                                    <td>
                                        <span class="main-erp-percent-badge">@percent(line.TotalPercent ?? line.CurrPercent)</span>
                                        <span class="main-erp-mini-progress"><span style="width:@progress%"></span></span>
                                    </td>
                                    <td>@money(line.LineDiscount)</td>
                                    <td>@money(line.NetBeforeVat)</td>
                                    <td>@money(line.LineVat)</td>
                                    <td>@money(line.NetWithVat)</td>
                                    <td>@money(line.PerformanceLineDiscount)</td>
                                    <td class="main-erp-strong">@money(line.LineFinal)</td>
                                    <td>@(String.IsNullOrWhiteSpace(line.AccountDisplay) ? "لا يوجد حساب مرتبط" : line.AccountDisplay)</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="9">الإجماليات</td>
                                <td>@money(Model.DetailCurrentValueTotal)</td>
                                <td></td>
                                <td></td>
                                <td></td>
                                <td>@money(Model.DetailDiscountTotal)</td>
                                <td></td>
                                <td>@money(Model.DetailVatTotal)</td>
                                <td></td>
                                <td></td>
                                <td>@money(Model.DetailFinalTotal)</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
        </section>

        <section>
            <h4>الخصومات والضريبة</h4>
            <div class="main-erp-kpi-grid">
                <div class="main-erp-kpi-card"><span>خصومات البنود</span><strong>@money(Model.DetailDiscountTotal)</strong></div>
                <div class="main-erp-kpi-card"><span>ضريبة البنود</span><strong>@money(Model.DetailVatTotal)</strong></div>
                <div class="main-erp-kpi-card"><span>استقطاع البنود</span><strong>@money(Model.DetailLines.Sum(x => x.PerformanceLineDiscount ?? 0m))</strong></div>
                <div class="main-erp-kpi-card"><span>صافي البنود النهائي</span><strong>@money(Model.DetailFinalTotal)</strong></div>
            </div>
        </section>

        <section>
            <h4>الدفعات المقدمة</h4>
            @if (Model.AdvancePayments.Count == 0)
            {
                <div class="main-erp-empty">لا توجد دفعات مقدمة مرتبطة بهذا المستخلص</div>
            }
            else
            {
                <div class="main-erp-table-wrap">
                    <table class="main-erp-table">
                        <thead>
                            <tr>
                                <th>المصدر</th>
                                <th>NoteID / Transaction</th>
                                <th>السيريال</th>
                                <th>التاريخ</th>
                                <th>قيمة السند</th>
                                <th>المسدد</th>
                                <th>المتبقي</th>
                                <th>الصافي</th>
                                <th>الضريبة</th>
                                <th>TypeTrans</th>
                                <th>NCashingType</th>
                                <th>الفرع</th>
                                <th>الحساب</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var payment in Model.AdvancePayments)
                            {
                                <tr>
                                    <td>@payment.SourceTable</td>
                                    <td>@payment.NoteId / @payment.TransactionId</td>
                                    <td>@payment.NoteSerial</td>
                                    <td>@String.Format("{0:yyyy-MM-dd}", payment.NoteDate)</td>
                                    <td>@money(payment.NoteValue)</td>
                                    <td>@money(payment.PayedValue)</td>
                                    <td>@money(payment.RemainingValue)</td>
                                    <td>@money(payment.NetValue)</td>
                                    <td>@money(payment.Vat)</td>
                                    <td>@payment.TypeTrans</td>
                                    <td>@payment.NCashingType</td>
                                    <td>@payment.BranchName</td>
                                    <td>@payment.AccountDisplay</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>

        <section>
            <h4>القيود المحاسبية</h4>
            <div class="main-erp-grid-toolbar">
                <span>عدد السطور: <strong>@Model.VoucherLines.Count</strong></span>
                <span>إجمالي مدين: <strong>@money(Model.VoucherDebitTotal)</strong></span>
                <span>إجمالي دائن: <strong>@money(Model.VoucherCreditTotal)</strong></span>
                <span class="@(voucherBalanced ? "main-erp-ok" : "main-erp-danger")">الفرق: @money(Model.VoucherBalanceDifference)</span>
                @if (Model.NoteId.HasValue)
                {
                    <a class="main-erp-button" href="@Url.Action("DetailsByNote", "JournalEntries", new { area = "MainErp", noteId = Model.NoteId.Value })">فتح القيد</a>
                }
            </div>

            @if (Model.VoucherLines.Count == 0)
            {
                <div class="main-erp-empty">لا توجد قيود محاسبية مرتبطة بهذا المستخلص</div>
            }
            else
            {
                <div class="main-erp-table-wrap">
                    <table class="main-erp-table">
                        <thead>
                            <tr>
                                <th>Voucher</th>
                                <th>NoteSerial</th>
                                <th>التاريخ</th>
                                <th>الحساب</th>
                                <th>مدين</th>
                                <th>دائن</th>
                                <th>الوصف</th>
                                <th>الفرع</th>
                                <th>المشروع</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var voucher in Model.VoucherLines)
                            {
                                <tr>
                                    <td>@voucher.VoucherId / @voucher.LineNo</td>
                                    <td>@voucher.NoteSerial</td>
                                    <td>@String.Format("{0:yyyy-MM-dd}", voucher.RecordDate)</td>
                                    <td>@voucher.AccountDisplay</td>
                                    <td>@money(voucher.Debit)</td>
                                    <td>@money(voucher.Credit)</td>
                                    <td>@voucher.Description</td>
                                    <td>@voucher.BranchName</td>
                                    <td>@voucher.ProjectName</td>
                                    <td>
                                        @if (voucher.NoteId.HasValue)
                                        {
                                            <a href="@Url.Action("DetailsByNote", "JournalEntries", new { area = "MainErp", noteId = voucher.NoteId.Value })">فتح القيد</a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>

        <section>
            <h4>الملاحظات والتقارير</h4>
            <div class="main-erp-warning">هذه الصفحة الآن تعرض Workspace تشغيلي حقيقي للمستخلص. معاينة الحفظ أدناه قراءة فقط ولا تنفذ أي كتابة.</div>
            <div class="main-erp-kpi-grid">
                <div class="main-erp-kpi-card"><span>رأس المستخلص</span><strong>@Model.Id</strong><small>قراءة فقط</small></div>
                <div class="main-erp-kpi-card"><span>بنود التنفيذ</span><strong>@Model.DetailLineCount</strong><small>@money(Model.DetailCurrentValueTotal)</small></div>
                <div class="main-erp-kpi-card"><span>الضريبة</span><strong>@money(Model.DetailVatTotal)</strong><small>من البنود</small></div>
                <div class="main-erp-kpi-card"><span>القيود</span><strong>@Model.VoucherLines.Count</strong><small>@(voucherBalanced ? "متوازنة" : "تحتاج مراجعة")</small></div>
            </div>
            <p class="main-erp-remarks">@Model.Remarks</p>
            <div class="main-erp-warning">الطباعة والتقارير محفوظة كمدخلات قراءة آمنة حاليًا، ولن يتم تفعيلها قبل اعتماد قوالب التقارير وربطها بدون تأثير مالي.</div>
        </section>
    </div>
</section>
