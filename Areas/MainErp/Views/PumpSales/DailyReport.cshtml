@model MyERP.Areas.MainErp.ViewModels.SalesInvoices.SalesInvoiceDetailsViewModel
@{
    Layout = "~/Areas/MainErp/Views/Shared/_MainErpLayout.cshtml";
    ViewBag.Title = "تقرير المضخات اليومي";
    Func<decimal?, string> money = v => String.Format("{0:n2}", v ?? 0m);
    Func<decimal, string> moneyValue = v => String.Format("{0:n2}", v);
    var grouped = Model.Lines
        .GroupBy(x => new { x.PumpId, x.PumpName, x.ItemName })
        .Select(g => new
        {
            g.Key.PumpId,
            g.Key.PumpName,
            g.Key.ItemName,
            PrevQty = g.Max(x => x.PrevQty ?? 0m),
            CurrentQty = g.Max(x => x.CurrentQty ?? 0m),
            CashQty = g.Sum(x => x.CashQty ?? 0m),
            MadaQty = g.Sum(x => x.MadaQty ?? 0m),
            VisaQty = g.Sum(x => x.VisaQty ?? 0m),
            DeferredQty = g.Sum(x => x.DeferredQty ?? 0m),
            Cash = g.Sum(x => x.Cash ?? 0m),
            Mada = g.Sum(x => x.Mada ?? 0m),
            Visa = g.Sum(x => x.Visa ?? 0m),
            Deferred = g.Sum(x => x.Deferred ?? 0m)
        })
        .ToList();
}

<section class="main-erp-panel invoice-workspace" dir="rtl">
    <div class="main-erp-title-row">
        <div>
            <h3>تقرير المضخات اليومي</h3>
            <p>نسخة ويب مرتبطة بمنطق `DailyPumpR.Rpt` من `FrmSaleBill6`، مبنية من `Transactions` و `Transaction_Details` و `tblPumpType` لنفس الفاتورة.</p>
        </div>
        <div class="main-erp-actions">
            <a class="main-erp-button" href="@Url.Action("Details", "PumpSales", new { area = "MainErp", id = Model.TransactionId })">رجوع للفاتورة</a>
            <button type="button" class="main-erp-button" onclick="window.print()">طباعة</button>
        </div>
    </div>

    <div class="main-erp-kpi-grid">
        <div class="main-erp-kpi-card"><span>الفاتورة</span><strong>@Model.NoteSerial1</strong><small>@Model.TransactionId</small></div>
        <div class="main-erp-kpi-card"><span>التاريخ</span><strong>@String.Format("{0:yyyy-MM-dd}", Model.TransactionDate)</strong></div>
        <div class="main-erp-kpi-card"><span>العميل</span><strong>@(String.IsNullOrWhiteSpace(Model.CustomerName) ? Model.CashCustomerName : Model.CustomerName)</strong></div>
        <div class="main-erp-kpi-card"><span>الإجمالي</span><strong>@moneyValue(Model.PumpLinePaymentTotal)</strong></div>
    </div>

    <div class="main-erp-table-wrap">
        <table class="main-erp-table">
            <thead>
                <tr>
                    <th>المضخة</th>
                    <th>الصنف</th>
                    <th>بداية القراءة</th>
                    <th>نهاية القراءة</th>
                    <th>اللترات</th>
                    <th>نقدي كمية/قيمة</th>
                    <th>مدى كمية/قيمة</th>
                    <th>فيزا كمية/قيمة</th>
                    <th>آجل كمية/قيمة</th>
                    <th>الإجمالي</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in grouped)
                {
                    <tr>
                        <td>@row.PumpName</td>
                        <td>@row.ItemName</td>
                        <td>@moneyValue(row.PrevQty)</td>
                        <td>@moneyValue(row.CurrentQty)</td>
                        <td>@moneyValue(row.CurrentQty - row.PrevQty)</td>
                        <td>@moneyValue(row.CashQty) / @moneyValue(row.Cash)</td>
                        <td>@moneyValue(row.MadaQty) / @moneyValue(row.Mada)</td>
                        <td>@moneyValue(row.VisaQty) / @moneyValue(row.Visa)</td>
                        <td>@moneyValue(row.DeferredQty) / @moneyValue(row.Deferred)</td>
                        <td class="main-erp-strong">@moneyValue(row.Cash + row.Mada + row.Visa + row.Deferred)</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="5">الإجماليات</td>
                    <td>@moneyValue(grouped.Sum(x => x.CashQty)) / @moneyValue(grouped.Sum(x => x.Cash))</td>
                    <td>@moneyValue(grouped.Sum(x => x.MadaQty)) / @moneyValue(grouped.Sum(x => x.Mada))</td>
                    <td>@moneyValue(grouped.Sum(x => x.VisaQty)) / @moneyValue(grouped.Sum(x => x.Visa))</td>
                    <td>@moneyValue(grouped.Sum(x => x.DeferredQty)) / @moneyValue(grouped.Sum(x => x.Deferred))</td>
                    <td>@moneyValue(grouped.Sum(x => x.Cash + x.Mada + x.Visa + x.Deferred))</td>
                </tr>
            </tfoot>
        </table>
    </div>

    <h4>تجميع العملاء والبنود</h4>
    <div class="main-erp-table-wrap">
        <table class="main-erp-table">
            <thead><tr><th>المضخة</th><th>العميل</th><th>الفاتورة</th><th>الصنف</th><th>التاريخ</th><th>الكمية</th><th>السعر</th><th>الإجمالي</th></tr></thead>
            <tbody>
                @foreach (var line in Model.Lines)
                {
                    <tr>
                        <td>@line.PumpName</td>
                        <td>@(String.IsNullOrWhiteSpace(Model.CashCustomerName) ? Model.CustomerName : Model.CashCustomerName)</td>
                        <td>@Model.NoteSerial1</td>
                        <td>@line.ItemName</td>
                        <td>@String.Format("{0:yyyy-MM-dd}", Model.TransactionDate)</td>
                        <td>@money(line.Quantity ?? line.ShowQty)</td>
                        <td>@money(line.ShowPrice ?? line.Price)</td>
                        <td>@moneyValue(line.LineTotal)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
