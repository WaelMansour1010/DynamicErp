@model MyERP.Areas.MainErp.ViewModels.SalesInvoices.PumpDeferredDistributionEditViewModel
@{
    Layout = "~/Areas/MainErp/Views/Shared/_MainErpLayout.cshtml";
    ViewBag.Title = "توزيع الآجل على عملاء المضخات";
    Func<decimal?, string> money = v => String.Format("{0:n2}", v ?? 0m);
}

<section class="main-erp-panel invoice-workspace" dir="rtl">
    <div class="main-erp-title-row">
        <div>
            <h3>توزيع الآجل على عملاء المضخات</h3>
            <p>نقل آمن لسلوك النافذة الصغيرة في VB6: `FrmitemShowDet` يكتب فقط `DetailsPump` و `Deferred` و `DeferredQty` للبند. لا يتم إنشاء قيود أو مخزون أو Notes.</p>
        </div>
        <div class="main-erp-actions">
            <a class="main-erp-button" href="@Url.Action("Details", "PumpSales", new { area = "MainErp", id = Model.TransactionId })">رجوع للفاتورة</a>
        </div>
    </div>

    @if (!String.IsNullOrWhiteSpace(Model.Message))
    {
        <div class="main-erp-warning">@Model.Message</div>
    }

    @if (Model.Warnings.Count > 0)
    {
        <div class="main-erp-warning">
            <ul>
                @foreach (var warning in Model.Warnings)
                {
                    <li>@warning</li>
                }
            </ul>
        </div>
    }

    <div class="main-erp-kpi-grid">
        <div class="main-erp-kpi-card"><span>رقم الفاتورة</span><strong>@Model.TransactionId</strong><small>@Model.NoteSerial</small></div>
        <div class="main-erp-kpi-card"><span>العميل الرئيسي</span><strong>@Model.CustomerName</strong><small>@String.Format("{0:yyyy-MM-dd}", Model.TransactionDate)</small></div>
        <div class="main-erp-kpi-card"><span>البند / المضخة</span><strong>@Model.ItemName</strong><small>@Model.PumpName</small></div>
        <div class="main-erp-kpi-card"><span>الآجل الحالي</span><strong>@money(Model.CurrentDeferred)</strong><small>كمية @money(Model.CurrentDeferredQty)</small></div>
        <div class="main-erp-kpi-card"><span>إجمالي التوزيع الجديد</span><strong>@money(Model.AllocationAmountTotal)</strong><small>كمية @money(Model.AllocationQuantityTotal)</small></div>
        <div class="main-erp-kpi-card"><span>حالة الفاتورة</span><strong>@(Model.IsLocked ? "مغلقة/مرحلة" : "مسموح كتوزيع آجل")</strong><small>حفظ محدود فقط</small></div>
    </div>

    <div class="main-erp-warning">
        هذه الشاشة لا تنفذ حفظ فاتورة كامل. الحفظ هنا خاص بتوزيع آجِل المضخات فقط، ويمنع الإجراء المخزن التعديل إذا كانت الفاتورة مغلقة أو مرحلة أو معتمدة.
    </div>

    @using (Html.BeginForm("DeferredDistribution", "PumpSales", new { area = "MainErp" }, FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(x => x.TransactionId)
        @Html.HiddenFor(x => x.LineId)

        <div class="main-erp-table-wrap">
            <table class="main-erp-table">
                <thead>
                    <tr>
                        <th>كود العميل</th>
                        <th>اسم العميل</th>
                        <th>UnitId</th>
                        <th>الكمية</th>
                        <th>السعر</th>
                        <th>القيمة</th>
                        <th>RecNo</th>
                        <th>حساب العميل</th>
                    </tr>
                </thead>
                <tbody>
                    @for (var i = 0; i < Model.Allocations.Count; i++)
                    {
                        <tr>
                            <td>
                                @Html.HiddenFor(x => x.Allocations[i].LineId)
                                @Html.TextBoxFor(x => x.Allocations[i].CustomerId, new { @class = "main-erp-input", type = "number" })
                            </td>
                            <td>@Html.TextBoxFor(x => x.Allocations[i].CustomerName, new { @class = "main-erp-input" })</td>
                            <td>@Html.TextBoxFor(x => x.Allocations[i].UnitId, new { @class = "main-erp-input", type = "number" })</td>
                            <td>@Html.TextBoxFor(x => x.Allocations[i].Quantity, new { @class = "main-erp-input", type = "number", step = "0.0001" })</td>
                            <td>@Html.TextBoxFor(x => x.Allocations[i].UnitPrice, new { @class = "main-erp-input", type = "number", step = "0.0001" })</td>
                            <td>@Html.TextBoxFor(x => x.Allocations[i].Amount, new { @class = "main-erp-input", type = "number", step = "0.0001" })</td>
                            <td>@Html.TextBoxFor(x => x.Allocations[i].ReferenceNo, new { @class = "main-erp-input", type = "number" })</td>
                            <td>@Model.Allocations[i].CustomerAccountDisplay</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="3">الإجماليات</td>
                        <td>@money(Model.AllocationQuantityTotal)</td>
                        <td></td>
                        <td>@money(Model.AllocationAmountTotal)</td>
                        <td colspan="2">الحالي: @money(Model.CurrentDeferred) / كمية @money(Model.CurrentDeferredQty)</td>
                    </tr>
                </tfoot>
            </table>
        </div>

        <div class="main-erp-actions" style="margin-top:16px">
            <button type="submit" name="command" value="preview" class="main-erp-button">معاينة بدون حفظ</button>
            <button type="submit" name="command" value="save" class="main-erp-button" @(Model.IsLocked ? "disabled=\"disabled\"" : "")>حفظ توزيع الآجل فقط</button>
        </div>
    }
</section>
