@{
    Layout = "~/Areas/MainErp/Views/Shared/_MainErpLayout.cshtml";
    ViewBag.Title = "المشتريات";
}
<section class="main-erp-panel main-erp-operational-page">
    <div class="main-erp-title-row">
        <div>
            <h3>فاتورة مشتريات</h3>
            <p>Reused from Kishny generic module. تم نقل شكل العمل العام من شاشة مشتريات Kishny/POS مع إزالة جلسة POS وتعطيل الحفظ والاستيراد مؤقتا.</p>
        </div>
        <span class="main-erp-badge">Reused from Kishny generic module</span>
    </div>

    <div class="main-erp-vb6-toolbar">
        <button type="button">بحث</button>
        <button type="button">فاتورة جديدة</button>
        <button type="button" disabled>حفظ معطل لحين فصل POS dependencies</button>
        <button type="button" disabled>استيراد Excel معطل</button>
        <button type="button" disabled>طباعة</button>
    </div>

    <section class="main-erp-tabs">
        <section>
            <h4>بحث فواتير المشتريات</h4>
            <div class="main-erp-form-grid">
                <label><span>من تاريخ</span><input type="date" /></label>
                <label><span>إلى تاريخ</span><input type="date" /></label>
                <label><span>رقم الفاتورة</span><input type="text" placeholder="رقم الفاتورة أو رقم المورد" /></label>
                <label><span>المورد</span><input type="text" placeholder="كود أو اسم المورد" /></label>
                <label><span>الفرع</span><input type="text" placeholder="كل الفروع" /></label>
                <label><span>المخزن</span><input type="text" placeholder="كل المخازن" /></label>
                <label><span>طريقة الدفع</span><select><option>كل الطرق</option><option>آجل / على المورد</option><option>نقدي</option><option>بنك</option></select></label>
            </div>
            <div class="main-erp-reused-note">هذه الفلاتر من شاشة Kishny/POS العامة. الخطوة التالية هي توصيلها بمستودع MainErp يقرأ من قاعدة Eng عبر MainErp_ConnectionString.</div>
        </section>

        <section>
            <h4>بيانات الفاتورة</h4>
            <div class="main-erp-form-grid">
                <label><span>رقم الفاتورة</span><input type="text" disabled /></label>
                <label><span>تاريخ الفاتورة</span><input type="date" disabled /></label>
                <label><span>المورد</span><input type="text" disabled /></label>
                <label><span>الفرع</span><input type="text" disabled /></label>
                <label><span>المخزن</span><input type="text" disabled /></label>
                <label><span>طريقة الدفع</span><input type="text" disabled /></label>
                <label><span>الصندوق</span><input type="text" disabled /></label>
                <label><span>البنك</span><input type="text" disabled /></label>
                <label class="main-erp-wide-field"><span>ملاحظات</span><textarea disabled></textarea></label>
            </div>
        </section>

        <section>
            <h4>الأصناف</h4>
            <div class="main-erp-table-wrap">
                <table class="main-erp-table">
                    <thead>
                        <tr>
                            <th>الصنف</th>
                            <th>الوحدة</th>
                            <th>الكمية</th>
                            <th>السعر</th>
                            <th>الخصم</th>
                            <th>VAT %</th>
                            <th>VAT</th>
                            <th>السيريال</th>
                            <th>الإجمالي</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td colspan="9">سيتم تحميل البنود من MainErp بعد فصل Repository عن PosSqlRepository.</td></tr>
                    </tbody>
                </table>
            </div>
        </section>

        <section>
            <h4>الإجماليات</h4>
            <dl class="main-erp-details">
                <dt>إجمالي قبل الخصم</dt><dd>0.00</dd>
                <dt>إجمالي الخصم</dt><dd>0.00</dd>
                <dt>إجمالي VAT</dt><dd>0.00</dd>
                <dt>الصافي</dt><dd>0.00</dd>
            </dl>
        </section>
    </section>
</section>
