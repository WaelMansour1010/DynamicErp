@{
    Layout = "~/Areas/MainErp/Views/Shared/_MainErpLayout.cshtml";
    ViewBag.Title = "Sales Reports";
}
<section class="main-erp-panel">
    <div class="main-erp-title-row">
        <div>
            <h3>تقارير المبيعات العامة</h3>
            <p>هذه صفحة MainErp فقط لتجميع تقارير المبيعات العامة المرشحة. التقارير التشغيلية المتخصصة مستبعدة من هذه الوحدة.</p>
        </div>
        <span class="main-erp-badge">Shell only</span>
    </div>
    <div class="main-erp-sections">
        <div><strong>ملخص المبيعات خلال فترة</strong><br /><a href="@Url.Action("SalesSummary", "SalesReports", new { area = "MainErp" })">فتح التقرير</a></div>
        <div><strong>تقرير المبيعات الشامل</strong><br /><span>سيتم ربطه بجداول ERP العامة فقط.</span></div>
        <div><strong>تحليل المبيعات حسب الفرع</strong><br /><span>مسموح إذا كان غير مرتبط بالكاشير أو POS session.</span></div>
    </div>
</section>
