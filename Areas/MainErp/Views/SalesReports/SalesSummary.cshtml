@model MyERP.Areas.MainErp.ViewModels.Reports.SalesSummaryReportViewModel
@{
    Layout = "~/Areas/MainErp/Views/Shared/_MainErpLayout.cshtml";
    ViewBag.Title = "Sales Summary";
}
<section class="main-erp-panel">
    <div class="main-erp-title-row">
        <div>
            <h3>ملخص المبيعات خلال فترة</h3>
            <p>تقرير قراءة فقط من فواتير المبيعات العامة المرشحة.</p>
        </div>
        <span class="main-erp-badge">Read-only</span>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Warning))
    {
        <div class="main-erp-warning">@Model.Warning</div>
    }

    @using (Html.BeginForm("SalesSummary", "SalesReports", new { area = "MainErp" }, FormMethod.Get, new { @class = "main-erp-filter" }))
    {
        <input type="date" name="fromDate" value="@(Model.FromDate.HasValue ? Model.FromDate.Value.ToString("yyyy-MM-dd") : string.Empty)" title="من تاريخ" />
        <input type="date" name="toDate" value="@(Model.ToDate.HasValue ? Model.ToDate.Value.ToString("yyyy-MM-dd") : string.Empty)" title="إلى تاريخ" />
        <input type="number" name="branchId" value="@Model.BranchId" placeholder="الفرع" />
        <input type="number" name="userId" value="@Model.UserId" placeholder="المستخدم" />
        <input type="number" name="customerId" value="@Model.CustomerId" placeholder="العميل" />
        <button type="submit">عرض التقرير</button>
    }

    <table class="main-erp-table">
        <thead>
            <tr>
                <th>التاريخ</th>
                <th>الفرع</th>
                <th>المستخدم</th>
                <th>عدد الفواتير</th>
                <th>قبل الضريبة</th>
                <th>الضريبة</th>
                <th>الإجمالي</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Model.Rows)
            {
                <tr>
                    <td>@(row.Date.HasValue ? row.Date.Value.ToString("dd/MM/yyyy") : "")</td>
                    <td>@row.BranchName</td>
                    <td>@row.UserName</td>
                    <td>@row.InvoiceCount</td>
                    <td>@row.TotalBeforeVat.ToString("N2")</td>
                    <td>@row.Vat.ToString("N2")</td>
                    <td>@row.Total.ToString("N2")</td>
                </tr>
            }
            @if (Model.Rows.Count == 0)
            {
                <tr><td colspan="7">لا توجد بيانات للعرض.</td></tr>
            }
        </tbody>
        <tfoot>
            <tr>
                <th colspan="3">الإجمالي</th>
                <th>@Model.InvoiceCount</th>
                <th>@Model.TotalBeforeVat.ToString("N2")</th>
                <th>@Model.TotalVat.ToString("N2")</th>
                <th>@Model.TotalAmount.ToString("N2")</th>
            </tr>
        </tfoot>
    </table>
</section>
