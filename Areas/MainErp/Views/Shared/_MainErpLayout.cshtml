@{
    Layout = null;
    Func<string, string> T = MyERP.Areas.MainErp.Infrastructure.Localization.MainErpLocalizationService.T;
    var culture = MyERP.Areas.MainErp.Infrastructure.Localization.MainErpCultureManager.CurrentLanguage;
    var direction = MyERP.Areas.MainErp.Infrastructure.Localization.MainErpCultureManager.Direction;
    var directionClass = MyERP.Areas.MainErp.Infrastructure.Localization.MainErpCultureManager.DirectionCssClass;
    var pageTitle = string.IsNullOrWhiteSpace(Convert.ToString(ViewBag.Title))
        ? T("MainErp")
        : Convert.ToString(ViewBag.Title);
    var mainErpContext = Session["MainErp.UserContext"] as MyERP.Areas.MainErp.Models.Security.MainErpUserContext;
    var isAdmin = mainErpContext != null && mainErpContext.IsAdmin;
    var returnUrl = Request.RawUrl;
}
<!DOCTYPE html>
<html lang="@culture" dir="@direction">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@pageTitle</title>
    <link href="@Url.Content("~/assets/css/Courses/css/fontawesome-all.min.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Areas/MainErp/Content/mainerp/mainerp.css?v=20260507-lc-premium")" rel="stylesheet" />
    <link href="@Url.Content("~/Areas/MainErp/Content/enterprise-ui.css?v=20260509-enterprise-ui")" rel="stylesheet" />
    <script src="@Url.Content("~/assets/libs/chart-js/Chart.bundle.min.js")"></script>
</head>
<body class="main-erp-body @directionClass">
    <div class="pos-main-shell main-erp-app-shell" dir="@direction"
         data-is-admin="@(isAdmin ? "true" : "false")"
         data-app-name="MainErp">
        @Html.Partial("_MainErpSidebar")

        <main class="pos-main-content main-erp-main-content">
            <header class="pos-main-topbar main-erp-topbar">
                <div>
                    <h1>@pageTitle</h1>
                    <p>
                        @T("User"): @(mainErpContext != null ? mainErpContext.UserName : "")
                        @if (mainErpContext != null && mainErpContext.BranchId.HasValue)
                        {
                            <text> | @T("Branch"): @(string.IsNullOrWhiteSpace(mainErpContext.BranchName) ? mainErpContext.BranchId.ToString() : mainErpContext.BranchName)</text>
                        }
                    </p>
                </div>
                <div class="main-erp-topbar-actions">
                    <a class="main-erp-topbar-link" href="@Url.Action("Set", "Localization", new { area = "MainErp", culture = culture == "ar" ? "en" : "ar", returnUrl })">
                        <i class="fas fa-language" aria-hidden="true"></i>
                        @(culture == "ar" ? "English" : "العربية")
                    </a>
                    <a class="main-erp-topbar-link" href="@Url.Action("Index", "Dashboard", new { area = "MainErp" })">
                        <i class="fas fa-tachometer-alt" aria-hidden="true"></i>
                        @T("Dashboard")
                    </a>
                    @if (mainErpContext != null)
                    {
                        using (Html.BeginForm("Logout", "Login", new { area = "MainErp" }, FormMethod.Post, new { @class = "pos-main-logout main-erp-logout" }))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit">@T("Logout")</button>
                        }
                    }
                </div>
            </header>

            <section class="main-erp-page-host">
                @RenderBody()
            </section>
        </main>

        <div class="pos-main-loading-overlay" id="mainErpLoadingOverlay" aria-live="polite" aria-hidden="true">
            <div class="pos-loading-box">
                <span class="pos-loading-spinner" aria-hidden="true"></span>
                <span id="mainErpLoadingText">@T("LoadingScreen")</span>
            </div>
        </div>
    </div>

    <script>
        (function () {
            var sidebar = document.getElementById("mainErpSidebar");
            var collapseBtn = document.getElementById("mainErpSidebarCollapseBtn");
            var overlay = document.getElementById("mainErpLoadingOverlay");
            var navLinks = document.querySelectorAll(".main-erp-nav-link[href]");
            function showLoading() {
                if (!overlay) { return; }
                overlay.setAttribute("aria-hidden", "false");
                overlay.classList.add("is-visible");
            }
            document.querySelectorAll("[data-menu-toggle]").forEach(function (button) {
                button.addEventListener("click", function () {
                    var section = button.closest(".pos-nav-section");
                    if (section) { section.classList.toggle("is-open"); }
                });
            });
            if (collapseBtn && sidebar) {
                collapseBtn.addEventListener("click", function () {
                    sidebar.classList.toggle("is-collapsed");
                    document.body.classList.toggle("main-erp-sidebar-collapsed");
                });
            }
            navLinks.forEach(function (link) {
                link.addEventListener("click", function () {
                    if (!link.classList.contains("is-disabled")) { showLoading(); }
                });
            });
            window.addEventListener("pageshow", function () {
                if (!overlay) { return; }
                overlay.classList.remove("is-visible");
                overlay.setAttribute("aria-hidden", "true");
            });
        })();
    </script>
    <script src="@Url.Content("~/Areas/MainErp/Scripts/enterprise-ui.js?v=20260509-enterprise-ui")"></script>
    @RenderSection("scripts", required: false)
</body>
</html>
