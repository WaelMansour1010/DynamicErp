@{
    Func<string, string> T = MyERP.Areas.MainErp.Infrastructure.Localization.MainErpLocalizationService.T;
    var mainErpContext = Session["MainErp.UserContext"] as MyERP.Areas.MainErp.Models.Security.MainErpUserContext;
    var activeScreen = (ViewBag.ActiveScreen as string) ?? "";
    Func<string, bool> isActive = key => string.Equals(activeScreen, key, StringComparison.OrdinalIgnoreCase);
    Func<string[], bool> sectionActive = keys => keys.Any(k => string.Equals(activeScreen, k, StringComparison.OrdinalIgnoreCase));

    var accountingOpen = sectionActive(new[] { "journal-entries", "discount-notifications", "accounts", "accounting-reports", "account-movement", "voucher-preview", "payments", "cashing", "dynamic-reports", "employee-payroll", "salary-run", "medical-insurance", "medical-insurance-reports" });
    var salesOpen = sectionActive(new[] { "workshop-sales", "pump-sales", "sales-reports", "sales-summary" });
    var purchasesOpen = sectionActive(new[] { "purchases" });
    var inventoryOpen = sectionActive(new[] { "stock-transfers" });
    var projectsOpen = sectionActive(new[] { "project-extracts" });
    var lcOpen = sectionActive(new[] { "lc" });
    var adminOpen = sectionActive(new[] { "database-migration" });
    if (!(accountingOpen || salesOpen || purchasesOpen || inventoryOpen || projectsOpen || lcOpen || adminOpen || isActive("dashboard"))) { accountingOpen = true; }
}

<aside class="pos-main-sidebar main-erp-sidebar" id="mainErpSidebar">
    <div class="pos-sidebar-brand main-erp-sidebar-brand">
        <div class="pos-main-logo main-erp-main-logo">
            <span class="main-erp-brand-mark">ERP</span>
            <div class="main-erp-brand-text">
                <strong>@T("MainErp")</strong>
                <small>MainErp</small>
            </div>
        </div>
        <button type="button" class="pos-sidebar-collapse" id="mainErpSidebarCollapseBtn" aria-label="@T("MenuCollapse")" title="@T("MenuCollapse")">
            <i class="fas fa-bars" aria-hidden="true"></i>
        </button>
    </div>

    <div class="pos-sidebar-user main-erp-sidebar-user" title="@T("User")">
        <span class="user-avatar"><i class="fas fa-user" aria-hidden="true"></i></span>
        <div>
            <strong>@(mainErpContext != null ? mainErpContext.UserName : "")</strong>
            <small>@(mainErpContext != null && !string.IsNullOrWhiteSpace(mainErpContext.BranchName) ? mainErpContext.BranchName : T("MainErp"))</small>
        </div>
    </div>

    <nav class="pos-main-nav pos-modern-nav main-erp-main-nav" aria-label="@T("MainErp")">
        <a class="pos-nav-link main-erp-nav-link pos-nav-home @(isActive("dashboard") ? "active" : "")" href="@Url.Action("Index", "Dashboard", new { area = "MainErp" })" title="@T("Dashboard")">
            <i class="fas fa-tachometer-alt" aria-hidden="true"></i><span>@T("Dashboard")</span>
        </a>

        <section class="pos-nav-section @(accountingOpen ? "is-open" : "")">
            <button type="button" class="pos-nav-section-toggle" data-menu-toggle title="@T("Accounting")">
                <span><i class="fas fa-book" aria-hidden="true"></i><b>@T("Accounting")</b></span>
                <i class="fas fa-chevron-down nav-chevron" aria-hidden="true"></i>
            </button>
            <div class="pos-nav-submenu">
                <a class="pos-nav-link main-erp-nav-link @(isActive("journal-entries") ? "active" : "")" href="@Url.Action("Index", "JournalEntries", new { area = "MainErp" })" title="@T("JournalEntries")"><i class="fas fa-list-alt"></i><span>@T("JournalEntries")</span></a>
                <a class="pos-nav-link main-erp-nav-link @(isActive("discount-notifications") ? "active" : "")" href="@Url.Action("Index", "DiscountNotifications", new { area = "MainErp" })" title="@T("DiscountNotifications")"><i class="fas fa-file-invoice-dollar"></i><span>@T("DiscountNotifications")</span></a>
                <a class="pos-nav-link main-erp-nav-link @(isActive("accounting-reports") ? "active" : "")" href="@Url.Action("Index", "AccountingReports", new { area = "MainErp" })" title="@T("AccountingReports")"><i class="fas fa-chart-pie"></i><span>@T("AccountingReports")</span></a>
                <a class="pos-nav-link main-erp-nav-link @(isActive("dynamic-reports") ? "active" : "")" href="@Url.Content("~/MainErp/DynamicReports/Index")" title="ط§ظ„طھظ‚ط§ط±ظٹط± ط§ظ„ط¯ظٹظ†ط§ظ…ظٹظƒظٹط©"><i class="fas fa-sliders-h"></i><span>ط§ظ„طھظ‚ط§ط±ظٹط± ط§ظ„ط¯ظٹظ†ط§ظ…ظٹظƒظٹط©</span></a>
                @if (mainErpContext != null && mainErpContext.IsAdmin)
                {
                    <a class="pos-nav-link main-erp-nav-link" href="@Url.Content("~/MainErp/DynamicReportsAdmin/Index")" title="ط¥ط¯ط§ط±ط© ط§ظ„طھظ‚ط§ط±ظٹط± ط§ظ„ط¯ظٹظ†ط§ظ…ظٹظƒظٹط©"><i class="fas fa-cogs"></i><span>ط¥ط¯ط§ط±ط© ط§ظ„طھظ‚ط§ط±ظٹط± ط§ظ„ط¯ظٹظ†ط§ظ…ظٹظƒظٹط©</span></a>
                }
                <a class="pos-nav-link main-erp-nav-link @(isActive("account-movement") ? "active" : "")" href="@Url.Action("AccountMovement", "AccountingReports", new { area = "MainErp" })" title="@T("AccountMovement")"><i class="fas fa-exchange-alt"></i><span>@T("AccountMovement")</span></a>
                <a class="pos-nav-link main-erp-nav-link @(isActive("voucher-preview") ? "active" : "")" href="@Url.Action("PreviewTest", "Accounting", new { area = "MainErp" })" title="@T("PreviewVoucher")"><i class="fas fa-eye"></i><span>@T("PreviewVoucher")</span></a>
                <a class="pos-nav-link main-erp-nav-link @(isActive("payments") ? "active" : "")" href="@Url.Action("Index", "Payments", new { area = "MainErp" })" title="ط³ظ†ط¯ط§طھ ط§ظ„طµط±ظپ"><i class="fas fa-money-bill-wave"></i><span>ط³ظ†ط¯ط§طھ ط§ظ„طµط±ظپ</span></a>
                <a class="pos-nav-link main-erp-nav-link @(isActive("cashing") ? "active" : "")" href="@Url.Action("Index", "Cashing", new { area = "MainErp" })" title="ط³ظ†ط¯ط§طھ ط§ظ„ظ‚ط¨ط¶"><i class="fas fa-hand-holding-usd"></i><span>ط³ظ†ط¯ط§طھ ط§ظ„ظ‚ط¨ط¶</span></a>
                <a class="pos-nav-link main-erp-nav-link @(isActive("employee-payroll") ? "active" : "")" href="@Url.Action("Employees", "EmployeePayroll", new { area = "MainErp" })" title="ط§ظ„ظ…ظˆط¸ظپظˆظ†"><i class="fas fa-users"></i><span>ط§ظ„ظ…ظˆط¸ظپظˆظ†</span></a>
                <a class="pos-nav-link main-erp-nav-link @(isActive("salary-run") ? "active" : "")" href="@Url.Action("SalaryRun", "EmployeePayroll", new { area = "MainErp" })" title="ظ…ط³ظٹط± ط§ظ„ط±ظˆط§طھط¨"><i class="fas fa-file-invoice-dollar"></i><span>ظ…ط³ظٹط± ط§ظ„ط±ظˆط§طھط¨</span></a>
                <a class="pos-nav-link main-erp-nav-link @(isActive("medical-insurance") ? "active" : "")" href="@Url.Action("MedicalInsurance", "EmployeePayroll", new { area = "MainErp" })" title="ط§ظ„طھط£ظ…ظٹظ† ط§ظ„ط·ط¨ظٹ"><i class="fas fa-briefcase-medical"></i><span>ط§ظ„طھط£ظ…ظٹظ† ط§ظ„ط·ط¨ظٹ</span></a>
                <a class="pos-nav-link main-erp-nav-link @(isActive("medical-insurance-reports") ? "active" : "")" href="@Url.Action("MedicalInsuranceReports", "EmployeePayroll", new { area = "MainErp" })" title="طھظ‚ط§ط±ظٹط± ط§ظ„طھط£ظ…ظٹظ† ط§ظ„ط·ط¨ظٹ"><i class="fas fa-chart-bar"></i><span>طھظ‚ط§ط±ظٹط± ط§ظ„طھط£ظ…ظٹظ†</span></a>
            </div>
        </section>

        <section class="pos-nav-section @(salesOpen ? "is-open" : "")">
            <button type="button" class="pos-nav-section-toggle" data-menu-toggle title="@T("Sales")"><span><i class="fas fa-chart-line"></i><b>@T("Sales")</b></span><i class="fas fa-chevron-down nav-chevron"></i></button>
            <div class="pos-nav-submenu">
                <a class="pos-nav-link main-erp-nav-link @(isActive("workshop-sales") ? "active" : "")" href="@Url.Action("Index", "WorkshopSales", new { area = "MainErp" })"><i class="fas fa-tools"></i><span>@T("WorkshopSalesInvoice")</span></a>
                <a class="pos-nav-link main-erp-nav-link @(isActive("pump-sales") ? "active" : "")" href="@Url.Action("Index", "PumpSales", new { area = "MainErp" })"><i class="fas fa-gas-pump"></i><span>@T("PumpSalesInvoice")</span></a>
                <a class="pos-nav-link main-erp-nav-link @(isActive("sales-reports") ? "active" : "")" href="@Url.Action("Index", "SalesReports", new { area = "MainErp" })"><i class="fas fa-chart-bar"></i><span>@T("SalesReports")</span></a>
                <a class="pos-nav-link main-erp-nav-link @(isActive("sales-summary") ? "active" : "")" href="@Url.Action("SalesSummary", "SalesReports", new { area = "MainErp" })"><i class="fas fa-receipt"></i><span>@T("SalesSummary")</span></a>
            </div>
        </section>

        <section class="pos-nav-section @(purchasesOpen ? "is-open" : "")">
            <button type="button" class="pos-nav-section-toggle" data-menu-toggle title="@T("Purchases")"><span><i class="fas fa-file-invoice"></i><b>@T("Purchases")</b></span><i class="fas fa-chevron-down nav-chevron"></i></button>
            <div class="pos-nav-submenu"><a class="pos-nav-link main-erp-nav-link @(isActive("purchases") ? "active" : "")" href="@Url.Action("Index", "Purchases", new { area = "MainErp" })"><i class="fas fa-file-alt"></i><span>@T("Purchases")</span></a></div>
        </section>

        <section class="pos-nav-section @(inventoryOpen ? "is-open" : "")">
            <button type="button" class="pos-nav-section-toggle" data-menu-toggle title="@T("Inventory")"><span><i class="fas fa-boxes"></i><b>@T("Inventory")</b></span><i class="fas fa-chevron-down nav-chevron"></i></button>
            <div class="pos-nav-submenu"><a class="pos-nav-link main-erp-nav-link @(isActive("stock-transfers") ? "active" : "")" href="@Url.Action("Index", "StockTransfers", new { area = "MainErp" })"><i class="fas fa-random"></i><span>@T("StockTransfers")</span></a></div>
        </section>

        <section class="pos-nav-section @(projectsOpen ? "is-open" : "")">
            <button type="button" class="pos-nav-section-toggle" data-menu-toggle title="@T("Projects")"><span><i class="fas fa-project-diagram"></i><b>@T("Projects")</b></span><i class="fas fa-chevron-down nav-chevron"></i></button>
            <div class="pos-nav-submenu"><a class="pos-nav-link main-erp-nav-link @(isActive("project-extracts") ? "active" : "")" href="@Url.Action("Index", "ProjectExtracts", new { area = "MainErp" })"><i class="fas fa-tasks"></i><span>@T("ProjectExtracts")</span></a></div>
        </section>

        <section class="pos-nav-section @(lcOpen ? "is-open" : "")">
            <button type="button" class="pos-nav-section-toggle" data-menu-toggle title="@T("LettersOfCredit")"><span><i class="fas fa-university"></i><b>@T("LettersOfCredit")</b></span><i class="fas fa-chevron-down nav-chevron"></i></button>
            <div class="pos-nav-submenu"><a class="pos-nav-link main-erp-nav-link @(isActive("lc") ? "active" : "")" href="@Url.Action("Index", "LC", new { area = "MainErp" })"><i class="fas fa-landmark"></i><span>@T("LcScreen")</span></a></div>
        </section>
        @if (mainErpContext != null && mainErpContext.IsAdmin)
        {
            <section class="pos-nav-section @(adminOpen ? "is-open" : "")">
                <button type="button" class="pos-nav-section-toggle" data-menu-toggle title="System Administration"><span><i class="fas fa-shield-alt"></i><b>System Administration</b></span><i class="fas fa-chevron-down nav-chevron"></i></button>
                <div class="pos-nav-submenu">
                    <a class="pos-nav-link main-erp-nav-link @(isActive("database-migration") ? "active" : "")" href="@Url.Action("Index", "DatabaseMigration", new { area = "MainErp" })" title="Database Update Manager"><i class="fas fa-database"></i><span>Database Update Manager</span></a>
                </div>
            </section>
