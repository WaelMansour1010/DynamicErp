@{
    var mainErpContext = Session["MainErp.UserContext"] as MyERP.Areas.MainErp.Models.Security.MainErpUserContext;
    var activeScreen = (ViewBag.ActiveScreen as string) ?? "";
    Func<string, bool> isActive = key => string.Equals(activeScreen, key, StringComparison.OrdinalIgnoreCase);
    Func<string[], bool> sectionActive = keys => keys.Any(k => string.Equals(activeScreen, k, StringComparison.OrdinalIgnoreCase));

    var accountingOpen = sectionActive(new[] { "journal-entries", "accounts", "accounting-reports", "account-movement", "voucher-preview" });
    var salesOpen = sectionActive(new[] { "sales-reports", "sales-summary" });
    var purchasesOpen = sectionActive(new[] { "purchases" });
    var inventoryOpen = sectionActive(new[] { "stock-transfers" });
    var projectsOpen = sectionActive(new[] { "project-extracts" });
    var lcOpen = sectionActive(new[] { "lc" });

    if (!(accountingOpen || salesOpen || purchasesOpen || inventoryOpen || projectsOpen || lcOpen || isActive("dashboard")))
    {
        accountingOpen = true;
    }
}

<aside class="pos-main-sidebar main-erp-sidebar" id="mainErpSidebar">
    <div class="pos-sidebar-brand main-erp-sidebar-brand">
        <div class="pos-main-logo main-erp-main-logo">
            <span class="main-erp-brand-mark">ERP</span>
            <div class="main-erp-brand-text">
                <strong>النظام الرئيسي</strong>
                <small>MainErp</small>
            </div>
        </div>
        <button type="button" class="pos-sidebar-collapse" id="mainErpSidebarCollapseBtn" aria-label="تصغير القائمة" title="تصغير القائمة">
            <i class="fas fa-bars" aria-hidden="true"></i>
        </button>
    </div>

    <div class="pos-sidebar-user main-erp-sidebar-user" title="المستخدم الحالي">
        <span class="user-avatar"><i class="fas fa-user" aria-hidden="true"></i></span>
        <div>
            <strong>@(mainErpContext != null ? mainErpContext.UserName : "")</strong>
            <small>@(mainErpContext != null && !string.IsNullOrWhiteSpace(mainErpContext.BranchName) ? mainErpContext.BranchName : "Main ERP")</small>
        </div>
    </div>

    <nav class="pos-main-nav pos-modern-nav main-erp-main-nav" aria-label="قائمة النظام الرئيسي">
        <a class="pos-nav-link main-erp-nav-link pos-nav-home @(isActive("dashboard") ? "active" : "")"
           href="@Url.Action("Index", "Dashboard", new { area = "MainErp" })"
           title="لوحة التحكم">
            <i class="fas fa-tachometer-alt" aria-hidden="true"></i><span>لوحة التحكم</span>
        </a>

        <section class="pos-nav-section @(accountingOpen ? "is-open" : "")">
            <button type="button" class="pos-nav-section-toggle" data-menu-toggle title="الحسابات">
                <span><i class="fas fa-book" aria-hidden="true"></i><b>الحسابات</b></span>
                <i class="fas fa-chevron-down nav-chevron" aria-hidden="true"></i>
            </button>
            <div class="pos-nav-submenu">
                <a class="pos-nav-link main-erp-nav-link @(isActive("journal-entries") ? "active" : "")"
                   href="@Url.Action("Index", "JournalEntries", new { area = "MainErp" })"
                   title="القيود اليومية">
                    <i class="fas fa-list-alt" aria-hidden="true"></i><span>القيود اليومية</span>
                </a>
                <a class="pos-nav-link main-erp-nav-link @(isActive("accounting-reports") ? "active" : "")"
                   href="@Url.Action("Index", "AccountingReports", new { area = "MainErp" })"
                   title="التقارير المحاسبية">
                    <i class="fas fa-chart-pie" aria-hidden="true"></i><span>التقارير المحاسبية</span>
                </a>
                <a class="pos-nav-link main-erp-nav-link @(isActive("account-movement") ? "active" : "")"
                   href="@Url.Action("AccountMovement", "AccountingReports", new { area = "MainErp" })"
                   title="حركة حساب">
                    <i class="fas fa-exchange-alt" aria-hidden="true"></i><span>حركة حساب</span>
                </a>
                <a class="pos-nav-link main-erp-nav-link @(isActive("voucher-preview") ? "active" : "")"
                   href="@Url.Action("PreviewTest", "Accounting", new { area = "MainErp" })"
                   title="معاينة القيود">
                    <i class="fas fa-eye" aria-hidden="true"></i><span>معاينة القيود</span>
                </a>
            </div>
        </section>

        <section class="pos-nav-section @(salesOpen ? "is-open" : "")">
            <button type="button" class="pos-nav-section-toggle" data-menu-toggle title="المبيعات">
                <span><i class="fas fa-chart-line" aria-hidden="true"></i><b>المبيعات</b></span>
                <i class="fas fa-chevron-down nav-chevron" aria-hidden="true"></i>
            </button>
            <div class="pos-nav-submenu">
                <a class="pos-nav-link main-erp-nav-link @(isActive("sales-reports") ? "active" : "")"
                   href="@Url.Action("Index", "SalesReports", new { area = "MainErp" })"
                   title="تقارير المبيعات">
                    <i class="fas fa-chart-bar" aria-hidden="true"></i><span>تقارير المبيعات</span>
                </a>
                <a class="pos-nav-link main-erp-nav-link @(isActive("sales-summary") ? "active" : "")"
                   href="@Url.Action("SalesSummary", "SalesReports", new { area = "MainErp" })"
                   title="ملخص المبيعات">
                    <i class="fas fa-receipt" aria-hidden="true"></i><span>ملخص المبيعات</span>
                </a>
            </div>
        </section>

        <section class="pos-nav-section @(purchasesOpen ? "is-open" : "")">
            <button type="button" class="pos-nav-section-toggle" data-menu-toggle title="المشتريات">
                <span><i class="fas fa-file-invoice" aria-hidden="true"></i><b>المشتريات</b></span>
                <i class="fas fa-chevron-down nav-chevron" aria-hidden="true"></i>
            </button>
            <div class="pos-nav-submenu">
                <a class="pos-nav-link main-erp-nav-link @(isActive("purchases") ? "active" : "")"
                   href="@Url.Action("Index", "Purchases", new { area = "MainErp" })"
                   title="فواتير المشتريات">
                    <i class="fas fa-file-alt" aria-hidden="true"></i><span>فواتير المشتريات</span>
                </a>
            </div>
        </section>

        <section class="pos-nav-section @(inventoryOpen ? "is-open" : "")">
            <button type="button" class="pos-nav-section-toggle" data-menu-toggle title="المخزون">
                <span><i class="fas fa-boxes" aria-hidden="true"></i><b>المخزون</b></span>
                <i class="fas fa-chevron-down nav-chevron" aria-hidden="true"></i>
            </button>
            <div class="pos-nav-submenu">
                <a class="pos-nav-link main-erp-nav-link @(isActive("stock-transfers") ? "active" : "")"
                   href="@Url.Action("Index", "StockTransfers", new { area = "MainErp" })"
                   title="التحويلات المخزنية">
                    <i class="fas fa-random" aria-hidden="true"></i><span>التحويلات المخزنية</span>
                </a>
            </div>
        </section>

        <section class="pos-nav-section @(projectsOpen ? "is-open" : "")">
            <button type="button" class="pos-nav-section-toggle" data-menu-toggle title="المشاريع">
                <span><i class="fas fa-project-diagram" aria-hidden="true"></i><b>المشاريع</b></span>
                <i class="fas fa-chevron-down nav-chevron" aria-hidden="true"></i>
            </button>
            <div class="pos-nav-submenu">
                <a class="pos-nav-link main-erp-nav-link @(isActive("project-extracts") ? "active" : "")"
                   href="@Url.Action("Index", "ProjectExtracts", new { area = "MainErp" })"
                   title="مستخلصات المشاريع">
                    <i class="fas fa-tasks" aria-hidden="true"></i><span>مستخلصات المشاريع</span>
                </a>
            </div>
        </section>

        <section class="pos-nav-section @(lcOpen ? "is-open" : "")">
            <button type="button" class="pos-nav-section-toggle" data-menu-toggle title="الاعتمادات المستندية">
                <span><i class="fas fa-university" aria-hidden="true"></i><b>الاعتمادات المستندية</b></span>
                <i class="fas fa-chevron-down nav-chevron" aria-hidden="true"></i>
            </button>
            <div class="pos-nav-submenu">
                <a class="pos-nav-link main-erp-nav-link @(isActive("lc") ? "active" : "")"
                   href="@Url.Action("Index", "LC", new { area = "MainErp" })"
                   title="شاشة الاعتمادات">
                    <i class="fas fa-landmark" aria-hidden="true"></i><span>شاشة الاعتمادات</span>
                </a>
            </div>
        </section>
    </nav>
</aside>
