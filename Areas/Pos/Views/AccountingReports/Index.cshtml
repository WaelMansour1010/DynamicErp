@model MyERP.Models.Reports.HtmlReportPageViewModel
@{
    var areaName = (ViewBag.AccountingReportsArea as string) ?? "Pos";
    Layout = string.Equals(areaName, "MainErp", StringComparison.OrdinalIgnoreCase) ? "~/Areas/MainErp/Views/Shared/_MainErpLayout.cshtml" : null;
    ViewBag.Title = "تقارير الحسابات";
    var accountTreeUrl = Url.Action("AccountTree", "AccountingReports", new { area = areaName });
    var fromDateText = Model.Filter.FromDate.HasValue ? Model.Filter.FromDate.Value.ToString("yyyy-MM-dd") : "";
    var toDateText = Model.Filter.ToDate.HasValue ? Model.Filter.ToDate.Value.ToString("yyyy-MM-dd") : "";
}
<link href="@Url.Content("~/Areas/Pos/Content/html-reports.css?v=20260520-accounting-clean-ui")" rel="stylesheet" />

<main class="html-report-page erp-ui-page accounting-reports-page" data-account-tree-url="@accountTreeUrl">
    <header class="erp-hero-card">
        <div>
            <h1>تقارير الحسابات</h1>
            <p>شاشة موحدة لعرض تقارير الحسابات من MainErp و POS بنفس الفلاتر والصلاحيات.</p>
        </div>
        <strong>@areaName</strong>
    </header>

    @if (!string.IsNullOrWhiteSpace(Model.Message))
    {
        <section class="erp-alert erp-alert-danger no-print">@Model.Message</section>
    }
    <section id="accountingReportClientMessage" class="erp-alert erp-alert-danger no-print" style="display:none"></section>
    <section id="accountingReportProgress" class="accounting-report-progress no-print" hidden aria-live="polite" aria-busy="true">
        <div class="accounting-progress-head">
            <strong id="accountingProgressTitle">جاري تشغيل التقرير</strong>
            <span id="accountingProgressElapsed">00:00</span>
        </div>
        <div class="accounting-progress-bar"><span></span></div>
        <p id="accountingProgressDetails">يتم تطبيق الفلاتر داخل قاعدة البيانات وتجهيز النتائج...</p>
    </section>

    @using (Html.BeginForm("Search", "AccountingReports", new { area = areaName }, FormMethod.Post, new { id = "accountingReportForm", @class = "erp-report-form no-print" }))
    {
        @Html.HiddenFor(m => m.Filter.ReportKey, new { id = "ReportKey" })
        @Html.HiddenFor(m => m.Filter.AccountCodes, new { id = "SelectedAccountCodes" })
        @Html.HiddenFor(m => m.Filter.AccountFrom)
        @Html.HiddenFor(m => m.Filter.AccountTo)

        <section class="erp-card">
            <div class="erp-card-head">
                <div>
                    <h2>اختر التقرير</h2>
                    <p>اختر التقرير المطلوب، ثم اضبط الفلاتر من الأسفل قبل العرض أو الطباعة أو التصدير.</p>
                </div>
            </div>
            <div class="erp-report-grid">
                @foreach (var report in Model.Reports)
                {
                    var active = string.Equals(report.Key, Model.Filter.ReportKey, StringComparison.OrdinalIgnoreCase);
                    <button type="button" class="erp-report-tile @(active ? "is-active" : "")" data-report-key="@report.Key" aria-pressed="@(active ? "true" : "false")" title="اختيار @report.Title">
                        <span class="erp-report-dot"></span>
                        <strong>@report.Title</strong>
                        <small>@report.Description</small>
                    </button>
                }
            </div>
        </section>

        <section class="erp-card">
            <div class="erp-card-head">
                <div>
                    <h2>فلاتر التقرير</h2>
                    <p>الفلاتر تطبق داخل قاعدة البيانات، والحسابات يتم اختيارها من شجرة الحسابات.</p>
                </div>
            </div>
            <div class="erp-filter-grid">
                <label class="erp-field">
                    <span>من تاريخ</span>
                    @Html.TextBoxFor(m => m.Filter.FromDate, new { type = "text", value = fromDateText, @class = "gregorian-date-input", inputmode = "numeric", autocomplete = "off", placeholder = "yyyy-MM-dd", pattern = "\\d{4}-\\d{2}-\\d{2}" })
                </label>
                <label class="erp-field">
                    <span>إلى تاريخ</span>
                    @Html.TextBoxFor(m => m.Filter.ToDate, new { type = "text", value = toDateText, @class = "gregorian-date-input", inputmode = "numeric", autocomplete = "off", placeholder = "yyyy-MM-dd", pattern = "\\d{4}-\\d{2}-\\d{2}" })
                </label>
                <label class="erp-field">
                    <span>الفرع</span>
                    @Html.DropDownListFor(m => m.Filter.BranchId, new SelectList(Model.Branches, "Id", "Name", Model.Filter.BranchId), "كل الفروع")
                </label>
                <label class="erp-field">
                    <span>النشاط</span>
                    @Html.TextBoxFor(m => m.Filter.ActivityId, new { type = "number", placeholder = "اختياري" })
                </label>
                <label class="erp-field">
                    <span>المنطقة</span>
                    @Html.TextBoxFor(m => m.Filter.RegionId, new { type = "number", placeholder = "اختياري" })
                </label>
                <label class="erp-field">
                    <span>مركز التكلفة</span>
                    @Html.TextBoxFor(m => m.Filter.CostCenterId, new { type = "number", placeholder = "اختياري" })
                </label>
                <label class="erp-field">
                    <span>المشروع</span>
                    @Html.TextBoxFor(m => m.Filter.ProjectId, new { type = "number", placeholder = "اختياري" })
                </label>
                <label class="erp-field">
                    <span>نوع القيد</span>
                    @Html.TextBoxFor(m => m.Filter.NoteType, new { type = "number", placeholder = "اختياري" })
                </label>
                <label class="erp-field">
                    <span>مستوى الحساب</span>
                    @Html.TextBoxFor(m => m.Filter.AccountLevel, new { type = "number", placeholder = "0 = كل المستويات" })
                </label>
                <label class="erp-field">
                    <span>إخفاء الأرصدة الصفرية</span>
                    @Html.CheckBox("Filter.HideZeroBalance", Model.Filter.HideZeroBalance.GetValueOrDefault(true))
                </label>
                <label class="erp-field">
                    <span>تفصيلي</span>
                    @Html.CheckBox("Filter.Detailed", Model.Filter.Detailed.GetValueOrDefault(false))
                </label>
                <div class="erp-account-picker">
                    <div>
                        <strong>الحسابات</strong>
                        <span id="accountTreeSummary">@(string.IsNullOrWhiteSpace(Model.Filter.AccountCodes) ? "لم يتم اختيار حسابات" : "تم اختيار حسابات")</span>
                    </div>
                    <button type="button"
                            class="erp-btn erp-btn-secondary js-account-selector"
                            data-target-input="SelectedAccountCodes"
                            data-summary-target="accountTreeSummary"
                            data-account-tree-url="@accountTreeUrl">
                        اختيار الحسابات
                    </button>
                </div>
            </div>
            <div class="erp-actions">
                <button type="submit" class="erp-btn erp-btn-primary" data-progress-label="جاري تشغيل التقرير">عرض التقرير</button>
                <button type="button" class="erp-btn erp-btn-secondary" id="htmlReportPrintBtn">طباعة</button>
                <button type="submit" class="erp-btn erp-btn-secondary" formaction="@Url.Action("Export", "AccountingReports", new { area = areaName })" data-progress-label="جاري تجهيز ملف Excel" data-export-button="true">تصدير Excel</button>
            </div>
        </section>
    }

    @if (Model.Result != null)
    {
        <section class="erp-card erp-result-card" id="htmlReportResultCard">
            <div class="erp-card-head">
                <div>
                    <h2>@Model.ActiveReport.Title</h2>
                    <p>@Model.ActiveReport.Description</p>
                </div>
                <span class="erp-badge">تقرير حسابات</span>
            </div>
            <div class="filter-summary erp-filter-summary">
                <span>من تاريخ: @(Model.Filter.FromDate.HasValue ? Model.Filter.FromDate.Value.ToString("dd/MM/yyyy") : "-")</span>
                <span>إلى تاريخ: @(Model.Filter.ToDate.HasValue ? Model.Filter.ToDate.Value.ToString("dd/MM/yyyy") : "-")</span>
                <span>عدد السجلات: @Model.Result.Rows.Count</span>
            </div>
            <div class="html-report-table-wrap">
                <table class="html-report-table erp-data-table">
                    <thead>
                        <tr>
                            @foreach (var column in Model.Result.Columns)
                            {
                                <th>@column.Title</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Result.Rows.Count == 0)
                        {
                            <tr><td colspan="@Model.Result.Columns.Count" class="empty-cell">لا توجد بيانات</td></tr>
                        }
                        else
                        {
                            foreach (var row in Model.Result.Rows)
                            {
                                <tr>
                                    @foreach (var column in Model.Result.Columns)
                                    {
                                        var value = row.ContainsKey(column.Key) ? row[column.Key] : null;
                                        <td class="@(column.IsNumeric ? "numeric-cell" : "")">@FormatCell(value)</td>
                                    }
                                </tr>
                            }
                        }
                    </tbody>
                    @if (Model.Result.Totals.Count > 0)
                    {
                        <tfoot>
                            <tr>
                                @for (var i = 0; i < Model.Result.Columns.Count; i++)
                                {
                                    var column = Model.Result.Columns[i];
                                    if (i == 0)
                                    {
                                        <td>الإجمالي</td>
                                    }
                                    else if (column.ShowTotal && Model.Result.Totals.ContainsKey(column.Key))
                                    {
                                        <td class="numeric-cell">@Model.Result.Totals[column.Key].ToString("0.##")</td>
                                    }
                                    else
                                    {
                                        <td></td>
                                    }
                                }
                            </tr>
                        </tfoot>
                    }
                </table>
            </div>
        </section>
    }
    else
    {
        <section class="erp-card erp-empty-state">اختر التقرير والفترة ثم اضغط عرض التقرير.</section>
    }
</main>
<script src="@Url.Content("~/Areas/Pos/Scripts/account-selector.js")"></script>
<script>
(function () {
    var progressTimer = null;
    var progressStartedAt = null;
    var lastSubmitButton = null;
    function byId(id) { return document.getElementById(id); }
    function showClientMessage(message) {
        var box = byId("accountingReportClientMessage");
        if (!box) { return; }
        box.textContent = message || "";
        box.style.display = message ? "block" : "none";
        if (message) { box.scrollIntoView({ behavior: "smooth", block: "center" }); }
    }
    function formatElapsed(ms) {
        var total = Math.max(0, Math.floor(ms / 1000));
        var minutes = Math.floor(total / 60);
        var seconds = total % 60;
        return (minutes < 10 ? "0" : "") + minutes + ":" + (seconds < 10 ? "0" : "") + seconds;
    }
    function setBusy(isBusy) {
        var buttons = document.querySelectorAll(".accounting-reports-page button");
        for (var i = 0; i < buttons.length; i++) {
            if (buttons[i].id === "htmlReportPrintBtn") { continue; }
            buttons[i].disabled = isBusy;
        }
    }
    function isGregorianDate(value) {
        if (!/^\d{4}-\d{2}-\d{2}$/.test(value || "")) { return false; }
        var parts = value.split("-");
        var date = new Date(Number(parts[0]), Number(parts[1]) - 1, Number(parts[2]));
        return date.getFullYear() === Number(parts[0])
            && date.getMonth() === Number(parts[1]) - 1
            && date.getDate() === Number(parts[2]);
    }
    function showProgress(title, details) {
        var progress = byId("accountingReportProgress");
        if (!progress) { return; }
        byId("accountingProgressTitle").textContent = title || "جاري تشغيل التقرير";
        byId("accountingProgressDetails").textContent = details || "يتم تطبيق الفلاتر داخل قاعدة البيانات وتجهيز النتائج...";
        progress.hidden = false;
        progressStartedAt = new Date().getTime();
        byId("accountingProgressElapsed").textContent = "00:00";
        clearInterval(progressTimer);
        progressTimer = setInterval(function () {
            byId("accountingProgressElapsed").textContent = formatElapsed(new Date().getTime() - progressStartedAt);
        }, 500);
        progress.scrollIntoView({ behavior: "smooth", block: "center" });
        setBusy(true);
    }
    function hideProgress() {
        var progress = byId("accountingReportProgress");
        clearInterval(progressTimer);
        progressTimer = null;
        if (progress) { progress.hidden = true; }
        setBusy(false);
    }
    document.addEventListener("click", function (event) {
        var submitButton = event.target && event.target.closest ? event.target.closest('button[type="submit"]') : null;
        if (submitButton) { lastSubmitButton = submitButton; }
        if (event.target && event.target.id === "htmlReportPrintBtn") {
            if (!document.getElementById("htmlReportResultCard")) {
                showClientMessage("شغل التقرير أولا قبل الطباعة.");
                return;
            }
            window.print();
        }
        var option = event.target && event.target.closest ? event.target.closest(".erp-report-tile") : null;
        if (!option) { return; }
        var key = option.getAttribute("data-report-key") || "";
        var input = document.getElementById("ReportKey");
        if (input) { input.value = key; }
        showClientMessage("");
        var options = document.querySelectorAll(".erp-report-tile");
        for (var i = 0; i < options.length; i++) {
            options[i].classList.toggle("is-active", options[i] === option);
            options[i].setAttribute("aria-pressed", options[i] === option ? "true" : "false");
        }
    });
    var form = byId("accountingReportForm");
    if (form) {
        form.addEventListener("submit", function (event) {
            var reportKey = (byId("ReportKey") && byId("ReportKey").value || "").trim();
            if (!reportKey) {
                event.preventDefault();
                showClientMessage("اختر التقرير أولا من الكروت، ثم اضغط عرض التقرير أو تصدير Excel.");
                return false;
            }
            var fromDate = (document.getElementsByName("Filter.FromDate")[0] || {}).value || "";
            var toDate = (document.getElementsByName("Filter.ToDate")[0] || {}).value || "";
            if (!isGregorianDate(fromDate) || !isGregorianDate(toDate)) {
                event.preventDefault();
                showClientMessage("اكتب التاريخ بالميلادي بصيغة yyyy-MM-dd مثل 2026-05-20.");
                return false;
            }
            showClientMessage("");
            var submitter = event.submitter || lastSubmitButton;
            var isExport = submitter && submitter.getAttribute("data-export-button") === "true";
            showProgress(submitter && submitter.getAttribute("data-progress-label"), isExport ? "يتم تجهيز ملف Excel بنفس الفلاتر المختارة..." : "يتم تشغيل Stored Procedure وتطبيق الفلاتر وتجهيز التقرير...");
            if (isExport) {
                window.setTimeout(hideProgress, 5000);
            }
            return true;
        });
    }
})();
</script>

@functions {
    private static string FormatCell(object value)
    {
        if (value == null) { return string.Empty; }
        if (value is DateTime) { return ((DateTime)value).ToString("dd/MM/yyyy"); }
        if (value is decimal) { return ((decimal)value).ToString("0.##"); }
        if (value is double) { return ((double)value).ToString("0.##"); }
        if (value is float) { return ((float)value).ToString("0.##"); }
        return Convert.ToString(value);
    }
}

