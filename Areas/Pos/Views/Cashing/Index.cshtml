@model MyERP.Areas.MainErp.ViewModels.Payments.PaymentVoucherSearchViewModel
@functions {
    private static string FormatVoucherSerial(string value)
    {
        decimal numericValue;
        return !string.IsNullOrWhiteSpace(value)
            && value.IndexOf("e", StringComparison.OrdinalIgnoreCase) >= 0
            && decimal.TryParse(value, System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out numericValue)
            ? numericValue.ToString("0.############################", System.Globalization.CultureInfo.InvariantCulture)
            : value;
    }

    private static bool IsBalancedStatus(string value)
    {
        return !string.IsNullOrWhiteSpace(value)
            && value.IndexOf("غير", StringComparison.OrdinalIgnoreCase) < 0
            && value.IndexOf("متوازن", StringComparison.OrdinalIgnoreCase) >= 0;
    }
}
@{
    Layout = null;
    ViewBag.Title = "سندات القبض";
    var totalValue = Model.Items.Sum(x => x.Total);
    var unbalancedCount = Model.Items.Count(x => !IsBalancedStatus(x.BalancedStatus));
    var showAccountingStatus = unbalancedCount > 0;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title</title>
    <link href="@Url.Content("~/Areas/Pos/Content/pos-transaction.css")" rel="stylesheet" />
    @Html.Partial("~/Areas/Pos/Views/Shared/_VoucherScreenStyles.cshtml")
</head>
<body>
<div class="pos-page voucher-pos-page">
    <section class="pos-panel voucher-pos-panel">
        <header class="voucher-page-header">
            <div>
                <span class="voucher-eyebrow">FrmCashing</span>
                <h2>سندات القبض</h2>
                <p>عرض وتشغيل سندات القبض مع تخصيصات السداد وتتبع القيد المحاسبي من قاعدة POS/Kishny.</p>
            </div>
            <div class="voucher-header-actions">
                <span class="voucher-status is-readonly">تشغيل فعلي</span>
                <a class="primary-action voucher-primary-action" href="@Url.Action("Create", "Cashing", new { area = "Pos" })">إضافة سند قبض</a>
            </div>
        </header>

        <div class="voucher-metric-strip">
            <article><span>عدد النتائج</span><strong>@Model.TotalCount</strong></article>
            <article><span>إجمالي النتائج</span><strong>@totalValue.ToString("N2")</strong></article>
            @if (showAccountingStatus)
            {
                <article><span>قيود غير متوازنة</span><strong>@unbalancedCount</strong></article>
            }
            <article><span>الوضع</span><strong>عرض وحفظ</strong></article>
        </div>

        @using (Html.BeginForm("Index", "Cashing", new { area = "Pos" }, FormMethod.Get, new { @class = "voucher-search-panel" }))
        {
            <label><span>من تاريخ</span><input type="date" name="fromDate" value="@(Model.FromDate.HasValue ? Model.FromDate.Value.ToString("yyyy-MM-dd") : "")" /></label>
            <label><span>إلى تاريخ</span><input type="date" name="toDate" value="@(Model.ToDate.HasValue ? Model.ToDate.Value.ToString("yyyy-MM-dd") : "")" /></label>
            <label><span>رقم السند</span><input type="text" name="serial" value="@Model.Serial" /></label>
            <label><span>الطرف</span><input type="text" name="party" value="@Model.Party" /></label>
            <label><span>الفرع</span><input type="number" name="branchId" value="@Model.BranchId" /></label>
            <label><span>الخزنة / البنك</span><input type="text" name="cashboxOrBank" value="@Model.CashboxOrBank" /></label>
            <label><span>المبلغ</span><input type="number" step="0.01" name="amount" value="@Model.Amount" /></label>
            <button type="submit" class="primary-action">بحث</button>
        }

        <div class="voucher-table-card">
            <div class="voucher-table-title">
                <h3>نتائج البحث</h3>
                <span>@Model.TotalCount سند</span>
            </div>
            <div class="report-result compact-result voucher-table-wrap">
                <table class="voucher-table">
                    <thead><tr><th>رقم السند</th><th>التاريخ</th><th>الطرف</th><th>الخزنة / البنك</th><th>الإجمالي</th>@if (showAccountingStatus) { <th>تنبيه القيد</th> }<th></th></tr></thead>
                    <tbody>
                    @foreach (var item in Model.Items)
                    {
                        var isBalanced = IsBalancedStatus(item.BalancedStatus);
                        <tr>
                            <td><strong>@FormatVoucherSerial(item.NoteSerial)</strong></td>
                            <td>@(item.NoteDate.HasValue ? item.NoteDate.Value.ToString("dd/MM/yyyy") : "")</td>
                            <td>@item.PartyDisplay</td>
                            <td>@item.CashboxOrBankDisplay</td>
                            <td class="voucher-number"><strong>@item.Total.ToString("N2")</strong></td>
                            @if (showAccountingStatus)
                            {
                                <td>@if (!isBalanced) { <span class="voucher-status is-unbalanced">@item.BalancedStatus</span> }</td>
                            }
                            <td>
                                <div class="voucher-row-actions">
                                    <a class="voucher-details-link" href="@Url.Action("Details", "Cashing", new { area = "Pos", id = item.NoteId })">تفاصيل</a>
                                    <a class="voucher-details-link" href="@Url.Action("Edit", "Cashing", new { area = "Pos", id = item.NoteId })">تعديل</a>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (Model.Items.Count == 0) { <tr><td colspan="@(showAccountingStatus ? 7 : 6)" class="voucher-empty">لا توجد نتائج مطابقة.</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="voucher-pager">
            <span>صفحة @Model.Page من @Math.Max(1, (int)Math.Ceiling(Model.TotalCount / (double)Model.PageSize))</span>
            <div>
                @if (Model.HasPreviousPage)
                {
                    <a class="voucher-details-link" href="@Url.Action("Index", "Cashing", new { area = "Pos", fromDate = Model.FromDate.HasValue ? Model.FromDate.Value.ToString("yyyy-MM-dd") : null, toDate = Model.ToDate.HasValue ? Model.ToDate.Value.ToString("yyyy-MM-dd") : null, serial = Model.Serial, party = Model.Party, branchId = Model.BranchId, cashboxOrBank = Model.CashboxOrBank, amount = Model.Amount, page = Model.Page - 1, pageSize = Model.PageSize })">السابق</a>
                }
                @if (Model.HasNextPage)
                {
                    <a class="voucher-details-link" href="@Url.Action("Index", "Cashing", new { area = "Pos", fromDate = Model.FromDate.HasValue ? Model.FromDate.Value.ToString("yyyy-MM-dd") : null, toDate = Model.ToDate.HasValue ? Model.ToDate.Value.ToString("yyyy-MM-dd") : null, serial = Model.Serial, party = Model.Party, branchId = Model.BranchId, cashboxOrBank = Model.CashboxOrBank, amount = Model.Amount, page = Model.Page + 1, pageSize = Model.PageSize })">التالي</a>
                }
            </div>
        </div>
    </section>
</div>
</body>
</html>
