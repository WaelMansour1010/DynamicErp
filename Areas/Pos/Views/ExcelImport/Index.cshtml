@model MyERP.Areas.Pos.Models.PosExcelImportIndexViewModel
@{
    Layout = null;
    var kycRows = ViewBag.KycRows as System.Collections.Generic.IList<MyERP.Areas.Pos.Models.PosKycExcelPreviewRow>;
    var kycCommitResult = ViewBag.KycCommitResult as MyERP.Areas.Pos.Models.PosKycExcelCommitResult;
    var kycErrorMessage = ViewBag.KycErrorMessage as string;
    var kycFileName = ViewBag.KycFileName as string;
    var tokenInvoicePreview = ViewBag.TokenInvoicePreview as MyERP.Areas.Pos.Models.PosKishnyTokenInvoiceImportPreview;
    var tokenInvoiceResult = ViewBag.TokenInvoiceResult as MyERP.Areas.Pos.Models.PosKishnyTokenInvoiceImportResult;
    var tokenInvoiceErrorMessage = ViewBag.TokenInvoiceErrorMessage as string;
    var tokenInvoiceFileName = ViewBag.TokenInvoiceFileName as string;
    ViewBag.Title = "استيراد العمليات من Excel";
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title</title>
    <link href="@Url.Content("~/Areas/Pos/Content/pos-transaction.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Areas/Pos/Content/html-reports.css")" rel="stylesheet" />
    <style>
        .excel-import-page { padding: 18px; background: #f5f7fa; min-height: 100vh; }
        .excel-import-grid { display: grid; grid-template-columns: repeat(4, minmax(160px, 1fr)); gap: 12px; }
        .excel-import-field { display: grid; gap: 6px; }
        .excel-import-field span { color: #475569; font-size: 13px; font-weight: 700; }
        .excel-import-field input,
        .excel-import-field select { border: 1px solid #cbd5e1; border-radius: 6px; padding: 9px 10px; width: 100%; }
        .file-picker { align-items: center; border: 1px dashed #94a3b8; border-radius: 8px; display: flex; gap: 10px; padding: 12px; }
        .file-picker input { width: 100%; }
        .import-note { background: #fff7ed; border: 1px solid #fed7aa; border-radius: 8px; color: #9a3412; padding: 10px 12px; }
        .kyc-import-note { background: #eef6ff; border: 1px solid #bfdbfe; border-radius: 8px; color: #1e3a8a; padding: 10px 12px; }
        .kyc-warning-list { margin: 0; padding-right: 16px; color: #92400e; }
        .status-chip { border-radius: 999px; display: inline-block; font-size: 12px; font-weight: 700; padding: 4px 9px; }
        .status-draft { background: #e0f2fe; color: #075985; }
        .status-ready { background: #dcfce7; color: #166534; }
        .status-rejected { background: #fee2e2; color: #991b1b; }
        .import-progress { background:#e2e8f0; border-radius:999px; display:none; height:10px; margin-top:10px; overflow:hidden; }
        .import-progress span { animation: importMove 1.2s infinite linear; background:#2563eb; display:block; height:100%; width:35%; }
        .import-progress.is-determinate span { animation:none; margin-right:0; transition:width .25s ease; width:0%; }
        @@keyframes importMove { from { margin-right:-35%; } to { margin-right:100%; } }
        @@media (max-width: 900px) { .excel-import-grid { grid-template-columns: 1fr; } }
    </style>
</head>
<body>
<main class="html-report-page erp-ui-page excel-import-page">
    <header class="erp-hero-card">
        <div>
            <h1>استيراد العمليات من Excel</h1>
            <p>معاينة آمنة لشيتات التشغيل اليومية قبل أي حفظ فعلي داخل POS.</p>
        </div>
        <strong>POS Excel</strong>
    </header>

    <section class="erp-card">
        <div class="erp-card-head">
            <div>
                <h2>رفع ومعاينة</h2>
                <p>هذه المرحلة تقرأ الملف وتعرض المطابقة والتحذيرات فقط، ولا تنشئ فواتير.</p>
            </div>
        </div>

        <form method="post" action="@Url.Action("Preview", "ExcelImport", new { area = "Pos" })" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="file-picker">
                <i class="fas fa-file-excel" aria-hidden="true"></i>
                <input type="file" name="excelFile" accept=".xlsx,.xls" required />
            </div>

            <div class="excel-import-grid" style="margin-top:14px;">
                <label class="excel-import-field">
                    <span>استراتيجية مطابقة التوكن</span>
                    <select name="tokenMatchingStrategy">
                        <option value="Sequential">مطابقة متسلسلة</option>
                        <option value="Manual" disabled>مطابقة يدوية - مرحلة لاحقة</option>
                        <option value="Hybrid" disabled>هجين - مرحلة لاحقة</option>
                    </select>
                </label>
            </div>

            <div class="import-note" style="margin-top:14px;">
                سيتم تحديد الفرع تلقائيا من اسم الملف، ثم تحميل مستخدم POS الافتراضي والمخزن والخزنة وطريقة الدفع وأصناف الخدمات وفق إعدادات شاشة POS المعتمدة. لا يتم حفظ أي فاتورة في هذه المرحلة.
            </div>

            <div class="erp-actions erp-actions-inline" style="margin-top:14px;">
                <button type="submit" class="erp-btn erp-btn-primary">
                    <i class="fas fa-search" aria-hidden="true"></i>
                    معاينة الملف
                </button>
            </div>
        </form>
    </section>

    <section class="erp-card">
        <div class="erp-card-head">
            <div>
                <h2>استيراد فواتير كروت كيشني من التوكنات</h2>
                <p>ارفع ملف يحتوي على التوكن والرقم القومي وكود الفرع والتاريخ. سيتم تحديد صنف الكارت من رصيد التوكن في المخزن وإنشاء الفاتورة بنفس مسار شاشة البيع.</p>
            </div>
            <span class="status-chip status-draft">Token invoices</span>
        </div>

        <form method="post" action="@Url.Action("TokenInvoicePreview", "ExcelImport", new { area = "Pos" })" enctype="multipart/form-data" id="tokenInvoicePreviewForm" data-async-preview-url="@Url.Action("StartTokenInvoicePreview", "ExcelImport", new { area = "Pos" })" data-progress-url="@Url.Action("TokenInvoicePreviewProgress", "ExcelImport", new { area = "Pos" })">
            @Html.AntiForgeryToken()
            <div class="file-picker">
                <i class="fas fa-file-excel" aria-hidden="true"></i>
                <input type="file" name="tokenInvoiceExcelFile" accept=".xlsx,.xls" required />
            </div>
            <div class="excel-import-grid" style="margin-top:14px;">
                <label class="excel-import-field">
                    <span>تاريخ افتراضي عند غياب تاريخ الصف</span>
                    <input type="date" name="defaultImportDate" />
                </label>
            </div>
            <div class="kyc-import-note" style="margin-top:14px;">
                الأعمدة تقرأ بمرونة: Token / التوكن / رقم الكارت، National ID / الرقم القومي، Mobile / الموبايل، Full name / اسم العميل، كود الفرع / Branch Code، Date / التاريخ. لن يتم ترحيل أي صف قبل المعاينة.
            </div>
            <div class="erp-actions erp-actions-inline" style="margin-top:14px;">
                <button type="submit" class="erp-btn erp-btn-primary">معاينة فواتير التوكنات</button>
                <a class="erp-btn erp-btn-secondary" href="@Url.Action("DownloadTokenInvoiceTemplate", "ExcelImport", new { area = "Pos" })">تحميل نموذج</a>
            </div>
            <div class="import-progress token-preview-progress"><span></span></div>
            <div class="import-note token-preview-progress-text" style="display:none;margin-top:10px;"></div>
        </form>

        @if (!string.IsNullOrWhiteSpace(tokenInvoiceErrorMessage))
        {
            <div class="import-note" style="margin-top:14px;">@tokenInvoiceErrorMessage</div>
        }

        @if (tokenInvoicePreview != null && tokenInvoicePreview.Rows != null && tokenInvoicePreview.Rows.Count > 0)
        {
            var readyRows = tokenInvoicePreview.Rows.Count(x => x.Status == "Ready");
            var rejectedRows = tokenInvoicePreview.Rows.Count(x => x.Status != "Ready");
            <div class="erp-card-head" style="margin-top:18px;">
                <div>
                    <h2>معاينة فواتير التوكنات</h2>
                    <p>@tokenInvoiceFileName - الإجمالي: @tokenInvoicePreview.Rows.Count - جاهز: @readyRows - مرفوض/يحتاج مراجعة: @rejectedRows</p>
                    <p>الأعمدة المكتشفة: Token=@tokenInvoicePreview.Mapping.TokenColumn، National=@tokenInvoicePreview.Mapping.NationalIdColumn، Mobile=@tokenInvoicePreview.Mapping.MobileColumn، Name=@tokenInvoicePreview.Mapping.FullNameColumn، Branch=@tokenInvoicePreview.Mapping.BranchColumn، Date=@tokenInvoicePreview.Mapping.DateColumn</p>
                </div>
                <div class="erp-actions erp-actions-inline">
                    <a class="erp-btn erp-btn-secondary" href="@Url.Action("ExportTokenInvoiceResult", "ExcelImport", new { area = "Pos", type = "all" })">تصدير المعاينة</a>
                    <a class="erp-btn erp-btn-secondary" href="@Url.Action("ExportTokenInvoiceResult", "ExcelImport", new { area = "Pos", type = "failed" })">تصدير الأخطاء</a>
                </div>
            </div>
            <div class="responsive-table">
                <table class="pos-table">
                    <thead>
                        <tr>
                            <th>الصف</th>
                            <th>الحالة</th>
                            <th>التوكن</th>
                            <th>الرقم القومي</th>
                            <th>الموبايل</th>
                            <th>اسم العميل</th>
                            <th>كود الفرع</th>
                            <th>الفرع</th>
                            <th>التاريخ</th>
                            <th>صنف الكارت</th>
                            <th>KYC</th>
                            <th>ملاحظات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in tokenInvoicePreview.Rows.Take(300))
                        {
                            var statusClass = row.Status == "Ready" ? "status-ready" : "status-rejected";
                            <tr>
                                <td>@row.RowNumber</td>
                                <td><span class="status-chip @statusClass">@row.Status</span></td>
                                <td>@row.Token</td>
                                <td>@row.NationalId</td>
                                <td>@row.Mobile</td>
                                <td>@row.FullName</td>
                                <td>@row.BranchCode</td>
                                <td>@row.BranchName</td>
                                <td>@(row.InvoiceDate.HasValue ? row.InvoiceDate.Value.ToString("yyyy-MM-dd") : "")</td>
                                <td>@(row.CardItemId.HasValue ? row.CardItemId + " - " + row.CardItemName : "")</td>
                                <td>@row.KycStatus</td>
                                <td>@(row.Messages != null ? string.Join(" | ", row.Messages) : "")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <form method="post" action="@Url.Action("TokenInvoiceCommit", "ExcelImport", new { area = "Pos" })" style="margin-top:14px;" id="tokenInvoiceCommitForm" data-start-url="@Url.Action("StartTokenInvoiceCommit", "ExcelImport", new { area = "Pos" })" data-progress-url="@Url.Action("TokenInvoiceCommitProgress", "ExcelImport", new { area = "Pos" })">
                @Html.AntiForgeryToken()
                <div class="excel-import-grid">
                    <label class="excel-import-field">
                        <span>كلمة مرور المستخدم للتنفيذ</span>
                        <input type="password" name="adminPassword" autocomplete="current-password" required />
                    </label>
                </div>
                <div class="erp-actions erp-actions-inline" style="margin-top:14px;">
                    <button type="submit" class="erp-btn erp-btn-primary">ترحيل الصفوف الجاهزة كفواتير كارت</button>
                </div>
                <div class="import-progress token-commit-progress"><span></span></div>
                <div class="kyc-import-note token-commit-progress-text" style="display:none;margin-top:10px;"></div>
                <div class="excel-import-grid token-commit-kpis" style="display:none;margin-top:10px;">
                    <div class="excel-import-field"><span>المعالج</span><strong data-token-commit-processed>0 / 0</strong></div>
                    <div class="excel-import-field"><span>تم ترحيله</span><strong data-token-commit-imported>0</strong></div>
                    <div class="excel-import-field"><span>فشل</span><strong data-token-commit-failed>0</strong></div>
                    <div class="excel-import-field"><span>مكرر</span><strong data-token-commit-skipped>0</strong></div>
                </div>
                <div class="import-note" style="margin-top:10px;">
                    سيتم ترحيل الصفوف الجاهزة فقط. الصف الذي يفشل لا يوقف باقي الصفوف، ولن يتم تعديل KYC متعارض أو بيع توكن مكرر.
                </div>
            </form>
        }

        @if (tokenInvoiceResult != null)
        {
            <div class="erp-card-head" style="margin-top:18px;">
                <div>
                    <h2>نتيجة ترحيل فواتير التوكنات</h2>
                    <p>الإجمالي: @tokenInvoiceResult.TotalRows - فواتير: @tokenInvoiceResult.ImportedInvoicesCount - KYC جديد: @tokenInvoiceResult.CreatedKycCount - KYC موجود: @tokenInvoiceResult.LinkedExistingKycCount - فشل: @tokenInvoiceResult.FailedRowsCount - تكرار توكن: @tokenInvoiceResult.DuplicateTokenCount</p>
                </div>
                <div class="erp-actions erp-actions-inline">
                    <a class="erp-btn erp-btn-secondary" href="@Url.Action("ExportTokenInvoiceResult", "ExcelImport", new { area = "Pos", type = "success" })">تصدير الناجح</a>
                    <a class="erp-btn erp-btn-secondary" href="@Url.Action("ExportTokenInvoiceResult", "ExcelImport", new { area = "Pos", type = "failed" })">تصدير الفاشل</a>
                </div>
            </div>
            <div class="responsive-table">
                <table class="pos-table">
                    <thead>
                        <tr>
                            <th>الحالة</th>
                            <th>الصف</th>
                            <th>التوكن</th>
                            <th>Transaction_ID</th>
                            <th>رقم الفاتورة</th>
                            <th>KYC</th>
                            <th>الرسالة</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in tokenInvoiceResult.Rows)
                        {
                            var statusClass = row.Status == "Imported" ? "status-ready" : "status-rejected";
                            <tr>
                                <td><span class="status-chip @statusClass">@row.Status</span></td>
                                <td>@row.RowNumber</td>
                                <td>@row.Token</td>
                                <td>@row.TransactionId</td>
                                <td>@row.InvoiceNumber</td>
                                <td>@row.KycStatus</td>
                                <td>@(row.Messages != null ? string.Join(" | ", row.Messages) : "")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="erp-card">
        <div class="erp-card-head">
            <div>
                <h2>قسم KYC</h2>
                <p>سحب بيانات العملاء من شيت KYC لمراجعتها قبل تفعيل الكارت من شاشة البيع.</p>
            </div>
            <span class="status-chip status-draft">KYC Excel</span>
        </div>

        <form method="post" action="@Url.Action("KycPreview", "ExcelImport", new { area = "Pos" })" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="file-picker">
                <i class="fas fa-address-card" aria-hidden="true"></i>
                <input type="file" name="kycExcelFile" accept=".xlsx,.xls" required />
            </div>
            <div class="kyc-import-note" style="margin-top:14px;">
                هذا القسم يقرأ نموذج KYC فقط ويعرض بيانات العميل والتوكن والفرع. لا يتم إنشاء عميل أو فاتورة من هنا.
            </div>
            <div class="erp-actions erp-actions-inline" style="margin-top:14px;">
                <button type="submit" class="erp-btn erp-btn-secondary">
                    <i class="fas fa-search" aria-hidden="true"></i>
                    سحب بيانات KYC
                </button>
            </div>
        </form>

        @if (!string.IsNullOrWhiteSpace(kycErrorMessage))
        {
            <div class="import-note" style="margin-top:14px;">@kycErrorMessage</div>
        }

        @if (kycRows != null && kycRows.Count > 0)
        {
            <div class="erp-card-head" style="margin-top:18px;">
                <div>
                    <h2>نتيجة سحب KYC</h2>
                    <p>@kycFileName - عدد الصفوف: @kycRows.Count</p>
                </div>
            </div>
            <div class="responsive-table">
                <table class="pos-table">
                    <thead>
                        <tr>
                            <th>الصف</th>
                            <th>التوكن</th>
                            <th>اسم العميل</th>
                            <th>National ID</th>
                            <th>الموبايل</th>
                            <th>كود الفرع</th>
                            <th>الفرع</th>
                            <th>تاريخ البيع</th>
                            <th>تاريخ الإصدار</th>
                            <th>تاريخ الانتهاء</th>
                            <th>تنبيهات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in kycRows)
                        {
                            var customer = row.Customer;
                            <tr>
                                <td>@row.RowNumber</td>
                                <td>@(customer != null ? customer.CardNo : "")</td>
                                <td>@(customer != null ? customer.CustomerName : "")</td>
                                <td>@(customer != null ? customer.Tet_NumPoket : "")</td>
                                <td>@(customer != null ? customer.Phone2 : "")</td>
                                <td>@row.BranchCode</td>
                                <td>@row.BranchName</td>
                                <td>@(customer != null && customer.OrderDate.HasValue ? customer.OrderDate.Value.ToString("yyyy-MM-dd") : "")</td>
                                <td>@(customer != null && customer.CardDate.HasValue ? customer.CardDate.Value.ToString("yyyy-MM-dd") : "")</td>
                                <td>@(customer != null && customer.CardEndDate.HasValue ? customer.CardEndDate.Value.ToString("yyyy-MM-dd") : "")</td>
                                <td>
                                    @if (row.Warnings != null && row.Warnings.Count > 0)
                                    {
                                        <ul class="kyc-warning-list">
                                            @foreach (var warning in row.Warnings)
                                            {
                                                <li>@warning</li>
                                            }
                                        </ul>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <form method="post" action="@Url.Action("KycCommit", "ExcelImport", new { area = "Pos" })" style="margin-top:14px;" id="kycCommitForm" data-start-url="@Url.Action("StartKycCommit", "ExcelImport", new { area = "Pos" })" data-progress-url="@Url.Action("KycCommitProgress", "ExcelImport", new { area = "Pos" })">
                @Html.AntiForgeryToken()
                <div class="excel-import-grid">
                    <label class="excel-import-field">
                        <span>كلمة مرور المستخدم للتنفيذ</span>
                        <input type="password" name="adminPassword" autocomplete="current-password" required />
                    </label>
                </div>
                <div class="erp-actions erp-actions-inline" style="margin-top:14px;">
                    <button type="submit" class="erp-btn erp-btn-primary">
                        <i class="fas fa-check" aria-hidden="true"></i>
                        حفظ وتفعيل عملاء KYC الجاهزين
                    </button>
                </div>
                <div class="import-progress kyc-commit-progress"><span></span></div>
                <div class="kyc-import-note kyc-commit-progress-text" style="display:none;margin-top:10px;"></div>
                <div class="excel-import-grid kyc-commit-kpis" style="display:none;margin-top:10px;">
                    <div class="excel-import-field"><span>المعالج</span><strong data-kyc-commit-processed>0 / 0</strong></div>
                    <div class="excel-import-field"><span>تم حفظه</span><strong data-kyc-commit-imported>0</strong></div>
                    <div class="excel-import-field"><span>فشل</span><strong data-kyc-commit-failed>0</strong></div>
                </div>
                <div class="kyc-import-note" style="margin-top:10px;">
                    سيتم حفظ كل صف صالح كعميل KYC بنفس منطق تفعيل الكارت الحالي. الصف الذي يفشل لا يوقف باقي الصفوف، وسيظهر سبب الرفض في النتيجة.
                </div>
            </form>
        }

        @if (kycCommitResult != null)
        {
            <div class="erp-card-head" style="margin-top:18px;">
                <div>
                    <h2>نتيجة حفظ KYC</h2>
                    <p>@kycCommitResult.Status - تم: @kycCommitResult.ImportedCount - فشل: @kycCommitResult.FailedCount</p>
                </div>
            </div>
            <div class="responsive-table">
                <table class="pos-table">
                    <thead>
                        <tr>
                            <th>الحالة</th>
                            <th>الصف</th>
                            <th>التوكن</th>
                            <th>اسم العميل</th>
                            <th>رقم العميل</th>
                            <th>الرسالة</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in kycCommitResult.Rows)
                        {
                            var statusClass = row.Status == "Imported" ? "status-ready" : "status-rejected";
                            <tr>
                                <td><span class="status-chip @statusClass">@row.Status</span></td>
                                <td>@row.RowNumber</td>
                                <td>@row.Token</td>
                                <td>@row.CustomerName</td>
                                <td>@row.CustomerId</td>
                                <td>@row.Message</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="erp-card">
        <div class="erp-card-head">
            <div>
                <h2>دفعات الاستيراد السابقة</h2>
                <p>سيتم تفعيل سجل الدفعات مع مرحلة الحفظ والتدقيق.</p>
            </div>
            <span class="status-chip status-draft">Phase 1</span>
        </div>
        <div class="responsive-table">
            <table class="pos-table">
                <thead>
                    <tr>
                        <th>رقم الدفعة</th>
                        <th>الملف</th>
                        <th>الحالة</th>
                        <th>الفواتير</th>
                        <th>المرفوض</th>
                        <th>التاريخ</th>
                        <th>المستخدم</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || Model.Batches == null || Model.Batches.Count == 0)
                    {
                        <tr><td colspan="7">لا توجد دفعات محفوظة في مرحلة المعاينة الحالية.</td></tr>
                    }
                    else
                    {
                        foreach (var batch in Model.Batches)
                        {
                            <tr>
                                <td>@batch.BatchId</td>
                                <td>@batch.SourceFileName</td>
                                <td>@batch.Status</td>
                                <td>@batch.ImportedInvoicesCount</td>
                                <td>@batch.FailedRowsCount</td>
                                <td>@(batch.CreatedAt.HasValue ? batch.CreatedAt.Value.ToString("yyyy-MM-dd HH:mm") : "")</td>
                                <td>@batch.CreatedBy</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </section>
</main>
<script>
    (function () {
        var previewForm = document.getElementById("tokenInvoicePreviewForm");
        if (previewForm && window.FormData && window.fetch) {
            previewForm.addEventListener("submit", function (event) {
                event.preventDefault();
                var form = this;
                var button = form.querySelector('button[type="submit"]');
                var progress = form.querySelector(".token-preview-progress");
                var progressBar = progress ? progress.querySelector("span") : null;
                var progressText = form.querySelector(".token-preview-progress-text");
                var startUrl = form.getAttribute("data-async-preview-url");
                var progressUrl = form.getAttribute("data-progress-url");

                if (progress) {
                    progress.className = progress.className + " is-determinate";
                    progress.style.display = "block";
                }
                if (progressBar) {
                    progressBar.style.width = "1%";
                }
                if (progressText) {
                    progressText.style.display = "block";
                    progressText.innerText = "جاري رفع الملف وبدء المعاينة...";
                }
                if (button) {
                    button.disabled = true;
                    button.innerText = "جاري قراءة الملف...";
                }

                fetch(startUrl, {
                    method: "POST",
                    body: new FormData(form),
                    credentials: "same-origin"
                }).then(function (response) {
                    return response.json();
                }).then(function (data) {
                    if (!data || !data.ok) {
                        throw new Error(data && data.message ? data.message : "تعذر بدء معاينة فواتير التوكنات.");
                    }

                    pollTokenInvoicePreview(data.jobId, progressUrl, progressBar, progressText, button);
                }).catch(function (error) {
                    if (progressText) {
                        progressText.style.display = "block";
                        progressText.innerText = error.message || "تعذر بدء معاينة فواتير التوكنات.";
                    }
                    if (button) {
                        button.disabled = false;
                        button.innerText = "معاينة فواتير التوكنات";
                    }
                });
            });
        }

        function pollTokenInvoicePreview(jobId, progressUrl, progressBar, progressText, button) {
            fetch(progressUrl + "?jobId=" + encodeURIComponent(jobId), {
                credentials: "same-origin"
            }).then(function (response) {
                return response.json();
            }).then(function (data) {
                if (!data || !data.ok) {
                    throw new Error(data && data.message ? data.message : "تعذر متابعة تقدم المعاينة.");
                }

                var percent = Math.max(0, Math.min(100, parseInt(data.percent || 0, 10)));
                if (progressBar) {
                    progressBar.style.width = Math.max(1, percent) + "%";
                }

                if (progressText) {
                    var rowPart = data.totalRows > 0
                        ? " (" + (data.processedRows || 0) + " / " + data.totalRows + " صف)"
                        : "";
                    progressText.innerText = (data.currentMessage || "جاري قراءة الملف...") + rowPart + " - " + percent + "%";
                }

                if (data.isDone) {
                    if (data.isSuccess && data.resultUrl) {
                        window.location.href = data.resultUrl;
                        return;
                    }

                    throw new Error(data.errorMessage || "فشلت معاينة ملف فواتير التوكنات.");
                }

                window.setTimeout(function () {
                    pollTokenInvoicePreview(jobId, progressUrl, progressBar, progressText, button);
                }, 900);
            }).catch(function (error) {
                if (progressText) {
                    progressText.style.display = "block";
                    progressText.innerText = error.message || "تعذر متابعة تقدم المعاينة.";
                }
                if (button) {
                    button.disabled = false;
                    button.innerText = "معاينة فواتير التوكنات";
                }
            });
        }

        var tokenCommitForm = document.getElementById("tokenInvoiceCommitForm");
        if (tokenCommitForm && window.FormData && window.fetch) {
            tokenCommitForm.addEventListener("submit", function (event) {
                event.preventDefault();
                var form = this;
                var button = form.querySelector('button[type="submit"]');
                var progress = form.querySelector(".token-commit-progress");
                var progressBar = progress ? progress.querySelector("span") : null;
                var progressText = form.querySelector(".token-commit-progress-text");
                var kpis = form.querySelector(".token-commit-kpis");
                var startUrl = form.getAttribute("data-start-url");
                var progressUrl = form.getAttribute("data-progress-url");

                if (progress) {
                    progress.className = progress.className + " is-determinate";
                    progress.style.display = "block";
                }
                if (progressBar) {
                    progressBar.style.width = "1%";
                }
                if (progressText) {
                    progressText.style.display = "block";
                    progressText.innerText = "جاري بدء ترحيل فواتير التوكنات...";
                }
                if (kpis) {
                    kpis.style.display = "grid";
                }
                if (button) {
                    button.disabled = true;
                    button.innerText = "جاري الترحيل...";
                }

                fetch(startUrl, {
                    method: "POST",
                    body: new FormData(form),
                    credentials: "same-origin"
                }).then(function (response) {
                    return response.json();
                }).then(function (data) {
                    if (!data || !data.ok) {
                        throw new Error(data && data.message ? data.message : "تعذر بدء ترحيل فواتير التوكنات.");
                    }

                    pollTokenInvoiceCommit(data.jobId, progressUrl, form, progressBar, progressText, button);
                }).catch(function (error) {
                    if (progressText) {
                        progressText.style.display = "block";
                        progressText.innerText = error.message || "تعذر بدء ترحيل فواتير التوكنات.";
                    }
                    if (button) {
                        button.disabled = false;
                        button.innerText = "ترحيل الصفوف الجاهزة كفواتير كارت";
                    }
                });
            });
        }

        function pollTokenInvoiceCommit(jobId, progressUrl, form, progressBar, progressText, button) {
            fetch(progressUrl + "?jobId=" + encodeURIComponent(jobId), {
                credentials: "same-origin"
            }).then(function (response) {
                return response.json();
            }).then(function (data) {
                if (!data || !data.ok) {
                    throw new Error(data && data.message ? data.message : "تعذر متابعة تقدم الترحيل.");
                }

                var percent = Math.max(0, Math.min(100, parseInt(data.percent || 0, 10)));
                if (progressBar) {
                    progressBar.style.width = Math.max(1, percent) + "%";
                }

                var processed = form.querySelector("[data-token-commit-processed]");
                var imported = form.querySelector("[data-token-commit-imported]");
                var failed = form.querySelector("[data-token-commit-failed]");
                var skipped = form.querySelector("[data-token-commit-skipped]");
                if (processed) { processed.innerText = (data.processedCount || 0) + " / " + (data.totalCount || 0); }
                if (imported) { imported.innerText = data.importedCount || 0; }
                if (failed) { failed.innerText = data.failedCount || 0; }
                if (skipped) { skipped.innerText = data.skippedCount || 0; }

                if (progressText) {
                    var rowPart = data.totalCount > 0
                        ? " (" + (data.processedCount || 0) + " / " + data.totalCount + " صف)"
                        : "";
                    var tokenPart = data.currentServiceType ? " - التوكن: " + data.currentServiceType : "";
                    progressText.innerText = (data.currentMessage || "جاري الترحيل...") + rowPart + tokenPart + " - " + percent + "%";
                }

                if (data.isDone) {
                    if (data.resultUrl) {
                        window.location.href = data.resultUrl;
                        return;
                    }

                    if (button) {
                        button.disabled = false;
                        button.innerText = "ترحيل الصفوف الجاهزة كفواتير كارت";
                    }
                    return;
                }

                window.setTimeout(function () {
                    pollTokenInvoiceCommit(jobId, progressUrl, form, progressBar, progressText, button);
                }, 900);
            }).catch(function (error) {
                if (progressText) {
                    progressText.style.display = "block";
                    progressText.innerText = error.message || "تعذر متابعة تقدم الترحيل.";
                }
                if (button) {
                    button.disabled = false;
                    button.innerText = "ترحيل الصفوف الجاهزة كفواتير كارت";
                }
            });
        }

        var kycCommitForm = document.getElementById("kycCommitForm");
        if (kycCommitForm && window.FormData && window.fetch) {
            kycCommitForm.addEventListener("submit", function (event) {
                event.preventDefault();
                var form = this;
                var button = form.querySelector('button[type="submit"]');
                var progress = form.querySelector(".kyc-commit-progress");
                var progressBar = progress ? progress.querySelector("span") : null;
                var progressText = form.querySelector(".kyc-commit-progress-text");
                var kpis = form.querySelector(".kyc-commit-kpis");
                var startUrl = form.getAttribute("data-start-url");
                var progressUrl = form.getAttribute("data-progress-url");

                if (progress) {
                    progress.className = progress.className + " is-determinate";
                    progress.style.display = "block";
                }
                if (progressBar) {
                    progressBar.style.width = "1%";
                }
                if (progressText) {
                    progressText.style.display = "block";
                    progressText.innerText = "جاري بدء حفظ بيانات KYC...";
                }
                if (kpis) {
                    kpis.style.display = "grid";
                }
                if (button) {
                    button.disabled = true;
                    button.innerText = "جاري الحفظ...";
                }

                fetch(startUrl, {
                    method: "POST",
                    body: new FormData(form),
                    credentials: "same-origin"
                }).then(function (response) {
                    return response.json();
                }).then(function (data) {
                    if (!data || !data.ok) {
                        throw new Error(data && data.message ? data.message : "تعذر بدء حفظ بيانات KYC.");
                    }

                    pollKycCommit(data.jobId, progressUrl, form, progressBar, progressText, button);
                }).catch(function (error) {
                    if (progressText) {
                        progressText.style.display = "block";
                        progressText.innerText = error.message || "تعذر بدء حفظ بيانات KYC.";
                    }
                    if (button) {
                        button.disabled = false;
                        button.innerText = "حفظ وتفعيل عملاء KYC الجاهزين";
                    }
                });
            });
        }

        function pollKycCommit(jobId, progressUrl, form, progressBar, progressText, button) {
            fetch(progressUrl + "?jobId=" + encodeURIComponent(jobId), {
                credentials: "same-origin"
            }).then(function (response) {
                return response.json();
            }).then(function (data) {
                if (!data || !data.ok) {
                    throw new Error(data && data.message ? data.message : "تعذر متابعة تقدم حفظ KYC.");
                }

                var percent = Math.max(0, Math.min(100, parseInt(data.percent || 0, 10)));
                if (progressBar) {
                    progressBar.style.width = Math.max(1, percent) + "%";
                }

                var processed = form.querySelector("[data-kyc-commit-processed]");
                var imported = form.querySelector("[data-kyc-commit-imported]");
                var failed = form.querySelector("[data-kyc-commit-failed]");
                if (processed) { processed.innerText = (data.processedCount || 0) + " / " + (data.totalCount || 0); }
                if (imported) { imported.innerText = data.importedCount || 0; }
                if (failed) { failed.innerText = data.failedCount || 0; }

                if (progressText) {
                    var rowPart = data.totalCount > 0
                        ? " (" + (data.processedCount || 0) + " / " + data.totalCount + " صف)"
                        : "";
                    var tokenPart = data.currentServiceType ? " - التوكن: " + data.currentServiceType : "";
                    progressText.innerText = (data.currentMessage || "جاري حفظ KYC...") + rowPart + tokenPart + " - " + percent + "%";
                }

                if (data.isDone) {
                    if (data.resultUrl) {
                        window.location.href = data.resultUrl;
                        return;
                    }

                    if (button) {
                        button.disabled = false;
                        button.innerText = "حفظ وتفعيل عملاء KYC الجاهزين";
                    }
                    return;
                }

                window.setTimeout(function () {
                    pollKycCommit(jobId, progressUrl, form, progressBar, progressText, button);
                }, 900);
            }).catch(function (error) {
                if (progressText) {
                    progressText.style.display = "block";
                    progressText.innerText = error.message || "تعذر متابعة تقدم حفظ KYC.";
                }
                if (button) {
                    button.disabled = false;
                    button.innerText = "حفظ وتفعيل عملاء KYC الجاهزين";
                }
            });
        }

        var forms = document.querySelectorAll('form[action*="TokenInvoice"]');
        for (var i = 0; i < forms.length; i++) {
            forms[i].addEventListener("submit", function () {
                if ((this.id === "tokenInvoicePreviewForm" || this.id === "tokenInvoiceCommitForm") && window.FormData && window.fetch) {
                    return;
                }

                var progress = this.querySelector(".import-progress");
                var button = this.querySelector('button[type="submit"]');
                if (progress) { progress.style.display = "block"; }
                if (button) {
                    button.disabled = true;
                    button.innerText = "جاري التنفيذ...";
                }
            });
        }
    })();
</script>
</body>
</html>
