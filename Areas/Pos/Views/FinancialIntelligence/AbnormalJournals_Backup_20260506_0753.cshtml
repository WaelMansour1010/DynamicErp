@model MyERP.Areas.Pos.Models.PosFinancialIntelligencePageModel
@{
    Layout = null;
    ViewBag.Title = "اكتشاف القيود غير الطبيعية";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title</title>
    <link href="@Url.Content("~/Areas/Pos/Content/financial-intelligence.css")" rel="stylesheet" />
</head>
<body data-fi-endpoint="@Url.Action("AbnormalJournalsData", "FinancialIntelligence", new { area = "Pos" })"
      data-fi-mode="diagnostic">
    <main class="fi-page">
        @Html.Partial("_Nav", Model, new ViewDataDictionary { { "Active", "journals" } })
        <section class="fi-filter">
            @Html.Partial("_Filters", Model)
            <label class="fi-field"><span>رقم المستخدم</span><input type="number" data-fi-user placeholder="اختياري" /></label>
            <div class="fi-actions"><button type="button" class="fi-btn fi-btn-primary" data-fi-load>اكتشاف القيود</button></div>
        </section>
        <div data-fi-error></div>
        <section class="fi-panel">
            <h2>قيود تستحق التحقيق</h2>
            <div data-fi-main-table></div>
        </section>
    </main>
    <script src="@Url.Content("~/assets/libs/chart-js/Chart.bundle.min.js")"></script>
    <script src="@Url.Content("~/Areas/Pos/Scripts/financial-intelligence.js")"></script>
</body>
</html>
