@model MyERP.Areas.Pos.Models.PosFinancialIntelligencePageModel
@{
    Layout = null;
    ViewBag.Title = "لوحة المؤشرات المالية";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title</title>
    <link href="@Url.Content("~/assets/css/Courses/css/fontawesome-all.min.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Areas/Pos/Content/financial-intelligence.css")" rel="stylesheet" />
</head>
<body data-fi-endpoint="@Url.Action("DashboardData", "FinancialIntelligence", new { area = "Pos" })"
      data-fi-root-url="@Url.Action("RootCause", "FinancialIntelligence", new { area = "Pos" })"
      data-fi-journal-details-url="@Url.Action("JournalDetails", "FinancialIntelligence", new { area = "Pos" })"
      data-fi-journal-url="@Url.Content("~/Pos/JournalEntries/Index")"
      data-fi-account-url="@Url.Content("~/Pos/AccountingReports/Index")"
      data-fi-source-url="@Url.Content("~/Pos/PosTransaction/Index")"
      data-fi-mode="dashboard"
      data-fi-autoload="true">
    <main class="fi-page">
        @Html.Partial("_Nav", Model, new ViewDataDictionary { { "Active", "index" } })
        <section class="fi-filter">
            @Html.Partial("_Filters", Model)
            <label class="fi-field"><span>رقم المستخدم</span><input type="number" data-fi-user placeholder="اختياري" /></label>
            <label class="fi-field"><span>Serial ذمم الموظفين</span><input type="number" data-fi-receivable-parent placeholder="اختياري" /></label>
            <label class="fi-field"><span>Serial العهد والسلف</span><input type="number" data-fi-custody-parent placeholder="اختياري" /></label>
            <div class="fi-actions">
                <button type="button" class="fi-btn fi-btn-primary" data-fi-load><i class="fas fa-sync-alt"></i>تحميل المؤشرات</button>
                <button type="button" class="fi-btn" data-fi-export><i class="fas fa-file-excel"></i>تصدير Excel</button>
            </div>
        </section>
        <div data-fi-error></div>
        <section class="fi-kpis" data-fi-kpis></section>
        <section class="fi-grid">
            <article class="fi-panel"><h2>اتجاه الحركة المالية</h2><div class="fi-chart-box"><canvas data-fi-chart></canvas></div></article>
            <article class="fi-panel"><h2>ترتيب الفروع</h2><div data-fi-main-table></div></article>
            <article class="fi-panel"><h2>أعلى حسابات المصروفات</h2><div data-fi-side-table></div></article>
            <article class="fi-panel"><h2>تنبيهات تحتاج مراجعة</h2><div data-fi-extra-table></div></article>
        </section>
    </main>
    <script src="@Url.Content("~/assets/libs/chart-js/Chart.bundle.min.js")"></script>
    <script src="@Url.Content("~/Areas/Pos/Scripts/financial-intelligence.js")"></script>
</body>
</html>
