@model MyERP.Areas.Pos.Models.PosFinancialIntelligencePageModel
@{
    Layout = null;
    ViewBag.Title = "تحليل سبب المشكلة";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title</title>
    <link href="@Url.Content("~/assets/css/Courses/css/fontawesome-all.min.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Areas/Pos/Content/financial-intelligence.css?v=20260506-clean")" rel="stylesheet" />
</head>
<body data-fi-endpoint="@Url.Action("RootCauseData", "FinancialIntelligence", new { area = "Pos" })"
      data-fi-mode="root"
      data-fi-journal-details-url="@Url.Action("JournalDetails", "FinancialIntelligence", new { area = "Pos" })"
      data-fi-journal-url="@Url.Content("~/Pos/JournalEntries/Index")"
      data-fi-account-url="@Url.Content("~/Pos/AccountingReports/Index")"
      data-fi-source-url="@Url.Content("~/Pos/PosTransaction/Index")"
      data-fi-autoload="@(string.IsNullOrWhiteSpace(Model.InitialAccountCode) ? "false" : "true")">
    <main class="fi-page">
        @Html.Partial("_Nav", Model, new ViewDataDictionary { { "Active", "root" } })
        <section class="fi-filter">
            @Html.Partial("_Filters", Model)
            <label class="fi-field"><span>كود الحساب</span><input type="text" data-fi-account value="@Model.InitialAccountCode" required /></label>
            <div class="fi-actions">
                <button type="button" class="fi-btn fi-btn-primary" data-fi-load><i class="fas fa-search"></i>تحليل السبب</button>
                <button type="button" class="fi-btn" data-fi-export><i class="fas fa-file-excel"></i>تصدير Excel</button>
            </div>
        </section>
        <div data-fi-error></div>
        <section class="fi-alert" data-fi-explanation></section>
        <section class="fi-grid">
            <article class="fi-panel fi-panel-wide"><h2>تطور الرصيد وتحليل الانحرافات المحاسبية</h2><div class="fi-chart-box"><canvas data-fi-chart></canvas></div><div data-fi-main-table></div></article>
            <article class="fi-panel"><h2>أكبر الحركات المؤثرة</h2><div data-fi-side-table></div></article>
            <article class="fi-panel"><h2>المستخدمون والفروع الأكثر تأثيرا</h2><div data-fi-extra-table></div></article>
        </section>
    </main>
    <script src="@Url.Content("~/assets/libs/chart-js/Chart.bundle.min.js")"></script>
    <script src="@Url.Content("~/Areas/Pos/Scripts/financial-intelligence.js?v=20260506-clean")"></script>
</body>
</html>
