@model MyERP.Areas.Pos.Models.PosFinancialIntelligencePageModel
@{
    Layout = null;
    ViewBag.Title = "Root Cause Analyzer";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title</title>
    <link href="@Url.Content("~/Areas/Pos/Content/financial-intelligence.css")" rel="stylesheet" />
</head>
<body data-fi-endpoint="@Url.Action("RootCauseData", "FinancialIntelligence", new { area = "Pos" })"
      data-fi-mode="root"
      data-fi-autoload="@(string.IsNullOrWhiteSpace(Model.InitialAccountCode) ? "false" : "true")">
    <main class="fi-page">
        @Html.Partial("_Nav", Model, new ViewDataDictionary { { "Active", "root" } })
        <section class="fi-filter">
            @Html.Partial("_Filters", Model)
            <label class="fi-field"><span>كود الحساب</span><input type="text" data-fi-account value="@Model.InitialAccountCode" required /></label>
            <div class="fi-actions"><button type="button" class="fi-btn fi-btn-primary" data-fi-load>Analyze Problem</button></div>
        </section>
        <div data-fi-error></div>
        <section class="fi-alert" data-fi-explanation></section>
        <section class="fi-grid">
            <article class="fi-panel"><h2>تطور الرصيد وعلامات الشذوذ</h2><div class="fi-chart-box"><canvas data-fi-chart></canvas></div><div data-fi-main-table></div></article>
            <article class="fi-panel"><h2>أكبر القيود والأطراف المؤثرة</h2><div data-fi-side-table></div></article>
        </section>
    </main>
    <script src="@Url.Content("~/assets/libs/chart-js/Chart.bundle.min.js")"></script>
    <script src="@Url.Content("~/Areas/Pos/Scripts/financial-intelligence.js")"></script>
</body>
</html>
