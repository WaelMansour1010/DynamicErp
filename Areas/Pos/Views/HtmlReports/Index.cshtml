@model MyERP.Models.Reports.HtmlReportPageViewModel
@{
    Layout = null;
    ViewBag.Title = Model.PageTitle;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title</title>
    <link href="@Url.Content("~/Areas/Pos/Content/html-reports.css")" rel="stylesheet" />
</head>
<body>
    <main class="html-report-page" data-lookup-url="@Url.Action("Lookups", "HtmlReports", new { area = "Pos" })">
        <header class="html-report-header">
            <div>
                <h1>&#1575;&#1604;&#1578;&#1602;&#1575;&#1585;&#1610;&#1585; &#1575;&#1604;&#1584;&#1603;&#1610;&#1577;</h1>
                <p>&#1578;&#1602;&#1575;&#1585;&#1610;&#1585; &#1578;&#1588;&#1594;&#1610;&#1604;&#1610;&#1577; &#1582;&#1601;&#1610;&#1601;&#1577; &#1602;&#1575;&#1576;&#1604;&#1577; &#1604;&#1604;&#1591;&#1576;&#1575;&#1593;&#1577; &#1608;&#1575;&#1604;&#1578;&#1589;&#1583;&#1610;&#1585;</p>
            </div>
            <strong>Dynamic ERP</strong>
        </header>

        <section class="html-report-card no-print">
            @Html.Partial("~/Areas/Pos/Views/HtmlReports/Shared/_FilterToolbar.cshtml", Model)
        </section>

        @if (Model.Result != null)
        {
            <section class="html-report-card" id="htmlReportResultCard" data-report-key="@Model.Filter.ReportKey">
                <div class="html-report-title">
                    <div>
                        <h2>@Model.ActiveReport.Title</h2>
                        <p>@Model.ActiveReport.Description</p>
                    </div>
                    <span>&#1578;&#1602;&#1585;&#1610;&#1585; &#1578;&#1588;&#1594;&#1610;&#1604;&#1610;</span>
                </div>

                <div class="filter-summary">
                    <span>&#1605;&#1606; &#1578;&#1575;&#1585;&#1610;&#1582;: @(Model.Filter.FromDate.HasValue ? Model.Filter.FromDate.Value.ToString("yyyy-MM-dd") : "-")</span>
                    <span>&#1573;&#1604;&#1609; &#1578;&#1575;&#1585;&#1610;&#1582;: @(Model.Filter.ToDate.HasValue ? Model.Filter.ToDate.Value.ToString("yyyy-MM-dd") : "-")</span>
                    <span>&#1593;&#1583;&#1583; &#1575;&#1604;&#1587;&#1580;&#1604;&#1575;&#1578;: @Model.Result.Rows.Count</span>
                </div>

                @Html.Partial("~/Areas/Pos/Views/HtmlReports/Shared/_ReportActions.cshtml", Model)

                <div class="html-report-table-wrap">
                    <table class="html-report-table">
                        <thead>
                            <tr>
                                @foreach (var column in Model.Result.Columns)
                                {
                                    <th>@column.Title</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Result.Rows.Count == 0)
                            {
                                <tr>
                                    <td colspan="@Model.Result.Columns.Count" class="empty-cell">&#1604;&#1575; &#1578;&#1608;&#1580;&#1583; &#1576;&#1610;&#1575;&#1606;&#1575;&#1578;</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var row in Model.Result.Rows)
                                {
                                    <tr>
                                        @foreach (var column in Model.Result.Columns)
                                        {
                                            var value = row.ContainsKey(column.Key) ? row[column.Key] : null;
                                            <td class="@(column.IsNumeric ? "numeric-cell" : "")">@FormatCell(value)</td>
                                        }
                                    </tr>
                                }
                            }
                        </tbody>
                        @if (Model.Result.Totals.Count > 0)
                        {
                            <tfoot>
                                <tr>
                                    @foreach (var column in Model.Result.Columns)
                                    {
                                        if (column == Model.Result.Columns.First())
                                        {
                                            <td>&#1575;&#1604;&#1573;&#1580;&#1605;&#1575;&#1604;&#1610;</td>
                                        }
                                        else if (column.ShowTotal && Model.Result.Totals.ContainsKey(column.Key))
                                        {
                                            <td class="numeric-cell">@Model.Result.Totals[column.Key].ToString("0.##")</td>
                                        }
                                        else
                                        {
                                            <td></td>
                                        }
                                    }
                                </tr>
                            </tfoot>
                        }
                    </table>
                </div>
            </section>
        }
        else
        {
            <section class="html-report-card empty-state">
                &#1575;&#1582;&#1578;&#1585; &#1575;&#1604;&#1578;&#1602;&#1585;&#1610;&#1585; &#1608;&#1575;&#1604;&#1601;&#1578;&#1585;&#1577; &#1579;&#1605; &#1575;&#1590;&#1594;&#1591; &#1576;&#1581;&#1579;.
            </section>
        }
    </main>

    <script>
        (function () {
            function enhanceSelectSearch(select, placeholder) {
                if (!select || select.getAttribute("data-enhanced") === "true") { return; }
                select.setAttribute("data-enhanced", "true");
                var parent = select.parentNode;
                var wrap = document.createElement("span");
                wrap.className = "html-smart-select";
                parent.insertBefore(wrap, select);
                wrap.appendChild(select);
                var input = document.createElement("input");
                input.type = "text";
                input.className = "html-smart-select-input";
                input.placeholder = placeholder || "اكتب للبحث";
                input.autocomplete = "off";
                var results = document.createElement("div");
                results.className = "html-smart-select-results";
                wrap.insertBefore(input, select);
                wrap.appendChild(results);
                function text(opt) { return opt ? (opt.textContent || opt.innerText || "").trim() : ""; }
                function sync() { input.value = select.value ? text(select.options[select.selectedIndex]) : ""; }
                function close() { results.classList.remove("is-open"); }
                function choose(opt) {
                    select.value = opt.value;
                    sync();
                    close();
                    select.dispatchEvent(new Event("change"));
                }
                function render() {
                    var term = input.value.trim().toLowerCase();
                    var opts = Array.prototype.slice.call(select.options).filter(function (opt) {
                        if (!opt.value) { return term.length === 0; }
                        return text(opt).toLowerCase().indexOf(term) >= 0 || String(opt.value).toLowerCase().indexOf(term) >= 0;
                    }).slice(0, 40);
                    results.innerHTML = "";
                    if (!opts.length) {
                        var empty = document.createElement("div");
                        empty.className = "html-smart-select-option is-empty";
                        empty.textContent = "لا توجد نتائج";
                        results.appendChild(empty);
                    } else {
                        opts.forEach(function (opt) {
                            var row = document.createElement("button");
                            row.type = "button";
                            row.className = "html-smart-select-option";
                            row.textContent = text(opt);
                            row.addEventListener("mousedown", function (event) {
                                event.preventDefault();
                                choose(opt);
                            });
                            results.appendChild(row);
                        });
                    }
                    results.classList.add("is-open");
                }
                input.addEventListener("input", render);
                input.addEventListener("focus", render);
                input.addEventListener("blur", function () { window.setTimeout(close, 150); });
                sync();
            }

            function loadLookup(select, type, extra) {
                var page = document.querySelector(".html-report-page");
                if (!page || !select || select.getAttribute("data-loaded") === "true" || select.getAttribute("data-loading") === "true") { return; }
                select.setAttribute("data-loading", "true");
                var url = page.getAttribute("data-lookup-url") + "?type=" + encodeURIComponent(type || "");
                if (extra && extra.branchId) {
                    url += "&branchId=" + encodeURIComponent(extra.branchId);
                }

                var xhr = new XMLHttpRequest();
                xhr.open("GET", url, true);
                xhr.onreadystatechange = function () {
                    if (xhr.readyState !== 4) { return; }
                    select.removeAttribute("data-loading");
                    var data = null;
                    try { data = xhr.responseText ? JSON.parse(xhr.responseText) : null; } catch (ignore) { }
                    if (xhr.status < 200 || xhr.status >= 300 || !data || !data.success || !data.rows) { return; }

                    var current = select.value;
                    for (var i = 0; i < data.rows.length; i++) {
                        var row = data.rows[i];
                        if (select.querySelector('option[value="' + String(row.id).replace(/"/g, '\\"') + '"]')) { continue; }
                        var option = document.createElement("option");
                        option.value = row.id;
                        option.textContent = row.name;
                        select.appendChild(option);
                    }
                    select.value = current;
                    select.setAttribute("data-loaded", "true");
                    var lookupInput = select.parentNode ? select.parentNode.querySelector(".html-smart-select-input") : null;
                    if (lookupInput) { lookupInput.dispatchEvent(new Event("input")); }
                };
                xhr.send();
            }

            function lazyLookup(select, type, extraFactory) {
                if (!select) { return; }
                function run() {
                    loadLookup(select, type, typeof extraFactory === "function" ? extraFactory() : null);
                }
                select.addEventListener("focus", run);
                select.addEventListener("mousedown", run);
                var input = select.parentNode ? select.parentNode.querySelector(".html-smart-select-input") : null;
                if (input) {
                    input.addEventListener("focus", run);
                    input.addEventListener("input", run);
                }
            }

            enhanceSelectSearch(document.querySelector("select[name='BranchId']"), "اكتب اسم الفرع أو الكود");
            enhanceSelectSearch(document.querySelector("select[name='StoreId']"), "اكتب اسم المخزن أو الكود");
            lazyLookup(document.querySelector("select[name='BranchId']"), "branches");
            lazyLookup(document.querySelector("select[name='StoreId']"), "stores", function () {
                var branch = document.querySelector("select[name='BranchId']");
                return { branchId: branch ? branch.value : "" };
            });
            var branchSelect = document.querySelector("select[name='BranchId']");
            if (branchSelect) {
                branchSelect.addEventListener("change", function () {
                    var store = document.querySelector("select[name='StoreId']");
                    if (!store) { return; }
                    store.setAttribute("data-loaded", "false");
                    while (store.options.length > 1) { store.remove(1); }
                    var input = store.parentNode ? store.parentNode.querySelector(".html-smart-select-input") : null;
                    if (input) { input.value = ""; }
                });
            }

            var filterForm = document.getElementById("htmlReportFilterForm");
            if (filterForm) {
                filterForm.addEventListener("submit", function (event) {
                    var reportKey = document.getElementById("ReportKey");
                    var searchButton = document.getElementById("htmlReportSearchBtn");
                    var progress = document.getElementById("htmlReportProgress");

                    if (!reportKey || !reportKey.value) {
                        event.preventDefault();
                        if (progress) {
                            progress.textContent = "اختر التقرير أولا";
                        }
                        return;
                    }

                    if (searchButton && searchButton.disabled) {
                        event.preventDefault();
                        return;
                    }

                    if (searchButton) {
                        searchButton.disabled = true;
                        searchButton.textContent = "جاري التجهيز...";
                    }

                    if (progress) {
                        progress.textContent = "جاري تجهيز التقرير...";
                    }
                });
            }

            document.addEventListener("click", function (event) {
                if (event.target && event.target.id === "htmlReportPrintBtn") {
                    window.print();
                }
            });

            function applyReportSelection(option) {
                if (!option) { return; }

                var reportKey = option.getAttribute("data-report-key") || "";
                var reportKeyInput = document.getElementById("ReportKey");
                if (reportKeyInput) {
                    reportKeyInput.value = reportKey;
                }

                var options = document.querySelectorAll(".html-report-option");
                for (var i = 0; i < options.length; i++) {
                    var isActive = options[i] === option;
                    options[i].classList.toggle("is-active", isActive);
                    options[i].setAttribute("aria-pressed", isActive ? "true" : "false");
                }

                var supportsStore = option.getAttribute("data-supports-store") === "true";
                var storeFilters = document.querySelectorAll(".store-only-filter");
                for (var j = 0; j < storeFilters.length; j++) {
                    storeFilters[j].style.display = supportsStore ? "" : "none";
                }

                var resultCard = document.getElementById("htmlReportResultCard");
                if (resultCard && resultCard.getAttribute("data-report-key") !== reportKey) {
                    resultCard.classList.add("is-hidden-ui");
                }
            }

            document.addEventListener("click", function (event) {
                var option = event.target && event.target.closest ? event.target.closest(".html-report-option") : null;
                if (option) {
                    applyReportSelection(option);
                }
            });
        })();
    </script>
</body>
</html>

@functions {
    private static string FormatCell(object value)
    {
        if (value == null)
        {
            return string.Empty;
        }

        if (value is DateTime)
        {
            return ((DateTime)value).ToString("dd/MM/yyyy");
        }

        if (value is decimal)
        {
            return ((decimal)value).ToString("0.##");
        }

        if (value is double)
        {
            return ((double)value).ToString("0.##");
        }

        if (value is float)
        {
            return ((float)value).ToString("0.##");
        }

        var text = Convert.ToString(value);
        if (!string.IsNullOrWhiteSpace(text))
        {
            text = text.Trim();
            var match = System.Text.RegularExpressions.Regex.Match(text, @"\/Date\((-?\d+)(?:[+-]\d+)?\)\/");
            long milliseconds;
            if (match.Success && long.TryParse(match.Groups[1].Value, out milliseconds))
            {
                return new DateTime(1970, 1, 1).AddMilliseconds(milliseconds).ToLocalTime().ToString("dd/MM/yyyy");
            }
        }

        return text;
    }
}
