@model MyERP.Models.Reports.HtmlReportPageViewModel
@{ var showStore = Model.ActiveReport != null && Model.ActiveReport.SupportsStoreFilter; }

@using (Html.BeginForm("Search", "HtmlReports", new { area = "Pos" }, FormMethod.Post, new { @class = "html-report-filters", id = "htmlReportFilterForm" }))
{
    <input type="hidden" id="ReportKey" name="ReportKey" value="@Model.Filter.ReportKey" />

    <div class="html-report-picker">
        <div class="html-report-picker-head">
            <span>&#1575;&#1582;&#1578;&#1585; &#1575;&#1604;&#1578;&#1602;&#1585;&#1610;&#1585;</span>
            <small>&#1575;&#1590;&#1594;&#1591; &#1593;&#1604;&#1609; &#1575;&#1604;&#1578;&#1602;&#1585;&#1610;&#1585; &#1579;&#1605; &#1576;&#1581;&#1579;</small>
        </div>
        <div class="html-report-picker-grid" role="listbox" aria-label="Reports">
            @foreach (var report in Model.Reports)
            {
                var isActive = string.Equals(Model.Filter.ReportKey, report.Key, StringComparison.OrdinalIgnoreCase);
                <button type="button"
                        class="html-report-option @(isActive ? "is-active" : "")"
                        data-report-key="@report.Key"
                        data-supports-store="@(report.SupportsStoreFilter ? "true" : "false")"
                        aria-pressed="@(isActive ? "true" : "false")">
                    <strong>@report.Title</strong>
                    <span>@report.Description</span>
                    <em>تقرير تشغيلي</em>
                </button>
            }
        </div>
    </div>

    <label>
        &#1605;&#1606; &#1578;&#1575;&#1585;&#1610;&#1582;
        <input type="date" name="FromDate" value="@(Model.Filter.FromDate.HasValue ? Model.Filter.FromDate.Value.ToString("yyyy-MM-dd") : "")" />
    </label>

    <label>
        &#1573;&#1604;&#1609; &#1578;&#1575;&#1585;&#1610;&#1582;
        <input type="date" name="ToDate" value="@(Model.Filter.ToDate.HasValue ? Model.Filter.ToDate.Value.ToString("yyyy-MM-dd") : "")" />
    </label>

    <label>
        &#1575;&#1604;&#1601;&#1585;&#1593;
        <select name="BranchId">
            <option value="">&#1603;&#1604; &#1575;&#1604;&#1601;&#1585;&#1608;&#1593; &#1575;&#1604;&#1605;&#1578;&#1575;&#1581;&#1577;</option>
            @foreach (var branch in Model.Branches)
            {
                <option value="@branch.Id" @(Model.Filter.BranchId == branch.Id ? "selected" : "")>@branch.Name</option>
            }
        </select>
    </label>

    <label class="store-only-filter" style="@(showStore ? "" : "display:none")">
        &#1575;&#1604;&#1605;&#1582;&#1586;&#1606;
        <select name="StoreId">
            <option value="">&#1603;&#1604; &#1575;&#1604;&#1605;&#1582;&#1575;&#1586;&#1606; &#1575;&#1604;&#1605;&#1578;&#1575;&#1581;&#1577;</option>
            @foreach (var store in Model.Stores)
            {
                <option value="@store.Id" @(Model.Filter.StoreId == store.Id ? "selected" : "")>@store.Name</option>
            }
        </select>
    </label>

    <label class="store-only-filter" style="@(showStore ? "" : "display:none")">
        &#1576;&#1581;&#1579; &#1587;&#1610;&#1585;&#1610;&#1575;&#1604;/&#1589;&#1606;&#1601;
        <input type="text" name="SerialSearch" value="@Model.Filter.SerialSearch" />
    </label>

    <div class="html-report-buttons">
        <button type="submit" class="primary" id="htmlReportSearchBtn">بحث البيانات</button>
        <span class="html-report-progress" id="htmlReportProgress" aria-live="polite"></span>
    </div>
}
