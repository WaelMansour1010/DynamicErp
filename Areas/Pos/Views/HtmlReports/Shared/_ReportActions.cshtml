@model MyERP.Models.Reports.HtmlReportPageViewModel

@using (Html.BeginForm("Export", "HtmlReports", new { area = "Pos" }, FormMethod.Post, new { @class = "html-report-actions no-print" }))
{
    <input type="hidden" name="ReportKey" value="@Model.Filter.ReportKey" />
    <input type="hidden" name="FromDate" value="@(Model.Filter.FromDate.HasValue ? Model.Filter.FromDate.Value.ToString("yyyy-MM-dd") : "")" />
    <input type="hidden" name="ToDate" value="@(Model.Filter.ToDate.HasValue ? Model.Filter.ToDate.Value.ToString("yyyy-MM-dd") : "")" />
    <input type="hidden" name="BranchId" value="@Model.Filter.BranchId" />
    <input type="hidden" name="StoreId" value="@Model.Filter.StoreId" />
    <input type="hidden" name="SerialSearch" value="@Model.Filter.SerialSearch" />
    <button type="button" id="htmlReportPrintBtn">طباعة</button>
    <button type="submit" class="primary">تصدير Excel</button>
}
