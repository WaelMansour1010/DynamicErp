    <div class="recon-actions">
        <button type="button" class="recon-btn danger-action" id="confirmDeleteBtn">تأكيد الحذف الآمن</button>
        <button type="button" class="recon-btn secondary" id="cancelDeleteBtn">إلغاء</button>
    </div>
