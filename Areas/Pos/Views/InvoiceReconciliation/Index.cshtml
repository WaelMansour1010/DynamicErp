@model MyERP.Areas.Pos.Models.PosInvoiceReconciliationIndexViewModel
@{
    Layout = null;
    ViewBag.Title = "مراجعة وتسوية فواتير Excel";
    var result = Model != null ? Model.Result : null;
    var saved = Model != null ? Model.SavedResult : null;
    Func<string, string> statusClass = status =>
    {
        status = status ?? "";
        if (status == "Exact Match") return "ok";
        if (status == "Not Found") return "missing";
        if (status.IndexOf("Mismatch", StringComparison.OrdinalIgnoreCase) >= 0) return "warn";
        if (status.IndexOf("Duplicate", StringComparison.OrdinalIgnoreCase) >= 0) return "danger";
        return "info";
    };
    Func<string, string> arStatus = status =>
    {
        if (status == "Exact Match") return "مطابق وموجود من قبل";
        if (status == "Probable Duplicate") return "غالبا مكرر ويحتاج مراجعة";
        if (status == "Possible Match") return "تشابه محتمل";
        if (status == "Amount Mismatch") return "اختلاف في المبلغ";
        if (status == "Customer Mismatch") return "اختلاف في بيانات العميل";
        if (status == "Date Mismatch") return "اختلاف في التاريخ";
        if (status == "Not Found") return "غير موجود في النظام";
        if (status == "Database Duplicate") return "مكرر داخل قاعدة البيانات";
        if (status == "Excel Duplicate") return "مكرر داخل ملف Excel";
        if (status == "Confirmed Duplicate") return "تكرار مؤكد";
        if (status == "Possible Duplicate") return "تكرار محتمل";
        if (status == "Token Conflict") return "تعارض في التوكن";
        if (status == "Phone Conflict") return "تعارض في رقم الهاتف";
        if (status == "Needs Review") return "يحتاج مراجعة";
        if (status == "No Issue") return "لا توجد مشكلة واضحة";
        return string.IsNullOrWhiteSpace(status) ? "" : status;
    };
    Func<string, string> arRisk = risk =>
    {
        if (risk == "Critical") return "حرج جدا";
        if (risk == "High") return "مرتفع";
        if (risk == "Medium") return "متوسط";
        if (risk == "Low") return "منخفض";
        return string.IsNullOrWhiteSpace(risk) ? "" : risk;
    };
    Func<string, string> arService = service =>
    {
        if (service == "Cash In") return "إيداع / شحن";
        if (service == "Cash Out") return "سحب";
        if (service == "Card") return "كارت / توكن";
        if (service == "Violations") return "مخالفات";
        return string.IsNullOrWhiteSpace(service) ? "" : service;
    };
    Func<string, string> arSource = source =>
    {
        if (source == "Excel Imported" || source == "Estimated Excel") return "مستورد من Excel";
        if (source == "POS Manual/System" || source == "Estimated Manual") return "مدخل من النظام";
        if (source == "Normal POS") return "مدخل من النظام";
        if (source == "Unknown") return "مصدر غير مؤكد";
        return string.IsNullOrWhiteSpace(source) ? "" : source;
    };
    Func<string, string> arReason = reason =>
    {
        if (string.IsNullOrWhiteSpace(reason)) return "";
        return reason
            .Replace("Same token exists in Excel-imported and normal invoice", "نفس التوكن موجود في فاتورة مستوردة من Excel وفاتورة مدخلة من النظام")
            .Replace("Same phone + same amount + same date exists in both sources", "نفس الهاتف ونفس المبلغ ونفس التاريخ موجودين في المصدرين")
            .Replace("Same national ID + same amount/date exists in both sources", "نفس الرقم القومي مع نفس المبلغ والتاريخ موجود في المصدرين")
            .Replace("Large amount difference or many similar matches", "يوجد فرق كبير في الإجمالي أو عدد كبير من التشابهات")
            .Replace("Potential duplicate matches found", "تم العثور على فواتير متشابهة تحتاج مراجعة")
            .Replace("Same day has both Excel and normal entries", "نفس اليوم يحتوي فواتير مستوردة وفواتير مدخلة من النظام")
            .Replace("Single source only in selected filters", "النتائج من مصدر واحد فقط حسب الفلاتر المختارة")
            .Replace("Same token", "نفس التوكن")
            .Replace("Same card serial", "نفس رقم الكارت")
            .Replace("Same national ID + phone", "نفس الرقم القومي ورقم الهاتف")
            .Replace("Same manual/IPN + date + branch", "نفس الرقم اليدوي أو IPN مع نفس التاريخ والفرع")
            .Replace("Same phone + amount + date", "نفس الهاتف والمبلغ والتاريخ")
            .Replace("Same national ID + amount + date", "نفس الرقم القومي والمبلغ والتاريخ")
            .Replace("Same token but amount differs", "نفس التوكن لكن المبلغ مختلف")
            .Replace("Same normalized customer name + phone", "نفس اسم العميل بعد التنسيق ونفس الهاتف")
            .Replace("Same amount + service + branch + close time", "نفس المبلغ والخدمة والفرع في وقت قريب")
            .Replace("Same phone + close amount", "نفس الهاتف مع مبلغ قريب")
            .Replace("Same amount only in same branch/day", "نفس المبلغ فقط في نفس الفرع واليوم")
            .Replace("Similar customer name only", "تشابه في اسم العميل فقط")
            .Replace("Same teller + amount + service + date", "نفس المستخدم والمبلغ والخدمة والتاريخ")
            .Replace("Amount differs for a matching token/phone", "المبلغ مختلف مع تطابق التوكن أو الهاتف")
            .Replace("Customer name differs for a matching token/phone", "اسم العميل مختلف مع تطابق التوكن أو الهاتف")
            .Replace("Card sale invoice exists but issue voucher is missing", "فاتورة بيع الكارت موجودة لكن سند الصرف غير موجود")
            .Replace("Issue voucher exists but sale invoice is missing", "سند الصرف موجود لكن فاتورة البيع غير موجودة")
            .Replace("Invalid or missing invoice date", "تاريخ الفاتورة غير موجود أو غير صحيح")
            .Replace("Invalid or missing amount", "المبلغ غير موجود أو غير صحيح")
            .Replace("No matching key found: token, phone, invoice number, or national ID is required", "لا يوجد مفتاح واضح للمطابقة: يجب وجود توكن أو هاتف أو رقم فاتورة أو رقم قومي")
            .Replace("Service type is missing", "نوع الخدمة غير موجود")
            .Replace("Token matched", "التوكن مطابق")
            .Replace("Phone matched", "رقم الهاتف مطابق")
            .Replace("Invoice/IPN matched", "رقم الفاتورة أو IPN مطابق")
            .Replace("National ID matched", "الرقم القومي مطابق")
            .Replace("Amount matched", "المبلغ مطابق")
            .Replace("Date matched", "التاريخ مطابق")
            .Replace("Date is close, possible time/day shift", "التاريخ قريب وقد يكون هناك فرق وقت أو يوم")
            .Replace("Amount may be net/base vs commission-inclusive", "قد يكون الفرق بسبب العمولة: مبلغ صافى مقابل مبلغ شامل العمولة")
            .Replace("Card invoice exists but related issue voucher was not detected", "فاتورة الكارت موجودة لكن لم يتم العثور على سند الصرف المرتبط بها")
            .Replace("Matched an issue voucher; sale invoice may be missing or outside selected range", "تمت المطابقة مع سند صرف، وقد تكون فاتورة البيع غير موجودة أو خارج الفترة المختارة")
            .Replace("Excel row may be entered under a different branch", "قد تكون فاتورة Excel مدخلة على فرع مختلف")
            .Replace("Excel row may be entered under a different user", "قد تكون فاتورة Excel مدخلة باسم مستخدم مختلف")
            .Replace("Token matched header but was not found in Transaction_Details.ItemSerial", "التوكن موجود في رأس الفاتورة لكنه غير موجود في تفاصيل الأصناف")
            .Replace("Excel duplicate: repeated token/phone+amount+day/national ID+token/invoice number", "صف مكرر داخل Excel: نفس التوكن أو نفس الهاتف مع المبلغ واليوم أو نفس الرقم القومي مع التوكن أو نفس رقم الفاتورة")
            .Replace("Amount differs for a likely same transaction", "المبلغ مختلف رغم أن الفاتورة تبدو لنفس العملية")
            .Replace(" | ", " - ");
    };
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title</title>
    <link href="@Url.Content("~/Areas/Pos/Content/pos-transaction.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Areas/Pos/Content/html-reports.css")" rel="stylesheet" />
    <style>
        .recon-page { min-height: 100vh; padding: 18px; background: #f4f7fb; color: #172033; }
        .recon-title { display: flex; justify-content: space-between; gap: 16px; align-items: center; margin-bottom: 14px; }
        .recon-title h1 { margin: 0; font-size: 26px; font-weight: 800; }
        .recon-title p { margin: 5px 0 0; color: #64748b; }
        .recon-badge { background: #e8f5e9; color: #17633a; border: 1px solid #b8e2c0; border-radius: 999px; padding: 7px 12px; font-weight: 800; white-space: nowrap; }
        .recon-panel { background: #fff; border: 1px solid #dbe3ef; border-radius: 8px; padding: 14px; margin-bottom: 14px; box-shadow: 0 8px 20px rgba(15, 23, 42, .05); }
        .sticky-filter { position: sticky; top: 0; z-index: 20; box-shadow: 0 12px 28px rgba(15, 23, 42, .12); }
        .investigation-shell { display: grid; grid-template-columns: minmax(0, 1fr) 360px; gap: 14px; align-items: start; }
        .detail-drawer { position: sticky; top: 92px; border: 1px solid #cbd5e1; border-radius: 8px; background: #fff; padding: 12px; min-height: 320px; }
        .detail-drawer h3 { margin-top: 0; }
        .mini-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 8px; }
        .mini-cell { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 6px; padding: 8px; }
        .mini-cell small { display:block; color:#64748b; font-weight:800; }
        .clickable-row { cursor: pointer; }
        .clickable-row:hover { background: #f8fafc; }
        .split-compare { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
        .compare-card { border: 1px solid #dbe3ef; border-radius: 8px; padding: 10px; background: #fff; }
        .compare-card h4 { margin: 0 0 8px; }
        .toolbar-line { display:flex; gap:8px; flex-wrap:wrap; align-items:center; justify-content:space-between; margin-bottom:10px; }
        .danger-action { background:#991b1b !important; color:#fff !important; }
        .recon-grid { display: grid; grid-template-columns: 2fr repeat(4, minmax(140px, 1fr)); gap: 10px; align-items: end; }
        .recon-field { display: grid; gap: 6px; }
        .recon-field span { font-size: 13px; font-weight: 800; color: #475569; }
        .recon-field input, .recon-field select { min-height: 38px; border: 1px solid #cbd5e1; border-radius: 6px; padding: 8px 10px; background: #fff; }
        .recon-actions { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; margin-top: 12px; }
        .recon-btn { border: 0; border-radius: 6px; padding: 10px 14px; font-weight: 800; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 7px; }
        .recon-btn.primary { background: #2457d6; color: #fff; }
        .recon-btn.secondary { background: #e2e8f0; color: #172033; }
        .recon-note { background: #fff7ed; border: 1px solid #fed7aa; color: #9a3412; border-radius: 8px; padding: 10px 12px; margin-top: 12px; }
        .recon-tabs { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 14px; }
        .recon-tab-btn { border: 1px solid #cbd5e1; border-radius: 6px; background: #fff; color: #334155; padding: 9px 12px; font-weight: 800; cursor: pointer; }
        .recon-tab-btn.active { background: #2457d6; color: #fff; border-color: #2457d6; }
        .recon-tab-panel { display: none; }
        .recon-tab-panel.active { display: block; }
        .recon-error { background: #fee2e2; border: 1px solid #fecaca; color: #991b1b; border-radius: 8px; padding: 10px 12px; margin-bottom: 14px; }
        .summary-grid { display: grid; grid-template-columns: repeat(6, minmax(120px, 1fr)); gap: 10px; }
        .summary-tile { border: 1px solid #dbe3ef; border-radius: 8px; padding: 10px; background: #f8fafc; }
        .summary-tile small { display: block; color: #64748b; font-weight: 800; min-height: 34px; }
        .summary-tile strong { display: block; font-size: 24px; margin-top: 4px; color: #0f172a; }
        .mapping-grid { display: grid; grid-template-columns: repeat(4, minmax(160px, 1fr)); gap: 8px; }
        .mapping-item { border: 1px solid #dbe3ef; border-radius: 8px; padding: 9px; background: #f8fafc; }
        .mapping-item small { display: block; color: #64748b; }
        .mapping-item strong { display: block; margin-top: 4px; overflow-wrap: anywhere; }
        .table-tools { display: grid; grid-template-columns: repeat(5, minmax(140px, 1fr)); gap: 8px; margin-bottom: 10px; }
        .table-tools input, .table-tools select { border: 1px solid #cbd5e1; border-radius: 6px; padding: 8px 10px; min-height: 36px; }
        .recon-table-wrap { overflow: auto; border: 1px solid #dbe3ef; border-radius: 8px; background: #fff; max-height: 62vh; }
        .recon-table { width: 100%; min-width: 1900px; border-collapse: collapse; font-size: 13px; }
        .recon-table th { position: sticky; top: 0; background: #eef2f7; z-index: 2; color: #334155; text-align: right; }
        .recon-table th, .recon-table td { padding: 8px; border-bottom: 1px solid #e2e8f0; vertical-align: top; }
        .status-chip { display: inline-block; border-radius: 999px; padding: 4px 9px; font-size: 12px; font-weight: 800; white-space: nowrap; }
        .status-chip.ok { background: #dcfce7; color: #166534; }
        .status-chip.warn { background: #fef3c7; color: #92400e; }
        .status-chip.danger { background: #fee2e2; color: #991b1b; }
        .status-chip.missing { background: #e0f2fe; color: #075985; }
        .status-chip.info { background: #ede9fe; color: #5b21b6; }
        .warnings { margin: 0; padding-right: 16px; color: #92400e; }
        .invalid-list { margin: 0; padding-right: 18px; color: #991b1b; }
        @@media (max-width: 1100px) {
            .recon-grid, .summary-grid, .mapping-grid, .table-tools, .investigation-shell, .split-compare { grid-template-columns: 1fr 1fr; }
        }
        @@media (max-width: 700px) {
            .recon-title { display: block; }
            .recon-grid, .summary-grid, .mapping-grid, .table-tools, .investigation-shell, .split-compare { grid-template-columns: 1fr; }
            .detail-drawer, .sticky-filter { position: static; }
        }
    </style>
</head>
<body>
<main class="recon-page">
    <div class="recon-title">
        <div>
            <h1>مراجعة وتسوية فواتير Excel</h1>
            <p>تحليل وقراءة فقط لمقارنة شيتات الإدارة مع فواتير POS قبل أي قرار ترحيل أو تعديل.</p>
        </div>
        <span class="recon-badge">مراجعة فقط بدون تعديل</span>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="recon-error">@Model.ErrorMessage</div>
    }

    <div class="recon-tabs">
        <button type="button" class="recon-tab-btn active" data-tab-target="tab-upload">رفع ومطابقة Excel</button>
        <button type="button" class="recon-tab-btn" data-tab-target="tab-saved">تحليل Excel المحفوظ في النظام</button>
        @if (saved != null)
        {
            <button type="button" class="recon-tab-btn" data-tab-target="tab-period">ملخص الفترة</button>
            <button type="button" class="recon-tab-btn" data-tab-target="tab-days">الأيام والفروع</button>
            <button type="button" class="recon-tab-btn" data-tab-target="tab-excel-invoices">فواتير Excel</button>
            <button type="button" class="recon-tab-btn" data-tab-target="tab-system-invoices">فواتير النظام</button>
            <button type="button" class="recon-tab-btn" data-tab-target="tab-pairs">المشتبهات الذكية (@saved.DuplicatePairs.Count)</button>
            <button type="button" class="recon-tab-btn" data-tab-target="tab-tokens">مشاكل الكروت والتوكينات</button>
            <button type="button" class="recon-tab-btn" data-tab-target="tab-actions">سجل الإجراءات</button>
        }
    </div>

    <section class="recon-panel recon-tab-panel active" id="tab-upload">
        <form method="post" action="@Url.Action("Analyze", "PosInvoiceReconciliation", new { area = "Pos" })" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="recon-grid">
                <label class="recon-field">
                    <span>ملفات Excel</span>
                    <input type="file" name="excelFiles" accept=".xlsx,.xls" multiple required />
                </label>
                <label class="recon-field">
                    <span>من تاريخ</span>
                    <input type="date" name="fromDate" value="@Model.FromDate.ToString("yyyy-MM-dd")" required />
                </label>
                <label class="recon-field">
                    <span>إلى تاريخ</span>
                    <input type="date" name="toDate" value="@Model.ToDate.ToString("yyyy-MM-dd")" required />
                </label>
                <label class="recon-field">
                    <span>الفرع</span>
                    <select name="branchId">
                        <option value="">كل الفروع</option>
                        @foreach (var branch in Model.Branches)
                        {
                            <option value="@branch.BranchId" @(Model.BranchId == branch.BranchId ? "selected" : "")>@branch.BranchName</option>
                        }
                    </select>
                </label>
                <label class="recon-field">
                    <span>نوع الخدمة</span>
                    <select name="serviceType">
                        <option value="" @(string.IsNullOrWhiteSpace(Model.ServiceType) ? "selected" : "")>الكل</option>
                        <option value="Cash In" @(Model.ServiceType == "Cash In" ? "selected" : "")>إيداع / شحن</option>
                        <option value="Cash Out" @(Model.ServiceType == "Cash Out" ? "selected" : "")>سحب</option>
                        <option value="Card" @(Model.ServiceType == "Card" ? "selected" : "")>كارت / توكن</option>
                        <option value="Violations" @(Model.ServiceType == "Violations" ? "selected" : "")>مخالفات</option>
                    </select>
                </label>
            </div>
            <div class="recon-actions">
                <button type="submit" class="recon-btn primary">تحليل ومراجعة</button>
                @if (result != null)
                {
                    <a class="recon-btn secondary" href="@Url.Action("Export", "PosInvoiceReconciliation", new { area = "Pos" })">تصدير تقرير المراجعة</a>
                }
            </div>
            <div class="recon-note">هذه الشاشة للمراجعة فقط. لن يتم إضافة أو تعديل أو حذف أي فاتورة من هنا.</div>
        </form>
    </section>

    <section class="recon-panel recon-tab-panel sticky-filter" id="tab-saved">
        <h2>تحليل الفواتير المستوردة من Excel داخل قاعدة البيانات</h2>
        <form method="post" action="@Url.Action("AnalyzeSaved", "PosInvoiceReconciliation", new { area = "Pos" })">
            @Html.AntiForgeryToken()
            <div class="recon-grid">
                <label class="recon-field">
                    <span>الشهر</span>
                    <input type="month" name="month" value="@Model.Month" />
                </label>
                <label class="recon-field">
                    <span>من تاريخ</span>
                    <input type="date" name="fromDate" value="@Model.FromDate.ToString("yyyy-MM-dd")" required />
                </label>
                <label class="recon-field">
                    <span>إلى تاريخ</span>
                    <input type="date" name="toDate" value="@Model.ToDate.ToString("yyyy-MM-dd")" required />
                </label>
                <label class="recon-field">
                    <span>الفرع</span>
                    <select name="branchId">
                        <option value="">كل الفروع</option>
                        @foreach (var branch in Model.Branches)
                        {
                            <option value="@branch.BranchId" @(Model.BranchId == branch.BranchId ? "selected" : "")>@branch.BranchName</option>
                        }
                    </select>
                </label>
                <label class="recon-field">
                    <span>نوع الخدمة</span>
                    <select name="serviceType">
                        <option value="" @(string.IsNullOrWhiteSpace(Model.ServiceType) ? "selected" : "")>الكل</option>
                        <option value="Cash In" @(Model.ServiceType == "Cash In" ? "selected" : "")>إيداع / شحن</option>
                        <option value="Cash Out" @(Model.ServiceType == "Cash Out" ? "selected" : "")>سحب</option>
                        <option value="Card" @(Model.ServiceType == "Card" ? "selected" : "")>كارت / توكن</option>
                        <option value="Violations" @(Model.ServiceType == "Violations" ? "selected" : "")>مخالفات</option>
                    </select>
                </label>
                <label class="recon-field">
                    <span>المستخدم / التلر</span>
                    <select name="tellerUserId">
                        <option value="">كل المستخدمين</option>
                        @foreach (var user in Model.Users)
                        {
                            <option value="@user.UserId" @(Model.UserId == user.UserId ? "selected" : "")>@user.UserName @(string.IsNullOrWhiteSpace(user.EmpName) ? "" : " - " + user.EmpName)</option>
                        }
                    </select>
                </label>
                <label class="recon-field">
                    <span>مصدر الفاتورة</span>
                    <select name="importSource">
                        <option value="Both" @(Model.ImportSource == "Both" || string.IsNullOrWhiteSpace(Model.ImportSource) ? "selected" : "")>الاثنان معا</option>
                        <option value="Excel" @(Model.ImportSource == "Excel" ? "selected" : "")>فواتير مستوردة من Excel</option>
                        <option value="Normal" @(Model.ImportSource == "Normal" ? "selected" : "")>فواتير مدخلة من النظام</option>
                    </select>
                </label>
                <label class="recon-field">
                    <span>مستوى الخطورة</span>
                    <select name="riskLevel">
                        <option value="" @(string.IsNullOrWhiteSpace(Model.RiskLevel) ? "selected" : "")>كل المستويات</option>
                        <option value="Critical" @(Model.RiskLevel == "Critical" ? "selected" : "")>حرج جدا</option>
                        <option value="High" @(Model.RiskLevel == "High" ? "selected" : "")>مرتفع</option>
                        <option value="Medium" @(Model.RiskLevel == "Medium" ? "selected" : "")>متوسط</option>
                        <option value="Low" @(Model.RiskLevel == "Low" ? "selected" : "")>منخفض</option>
                    </select>
                </label>
                <label class="recon-field">
                    <span>بحث ذكي</span>
                    <input type="search" name="searchTerm" value="@Model.SearchTerm" placeholder="هاتف / عميل / توكن / رقم فاتورة" />
                </label>
                <label class="recon-field">
                    <span>المبلغ من</span>
                    <input type="number" step="0.01" name="minAmount" value="@(Model.MinAmount.HasValue ? Model.MinAmount.Value.ToString("0.##") : "")" />
                </label>
                <label class="recon-field">
                    <span>المبلغ إلى</span>
                    <input type="number" step="0.01" name="maxAmount" value="@(Model.MaxAmount.HasValue ? Model.MaxAmount.Value.ToString("0.##") : "")" />
                </label>
                <label class="recon-field">
                    <span>التوكن</span>
                    <input type="text" name="token" value="@Model.Token" />
                </label>
                <label class="recon-field">
                    <span>الهاتف</span>
                    <input type="text" name="phone" value="@Model.Phone" />
                </label>
                <label class="recon-field">
                    <span>الرقم القومي</span>
                    <input type="text" name="nationalId" value="@Model.NationalId" />
                </label>
                <label class="recon-field">
                    <span>اسم العميل</span>
                    <input type="text" name="customerName" value="@Model.CustomerName" />
                </label>
                <label class="recon-field" style="display:flex;gap:8px;align-items:center;">
                    <input type="checkbox" name="onlyBothSources" value="true" @(Model.OnlyBothSources ? "checked" : "") style="width:18px;height:18px;" />
                    <span>عرض الأيام التي بها Excel والنظام معا فقط</span>
                </label>
                <label class="recon-field" style="display:flex;gap:8px;align-items:center;">
                    <input type="checkbox" name="suspiciousOnly" value="true" @(Model.SuspiciousOnly ? "checked" : "") style="width:18px;height:18px;" />
                    <span>عرض المشتبهات فقط</span>
                </label>
            </div>
            <div class="recon-actions">
                <button type="submit" class="recon-btn primary">تحليل الفواتير المحفوظة</button>
                @if (saved != null)
                {
                    <a class="recon-btn secondary" href="@Url.Action("ExportSaved", "PosInvoiceReconciliation", new { area = "Pos" })">تصدير تقرير المراجعة</a>
                    <button type="button" class="recon-btn secondary" disabled>تعليم كمراجع</button>
                    <button type="button" class="recon-btn secondary" disabled>إنشاء مهمة متابعة</button>
                }
            </div>
            <div class="recon-note">هذا التحليل يقارن الفواتير الموجودة داخل قاعدة البيانات فقط. لن يتم حذف أو دمج أو تعديل أي فاتورة.</div>
        </form>
        @if (saved != null && saved.HasUncertainSource)
        {
            <div class="recon-note">@saved.SourceDetectionWarning</div>
        }
    </section>

    @if (result != null)
    {
