@functions {
    public static string ArStatus(string status)
    {
        if (status == "Exact Match") return "مطابق وموجود من قبل";
        if (status == "Probable Duplicate") return "غالبا مكرر ويحتاج مراجعة";
        if (status == "Possible Match") return "تشابه محتمل";
        if (status == "Amount Mismatch") return "اختلاف في المبلغ";
        if (status == "Customer Mismatch") return "اختلاف في بيانات العميل";
        if (status == "Date Mismatch") return "اختلاف في التاريخ";
        if (status == "Not Found") return "غير موجود في النظام";
        if (status == "Database Duplicate") return "مكرر داخل قاعدة البيانات";
        if (status == "Excel Duplicate") return "مكرر داخل ملف Excel";
        if (status == "Confirmed Duplicate") return "تكرار مؤكد";
        if (status == "Possible Duplicate") return "تكرار محتمل";
        if (status == "Token Conflict") return "تعارض في التوكن";
        if (status == "Phone Conflict") return "تعارض في رقم الهاتف";
        if (status == "Needs Review") return "يحتاج مراجعة";
        if (status == "No Issue") return "لا توجد مشكلة واضحة";
        return string.IsNullOrWhiteSpace(status) ? "" : status;
    }

    public static string ArRisk(string risk)
    {
        if (risk == "Critical") return "حرج جدا";
        if (risk == "High") return "مرتفع";
        if (risk == "Medium") return "متوسط";
        if (risk == "Low") return "منخفض";
        return string.IsNullOrWhiteSpace(risk) ? "" : risk;
    }

    public static string ArService(string service)
    {
        if (service == "Cash In") return "إيداع / شحن";
        if (service == "Cash Out") return "سحب";
        if (service == "Card") return "كارت / توكن";
        if (service == "Violations") return "مخالفات";
        return string.IsNullOrWhiteSpace(service) ? "" : service;
    }

    public static string ArSource(string source)
    {
        if (source == "Excel Imported" || source == "Estimated Excel") return "مستورد من Excel";
        if (source == "POS Manual/System" || source == "Estimated Manual") return "مدخل من النظام";
        if (source == "Normal POS") return "مدخل من النظام";
        if (source == "Unknown") return "مصدر غير مؤكد";
        return string.IsNullOrWhiteSpace(source) ? "" : source;
    }

    public static string ArReason(string reason)
    {
        if (string.IsNullOrWhiteSpace(reason)) return "";
        return reason
            .Replace("Same token exists in Excel-imported and normal invoice", "نفس التوكن موجود في فاتورة مستوردة من Excel وفاتورة مدخلة من النظام")
            .Replace("Same phone + same amount + same date exists in both sources", "نفس الهاتف ونفس المبلغ ونفس التاريخ موجودين في المصدرين")
            .Replace("Same national ID + same amount/date exists in both sources", "نفس الرقم القومي مع نفس المبلغ والتاريخ موجود في المصدرين")
            .Replace("Large amount difference or many similar matches", "يوجد فرق كبير في الإجمالي أو عدد كبير من التشابهات")
            .Replace("Potential duplicate matches found", "تم العثور على فواتير متشابهة تحتاج مراجعة")
            .Replace("Same day has both Excel and normal entries", "نفس اليوم يحتوي فواتير مستوردة وفواتير مدخلة من النظام")
            .Replace("Single source only in selected filters", "النتائج من مصدر واحد فقط حسب الفلاتر المختارة")
            .Replace("Same token", "نفس التوكن")
            .Replace("Same card serial", "نفس رقم الكارت")
            .Replace("Same national ID + phone", "نفس الرقم القومي ورقم الهاتف")
            .Replace("Same manual/IPN + date + branch", "نفس الرقم اليدوي أو IPN مع نفس التاريخ والفرع")
            .Replace("Same phone + amount + date", "نفس الهاتف والمبلغ والتاريخ")
            .Replace("Same national ID + amount + date", "نفس الرقم القومي والمبلغ والتاريخ")
            .Replace("Same token but amount differs", "نفس التوكن لكن المبلغ مختلف")
            .Replace("Same normalized customer name + phone", "نفس اسم العميل بعد التنسيق ونفس الهاتف")
            .Replace("Same amount + service + branch + close time", "نفس المبلغ والخدمة والفرع في وقت قريب")
            .Replace("Same phone + close amount", "نفس الهاتف مع مبلغ قريب")
            .Replace("Same amount only in same branch/day", "نفس المبلغ فقط في نفس الفرع واليوم")
            .Replace("Similar customer name only", "تشابه في اسم العميل فقط")
            .Replace("Same teller + amount + service + date", "نفس المستخدم والمبلغ والخدمة والتاريخ")
            .Replace("Amount differs for a matching token/phone", "المبلغ مختلف مع تطابق التوكن أو الهاتف")
            .Replace("Customer name differs for a matching token/phone", "اسم العميل مختلف مع تطابق التوكن أو الهاتف")
            .Replace("Card sale invoice exists but issue voucher is missing", "فاتورة بيع الكارت موجودة لكن سند الصرف غير موجود")
            .Replace("Issue voucher exists but sale invoice is missing", "سند الصرف موجود لكن فاتورة البيع غير موجودة")
            .Replace("Amount differs for a likely same transaction", "المبلغ مختلف رغم أن الفاتورة تبدو لنفس العملية")
            .Replace(" | ", " - ");
    }
}
@helper RenderDimensionSummary(System.Collections.Generic.IList<MyERP.Areas.Pos.Models.PosSavedInvoiceDimensionSummary> rows)
{
    <div class="recon-table-wrap" style="max-height:34vh;">
        <table class="recon-table" style="min-width:1200px;">
            <thead><tr><th>البند</th><th>عدد Excel</th><th>إجمالي Excel</th><th>عدد النظام</th><th>إجمالي النظام</th><th>فرق العدد</th><th>فرق الإجمالي</th><th>تشابهات تحتاج مراجعة</th><th>الخطورة</th><th>السبب</th></tr></thead>
            <tbody>
            @foreach (var row in rows)
            {
                <tr>
                    <td>@ArSource(ArService(row.DimensionName))</td>
                    <td>@row.ExcelImportedCount</td>
                    <td>@row.ExcelImportedAmount.ToString("0.##")</td>
                    <td>@row.NormalPosCount</td>
                    <td>@row.NormalPosAmount.ToString("0.##")</td>
                    <td>@row.CountDifference</td>
                    <td>@row.AmountDifference.ToString("0.##")</td>
                    <td>@row.SuspiciousDuplicatePairs</td>
                    <td><span class="status-chip @(row.RiskLevel == "Critical" ? "danger" : row.RiskLevel == "High" ? "warn" : row.RiskLevel == "Medium" ? "info" : "ok")">@ArRisk(row.RiskLevel)</span></td>
                    <td>@ArReason(row.Reason)</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
@helper RenderInvoiceList(System.Collections.Generic.IList<MyERP.Areas.Pos.Models.PosSavedInvoiceListItem> rows, bool selectable)
{
    <div class="recon-table-wrap">
        <table class="recon-table invoice-list-table" style="min-width:1500px;">
            <thead><tr>@if (selectable) { <th>اختيار</th> }<th>رقم الفاتورة</th><th>التاريخ</th><th>السيريال</th><th>الخدمة</th><th>المصدر</th><th>الفرع</th><th>المستخدم</th><th>التوكن</th><th>الهاتف</th><th>العميل</th><th>المبلغ</th><th>الخطورة</th><th>الحالة</th></tr></thead>
            <tbody>
            @foreach (var row in rows)
            {
                <tr class="clickable-row invoice-row" data-transaction-id="@row.TransactionId">
                    @if (selectable) { <td><input type="checkbox" class="invoice-select" value="@row.TransactionId" /></td> }
                    <td>@row.TransactionId</td>
                    <td>@(row.InvoiceDate.HasValue ? row.InvoiceDate.Value.ToString("yyyy-MM-dd HH:mm") : "")</td>
                    <td>@row.Serial</td>
                    <td>@ArService(row.ServiceType)</td>
                    <td>@ArSource(row.Source)</td>
                    <td>@row.BranchName</td>
                    <td>@row.UserName</td>
                    <td>@row.Token</td>
                    <td>@row.Phone</td>
                    <td>@row.CustomerName</td>
                    <td>@row.Amount.ToString("0.##")</td>
                    <td><span class="status-chip @(row.RiskLevel == "Critical" ? "danger" : row.RiskLevel == "High" ? "warn" : row.RiskLevel == "Medium" ? "info" : "ok")">@ArRisk(row.RiskLevel)</span></td>
                    <td>@ArStatus(row.ReviewStatus)</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
@helper RenderPairs(System.Collections.Generic.IList<MyERP.Areas.Pos.Models.PosSavedInvoiceDuplicatePair> pairs)
{
    <div class="recon-table-wrap">
        <table class="recon-table" style="min-width:2200px;">
            <thead>
                <tr>
                    <th>اختيار</th><th>رقم فاتورة Excel في النظام</th><th>وقت فاتورة Excel</th><th>سيريال / IPN Excel</th><th>مصدر Excel / الدفعة</th><th>رقم فاتورة النظام</th><th>وقت فاتورة النظام</th><th>سيريال / IPN النظام</th><th>الخدمة</th><th>الفرع</th><th>مستخدم Excel</th><th>مستخدم النظام</th><th>توكن Excel</th><th>توكن النظام</th><th>هاتف Excel</th><th>هاتف النظام</th><th>رقم قومي Excel</th><th>رقم قومي النظام</th><th>عميل Excel</th><th>عميل النظام</th><th>مبلغ Excel</th><th>مبلغ النظام</th><th>الفرق</th><th>فرق الوقت بالدقائق</th><th>درجة التشابه</th><th>التصنيف</th><th>سبب الاشتباه والتنبيهات</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var row in pairs)
            {
                <tr class="clickable-row pair-row" data-excel-id="@row.ExcelTransactionId" data-system-id="@row.NormalTransactionId">
                    <td><input type="checkbox" class="invoice-select" value="@row.ExcelTransactionId" /> <input type="checkbox" class="invoice-select" value="@row.NormalTransactionId" /></td>
                    <td>@row.ExcelTransactionId</td>
                    <td>@(row.ExcelInvoiceDate.HasValue ? row.ExcelInvoiceDate.Value.ToString("yyyy-MM-dd HH:mm") : "")</td>
                    <td>@row.ExcelSerial</td>
                    <td>@ArSource(row.ExcelSource) @(row.ExcelImportBatchId.HasValue ? " / دفعة " + row.ExcelImportBatchId.Value : "") @(string.IsNullOrWhiteSpace(row.ExcelSourceFileName) ? "" : " / " + row.ExcelSourceFileName)</td>
                    <td>@row.NormalTransactionId</td>
                    <td>@(row.NormalInvoiceDate.HasValue ? row.NormalInvoiceDate.Value.ToString("yyyy-MM-dd HH:mm") : "")</td>
                    <td>@row.NormalSerial</td>
                    <td>@ArService(row.ServiceType)</td>
                    <td>@row.BranchName</td>
                    <td>@row.ExcelUserName</td>
                    <td>@row.NormalUserName</td>
                    <td>@row.ExcelToken</td>
                    <td>@row.NormalToken</td>
                    <td>@row.ExcelPhone</td>
                    <td>@row.NormalPhone</td>
                    <td>@row.ExcelNationalId</td>
                    <td>@row.NormalNationalId</td>
                    <td>@row.ExcelCustomerName</td>
                    <td>@row.NormalCustomerName</td>
                    <td>@row.ExcelAmount.ToString("0.##")</td>
                    <td>@row.NormalAmount.ToString("0.##")</td>
                    <td>@row.AmountDifference.ToString("0.##")</td>
                    <td>@(row.TimeDifferenceMinutes.HasValue ? row.TimeDifferenceMinutes.Value.ToString("0.#") : "")</td>
                    <td>@row.MatchScore</td>
                    <td><span class="status-chip @(row.MatchClassification == "Confirmed Duplicate" || row.MatchClassification == "Token Conflict" ? "danger" : row.MatchClassification == "Probable Duplicate" || row.MatchClassification == "Amount Mismatch" ? "warn" : "info")">@ArStatus(row.MatchClassification)</span></td>
                    <td>@ArReason(string.Join(" | ", row.Reasons.Concat(row.Warnings)))</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
<script>
(function () {
    var buttons = document.querySelectorAll("[data-tab-target]");
    var panels = document.querySelectorAll(".recon-tab-panel");
    var uploadResults = document.querySelectorAll(".upload-result-panel");
    function openTab(id) {
        var target = document.getElementById(id);
        if (!target) {
            id = "tab-saved";
        }
        Array.prototype.forEach.call(buttons, function (b) { b.classList.toggle("active", b.getAttribute("data-tab-target") === id); });
        Array.prototype.forEach.call(panels, function (p) { p.classList.toggle("active", p.id === id); });
        Array.prototype.forEach.call(uploadResults, function (p) { p.style.display = id === "tab-upload" ? "" : "none"; });
    }
    Array.prototype.forEach.call(buttons, function (b) { b.addEventListener("click", function () { openTab(b.getAttribute("data-tab-target")); }); });
    openTab("@(saved != null ? "tab-period" : "tab-upload")");
})();
(function () {
    var table = document.getElementById("resultTable");
    if (!table) return;
    var status = document.getElementById("statusFilter");
    var service = document.getElementById("serviceFilter");
    var branch = document.getElementById("branchFilter");
    var text = document.getElementById("textFilter");
    var needsAction = document.getElementById("needsActionOnly");
    function apply() {
        var statusValue = status.value;
        var serviceValue = service.value;
        var branchValue = (branch.value || "").toLowerCase();
        var textValue = (text.value || "").toLowerCase();
        Array.prototype.forEach.call(table.tBodies[0].rows, function (row) {
            var rowStatus = row.getAttribute("data-status") || "";
            var visible = true;
            if (statusValue && rowStatus !== statusValue) visible = false;
            if (serviceValue && (row.getAttribute("data-service") || "") !== serviceValue) visible = false;
            if (branchValue && (row.getAttribute("data-branch") || "").indexOf(branchValue) < 0) visible = false;
            if (textValue && (row.getAttribute("data-text") || "").indexOf(textValue) < 0) visible = false;
            if (needsAction.checked && rowStatus === "Exact Match") visible = false;
            row.style.display = visible ? "" : "none";
        });
    }
    [status, service, branch, text, needsAction].forEach(function (control) {
        control.addEventListener("input", apply);
        control.addEventListener("change", apply);
    });
})();
(function () {
    function qs(name) { return document.querySelector(name); }
    function qsa(name) { return Array.prototype.slice.call(document.querySelectorAll(name)); }
    function money(v) { return Number(v || 0).toLocaleString("ar-EG", { maximumFractionDigits: 2 }); }
    function postJson(url, data) {
        return fetch(url, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data || {})
        }).then(function (r) { return r.json(); });
    }
    function getJson(url) { return fetch(url).then(function (r) { return r.json(); }); }
    function invoiceTable(title, rows) {
        var html = "<h4>" + title + "</h4><div class='recon-table-wrap' style='max-height:260px'><table class='recon-table' style='min-width:900px'><thead><tr><th>رقم</th><th>وقت</th><th>عميل</th><th>هاتف</th><th>توكن</th><th>مبلغ</th><th>خطورة</th></tr></thead><tbody>";
        (rows || []).forEach(function (x) {
            html += "<tr class='clickable-row invoice-row' data-transaction-id='" + x.TransactionId + "'><td>" + x.TransactionId + "</td><td>" + (x.InvoiceDate ? x.InvoiceDate.replace("T", " ").substring(0, 16) : "") + "</td><td>" + (x.CustomerName || "") + "</td><td>" + (x.Phone || "") + "</td><td>" + (x.Token || "") + "</td><td>" + money(x.Amount) + "</td><td>" + (x.RiskLevel || "") + "</td></tr>";
        });
        return html + "</tbody></table></div>";
    }
    qsa(".day-branch-row").forEach(function (row) {
        row.addEventListener("click", function () {
            var date = row.getAttribute("data-date");
            var branchId = row.getAttribute("data-branch-id") || "";
            getJson("@Url.Action("GetReconciliationDayDetails", "PosInvoiceReconciliation", new { area = "Pos" })" + "?date=" + encodeURIComponent(date) + "&branchId=" + encodeURIComponent(branchId)).then(function (data) {
                if (!data.success) { alert(data.message || "تعذر تحميل التفاصيل"); return; }
                var s = data.summary || {};
                qs("#dayMiniSummary").innerHTML =
                    "<div class='mini-cell'><small>عدد Excel</small><strong>" + s.excelCount + "</strong></div>" +
                    "<div class='mini-cell'><small>إجمالي Excel</small><strong>" + money(s.excelTotal) + "</strong></div>" +
                    "<div class='mini-cell'><small>عدد النظام</small><strong>" + s.systemCount + "</strong></div>" +
                    "<div class='mini-cell'><small>إجمالي النظام</small><strong>" + money(s.systemTotal) + "</strong></div>" +
                    "<div class='mini-cell'><small>الفرق</small><strong>" + money(s.difference) + "</strong></div>" +
                    "<div class='mini-cell'><small>تشابهات</small><strong>" + s.suspiciousCount + "</strong></div>";
                qs("#dayDetailsContent").innerHTML =
                    "<p class='recon-note'>" + (s.riskReason || "") + "</p>" +
                    invoiceTable("فواتير Excel", data.excel) +
                    invoiceTable("فواتير النظام", data.system) +
                    "<h4>التشابهات بينهما</h4><p>" + ((data.pairs || []).length) + " تشابه يحتاج مراجعة</p>";
            });
        });
    });
    document.addEventListener("click", function (e) {
        var row = e.target.closest && e.target.closest(".invoice-row");
        if (!row || e.target.type === "checkbox") return;
        getJson("@Url.Action("GetInvoiceReconciliationDetails", "PosInvoiceReconciliation", new { area = "Pos" })" + "?transactionId=" + encodeURIComponent(row.getAttribute("data-transaction-id"))).then(function (data) {
            if (!data.success) { alert(data.message || "تعذر تحميل الفاتورة"); return; }
            var x = data.invoice;
            alert("فاتورة رقم: " + x.TransactionId + "\nالعميل: " + (x.CustomerName || "") + "\nالهاتف: " + (x.Phone || "") + "\nالتوكن: " + (x.Token || "") + "\nالمبلغ: " + money(x.Amount) + "\nعدد التشابهات: " + (data.similarPairs || []).length);
        });
    });
    var modal = qs("#deleteModal");
    qsa(".delete-selected-btn").forEach(function (btn) {
        btn.addEventListener("click", function () {
            var ids = qsa(".invoice-select:checked").map(function (x) { return x.value; }).filter(function (v, i, a) { return a.indexOf(v) === i; });
            if (!ids.length) { alert("اختر فاتورة واحدة على الأقل."); return; }
            qs("#deleteList").innerHTML = "الفواتير المختارة: " + ids.join("، ");
            modal.setAttribute("data-ids", ids.join(","));
            modal.style.display = "block";
        });
    });
    var cancelDelete = qs("#cancelDeleteBtn");
    if (cancelDelete) cancelDelete.addEventListener("click", function () { modal.style.display = "none"; });
    var confirmDelete = qs("#confirmDeleteBtn");
    if (confirmDelete) confirmDelete.addEventListener("click", function () {
        var ids = (modal.getAttribute("data-ids") || "").split(",").filter(Boolean).map(function (x) { return parseInt(x, 10); });
        postJson("@Url.Action("DeleteOrCancelReconciliationInvoices", "PosInvoiceReconciliation", new { area = "Pos" })", {
            TransactionIds: ids,
            Password: qs("#deletePassword").value,
            Reason: qs("#deleteReason").value
        }).then(function (data) {
            alert(data.message || (data.success ? "تم تنفيذ الإجراء" : "تعذر تنفيذ الإجراء"));
            if (data.success) window.location.reload();
        });
    });
})();
</script>
</body>
</html>
