@model MyERP.Common.JournalEntries.SharedJournalWorkspaceViewModel
@{
    Layout = null;
    ViewBag.Title = Model.Title;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title</title>
    <link href="@Url.Content("~/Areas/Pos/Content/pos-transaction.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Areas/Pos/Content/html-reports.css")" rel="stylesheet" />
    <style>
        .journal-entry-page:not(.is-editing) .journal-form-card,
        .journal-entry-page:not(.is-editing) .journal-lines-card,
        .journal-entry-page:not(.is-editing) .journal-totals-card {
            display: none;
        }

        .journal-browse-inline {
            background: transparent;
            display: block;
            inset: auto;
            margin-bottom: 18px;
            opacity: 1;
            pointer-events: auto;
            position: static;
            visibility: visible;
        }

        .journal-browse-inline .erp-modal-backdrop,
        .journal-browse-inline .erp-icon-btn {
            display: none;
        }

        .journal-browse-inline .erp-modal-dialog {
            box-shadow: 0 16px 36px rgba(15, 23, 42, .08);
            margin: 0;
            max-height: none;
            max-width: none;
            overflow: visible;
            width: 100%;
        }
    </style>
</head>
<body>
    @Html.Partial("~/Views/Shared/JournalEntries/_JournalWorkspace.cshtml", Model)
    <script src="@Url.Content("~/Areas/Pos/Scripts/account-selector.js")"></script>
    <script src="@Url.Content("~/Scripts/JournalEntries/shared-journal-workspace.js?v=20260515-arfix")"></script>
</body>
</html>
