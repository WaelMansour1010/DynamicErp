@{
    Layout = null;
    ViewBag.Title = "إدخال واستعراض القيود";
    var context = ViewBag.PosContext as MyERP.Areas.Pos.Models.PosUserContext;
    var branches = ViewBag.Branches as IEnumerable<MyERP.Areas.Pos.Models.PosBranchDto>;
    var isAdmin = context != null && context.UserType.GetValueOrDefault(-1) == 0;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title</title>
    <link href="@Url.Content("~/Areas/Pos/Content/pos-transaction.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Areas/Pos/Content/html-reports.css")" rel="stylesheet" />
</head>
<body>
    <main class="html-report-page erp-ui-page journal-entry-page"
          data-search-url="@Url.Action("Search", "JournalEntries", new { area = "Pos" })"
          data-get-url="@Url.Action("Get", "JournalEntries", new { area = "Pos" })"
          data-save-url="@Url.Action("Save", "JournalEntries", new { area = "Pos" })"
          data-account-lookup-url="@Url.Action("Accounts", "JournalEntries", new { area = "Pos" })"
          data-account-tree-url="@Url.Action("AccountTree", "JournalEntries", new { area = "Pos" })"
          data-can-create="@(isAdmin || (context != null && context.CanCreateJournalEntry) ? "true" : "false")"
          data-can-edit="@(isAdmin || (context != null && context.CanEditJournalEntry) ? "true" : "false")">

        <header class="erp-hero-card">
            <div>
                <h1>إدخال واستعراض القيود</h1>
                <p>إدخال القيود اليدوية واستعراض القيود السابقة مع حماية تعديل القيود الآلية.</p>
            </div>
            <strong>Dynamic ERP</strong>
        </header>

        <section class="erp-card journal-command-card no-print">
            <div class="erp-card-head">
                <div>
                    <h2>إدارة القيود</h2>
                    <p>أنشئ قيدا جديدا أو افتح شاشة البحث لاختيار قيد سابق للعرض.</p>
                </div>
                <div class="erp-actions erp-actions-inline">
                    <button type="button" class="erp-btn erp-btn-primary" id="browseJournalBtn">استعراض القيود</button>
                    <button type="button" class="erp-btn erp-btn-secondary" id="newJournalBtn">قيد جديد</button>
                </div>
            </div>
            <div id="journalMessage" class="pos-validation"></div>
        </section>

        <section class="erp-card journal-form-card">
            <div class="erp-card-head">
                <div>
                    <h2>بيانات القيد</h2>
                    <p id="entryKindLabel">قيد يدوي جديد</p>
                </div>
                <span class="erp-badge" id="journalStatusBadge">جاهز للإدخال</span>
            </div>
            <input type="hidden" id="noteId" />
            <div class="erp-filter-grid journal-header-grid">
                <label class="erp-field">
                    <span>رقم القيد</span>
                    <input type="text" id="noteSerialDisplay" readonly placeholder="يتم تحديده بعد الحفظ أو الفتح" />
                </label>
                <label class="erp-field">
                    <span>التاريخ</span>
                    <input type="date" id="noteDate" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                </label>
                <label class="erp-field">
                    <span>الفرع</span>
                    <select id="branchId" @(isAdmin ? "" : "disabled")>
                        @if (branches != null)
                        {
                            foreach (var branch in branches)
                            {
                                <option value="@branch.BranchId" @(context != null && context.BranchId == branch.BranchId ? "selected" : "")>@branch.BranchName</option>
                            }
                        }
                    </select>
                </label>
                <label class="erp-field erp-field-wide">
                    <span>البيان</span>
                    <input type="text" id="entryDescription" placeholder="اكتب بيان القيد" />
                </label>
                <label class="erp-field" id="adminPasswordWrap" style="display:none">
                    <span>كلمة مرور المدير العام</span>
                    <input type="password" id="adminPassword" autocomplete="off" />
                </label>
            </div>
        </section>

        <section class="erp-card journal-lines-card">
            <div class="erp-card-head">
                <div>
                    <h2>تفاصيل القيد</h2>
                    <p>اختر الحسابات وأدخل المدين والدائن، ويجب أن يتساوى الإجمالي قبل الحفظ.</p>
                </div>
                <button type="button" class="erp-btn erp-btn-secondary" id="addLineBtn">إضافة سطر</button>
            </div>
            <div class="html-report-table-wrap">
                <table class="html-report-table erp-data-table journal-lines-table">
                    <thead>
                        <tr>
                            <th>رقم الحساب</th>
                            <th>اسم الحساب</th>
                            <th>البيان</th>
                            <th>مدين</th>
                            <th>دائن</th>
                            <th>حذف</th>
                        </tr>
                    </thead>
                    <tbody id="journalLinesBody"></tbody>
                </table>
            </div>
        </section>

        <section class="erp-card journal-totals-card">
            <div class="journal-totals-grid">
                <div>
                    <span>إجمالي المدين</span>
                    <strong id="debitTotal">0.00</strong>
                </div>
                <div>
                    <span>إجمالي الدائن</span>
                    <strong id="creditTotal">0.00</strong>
                </div>
                <div>
                    <span>الفرق</span>
                    <strong id="journalDifference">0.00</strong>
                </div>
            </div>
            <div class="erp-actions">
                <button type="button" class="erp-btn erp-btn-primary" id="saveJournalBtn">حفظ القيد</button>
            </div>
        </section>

        <div class="erp-modal" id="journalBrowseModal" aria-hidden="true">
            <div class="erp-modal-backdrop" id="journalBrowseBackdrop"></div>
            <div class="erp-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="journalBrowseTitle">
                <div class="erp-modal-head">
                    <div>
                        <h2 id="journalBrowseTitle">استعراض القيود</h2>
                        <p>ابحث برقم القيد أو الفترة أو الحساب أو البيان، ثم اختر القيد المطلوب.</p>
                    </div>
                    <button type="button" class="erp-icon-btn" id="closeJournalBrowseBtn" aria-label="إغلاق">×</button>
                </div>
                <div class="erp-filter-grid journal-browse-grid">
                    <label class="erp-field">
                        <span>رقم القيد</span>
                        <input type="text" id="searchVoucherNo" placeholder="رقم القيد" />
                    </label>
                    <label class="erp-field">
                        <span>من تاريخ</span>
                        <input type="date" id="searchFromDate" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    </label>
                    <label class="erp-field">
                        <span>إلى تاريخ</span>
                        <input type="date" id="searchToDate" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    </label>
                    <label class="erp-field">
                        <span>الفرع</span>
                        <select id="searchBranchId" @(isAdmin ? "" : "disabled")>
                            <option value="">كل الفروع</option>
                            @if (branches != null)
                            {
                                foreach (var branch in branches)
                                {
                                    <option value="@branch.BranchId" @(context != null && context.BranchId == branch.BranchId ? "selected" : "")>@branch.BranchName</option>
                                }
                            }
                        </select>
                    </label>
                    <label class="erp-field erp-field-wide">
                        <span>البيان</span>
                        <input type="text" id="searchDescription" placeholder="كلمة من البيان" />
                    </label>
                    <input type="hidden" id="searchAccountCode" />
                    <input type="hidden" id="searchAccountCodes" />
                    <div class="erp-account-picker">
                        <div>
                            <strong>الحسابات</strong>
                            <span id="journalAccountTreeSummary">لم يتم اختيار حسابات</span>
                        </div>
                        <button type="button"
                                class="erp-btn erp-btn-secondary js-account-selector"
                                data-target-input="searchAccountCodes"
                                data-summary-target="journalAccountTreeSummary"
                                data-account-tree-url="@Url.Action("AccountTree", "JournalEntries", new { area = "Pos" })">
                            اختيار الحسابات
                        </button>
                    </div>
                </div>
                <div class="erp-actions">
                    <button type="button" class="erp-btn erp-btn-primary" id="searchJournalBtn">بحث</button>
                    <button type="button" class="erp-btn erp-btn-secondary" id="clearJournalSearchBtn">مسح الفلاتر</button>
                </div>
                <div class="html-report-table-wrap journal-browse-results">
                    <table class="html-report-table erp-data-table">
                        <thead>
                            <tr>
                                <th>رقم القيد</th>
                                <th>التاريخ</th>
                                <th>الفرع</th>
                                <th>النوع</th>
                                <th>البيان</th>
                                <th>مدين</th>
                                <th>دائن</th>
                                <th>إجراء</th>
                            </tr>
                        </thead>
                        <tbody id="journalSearchBody">
                            <tr><td colspan="8" class="empty-cell">اضغط بحث لعرض القيود.</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <datalist id="journalAccountOptions"></datalist>
    </main>

    <script src="@Url.Content("~/Areas/Pos/Scripts/account-selector.js")"></script>
    <script>
        (function () {
            var root = document.querySelector(".journal-entry-page");
            var canCreate = root.getAttribute("data-can-create") === "true";
            var canEdit = root.getAttribute("data-can-edit") === "true";
            var loadedIsManual = true;
            var accountOptionMap = {};
            var accountLookupTimer = null;

            function byId(id) { return document.getElementById(id); }
            function msg(text, error) { byId("journalMessage").textContent = text || ""; byId("journalMessage").classList.toggle("error", !!error); }
            function money(v) { v = parseFloat(v || 0); return isNaN(v) ? 0 : v; }
            function fmt(v) { return money(v).toFixed(2); }
            function dateText(v) {
                if (!v) { return ""; }
                var match = /\/Date\((\d+)/.exec(v);
                var date = match ? new Date(parseInt(match[1], 10)) : new Date(v);
                return isNaN(date.getTime()) ? "" : date.toLocaleDateString("en-GB");
            }
            function toInputDate(v) {
                if (!v) { return ""; }
                var match = /\/Date\((\d+)/.exec(v);
                var date = match ? new Date(parseInt(match[1], 10)) : new Date(v);
                return isNaN(date.getTime()) ? "" : date.toISOString().slice(0, 10);
            }
            function escapeHtml(v) {
                return String(v || "").replace(/[&<>"']/g, function (c) {
                    return { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c];
                });
            }
            function openBrowseModal() {
                byId("journalBrowseModal").classList.add("is-open");
                document.body.classList.add("account-modal-open");
                byId("searchVoucherNo").focus();
            }
            function closeBrowseModal() {
                byId("journalBrowseModal").classList.remove("is-open");
                document.body.classList.remove("account-modal-open");
            }
            function clearBrowseFilters() {
                byId("searchVoucherNo").value = "";
                byId("searchDescription").value = "";
                byId("searchAccountCode").value = "";
                byId("searchAccountCodes").value = "";
                var summary = byId("journalAccountTreeSummary");
                if (summary) { summary.textContent = "لم يتم اختيار حسابات"; }
                byId("journalSearchBody").innerHTML = "<tr><td colspan='8' class='empty-cell'>اضغط بحث لعرض القيود.</td></tr>";
            }

            function loadAccountOptions(term) {
                term = (term || "").trim();
                if (term.length < 2) { return; }
                var url = root.getAttribute("data-account-lookup-url");
                if (!url) { return; }
                fetch(url + "?term=" + encodeURIComponent(term), { credentials: "same-origin" })
                    .then(function (response) { return response.ok ? response.json() : []; })
                    .then(function (rows) {
                        var list = byId("journalAccountOptions");
                        accountOptionMap = {};
                        list.innerHTML = "";
                        (rows || []).forEach(function (row) {
                            var text = row.text || row.Text || "";
                            if (!text) { return; }
                            accountOptionMap[text] = { code: row.id || row.Id || "", serial: row.serial || row.Serial || "", name: text.replace(/^.*? - /, "") };
                            var option = document.createElement("option");
                            option.value = text;
                            list.appendChild(option);
                        });
                    });
            }

            function applyAccountOption(input) {
                var option = accountOptionMap[input.value];
                if (!option) { return; }
                var tr = input.closest("tr");
                if (!tr) { return; }
                tr.querySelector(".line-account-code").value = option.code;
                tr.querySelector(".line-account-serial").value = option.serial || input.value;
                tr.querySelector(".line-account-name").value = option.name || "";
            }

            function addLine(line) {
                line = line || {};
                var tr = document.createElement("tr");
                tr.innerHTML =
                    "<td><input type='hidden' class='line-account-code' value='" + escapeHtml(line.AccountCode) + "' /><input class='line-account-serial' list='journalAccountOptions' value='" + escapeHtml(line.AccountSerial) + "' placeholder='ابحث بالكود أو اسم الحساب' /></td>" +
                    "<td><input class='line-account-name' value='" + escapeHtml(line.AccountName) + "' readonly /></td>" +
                    "<td><input class='line-description' value='" + escapeHtml(line.Description) + "' placeholder='بيان السطر' /></td>" +
                    "<td><input type='number' step='0.01' class='line-debit' value='" + fmt(line.Debit) + "' /></td>" +
                    "<td><input type='number' step='0.01' class='line-credit' value='" + fmt(line.Credit) + "' /></td>" +
                    "<td><button type='button' class='erp-btn erp-btn-danger remove-line'>حذف</button></td>";
                byId("journalLinesBody").appendChild(tr);
                updateTotals();
            }

            function updateTotals() {
                var debit = 0, credit = 0;
                document.querySelectorAll("#journalLinesBody tr").forEach(function (tr) {
                    debit += money(tr.querySelector(".line-debit").value);
                    credit += money(tr.querySelector(".line-credit").value);
                });
                var diff = debit - credit;
                byId("debitTotal").textContent = fmt(debit);
                byId("creditTotal").textContent = fmt(credit);
                byId("journalDifference").textContent = fmt(diff);
                byId("journalDifference").classList.toggle("is-balanced", Math.abs(diff) < 0.01);
            }

            function clearForm() {
                byId("noteId").value = "";
                byId("noteSerialDisplay").value = "";
                byId("entryDescription").value = "";
                byId("adminPassword").value = "";
                byId("adminPasswordWrap").style.display = "none";
                byId("entryKindLabel").textContent = "قيد يدوي جديد";
                byId("journalStatusBadge").textContent = "جاهز للإدخال";
                loadedIsManual = true;
                byId("journalLinesBody").innerHTML = "";
                addLine({});
                addLine({});
                byId("saveJournalBtn").disabled = !canCreate;
                msg("", false);
            }

            function collectLines() {
                var lines = [];
                document.querySelectorAll("#journalLinesBody tr").forEach(function (tr) {
                    lines.push({
                        AccountCode: tr.querySelector(".line-account-code").value,
                        AccountSerial: tr.querySelector(".line-account-serial").value,
                        AccountName: tr.querySelector(".line-account-name").value,
                        Description: tr.querySelector(".line-description").value,
                        Debit: money(tr.querySelector(".line-debit").value),
                        Credit: money(tr.querySelector(".line-credit").value)
                    });
                });
                return lines;
            }

            function postJson(url, data) {
                return fetch(url, {
                    method: "POST",
                    headers: { "Content-Type": "application/json; charset=utf-8" },
                    body: JSON.stringify(data || {})
                }).then(function (response) {
                    return response.json();
                });
            }

            function search() {
                msg("جاري البحث...", false);
                postJson(root.getAttribute("data-search-url"), {
                    VoucherNo: byId("searchVoucherNo").value,
                    FromDate: byId("searchFromDate").value,
                    ToDate: byId("searchToDate").value,
                    BranchId: byId("searchBranchId").value || null,
                    AccountCode: byId("searchAccountCode").value,
                    AccountCodes: byId("searchAccountCodes").value,
                    Description: byId("searchDescription").value
                }).then(function (data) {
                    if (!data.success) { msg(data.message || "تعذر البحث", true); return; }
                    var body = byId("journalSearchBody");
                    body.innerHTML = "";
                    if (!data.rows || data.rows.length === 0) {
                        body.innerHTML = "<tr><td colspan='8' class='empty-cell'>لا توجد قيود مطابقة.</td></tr>";
                    } else {
                        data.rows.forEach(function (row) {
                            body.innerHTML += "<tr><td>" + escapeHtml(row.NoteSerial || row.NoteId) + "</td><td>" + dateText(row.NoteDate) + "</td><td>" + escapeHtml(row.BranchName) + "</td><td>" + escapeHtml(row.EntryKind) + "</td><td>" + escapeHtml(row.Description) + "</td><td>" + fmt(row.DebitTotal) + "</td><td>" + fmt(row.CreditTotal) + "</td><td><button type='button' class='erp-btn erp-btn-secondary open-entry' data-id='" + row.NoteId + "'>اختيار</button></td></tr>";
                        });
                    }
                    msg("", false);
                }).catch(function (error) {
                    msg("تعذر قراءة رد السيرفر: " + error.message, true);
                });
            }

            function openEntry(id) {
                fetch(root.getAttribute("data-get-url") + "/" + encodeURIComponent(id))
                    .then(function (response) { return response.json(); })
                    .then(function (data) {
                        if (!data.success) { msg(data.message || "تعذر فتح القيد", true); return; }
                        var entry = data.entry;
                        loadedIsManual = entry.IsManual === true;
                        byId("noteId").value = entry.NoteId || "";
                        byId("noteSerialDisplay").value = entry.NoteSerial || entry.NoteSerial1 || entry.NoteId || "";
                        byId("noteDate").value = toInputDate(entry.NoteDate);
                        byId("branchId").value = entry.BranchId || "";
                        byId("entryDescription").value = entry.Description || "";
                        byId("entryKindLabel").textContent = entry.EntryKind || "";
                        byId("journalStatusBadge").textContent = entry.EntryKind || "تم فتح القيد";
                        byId("adminPasswordWrap").style.display = loadedIsManual ? "none" : "";
                        byId("journalLinesBody").innerHTML = "";
                        (entry.Lines || []).forEach(addLine);
                        byId("saveJournalBtn").disabled = !canEdit;
                        closeBrowseModal();
                        msg(loadedIsManual ? "تم فتح قيد يدوي." : "تم فتح قيد آلي للعرض. التعديل يحتاج كلمة مرور المدير العام.", false);
                    }).catch(function (error) {
                        msg("تعذر فتح القيد: " + error.message, true);
                    });
            }

            function save() {
                byId("saveJournalBtn").disabled = true;
                msg("جاري الحفظ...", false);
                postJson(root.getAttribute("data-save-url"), {
                    NoteId: byId("noteId").value || null,
                    NoteDate: byId("noteDate").value,
                    BranchId: byId("branchId").value || null,
                    Description: byId("entryDescription").value,
                    AdminPassword: byId("adminPassword").value,
                    Lines: collectLines()
                }).then(function (data) {
                    byId("saveJournalBtn").disabled = false;
                    if (!data.success) {
                        msg((data.message || "تعذر حفظ القيد") + (data.details ? " - " + data.details : ""), true);
                        return;
                    }
                    msg(data.message || "تم الحفظ بنجاح", false);
                    if (data.entry) { openEntry(data.entry.NoteId); }
                }).catch(function (error) {
                    byId("saveJournalBtn").disabled = false;
                    msg("تعذر قراءة رد السيرفر: " + error.message, true);
                });
            }

            document.addEventListener("click", function (event) {
                if (event.target.id === "browseJournalBtn") { openBrowseModal(); }
                if (event.target.id === "closeJournalBrowseBtn" || event.target.id === "journalBrowseBackdrop") { closeBrowseModal(); }
                if (event.target.id === "searchJournalBtn") { search(); }
                if (event.target.id === "clearJournalSearchBtn") { clearBrowseFilters(); }
                if (event.target.id === "newJournalBtn") { clearForm(); }
                if (event.target.id === "addLineBtn") { addLine({}); }
                if (event.target.id === "saveJournalBtn") { save(); }
                if (event.target.classList.contains("remove-line")) { event.target.closest("tr").remove(); updateTotals(); }
                if (event.target.classList.contains("open-entry")) { openEntry(event.target.getAttribute("data-id")); }
            });
            document.addEventListener("keydown", function (event) {
                if (event.key === "Escape" && byId("journalBrowseModal").classList.contains("is-open")) {
                    closeBrowseModal();
                }
            });
            document.addEventListener("input", function (event) {
                if (event.target.classList.contains("line-debit") || event.target.classList.contains("line-credit")) {
                    updateTotals();
                }
                if (event.target.classList.contains("line-account-serial")) {
                    clearTimeout(accountLookupTimer);
                    var input = event.target;
                    accountLookupTimer = setTimeout(function () { loadAccountOptions(input.value); }, 220);
                }
            });
            document.addEventListener("change", function (event) {
                if (event.target.classList.contains("line-account-serial")) {
                    applyAccountOption(event.target);
                }
            });

            clearForm();
        })();
    </script>
</body>
</html>
