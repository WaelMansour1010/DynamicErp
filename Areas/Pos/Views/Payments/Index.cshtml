@{
    Layout = null;
    ViewBag.Title = "استعاضة العهدة وتمويل الخزينة";
    var context = ViewBag.Context as MyERP.Areas.Pos.Models.PosUserContext;
    var branches = ViewBag.Branches as IEnumerable<MyERP.Areas.Pos.Models.PosBranchDto>;
    var canExecute = context != null && (context.IsFullAccess || context.CanExecutePayments);
    var canEdit = context != null && (context.IsFullAccess || context.CanEditPayments);
    var canViewJournal = context != null && (context.IsFullAccess || context.CanViewJournalEntry);
    var canChangeBranch = context != null && (context.IsFullAccess || context.CanChangeDefaults || context.UserType.GetValueOrDefault(-1) == 0);
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title</title>
    <link href="@Url.Content("~/Areas/Pos/Content/pos-transaction.css")" rel="stylesheet" />
    <style>
        .payments-index-actions {
            align-items: center;
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            justify-content: flex-end;
            margin-top: 12px;
        }

        .payments-entry-header {
            align-items: center;
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            justify-content: space-between;
            margin-bottom: 16px;
        }

        .payments-entry-header h3 {
            margin: 0;
        }

        .is-hidden-ui {
            display: none !important;
        }

        .payment-status-message {
            color: #1769aa;
            display: inline-flex;
            font-weight: 800;
            min-height: 24px;
        }

        .payment-status-message.error,
        .payment-status-message.is-error {
            color: #b42318;
        }

        .payment-status-message.success {
            color: #16834f;
        }

        .payment-required {
            color: #b42318;
            font-weight: 800;
        }

        .payment-source-cell {
            color: #475467;
            display: block;
            font-size: 12px;
            margin-top: 3px;
        }

        .payment-row-posted {
            color: #16834f;
            font-weight: 800;
        }

        .payment-row-unposted {
            color: #b45309;
            font-weight: 800;
        }

        .payment-report-summary {
            display: grid;
            gap: 8px;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            margin: 12px 0;
        }

        .payment-report-summary span {
            background: #f8fafc;
            border: 1px solid #e4e7ec;
            border-radius: 8px;
            padding: 8px 10px;
        }

        .payment-detail-modal {
            background: rgba(15, 23, 42, .48);
            bottom: 0;
            display: flex;
            left: 0;
            padding: 24px;
            position: fixed;
            right: 0;
            top: 0;
            z-index: 1000;
        }

        .payment-detail-card {
            background: #fff;
            border-radius: 8px;
            box-shadow: 0 18px 45px rgba(15, 23, 42, .22);
            margin: auto;
            max-height: 90vh;
            max-width: 980px;
            overflow: auto;
            padding: 18px;
            width: 100%;
        }

        .payment-detail-grid {
            display: grid;
            gap: 10px;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            margin: 12px 0;
        }

        .payment-detail-grid div {
            border-bottom: 1px solid #eef2f6;
            padding-bottom: 8px;
        }

        .payment-detail-grid strong {
            color: #475467;
            display: block;
            font-size: 12px;
        }

        @@media print {
            body.payment-print-list .pos-shell > *:not(#paymentIndexPanel),
            body.payment-print-list .payment-search-panel .pos-grid,
            body.payment-print-list .payments-index-actions,
            body.payment-print-list #paymentMessage,
            body.payment-print-list .load-payment-row,
            body.payment-print-list .payment-detail-modal {
                display: none !important;
            }
        }
    </style>
</head>
<body>
    <div class="pos-page pos-payments-page"
         data-preview-url="@Url.Action("Preview", "Payments", new { area = "Pos" })"
         data-save-url="@Url.Action("Create", "Payments", new { area = "Pos" })"
         data-search-url="@Url.Action("Search", "Payments", new { area = "Pos" })"
         data-get-url="@Url.Action("Get", "Payments", new { area = "Pos" })"
         data-lookup-url="@Url.Action("Lookup", "Payments", new { area = "Pos" })"
         data-lookups-url="@Url.Action("Lookups", "Payments", new { area = "Pos" })"
         data-balance-url="@Url.Action("AccountBalance", "Payments", new { area = "Pos" })"
         data-employee-custody-url="@Url.Action("EmployeeCustody", "Payments", new { area = "Pos" })"
         data-can-execute="@(canExecute ? "true" : "false")"
         data-can-edit="@(canEdit ? "true" : "false")">
        <div class="pos-shell">
            <section class="pos-panel" id="paymentIndexPanel">
                <div class="panel-heading">
                    <h2>استعاضة العهدة وتمويل الخزينة</h2>
                    <span>ابحث عن حركة سابقة أو ابدأ حركة استعاضة عهدة جديدة.</span>
                </div>

                <div class="pos-panel soft-panel payment-search-panel">
                    <div class="panel-heading">
                        <h3>بحث الحركات السابقة</h3>
                        <span>افتح الحركة للمراجعة أو التعديل حسب الصلاحية</span>
                    </div>
                    <div class="pos-grid four-cols">
                        <label>رقم/بحث عام<input type="text" id="paymentSearchText" placeholder="رقم الحركة، السند، الاسم، البيان" /></label>
                        <label>من تاريخ<input type="date" id="paymentSearchFrom" /></label>
                        <label>إلى تاريخ<input type="date" id="paymentSearchTo" /></label>
                        <label>
                            الفرع
                            <select id="paymentSearchBranch" @(context != null && !canChangeBranch ? "disabled" : "")>
                                <option value="">كل الفروع</option>
                                @if (branches != null)
                                {
                                    foreach (var branch in branches)
                                    {
                                        <option value="@branch.BranchId" @(context != null && context.BranchId == branch.BranchId ? "selected" : "")>@branch.BranchName</option>
                                    }
                                }
                            </select>
                        </label>
                        <label>
                            صاحب العهدة
                            <span class="smart-lookup" data-lookup-kind="name-account" data-target-id="paymentSearchCustodyAccount" data-text-id="paymentSearchCustodyText">
                                <input type="hidden" id="paymentSearchCustodyAccount" />
                                <input type="text" id="paymentSearchCustodyText" class="lookup-input" placeholder="اكتب كود أو اسم صاحب العهدة" autocomplete="off" />
                                <button type="button" class="lookup-clear" aria-label="مسح">×</button>
                                <span class="lookup-results" role="listbox"></span>
                            </span>
                        </label>
                        <label>
                            الموظف
                            <span class="smart-lookup" data-lookup-kind="employee" data-target-id="paymentSearchEmpId" data-text-id="paymentSearchEmpText">
                                <input type="hidden" id="paymentSearchEmpId" />
                                <input type="text" id="paymentSearchEmpText" class="lookup-input" placeholder="اكتب كود أو اسم الموظف" autocomplete="off" />
                                <button type="button" class="lookup-clear" aria-label="مسح">×</button>
                                <span class="lookup-results" role="listbox"></span>
                            </span>
                        </label>
                        <label>مصدر الدفع<input type="text" id="paymentSearchSource" placeholder="الخزنة، البنك، رقم الشيك/الحوالة" /></label>
                        <label>
                            حالة الترحيل
                            <select id="paymentSearchPosted">
                                <option value="">الكل</option>
                                <option value="1">مرحل</option>
                                <option value="0">غير مرحل</option>
                            </select>
                        </label>
                    </div>
                    <div class="payments-index-actions">
                        <button type="button" class="secondary-action" id="searchPaymentBtn">بحث</button>
                        <button type="button" class="secondary-action" id="exportPaymentReportBtn">تصدير CSV</button>
                        <button type="button" class="secondary-action" id="printPaymentReportBtn">طباعة</button>
                        <button type="button" class="secondary-action" id="newPaymentBtn">حركة جديدة</button>
                    </div>
                    <div id="paymentSearchResult" class="report-result compact-result"></div>
                </div>
            </section>

            <section class="pos-panel is-hidden-ui" id="paymentEntryPanel">
                <div class="payments-entry-header">
                    <div>
                        <h3>حركة استعاضة العهدة</h3>
                        <span>بيانات الحركة والقيد المحاسبي</span>
                    </div>
                    <button type="button" class="secondary-action" id="backToPaymentIndexBtn">رجوع للبحث</button>
                </div>

                <div class="payments-section-title">
                    <h3>بيانات الحركة</h3>
                    <span>حدد نوع الحركة والحساب الرئيسي للحركة</span>
                </div>

                <div class="payments-tab-panel active payment-section" data-payment-panel="main">
                    <input type="hidden" id="paymentNoteId" />
                    <input type="hidden" id="paymentClientRequestId" />
                    <div class="pos-grid four-cols">
                        <label>
                            الفرع
                            <select id="paymentBranchId" @(context != null && !canChangeBranch ? "disabled" : "")>
                                @if (branches != null)
                                {
                                    foreach (var branch in branches)
                                    {
                                        <option value="@branch.BranchId" @(context != null && context.BranchId == branch.BranchId ? "selected" : "")>@branch.BranchName</option>
                                    }
                                }
                            </select>
                        </label>
                        <label>
                            التاريخ
                            <input type="date" id="paymentDate" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        </label>
                        <label>
                            نوع المدفوعات
                            <select id="paymentCashingType">
                                <option value="5">استعاضة عهدة</option>
                                <option value="6">تمويل خزينة</option>
                            </select>
                        </label>
                        <label>
                            القيمة
                            <input type="number" id="paymentValue" min="0" step="0.01" />
                        </label>
                    </div>
                    <div class="pos-grid two-cols">
                        <label>
                            صاحب العهدة <span class="payment-required">*</span>
                            <span class="smart-lookup" data-lookup-kind="name-account" data-target-id="paymentNameAccount" data-text-id="paymentNameAccountText">
                                <input type="hidden" id="paymentNameAccount" />
                                <input type="text" id="paymentNameAccountText" class="lookup-input" placeholder="اكتب كود أو اسم صاحب العهدة" autocomplete="off" />
                                <button type="button" class="lookup-clear" aria-label="مسح">×</button>
                                <span class="lookup-results" role="listbox"></span>
                            </span>
                            <small id="paymentNameBalance" class="field-hint"></small>
                        </label>
                        <label>
                            البيان
                            <input type="text" id="paymentRemarks" />
                        </label>
                    </div>
                </div>

                <div class="payments-section-title">
                    <h3>القيم والدفع</h3>
                    <span>اختر طريقة الدفع والخزنة أو البنك عند الحاجة</span>
                </div>

                <div class="payments-tab-panel active payment-section" data-payment-panel="pay">
                    <div class="pos-grid four-cols">
                        <label>
                            طريقة الدفع
                            <select id="paymentMethod">
                                <option value="0">نقدي</option>
                                <option value="1">شيك</option>
                                <option value="2">حوالة</option>
                                <option value="3">شيك مسدد</option>
                            </select>
                        </label>
                        <label>
                            الخزنة
                            <span class="smart-lookup" data-lookup-kind="box" data-target-id="paymentBoxId" data-text-id="paymentBoxText">
                                <input type="hidden" id="paymentBoxId" />
                                <input type="text" id="paymentBoxText" class="lookup-input" placeholder="اكتب كود أو اسم الخزنة" autocomplete="off" />
                                <button type="button" class="lookup-clear" aria-label="مسح">×</button>
                                <span class="lookup-results" role="listbox"></span>
                            </span>
                        </label>
                        <label>
                            البنك
                            <span class="smart-lookup" data-lookup-kind="bank" data-target-id="paymentBankId" data-text-id="paymentBankText">
                                <input type="hidden" id="paymentBankId" />
                                <input type="text" id="paymentBankText" class="lookup-input" placeholder="اكتب كود أو اسم البنك" autocomplete="off" />
                                <button type="button" class="lookup-clear" aria-label="مسح">×</button>
                                <span class="lookup-results" role="listbox"></span>
                            </span>
                        </label>
                        <label>
                            رقم الشيك/الحوالة
                            <input type="text" id="paymentReferenceNo" />
                        </label>
                    </div>
                    <div class="pos-grid two-cols">
                        <label>
                            تاريخ الاستحقاق/الحوالة
                            <input type="date" id="paymentReferenceDate" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        </label>
                        <label>
                            وصف عام
                            <input type="text" id="paymentGeneralDescription" />
                        </label>
                    </div>
                </div>

                <div class="payments-section-title">
                    <h3>الحسابات</h3>
                    <span>استعاضة العهدة تسجل بكامل قيمة الحركة من صاحب العهدة إلى الخزنة أو البنك</span>
                </div>

                <div class="payments-tab-panel active payment-section" data-payment-panel="accounts">
                    <div class="empty-state">
                        لا تدخل قيمة في هذا الجزء. اكتب المبلغ في خانة <strong>القيمة</strong> أعلى الشاشة فقط، وسيتم تكوين القيد تلقائياً: صاحب العهدة مدين والخزنة/البنك دائن.
                    </div>
                    <div class="pos-grid four-cols">
                        <label>
                            قيمة الخزنة
                            <input type="number" id="paymentBoxValue" min="0" step="0.01" value="0" readonly />
                            <small class="field-hint">تستخدم خانة القيمة أعلى الشاشة بدلاً منها</small>
                        </label>
                        <label>
                            الموظف / صاحب العهدة الفرعي
                            <span class="smart-lookup" data-lookup-kind="employee" data-target-id="paymentEmpId" data-text-id="paymentEmpText" data-extra-target-id="paymentEmpAccountCode">
                                <input type="hidden" id="paymentEmpId" />
                                <input type="text" id="paymentEmpText" class="lookup-input" placeholder="اكتب كود أو اسم الموظف" autocomplete="off" />
                                <button type="button" class="lookup-clear" aria-label="مسح">×</button>
                                <span class="lookup-results" role="listbox"></span>
                            </span>
                        </label>
                        <label>
                            حساب العهدة
                            <input type="hidden" id="paymentEmpAccountCode" />
                            <input type="text" id="paymentEmpAccountDisplay" readonly />
                            <small id="paymentEmpWarning" class="field-hint"></small>
                        </label>
                        <label>
                            قيمة العهدة
                            <input type="number" id="paymentEmpValue" min="0" step="0.01" value="0" readonly />
                            <small class="field-hint">تظل صفر في استعاضة العهدة</small>
                        </label>
                    </div>
                </div>

                <div class="payments-section-title">
                    <h3>القيد المحاسبي / المعاينة</h3>
                    <span>استعرض القيد قبل الحفظ حسب الصلاحية</span>
                </div>

                <div class="payments-tab-panel active payment-section" data-payment-panel="journal">
                    @if (canViewJournal)
                    {
                        <div class="pos-actions">
                            <button type="button" class="secondary-action" id="previewPaymentBtn">استعراض القيد</button>
                        </div>
                        <div id="paymentJournalResult" class="report-result"></div>
                    }
                    else
                    {
                        <div class="empty-state">ليست لديك صلاحية استعراض القيد</div>
                    }
                </div>

                <div class="pos-actions">
                    <button type="button" class="primary-action" id="savePaymentBtn" @(canExecute ? "" : "disabled")>تنفيذ العملية</button>
                    <span id="paymentMessage" class="payment-status-message" role="status" aria-live="polite"></span>
                </div>
            </section>
        </div>

    </div>

    <div id="paymentDetailModal" class="payment-detail-modal is-hidden-ui" role="dialog" aria-modal="true" aria-labelledby="paymentDetailTitle">
        <div class="payment-detail-card">
            <div class="payments-entry-header">
                <div>
                    <h3 id="paymentDetailTitle">تفاصيل حركة استعاضة العهدة</h3>
                    <span id="paymentDetailSubtitle"></span>
                </div>
                <button type="button" class="secondary-action" id="closePaymentDetailBtn">إغلاق</button>
            </div>
            <div id="paymentDetailContent"></div>
        </div>
    </div>

    <script>
        (function () {
            var page = document.querySelector(".pos-payments-page");
            var message = document.getElementById("paymentMessage");
            var canExecutePayment = page.getAttribute("data-can-execute") === "true";
            var paymentPreviewTimer = null;
            var paymentPreviewValid = false;
            var paymentSearchRunning = false;
            var paymentSaveRunning = false;
            var paymentReadOnly = false;
            var paymentLastSearchRows = [];
            var paymentLastSearchTotals = null;
            function byId(id) { return document.getElementById(id); }
            function setMessage(text, error, success) {
                message.innerText = text || "";
                message.classList.toggle("error", !!error);
                message.classList.toggle("is-error", !!error);
                message.classList.toggle("success", !!success && !error);
            }
            function todayText(offsetDays) {
                var date = new Date();
                date.setDate(date.getDate() + (offsetDays || 0));
                return date.getFullYear() + "-" + ("0" + (date.getMonth() + 1)).slice(-2) + "-" + ("0" + date.getDate()).slice(-2);
            }
            function initPaymentSearchDefaults() {
                if (byId("paymentSearchFrom") && !byId("paymentSearchFrom").value) { byId("paymentSearchFrom").value = todayText(0); }
                if (byId("paymentSearchTo") && !byId("paymentSearchTo").value) { byId("paymentSearchTo").value = todayText(0); }
            }
            function validatePaymentSearch() {
                var term = (byId("paymentSearchText").value || "").trim();
                var from = byId("paymentSearchFrom").value || "";
                var to = byId("paymentSearchTo").value || "";
                if (term && term.length < 3 && !/^[0-9]{3,}$/.test(term)) {
                    return "اكتب 3 أحرف على الأقل للبحث العام.";
                }
                if (!from || !to) {
                    return term.length >= 3 ? "" : "حدد فترة البحث أو اكتب بحثاً محدداً من 3 أحرف على الأقل.";
                }
                return "";
            }
            function setSearchButtonBusy(value) {
                var button = byId("searchPaymentBtn");
                if (!button) { return; }
                button.disabled = !!value;
                button.innerText = value ? "جاري البحث..." : "بحث";
            }
            function escapeHtml(value) {
                return String(value || "").replace(/[&<>"']/g, function (ch) {
                    return ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" })[ch];
                });
            }
            function lookupUrl(kind, term) {
                var url = page.getAttribute("data-lookup-url") + "?kind=" + encodeURIComponent(kind || "") + "&term=" + encodeURIComponent(term || "");
                if (kind === "name-account") {
                    url += "&cashingType=" + encodeURIComponent(byId("paymentCashingType").value || "5");
                }
                url += "&branchId=" + encodeURIComponent(currentLookupBranchId(kind) || "");
                return url;
            }
            function currentLookupBranchId(kind) {
                if (document.activeElement && document.activeElement.id && document.activeElement.id.indexOf("paymentSearch") === 0) {
                    return byId("paymentSearchBranch").value || byId("paymentBranchId").value || "";
                }
                return byId("paymentBranchId").value || byId("paymentSearchBranch").value || "";
            }
            function setLookupValue(hiddenId, textId, id, text, extra) {
                var hidden = byId(hiddenId);
                var input = byId(textId);
                if (hidden) { hidden.value = id === null || id === undefined ? "" : id; hidden.setAttribute("data-extra", extra || ""); }
                if (input) { input.value = text || ""; }
            }
            function clearLookup(wrapper) {
                if (!wrapper) { return; }
                setLookupValue(wrapper.getAttribute("data-target-id"), wrapper.getAttribute("data-text-id"), "", "", "");
                var extraTarget = wrapper.getAttribute("data-extra-target-id");
                if (extraTarget && byId(extraTarget)) { byId(extraTarget).value = ""; }
                var results = wrapper.querySelector(".lookup-results");
                if (results) { results.innerHTML = ""; results.classList.remove("is-open"); }
                afterLookupChange(wrapper.getAttribute("data-target-id"));
            }
            function selectLookupRow(wrapper, row) {
                setLookupValue(wrapper.getAttribute("data-target-id"), wrapper.getAttribute("data-text-id"), row.id, row.text, row.extra);
                var extraTarget = wrapper.getAttribute("data-extra-target-id");
                if (extraTarget && byId(extraTarget)) { byId(extraTarget).value = row.extra || ""; }
                var results = wrapper.querySelector(".lookup-results");
                if (results) { results.innerHTML = ""; results.classList.remove("is-open"); }
                afterLookupChange(wrapper.getAttribute("data-target-id"));
            }
            function renderLookupRows(wrapper, rows) {
                var results = wrapper.querySelector(".lookup-results");
                if (!results) { return; }
                if (!rows || !rows.length) {
                    results.innerHTML = "<button type='button' class='lookup-row empty' disabled>لا توجد نتائج</button>";
                    results.classList.add("is-open");
                    return;
                }
                results.innerHTML = rows.map(function (row, index) {
                    return "<button type='button' class='lookup-row' data-index='" + index + "'><strong>" + escapeHtml(row.text || "") + "</strong></button>";
                }).join("");
                results._rows = rows;
                results.classList.add("is-open");
            }
            function setupLookup(wrapper) {
                var input = byId(wrapper.getAttribute("data-text-id"));
                var clearButton = wrapper.querySelector(".lookup-clear");
                var timer = null;
                if (!input) { return; }
                function runLookup(term) {
                    var results = wrapper.querySelector(".lookup-results");
                    if (results) { results.innerHTML = "<button type='button' class='lookup-row empty' disabled>جاري البحث...</button>"; results.classList.add("is-open"); }
                    var xhr = new XMLHttpRequest();
                    xhr.open("GET", lookupUrl(wrapper.getAttribute("data-lookup-kind"), term), true);
                    xhr.onreadystatechange = function () {
                        if (xhr.readyState !== 4) { return; }
                        var data = null;
                        try { data = xhr.responseText ? JSON.parse(xhr.responseText) : null; } catch (ignore) { }
                        renderLookupRows(wrapper, data && data.success ? (data.rows || []) : []);
                    };
                    xhr.send();
                }
                input.addEventListener("input", function () {
                    var term = input.value.trim();
                    byId(wrapper.getAttribute("data-target-id")).value = "";
                    window.clearTimeout(timer);
                    if (term.length < 2) {
                        var results = wrapper.querySelector(".lookup-results");
                        if (results) { results.innerHTML = ""; results.classList.remove("is-open"); }
                        return;
                    }
                    timer = window.setTimeout(function () {
                        runLookup(term);
                    }, 250);
                });
                input.addEventListener("focus", function () {
                    if (input.value.trim().length === 0) {
                        runLookup("");
                    }
                });
                input.addEventListener("keydown", function (event) {
                    var results = wrapper.querySelector(".lookup-results");
                    if (!results || !results.classList.contains("is-open")) { return; }
                    var rows = Array.prototype.slice.call(results.querySelectorAll(".lookup-row:not(.empty)"));
                    if (!rows.length) { return; }
