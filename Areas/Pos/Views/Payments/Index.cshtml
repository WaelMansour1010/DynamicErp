                clearLookup(document.querySelector('[data-target-id="paymentNameAccount"]'));
                clearLookup(document.querySelector('[data-target-id="paymentBoxId"]'));
                clearLookup(document.querySelector('[data-target-id="paymentBankId"]'));
                clearLookup(document.querySelector('[data-target-id="paymentEmpId"]'));
                clearLookup(document.querySelector('[data-target-id="paymentSearchEmpId"]'));
                renderLines([]);
                setPreviewValid(false);
                paymentReadOnly = false;
                byId("savePaymentBtn").innerText = "تنفيذ العملية";
                setMessage("");
                applyPaymentMethodRules();
                validateCurrentRelationships();
                showEntry();
            }
            function applyMovement(movement, canEdit, editMessage) {
                if (!movement) { return; }
                byId("paymentNoteId").value = movement.NoteId || "";
                byId("paymentClientRequestId").value = createClientRequestId();
                setSelectValue("paymentBranchId", movement.BranchId);
                byId("paymentDate").value = dateText(movement.NoteDate);
                setSelectValue("paymentCashingType", movement.CashingType);
                setLookupValue("paymentNameAccount", "paymentNameAccountText", movement.NameAccountCode || "", accountDisplayName(movement), "");
                setSelectValue("paymentMethod", movement.PaymentMethod);
                byId("paymentValue").value = movement.Value || 0;
                setLookupValue("paymentBoxId", "paymentBoxText", movement.BoxId || "", movement.BoxName || "", "");
                setLookupValue("paymentBankId", "paymentBankText", movement.BankId || "", movement.BankName || "", "");
                byId("paymentReferenceNo").value = movement.ReferenceNo || "";
                byId("paymentReferenceDate").value = dateText(movement.ReferenceDate);
                setLookupValue("paymentEmpId", "paymentEmpText", movement.EmpId || "", movement.EmpName || "", movement.EmpAccountCode || "");
                byId("paymentEmpAccountCode").value = movement.EmpAccountCode || "";
                byId("paymentEmpAccountDisplay").value = "";
                byId("paymentBoxValue").value = 0;
                byId("paymentEmpValue").value = 0;
                byId("paymentRemarks").value = movement.Remarks || "";
                byId("paymentGeneralDescription").value = movement.GeneralDescription || "";
                renderLines(movement.Lines || []);
                paymentReadOnly = !canEdit;
                paymentPreviewValid = !!canEdit;
                byId("savePaymentBtn").disabled = !canEdit;
                byId("savePaymentBtn").innerText = canEdit ? "حفظ التعديل" : "عرض فقط";
                setMessage(canEdit ? "تم تحميل الحركة للتعديل" : (editMessage || "ليس لديك صلاحية تعديل هذه الحركة"), !canEdit);
                applyPaymentMethodRules();
                loadAccountBalance();
                loadEmployeeCustody({ useLoadedAccount: true });
                validateCurrentRelationships();
                showEntry();
            }
            document.addEventListener("click", function (event) {
                if (event.target.getAttribute("data-payment-tab")) {
                    var tab = event.target.getAttribute("data-payment-tab");
                    document.querySelectorAll("[data-payment-tab]").forEach(function (x) { x.classList.toggle("active", x === event.target); });
                    document.querySelectorAll("[data-payment-panel]").forEach(function (x) { x.classList.toggle("active", x.getAttribute("data-payment-panel") === tab); });
                }
                if (event.target.id === "previewPaymentBtn") {
                    var previewPayload = requestPayload();
                    var previewValidation = validatePaymentForm(previewPayload);
                    if (previewValidation) {
                        setPreviewValid(false);
                        renderLines([]);
                        setMessage(previewValidation, true);
                        return;
                    }
                    setMessage("جاري استعراض القيد...");
                    post(page.getAttribute("data-preview-url"), previewPayload, function (status, data) {
                        if (data && data.success) { renderLines(data.lines || []); setPreviewValid(true); setMessage(""); } else { setPreviewValid(false); setMessage((data && data.message) || "تعذر استعراض القيد", true); }
                    });
                }
                if (event.target.id === "savePaymentBtn") {
                    if (paymentReadOnly) { return; }
                    if (paymentSaveRunning) { return; }
                    var payload = requestPayload();
                    var validation = validatePaymentForm(payload);
                    if (validation) {
                        setMessage(validation, true);
                        setPreviewValid(false);
                        refreshPaymentPreview();
                        return;
                    }
                    if (!paymentPreviewValid) {
                        refreshPaymentPreview();
                        setMessage("راجع القيد المحاسبي قبل الحفظ", true);
                        return;
                    }
                    setMessage("جاري الحفظ...");
                    setSaveBusy(true);
                    post(page.getAttribute("data-save-url"), payload, function (status, data) {
                        setSaveBusy(false);
                        if (data && data.success) {
                            if (data.result && data.result.NoteId) { byId("paymentNoteId").value = data.result.NoteId; }
                            renderLines(data.result && data.result.Lines);
                            setPreviewValid(true);
                            byId("savePaymentBtn").innerText = "حفظ التعديل";
                            setMessage((data.message || "تم الحفظ بنجاح") + " - رقم السند: " + ((data.result && (data.result.NoteSerial1 || data.result.NoteSerial || data.result.NoteId)) || ""), false, true);
                        }
                        else { setPreviewValid(false); setMessage((data && data.message) || "تعذر حفظ العملية", true); }
                    });
                }
                if (event.target.id === "searchPaymentBtn") {
                    var validationMessage = validatePaymentSearch();
                    if (validationMessage) {
                        setMessage(validationMessage, true);
                        return;
                    }
                    if (paymentSearchRunning) { return; }
                    paymentSearchRunning = true;
                    setSearchButtonBusy(true);
                    setMessage("جاري البحث...");
                    post(page.getAttribute("data-search-url"), searchPayload(), function (status, data) {
                        paymentSearchRunning = false;
                        setSearchButtonBusy(false);
                        if (data && data.success) { renderSearch(data.rows || [], data.totals || null); setMessage("تم البحث", false); }
                        else { setMessage((data && data.message) || "تعذر البحث", true); }
                    });
                }
                if (event.target.id === "exportPaymentReportBtn") {
                    exportPaymentReportCsv();
                }
                if (event.target.id === "printPaymentReportBtn") {
                    printPaymentReport();
                }
                if (event.target.id === "newPaymentBtn") {
                    resetPaymentForm();
                }
                if (event.target.id === "closePaymentDetailBtn" || event.target.id === "paymentDetailModal") {
                    byId("paymentDetailModal").classList.add("is-hidden-ui");
                }
                if (event.target.id === "backToPaymentIndexBtn") {
                    showIndex();
                }
                if (event.target.classList && event.target.classList.contains("show-payment-detail")) {
                    var detailId = event.target.getAttribute("data-note-id");
                    var detailXhr = new XMLHttpRequest();
                    detailXhr.open("GET", page.getAttribute("data-get-url").replace(/\/$/, "") + "/" + encodeURIComponent(detailId), true);
                    detailXhr.onreadystatechange = function () {
                        if (detailXhr.readyState !== 4) { return; }
                        var detailData = null;
                        try { detailData = detailXhr.responseText ? JSON.parse(detailXhr.responseText) : null; } catch (ignore) { }
                        if (detailXhr.status >= 200 && detailXhr.status < 300 && detailData && detailData.success) {
                            renderPaymentDetail(detailData.movement, detailData.canEdit, detailData.editMessage);
                        } else {
                            setMessage((detailData && detailData.message) || "تعذر تحميل تفاصيل الحركة", true);
                        }
                    };
                    detailXhr.send();
                }
                if (event.target.classList && event.target.classList.contains("load-payment-row")) {
                    var id = event.target.getAttribute("data-note-id");
                    var xhr = new XMLHttpRequest();
                    xhr.open("GET", page.getAttribute("data-get-url").replace(/\/$/, "") + "/" + encodeURIComponent(id), true);
                    xhr.onreadystatechange = function () {
                        if (xhr.readyState !== 4) { return; }
                        var data = null;
                        try { data = xhr.responseText ? JSON.parse(xhr.responseText) : null; } catch (ignore) { }
                        if (xhr.status >= 200 && xhr.status < 300 && data && data.success) {
                            applyMovement(data.movement, data.canEdit, data.editMessage);
                        } else {
                            setMessage((data && data.message) || "تعذر تحميل الحركة", true);
                        }
                    };
                    xhr.send();
                }
            });
            byId("paymentCashingType").addEventListener("change", function () {
                clearLookup(document.querySelector('[data-target-id="paymentNameAccount"]'));
                validateCurrentRelationships();
                schedulePaymentPreview();
            });
            byId("paymentBranchId").addEventListener("change", function () {
                validateCurrentRelationships();
                loadAccountBalance();
                loadEmployeeCustody();
            });
            byId("paymentMethod").addEventListener("change", applyPaymentMethodRules);
            ["paymentDate", "paymentValue", "paymentReferenceNo", "paymentReferenceDate", "paymentBoxValue", "paymentEmpValue", "paymentRemarks", "paymentGeneralDescription"].forEach(function (id) {
                var element = byId(id);
                if (!element) { return; }
                element.addEventListener("input", function () {
                    if (id === "paymentDate") { loadAccountBalance(); }
                    schedulePaymentPreview();
                });
                element.addEventListener("change", schedulePaymentPreview);
            });
            document.querySelectorAll(".smart-lookup").forEach(setupLookup);
            initPaymentSearchDefaults();
            byId("paymentClientRequestId").value = createClientRequestId();
            applyPaymentMethodRules();
            updateSaveButton();
        })();
    </script>
</body>
</html>
