@{
    Layout = null;
    ViewBag.Title = "كيشني - لوحة التشغيل";
    var posContext = ViewBag.PosContext as MyERP.Areas.Pos.Models.PosUserContext;
    var branches = ViewBag.Branches as IEnumerable<MyERP.Areas.Pos.Models.PosBranchDto>;
    var activeScreen = (ViewBag.ActiveScreen as string) ?? "sales";
    var initialScreenUrl = (ViewBag.InitialScreenUrl as string) ?? Url.Content("~/Pos/PosTransaction/Index");
    var canViewReports = posContext != null && posContext.CanViewReports;
    var isAdmin = posContext != null && posContext.IsFullAccess;
    var logoPath = "~/Areas/Pos/assets/images/company-logo.png";
    var logoAltPath = "~/Areas/Pos/assets/images/company-logo-1.png";
    var companyLogoPath = System.IO.File.Exists(Server.MapPath(logoPath))
        ? logoPath
        : (System.IO.File.Exists(Server.MapPath(logoAltPath)) ? logoAltPath : null);
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title</title>
    <link href="@Url.Content("~/Areas/Pos/Content/pos-transaction.css")" rel="stylesheet" />
    <script src="@Url.Content("~/assets/libs/chart-js/Chart.bundle.min.js")"></script>
</head>
<body>
    <div class="pos-main-shell" dir="rtl"
         data-dashboard-summary-url="@Url.Action("Summary", "PosDashboard", new { area = "Pos" })"
         data-sales-url="@Url.Content("~/Pos/PosTransaction/Index")"
         data-is-admin="@(isAdmin ? "true" : "false")">
        <aside class="pos-main-sidebar">
            <div class="pos-main-logo">
                @if (!string.IsNullOrWhiteSpace(companyLogoPath))
                {
                    <img src="@Url.Content(companyLogoPath)" alt="Keshni" />
                }
                else
                {
                    <strong>كيشني</strong>
                }
            </div>

            <nav class="pos-main-nav" aria-label="قائمة نقطة البيع">
                @if (isAdmin)
                {
                    <a class="@(activeScreen == "dashboard" ? "active" : "")"
                       href="@Url.Action("Index", "PosDashboard", new { area = "Pos" })"
                       data-dashboard-screen="true">Dashboard الإدارة</a>
                }
                <a class="@(activeScreen == "sales" ? "active" : "")"
                   href="@Url.Action("Sales", "PosDashboard", new { area = "Pos" })"
                   data-screen-url="@Url.Content("~/Pos/PosTransaction/Index")">شاشة البيع</a>
                <a class="@(activeScreen == "closing" ? "active" : "")"
                   href="@Url.Action("Closing", "PosDashboard", new { area = "Pos" })"
                   data-screen-url="@Url.Content("~/Pos/PosClosing/Index")">الإغلاق</a>
                <a class="@(activeScreen == "kyc" ? "active" : "")"
                   href="@Url.Action("Kyc", "PosDashboard", new { area = "Pos" })"
                   data-screen-url="@Url.Content("~/Pos/PosTransaction/Index?openKyc=true")">KYC</a>
                @if (canViewReports)
                {
                    <a class="@(activeScreen == "reports" ? "active" : "")"
                       href="@Url.Action("Reports", "PosDashboard", new { area = "Pos" })"
                       data-screen-url="@Url.Content("~/Pos/PosReports/Index")">تقارير</a>
                }
                @if (isAdmin || (posContext != null && posContext.CanOpenPayments))
                {
                    <a class="@(activeScreen == "payments" ? "active" : "")"
                       href="@Url.Action("Payments", "PosDashboard", new { area = "Pos" })"
                       data-screen-url="@Url.Content("~/Pos/Payments/Index")">تمويل واستعاضة</a>
                }
                @if (isAdmin)
                {
                    <a class="@(activeScreen == "permissions" ? "active" : "")"
                       href="@Url.Action("Index", "PosPermissions", new { area = "Pos" })"
                       data-screen-url="@Url.Content("~/Pos/PosPermissions/Index")">صلاحيات POS</a>
                }
            </nav>
        </aside>

        <main class="pos-main-content">
            <header class="pos-main-topbar">
                <div>
                    <h1>لوحة تشغيل كيشني</h1>
                    <p>المستخدم: @(posContext != null ? posContext.UserName : "") | الفرع: @(posContext != null ? posContext.BranchName : "")</p>
                </div>
                @using (Html.BeginForm("Logout", "PosLogin", new { area = "Pos" }, FormMethod.Post, new { @class = "pos-main-logout" }))
                {
                    @Html.AntiForgeryToken()
                    <button type="submit">خروج</button>
                }
            </header>

            @if (isAdmin)
            {
                <section id="adminDashboardPanel" class="pos-admin-dashboard @(activeScreen == "dashboard" ? "" : "is-hidden-ui")">
                    <div class="pos-panel">
                        <div class="panel-heading">
                            <h2>Dashboard الإدارة</h2>
                            <button type="button" class="link-action" id="reloadAdminDashboardBtn">تحديث</button>
                        </div>
                        <div class="pos-grid four-cols reports-filter-grid dashboard-filter-grid">
                            <label>من تاريخ<input type="date" id="dashboardFromDate" value="@DateTime.Today.ToString("yyyy-MM-dd")" /></label>
                            <label>إلى تاريخ<input type="date" id="dashboardToDate" value="@DateTime.Today.ToString("yyyy-MM-dd")" /></label>
                            <label>
                                الفرع
                                <select id="dashboardBranchId">
                                    <option value="">كل الفروع</option>
                                    @if (branches != null)
                                    {
                                        foreach (var branch in branches)
                                        {
                                            <option value="@branch.BranchId">@branch.BranchName</option>
                                        }
                                    }
                                </select>
                            </label>
                            <label>نوع العملية<select id="dashboardOperationType"><option value="">كل العمليات</option><option value="cash-in">Cash In</option><option value="cash-out">Cash Out</option><option value="card">كارت كيشني</option><option value="violations">مخالفات</option></select></label>
                        </div>
                    </div>

                    <div id="adminDashboardMessage" class="pos-validation"></div>
                    <div id="adminDashboardKpis" class="admin-kpi-grid"></div>

                    <div class="admin-dashboard-grid">
                        <section class="pos-panel">
                            <div class="panel-heading"><h2>تحليل نوع العملية</h2></div>
                            <div class="dashboard-chart-wrap"><canvas id="operationDonutChart"></canvas></div>
                            <div id="adminOperationSummary" class="report-result compact-result"></div>
                        </section>
                        <section class="pos-panel">
                            <div class="panel-heading"><h2>Top 5 Branches</h2></div>
                            <div class="dashboard-chart-wrap"><canvas id="branchBarChart"></canvas></div>
                            <div id="adminBranchComparison" class="report-result"></div>
                        </section>
                        <section class="pos-panel">
                            <div class="panel-heading"><h2>الخدمات الأكثر استخدامًا</h2></div>
                            <div class="dashboard-chart-wrap"><canvas id="topServicesChart"></canvas></div>
                            <div id="adminTopServices" class="report-result"></div>
                        </section>
                        <section class="pos-panel">
                            <div class="panel-heading"><h2>Daily Trend</h2></div>
                            <div class="dashboard-chart-wrap"><canvas id="dailyTrendChart"></canvas></div>
                            <div id="adminDailyTrend" class="report-result"></div>
                        </section>
                    </div>
                </section>
            }

            <section id="posFrameSection" class="pos-main-frame-card @(activeScreen == "dashboard" ? "is-hidden-ui" : "")">
                <iframe id="posMainFrame"
                        title="POS screen"
                        src="@initialScreenUrl"
                        loading="eager"></iframe>
            </section>
        </main>
    </div>

    <script>
        (function () {
            var shell = document.querySelector(".pos-main-shell");
            var frame = document.getElementById("posMainFrame");
            var links = document.querySelectorAll("[data-screen-url]");
            var dashboardLink = document.querySelector("[data-dashboard-screen]");
            var dashboardPanel = document.getElementById("adminDashboardPanel");
            var frameSection = document.getElementById("posFrameSection");
            var charts = {};

            function escapeHtml(value) {
                return String(value === null || value === undefined ? "" : value)
                    .replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
            }

            function money(value) {
                var number = parseFloat(value || 0);
                return isNaN(number) ? "0.00" : number.toFixed(2);
            }

            function operationLabel(value) {
                if (value === "cash-in") { return "Cash In"; }
                if (value === "cash-out") { return "Cash Out"; }
                if (value === "card") { return "كارت كيشني"; }
                if (value === "violations") { return "مخالفات"; }
                return value || "";
            }

            function destroyChart(id) {
                if (charts[id]) {
                    charts[id].destroy();
                    charts[id] = null;
                }
            }

            function renderChart(id, type, labels, values, title) {
                var canvas = document.getElementById(id);
                if (!canvas || typeof Chart === "undefined") { return; }
                destroyChart(id);
                if (!labels || !labels.length) {
                    var parent = canvas.parentNode;
                    if (parent) { parent.setAttribute("data-empty", "لا توجد بيانات للعرض"); }
                    return;
                }
                if (canvas.parentNode) { canvas.parentNode.removeAttribute("data-empty"); }
                charts[id] = new Chart(canvas.getContext("2d"), {
                    type: type,
                    data: {
                        labels: labels,
                        datasets: [{
                            label: title || "",
                            data: values,
                            backgroundColor: ["#2563eb", "#7c3aed", "#f97316", "#14b8a6", "#0ea5e9", "#22c55e"],
                            borderColor: "#ffffff",
                            borderWidth: type === "line" ? 2 : 1,
                            fill: type === "line" ? false : true
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        legend: { display: type === "doughnut", position: "bottom" },
                        scales: type === "doughnut" ? {} : {
                            yAxes: [{ ticks: { beginAtZero: true } }],
                            xAxes: [{ ticks: { autoSkip: false } }]
                        }
                    }
                });
            }

            function setActive(url, dashboard) {
                for (var i = 0; i < links.length; i++) {
                    var linkUrl = links[i].getAttribute("data-screen-url");
                    links[i].classList.toggle("active", !dashboard && linkUrl === url);
                }
                if (dashboardLink) { dashboardLink.classList.toggle("active", !!dashboard); }
            }

            function showFrame(url) {
                if (!url || !frame) { return; }
                if (dashboardPanel) { dashboardPanel.classList.add("is-hidden-ui"); }
                if (frameSection) { frameSection.classList.remove("is-hidden-ui"); }
                frame.src = url;
                setActive(url, false);
            }

            function showDashboard() {
                if (!dashboardPanel) { return; }
                if (frameSection) { frameSection.classList.add("is-hidden-ui"); }
                dashboardPanel.classList.remove("is-hidden-ui");
                setActive("", true);
                loadAdminDashboard();
            }

            function renderTable(targetId, columns, rows) {
                var target = document.getElementById(targetId);
                if (!target) { return; }
                if (!rows || !rows.length) {
                    target.innerHTML = "<div class=\"empty-state\">لا توجد بيانات</div>";
                    return;
                }
                var html = "<div class=\"responsive-table\"><table class=\"pos-table\"><thead><tr>";
                for (var c = 0; c < columns.length; c++) { html += "<th>" + escapeHtml(columns[c].title) + "</th>"; }
                html += "</tr></thead><tbody>";
                for (var r = 0; r < rows.length; r++) {
                    html += "<tr>";
                    for (var x = 0; x < columns.length; x++) {
                        var value = rows[r][columns[x].key];
                        html += "<td>" + escapeHtml(columns[x].money ? money(value) : value) + "</td>";
                    }
                    html += "</tr>";
                }
                html += "</tbody></table></div>";
                target.innerHTML = html;
            }

            function renderKpis(kpis) {
                var target = document.getElementById("adminDashboardKpis");
                if (!target) { return; }
                kpis = kpis || {};
                var items = [
                    ["إجمالي عدد الحركات", kpis.TransactionCount || 0],
                    ["إجمالي قيمة المبيعات/الشحن", money(kpis.SalesTotal)],
                    ["إجمالي الرسوم", money(kpis.FeesTotal)],
                    ["إجمالي الضريبة", money(kpis.VatTotal)],
                    ["صافي التحصيل", money(kpis.NetCollection)],
                    ["كروت KYC المفعلة", kpis.ActivatedKycCards || 0],
                    ["فواتير ملغاة/مرتجعة", kpis.CancelledOrReturnedCount || 0]
                ];
                var html = "";
                for (var i = 0; i < items.length; i++) {
                    html += "<article><span>" + escapeHtml(items[i][0]) + "</span><strong>" + escapeHtml(items[i][1]) + "</strong></article>";
                }
                target.innerHTML = html;
            }

            function loadAdminDashboard() {
                if (!shell || shell.getAttribute("data-is-admin") !== "true") { return; }
                var message = document.getElementById("adminDashboardMessage");
                if (message) { message.innerText = "جاري تحميل Dashboard الإدارة..."; }
                var url = shell.getAttribute("data-dashboard-summary-url")
                    + "?fromDate=" + encodeURIComponent(document.getElementById("dashboardFromDate").value)
                    + "&toDate=" + encodeURIComponent(document.getElementById("dashboardToDate").value)
                    + "&branchId=" + encodeURIComponent(document.getElementById("dashboardBranchId").value || "")
                    + "&operationType=" + encodeURIComponent(document.getElementById("dashboardOperationType").value || "");
                var xhr = new XMLHttpRequest();
                xhr.open("GET", url, true);
                xhr.onreadystatechange = function () {
                    if (xhr.readyState !== 4) { return; }
                    var response = null;
                    try { response = xhr.responseText ? JSON.parse(xhr.responseText) : null; } catch (ignore) { }
                    if (xhr.status < 200 || xhr.status >= 300 || !response || !response.success) {
                        if (message) { message.innerText = (response && response.message) || "تعذر تحميل Dashboard الإدارة"; }
                        return;
                    }
                    if (message) { message.innerText = "تم تحميل البيانات"; }
                    var data = response.data || {};
                    renderKpis(data.Kpis);
                    renderTable("adminBranchComparison", [
                        { key: "BranchName", title: "الفرع" },
                        { key: "TransactionCount", title: "عدد الحركات" },
                        { key: "TotalValue", title: "إجمالي القيمة", money: true },
                        { key: "FeesTotal", title: "إجمالي الرسوم", money: true }
                    ], data.BranchComparison);
                    renderTable("adminTopServices", [
                        { key: "ItemName", title: "الخدمة" },
                        { key: "SaleCount", title: "عدد مرات البيع" },
                        { key: "TotalValue", title: "إجمالي القيمة", money: true },
                        { key: "FeesTotal", title: "إجمالي الرسوم", money: true }
                    ], data.TopServices);
                    renderTable("adminOperationSummary", [
                        { key: "OperationType", title: "نوع العملية" },
                        { key: "TransactionCount", title: "عدد الحركات" },
                        { key: "RechargeTotal", title: "إجمالي القيمة", money: true },
                        { key: "FeesTotal", title: "الرسوم", money: true },
                        { key: "VatTotal", title: "الضريبة", money: true },
                        { key: "NetCollection", title: "الصافي", money: true }
                    ], data.OperationTypeSummary);
                    renderTable("adminDailyTrend", [
                        { key: "Day", title: "اليوم" },
                        { key: "TransactionCount", title: "عدد الحركات" },
                        { key: "NetCollection", title: "صافي التحصيل", money: true }
                    ], data.DailyTrend);
                    renderChart("operationDonutChart", "doughnut",
                        (data.OperationTypeSummary || []).map(function (x) { return operationLabel(x.OperationType); }),
                        (data.OperationTypeSummary || []).map(function (x) { return parseFloat(x.NetCollection || 0); }),
                        "الصافي");
                    renderChart("branchBarChart", "bar",
                        (data.BranchComparison || []).map(function (x) { return x.BranchName; }),
                        (data.BranchComparison || []).map(function (x) { return parseFloat(x.TotalValue || 0); }),
                        "إجمالي القيمة");
                    renderChart("topServicesChart", "bar",
                        (data.TopServices || []).map(function (x) { return x.ItemName; }),
                        (data.TopServices || []).map(function (x) { return parseFloat(x.TotalValue || 0); }),
                        "إجمالي القيمة");
                    renderChart("dailyTrendChart", "line",
                        (data.DailyTrend || []).map(function (x) { return x.Day; }),
                        (data.DailyTrend || []).map(function (x) { return parseFloat(x.NetCollection || 0); }),
                        "صافي التحصيل");
                };
                xhr.send();
            }

            for (var i = 0; i < links.length; i++) {
                links[i].addEventListener("click", function (event) {
                    var url = this.getAttribute("data-screen-url");
                    if (!url || !frame) { return; }
                    event.preventDefault();
                    showFrame(url);
                });
            }

            if (dashboardLink) {
                dashboardLink.addEventListener("click", function (event) {
                    event.preventDefault();
                    showDashboard();
                });
            }

            document.addEventListener("click", function (event) {
                if (event.target && event.target.id === "reloadAdminDashboardBtn") {
                    loadAdminDashboard();
                }
            });

            document.addEventListener("change", function (event) {
                if (event.target && /dashboard(FromDate|ToDate|BranchId|OperationType)/.test(event.target.id)) {
                    loadAdminDashboard();
                }
            });

            if (window.matchMedia && window.matchMedia("(max-width: 1000px)").matches) {
                showFrame(shell.getAttribute("data-sales-url"));
                return;
            }

            if (dashboardPanel && !dashboardPanel.classList.contains("is-hidden-ui")) {
                loadAdminDashboard();
            }
        })();
    </script>
</body>
</html>
