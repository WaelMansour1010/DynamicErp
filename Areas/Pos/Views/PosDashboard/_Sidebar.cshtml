@{
    var posContext = ViewBag.PosContext as MyERP.Areas.Pos.Models.PosUserContext;
    var activeScreen = (ViewBag.ActiveScreen as string) ?? "sales";
    var canViewReports = posContext != null && posContext.CanViewReports;
    var isAdmin = posContext != null && (posContext.UserType.GetValueOrDefault(-1) == 0 || posContext.IsFullAccess);
    var legacyPermissionService = new MyERP.Areas.Pos.Services.PosLegacyScreenPermissionService();
    var webPermissionService = new MyERP.Areas.MainErp.Infrastructure.WebScreenPermissionService();
    var canOpenEmployeePayroll = isAdmin || (posContext != null && (legacyPermissionService.CanView(posContext, "FrmEmployee") || legacyPermissionService.CanView(posContext, "FrmEmpSalary5")));
    var canOpenCashing = isAdmin || (posContext != null && legacyPermissionService.CanView(posContext, "FrmCashing"));
    var canOpenFinanceOperations = isAdmin || (posContext != null && (posContext.CanViewAccountingReports || posContext.CanOpenPayments || posContext.CanViewJournalEntry || posContext.CanCreateJournalEntry || posContext.CanEditJournalEntry || posContext.CanDeleteJournalEntry || legacyPermissionService.CanView(posContext, "FrmCashing")));
    var canManagePrintTemplates = isAdmin || (posContext != null && posContext.CanManagePrintTemplates);
    var canOpenWebPermissions = isAdmin || (posContext != null && webPermissionService.CanView(posContext, "POS.Admin.WebPermissions"));
    var hasReportMenuAccess = isAdmin || (posContext != null && (
        posContext.CanViewReports
        || posContext.CanViewAccountingReports
        || posContext.CanReportSalesmen
        || posContext.CanReportSalesComplete
        || posContext.CanReportAllSales
        || posContext.CanReportDailyTransactions
        || posContext.CanReportDailyTransactions2
        || posContext.CanReportDailyTransactionsSectors));
    var logoPath = "~/Areas/Pos/assets/images/company-logo.png";
    var logoAltPath = "~/Areas/Pos/assets/images/company-logo-1.png";
    var companyLogoPath = System.IO.File.Exists(Server.MapPath(logoPath))
        ? logoPath
        : (System.IO.File.Exists(Server.MapPath(logoAltPath)) ? logoAltPath : null);
    Func<string, bool> isActive = key => string.Equals(activeScreen, key, StringComparison.OrdinalIgnoreCase);
    Func<string[], bool> sectionActive = keys => keys.Any(k => string.Equals(activeScreen, k, StringComparison.OrdinalIgnoreCase));
    Func<string, string> sharedMainErpUrl = path => Url.Content("~/MainErp/" + (path ?? string.Empty).TrimStart('/') + "?fromPos=1&host=pos");
    var excelOpen = sectionActive(new[] { "excel-import", "invoice-reconciliation", "token-invoice-lookup", "master-data-import", "excel-error-reports" });
    var salesOpen = sectionActive(new[] { "sales", "kyc", "kyc-bank-follow-up", "closing", "sales-performance", "sales-targets", "sales-collections" });
    var reportsOpen = sectionActive(new[] { "reports", "accounting-reports", "financial-intelligence", "dynamic-reports", "dynamic-reports-admin" });
    var purchasesOpen = sectionActive(new[] { "purchase-invoice" });
    var inventoryOpen = sectionActive(new[] { "enterprise-items", "stores", "stock-taking", "stock-transfer", "inventory-profitability" });
    var accountsOpen = sectionActive(new[] { "account-charts", "payments", "cashing", "payment-vouchers", "journal-entries", "discount-notifications", "branch-performance", "cash-flow", "expenses", "custody", "abnormal-journals", "root-cause" });
    var hrOpen = sectionActive(new[] { "employee-payroll", "salary-run", "medical-insurance", "medical-insurance-reports", "employee-receivables", "hr-advances", "hr-payroll-items", "hr-absences", "hr-vacations", "hr-allowances", "hr-end-service" });
    var settingsOpen = sectionActive(new[] { "legacy-branches-data", "print-templates", "branches", "options", "branch-account-linking" });
    var systemOpen = sectionActive(new[] { "dashboard", "permissions", "main-erp-permissions", "legacy-users", "system-health", "system-error-log", "sql-updates" });
    var userStorageKey = posContext != null ? posContext.UserId.ToString(System.Globalization.CultureInfo.InvariantCulture) : "guest";
    if (!(excelOpen || salesOpen || reportsOpen || purchasesOpen || inventoryOpen || accountsOpen || hrOpen || settingsOpen || systemOpen))
    {
        salesOpen = true;
    }
}

@helper PosIcon(string name, string extraClass = "")
