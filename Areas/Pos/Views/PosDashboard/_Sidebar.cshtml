@{
    var posContext = ViewBag.PosContext as MyERP.Areas.Pos.Models.PosUserContext;
    var activeScreen = (ViewBag.ActiveScreen as string) ?? "sales";
    var canViewReports = posContext != null && posContext.CanViewReports;
    var isAdmin = posContext != null && (posContext.UserType.GetValueOrDefault(-1) == 0 || posContext.IsFullAccess);
    var hasReportMenuAccess = isAdmin || (posContext != null && (
        posContext.CanViewReports
        || posContext.CanViewAccountingReports
        || posContext.CanReportSalesmen
        || posContext.CanReportSalesComplete
        || posContext.CanReportAllSales
        || posContext.CanReportDailyTransactions
        || posContext.CanReportDailyTransactions2
        || posContext.CanReportDailyTransactionsSectors));
    var logoPath = "~/Areas/Pos/assets/images/company-logo.png";
    var logoAltPath = "~/Areas/Pos/assets/images/company-logo-1.png";
    var companyLogoPath = System.IO.File.Exists(Server.MapPath(logoPath))
        ? logoPath
        : (System.IO.File.Exists(Server.MapPath(logoAltPath)) ? logoAltPath : null);
    Func<string, bool> isActive = key => string.Equals(activeScreen, key, StringComparison.OrdinalIgnoreCase);
    Func<string[], bool> sectionActive = keys => keys.Any(k => string.Equals(activeScreen, k, StringComparison.OrdinalIgnoreCase));
    var dailyOpen = sectionActive(new[] { "sales", "kyc", "closing", "payments", "stock-transfer", "purchase-invoice", "excel-import" });
    var financeOpen = sectionActive(new[] { "cashing", "payment-vouchers", "journal-entries", "discount-notifications", "accounting-reports" });
    var reportsOpen = sectionActive(new[] { "reports", "financial-intelligence", "sales-performance" });
    var peopleOpen = sectionActive(new[] { "employee-payroll", "salary-run", "medical-insurance", "medical-insurance-reports", "sales-targets" });
    var adminOpen = sectionActive(new[] { "dashboard", "kyc-bank-follow-up", "permissions", "system-health", "system-error-log", "sql-updates", "print-templates" });
    var userStorageKey = posContext != null ? posContext.UserId.ToString(System.Globalization.CultureInfo.InvariantCulture) : "guest";
    if (!(dailyOpen || financeOpen || reportsOpen || peopleOpen || adminOpen))
    {
        dailyOpen = true;
    }
}

