                    </a>
                    <a class="pos-nav-link @(isActive("discount-notifications") ? "active" : "")"
                       href="@Url.Content("~/Pos/DiscountNotifications/Index")"
                       data-screen-url="@Url.Content("~/Pos/DiscountNotifications/Index")"
                       data-nav-id="discount-notifications"
                       data-nav-section="المالية"
                       data-nav-text="إشعارات خصم discount notifications debit credit"
                       title="الإشعارات">
                        <i class="fas fa-file-invoice-dollar" aria-hidden="true"></i><span>إشعارات الخصم</span>
                    </a>
                }
                @if (isAdmin || (posContext != null && posContext.CanViewAccountingReports))
                {
                    <a class="pos-nav-link @(isActive("accounting-reports") ? "active" : "")"
                       href="@Url.Action("AccountingReports", "PosDashboard", new { area = "Pos" })"
                       data-screen-url="@Url.Content("~/Pos/AccountingReports/Index")"
                       data-nav-id="accounting-reports"
                       data-nav-section="المالية"
                       data-nav-text="تقارير مالية حسابات accounting reports financial"
                       title="تقارير الحسابات">
                        <i class="fas fa-chart-pie" aria-hidden="true"></i><span>التقارير المالية</span>
                    </a>
                }
            </div>
        </section>

        <section class="pos-nav-section @(reportsOpen ? "is-open" : "")" data-section-id="reports">
            <button type="button" class="pos-nav-section-toggle" data-menu-toggle title="التقارير والتحليلات" aria-expanded="@(reportsOpen ? "true" : "false")">
                <span><i class="fas fa-chart-line" aria-hidden="true"></i><b>التقارير والتحليلات</b><small>تشغيل، فروع، مؤشرات</small></span>
                <i class="fas fa-chevron-down nav-chevron" aria-hidden="true"></i>
            </button>
            <div class="pos-nav-submenu">
                @if (hasReportMenuAccess)
                {
                    <a class="pos-nav-link @(isActive("reports") ? "active" : "")"
                       href="@Url.Action("Reports", "PosDashboard", new { area = "Pos" })"
                       data-screen-url="@Url.Content("~/Pos/PosReports/Index")"
                       data-nav-id="reports"
                       data-nav-section="التقارير والتحليلات"
                       data-nav-text="تقارير تشغيلية تقرير الحركات اليومية reports operational daily transactions"
                       title="التقارير التشغيلية">
                        <i class="fas fa-chart-bar" aria-hidden="true"></i><span>التقارير التشغيلية</span>
                    </a>
                    <a class="pos-nav-link"
                       href="@Url.Content("~/Pos/HtmlReports/Index")"
                       data-screen-url="@Url.Content("~/Pos/HtmlReports/Index")"
                       data-nav-id="html-reports"
                       data-nav-section="التقارير والتحليلات"
                       data-nav-text="تقارير ذكية html reports report viewer"
                       title="التقارير الذكية">
                        <i class="fas fa-table" aria-hidden="true"></i><span>التقارير الذكية</span>
                    </a>
                    <a class="pos-nav-link"
                       href="@Url.Content("~/Pos/DynamicReports/Index")"
                       data-screen-url="@Url.Content("~/Pos/DynamicReports/Index")"
                       data-nav-id="dynamic-reports"
                       data-nav-section="التقارير والتحليلات"
                       data-nav-text="مصمم التقارير الديناميكي dynamic report designer"
                       title="مصمم التقارير الديناميكي">
                        <i class="fas fa-sliders-h" aria-hidden="true"></i><span>مصمم التقارير الديناميكي</span>
                    </a>
                }
                @if (isAdmin || (posContext != null && (posContext.CanReportSalesmen || posContext.CanReportSalesComplete || posContext.CanReportAllSales || posContext.CanViewReports)))
                {
                    <a class="pos-nav-link @(isActive("sales-performance") ? "active" : "")"
                       href="@Url.Content("~/Pos/SalesRepresentativesPerformance/Index")"
                       data-screen-url="@Url.Content("~/Pos/SalesRepresentativesPerformance/Index")"
                       data-nav-id="sales-performance"
                       data-nav-section="التقارير والتحليلات"
                       data-nav-text="أداء المناديب المبيعات sales representatives performance targets"
                       title="لوحة أداء المناديب والمبيعات">
                        <i class="fas fa-user-tie" aria-hidden="true"></i><span>أداء المناديب والمبيعات</span>
