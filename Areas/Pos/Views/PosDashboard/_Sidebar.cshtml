        @if (isAdmin)
        {
            <section class="pos-nav-section @(peopleOpen ? "is-open" : "")" data-section-id="people">
                <button type="button" class="pos-nav-section-toggle" data-menu-toggle title="الموظفون والمبيعات" aria-expanded="@(peopleOpen ? "true" : "false")">
                    <span><i class="fas fa-users" aria-hidden="true"></i><b>الموظفون والمبيعات</b><small>رواتب، تأمين، تارجت</small></span>
                    <i class="fas fa-chevron-down nav-chevron" aria-hidden="true"></i>
