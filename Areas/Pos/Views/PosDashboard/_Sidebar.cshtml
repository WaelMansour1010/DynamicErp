@{
    var posContext = ViewBag.PosContext as MyERP.Areas.Pos.Models.PosUserContext;
    var activeScreen = (ViewBag.ActiveScreen as string) ?? "sales";
    var isAdmin = posContext != null && (posContext.UserType.GetValueOrDefault(-1) == 0 || posContext.IsFullAccess);

    Func<string, bool> isActive = key => string.Equals(activeScreen, key, StringComparison.OrdinalIgnoreCase);
    Func<string[], bool> sectionActive = keys => keys.Any(k => string.Equals(activeScreen, k, StringComparison.OrdinalIgnoreCase));

    var hasReportMenuAccess = isAdmin || (posContext != null && (
        posContext.CanViewReports
        || posContext.CanViewAccountingReports
        || posContext.CanReportSalesmen
        || posContext.CanReportSalesComplete
        || posContext.CanReportAllSales
        || posContext.CanReportDailyTransactions
        || posContext.CanReportDailyTransactions2
        || posContext.CanReportDailyTransactionsSectors));

    var canTreasury = isAdmin || (posContext != null && (posContext.CanOpenPayments || posContext.CanViewAccountingReports));
    var canAccounting = isAdmin || (posContext != null && (
        posContext.CanViewAccountingReports
        || posContext.CanViewJournalEntry
        || posContext.CanCreateJournalEntry
        || posContext.CanEditJournalEntry
        || posContext.CanDeleteJournalEntry));
    var canReportsAndAnalytics = hasReportMenuAccess || (isAdmin || (posContext != null && posContext.CanViewAccountingReports));
    var canSalesManagement = isAdmin || (posContext != null && (posContext.CanReportSalesmen || posContext.CanReportSalesComplete || posContext.CanReportAllSales || posContext.CanViewReports));
    var canHr = isAdmin;
    var canKycFollowUp = isAdmin || (posContext != null && posContext.IsFullAccessCustomerService);
    var canTools = isAdmin || (posContext != null && posContext.CanManagePrintTemplates);

    var operationsOpen = sectionActive(new[] { "sales", "closing", "stock-transfer", "purchase-invoice", "excel-import" });
    var treasuryOpen = sectionActive(new[] { "payments", "payment-vouchers", "cashing" });
    var accountingOpen = sectionActive(new[] { "journal-entries", "discount-notifications", "accounting-reports" });
    var analyticsOpen = sectionActive(new[] { "reports", "financial-intelligence" });
    var salesManagementOpen = sectionActive(new[] { "sales-performance", "sales-targets" });
    var hrOpen = sectionActive(new[] { "employee-payroll", "salary-run", "medical-insurance", "medical-insurance-reports" });
    var kycOpen = sectionActive(new[] { "kyc", "kyc-bank-follow-up" });
    var systemOpen = sectionActive(new[] { "system-health", "system-error-log", "permissions" });
    var toolsOpen = sectionActive(new[] { "print-templates" });

    if (!(operationsOpen || treasuryOpen || accountingOpen || analyticsOpen || salesManagementOpen || hrOpen || kycOpen || systemOpen || toolsOpen || isActive("dashboard")))
    {
        operationsOpen = true;
    }

    var logoPath = "~/Areas/Pos/assets/images/company-logo.png";
    var logoAltPath = "~/Areas/Pos/assets/images/company-logo-1.png";
    var companyLogoPath = System.IO.File.Exists(Server.MapPath(logoPath))
        ? logoPath
        : (System.IO.File.Exists(Server.MapPath(logoAltPath)) ? logoAltPath : null);
}

<aside class="pos-main-sidebar" id="posMainSidebar">
    <div class="pos-sidebar-brand">
        <div class="pos-main-logo">
            @if (!string.IsNullOrWhiteSpace(companyLogoPath))
            {
                <img src="@Url.Content(companyLogoPath)" alt="Keshni" />
            }
            else
            {
                <strong>كيشني</strong>
            }
        </div>
        <button type="button" class="pos-sidebar-collapse" id="posSidebarCollapseBtn" aria-label="تصغير القائمة" title="تصغير القائمة">
            <i class="fas fa-bars" aria-hidden="true"></i>
        </button>
    </div>

    <div class="pos-sidebar-user" title="المستخدم الحالي">
        <span class="user-avatar"><i class="fas fa-user" aria-hidden="true"></i></span>
        <div>
            <strong>@(posContext != null ? posContext.UserName : "")</strong>
            <small>@(posContext != null ? posContext.BranchName : "")</small>
        </div>
    </div>

    <nav class="pos-main-nav pos-modern-nav" aria-label="قائمة نقطة البيع">
        <a class="pos-nav-link pos-nav-home @(isActive("dashboard") ? "active" : "")"
           href="@Url.Action("Index", "PosDashboard", new { area = "Pos" })"
           data-dashboard-screen="true"
           title="لوحة التحكم">
            <i class="fas fa-tachometer-alt" aria-hidden="true"></i><span>لوحة التحكم</span>
        </a>

        <section class="pos-nav-section teller-sales-section @(operationsOpen ? "is-open" : "")">
            <button type="button" class="pos-nav-section-toggle" data-menu-toggle title="العمليات اليومية">
                <span><i class="fas fa-cash-register" aria-hidden="true"></i><b>العمليات اليومية</b></span>
                <i class="fas fa-chevron-down nav-chevron" aria-hidden="true"></i>
            </button>
            <div class="pos-nav-submenu">
                <a class="pos-nav-link teller-sales-link @(isActive("sales") ? "active" : "")"
                   href="@Url.Action("Sales", "PosDashboard", new { area = "Pos" })"
                   data-screen-url="@Url.Content("~/Pos/PosTransaction/Index")"
                   title="شاشة البيع">
                    <i class="fas fa-shopping-cart" aria-hidden="true"></i><span>شاشة البيع</span>
                </a>
                <a class="pos-nav-link @(isActive("closing") ? "active" : "")"
                   href="@Url.Action("Closing", "PosDashboard", new { area = "Pos" })"
                   data-screen-url="@Url.Content("~/Pos/PosClosing/Index")"
                   title="إغلاق الوردية">
                    <i class="fas fa-lock" aria-hidden="true"></i><span>إغلاق الوردية</span>
                </a>
                @if (isAdmin || (posContext != null && posContext.CanSave))
                {
                    <a class="pos-nav-link @(isActive("stock-transfer") ? "active" : "")"
                       href="@Url.Action("StockTransfer", "PosDashboard", new { area = "Pos" })"
                       data-screen-url="@Url.Content("~/Pos/StockTransfer/Index")"
                       title="تحويل مخزون">
                        <i class="fas fa-exchange-alt" aria-hidden="true"></i><span>تحويل مخزون</span>
                    </a>
                    <a class="pos-nav-link @(isActive("purchase-invoice") ? "active" : "")"
                       href="@Url.Action("PurchaseInvoice", "PosDashboard", new { area = "Pos" })"
                       data-screen-url="@Url.Content("~/Pos/PurchaseInvoice/Index")"
                       title="فواتير مشتريات">
                        <i class="fas fa-file-alt" aria-hidden="true"></i><span>فواتير مشتريات</span>
                    </a>
                    if (isAdmin || (posContext != null && posContext.CanImportExcel))
                    {
                        <a class="pos-nav-link @(isActive("excel-import") ? "active" : "")"
                           href="@Url.Action("ExcelImport", "PosDashboard", new { area = "Pos" })"
                           data-screen-url="@Url.Content("~/Pos/ExcelImport/Index")"
                           title="استيراد العمليات من Excel">
                            <i class="fas fa-file-import" aria-hidden="true"></i><span>استيراد العمليات</span>
                        </a>
                    }
                }
            </div>
        </section>

        @if (canTreasury)
        {
            <section class="pos-nav-section @(treasuryOpen ? "is-open" : "")">
                <button type="button" class="pos-nav-section-toggle" data-menu-toggle title="الخزينة والعهد">
                    <span><i class="fas fa-wallet" aria-hidden="true"></i><b>الخزينة والعهد</b></span>
                    <i class="fas fa-chevron-down nav-chevron" aria-hidden="true"></i>
                </button>
                <div class="pos-nav-submenu">
                    @if (isAdmin || (posContext != null && posContext.CanOpenPayments))
                    {
                        <a class="pos-nav-link @(isActive("payments") ? "active" : "")"
                           href="@Url.Action("Payments", "PosDashboard", new { area = "Pos" })"
                           data-screen-url="@Url.Content("~/Pos/Payments/Index")"
                           title="تمويل العهدة">
                            <i class="fas fa-money-bill-alt" aria-hidden="true"></i><span>تمويل العهدة</span>
                        </a>
                    }
                    @if (isAdmin || (posContext != null && posContext.CanViewAccountingReports))
                    {
                        <a class="pos-nav-link @(isActive("payment-vouchers") ? "active" : "")"
                           href="@Url.Content("~/Pos/Payments/Vouchers")"
                           data-screen-url="@Url.Content("~/Pos/Payments/Vouchers")"
                           title="سندات الصرف">
                            <i class="fas fa-money-bill-wave" aria-hidden="true"></i><span>سندات الصرف</span>
                        </a>
                        <a class="pos-nav-link @(isActive("cashing") ? "active" : "")"
                           href="@Url.Action("Cashing", "PosDashboard", new { area = "Pos" })"
                           data-screen-url="@Url.Content("~/Pos/Cashing/Index")"
                           title="سندات القبض">
                            <i class="fas fa-hand-holding-usd" aria-hidden="true"></i><span>سندات القبض</span>
                        </a>
                    }
                </div>
            </section>
        }

        @if (canAccounting)
        {
            <section class="pos-nav-section @(accountingOpen ? "is-open" : "")">
                <button type="button" class="pos-nav-section-toggle" data-menu-toggle title="الحسابات">
                    <span><i class="fas fa-book" aria-hidden="true"></i><b>الحسابات</b></span>
                    <i class="fas fa-chevron-down nav-chevron" aria-hidden="true"></i>
                </button>
                <div class="pos-nav-submenu">
                    @if (isAdmin || (posContext != null && (posContext.CanViewJournalEntry || posContext.CanCreateJournalEntry || posContext.CanEditJournalEntry || posContext.CanDeleteJournalEntry)))
                    {
                        <a class="pos-nav-link @(isActive("journal-entries") ? "active" : "")"
                           href="@Url.Action("JournalEntries", "PosDashboard", new { area = "Pos" })"
                           data-screen-url="@Url.Content("~/Pos/JournalEntries/Index")"
                           title="إدخال واستعراض القيود">
                            <i class="fas fa-book" aria-hidden="true"></i><span>إدخال واستعراض القيود</span>
                        </a>
                        <a class="pos-nav-link @(isActive("discount-notifications") ? "active" : "")"
                           href="@Url.Content("~/Pos/DiscountNotifications/Index")"
                           data-screen-url="@Url.Content("~/Pos/DiscountNotifications/Index")"
                           title="الإشعارات">
                            <i class="fas fa-file-invoice-dollar" aria-hidden="true"></i><span>الإشعارات</span>
                        </a>
                    }
                    @if (isAdmin || (posContext != null && posContext.CanViewAccountingReports))
                    {
                        <a class="pos-nav-link @(isActive("accounting-reports") ? "active" : "")"
                           href="@Url.Action("AccountingReports", "PosDashboard", new { area = "Pos" })"
                           data-screen-url="@Url.Content("~/Pos/AccountingReports/Index")"
                           title="تقارير الحسابات">
                            <i class="fas fa-chart-pie" aria-hidden="true"></i><span>تقارير الحسابات</span>
                        </a>
                    }
                </div>
            </section>
        }

        @if (canReportsAndAnalytics)
        {
            <section class="pos-nav-section @(analyticsOpen ? "is-open" : "")">
                <button type="button" class="pos-nav-section-toggle" data-menu-toggle title="التقارير والتحليلات">
                    <span><i class="fas fa-chart-line" aria-hidden="true"></i><b>التقارير والتحليلات</b></span>
                    <i class="fas fa-chevron-down nav-chevron" aria-hidden="true"></i>
                </button>
                <div class="pos-nav-submenu">
                    @if (hasReportMenuAccess)
                    {
                        <a class="pos-nav-link @(isActive("reports") ? "active" : "")"
                           href="@Url.Action("Reports", "PosDashboard", new { area = "Pos" })"
                           data-screen-url="@Url.Content("~/Pos/PosReports/Index")"
                           title="التقارير التشغيلية">
                            <i class="fas fa-chart-bar" aria-hidden="true"></i><span>التقارير التشغيلية</span>
                        </a>
                        <a class="pos-nav-link"
                           href="@Url.Content("~/Pos/HtmlReports/Index")"
                           data-screen-url="@Url.Content("~/Pos/HtmlReports/Index")"
                           title="التقارير الذكية">
                            <i class="fas fa-chart-bar" aria-hidden="true"></i><span>التقارير الذكية</span>
                        </a>
                        <a class="pos-nav-link"
                           href="@Url.Content("~/Pos/DynamicReports/Index")"
                           data-screen-url="@Url.Content("~/Pos/DynamicReports/Index")"
                           title="مصمم التقارير الديناميكي">
                            <i class="fas fa-sliders-h" aria-hidden="true"></i><span>مصمم التقارير</span>
                        </a>
                    }
                    @if (isAdmin || (posContext != null && posContext.CanViewAccountingReports))
                    {
                        <a class="pos-nav-link @(isActive("financial-intelligence") ? "active" : "")"
                           href="@Url.Action("FinancialIntelligence", "PosDashboard", new { area = "Pos" })"
                           data-screen-url="@Url.Content("~/Pos/FinancialIntelligence/Index")"
                           title="لوحة المؤشرات المالية">
                            <i class="fas fa-tachometer-alt" aria-hidden="true"></i><span>لوحة المؤشرات المالية</span>
                        </a>
                        <a class="pos-nav-link" href="@Url.Content("~/Pos/FinancialIntelligence/BranchPerformance")" data-screen-url="@Url.Content("~/Pos/FinancialIntelligence/BranchPerformance")" title="أداء الفروع المالي">
                            <i class="fas fa-building" aria-hidden="true"></i><span>أداء الفروع المالي</span>
                        </a>
                        <a class="pos-nav-link" href="@Url.Content("~/Pos/FinancialIntelligence/CashFlow")" data-screen-url="@Url.Content("~/Pos/FinancialIntelligence/CashFlow")" title="التدفقات النقدية">
                            <i class="fas fa-coins" aria-hidden="true"></i><span>التدفقات النقدية</span>
                        </a>
                        <a class="pos-nav-link" href="@Url.Content("~/Pos/FinancialIntelligence/SalesCollections")" data-screen-url="@Url.Content("~/Pos/FinancialIntelligence/SalesCollections")" title="المبيعات والتحصيل">
                            <i class="fas fa-chart-line" aria-hidden="true"></i><span>المبيعات والتحصيل</span>
                        </a>
                        <a class="pos-nav-link" href="@Url.Content("~/Pos/FinancialIntelligence/Expenses")" data-screen-url="@Url.Content("~/Pos/FinancialIntelligence/Expenses")" title="تحليل المصروفات">
                            <i class="fas fa-chart-pie" aria-hidden="true"></i><span>تحليل المصروفات</span>
                        </a>
                        <a class="pos-nav-link" href="@Url.Content("~/Pos/FinancialIntelligence/InventoryProfitability")" data-screen-url="@Url.Content("~/Pos/FinancialIntelligence/InventoryProfitability")" title="المخزون والربحية">
                            <i class="fas fa-boxes" aria-hidden="true"></i><span>المخزون والربحية</span>
                        </a>
                        <a class="pos-nav-link" href="@Url.Content("~/Pos/FinancialIntelligence/AbnormalJournals")" data-screen-url="@Url.Content("~/Pos/FinancialIntelligence/AbnormalJournals")" title="تنبيهات محاسبية">
                            <i class="fas fa-exclamation-triangle" aria-hidden="true"></i><span>تنبيهات محاسبية</span>
                        </a>
                        <a class="pos-nav-link" href="@Url.Content("~/Pos/FinancialIntelligence/RootCause")" data-screen-url="@Url.Content("~/Pos/FinancialIntelligence/RootCause")" title="تحليل سبب المشكلة">
                            <i class="fas fa-search" aria-hidden="true"></i><span>تحليل السبب</span>
                        </a>
                    }
                </div>
            </section>
        }

        @if (canSalesManagement)
        {
            <section class="pos-nav-section @(salesManagementOpen ? "is-open" : "")">
                <button type="button" class="pos-nav-section-toggle" data-menu-toggle title="المبيعات والمندوبون">
                    <span><i class="fas fa-user-tie" aria-hidden="true"></i><b>المبيعات والمندوبون</b></span>
                    <i class="fas fa-chevron-down nav-chevron" aria-hidden="true"></i>
                </button>
                <div class="pos-nav-submenu">
                    <a class="pos-nav-link @(isActive("sales-performance") ? "active" : "")"
                       href="@Url.Content("~/Pos/SalesRepresentativesPerformance/Index")"
                       data-screen-url="@Url.Content("~/Pos/SalesRepresentativesPerformance/Index")"
                       title="أداء المناديب والمبيعات">
                        <i class="fas fa-user-tie" aria-hidden="true"></i><span>أداء المناديب</span>
                    </a>
                    @if (isAdmin)
                    {
                        <a class="pos-nav-link @(isActive("sales-targets") ? "active" : "")"
                           href="@Url.Content("~/Pos/SalesTargets/Index")"
                           data-screen-url="@Url.Content("~/Pos/SalesTargets/Index")"
                           title="إدارة تارجت المناديب">
                            <i class="fas fa-bullseye" aria-hidden="true"></i><span>تارجت المناديب</span>
                        </a>
                    }
                </div>
            </section>
        }

        @if (canHr)
        {
            <section class="pos-nav-section @(hrOpen ? "is-open" : "")">
                <button type="button" class="pos-nav-section-toggle" data-menu-toggle title="شؤون الموظفين">
                    <span><i class="fas fa-users" aria-hidden="true"></i><b>شؤون الموظفين</b></span>
                    <i class="fas fa-chevron-down nav-chevron" aria-hidden="true"></i>
                </button>
                <div class="pos-nav-submenu">
                    <a class="pos-nav-link @(isActive("employee-payroll") ? "active" : "")"
                       href="@Url.Action("EmployeePayroll", "PosDashboard", new { area = "Pos" })"
                       data-screen-url="@Url.Content("~/Pos/EmployeePayroll/Employees")"
                       title="الموظفون">
                        <i class="fas fa-users" aria-hidden="true"></i><span>الموظفون</span>
                    </a>
                    <a class="pos-nav-link @(isActive("salary-run") ? "active" : "")"
                       href="@Url.Action("SalaryRun", "PosDashboard", new { area = "Pos" })"
                       data-screen-url="@Url.Content("~/Pos/EmployeePayroll/SalaryRun")"
                       title="مسير الرواتب">
                        <i class="fas fa-file-invoice-dollar" aria-hidden="true"></i><span>مسير الرواتب</span>
                    </a>
                    <a class="pos-nav-link @(isActive("medical-insurance") ? "active" : "")"
                       href="@Url.Action("MedicalInsurance", "PosDashboard", new { area = "Pos" })"
                       data-screen-url="@Url.Content("~/Pos/EmployeePayroll/MedicalInsurance")"
                       title="التأمين الطبي">
                        <i class="fas fa-briefcase-medical" aria-hidden="true"></i><span>التأمين الطبي</span>
                    </a>
                    <a class="pos-nav-link @(isActive("medical-insurance-reports") ? "active" : "")"
                       href="@Url.Action("MedicalInsuranceReports", "PosDashboard", new { area = "Pos" })"
                       data-screen-url="@Url.Content("~/Pos/EmployeePayroll/MedicalInsuranceReports")"
                       title="تقارير التأمين الطبي">
                        <i class="fas fa-chart-bar" aria-hidden="true"></i><span>تقارير التأمين</span>
                    </a>
                    <a class="pos-nav-link" href="@Url.Content("~/Pos/FinancialIntelligence/EmployeeReceivables")" data-screen-url="@Url.Content("~/Pos/FinancialIntelligence/EmployeeReceivables")" title="ذمم الموظفين">
                        <i class="fas fa-user-check" aria-hidden="true"></i><span>ذمم الموظفين</span>
                    </a>
                </div>
            </section>
        }

        <section class="pos-nav-section @(kycOpen ? "is-open" : "")">
            <button type="button" class="pos-nav-section-toggle" data-menu-toggle title="KYC والبنك">
                <span><i class="fas fa-id-card" aria-hidden="true"></i><b>KYC والبنك</b></span>
                <i class="fas fa-chevron-down nav-chevron" aria-hidden="true"></i>
            </button>
            <div class="pos-nav-submenu">
                <a class="pos-nav-link @(isActive("kyc") ? "active" : "")"
                   href="@Url.Action("Kyc", "PosDashboard", new { area = "Pos" })"
                   data-screen-url="@Url.Content("~/Pos/PosTransaction/Index?openKyc=true")"
                   title="KYC">
                    <i class="fas fa-address-card" aria-hidden="true"></i><span>KYC</span>
                </a>
                @if (canKycFollowUp)
                {
                    <a class="pos-nav-link @(isActive("kyc-bank-follow-up") ? "active" : "")"
                       href="@Url.Action("KycBankFollowUp", "PosDashboard", new { area = "Pos" })"
                       data-screen-url="@Url.Content("~/Pos/KycBankFollowUp/Index")"
                       title="متابعة KYC والبنك">
                        <i class="fas fa-university" aria-hidden="true"></i><span>متابعة KYC والبنك</span>
                    </a>
                }
            </div>
        </section>

        @if (isAdmin)
        {
            <section class="pos-nav-section @(systemOpen ? "is-open" : "")">
                <button type="button" class="pos-nav-section-toggle" data-menu-toggle title="النظام والصلاحيات">
                    <span><i class="fas fa-shield-alt" aria-hidden="true"></i><b>النظام والصلاحيات</b></span>
                    <i class="fas fa-chevron-down nav-chevron" aria-hidden="true"></i>
                </button>
                <div class="pos-nav-submenu">
                    <a class="pos-nav-link @(isActive("system-health") ? "active" : "")" href="@Url.Action("SystemHealth", "PosDashboard", new { area = "Pos" })" data-screen-url="@Url.Content("~/Pos/PosSystemHealth/Index")" title="مراقبة النظام">
                        <i class="fas fa-desktop" aria-hidden="true"></i><span>مراقبة النظام</span>
                    </a>
                    <a class="pos-nav-link @(isActive("system-error-log") ? "active" : "")" href="@Url.Content("~/Pos/PosSystemErrorLog/Index")" data-screen-url="@Url.Content("~/Pos/PosSystemErrorLog/Index")" title="سجل أخطاء النظام">
                        <i class="fas fa-bug" aria-hidden="true"></i><span>سجل الأخطاء</span>
                    </a>
                    <a class="pos-nav-link @(isActive("permissions") ? "active" : "")" href="@Url.Action("Index", "PosPermissions", new { area = "Pos" })" data-screen-url="@Url.Content("~/Pos/PosPermissions/Index")" title="صلاحيات POS">
                        <i class="fas fa-shield-alt" aria-hidden="true"></i><span>صلاحيات POS</span>
                    </a>
                </div>
            </section>
        }

        @if (canTools)
        {
            <section class="pos-nav-section @(toolsOpen ? "is-open" : "")">
                <button type="button" class="pos-nav-section-toggle" data-menu-toggle title="الأدوات والإعدادات">
                    <span><i class="fas fa-tools" aria-hidden="true"></i><b>الأدوات والإعدادات</b></span>
                    <i class="fas fa-chevron-down nav-chevron" aria-hidden="true"></i>
                </button>
                <div class="pos-nav-submenu">
                    @if (isAdmin)
                    {
                        <a class="pos-nav-link" href="@Url.Content("~/Pos/DynamicReportsAdmin/Index")" data-screen-url="@Url.Content("~/Pos/DynamicReportsAdmin/Index")" title="إدارة التقارير الديناميكية">
                            <i class="fas fa-cogs" aria-hidden="true"></i><span>إدارة التقارير</span>
                        </a>
                    }
                    <a class="pos-nav-link @(isActive("print-templates") ? "active" : "")"
                       href="@Url.Action("PrintTemplates", "PosDashboard", new { area = "Pos" })"
                       data-screen-url="@Url.Content("~/Pos/PrintTemplate/Index?name=KycCard")"
                       title="مصمم نماذج الطباعة">
                        <i class="fas fa-print" aria-hidden="true"></i><span>نماذج الطباعة</span>
                    </a>
                </div>
            </section>
        }
    </nav>
</aside>
