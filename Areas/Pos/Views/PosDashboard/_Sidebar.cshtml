                        <i class="fas fa-tachometer-alt" aria-hidden="true"></i><span>لوحة المؤشرات المالية</span>
                    </a>
                    <a class="pos-nav-link" href="@Url.Content("~/Pos/FinancialIntelligence/BranchPerformance")" data-screen-url="@Url.Content("~/Pos/FinancialIntelligence/BranchPerformance")" data-nav-id="branch-performance" data-nav-section="التقارير والتحليلات" data-nav-text="أداء الفروع المالي branch performance" title="أداء الفروع المالي"><i class="fas fa-building" aria-hidden="true"></i><span>أداء الفروع المالي</span></a>
                    <a class="pos-nav-link" href="@Url.Content("~/Pos/FinancialIntelligence/CashFlow")" data-screen-url="@Url.Content("~/Pos/FinancialIntelligence/CashFlow")" data-nav-id="cash-flow" data-nav-section="التقارير والتحليلات" data-nav-text="التدفقات النقدية cash flow" title="تحليل التدفقات النقدية"><i class="fas fa-coins" aria-hidden="true"></i><span>تحليل التدفقات النقدية</span></a>
