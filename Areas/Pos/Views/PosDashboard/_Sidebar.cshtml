                        <i class="fas fa-file-invoice-dollar" aria-hidden="true"></i><span>مسير الرواتب</span>
                    </a>
                    <a class="pos-nav-link @(isActive("medical-insurance") ? "active" : "")"
                       href="@Url.Action("MedicalInsurance", "PosDashboard", new { area = "Pos" })"
                       data-screen-url="@Url.Content("~/Pos/EmployeePayroll/MedicalInsurance")"
                       data-nav-id="medical-insurance"
                       data-nav-section="الموظفون والمبيعات"
                       data-nav-text="التأمين الطبي medical insurance"
                       title="التأمين الطبي">
                        <i class="fas fa-briefcase-medical" aria-hidden="true"></i><span>التأمين الطبي</span>
