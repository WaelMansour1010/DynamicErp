@{
    var posContext = ViewBag.PosContext as MyERP.Areas.Pos.Models.PosUserContext;
    var activeScreen = (ViewBag.ActiveScreen as string) ?? "sales";
    var canViewReports = posContext != null && posContext.CanViewReports;
    var isAdmin = posContext != null && (posContext.UserType.GetValueOrDefault(-1) == 0 || posContext.IsFullAccess);
    var hasReportMenuAccess = isAdmin || (posContext != null && (
        posContext.CanViewReports
        || posContext.CanViewAccountingReports
        || posContext.CanReportSalesmen
        || posContext.CanReportSalesComplete
        || posContext.CanReportAllSales
        || posContext.CanReportDailyTransactions
        || posContext.CanReportDailyTransactions2
        || posContext.CanReportDailyTransactionsSectors));
    var logoPath = "~/Areas/Pos/assets/images/company-logo.png";
    var logoAltPath = "~/Areas/Pos/assets/images/company-logo-1.png";
    var companyLogoPath = System.IO.File.Exists(Server.MapPath(logoPath))
        ? logoPath
        : (System.IO.File.Exists(Server.MapPath(logoAltPath)) ? logoAltPath : null);
    Func<string, bool> isActive = key => string.Equals(activeScreen, key, StringComparison.OrdinalIgnoreCase);
    Func<string[], bool> sectionActive = keys => keys.Any(k => string.Equals(activeScreen, k, StringComparison.OrdinalIgnoreCase));
    var dailyOpen = sectionActive(new[] { "sales", "kyc", "closing", "payments", "stock-transfer", "purchase-invoice", "excel-import" });
    var financeOpen = sectionActive(new[] { "cashing", "payment-vouchers", "journal-entries", "discount-notifications", "accounting-reports" });
    var reportsOpen = sectionActive(new[] { "reports", "financial-intelligence", "sales-performance" });
    var peopleOpen = sectionActive(new[] { "employee-payroll", "salary-run", "medical-insurance", "medical-insurance-reports", "sales-targets" });
    var adminOpen = sectionActive(new[] { "dashboard", "kyc-bank-follow-up", "permissions", "system-health", "system-error-log", "sql-updates", "print-templates" });
    var userStorageKey = posContext != null ? posContext.UserId.ToString(System.Globalization.CultureInfo.InvariantCulture) : "guest";
    if (!(dailyOpen || financeOpen || reportsOpen || peopleOpen || adminOpen))
    {
        dailyOpen = true;
    }
}

<aside class="pos-main-sidebar" id="posMainSidebar" data-pos-user-key="@userStorageKey">
    <div class="pos-sidebar-brand">
        <div class="pos-main-logo">
            @if (!string.IsNullOrWhiteSpace(companyLogoPath))
            {
                <img src="@Url.Content(companyLogoPath)" alt="Keshni" />
            }
            else
            {
                <strong>كيشني</strong>
            }
        </div>
        <button type="button" class="pos-sidebar-collapse" id="posSidebarCollapseBtn" aria-label="تصغير القائمة" title="تصغير القائمة">
            <i class="fas fa-bars" aria-hidden="true"></i>
        </button>
    </div>

    <div class="pos-sidebar-user" title="المستخدم الحالي">
        <span class="user-avatar"><i class="fas fa-user" aria-hidden="true"></i></span>
        <div>
            <strong>@(posContext != null ? posContext.UserName : "")</strong>
            <small>@(posContext != null ? posContext.BranchName : "")</small>
        </div>
    </div>

    <div class="pos-sidebar-search" role="search">
        <i class="fas fa-search" aria-hidden="true"></i>
        <input id="posMenuSearch" type="search" autocomplete="off" placeholder="بحث سريع: قبض، KYC، تقارير..." aria-label="بحث في قائمة POS" />
        <button type="button" id="posMenuSearchClear" aria-label="مسح البحث" title="مسح البحث"><i class="fas fa-times" aria-hidden="true"></i></button>
    </div>

    <section class="pos-nav-quick-access" id="posQuickAccess" aria-label="الوصول السريع">
        <div class="pos-nav-quick-heading">
            <span><i class="fas fa-thumbtack" aria-hidden="true"></i> الوصول السريع</span>
            <small id="posQuickAccessCount">0</small>
        </div>
        <div class="pos-nav-favorites" id="posFavoritesList"></div>
        <div class="pos-nav-empty" id="posFavoritesEmpty">ثبت الشاشات الأكثر استخداماً من علامة الدبوس.</div>
    </section>

    <nav class="pos-main-nav pos-modern-nav" aria-label="قائمة نقطة البيع">
        <a class="pos-nav-link pos-nav-home @(isActive("dashboard") ? "active" : "")"
           href="@Url.Action("Index", "PosDashboard", new { area = "Pos" })"
           data-dashboard-screen="true"
           data-nav-id="dashboard"
           data-nav-section="الإدارة والإعدادات"
           data-nav-text="لوحة التحكم dashboard admin management"
           title="لوحة التحكم">
            <i class="fas fa-tachometer-alt" aria-hidden="true"></i><span>لوحة التحكم</span>
        </a>

        <section class="pos-nav-section teller-sales-section @(dailyOpen ? "is-open" : "")" data-section-id="daily">
            <button type="button" class="pos-nav-section-toggle" data-menu-toggle title="العمليات اليومية" aria-expanded="@(dailyOpen ? "true" : "false")">
