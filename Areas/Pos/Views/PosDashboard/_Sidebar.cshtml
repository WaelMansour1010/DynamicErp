        case "user": body = "<path d=\"M19 21a7 7 0 0 0-14 0\"/><circle cx=\"12\" cy=\"7\" r=\"4\"/>"; break;
        case "search": body = "<circle cx=\"11\" cy=\"11\" r=\"8\"/><path d=\"m21 21-4.3-4.3\"/>"; break;
        case "x": body = "<path d=\"M18 6 6 18\"/><path d=\"m6 6 12 12\"/>"; break;
        case "pin": body = "<path d=\"M12 17v5\"/><path d=\"M5 17h14\"/><path d=\"m7 7 10 10\"/><path d=\"M9 7V3h6v4l2 2v2H7V9z\"/>"; break;
        case "chevron-down": body = "<path d=\"m6 9 6 6 6-6\"/>"; break;
        case "gauge": body = "<path d=\"M12 14l4-4\"/><path d=\"M3.34 19a10 10 0 1 1 17.32 0\"/>"; break;
        case "store": body = "<path d=\"M3 9h18l-2-5H5L3 9z\"/><path d=\"M5 9v11h14V9\"/><path d=\"M9 20v-6h6v6\"/>"; break;
        case "terminal": body = "<path d=\"M4 6h16v12H4z\"/><path d=\"M8 10l3 2-3 2\"/><path d=\"M13 14h3\"/>"; break;
        case "id-card": body = "<rect x=\"3\" y=\"5\" width=\"18\" height=\"14\" rx=\"2\"/><circle cx=\"9\" cy=\"11\" r=\"2\"/><path d=\"M7 15h4\"/><path d=\"M14 10h4\"/><path d=\"M14 14h4\"/>"; break;
        case "lock-check": body = "<rect x=\"5\" y=\"11\" width=\"14\" height=\"10\" rx=\"2\"/><path d=\"M8 11V7a4 4 0 0 1 8 0v4\"/><path d=\"m9 16 2 2 4-4\"/>"; break;
        case "wallet": body = "<path d=\"M19 7V6a2 2 0 0 0-2-2H5a2 2 0 0 0 0 4h14a2 2 0 0 1 2 2v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6\"/><path d=\"M16 13h.01\"/>"; break;
        case "arrows-left-right": body = "<path d=\"m7 7-4 4 4 4\"/><path d=\"M3 11h18\"/><path d=\"m17 7 4 4-4 4\"/>"; break;
        case "receipt": body = "<path d=\"M4 2v20l2-1 2 1 2-1 2 1 2-1 2 1 2-1 2 1V2l-2 1-2-1-2 1-2-1-2 1-2-1-2 1z\"/><path d=\"M8 7h8\"/><path d=\"M8 11h8\"/><path d=\"M8 15h5\"/>"; break;
        case "spreadsheet": body = "<path d=\"M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z\"/><path d=\"M14 2v6h6\"/><path d=\"M8 13h8\"/><path d=\"M8 17h8\"/><path d=\"M12 9v10\"/>"; break;
        case "landmark": body = "<path d=\"M3 21h18\"/><path d=\"M5 21V10\"/><path d=\"M19 21V10\"/><path d=\"M9 21V10\"/><path d=\"M15 21V10\"/><path d=\"M12 3 3 8h18z\"/>"; break;
        case "receipt-plus": body = "<path d=\"M4 2v20l2-1 2 1 2-1 2 1 2-1 2 1 2-1 2 1V2l-2 1-2-1-2 1-2-1-2 1-2-1-2 1z\"/><path d=\"M8 8h8\"/><path d=\"M12 12v6\"/><path d=\"M9 15h6\"/>"; break;
        case "banknote-arrow": body = "<rect x=\"3\" y=\"6\" width=\"18\" height=\"12\" rx=\"2\"/><circle cx=\"12\" cy=\"12\" r=\"2\"/><path d=\"M7 12h.01\"/><path d=\"M17 12h.01\"/><path d=\"m15 3 3 3 3-3\"/>"; break;
        case "book-open": body = "<path d=\"M12 7v14\"/><path d=\"M3 5a2 2 0 0 1 2-2h5a2 2 0 0 1 2 2v16a3 3 0 0 0-3-3H5a2 2 0 0 1-2-2z\"/><path d=\"M21 5a2 2 0 0 0-2-2h-5a2 2 0 0 0-2 2v16a3 3 0 0 1 3-3h4a2 2 0 0 0 2-2z\"/>"; break;
        case "file-percent": body = "<path d=\"M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z\"/><path d=\"M14 2v6h6\"/><path d=\"m9 17 6-6\"/><circle cx=\"9\" cy=\"11\" r=\"1\"/><circle cx=\"15\" cy=\"17\" r=\"1\"/>"; break;
        case "chart-pie": body = "<path d=\"M21 12a9 9 0 1 1-9-9v9z\"/><path d=\"M12 3a9 9 0 0 1 9 9h-9z\"/>"; break;
        case "chart-bar": body = "<path d=\"M3 3v18h18\"/><path d=\"M7 16v-5\"/><path d=\"M12 16V7\"/><path d=\"M17 16v-8\"/>"; break;
        case "chart-line": body = "<path d=\"M3 3v18h18\"/><path d=\"m7 15 4-4 3 3 5-7\"/>"; break;
        case "table": body = "<rect x=\"3\" y=\"4\" width=\"18\" height=\"16\" rx=\"2\"/><path d=\"M3 10h18\"/><path d=\"M9 4v16\"/>"; break;
        case "sliders": body = "<path d=\"M4 21v-7\"/><path d=\"M4 10V3\"/><path d=\"M12 21v-9\"/><path d=\"M12 8V3\"/><path d=\"M20 21v-5\"/><path d=\"M20 12V3\"/><path d=\"M2 14h4\"/><path d=\"M10 8h4\"/><path d=\"M18 16h4\"/>"; break;
        case "briefcase-user": body = "<path d=\"M10 6V5a2 2 0 0 1 2-2h0a2 2 0 0 1 2 2v1\"/><rect x=\"3\" y=\"6\" width=\"18\" height=\"14\" rx=\"2\"/><circle cx=\"12\" cy=\"12\" r=\"2\"/><path d=\"M8 18a4 4 0 0 1 8 0\"/>"; break;
        case "users": body = "<path d=\"M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2\"/><circle cx=\"9\" cy=\"7\" r=\"4\"/><path d=\"M22 21v-2a4 4 0 0 0-3-3.87\"/><path d=\"M16 3.13a4 4 0 0 1 0 7.75\"/>"; break;
        case "building": body = "<rect x=\"4\" y=\"2\" width=\"16\" height=\"20\" rx=\"2\"/><path d=\"M9 22v-4h6v4\"/><path d=\"M8 6h.01\"/><path d=\"M16 6h.01\"/><path d=\"M8 10h.01\"/><path d=\"M16 10h.01\"/><path d=\"M8 14h.01\"/><path d=\"M16 14h.01\"/>"; break;
        case "coins": body = "<circle cx=\"8\" cy=\"8\" r=\"5\"/><path d=\"M18.09 10.37A5 5 0 1 1 10.37 18.09\"/><path d=\"M7 6h1v4\"/>"; break;
        case "boxes": body = "<path d=\"m7.5 4.27 4.5 2.6 4.5-2.6\"/><path d=\"M3 8.5 12 14l9-5.5\"/><path d=\"M12 22V14\"/><path d=\"M3 8.5v7L12 21l9-5.5v-7\"/>"; break;
        case "user-check": body = "<path d=\"M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2\"/><circle cx=\"9\" cy=\"7\" r=\"4\"/><path d=\"m16 11 2 2 4-4\"/>"; break;
        case "alert-triangle": body = "<path d=\"m21.73 18-8-14a2 2 0 0 0-3.46 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3\"/><path d=\"M12 9v4\"/><path d=\"M12 17h.01\"/>"; break;
        case "heart-pulse": body = "<path d=\"M19.5 12.6 12 20 4.5 12.6a5 5 0 0 1 7.5-6.5 5 5 0 0 1 7.5 6.5z\"/><path d=\"M3 12h4l2-3 3 6 2-3h7\"/>"; break;
        case "target": body = "<circle cx=\"12\" cy=\"12\" r=\"10\"/><circle cx=\"12\" cy=\"12\" r=\"6\"/><circle cx=\"12\" cy=\"12\" r=\"2\"/>"; break;
        case "shield-check": body = "<path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10\"/><path d=\"m9 12 2 2 4-4\"/>"; break;
        case "monitor": body = "<rect x=\"3\" y=\"4\" width=\"18\" height=\"12\" rx=\"2\"/><path d=\"M8 20h8\"/><path d=\"M12 16v4\"/>"; break;
        case "bug": body = "<path d=\"M8 2l1.5 3h5L16 2\"/><rect x=\"7\" y=\"5\" width=\"10\" height=\"14\" rx=\"5\"/><path d=\"M3 13h4\"/><path d=\"M17 13h4\"/><path d=\"M4 19l3-2\"/><path d=\"M20 19l-3-2\"/><path d=\"M4 7l3 2\"/><path d=\"M20 7l-3 2\"/>"; break;
        case "database": body = "<ellipse cx=\"12\" cy=\"5\" rx=\"9\" ry=\"3\"/><path d=\"M3 5v14c0 1.66 4.03 3 9 3s9-1.34 9-3V5\"/><path d=\"M3 12c0 1.66 4.03 3 9 3s9-1.34 9-3\"/>"; break;
        case "settings": body = "<path d=\"M12.22 2h-.44a2 2 0 0 0-2 2l-.11.62a2 2 0 0 1-2.31 1.33l-.61-.2a2 2 0 0 0-2.45.9l-.22.38a2 2 0 0 0 .44 2.55l.49.42a2 2 0 0 1 0 3l-.49.42a2 2 0 0 0-.44 2.55l.22.38a2 2 0 0 0 2.45.9l.61-.2a2 2 0 0 1 2.31 1.33l.11.62a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2l.11-.62a2 2 0 0 1 2.31-1.33l.61.2a2 2 0 0 0 2.45-.9l.22-.38a2 2 0 0 0-.44-2.55l-.49-.42a2 2 0 0 1 0-3l.49-.42a2 2 0 0 0 .44-2.55l-.22-.38a2 2 0 0 0-2.45-.9l-.61.2a2 2 0 0 1-2.31-1.33L14.22 4a2 2 0 0 0-2-2\"/><circle cx=\"12\" cy=\"12\" r=\"3\"/>"; break;
        case "printer": body = "<path d=\"M6 9V2h12v7\"/><path d=\"M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2\"/><path d=\"M6 14h12v8H6z\"/>"; break;
        default: body = "<circle cx=\"12\" cy=\"12\" r=\"9\"/><path d=\"M12 8v4l3 2\"/>"; break;
    }
    <svg class="@("pos-svg-icon " + extraClass)" viewBox="0 0 24 24" aria-hidden="true" focusable="false">@Html.Raw(body)</svg>
}

<aside class="pos-main-sidebar" id="posMainSidebar" data-pos-user-key="@userStorageKey">
    <div class="pos-sidebar-brand">
        <div class="pos-main-logo">
            @if (!string.IsNullOrWhiteSpace(companyLogoPath))
            {
                <img src="@Url.Content(companyLogoPath)" alt="Keshni" />
            }
            else
            {
                <strong>كيشني</strong>
            }
        </div>
        <button type="button" class="pos-sidebar-collapse" id="posSidebarCollapseBtn" aria-label="تصغير القائمة" title="تصغير القائمة">
            @PosIcon("menu")
        </button>
    </div>

    <div class="pos-sidebar-user" title="المستخدم الحالي">
        <span class="user-avatar">@PosIcon("user")</span>
        <div>
            <strong>@(posContext != null ? posContext.UserName : "")</strong>
            <small>@(posContext != null ? posContext.BranchName : "")</small>
        </div>
    </div>

    <div class="pos-sidebar-search" role="search">
        @PosIcon("search")
        <input id="posMenuSearch" type="search" autocomplete="off" placeholder="بحث سريع: قبض، KYC، تقارير..." aria-label="بحث في قائمة POS" />
        <button type="button" id="posMenuSearchClear" aria-label="مسح البحث" title="مسح البحث">@PosIcon("x")</button>
    </div>

    <section class="pos-nav-quick-access" id="posQuickAccess" aria-label="الوصول السريع">
        <div class="pos-nav-quick-heading">
            <span>@PosIcon("pin") الوصول السريع</span>
            <small id="posQuickAccessCount">0</small>
        </div>
        <div class="pos-nav-favorites" id="posFavoritesList"></div>
        <div class="pos-nav-empty" id="posFavoritesEmpty">ثبت الشاشات الأكثر استخداماً من علامة الدبوس.</div>
    </section>

    <nav class="pos-main-nav pos-modern-nav" aria-label="قائمة نقطة البيع">
        <section class="pos-nav-section teller-sales-section @(salesOpen ? "is-open" : "")" data-section-id="sales">
            <button type="button" class="pos-nav-section-toggle" data-menu-toggle title="المبيعات" aria-expanded="@(salesOpen ? "true" : "false")">
                <span>@PosIcon("store")<b>المبيعات</b><small>بيع، KYC، كروت، تشغيل يومي</small></span>
                @PosIcon("chevron-down", "nav-chevron")
            </button>
            <div class="pos-nav-submenu">
                <a class="pos-nav-link teller-sales-link @(isActive("sales") ? "active" : "")" href="@Url.Action("Sales", "PosDashboard", new { area = "Pos" })" data-screen-url="@Url.Content("~/Pos/PosTransaction/Index")" data-nav-id="sales" data-nav-section="المبيعات" data-nav-text="شاشة البيع فاتورة بيع نقطة البيع pos sales cashier teller" title="شاشة البيع">@PosIcon("terminal")<span>شاشة البيع</span></a>
                <a class="pos-nav-link @(isActive("kyc") ? "active" : "")" href="@Url.Action("Kyc", "PosDashboard", new { area = "Pos" })" data-screen-url="@Url.Content("~/Pos/PosTransaction/Kyc")" data-nav-id="kyc" data-nav-section="المبيعات" data-nav-text="KYC العملاء الكروت كيشني كارت اعرف عميلك customer card bank" title="KYC">@PosIcon("id-card")<span>KYC</span></a>
                <a class="pos-nav-link @(isActive("kyc-bank-follow-up") ? "active" : "")" href="@Url.Action("KycBankFollowUp", "PosDashboard", new { area = "Pos" })" data-screen-url="@Url.Content("~/Pos/KycBankFollowUp/Index")" data-nav-id="kyc-bank-follow-up" data-nav-section="المبيعات" data-nav-text="متابعة KYC البنك bank follow up customer service" title="متابعة KYC">@PosIcon("landmark")<span>متابعة KYC</span></a>
                <a class="pos-nav-link @(isActive("closing") ? "active" : "")" href="@Url.Action("Closing", "PosDashboard", new { area = "Pos" })" data-screen-url="@Url.Content("~/Pos/PosClosing/Index")" data-nav-id="closing" data-nav-section="المبيعات" data-nav-text="إغلاق اليومية closing day close cashier" title="إغلاق اليومية">@PosIcon("lock-check")<span>إغلاق اليومية</span></a>
                <a class="pos-nav-link @(isActive("sales-performance") ? "active" : "")" href="@Url.Content("~/Pos/SalesRepresentativesPerformance/Index")" data-screen-url="@Url.Content("~/Pos/SalesRepresentativesPerformance/Index")" data-nav-id="sales-performance" data-nav-section="المبيعات" data-nav-text="أداء المناديب المبيعات sales representatives performance targets" title="أداء المناديب والمبيعات">@PosIcon("briefcase-user")<span>أداء المناديب والمبيعات</span></a>
                <a class="pos-nav-link @(isActive("sales-targets") ? "active" : "")" href="@Url.Content("~/Pos/SalesTargets/Index")" data-screen-url="@Url.Content("~/Pos/SalesTargets/Index")" data-nav-id="sales-targets" data-nav-section="المبيعات" data-nav-text="تارجت المناديب sales targets" title="تارجت المناديب">@PosIcon("target")<span>تارجت المناديب</span></a>
                <a class="pos-nav-link" href="@Url.Content("~/Pos/FinancialIntelligence/SalesCollections")" data-screen-url="@Url.Content("~/Pos/FinancialIntelligence/SalesCollections")" data-nav-id="sales-collections" data-nav-section="المبيعات" data-nav-text="المبيعات والتحصيل sales collections" title="تحليل المبيعات والتحصيل">@PosIcon("chart-line")<span>تحليل المبيعات والتحصيل</span></a>
            </div>
        </section>

        <section class="pos-nav-section @(reportsOpen ? "is-open" : "")" data-section-id="reports">
            <button type="button" class="pos-nav-section-toggle" data-menu-toggle title="التقارير" aria-expanded="@(reportsOpen ? "true" : "false")">
                <span>@PosIcon("chart-bar")<b>التقارير</b><small>كيشني، مالية، حسابات، تقارير ديناميكية</small></span>
                @PosIcon("chevron-down", "nav-chevron")
            </button>
            <div class="pos-nav-submenu">
                <a class="pos-nav-link @(isActive("reports") ? "active" : "")" href="@Url.Action("Reports", "PosDashboard", new { area = "Pos" })" data-screen-url="@Url.Content("~/Pos/PosReports/Index")" data-nav-id="reports" data-nav-section="التقارير" data-nav-text="تقارير كيشني الإغلاقات المبيعات التشغيل الكروت التوكينات المخالفات kishny reports" title="تقارير كيشني">@PosIcon("chart-bar")<span>تقارير كيشني</span></a>
                <a class="pos-nav-link @(isActive("financial-intelligence") ? "active" : "")" href="@Url.Action("FinancialIntelligence", "PosDashboard", new { area = "Pos" })" data-screen-url="@Url.Content("~/Pos/FinancialIntelligence/Index")" data-nav-id="financial-intelligence" data-nav-section="التقارير" data-nav-text="التقارير المالية مؤشرات مالية financial reports dashboard" title="التقارير المالية">@PosIcon("gauge")<span>التقارير المالية</span></a>
                <a class="pos-nav-link @(isActive("accounting-reports") ? "active" : "")" href="@Url.Action("AccountingReports", "PosDashboard", new { area = "Pos" })" data-screen-url="@Url.Content("~/Pos/AccountingReports/Index")" data-nav-id="accounting-reports" data-nav-section="التقارير" data-nav-text="تقارير الحسابات البنوك الخزن accounting reports" title="تقارير الحسابات">@PosIcon("landmark")<span>تقارير الحسابات</span></a>
                <a class="pos-nav-link" href="@Url.Content("~/Pos/DynamicReportsAdmin/Index")" data-screen-url="@Url.Content("~/Pos/DynamicReportsAdmin/Index")" data-nav-id="dynamic-reports-admin" data-nav-section="التقارير" data-nav-text="إدارة التقارير الديناميكية dynamic reports admin" title="إدارة التقارير الديناميكية">@PosIcon("settings")<span>إدارة التقارير الديناميكية</span></a>
                <a class="pos-nav-link" href="@Url.Content("~/Pos/DynamicReports/Index")" data-screen-url="@Url.Content("~/Pos/DynamicReports/Index")" data-nav-id="dynamic-reports" data-nav-section="التقارير" data-nav-text="مصمم التقارير الديناميكي dynamic report designer" title="مصمم التقارير الديناميكي">@PosIcon("sliders")<span>مصمم التقارير الديناميكي</span></a>
            </div>
        </section>

        <section class="pos-nav-section @(inventoryOpen ? "is-open" : "")" data-section-id="inventory">
            <button type="button" class="pos-nav-section-toggle" data-menu-toggle title="المخزون" aria-expanded="@(inventoryOpen ? "true" : "false")">
                <span>@PosIcon("boxes")<b>المخزون</b><small>أصناف، مخازن، جرد، تحويل</small></span>
                @PosIcon("chevron-down", "nav-chevron")
            </button>
            <div class="pos-nav-submenu">
