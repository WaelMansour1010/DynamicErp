        case "building": body = "<rect x=\"4\" y=\"2\" width=\"16\" height=\"20\" rx=\"2\"/><path d=\"M9 22v-4h6v4\"/><path d=\"M8 6h.01\"/><path d=\"M16 6h.01\"/><path d=\"M8 10h.01\"/><path d=\"M16 10h.01\"/><path d=\"M8 14h.01\"/><path d=\"M16 14h.01\"/>"; break;
        case "coins": body = "<circle cx=\"8\" cy=\"8\" r=\"5\"/><path d=\"M18.09 10.37A5 5 0 1 1 10.37 18.09\"/><path d=\"M7 6h1v4\"/>"; break;
        case "boxes": body = "<path d=\"m7.5 4.27 4.5 2.6 4.5-2.6\"/><path d=\"M3 8.5 12 14l9-5.5\"/><path d=\"M12 22V14\"/><path d=\"M3 8.5v7L12 21l9-5.5v-7\"/>"; break;
        case "user-check": body = "<path d=\"M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2\"/><circle cx=\"9\" cy=\"7\" r=\"4\"/><path d=\"m16 11 2 2 4-4\"/>"; break;
        case "alert-triangle": body = "<path d=\"m21.73 18-8-14a2 2 0 0 0-3.46 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3\"/><path d=\"M12 9v4\"/><path d=\"M12 17h.01\"/>"; break;
        case "heart-pulse": body = "<path d=\"M19.5 12.6 12 20 4.5 12.6a5 5 0 0 1 7.5-6.5 5 5 0 0 1 7.5 6.5z\"/><path d=\"M3 12h4l2-3 3 6 2-3h7\"/>"; break;
        case "target": body = "<circle cx=\"12\" cy=\"12\" r=\"10\"/><circle cx=\"12\" cy=\"12\" r=\"6\"/><circle cx=\"12\" cy=\"12\" r=\"2\"/>"; break;
        case "shield-check": body = "<path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10\"/><path d=\"m9 12 2 2 4-4\"/>"; break;
        case "monitor": body = "<rect x=\"3\" y=\"4\" width=\"18\" height=\"12\" rx=\"2\"/><path d=\"M8 20h8\"/><path d=\"M12 16v4\"/>"; break;
        case "bug": body = "<path d=\"M8 2l1.5 3h5L16 2\"/><rect x=\"7\" y=\"5\" width=\"10\" height=\"14\" rx=\"5\"/><path d=\"M3 13h4\"/><path d=\"M17 13h4\"/><path d=\"M4 19l3-2\"/><path d=\"M20 19l-3-2\"/><path d=\"M4 7l3 2\"/><path d=\"M20 7l-3 2\"/>"; break;
        case "database": body = "<ellipse cx=\"12\" cy=\"5\" rx=\"9\" ry=\"3\"/><path d=\"M3 5v14c0 1.66 4.03 3 9 3s9-1.34 9-3V5\"/><path d=\"M3 12c0 1.66 4.03 3 9 3s9-1.34 9-3\"/>"; break;
        case "settings": body = "<path d=\"M12.22 2h-.44a2 2 0 0 0-2 2l-.11.62a2 2 0 0 1-2.31 1.33l-.61-.2a2 2 0 0 0-2.45.9l-.22.38a2 2 0 0 0 .44 2.55l.49.42a2 2 0 0 1 0 3l-.49.42a2 2 0 0 0-.44 2.55l.22.38a2 2 0 0 0 2.45.9l.61-.2a2 2 0 0 1 2.31 1.33l.11.62a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2l.11-.62a2 2 0 0 1 2.31-1.33l.61.2a2 2 0 0 0 2.45-.9l.22-.38a2 2 0 0 0-.44-2.55l-.49-.42a2 2 0 0 1 0-3l.49-.42a2 2 0 0 0 .44-2.55l-.22-.38a2 2 0 0 0-2.45-.9l-.61.2a2 2 0 0 1-2.31-1.33L14.22 4a2 2 0 0 0-2-2\"/><circle cx=\"12\" cy=\"12\" r=\"3\"/>"; break;
        case "printer": body = "<path d=\"M6 9V2h12v7\"/><path d=\"M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2\"/><path d=\"M6 14h12v8H6z\"/>"; break;
        default: body = "<circle cx=\"12\" cy=\"12\" r=\"9\"/><path d=\"M12 8v4l3 2\"/>"; break;
    }
    <svg class="@("pos-svg-icon " + extraClass)" viewBox="0 0 24 24" aria-hidden="true" focusable="false">@Html.Raw(body)</svg>
}

<aside class="pos-main-sidebar" id="posMainSidebar" data-pos-user-key="@userStorageKey">
    <div class="pos-sidebar-brand">
        <div class="pos-main-logo">
            @if (!string.IsNullOrWhiteSpace(companyLogoPath))
            {
                <img src="@Url.Content(companyLogoPath)" alt="Keshni" />
            }
            else
            {
                <strong>كيشني</strong>
            }
        </div>
        <button type="button" class="pos-sidebar-collapse" id="posSidebarCollapseBtn" aria-label="تصغير القائمة" title="تصغير القائمة">
            @PosIcon("menu")
        </button>
    </div>

    <div class="pos-sidebar-user" title="المستخدم الحالي">
        <span class="user-avatar">@PosIcon("user")</span>
        <div>
            <strong>@(posContext != null ? posContext.UserName : "")</strong>
            <small>@(posContext != null ? posContext.BranchName : "")</small>
        </div>
    </div>

    <div class="pos-sidebar-search" role="search">
        @PosIcon("search")
        <input id="posMenuSearch" type="search" autocomplete="off" placeholder="بحث سريع: قبض، KYC، تقارير..." aria-label="بحث في قائمة POS" />
        <button type="button" id="posMenuSearchClear" aria-label="مسح البحث" title="مسح البحث">@PosIcon("x")</button>
    </div>

    <section class="pos-nav-quick-access" id="posQuickAccess" aria-label="الوصول السريع">
        <div class="pos-nav-quick-heading">
            <span>@PosIcon("pin") الوصول السريع</span>
            <small id="posQuickAccessCount">0</small>
        </div>
        <div class="pos-nav-favorites" id="posFavoritesList"></div>
        <div class="pos-nav-empty" id="posFavoritesEmpty">ثبت الشاشات الأكثر استخداماً من علامة الدبوس.</div>
    </section>

    <nav class="pos-main-nav pos-modern-nav" aria-label="قائمة نقطة البيع">
        <a class="pos-nav-link pos-nav-home @(isActive("dashboard") ? "active" : "")"
           href="@Url.Action("Index", "PosDashboard", new { area = "Pos" })"
           data-dashboard-screen="true"
           data-nav-id="dashboard"
           data-nav-section="الإدارة والإعدادات"
           data-nav-text="لوحة التحكم dashboard admin management"
           title="لوحة التحكم">
            @PosIcon("gauge")<span>لوحة التحكم</span>
        </a>

        <section class="pos-nav-section teller-sales-section @(dailyOpen ? "is-open" : "")" data-section-id="daily">
            <button type="button" class="pos-nav-section-toggle" data-menu-toggle title="العمليات اليومية" aria-expanded="@(dailyOpen ? "true" : "false")">
                <span>@PosIcon("store")<b>العمليات اليومية</b><small>بيع، KYC، إغلاق، مخزون</small></span>
                @PosIcon("chevron-down", "nav-chevron")
            </button>
            <div class="pos-nav-submenu">
                <a class="pos-nav-link teller-sales-link @(isActive("sales") ? "active" : "")"
                   href="@Url.Action("Sales", "PosDashboard", new { area = "Pos" })"
                   data-screen-url="@Url.Content("~/Pos/PosTransaction/Index")"
                   data-nav-id="sales"
                   data-nav-section="العمليات اليومية"
                   data-nav-text="نقطة البيع شاشة البيع pos sales cashier teller فاتورة بيع"
                   title="شاشة البيع">
                    @PosIcon("terminal")<span>نقطة البيع POS</span>
                </a>
                <a class="pos-nav-link @(isActive("kyc") ? "active" : "")"
                   href="@Url.Action("Kyc", "PosDashboard", new { area = "Pos" })"
                   data-screen-url="@Url.Content("~/Pos/PosTransaction/Index?openKyc=true")"
                   data-nav-id="kyc"
                   data-nav-section="العمليات اليومية"
                   data-nav-text="KYC اعرف عميلك كارت بطاقة customer card bank"
                   title="KYC">
                    @PosIcon("id-card")<span>KYC</span>
                </a>
                <a class="pos-nav-link @(isActive("closing") ? "active" : "")"
                   href="@Url.Action("Closing", "PosDashboard", new { area = "Pos" })"
                   data-screen-url="@Url.Content("~/Pos/PosClosing/Index")"
                   data-nav-id="closing"
                   data-nav-section="العمليات اليومية"
                   data-nav-text="الإغلاق إغلاق اليومية closing day close cashier"
                   title="الإغلاق">
                    @PosIcon("lock-check")<span>إغلاق اليومية</span>
                </a>
                @if (isAdmin || (posContext != null && posContext.CanOpenPayments))
                {
                    <a class="pos-nav-link @(isActive("payments") ? "active" : "")"
                       href="@Url.Action("Payments", "PosDashboard", new { area = "Pos" })"
                       data-screen-url="@Url.Content("~/Pos/Payments/Index")"
                       data-nav-id="payments"
                       data-nav-section="العمليات اليومية"
                       data-nav-text="تمويل العهدة payments custody cash box funding"
                       title="تمويل العهدة">
                        @PosIcon("wallet")<span>تمويل العهدة</span>
                    </a>
                }
                @if (isAdmin || (posContext != null && posContext.CanSave))
                {
                    <a class="pos-nav-link @(isActive("stock-transfer") ? "active" : "")"
                       href="@Url.Action("StockTransfer", "PosDashboard", new { area = "Pos" })"
                       data-screen-url="@Url.Content("~/Pos/StockTransfer/Index")"
                       data-nav-id="stock-transfer"
                       data-nav-section="العمليات اليومية"
                       data-nav-text="تحويل مخزون stock transfer store inventory"
                       title="تحويل مخزون">
                        @PosIcon("arrows-left-right")<span>تحويل مخزون</span>
                    </a>
                    <a class="pos-nav-link @(isActive("purchase-invoice") ? "active" : "")"
                       href="@Url.Action("PurchaseInvoice", "PosDashboard", new { area = "Pos" })"
                       data-screen-url="@Url.Content("~/Pos/PurchaseInvoice/Index")"
                       data-nav-id="purchase-invoice"
                       data-nav-section="العمليات اليومية"
                       data-nav-text="فاتورة مشتريات purchases purchase invoice supplier"
                       title="فواتير مشتريات">
                        @PosIcon("receipt")<span>فاتورة مشتريات</span>
                    </a>
                    if (isAdmin || (posContext != null && posContext.CanImportExcel))
                    {
                    <a class="pos-nav-link @(isActive("excel-import") ? "active" : "")"
                       href="@Url.Action("ExcelImport", "PosDashboard", new { area = "Pos" })"
                       data-screen-url="@Url.Content("~/Pos/ExcelImport/Index")"
                       data-nav-id="excel-import"
                       data-nav-section="العمليات اليومية"
                       data-nav-text="استيراد Excel العمليات import excel upload"
                       title="استيراد العمليات من Excel">
                        @PosIcon("spreadsheet")<span>استيراد العمليات من Excel</span>
                    </a>
                    }
                }
            </div>
        </section>

        <section class="pos-nav-section @(financeOpen ? "is-open" : "")" data-section-id="finance">
            <button type="button" class="pos-nav-section-toggle" data-menu-toggle title="المالية" aria-expanded="@(financeOpen ? "true" : "false")">
                <span>@PosIcon("landmark")<b>المالية</b><small>سندات، قيود، إشعارات</small></span>
                @PosIcon("chevron-down", "nav-chevron")
            </button>
            <div class="pos-nav-submenu">
                @if (isAdmin || (posContext != null && posContext.CanViewAccountingReports))
                {
                    <a class="pos-nav-link @(isActive("cashing") ? "active" : "")"
                       href="@Url.Action("Cashing", "PosDashboard", new { area = "Pos" })"
                       data-screen-url="@Url.Content("~/Pos/Cashing/Index")"
                       data-nav-id="cashing"
                       data-nav-section="المالية"
                       data-nav-text="سند قبض قبض cashing receipt voucher receive"
                       title="سندات القبض">
                        @PosIcon("receipt-plus")<span>سندات القبض</span>
                    </a>
                    <a class="pos-nav-link @(isActive("payment-vouchers") ? "active" : "")"
                       href="@Url.Content("~/Pos/Payments/Vouchers")"
                       data-screen-url="@Url.Content("~/Pos/Payments/Vouchers")"
                       data-nav-id="payment-vouchers"
                       data-nav-section="المالية"
                       data-nav-text="سند صرف صرف payment voucher payable"
                       title="سندات الصرف">
                        @PosIcon("banknote-arrow")<span>سندات الصرف</span>
                    </a>
                }
                @if (isAdmin || (posContext != null && (posContext.CanViewJournalEntry || posContext.CanCreateJournalEntry || posContext.CanEditJournalEntry || posContext.CanDeleteJournalEntry)))
                {
                    <a class="pos-nav-link @(isActive("journal-entries") ? "active" : "")"
                       href="@Url.Action("JournalEntries", "PosDashboard", new { area = "Pos" })"
                       data-screen-url="@Url.Content("~/Pos/JournalEntries/Index")"
                       data-nav-id="journal-entries"
                       data-nav-section="المالية"
                       data-nav-text="قيود يومية قيد journal entries accounting"
                       title="إدخال واستعراض القيود">
                        @PosIcon("book-open")<span>القيود اليومية</span>
                    </a>
                    <a class="pos-nav-link @(isActive("discount-notifications") ? "active" : "")"
                       href="@Url.Content("~/Pos/DiscountNotifications/Index")"
                       data-screen-url="@Url.Content("~/Pos/DiscountNotifications/Index")"
                       data-nav-id="discount-notifications"
                       data-nav-section="المالية"
                       data-nav-text="إشعارات خصم discount notifications debit credit"
                       title="الإشعارات">
                        @PosIcon("file-percent")<span>إشعارات الخصم</span>
                    </a>
                }
                @if (isAdmin || (posContext != null && posContext.CanViewAccountingReports))
                {
                    <a class="pos-nav-link @(isActive("accounting-reports") ? "active" : "")"
                       href="@Url.Action("AccountingReports", "PosDashboard", new { area = "Pos" })"
                       data-screen-url="@Url.Content("~/Pos/AccountingReports/Index")"
                       data-nav-id="accounting-reports"
                       data-nav-section="المالية"
                       data-nav-text="تقارير مالية حسابات accounting reports financial"
                       title="تقارير الحسابات">
                        @PosIcon("chart-pie")<span>التقارير المالية</span>
                    </a>
                }
            </div>
        </section>

        <section class="pos-nav-section @(reportsOpen ? "is-open" : "")" data-section-id="reports">
            <button type="button" class="pos-nav-section-toggle" data-menu-toggle title="التقارير والتحليلات" aria-expanded="@(reportsOpen ? "true" : "false")">
                <span>@PosIcon("chart-line")<b>التقارير والتحليلات</b><small>تشغيل، فروع، مؤشرات</small></span>
                @PosIcon("chevron-down", "nav-chevron")
            </button>
            <div class="pos-nav-submenu">
                @if (hasReportMenuAccess)
                {
                    <a class="pos-nav-link @(isActive("reports") ? "active" : "")"
                       href="@Url.Action("Reports", "PosDashboard", new { area = "Pos" })"
                       data-screen-url="@Url.Content("~/Pos/PosReports/Index")"
                       data-nav-id="reports"
                       data-nav-section="التقارير والتحليلات"
