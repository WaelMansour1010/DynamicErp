        case "user": body = "<path d=\"M19 21a7 7 0 0 0-14 0\"/><circle cx=\"12\" cy=\"7\" r=\"4\"/>"; break;
        case "search": body = "<circle cx=\"11\" cy=\"11\" r=\"8\"/><path d=\"m21 21-4.3-4.3\"/>"; break;
        case "x": body = "<path d=\"M18 6 6 18\"/><path d=\"m6 6 12 12\"/>"; break;
        case "pin": body = "<path d=\"M12 17v5\"/><path d=\"M5 17h14\"/><path d=\"m7 7 10 10\"/><path d=\"M9 7V3h6v4l2 2v2H7V9z\"/>"; break;
