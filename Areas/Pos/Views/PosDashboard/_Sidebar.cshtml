                <i class="fas fa-chevron-down nav-chevron" aria-hidden="true"></i>
            </button>
            <div class="pos-nav-submenu">
                @if (isAdmin || (posContext != null && posContext.CanViewAccountingReports))
                {
                    <a class="pos-nav-link @(isActive("cashing") ? "active" : "")"
                       href="@Url.Action("Cashing", "PosDashboard", new { area = "Pos" })"
                       data-screen-url="@Url.Content("~/Pos/Cashing/Index")"
                       data-nav-id="cashing"
                       data-nav-section="المالية"
