                        <i class="fas fa-hand-holding-usd" aria-hidden="true"></i><span>سندات القبض</span>
                    </a>
                    <a class="pos-nav-link @(isActive("payment-vouchers") ? "active" : "")"
                       href="@Url.Content("~/Pos/Payments/Vouchers")"
                       data-screen-url="@Url.Content("~/Pos/Payments/Vouchers")"
                       data-nav-id="payment-vouchers"
                       data-nav-section="المالية"
                       data-nav-text="سند صرف صرف payment voucher payable"
                       title="سندات الصرف">
                        <i class="fas fa-money-bill-wave" aria-hidden="true"></i><span>سندات الصرف</span>
                    </a>
                }
                @if (isAdmin || (posContext != null && (posContext.CanViewJournalEntry || posContext.CanCreateJournalEntry || posContext.CanEditJournalEntry || posContext.CanDeleteJournalEntry)))
