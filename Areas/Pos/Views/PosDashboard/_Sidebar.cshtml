                    <a class="pos-nav-link" href="@Url.Content("~/Pos/FinancialIntelligence/Expenses")" data-screen-url="@Url.Content("~/Pos/FinancialIntelligence/Expenses")" data-nav-id="expenses" data-nav-section="التقارير والتحليلات" data-nav-text="المصروفات expenses" title="تحليل المصروفات"><i class="fas fa-chart-pie" aria-hidden="true"></i><span>تحليل المصروفات</span></a>
                    <a class="pos-nav-link" href="@Url.Content("~/Pos/FinancialIntelligence/InventoryProfitability")" data-screen-url="@Url.Content("~/Pos/FinancialIntelligence/InventoryProfitability")" data-nav-id="inventory-profitability" data-nav-section="التقارير والتحليلات" data-nav-text="المخزون والربحية inventory profitability" title="مؤشرات المخزون والربحية"><i class="fas fa-boxes" aria-hidden="true"></i><span>مؤشرات المخزون والربحية</span></a>
                    <a class="pos-nav-link" href="@Url.Content("~/Pos/FinancialIntelligence/EmployeeReceivables")" data-screen-url="@Url.Content("~/Pos/FinancialIntelligence/EmployeeReceivables")" data-nav-id="employee-receivables" data-nav-section="التقارير والتحليلات" data-nav-text="ذمم الموظفين employee receivables" title="تشخيص ذمم الموظفين"><i class="fas fa-user-check" aria-hidden="true"></i><span>ذمم الموظفين</span></a>
                    <a class="pos-nav-link" href="@Url.Content("~/Pos/FinancialIntelligence/Custody")" data-screen-url="@Url.Content("~/Pos/FinancialIntelligence/Custody")" data-nav-id="custody" data-nav-section="التقارير والتحليلات" data-nav-text="العهد والسلف custody advances" title="تشخيص العهد والسلف"><i class="fas fa-wallet" aria-hidden="true"></i><span>العهد والسلف</span></a>
                    <a class="pos-nav-link" href="@Url.Content("~/Pos/FinancialIntelligence/AbnormalJournals")" data-screen-url="@Url.Content("~/Pos/FinancialIntelligence/AbnormalJournals")" data-nav-id="abnormal-journals" data-nav-section="التقارير والتحليلات" data-nav-text="تنبيهات مراجعة محاسبية قيود غير طبيعية abnormal journals" title="تنبيهات ومراجعة محاسبية"><i class="fas fa-exclamation-triangle" aria-hidden="true"></i><span>تنبيهات محاسبية</span></a>
