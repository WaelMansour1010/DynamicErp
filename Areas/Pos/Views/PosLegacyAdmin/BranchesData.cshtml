@model MyERP.Areas.Pos.Models.PosBranchesDataIndexModel
@using System.Collections.Generic
@{
    Layout = null;
    ViewBag.Title = "بيانات الأنشطة والفروع - FrmBranchesData";
    var selected = Model.Selected ?? new MyERP.Areas.Pos.Models.PosActivityEditModel();
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title</title>
    <link href="@Url.Content("~/Areas/Pos/Content/pos-transaction.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Areas/Pos/Content/legacy-admin.css?v=20260514")" rel="stylesheet" />
</head>
<body>
    <div class="pos-page legacy-admin-page" id="legacyBranchesPage"
         data-save-url="@Url.Action("SaveBranchesData", "PosLegacyAdmin", new { area = "Pos" })">
        @Html.AntiForgeryToken()
        <header class="legacy-admin-hero branches">
            <div>
                <span>FrmBranchesData - VB6 main original</span>
                <h1>بيانات الأنشطة والفروع</h1>
                <p>إعادة بناء شاشة الأنشطة والفروع من المشروع الرئيسي داخل POS مع الحفاظ على جدولَي <b>tblActivitesType</b> و<b>TblBranchesData</b>.</p>
            </div>
            <div class="legacy-actions">
                <a href="@Url.Action("BranchesData", "PosLegacyAdmin", new { area = "Pos" })">نشاط جديد</a>
                <button type="button" id="legacyBranchesAddRow">إضافة فرع</button>
                <button type="button" id="legacyBranchesSave">حفظ</button>
            </div>
        </header>
        <div id="legacyBranchesStatus" class="legacy-status" hidden></div>

        <div class="legacy-admin-shell">
            <aside class="legacy-side">
                <div class="legacy-list">
                    @foreach (var activity in Model.Activities)
                    {
                        <a class="legacy-row @(selected.Id == activity.Id ? "active" : "")" href="@Url.Action("BranchesData", "PosLegacyAdmin", new { area = "Pos", id = activity.Id })">
                            <strong>@activity.Name</strong>
                            <span>@activity.Id - @activity.NameEnglish</span>
                            <small>@activity.BranchCount فرع</small>
                        </a>
                    }
                </div>
            </aside>
            <main class="legacy-workspace">
                <form id="legacyBranchesForm">
                    <section class="legacy-card">
                        <div class="legacy-card-head"><h2>النشاط</h2><span>tblActivitesType</span></div>
                        <div class="legacy-grid three">
                            <label>رقم النشاط<input name="activity.Id" value="@selected.Id" readonly /></label>
                            <label>اسم النشاط عربي<input name="activity.Name" value="@selected.Name" maxlength="50" required /></label>
                            <label>اسم النشاط إنجليزي<input name="activity.NameEnglish" value="@selected.NameEnglish" maxlength="255" required /></label>
                        </div>
                    </section>

                    <section class="legacy-card">
                        <div class="legacy-card-head"><h2>الفروع التابعة للنشاط</h2><span>TblBranchesData</span></div>
                        <div class="legacy-table-wrap">
                            <table class="legacy-edit-table" id="legacyBranchesTable">
                                <thead>
                                    <tr>
                                        <th>رقم</th>
                                        <th>الكود</th>
                                        <th>الاسم عربي</th>
                                        <th>الاسم إنجليزي</th>
                                        <th>المدير</th>
                                        <th>التليفون</th>
                                        <th>VAT</th>
                                        <th>المنطقة</th>
                                        <th>المخزن</th>
                                        <th>الحساب</th>
                                        <th>إيقاف</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (var i = 0; i < Model.Branches.Count; i++)
                                    {
                                        @BranchRow(i, Model.Branches[i])
                                    }
                                </tbody>
                            </table>
                        </div>
                    </section>
                </form>
            </main>
        </div>

        <template id="legacyBranchRowTemplate">
            @BranchRow(-1, new MyERP.Areas.Pos.Models.PosBranchDataEditModel())
        </template>
    </div>

    <script src="@Url.Content("~/Areas/Pos/Scripts/legacy-admin.js?v=20260514")"></script>
</body>
</html>

@helper BranchRow(int index, MyERP.Areas.Pos.Models.PosBranchDataEditModel branch)
{
    var prefix = index < 0 ? "branches[__i__]" : "branches[" + index + "]";
    <tr>
        <td><input name="@(prefix).BranchId" value="@branch.BranchId" class="small" /></td>
        <td><input name="@(prefix).BranchCode" value="@branch.BranchCode" maxlength="255" /></td>
        <td><input name="@(prefix).BranchName" value="@branch.BranchName" maxlength="50" /></td>
        <td><input name="@(prefix).BranchNameEnglish" value="@branch.BranchNameEnglish" maxlength="50" /></td>
        <td><input name="@(prefix).Manager" value="@branch.Manager" maxlength="50" /></td>
        <td><input name="@(prefix).Telephone" value="@branch.Telephone" maxlength="50" /></td>
        <td><input name="@(prefix).VatNo" value="@branch.VatNo" maxlength="255" /></td>
        <td>@Select(prefix + ".RegionId", branch.RegionId, Model.Regions)</td>
        <td>@Select(prefix + ".StoreId", branch.StoreId, Model.Stores)</td>
        <td><input name="@(prefix).AccountCode" value="@branch.AccountCode" maxlength="255" /></td>
        <td><input type="checkbox" name="@(prefix).IsStopped" value="true" @(branch.IsStopped ? "checked" : "") /></td>
        <td><button type="button" class="legacy-row-remove">حذف</button></td>
    </tr>
}

@helper Select(string name, int? value, IEnumerable<MyERP.Areas.Pos.Models.PosLegacyLookupDto> rows)
{
    <select name="@name">
        <option value=""></option>
        @foreach (var row in rows)
        {
            <option value="@row.Id" @(value == row.Id ? "selected" : "")>@row.Display</option>
        }
    </select>
}
