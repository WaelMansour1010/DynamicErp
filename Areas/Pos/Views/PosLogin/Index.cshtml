@model MyERP.Areas.Pos.Models.PosLoginRequest
@{
    Layout = null;
    ViewBag.Title = "تسجيل دخول نقطة البيع";
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="utf-8" />
<title>@ViewBag.Title</title>
<link href="@Url.Content("~/Areas/Pos/Content/pos-transaction.css")" rel="stylesheet" />
</head>
<body>

<div class="pos-page pos-mode-card pos-login-page" dir="rtl">
    <div class="pos-shell login-shell">
        <header class="pos-header">
            <div>
                <h1>كيشني - تسجيل دخول نقطة البيع</h1>
                <p class="cash-db-warning">هذه شاشة تجريبية على قاعدة CASH - لا يوجد قيد أو خصم مخزون حتى الآن</p>
            </div>
        </header>

        <section class="pos-panel login-panel">
            @using (Html.BeginForm("Index", "PosLogin", new { area = "Pos" }, FormMethod.Post, new { autocomplete = "off" }))
            {
                @Html.AntiForgeryToken()
                <div class="pos-grid">
                    <label>اسم المستخدم<input type="text" name="UserName" value="@Model.UserName" autofocus /></label>
                    <label>كلمة المرور<input type="password" name="Password" /></label>
                </div>

                if (ViewBag.ErrorMessage != null)
                {
                    <div class="pos-validation">@ViewBag.ErrorMessage</div>
                }

                <footer class="pos-actions">
                    <button type="submit" class="primary-action">دخول</button>
                </footer>
            }
        </section>
    </div>
</div>
</body>
</html>
