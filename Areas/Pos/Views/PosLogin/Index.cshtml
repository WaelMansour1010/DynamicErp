@model MyERP.Areas.Pos.Models.PosLoginRequest
@{
    Layout = null;
    ViewBag.Title = "تسجيل دخول نقطة البيع";
    var primaryLogoPath = "~/Areas/Pos/assets/images/company-logo.png";
    var alternateLogoPath = "~/Areas/Pos/assets/images/company-logo-1.png";
    var legacyLogoPath = "~/Areas/Pos/assets/images/company-logo-2.png";
    var companyLogoPath = System.IO.File.Exists(Server.MapPath(primaryLogoPath))
        ? primaryLogoPath
        : (System.IO.File.Exists(Server.MapPath(alternateLogoPath))
            ? alternateLogoPath
            : (System.IO.File.Exists(Server.MapPath(legacyLogoPath)) ? legacyLogoPath : null));
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="utf-8" />
<title>@ViewBag.Title</title>
<script>
    (function () {
        var key = "kishny.pos.theme";
        var resetKey = "kishny.pos.theme.defaultLight.20260513";
        var saved = null;
        try {
            if (localStorage.getItem(resetKey) !== "true") {
                localStorage.setItem(key, "light");
                localStorage.setItem(resetKey, "true");
            }
            saved = localStorage.getItem(key);
        } catch (e) { saved = null; }
        document.documentElement.setAttribute("data-pos-theme", saved === "dark" ? "dark" : "light");
    })();
</script>
<link href="@Url.Content("~/Areas/Pos/Content/pos-transaction.css?v=20260513-light-default")" rel="stylesheet" />
</head>
<body>

<div class="pos-page pos-mode-card pos-login-page" dir="rtl">
    <div class="pos-shell login-shell">
        <div class="login-brand-card">
            @if (!string.IsNullOrWhiteSpace(companyLogoPath))
            {
                <img src="@Url.Content(companyLogoPath)"
                     alt="Company Logo"
                     class="login-company-logo" />
            }
            else
            {
                <span class="pos-company-logo-fallback">اسم الشركة</span>
            }
            <div>
                <h1>كيشني - تسجيل دخول نقطة البيع</h1>
                <p>أدخل بيانات مستخدم نقطة البيع للمتابعة</p>
            </div>
            <button type="button" class="pos-theme-toggle login-theme-toggle" id="posLoginThemeToggle" aria-label="تبديل الوضع" title="تبديل الوضع">
                <span class="theme-sun" aria-hidden="true"></span>
                <span class="theme-moon" aria-hidden="true"></span>
                <b id="posLoginThemeText">Light</b>
            </button>
        </div>

        <section class="pos-panel login-panel">
            @using (Html.BeginForm("Index", "PosLogin", new { area = "Pos" }, FormMethod.Post, new { autocomplete = "off" }))
            {
                @Html.AntiForgeryToken()
                <div class="pos-grid">
                    <label>اسم المستخدم<input type="text" name="UserName" value="@Model.UserName" autofocus /></label>
                    <label>كلمة المرور<input type="password" name="Password" /></label>
                </div>

                if (ViewBag.ErrorMessage != null)
                {
                    <div class="pos-validation">@ViewBag.ErrorMessage</div>
                }

                <footer class="pos-actions">
                    <button type="submit" class="primary-action">دخول</button>
                </footer>
            }
        </section>
    </div>
</div>
<script>
    (function () {
        var key = "kishny.pos.theme";
        var toggle = document.getElementById("posLoginThemeToggle");
        var label = document.getElementById("posLoginThemeText");
        function theme() { return document.documentElement.getAttribute("data-pos-theme") === "dark" ? "dark" : "light"; }
        function apply(next) {
            next = next === "dark" ? "dark" : "light";
            document.documentElement.setAttribute("data-pos-theme", next);
            try { localStorage.setItem(key, next); } catch (e) { }
            if (toggle) {
                toggle.setAttribute("aria-pressed", next === "dark" ? "true" : "false");
                toggle.setAttribute("title", next === "dark" ? "الوضع الداكن" : "الوضع الفاتح");
            }
            if (label) { label.textContent = next === "dark" ? "Dark" : "Light"; }
        }
        apply(theme());
        if (toggle) {
            toggle.addEventListener("click", function () {
                apply(theme() === "dark" ? "light" : "dark");
            });
        }
    })();
</script>
</body>
</html>
