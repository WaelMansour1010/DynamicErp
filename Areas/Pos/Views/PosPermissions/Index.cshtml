@{
    Layout = null;
    ViewBag.Title = "صلاحيات POS";
    var users = ViewBag.Users as IEnumerable<MyERP.Areas.Pos.Models.PosPermissionUserDto>;
    var permissions = ViewBag.Permissions as IEnumerable<MyERP.Areas.Pos.Models.PosPermissionItemDto>;
    var categories = ViewBag.UserCategories as IEnumerable<string>;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title</title>
    <link href="@Url.Content("~/Areas/Pos/Content/pos-transaction.css")" rel="stylesheet" />
</head>
<body>
    <div class="pos-page pos-permissions-page"
         data-load-url="@Url.Action("GetUserPermissions", "PosPermissions", new { area = "Pos" })"
         data-save-url="@Url.Action("Save", "PosPermissions", new { area = "Pos" })"
         data-save-category-url="@Url.Action("SaveUserCategory", "PosPermissions", new { area = "Pos" })"
         data-bulk-url="@Url.Action("BulkApply", "PosPermissions", new { area = "Pos" })">
        <div class="pos-shell">
            <section class="pos-panel">
                <div class="panel-heading">
                    <h2>إدارة صلاحيات POS المؤقتة</h2>
                    <span>Admin only</span>
                </div>
                <div class="pos-grid two-cols">
                    <label>
                        المستخدم
                        <select id="permissionUserId">
                            <option value="">اختر المستخدم</option>
                            @if (users != null)
                            {
                                foreach (var user in users)
                                {
                                    <option value="@user.UserId" data-category="@user.UserCategory">@user.UserName @(string.IsNullOrWhiteSpace(user.EmpName) ? "" : " - " + user.EmpName)</option>
                                }
                            }
                        </select>
                    </label>
                    <label>
                        فئة المستخدم
                        <select id="permissionUserCategory">
                            <option value="">بدون فئة</option>
                            @if (categories != null)
                            {
                                foreach (var category in categories)
                                {
                                    <option value="@category">@category</option>
                                }
                            }
                        </select>
                    </label>
                </div>
                <div class="pos-actions">
                    <button type="button" class="secondary-action" id="saveUserCategoryBtn">حفظ فئة المستخدم</button>
                </div>
            </section>

            <section class="pos-panel">
                <div id="permissionsGrid" class="permissions-grid">
                    @if (permissions != null)
                    {
                        foreach (var permission in permissions)
                        {
                            <label>
                                <input type="checkbox" value="@permission.Key" />
                                <span>@permission.Title</span>
                            </label>
                        }
                    }
                </div>
                <div class="pos-actions">
                    <button type="button" class="primary-action" id="savePosPermissionsBtn">حفظ الصلاحيات</button>
                </div>
                <div id="permissionsMessage" class="pos-validation"></div>
            </section>

            <section class="pos-panel">
                <div class="panel-heading">
                    <h2>تطبيق صلاحية على فئة كاملة</h2>
                    <span>Bulk permissions</span>
                </div>
                <div class="pos-grid three-cols">
                    <label>
                        الفئة
                        <select id="bulkCategory">
                            <option value="">اختر الفئة</option>
                            @if (categories != null)
                            {
                                foreach (var category in categories)
                                {
                                    <option value="@category">@category</option>
                                }
                            }
                        </select>
                    </label>
                    <label>
                        الصلاحية
                        <select id="bulkPermissionKey">
                            <option value="">اختر الصلاحية</option>
                            @if (permissions != null)
                            {
                                foreach (var permission in permissions)
                                {
                                    <option value="@permission.Key">@permission.Title</option>
                                }
                            }
                        </select>
                    </label>
                    <label>
                        الإجراء
                        <select id="bulkIsAllowed">
                            <option value="true">منح الصلاحية</option>
                            <option value="false">سحب الصلاحية</option>
                        </select>
                    </label>
                </div>
                <div class="pos-actions">
                    <button type="button" class="primary-action" id="bulkApplyPermissionsBtn">تطبيق على الفئة</button>
                </div>
                <div id="bulkPermissionsMessage" class="pos-validation"></div>
            </section>
        </div>
    </div>

    <script>
        (function () {
            var page = document.querySelector(".pos-permissions-page");
            var userSelect = document.getElementById("permissionUserId");
            var categorySelect = document.getElementById("permissionUserCategory");
            var message = document.getElementById("permissionsMessage");
            var bulkMessage = document.getElementById("bulkPermissionsMessage");

            function setMessage(text) { message.innerText = text || ""; }
            function setBulkMessage(text) { bulkMessage.innerText = text || ""; }
            function enhanceSelectSearch(select, placeholder) {
                if (!select || select.getAttribute("data-enhanced") === "true") { return; }
                select.setAttribute("data-enhanced", "true");
                var parent = select.parentNode;
                var wrap = document.createElement("span");
                wrap.className = "smart-lookup smart-select";
                parent.insertBefore(wrap, select);
                wrap.appendChild(select);

                var input = document.createElement("input");
                input.type = "text";
                input.className = "lookup-input";
                input.placeholder = placeholder || "اكتب للبحث";
                input.autocomplete = "off";
                var results = document.createElement("div");
                results.className = "lookup-results";
                wrap.insertBefore(input, select);
                wrap.appendChild(results);

                function optionText(option) { return option ? (option.textContent || option.innerText || "").trim() : ""; }
                function syncInput() {
                    input.value = select.value ? optionText(select.options[select.selectedIndex]) : "";
                }
                function close() { results.classList.remove("is-open"); }
                function choose(option) {
                    if (!option) { return; }
                    select.value = option.value;
                    syncInput();
                    close();
                    select.dispatchEvent(new Event("change"));
                }
                function render() {
                    var term = input.value.trim().toLowerCase();
                    var options = Array.prototype.slice.call(select.options).filter(function (opt) {
                        if (!opt.value) { return term.length === 0; }
                        return optionText(opt).toLowerCase().indexOf(term) >= 0 || String(opt.value).toLowerCase().indexOf(term) >= 0;
                    }).slice(0, 40);
                    results.innerHTML = "";
                    if (!options.length) {
                        var empty = document.createElement("div");
                        empty.className = "lookup-row empty";
                        empty.textContent = "لا توجد نتائج";
                        results.appendChild(empty);
                    } else {
                        options.forEach(function (opt) {
                            var row = document.createElement("button");
                            row.type = "button";
                            row.className = "lookup-row";
                            row.textContent = optionText(opt);
                            row.addEventListener("mousedown", function (event) {
                                event.preventDefault();
                                choose(opt);
                            });
                            results.appendChild(row);
                        });
                    }
                    results.classList.add("is-open");
                }
                input.addEventListener("input", render);
                input.addEventListener("focus", render);
                input.addEventListener("keydown", function (event) {
                    var rows = Array.prototype.slice.call(results.querySelectorAll(".lookup-row:not(.empty)"));
                    var current = results.querySelector(".lookup-row.is-active");
                    var index = rows.indexOf(current);
                    if (event.key === "ArrowDown") {
                        event.preventDefault();
                        if (current) { current.classList.remove("is-active"); }
                        var next = rows[Math.min(index + 1, rows.length - 1)];
                        if (next) { next.classList.add("is-active"); }
                    } else if (event.key === "ArrowUp") {
                        event.preventDefault();
                        if (current) { current.classList.remove("is-active"); }
                        var prev = rows[Math.max(index - 1, 0)];
                        if (prev) { prev.classList.add("is-active"); }
                    } else if (event.key === "Enter" && current) {
                        event.preventDefault();
                        current.dispatchEvent(new MouseEvent("mousedown"));
                    } else if (event.key === "Escape") {
                        close();
                    }
                });
                input.addEventListener("blur", function () { window.setTimeout(close, 150); });
                select.addEventListener("change", syncInput);
                syncInput();
            }
            function request(method, url, body, callback) {
                var xhr = new XMLHttpRequest();
                xhr.open(method, url, true);
                xhr.setRequestHeader("Content-Type", "application/json;charset=UTF-8");
                xhr.onreadystatechange = function () {
                    if (xhr.readyState !== 4) { return; }
                    var data = null;
                    try { data = xhr.responseText ? JSON.parse(xhr.responseText) : null; } catch (ignore) { }
                    callback(xhr.status, data);
                };
                xhr.send(body ? JSON.stringify(body) : null);
            }

            enhanceSelectSearch(userSelect, "اكتب اسم المستخدم أو الكود");
            enhanceSelectSearch(document.getElementById("bulkPermissionKey"), "اكتب اسم الصلاحية");
            enhanceSelectSearch(document.getElementById("bulkCategory"), "اكتب فئة المستخدم");

            function checkedItems() {
                var items = [];
                var inputs = document.querySelectorAll("#permissionsGrid input[type=checkbox]");
                for (var i = 0; i < inputs.length; i++) {
                    items.push({ Key: inputs[i].value, IsAllowed: inputs[i].checked });
                }
                return items;
            }

            function applyPermissions(items) {
                var map = {};
                for (var i = 0; items && i < items.length; i++) {
                    map[items[i].Key] = items[i].IsAllowed === true;
                }
                var inputs = document.querySelectorAll("#permissionsGrid input[type=checkbox]");
                for (var x = 0; x < inputs.length; x++) {
                    inputs[x].checked = map[inputs[x].value] === true;
                }
            }

            userSelect.addEventListener("change", function () {
                var userId = parseInt(userSelect.value, 10) || 0;
                applyPermissions([]);
                var selectedOption = userSelect.options[userSelect.selectedIndex];
                categorySelect.value = selectedOption ? (selectedOption.getAttribute("data-category") || "") : "";
                if (userId <= 0) { return; }
                setMessage("جاري تحميل الصلاحيات...");
                request("GET", page.getAttribute("data-load-url") + "?userId=" + encodeURIComponent(userId), null, function (status, data) {
                    if (status >= 200 && status < 300 && data && data.success) {
                        applyPermissions(data.permissions || []);
                        setMessage("");
                        return;
                    }
                    setMessage((data && data.message) || "تعذر تحميل الصلاحيات");
                });
            });

            document.getElementById("saveUserCategoryBtn").addEventListener("click", function () {
                var userId = parseInt(userSelect.value, 10) || 0;
                if (userId <= 0) {
                    setMessage("اختر المستخدم أولاً");
                    return;
                }

                setMessage("جاري حفظ فئة المستخدم...");
                request("POST", page.getAttribute("data-save-category-url"), { UserId: userId, UserCategory: categorySelect.value }, function (status, data) {
                    if (status >= 200 && status < 300 && data && data.success) {
                        var selectedOption = userSelect.options[userSelect.selectedIndex];
                        if (selectedOption) {
                            selectedOption.setAttribute("data-category", categorySelect.value || "");
                        }
                    }
                    setMessage((data && data.message) || (status >= 200 && status < 300 ? "تم الحفظ" : "تعذر حفظ فئة المستخدم"));
                });
            });

            document.getElementById("savePosPermissionsBtn").addEventListener("click", function () {
                var userId = parseInt(userSelect.value, 10) || 0;
                if (userId <= 0) {
                    setMessage("اختر المستخدم أولاً");
                    return;
                }
                setMessage("جاري الحفظ...");
                request("POST", page.getAttribute("data-save-url"), { UserId: userId, Permissions: checkedItems() }, function (status, data) {
                    setMessage((data && data.message) || (status >= 200 && status < 300 ? "تم الحفظ" : "تعذر حفظ الصلاحيات"));
                });
            });

            document.getElementById("bulkApplyPermissionsBtn").addEventListener("click", function () {
                var category = document.getElementById("bulkCategory").value;
                var permissionKey = document.getElementById("bulkPermissionKey").value;
                var isAllowed = document.getElementById("bulkIsAllowed").value === "true";
                if (!category || !permissionKey) {
                    setBulkMessage("اختر الفئة والصلاحية أولاً");
                    return;
                }

                if (!window.confirm("سيتم تعديل صلاحيات كل مستخدمي فئة " + category + "، هل تريد المتابعة؟")) {
                    return;
                }

                setBulkMessage("جاري التطبيق...");
                request("POST", page.getAttribute("data-bulk-url"), { UserCategory: category, PermissionKey: permissionKey, IsAllowed: isAllowed }, function (status, data) {
                    if (status >= 200 && status < 300 && data && data.success) {
                        setBulkMessage((data.message || "تم التطبيق") + " - عدد المستخدمين: " + data.affectedUsers + " - صفوف الصلاحيات المحدثة: " + data.updatedRows);
                        return;
                    }

                    setBulkMessage((data && data.message) || "تعذر تطبيق الصلاحية على الفئة");
                });
            });
        })();
    </script>
</body>
</html>
