                    };
                    reader.onerror = function () {
                        byId("reportMessage").innerText = "تعذر تصدير Excel";
                        endAction("export", key, button);
                    };
                    reader.readAsText(xhr.response || new Blob(), "utf-8");
                };
                xhr.onerror = function () {
                    byId("reportMessage").innerText = "تعذر الاتصال بالسيرفر أثناء تصدير Excel";
                    endAction("export", key, button);
                };
                var data = payload(key);
                var form = [
                    ["ReportKey", data.reportKey || ""],
                    ["FromDate", data.fromDate || ""],
                    ["ToDate", data.toDate || ""],
                    ["BranchId", data.branchId || ""],
                    ["BranchFromId", data.branchFromId || ""],
                    ["BranchToId", data.branchToId || ""],
                    ["StoreId", data.storeId || ""],
                    ["UserId", data.userId || ""],
                    ["ServiceType", data.serviceType || ""],
                    ["IncludeCardIssueCheck", data.includeCardIssueCheck ? "true" : "false"],
                    ["CardIssueMode", data.cardIssueMode || "none"],
                    ["LoginSource", data.loginSource || ""],
                    ["SortBy", data.sortBy || ""],
                    ["SerialSearch", data.serialSearch || ""],
                    ["ServiceSearch", data.serviceSearch || ""],
                    ["ShowEmptyBranches", data.showEmptyBranches ? "true" : "false"]
                ].map(function (item) {
                    return encodeURIComponent(item[0]) + "=" + encodeURIComponent(item[1]);
                }).join("&");
                xhr.send(form);
            }

            document.addEventListener("click", function (event) {
                var tab = event.target.closest ? event.target.closest("#reportTabs button") : null;
                if (tab) {
                    var buttons = document.querySelectorAll("#reportTabs button");
                    for (var i = 0; i < buttons.length; i++) { buttons[i].classList.remove("active"); }
                    tab.classList.add("active");
                    updateGroups(activeGroup());
                    return;
                }

                var reportButton = event.target.closest ? event.target.closest(".report-action") : null;
                if (reportButton && !reportButton.disabled) {
                    var reportKey = reportButton.getAttribute("data-report-key");
                    if (!beginAction("run", reportKey, reportButton, "جاري تجهيز التقرير...")) { return; }
                    runReport(reportKey, null, {
                        message: "جاري تجهيز التقرير...",
                        complete: function () { endAction("run", reportKey, reportButton); }
                    });
                    return;
                }

                var exportButton = event.target.closest ? event.target.closest(".report-export") : null;
                if (exportButton && !exportButton.disabled) {
                    var exportKey = exportButton.getAttribute("data-report-key");
                    if (!beginAction("export", exportKey, exportButton, "جاري تجهيز Excel...")) { return; }
                    exportReport(exportKey, exportButton);
                    return;
                }

                var printButton = event.target.closest ? event.target.closest(".report-print") : null;
                if (printButton && !printButton.disabled) {
                    var printKey = printButton.getAttribute("data-report-key");
                    if (!beginAction("print", printKey, printButton, "جاري الطباعة...")) { return; }
                    printReport(printKey, printButton);
                }
            });

            enhanceSelectSearch(byId("reportBranchId"), "اكتب اسم الفرع أو الكود");
            enhanceSelectSearch(byId("reportBranchFromId"), "من فرع");
            enhanceSelectSearch(byId("reportBranchToId"), "إلى فرع");
            enhanceSelectSearch(byId("reportUserId"), "اكتب اسم المستخدم أو الكود");
            enhanceSelectSearch(byId("reportStoreId"), "اكتب اسم المخزن أو الكود");
            lazyLookup(byId("reportBranchId"), "branches");
            lazyLookup(byId("reportBranchFromId"), "branches");
            lazyLookup(byId("reportBranchToId"), "branches");
            lazyLookup(byId("reportUserId"), "users");
            lazyLookup(byId("reportStoreId"), "stores", function () {
                return { branchId: byId("reportBranchId").value || "" };
            });
            byId("reportBranchId").addEventListener("change", function () {
                var store = byId("reportStoreId");
                store.setAttribute("data-loaded", "false");
                while (store.options.length > 1) { store.remove(1); }
            });
            updateGroups("sales");
        })();
    </script>
</body>
</html>
