@model MyERP.Areas.Pos.Models.PosSqlUpdateDashboardViewModel
@using System.Collections.Generic
@using System.Globalization
@{
    Layout = null;
    var status = Model != null ? Model.Status : null;
    var scripts = status != null ? status.Scripts : new List<MyERP.Areas.Pos.Models.PosSqlUpdateScriptViewModel>();
    Func<DateTime?, string> dateText = d => d.HasValue ? d.Value.ToString("yyyy-MM-dd HH:mm:ss", CultureInfo.InvariantCulture) : "-";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>إدارة تحديثات قاعدة البيانات</title>
    <style>
        :root { --bg:#f5f7fb; --text:#172033; --muted:#64748b; --line:#d9e1ec; --brand:#0f766e; --danger:#b42318; --warn:#b45309; --ok:#15803d; --info:#1d4ed8; }
        * { box-sizing:border-box; }
        body { margin:0; font-family:Tahoma, Arial, sans-serif; background:var(--bg); color:var(--text); }
        .page { padding:22px; max-width:1500px; margin:0 auto; }
        .header { display:flex; align-items:flex-start; justify-content:space-between; gap:16px; margin-bottom:18px; }
        h1 { margin:0 0 8px; font-size:24px; }
        .subtitle { color:var(--muted); font-size:13px; line-height:1.7; }
        .status-pill { display:inline-flex; align-items:center; gap:8px; padding:8px 12px; border-radius:6px; font-weight:700; border:1px solid var(--line); background:#fff; }
        .status-pill.ok { color:var(--ok); border-color:#bbf7d0; background:#f0fdf4; }
        .status-pill.pending { color:var(--warn); border-color:#fed7aa; background:#fff7ed; }
        .status-pill.danger, .status-pill.blocked { color:var(--danger); border-color:#fecaca; background:#fef2f2; }
        .cards { display:grid; grid-template-columns:repeat(5,minmax(140px,1fr)); gap:12px; margin-bottom:18px; }
        .card { background:#fff; border:1px solid var(--line); border-radius:8px; padding:14px; min-height:84px; }
        .card span { display:block; color:var(--muted); font-size:12px; margin-bottom:8px; }
        .card strong { font-size:22px; }
        .actions { display:flex; align-items:center; flex-wrap:wrap; gap:10px; background:#fff; border:1px solid var(--line); border-radius:8px; padding:12px; margin-bottom:14px; }
        button, .button { border:0; border-radius:6px; padding:10px 14px; font-weight:700; cursor:pointer; text-decoration:none; display:inline-flex; align-items:center; gap:8px; }
        .primary { background:var(--brand); color:#fff; }
        .secondary { background:#e2e8f0; color:#0f172a; }
        .danger { background:var(--danger); color:#fff; }
        .confirm { display:flex; align-items:center; gap:8px; color:#334155; font-size:13px; }
        .alert { border-radius:8px; padding:12px 14px; margin-bottom:14px; border:1px solid var(--line); background:#fff; }
        .alert.ok { border-color:#bbf7d0; background:#f0fdf4; color:#166534; }
        .alert.error { border-color:#fecaca; background:#fef2f2; color:#991b1b; }
        .warning { border-color:#fed7aa; background:#fff7ed; color:#9a3412; }
        .table-wrap { background:#fff; border:1px solid var(--line); border-radius:8px; overflow:auto; }
        table { width:100%; border-collapse:collapse; min-width:1100px; }
        th, td { padding:10px; border-bottom:1px solid #edf2f7; text-align:right; vertical-align:top; font-size:12px; }
        th { background:#f8fafc; color:#334155; position:sticky; top:0; z-index:1; }
        .hash { direction:ltr; text-align:left; font-family:Consolas, monospace; max-width:190px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
        .badge { display:inline-block; padding:5px 8px; border-radius:999px; font-weight:700; font-size:11px; }
        .badge.applied { background:#dcfce7; color:#166534; }
        .badge.pending { background:#ffedd5; color:#9a3412; }
        .badge.failed { background:#fee2e2; color:#991b1b; }
        .badge.hash-mismatch { background:#ffe4e6; color:#be123c; }
        .badge.manual { background:#e0e7ff; color:#3730a3; }
        .runs { margin-top:16px; background:#fff; border:1px solid var(--line); border-radius:8px; padding:14px; }
        .runs h2 { font-size:16px; margin:0 0 10px; }
        .small { color:var(--muted); font-size:12px; }
        @@media (max-width:900px) { .header { display:block; } .cards { grid-template-columns:repeat(2,minmax(0,1fr)); } .page { padding:14px; } }
    </style>
</head>
<body>
    <main class="page">
        <section class="header">
            <div>
                <h1>إدارة تحديثات قاعدة البيانات</h1>
                <div class="subtitle">
                    قاعدة البيانات: <strong>@(status != null ? status.DatabaseName : "-")</strong> |
                    السيرفر: <strong>@(status != null ? status.ServerName : "-")</strong> |
                    الموديول: <strong>@(status != null ? status.ModuleName : "Kishny POS")</strong>
                </div>
            </div>
            <div class="status-pill @(status != null ? status.StatusCssClass : "blocked")">
                @(status != null ? status.StatusText : "غير معروف")
            </div>
        </section>

        @if (!string.IsNullOrWhiteSpace(Model.Message))
        {
            <div class="alert @(Model.IsError ? "error" : "ok")">@Model.Message</div>
        }

        @if (status != null && !status.IsPosDatabase)
        {
            <div class="alert warning">تم منع التطبيق لأن قاعدة البيانات الحالية لا تحتوي على كائنات POS المطلوبة.</div>
        }
        @if (status != null && status.HashMismatchCount > 0)
        {
            <div class="alert error">يوجد اختلاف Hash في سكريبت مطبق سابقاً. التنفيذ متوقف حتى تتم المراجعة الفنية.</div>
        }

        <section class="cards">
            <div class="card"><span>تم تطبيقها</span><strong>@(status != null ? status.AppliedCount : 0)</strong></div>
            <div class="card"><span>منتظرة</span><strong>@(status != null ? status.PendingCount : 0)</strong></div>
            <div class="card"><span>فشل سابق</span><strong>@(status != null ? status.FailedCount : 0)</strong></div>
            <div class="card"><span>تحذيرات Hash</span><strong>@(status != null ? status.HashMismatchCount : 0)</strong></div>
            <div class="card"><span>آخر تطبيق</span><strong style="font-size:14px">@dateText(status != null ? status.LastAppliedOn : null)</strong></div>
        </section>

        <section class="actions">
            @using (Html.BeginForm("DryRun", "PosSqlUpdates", new { area = "Pos" }, FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <button type="submit" class="secondary">فحص بدون تنفيذ</button>
            }
            @using (Html.BeginForm("ApplyPending", "PosSqlUpdates", new { area = "Pos" }, FormMethod.Post, new { onsubmit = "return confirm('سيتم تطبيق تحديثات على قاعدة البيانات. تأكد من وجود Backup. هل تريد المتابعة؟');" }))
            {
                @Html.AntiForgeryToken()
                <label class="confirm">
                    <input type="checkbox" name="confirmBackup" value="true" />
                    أؤكد أنه تم أخذ نسخة احتياطية كاملة من قاعدة البيانات قبل تطبيق التحديثات.
                </label>
                <button type="submit" class="danger" @(status == null || !status.IsPosDatabase || status.HashMismatchCount > 0 ? "disabled" : "")>تطبيق التحديثات المنتظرة</button>
            }
            @if (status != null && status.LastRunId.HasValue)
            {
                <a class="button primary" href="@Url.Action("DownloadLog", "PosSqlUpdates", new { area = "Pos", id = status.LastRunId.Value })">تحميل سجل آخر تشغيل</a>
            }
        </section>

        <section class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>الترتيب</th>
                        <th>السكريبت</th>
                        <th>الغرض</th>
                        <th>الحالة</th>
                        <th>تاريخ التطبيق</th>
                        <th>بواسطة</th>
                        <th>Hash</th>
                        <th>آخر خطأ</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var script in scripts.OrderBy(s => s.IsManual).ThenBy(s => s.Order).ThenBy(s => s.ScriptName))
                    {
                        <tr>
                            <td>@(script.IsManual ? "-" : script.Order.ToString("0.##", CultureInfo.InvariantCulture))</td>
                            <td><strong>@script.ScriptName</strong><div class="small">@script.RelativePath</div></td>
                            <td>@script.Purpose</td>
                            <td><span class="badge @script.StatusCssClass">@script.StatusArabic</span></td>
                            <td>@dateText(script.AppliedOn)</td>
                            <td>@(string.IsNullOrWhiteSpace(script.AppliedBy) ? "-" : script.AppliedBy)</td>
                            <td class="hash" title="@script.Hash">@script.Hash</td>
                            <td>@(string.IsNullOrWhiteSpace(script.LastErrorSummary) ? "-" : script.LastErrorSummary)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </section>

        @if (status != null && status.RecentRuns.Any())
        {
            <section class="runs">
                <h2>آخر عمليات التشغيل</h2>
                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th>RunId</th>
                                <th>البداية</th>
                                <th>النهاية</th>
                                <th>الحالة</th>
                                <th>المستخدم</th>
                                <th>IP</th>
                                <th>إجمالي</th>
                                <th>تم</th>
                                <th>تخطى</th>
                                <th>فشل</th>
                                <th>السجل</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var run in status.RecentRuns)
                            {
                                <tr>
                                    <td>@run.RunId</td>
                                    <td>@run.StartedAt.ToString("yyyy-MM-dd HH:mm:ss", CultureInfo.InvariantCulture)</td>
                                    <td>@(run.FinishedAt.HasValue ? run.FinishedAt.Value.ToString("yyyy-MM-dd HH:mm:ss", CultureInfo.InvariantCulture) : "-")</td>
                                    <td>@run.Status</td>
                                    <td>@(string.IsNullOrWhiteSpace(run.UserName) ? run.StartedBy : run.UserName)</td>
                                    <td>@(string.IsNullOrWhiteSpace(run.ClientIp) ? "-" : run.ClientIp)</td>
                                    <td>@run.TotalScripts</td>
                                    <td>@run.AppliedCount</td>
                                    <td>@run.SkippedCount</td>
                                    <td>@run.FailedCount</td>
                                    <td><a href="@Url.Action("DownloadLog", "PosSqlUpdates", new { area = "Pos", id = run.RunId })">تحميل</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }
    </main>
</body>
</html>
