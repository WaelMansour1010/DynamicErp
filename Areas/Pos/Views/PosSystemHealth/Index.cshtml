@{
    Layout = null;
    ViewBag.Title = "مراقبة النظام";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title</title>
    <link href="@Url.Content("~/Areas/Pos/Content/pos-transaction.css")" rel="stylesheet" />
    <script src="@Url.Content("~/assets/libs/chart-js/Chart.bundle.min.js")"></script>
    <style>
        body { background: #f8fafc; color: #0f172a; font-family: "Tahoma", "Arial", sans-serif; margin: 0; }
        .health-page { display: grid; gap: 16px; padding: 18px; }
        .health-hero { background: #fff; border: 1px solid #e5e7eb; border-radius: 14px; box-shadow: 0 2px 12px rgba(15,23,42,.05); display: flex; justify-content: space-between; gap: 16px; padding: 18px; }
        .health-hero h1 { font-size: 28px; margin: 0; }
        .health-hero p { color: #64748b; margin: 6px 0 0; }
        .health-actions { align-items: center; display: flex; flex-wrap: wrap; gap: 10px; }
        .health-primary { background: #2563eb; border: 0; border-radius: 10px; color: #fff; cursor: pointer; font-weight: 700; padding: 12px 18px; }
        .health-primary[disabled] { cursor: wait; opacity: .65; }
        .health-muted { color: #64748b; font-size: 13px; }
        .health-grid { display: grid; gap: 12px; grid-template-columns: repeat(5, minmax(0, 1fr)); }
        .health-card, .health-panel { background: #fff; border: 1px solid #e5e7eb; border-radius: 14px; box-shadow: 0 2px 12px rgba(15,23,42,.05); padding: 16px; }
        .health-card { border-right: 5px solid #2563eb; min-height: 118px; }
        .health-card.warning { border-right-color: #f59e0b; }
        .health-card.danger { border-right-color: #ef4444; }
        .health-card.success { border-right-color: #22c55e; }
        .health-card span { color: #64748b; display: block; font-size: 13px; }
        .health-card strong { display: block; direction: ltr; font-size: 30px; margin-top: 12px; text-align: right; }
        .health-card small { color: #64748b; display: block; margin-top: 8px; }
        .health-panels { display: grid; gap: 14px; grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .health-panel h2 { font-size: 20px; margin: 0 0 12px; }
        .health-alerts { display: grid; gap: 10px; }
        .health-alert { border: 1px solid #dbeafe; border-radius: 12px; padding: 12px; }
        .health-alert.high { background: #fef2f2; border-color: #fecaca; }
        .health-alert.medium { background: #fffbeb; border-color: #fde68a; }
        .health-alert.low { background: #f0fdf4; border-color: #bbf7d0; }
        .health-alert strong { display: block; margin-bottom: 4px; }
        .health-table { border-collapse: collapse; width: 100%; }
        .health-table th, .health-table td { border-bottom: 1px solid #e5e7eb; padding: 10px; text-align: right; }
        .health-table th { background: #f1f5f9; color: #334155; position: sticky; top: 0; }
        .health-empty { color: #64748b; padding: 16px; text-align: center; }
        .health-chart { height: 220px; }
        @@media (max-width: 1100px) {
            .health-grid, .health-panels { grid-template-columns: 1fr; }
            .health-hero { display: grid; }
        }
    </style>
</head>
<body>
    <main class="health-page" data-snapshot-url="@Url.Action("Snapshot", "PosSystemHealth", new { area = "Pos" })">
        <section class="health-hero">
            <div>
                <h1>مراقبة النظام</h1>
                <p>متابعة فورية لصحة نقطة البيع، الأداء، الجلسات، وحالة قاعدة البيانات.</p>
            </div>
            <div class="health-actions">
                <button type="button" class="health-primary" id="refreshHealthBtn">تحديث مؤشرات النظام</button>
                <span class="health-muted" id="healthUpdatedAt">لا يتم تحميل مؤشرات الخادم الثقيلة إلا عند الضغط على التحديث.</span>
            </div>
        </section>

        <section class="health-grid" id="healthCards">
            <article class="health-card"><span>المستخدمون النشطون</span><strong>--</strong><small>آخر 15 دقيقة</small></article>
            <article class="health-card"><span>طلبات في الدقيقة</span><strong>--</strong><small>طلبات POS فقط</small></article>
            <article class="health-card"><span>متوسط زمن الاستجابة</span><strong>--</strong><small>آخر 5 دقائق</small></article>
            <article class="health-card"><span>معدل الأخطاء</span><strong>--</strong><small>HTTP 400+</small></article>
            <article class="health-card"><span>استعادة الجلسات</span><strong>--</strong><small>آخر ساعة</small></article>
        </section>

        <section class="health-panel">
            <h2>التنبيهات الذكية</h2>
            <div class="health-alerts" id="healthAlerts"><div class="health-empty">اضغط تحديث مؤشرات النظام لعرض التنبيهات.</div></div>
        </section>

        <section class="health-panels">
            <article class="health-panel">
                <h2>أداء الحفظ في POS</h2>
                <div class="health-chart"><canvas id="posSaveChart"></canvas></div>
                <div id="posHealthDetails"></div>
            </article>
            <article class="health-panel">
                <h2>آخر أخطاء التطبيق</h2>
                <div id="lastErrors"></div>
            </article>
            <article class="health-panel">
                <h2>أبطأ الاستعلامات الحالية</h2>
                <div id="slowQueries"></div>
            </article>
            <article class="health-panel">
                <h2>الحجز في قاعدة البيانات</h2>
                <div id="blockingSessions"></div>
            </article>
            <article class="health-panel">
                <h2>مؤشرات قاعدة البيانات</h2>
                <div id="dbCounters"></div>
            </article>
            <article class="health-panel">
                <h2>موارد النظام</h2>
                <div id="resourceHints"></div>
            </article>
        </section>
    </main>

    <script>
        (function () {
            var page = document.querySelector(".health-page");
            var button = document.getElementById("refreshHealthBtn");
            var chart;

            function html(value) {
                return String(value === null || value === undefined ? "" : value)
                    .replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
            }

            function number(value, suffix) {
                var n = parseFloat(value || 0);
                return (isNaN(n) ? "0" : n.toFixed(n % 1 === 0 ? 0 : 2)) + (suffix || "");
            }

            function cardClass(value, warn, danger) {
                value = parseFloat(value || 0);
                if (value >= danger) { return "danger"; }
                if (value >= warn) { return "warning"; }
                return "success";
            }

            function read(obj, name) {
                return obj ? (obj[name] !== undefined ? obj[name] : obj[name.charAt(0).toLowerCase() + name.slice(1)]) : undefined;
            }

            function renderCards(data) {
                var core = read(data, "Core") || {};
                var cards = [
                    ["المستخدمون النشطون", read(core, "ActiveUsers"), "آخر 15 دقيقة", cardClass(read(core, "ActiveUsers"), 90, 120)],
                    ["طلبات في الدقيقة", read(core, "RequestsPerMinute"), "طلبات POS فقط", cardClass(read(core, "RequestsPerMinute"), 300, 600)],
                    ["متوسط زمن الاستجابة", number(read(core, "AverageResponseMs"), " ms"), "أخضر < 300، أحمر > 800", cardClass(read(core, "AverageResponseMs"), 300, 800)],
                    ["معدل الأخطاء", number(read(core, "ErrorRatePercent"), "%"), "HTTP 400+", cardClass(read(core, "ErrorRatePercent"), 2, 5)],
                    ["استعادة الجلسات", read(core, "SessionRestoresLastHour"), "آخر ساعة", cardClass(read(core, "SessionRestoresLastHour"), 10, 30)]
                ];
                var out = "";
                for (var i = 0; i < cards.length; i++) {
                    out += "<article class=\"health-card " + cards[i][3] + "\"><span>" + html(cards[i][0]) + "</span><strong>" + html(cards[i][1] || 0) + "</strong><small>" + html(cards[i][2]) + "</small></article>";
                }
                document.getElementById("healthCards").innerHTML = out;
            }

            function renderAlerts(data) {
                var rows = read(data, "Alerts") || [];
                if (!rows.length) {
                    document.getElementById("healthAlerts").innerHTML = "<div class=\"health-empty\">لا توجد تنبيهات حاليا.</div>";
                    return;
                }
                var out = "";
                rows.forEach(function (a) {
                    var severity = String(read(a, "Severity") || "Low").toLowerCase();
                    out += "<article class=\"health-alert " + html(severity) + "\"><strong>" + html(read(a, "Icon") || "تنبيه") + " " + html(read(a, "Title")) + "</strong><span>" + html(read(a, "Message")) + "</span></article>";
                });
                document.getElementById("healthAlerts").innerHTML = out;
            }

            function table(targetId, columns, rows, empty) {
                var target = document.getElementById(targetId);
                if (!rows || !rows.length) {
                    target.innerHTML = "<div class=\"health-empty\">" + html(empty || "لا توجد بيانات") + "</div>";
                    return;
                }
                var out = "<table class=\"health-table\"><thead><tr>";
                columns.forEach(function (c) { out += "<th>" + html(c.title) + "</th>"; });
                out += "</tr></thead><tbody>";
                rows.forEach(function (row) {
                    out += "<tr>";
                    columns.forEach(function (c) { out += "<td>" + html(read(row, c.key) || "") + "</td>"; });
                    out += "</tr>";
                });
                out += "</tbody></table>";
                target.innerHTML = out;
            }

            function renderPos(data) {
                var pos = read(data, "Pos") || {};
                document.getElementById("posHealthDetails").innerHTML =
                    "<table class=\"health-table\"><tbody>"
                    + "<tr><th>متوسط حفظ الفاتورة</th><td>" + html(number(read(pos, "InvoiceSaveAverageMs"), " ms")) + "</td></tr>"
                    + "<tr><th>أقصى زمن حفظ</th><td>" + html(number(read(pos, "InvoiceSaveMaxMs"), " ms")) + "</td></tr>"
                    + "<tr><th>محاولات حفظ فاشلة</th><td>" + html(read(pos, "FailedSavesCount") || 0) + "</td></tr>"
                    + "<tr><th>استعادة الجلسات/ساعة</th><td>" + html(read(pos, "SessionRestoreRatePerHour") || 0) + "</td></tr>"
                    + "</tbody></table>";

                if (typeof Chart !== "undefined") {
                    if (chart) { chart.destroy(); }
                    chart = new Chart(document.getElementById("posSaveChart").getContext("2d"), {
                        type: "bar",
                        data: {
                            labels: ["متوسط الحفظ", "أقصى حفظ"],
                            datasets: [{ data: [read(pos, "InvoiceSaveAverageMs") || 0, read(pos, "InvoiceSaveMaxMs") || 0], backgroundColor: ["#2563eb", "#f59e0b"] }]
                        },
                        options: { responsive: true, maintainAspectRatio: false, legend: { display: false }, scales: { yAxes: [{ ticks: { beginAtZero: true } }] } }
                    });
                }
            }

            function renderDetails(data) {
                var core = read(data, "Core") || {};
                var db = read(data, "Database") || {};
                var pos = read(data, "Pos") || {};
                table("lastErrors", [
                    { key: "Path", title: "المسار" },
                    { key: "StatusCode", title: "الكود" },
                    { key: "Message", title: "الرسالة" }
                ], (read(core, "LastErrors") || []).concat(read(pos, "LastSaveErrors") || []), "لا توجد أخطاء مسجلة في الذاكرة الحالية");
                table("slowQueries", [
                    { key: "SessionId", title: "Session" },
                    { key: "ElapsedMs", title: "الزمن ms" },
                    { key: "Command", title: "الأمر" },
                    { key: "ProcedureName", title: "الإجراء" },
                    { key: "WaitType", title: "الانتظار" }
                ], read(db, "SlowQueries") || [], "لا توجد استعلامات نشطة بطيئة الآن");
                table("blockingSessions", [
                    { key: "SessionId", title: "Session" },
                    { key: "BlockingSessionId", title: "يحجزه" },
                    { key: "WaitType", title: "نوع الانتظار" },
                    { key: "WaitMs", title: "زمن الانتظار" }
                ], read(db, "BlockingSessions") || [], "لا يوجد حجز حاليا");
                document.getElementById("dbCounters").innerHTML =
                    "<table class=\"health-table\"><tbody>"
                    + "<tr><th>حركات POS في آخر دقيقة</th><td>" + html(read(db, "TransactionsPerMinute") || 0) + "</td></tr>"
                    + "<tr><th>مؤشر Deadlocks من SQL</th><td>" + html(read(db, "DeadlockCounter") || 0) + "</td></tr>"
                    + (read(db, "StatusMessage") ? "<tr><th>ملاحظة</th><td>" + html(read(db, "StatusMessage")) + "</td></tr>" : "")
                    + "</tbody></table>";
                table("resourceHints", [
                    { key: "Name", title: "المؤشر" },
                    { key: "Value", title: "القيمة" },
                    { key: "Status", title: "الحالة" }
                ], read(data, "Resources") || [], "لا توجد مؤشرات موارد متاحة");
            }

            function refresh() {
                button.disabled = true;
                button.textContent = "جاري التحديث...";
                var xhr = new XMLHttpRequest();
                xhr.open("GET", page.getAttribute("data-snapshot-url"), true);
                xhr.onreadystatechange = function () {
                    if (xhr.readyState !== 4) { return; }
                    button.disabled = false;
                    button.textContent = "تحديث مؤشرات النظام";
                    var response = null;
                    try { response = xhr.responseText ? JSON.parse(xhr.responseText) : null; } catch (ignore) { }
                    if (xhr.status < 200 || xhr.status >= 300 || !response || !response.success) {
                        document.getElementById("healthAlerts").innerHTML = "<article class=\"health-alert high\"><strong>تعذر تحميل المراقبة</strong><span>" + html((response && response.message) || "تعذر قراءة رد السيرفر") + "</span></article>";
                        return;
                    }
                    var data = response.data || {};
                    document.getElementById("healthUpdatedAt").textContent = "آخر تحديث: " + new Date().toLocaleString("ar-EG");
                    renderCards(data);
                    renderAlerts(data);
                    renderPos(data);
                    renderDetails(data);
                };
                xhr.send();
            }

            button.addEventListener("click", refresh);
        })();
    </script>
</body>
</html>
