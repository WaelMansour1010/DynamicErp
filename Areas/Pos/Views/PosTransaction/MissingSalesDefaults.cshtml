@{
    Layout = null;
    var message = (ViewBag.Message as string) ?? "لا توجد إعدادات بيع افتراضية لهذا المستخدم، برجاء مراجعة الإدارة";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>إعدادات البيع غير مكتملة</title>
    <link href="@Url.Content("~/Areas/Pos/Content/pos-transaction.css")" rel="stylesheet" />
</head>
<body>
    <main class="pos-page" dir="rtl">
        <section class="pos-panel" style="max-width:720px;margin:80px auto;text-align:center;">
            <h1>إعدادات البيع غير مكتملة</h1>
            <p class="pos-validation" style="display:block;font-size:18px;">@message</p>
            <p>يمكنك استخدام الشاشات الأخرى المتاحة حسب صلاحياتك، ولا يتم منع تسجيل الدخول بسبب إعدادات البيع.</p>
        </section>
    </main>
</body>
</html>
