@{
    Layout = ViewBag.LayoutPath as string;
    ViewBag.Title = "Dynamic Report Admin";
    var scope = (ViewBag.Scope as string) ?? "Web";
    var apiBase = (ViewBag.DynamicReportsApiBase as string) ?? Url.Content("~/Reports/Admin");
}
@if (Layout == null)
{
    <!DOCTYPE html>
    <html>
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>Dynamic Report Admin</title>
        <script src="@Url.Content("~/Scripts/jquery-3.3.1.min.js")"></script>
        <link href="@Url.Content("~/Areas/Reports/Content/dynamic-reports.css")" rel="stylesheet" />
    </head>
    <body>
        @RenderPage("~/Areas/Reports/Views/Admin/_AdminBody.cshtml")
        <script>window.DynamicReportsScope = "@scope"; window.DynamicReportsApiBase = "@apiBase";</script>
        <script src="@Url.Content("~/Areas/Reports/Scripts/dynamic-reports-admin.js")"></script>
    </body>
    </html>
}
else
{
    <link href="@Url.Content("~/Areas/Reports/Content/dynamic-reports.css")" rel="stylesheet" />
    @RenderPage("~/Areas/Reports/Views/Admin/_AdminBody.cshtml")
    <script>window.DynamicReportsScope = "@scope"; window.DynamicReportsApiBase = "@apiBase";</script>
    <script>window.jQuery || document.write('<script src="@Url.Content("~/Scripts/jquery-3.3.1.min.js")"><\/script>');</script>
    <script src="@Url.Content("~/Areas/Reports/Scripts/dynamic-reports-admin.js")"></script>
}
