@{
    Layout = ViewBag.LayoutPath as string;
    ViewBag.Title = "Dynamic Reports";
    var scope = (ViewBag.Scope as string) ?? "Web";
    var apiBase = (ViewBag.DynamicReportsApiBase as string) ?? Url.Content("~/Reports/Viewer");
}
@if (Layout == null)
{
    <!DOCTYPE html>
    <html>
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>Dynamic Reports</title>
        <script src="@Url.Content("~/Scripts/jquery-3.3.1.min.js")"></script>
        <link href="@Url.Content("~/Areas/Reports/Content/dynamic-reports.css")" rel="stylesheet" />
    </head>
    <body>
        @RenderPage("~/Areas/Reports/Views/Viewer/_ViewerBody.cshtml")
        <script>window.DynamicReportsScope = "@scope"; window.DynamicReportsApiBase = "@apiBase";</script>
        <script src="@Url.Content("~/Areas/Reports/Scripts/dynamic-reports-viewer.js")"></script>
    </body>
    </html>
}
else
{
    @section scripts {
        <script>window.DynamicReportsScope = "@scope"; window.DynamicReportsApiBase = "@apiBase";</script>
        <script src="@Url.Content("~/Areas/Reports/Scripts/dynamic-reports-viewer.js")"></script>
    }
    <link href="@Url.Content("~/Areas/Reports/Content/dynamic-reports.css")" rel="stylesheet" />
    @RenderPage("~/Areas/Reports/Views/Viewer/_ViewerBody.cshtml")
}
