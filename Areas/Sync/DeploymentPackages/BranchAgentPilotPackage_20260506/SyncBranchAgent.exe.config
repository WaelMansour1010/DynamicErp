<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <connectionStrings>
    <!-- Local POS database only. Prefer Windows Integrated Security for branch service identity. -->
    <add name="BranchLocalDb"
         connectionString="Data Source=.\SQLEXPRESS;Initial Catalog=BranchPosTest;Integrated Security=True;MultipleActiveResultSets=True;TrustServerCertificate=True"
         providerName="System.Data.SqlClient" />
  </connectionStrings>
  <appSettings>
    <add key="BranchAgent.BranchId" value="10" />
    <add key="BranchAgent.ServiceName" value="SatriahBranchSyncAgent" />
    <add key="BranchAgent.PollSeconds" value="60" />
    <add key="BranchAgent.BatchSize" value="25" />
    <add key="BranchAgent.LocalDbConnectionName" value="BranchLocalDb" />
    <add key="BranchAgent.CentralApiBaseUrl" value="https://central.example.com" />
    <add key="BranchAgent.ApiTokenEnvironmentVariable" value="SATRIAH_BRANCH_SYNC_TOKEN_10" />
    <add key="BranchAgent.OutboxPath" value="%ProgramData%\Satriah\BranchSyncAgent\outbox" />
    <add key="BranchAgent.WatermarkPath" value="%ProgramData%\Satriah\BranchSyncAgent\watermark.json" />
    <add key="BranchAgent.LogPath" value="%ProgramData%\Satriah\BranchSyncAgent\logs" />
    <add key="BranchAgent.EnableSend" value="false" />
    <add key="BranchAgent.DryRunSend" value="true" />
    <add key="BranchAgent.RequireHttps" value="true" />
    <add key="BranchAgent.ConfigVersion" value="1.0" />
    <add key="BranchAgent.PayloadSchemaVersion" value="1.0" />
    <add key="BranchAgent.MaxRetryCount" value="12" />
    <add key="BranchAgent.MaxRetryDelaySeconds" value="3600" />
    <add key="BranchAgent.CentralPingPath" value="sync/api/branch/ping" />
    <add key="BranchAgent.InvoiceCandidateQuery" value="" />
  </appSettings>
</configuration>
