<!--
  Data Sync Pilot - central server config template.
  Do not commit or deploy real passwords in this file.
  Prefer Windows Integrated Security for the pilot admin database.
-->
<connectionStrings>
  <add name="SyncAdminConnection"
       connectionString="Data Source=YOUR_SQL_SERVER;Initial Catalog=SyncAdminPilot;Integrated Security=True;MultipleActiveResultSets=True;TrustServerCertificate=True"
       providerName="System.Data.SqlClient" />
</connectionStrings>

<appSettings>
  <!-- Token lookup uses this prefix plus BranchId, for example SATRIAH_BRANCH_SYNC_TOKEN_10. -->
  <add key="Sync.BranchApiTokenEnvironmentPrefix" value="SATRIAH_BRANCH_SYNC_TOKEN_" />

  <!-- Keep true. Branch API payloads must be signed with HMAC. -->
  <add key="Sync.BranchApiRequireSignature" value="true" />
</appSettings>
