@model IEnumerable<MyERP.Areas.Sync.ViewModels.AdminAuditRow>
@{
    Layout = "~/Areas/Sync/Views/Shared/_SyncLayout.cshtml";
    ViewBag.Title = "سجل العمليات";
}
<form method="get" class="sync-card sticky-filter compact">
    <label class="check-inline"><input type="checkbox" name="dangerousOnly" value="true" @(ViewBag.DangerousOnly == true ? "checked" : "") /> العمليات الحساسة فقط</label>
    <button class="btn btn-primary" type="submit">تحديث</button>
</form>
<div class="sync-card">
    <table class="sync-table modern">
        <thead><tr><th>التاريخ</th><th>المستخدم</th><th>IP</th><th>العملية</th><th>الصلاحية</th><th>SyncKey</th><th>النتيجة</th><th>السبب</th></tr></thead>
        <tbody>
        @foreach (var row in Model)
        {
            <tr><td>@(row.CreatedAt.HasValue ? row.CreatedAt.Value.ToString("yyyy-MM-dd HH:mm") : "")</td><td>@row.UserName</td><td>@row.IpAddress</td><td>@row.Operation</td><td>@row.Permission</td><td class="mono">@row.SyncKey</td><td><span class="status @row.Result">@row.Result</span></td><td>@row.Reason</td></tr>
        }
        </tbody>
    </table>
</div>
