@{
    Layout = "~/Areas/Sync/Views/Shared/_SyncLayout.cshtml";
    ViewBag.Title = "تعذر تحميل بيانات المزامنة";
}
<div class="sync-card friendly-error">
    <div class="card-title">@ViewBag.SyncErrorTitle</div>
    <p>@ViewBag.SyncErrorMessage</p>
    <ul class="sync-safe-list">
        <li>تأكد من وجود `SyncAdminConnection` أو إعداد `Sync.ConnectionStringName`.</li>
        <li>تأكد من أن مستخدم التطبيق لديه صلاحية قراءة على جداول `Sync_*`.</li>
        <li>لن تعرض هذه الصفحة نص الاتصال أو كلمة المرور.</li>
    </ul>
</div>
