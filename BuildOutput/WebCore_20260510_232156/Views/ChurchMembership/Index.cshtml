@model IEnumerable<MyERP.Models.ChurchMembership>
@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.ChurchMembership;
}

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <a class="btn btn-primary" style="margin-left: 0.5rem;" href="@Url.Action("Gallary")" role="button">@MyERP.Properties.Resources.ShowGallary </a>
                @*<a class="btn btn-bordered-purple" href="@Url.Action("MembersBirthDay")" role="button" style="margin-left: 0.5rem;">@MyERP.Properties.Resources.MembersBirthDay</a>
                    <a class="btn btn-bordered-purple" href="@Url.Action("MemberSpiritualNote")" role="button" style="margin-left: 0.5rem;">@MyERP.Properties.Resources.SpiritualNote</a>*@
                <a class="btn btn-info" href="@Url.Action("AddEdit")" role="button" style="float:left;">@MyERP.Properties.Resources.AddNew</a>
            </div>
            <div class="hed page-title"> @MyERP.Properties.Resources.ChurchMembership </div>
        </div>
    </div>
</div>

<div class="card-box">
    <div class="row">
        <div class="col-12">
            <div class="form-horizontal" role="form">
                <div class="form-group row">
                    <div class="col-xs-12 col-sm-6 col-lg-3">
                        <input type="text" class="form-control searchtxt" value="@Html.Raw(ViewBag.searchWord)" placeholder="@MyERP.Properties.Resources.Search">
                    </div>
                    <div class="col-xs-10 col-sm-4 col-lg-2">
                        @Html.DropDownList("AreaId", null, @MyERP.Properties.Resources.Area, htmlAttributes: new { @class = "form-control searchtxt" })
                    </div>
                    <div class="col-xs-10 col-sm-4 col-lg-2">
                        @Html.DropDownList("FatherId", null, @MyERP.Properties.Resources.Father, htmlAttributes: new { @class = "form-control searchtxt" })
                    </div>
                    <div class="col-xs-10 col-sm-4 col-lg-2">
                        <input type="checkbox" id="FamiliesOnly" @(ViewBag.FamiliesOnly == true ? "checked" : "") /> @MyERP.Properties.Resources.FamiliesOnly
                    </div>
                    <div class="col-xs-12 col-sm-3 col-lg-3">
                        <button type="button" class="btn btn-success btnSearch" onclick="searchWord = $('.searchtxt').val(); paging();">
                            <i class="fa fa-search"></i>
                        </button>
                        <button type="button" class="btn btn-info btnSearch" onclick="pageNo = 1; searchWord=''; paging();">
                            <i class="fe-refresh-ccw"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="table-responsive">
                <table class="table table-striped table-centered mb-0">
                    <thead>
                        <tr>

                            <th>
                                @MyERP.Properties.Resources.Code
                            </th>

                            <th>
                                @MyERP.Properties.Resources.ArName
                            </th>
                            <th>
                                @MyERP.Properties.Resources.Mobile
                            </th>
                            <th>
                                @MyERP.Properties.Resources.Area
                            </th>
                            <th>
                                @MyERP.Properties.Resources.Notes
                            </th>
                            <th>
                                @MyERP.Properties.Resources.Image
                            </th>
                            <th>
                                @MyERP.Properties.Resources.Active
                            </th>
                            <th>
                                @MyERP.Properties.Resources.Edit
                            </th>
                            <th>
                                @MyERP.Properties.Resources.Delete
                            </th>
                            <th>
                                @MyERP.Properties.Resources.Send
                            </th>
                            <th>
                                @MyERP.Properties.Resources.Link
                            </th>

                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <input hidden class="Id" value="@item.Id" />
                                    @Html.DisplayFor(modelItem => item.Code)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.ArName)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.Mobile)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.Area.ArName)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.Notes)
                                </td>
                                <td>

                                    @if (item.Image != null)
                                    {
                                        <a class="my_images" href="@(item.Image)" target="_blank">
                                            <img src="@(item.Image)" alt="" class="MemberImage" style="width:50px;height:50px;border-radius:50px;" />
                                        </a>
                                        @*<img src="@(item.Image)" alt="" class="MemberImage" style="width:50px;height:50px;border-radius:50px;" />*@
                                    }
                                    else
                                    {
                                        <a class="my_images" href="~/assets/images/users/Avatar_User.png" target="_blank">
                                            <img src="~/assets/images/users/Avatar_User.png" alt="" class="MemberImage" style="width:50px;height:50px;border-radius:50px;" />
                                        </a>
                                        @*<img src="~/assets/images/users/Avatar_User.png" alt="" class="MemberImage" style="width:50px;height:50px;border-radius:50px;" />*@
                                    }
                                </td>
                                <td>
                                    <input type="checkbox" data-plugin="switchery" data-color="#00b19d" data-secondary-color="#ED5565" data-size="small" @Html.Raw(item.IsActive == true ? "checked" : "") onchange="ActivateDeactivate(@item.Id)" />
                                </td>
                                @if (item.ParentId != null)
                                {
                                    <td>
                                        <a href="@Url.Action("AddEdit", "ChurchMembership", new { id = item.ParentId })" onclick="$('#preloader, #status').fadeIn();">
                                            <i class="fa fa-edit"></i>
                                        </a>
                                    </td>
                                }
                                else
                                {
                                    <td>
                                        <a href="@Url.Action("AddEdit", "ChurchMembership", new { id = item.Id })" onclick="$('#preloader, #status').fadeIn();">
                                            <i class="fa fa-edit"></i>
                                        </a>
                                    </td>
                                }
                                <td>
                                    <a href="javascript:void(0);" onclick="Delete(@item.Id)">
                                        <i class="fas fa-trash-alt"></i>
                                    </a>
                                </td>
                                <td>
                                    @*<a href="https://api.whatsapp.com/send?phone=@item.Mobile&text=@ViewBag.domainName/ChurchMembership/AddEdit?id=@item.Id" target="_blank">*@
                                 <a onclick="Send(@item.Id,'@item.Mobile')" href="javascript:void(0);">
                                    <i class="fab fa-whatsapp"></i>
                                    </a>
                                </td>
                                <td>
                                    <a href="javascript:void(0);" class="LinkBtn" data-toggle="modal">
                                        <i class="fa fa-link"></i>
                                    </a>
                                </td>

                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>

<div style="text-align:center;margin-bottom: 50px;">

    <div class="form-group row">
        <div class="col-sm-4">
            <select id="ShowByPage" class="form-control" style="width:70px;float:left;" onchange="paging()">
                <option value="10">10</option>
                <option value="30">30</option>
                <option value="50">50</option>
                <option value="100">100</option>
                <option value="200">200</option>
                <option value="@ViewBag.Count">@MyERP.Properties.Resources.All</option>
            </select>
            <span style="font-size:12px;float:right;"> @MyERP.Properties.Resources.NoOfResults : <span id="RowsCount">@ViewBag.Count</span></span>
        </div>
        <div class="col-sm-2">
            <lablel class="col-sm-8"> @MyERP.Properties.Resources.PageNo : </lablel>
        </div>
        <div class="col-sm-2">
            <select id="pagination" class="pagination form-control" style="width:70px;float:left;">
            </select>
        </div>
    </div>
</div>

<!-- Modal Section -->
<!----------------- Link Member Modal ----------------->
<div id="LinkMemberModal" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true" style="display: none;">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">@MyERP.Properties.Resources.Link</h4>
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">×</button>
            </div>
            <div class="modal-body p-4">
                <div class="form-horizontal needs-validation" role="form">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <input hidden Id="ItemId" />

                                <label for="ArName" class="control-label">@MyERP.Properties.Resources.Family</label>
                                @Html.DropDownList("FamilyId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })
                            </div>
                            <div class="invalid-feedback">
                                @MyERP.Properties.Resources.Required
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="Relative" class="control-label">@MyERP.Properties.Resources.Relative</label>
                                <input type="text" class="form-control" id="RelativePopUp" placeholder="@MyERP.Properties.Resources.Relative">
                            </div>
                            <div class="invalid-feedback">
                                @MyERP.Properties.Resources.Required
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary waves-effect" data-dismiss="modal">@MyERP.Properties.Resources.Close</button>
                <button type="button" class="btn btn-info waves-effect waves-light" onclick="LinkMember()">@MyERP.Properties.Resources.Link</button>
            </div>
        </div>
    </div>
</div>
<!----------------- End Of Link Member Modal ----------------->
<!-------------------------------------- End Of Modal Section -------------------------------------->

<script>
     var pageNo = 1;
    var searchWord = '@Html.Raw(ViewBag.searchWord)';
    $('#ShowByPage').val(@ViewBag.wantedRowsNo);
    function paging() {
        var link = '/ChurchMembership/Index?' + 'pageIndex=' + pageNo + '&wantedRowsNo=' + $('#ShowByPage').val() + '&searchWord=' + searchWord + '&AreaId=' + $('#AreaId').val() + '&FatherId=' + $('#FatherId').val() + '&FamiliesOnly=' + $('#FamiliesOnly').prop('checked') + '&IsSearch=true';
        window.location.replace(link);
    }
    function setPages() {
        var count =@ViewBag.Count;
        for (var i = 0; i < Math.ceil(count / $('#ShowByPage').val()); i++)
   $('#pagination').append('<option onchange="pageNo=' + (i + 1) + '; paging();" id="pg' + (i + 1) + '">' + (i + 1) + '</option>');
    }
    setPages();
   $('#pg' +@ViewBag.PageIndex).attr('selected', 'selected')
    $('#pagination').on('change', function () {
        pageNo = $('#pagination').val();
         paging();
    })
    function Delete(id) {
        if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToDelete')) {
            $('#preloader, #status').fadeIn();
            $.ajax(
                {
                    url: '/ChurchMembership/Delete',
                    type: 'POST',
                    data: {
                        "Id": id,
                    },
                    error: function (e) {
                    },
                    success: function (r) {
                        if (r == 'true') {
                            window.location.reload();
                        }
                    }
                });
        }
    }
    function ActivateDeactivate(id) {
        $.ajax({
            url: '/ChurchMembership/ActivateDeactivate',
            type: 'POST',
            data: {
                "Id": id,
            },
            error: function (e) {
                alert('@MyERP.Properties.Resources.TheActivationStateNotChanged')
            },
            success: function (r) {
                if (r == 'true') {
                    alert('@MyERP.Properties.Resources.TheActivationStateHasChanged')
                }
            }
        });
    }

    function LinkMember() {
        let valid = true;
        let id = $('#ItemId').val();
        if (!$('#FamilyId').val()) {
            valid = false;
        }
        if ($('#LinkMemberModal').find(".form-control:invalid").length > 0) {
            $('#LinkMemberModal').find('.form-horizontal').addClass('was-validated');
                $('html, body').animate({
                    scrollTop: $(".form-control:invalid").eq(0).offset().top - 80
                }, 500);
            valid = false;
        }
        else {
            if (valid == true) {
                @*if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToDelete')) {*@
                    $('#preloader, #status').fadeIn();
                    $.ajax(
                        {
                            url: '/ChurchMembership/LinkMember?FamilyId=' + $('#FamilyId').val() + '&Relative=' + $('#RelativePopUp').val(),
                            type: 'POST',
                            data: {
                                "Id": id,
                            },
                            error: function (e) {
                            },
                            success: function (r) {
                                if (r == 'true') {
                                    window.location.reload();
                                    $('#RelativePopUp').val('');
                                    $('#FamilyId').prop('selectedIndex', 0);
                                    ; $('#FamilyId').select2();
                                }
                            }
                        });
                @*}*@
                $('#preloader, #status').fadeOut();
                $('#LinkMemberModal').modal("hide");
            }
        }
    }
    $(document).on('click', '.LinkBtn', function () {
        $('#LinkMemberModal').modal("show");
        let id = $(this).closest('tr').find('.Id').val();
        $('#ItemId').val(id);
    });

     function Send(id, mobile) {
        if (mobile != null) {
            var Checker = mobile.toString().slice(0, 3);
            if (Checker == 10 || Checker == 11 || Checker == 12 || Checker == 15) {
                mobile = "+2" + mobile
            }
        }
         var link = "https://api.whatsapp.com/send?phone=" + mobile + "&text=" + '@ViewBag.domainName' + "/ChurchMembership/AddEdit?id=" + id;
            window.open(link, "_blank");
    }

</script>