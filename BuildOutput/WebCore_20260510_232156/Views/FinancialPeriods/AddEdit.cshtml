</div>



<script>
            //--------------- Variables Declarations -------------------//
            //*********************************************************//
            //--------------- Ready Function -------------------//
            //*********************************************************//
            //--------------- Event Functions -------------------//
            //*********************************************************//
            //--------------- Other Functions -------------------//
    function getDays(year, month) {
        return new Date(year, month, 0).getDate();
    }

    function ShowDetails() {
        if ($('#PeriodStart').val() && $('#PeriodEnd').val()) {
            $('#FinancialPeriods').empty();
            var PeriodStartDate = new Date($('#PeriodStart').val());
            var PeriodEndDate = new Date($('#PeriodEnd').val());
            var months;
                months = (PeriodEndDate.getFullYear() - PeriodStartDate.getFullYear()) * 12;
                months += PeriodStartDate.getMonth();
                months += PeriodEndDate.getMonth();
                months = months <= 0 ? 0 : months;
            var Start;
            var End;
            for (var i = 0; i <= months; i++) {
                PeriodStartDate.setMonth(PeriodStartDate.getMonth() + 1);
                PeriodEndDate.setMonth(PeriodStartDate.getMonth() + 1);
                PeriodEndDate.setFullYear(PeriodStartDate.getFullYear());
                if (PeriodStartDate.getMonth() == 0) {
                    Start = (PeriodStartDate.getFullYear()-1) + "-" + "12" + "-" + zeroPadded(PeriodStartDate.getDate());
                    End = (PeriodStartDate.getFullYear()-1) + "-" + "12" + "-" + getDays(PeriodStartDate.getFullYear(), PeriodStartDate.getMonth() + 1) /*zeroPadded(PeriodEndDate.getDate())*/;
                }
                else if (PeriodStartDate.getMonth() < 12) {

                    Start = PeriodStartDate.getFullYear() + "-" + zeroPadded(PeriodStartDate.getMonth()) + "-" + zeroPadded(PeriodStartDate.getDate());
                    End = PeriodStartDate.getFullYear() + "-" + zeroPadded(PeriodStartDate.getMonth()) + "-" + getDays(PeriodStartDate.getFullYear(), PeriodStartDate.getMonth())/*zeroPadded(PeriodEndDate.getDate())*/;
                }
                let tr = '<tr><td><input hidden class="PostingStatus" type="checkbox"/><input hidden class="LockStatus" type="checkbox" /><input hidden  class="Opened" type="checkbox" /><input hidden class="Closed" type="checkbox" /><input hidden class="Status"/><input hidden class="IsActive" type="checkbox"/>'+
                    (i + 1) + '</label></td><td><label class="PeriodStart control-label">' +
                    Start + '</label> </td><td><label class="PeriodEnd control-label">' +
                    End + '</label></td><td><button type="button" class="btn btn-success opened" onclick="OpenPeriod(null)" disabled>@MyERP.Properties.Resources.OpenPeriod</button></td><td><button type="button" class="btn btn-danger closeed" onclick="ClosePeriod(null)" disabled>@MyERP.Properties.Resources.ClosePeriod</button></td></tr>';
                $('#FinancialPeriods').append(tr);
            }
        }
        else {
            alert('@MyERP.Properties.Resources.PeriodStart & @MyERP.Properties.Resources.PeriodEnd @MyERP.Properties.Resources.Required !')
        }
    }

    function convertToJavaScriptDate(value) {
        if (value === null)
            return null;
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        return ((dt.getMonth() + 1 + "/" + dt.getDate() + "/" + dt.getFullYear()));
    }

    function zeroPadded(val) {
        if (val >= 10)
            return val;
        else
            return '0' + val;
    }

    function ClosePeriod(id, MainId) {
        if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToClosePeriod')) {
            $('.closeed').closest("tr").find('.opend').prop("disabled", true);
            $('#preloader, #status').fadeIn();
            $.ajax(
                {
                    url: '/FinancialPeriods/ClosePeriod',
                    type: 'POST',
                    data: {
                        "DetailsId": id,
                        "MainId": MainId
                    },
                    error: function (e) {
                    },
                    success: function (r) {
                        if (r == 'True') {
                            window.location.reload();
                            $('#preloader, #status').fadeOut();
                        }
                        else {
                            alert("@MyERP.Properties.Resources.YouShouldClosePreviousPeriodFirst");
                            $('#preloader, #status').fadeOut();
                        }
                    }
                });
        }
    }

    function Cancel(id, MainId) {
        if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToCanclePeriodClosing')) {

            $('#preloader, #status').fadeIn();
            $.ajax(
                {
                    url: '/FinancialPeriods/ReOpen',
                    type: 'POST',
                    data: {
                        "DetailsId": id,
                        "MainId": MainId
                    },
                    error: function (e) {
                    },
                    success: function (r) {
                       // console.log(r)
                        if (r == 'True') {
                            window.location.reload();
                            $('#preloader, #status').fadeOut();
                        }
                        else {
                            alert("@MyERP.Properties.Resources.YouShouldCancelPeriodClosingNextPeriodFirst");
                            $('#preloader, #status').fadeOut();
                        }
                    }
                });
        }
    }

    function OpenPeriod(id, MainId) {
        if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToOpenPeriod')) {
            $('#preloader, #status').fadeIn();
            $.ajax(
                {
                    url: '/FinancialPeriods/OpenPeriod',
                    type: 'POST',
                    data: {
                        "DetailsId": id,
                        "MainId": MainId
                    },
                    error: function (e) {

                    },
                    success: function (r) {
                       // console.log(r)
                        if (r == 'True') {
                            window.location.reload();
                            $('#preloader, #status').fadeOut();

                        }
                        else {
                            alert("@MyERP.Properties.Resources.YouShouldOpenPreviousPeriodFirst");
                            $('#preloader, #status').fadeOut();
                        }
                    }
                });
        }
    }
//*****************************************************************************************************************//
    function addEdit(n) {
        let valid = true;
        if ($(".form-control:invalid").length > 0) {
            console.log($(".form-control:invalid"));
            $('.form-horizontal').addClass('was-validated');
            $('html, body').animate({
                scrollTop: $(".form-control:invalid").eq(0).offset().top - 100
            }, 500);
            valid = false;
        }
        else {
            var FinancialPeriods = [];
            $('#FinancialPeriods tr').each(function () {
                var td = $(this);
                var FinancialPeriod = {
                    FinancialPeriodMasterId: $('#Id').val(),
                    PeriodNo: td.find('.PeriodNo').text(),
                    PeriodStart: td.find('.PeriodStart').text(),
                    PeriodEnd: td.find('.PeriodEnd').text(),
                    IsActive: td.find('.IsActive').prop('checked'),
                    PostingStatus: td.find('.PostingStatus').prop('checked'),
                    LockStatus: td.find('.LockStatus').prop('checked'),
                    Opened: td.find('.Opened').prop('checked'),
                    Closed: $('#Id').val() > 0 ? td.find('.Closed').prop('checked') : null,
                    Status: td.find('.Status').val() == null || td.find('.Status').val() == "" ? "NotActive" : td.find('.Status').val(),
                };
                FinancialPeriods.push(FinancialPeriod);
            });
            //-------------------------------------------//
            var FinancialPeriodMaster =
            {
                Id: $('#Id').val(),
                ArName: $('#ArName').val(),
                EnName: $('#EnName').val(),
                PeriodStart: $('#PeriodStart').val(),
                PeriodEnd: $('#PeriodEnd').val(),
                UserId: $('#UserId').val(),
                IsActive: $('#IsActive').val(),
                IsDeleted: $('#IsDeleted').val(),
                PostingStatus: $('#PostingStatus').val(),
                LockStatus: $('#LockStatus').val(),
                Opened: $('#Opened').val(),
                Closed: $('#Closed').val(),
                Status: $('#Status').val(),
                FinancialPeriods: FinancialPeriods,
            };
            if ($('#FinancialPeriods tr').length == 0) {
                valid = false;
                alert('@MyERP.Properties.Resources.AllDetailsRequired');
            }
            if (valid == true && confirm('@MyERP.Properties.Resources.AreYouSureYouWantToSave'))
                $.ajax({
                    type: "POST",
                    url: "/FinancialPeriods/AddEdit",
                    data: FinancialPeriodMaster,
                    success: function (r) {
                        if (r.success == "true") {
                            if (n == "new") {
                                window.location.replace("/FinancialPeriods/AddEdit");
                            } else {
                                window.location.replace("/FinancialPeriods");
                            }
                        }
                        else
                            alert('@MyERP.Properties.Resources.NotSaved');
                        $('#preloader, #status').fadeOut();
                    },
                    error: function (r) {
                        $('#preloader, #status').fadeOut();
                        alert('@MyERP.Properties.Resources.NotSaved');
                    }
                });
        }
    }


</script>

