                                            @*@Html.EditorFor(model => model.PeriodEnd, new { htmlAttributes = new { @class = "form-control", @type = "datetime-local", required = "required" } })*@
                                            <input id="PeriodEnd" name="PeriodEnd" class="form-control" type="datetime-local" required />
                                        }
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>


                                <div class="row">
                                    <div class="col-sm-offset-2">
                                        <button type="button" onclick="ShowDetails()" class="btn btn-success">
                                            @MyERP.Properties.Resources.View
                                        </button>
                                        @if (Model != null)
                                        {
                                            if (Model.Closed == null || Model.Opened == null || Model.Status == null)
                                            {
                                                <button type="button" onclick="ClosePeriod(null,@Model.Id)" class="btn btn-primary">
                                                    @MyERP.Properties.Resources.GeneralClosure
                                                </button>
                                            }
                                            else if (Model.IsActive == true)
                                            {

                                                <button type="button" class="btn btn-success opened" onclick="OpenPeriod(null,@Model.Id)" disabled>
                                                    @MyERP.Properties.Resources.OpenPeriod
                                                </button>
                                                <button type="button" class="btn btn-danger closeed" onclick="ClosePeriod(null,@Model.Id)">
                                                    @MyERP.Properties.Resources.ClosePeriod
                                                </button>
                                            }
                                            else if (Model.LockStatus == true)
                                            {
                                                <button type="button" class="btn btn-success opened" onclick="OpenPeriod(null,@Model.Id)" disabled>
                                                    @MyERP.Properties.Resources.OpenPeriod
                                                </button>
                                                <button type="button" class="btn btn-danger closeed" onclick="Cancel(null,@Model.Id)">
                                                    @MyERP.Properties.Resources.ClosePeriod
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="button" class="btn btn-success opened" onclick="OpenPeriod(null,@Model.Id)">
                                                    @MyERP.Properties.Resources.OpenPeriod
                                                </button>
                                                <button type="button" class="btn btn-danger closed" onclick="ClosePeriod(null,@Model.Id)" disabled>
                                                    @MyERP.Properties.Resources.Closed
                                                </button>
                                            }
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
