                                                    <input hidden class="LockStatus" type="checkbox" @Html.Raw(item.LockStatus == true ? "checked" : "") @*value="@item.LockStatus"*@ />
                                                    <input hidden class="Opened" type="checkbox" @Html.Raw(item.Opened == true ? "checked" : "") @*value="@item.Opened"*@ />
                                                    <input hidden class="Closed" type="checkbox" @Html.Raw(item.Closed == true ? "checked" : "") @*value="@item.Closed"*@ />
                                                    <input hidden class="Status" value="@item.Status" />
                                                    <input hidden class="IsActive" type="checkbox" @Html.Raw(item.IsActive == true ? "checked" : "") @*value="@item.IsActive"*@ />
                                                    <label class="PeriodNo control-label">@item.PeriodNo</label>
                                                </td>

                                                <td>
                                                    <label class="PeriodStart control-label">@item.PeriodStart</label>
                                                </td>
                                                <td>
                                                    <label class="PeriodEnd control-label">@item.PeriodEnd</label>
                                                </td>
                                                <td>
                                                    <button type="button" class="btn btn-success opened" onclick="OpenPeriod(@item.Id,@Model.Id)" @Html.Raw(item.Opened == true ? "disabled" : "")>
                                                        @MyERP.Properties.Resources.OpenPeriod
                                                    </button>
                                                </td>
