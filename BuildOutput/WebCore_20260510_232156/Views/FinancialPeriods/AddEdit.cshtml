                                        @Html.HiddenFor(model => model.PostingStatus)
                                        @Html.HiddenFor(model => model.LockStatus)
                                        @Html.HiddenFor(model => model.Opened)
                                        @Html.HiddenFor(model => model.Closed)
                                        @Html.HiddenFor(model => model.Status)
                                    }

                                    <label for="inputtext3" class="col-sm-2 control-label"> @MyERP.Properties.Resources.ArName</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.ArName, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.ArName, required = "required" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.ArNameRequired
                                        </div>
                                    </div>

                                    <label for="inputtext3" class="col-sm-2 control-label"> @MyERP.Properties.Resources.EnName</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.EnName, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.EnName } })
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="inputtext3" class="col-sm-2 control-label"> @MyERP.Properties.Resources.PeriodStart</label>
                                    <div class="col-sm-4">
                                        @if (Model != null && Model.PeriodStart != null)
                                        {
                                            <input id="PeriodStart" name="PeriodStart" class="form-control" type="datetime-local" value="@ViewBag.PeriodStart" required />
                                        }
                                        else
                                        {
                                            @*@Html.EditorFor(model => model.PeriodStart, new { htmlAttributes = new { @class = "form-control", @type = "datetime-local", required = "required" } })*@
                                            <input id="PeriodStart" name="PeriodStart" class="form-control" type="datetime-local" required />
