                                                @*@if (item.IsActive == true)
                                                    {
                                                        <td>
                                                            <button type="button" class="btn btn-success opened" onclick="OpenPeriod(@item.Id,@Model.Id)">
                                                                @MyERP.Properties.Resources.OpenPeriod
                                                            </button>
                                                        </td>
                                                        <td>
                                                            <button type="button" class="btn btn-danger closed" onclick="ClosePeriod(@item.Id,@Model.Id)" disabled>
                                                                @MyERP.Properties.Resources.Closed
                                                            </button>
                                                        </td>
                                                    }
                                                    else if (item.LockStatus == true)
                                                    {
                                                        <td>
