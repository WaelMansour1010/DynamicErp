                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>

                                    <label for="inputtext3" class="col-sm-2 control-label">@MyERP.Properties.Resources.PeriodEnd</label>
                                    <div class="col-sm-4">
                                        @if (Model != null && Model.PeriodEnd != null)
                                        {
                                            <input id="PeriodEnd" name="PeriodEnd" class="form-control" type="datetime-local" value="@ViewBag.PeriodEnd" required />
                                        }
                                        else
