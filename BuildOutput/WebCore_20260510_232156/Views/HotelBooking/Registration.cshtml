    function getPosCustomers() {
        $.get('/Helper/GetCustomers').done(function (r) {
            posCustomers = r;
        });
    }
    function convertToJavaScriptDate(value) {
        if (value === null)
            return null;
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        return ((dt.getMonth() + 1 + "/" + dt.getDate() + "/" + dt.getFullYear()));
    }
    function showBookingDetails() {
        $.get('/HotelBooking/showBookingDetails?RoomTypeId=' + $("#RoomTypeId").val() + '&From=' + $("#From").val() + '&To=' + $("#To").val()).done(function (r) {
            if (r) {
                r.RegistrationDate = r.RegistrationDate != null ? convertToJavaScriptDate(r.RegistrationDate) : null;
                r.BookingStartDate = r.BookingStartDate != null ? convertToJavaScriptDate(r.BookingStartDate) : null;
                r.BookingEndDate = r.BookingEndDate != null ? convertToJavaScriptDate(r.BookingEndDate) : null;
                r.RoomTypeArName = r.RoomTypeArName != null ? r.RoomTypeArName : "";
                r.RequiredAmount = r.RequiredAmount != null ? r.RequiredAmount : "";
                r.DocumentNumber = r.DocumentNumber != null ? r.DocumentNumber.replaceAll("-",'') : "";
                r.Notes = r.Notes != null ? r.Notes : "";
                Booking = r;

                let Div = ' <div class="form-group row"><div class="col-sm-3"><label id="Price">'+
                                                r.Price +'</label></div > <label class="col-sm-3"> : @MyERP.Properties.Resources.Price  </label><div class="col-sm-3"><label id="RoomCode">'+
                                                r.RoomTypeArName +'</label></div > <label class="col-sm-3"> : @MyERP.Properties.Resources.Room  </label></div><div class="form-group row" > <div class="col-sm-3"><label id="BookingEndDate">' +
                                            r.BookingEndDate+ '</label></div> <label class="col-sm-3">: @MyERP.Properties.Resources.To</label><div class="col-sm-3"><label id = "BookingStartDate" > ' +
                r.BookingStartDate + ' </label></div><label class="col-sm-3">: @MyERP.Properties.Resources.From</label></div><div class="form-group row"><div class="col-sm-3"><label id="RequiredAmount">'+
                    r.Total + '  </label></div><label class="col-sm-3"> : @MyERP.Properties.Resources.Total </label><div class="col-sm-3"><label id="NightsNumber">' +
                    r.NightsNumber + '  </label></div><label class="col-sm-3">: @MyERP.Properties.Resources.NightsNumber</label></div><div class="form-group row" ><div class="col-sm-2"><label id="Remain"> ' +
                    r.RequiredAmount + ' </label></div><label class="col-sm-4">: @MyERP.Properties.Resources.TotalAfterTaxes </label> <div class="col-sm-3"><label id="Tax">' +
                    r.Tax + '</label></div><label class="col-sm-3">: @MyERP.Properties.Resources.Tax</label> </div><div class="form-group row" ><div class="col-sm-3"><label id="Paid">'+
                    r.Paid + '</label></div><label class="col-sm-3">: @MyERP.Properties.Resources.Paid</label><div class="col-sm-3"><label id="Remain"> ' + r.Remain + ' </label></div><label class="col-sm-3">: @MyERP.Properties.Resources.Remain </label> </div>';
                $('#BookingDetailsDiv').append(Div)
            }
        });

    }
    function AddCustomer(onlinePaymentId) {
        let valid = true;
        if ($(".form-control:invalid").length > 0) {
            console.log($(".form-control:invalid"));
            $('.form-horizontal').addClass('was-validated');
            $('html, body').animate({
                scrollTop: $(".form-control:invalid").eq(0).offset().top - 100
            }, 500);
            valid = false;
        }
        else {
            $('#AddCustomerBtnDiv').hide();
            $('#SpinnerDiv').show();

            $('#preloader, #status').fadeIn();
            let customer = posCustomers.filter(function (i) { return i.NationalId == $('#NationalId').val() })[0];
            if (customer != null) {
               // alert("العميل موجود من قبل")
                var CustomerId = customer.Id;
                var ArName = customer.ArName.split(/ (.*)/s)[0]
                var LastName = customer.ArName.split(/ (.*)/s)[1]
                $("#FirstName").val(ArName)
                $("#LastName").val(LastName)
                //if (customer.Email != null) {
                //    $('#Email').val(customer.Email)
                //}
                $('#CustomerId').val(CustomerId)
                $('#Mobile').val(customer.Mobile)
                $('#NationalId').val(customer.NationalId)
                if (valid /*& confirm('استكمال التسجيل ؟')*/) {
                    $.get('/HotelBooking/CompleteRegistration?CustomerId=' + $('#CustomerId').val() + '&RoomTypeId=' + $("#RoomTypeId").val() + '&From=' + $("#From").val() + '&To=' + $("#To").val() + '&Email=' + $("#Email").val() + '&PaymentMethodId=' + $("#PaymentMethodId").val() + '&OnlinePaymentId=' + onlinePaymentId).done(function (roomBooking) {
                        if (roomBooking != null) {
                            roomBooking.RegistrationDate = roomBooking.RegistrationDate != null ? convertToJavaScriptDate(roomBooking.RegistrationDate) : null;
                            roomBooking.BookingStartDate = roomBooking.BookingStartDate != null ? convertToJavaScriptDate(roomBooking.BookingStartDate) : null;
                            roomBooking.BookingEndDate = roomBooking.BookingEndDate != null ? convertToJavaScriptDate(roomBooking.BookingEndDate) : null;
                            $.ajax({
                                type: "POST", contentType: "application/json",
                                url: "/RoomBooking/AddEdit",
                                data: JSON.stringify(roomBooking),
                                success: function (r) {
                                    if (r.success == true) {
                                            alert('تم الحجز بنجاح , سيتم التواصل معكم')
                                            window.location.replace("/HotelBooking");
                                    }
                                    else {
                                        alert('لم يتم استكمال الحجز , برجاء المحاولة مرة اخري')
                                    }
                                    $('#preloader, #status').fadeOut();
                                },
                                error: function (r) {
                                    alert('لم يتم استكمال الحجز , برجاء المحاولة مرة اخري')
                                    $('#preloader, #status').fadeOut();
                                }
                            });
                        }
                    });
                }
            }
            else {
                if (valid) {
                    $.ajax(
                        {
                            url: '/Customers/AddEdit', contentType: "application/json",
                            type: 'POST',
                            data: JSON.stringify({
                                Id: 0,
                                Code: 1,
                                ArName: $("#FirstName").val() + " " + $("#LastName").val(),
                                EnName: $('#PosCustomerEnName').val(),
                                Email: $('#Email').val(),
                                Mobile: $('#Mobile').val(),
                                NationalId: $('#NationalId').val(),
                                CustomersGroupId: 1,
                            }),
                            error: function (e) {
                                $('#preloader, #status').fadeOut();
                            },
                            success: function (customer) {
                                if (valid/* & confirm('استكمال التسجيل ؟')*/) {
                                    $.get('/HotelBooking/CompleteRegistration?CustomerId=' + customer.Id + '&RoomTypeId=' + $("#RoomTypeId").val() + '&From=' + $("#From").val() + '&To=' + $("#To").val() + '&Email=' + $("#Email").val() + '&PaymentMethodId=' + $("#PaymentMethodId").val() + '&OnlinePaymentId=' + onlinePaymentId).done(function (roomBooking) {
                                        if (roomBooking != null) {
                                            roomBooking.RegistrationDate = roomBooking.RegistrationDate != null ? convertToJavaScriptDate(roomBooking.RegistrationDate) : null;
                                            roomBooking.BookingStartDate = roomBooking.BookingStartDate != null ? convertToJavaScriptDate(roomBooking.BookingStartDate) : null;
                                            roomBooking.BookingEndDate = roomBooking.BookingEndDate != null ? convertToJavaScriptDate(roomBooking.BookingEndDate) : null;
                                            $.ajax({
                                                type: "POST", contentType: "application/json",
                                                url: "/RoomBooking/AddEdit",
                                                data: JSON.stringify(roomBooking),
                                                success: function (r) {
                                                    if (r.success == true) {
                                                    alert('تم الحجز بنجاح , سيتم التواصل معكم')
                                               window.location.replace("/HotelBooking");
                                                    }
                                                    else {
                                                        alert('لم يتم استكمال الحجز , برجاء المحاولة مرة اخري')
                                                    }
                                                    $('#preloader, #status').fadeOut();
                                                },
                                                error: function (r) {
                                                    alert('لم يتم استكمال الحجز , برجاء المحاولة مرة اخري')
                                                    $('#preloader, #status').fadeOut();
                                                }
                                            });
                                        }
                                    });
                                }

                                $('#preloader, #status').fadeOut();

                            }
                        });
                }
            }
        }
    }

