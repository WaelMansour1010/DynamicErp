    function ChangeCurrency() {
        fetch("https://api.currencyfreaks.com/latest?apikey=d92bccc883f64bde8f65ddef4f11329c")
            .then((result) => {
                let myData = result.json();
                return myData;
            })
            .then((currency) => {
                let amount = Booking.Remain;
                var CurrencyRateInSAR = parseFloat(currency.rates["SAR"]);
                CurrencyRateInSAR = CurrencyRateInSAR.toFixed(2);
                var CurrencyInSAR = Math.round(amount / CurrencyRateInSAR);
                Booking.Remain = CurrencyInSAR;
                //console.log("CurrencyRateInSAR : ", CurrencyRateInSAR, " ,CurrencyInSAR : ", CurrencyInSAR);
               // console.log("Booking.Remain : ", Booking.Remain);

            });
    }

