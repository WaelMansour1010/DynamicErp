    function CalculateValueAddedTaxes(e) {
        if ($(e).closest('tr').next('tr').find('.IncludeValueAddedTax').val() == 'true') {
            var txtDebit = $(e).closest('tr').find('.txtDebit').inputmask('unmaskedvalue');
            var txtCredit = $(e).closest('tr').find('.txtCredit').inputmask('unmaskedvalue');
            var TaxDebit = txtDebit * taxPercentage;
            var TaxCredit = txtCredit * taxPercentage;
            $(e).closest('tr').next('tr').find('.txtDebit').val(TaxDebit);
            $(e).closest('tr').next('tr').find('.txtCredit').val(TaxCredit);
        }

        calculateTotalDebit();
        calculateTotalCredit();
        calculateDifference();
    }

    function CheckValueAddedTaxes(e) {
        var AccountId = $(e).val();
        var $sourceRow = $(e).closest('tr');
        var departmentId = $sourceRow.find('.DetailDepartmentId').val() || $('#DepartmentId').val();
        if (departmentId > 0) {
            $.get("/JournalEntries/CheckValueAddedTaxes?AccountId=" + AccountId + "&DepartmentId=" + departmentId).done(function (r) {
                var txtDebit = $sourceRow.find('.txtDebit').inputmask('unmaskedvalue');
                var txtCredit = $sourceRow.find('.txtCredit').inputmask('unmaskedvalue');
                var TaxDebit = txtDebit * taxPercentage;
                var TaxCredit = txtCredit * taxPercentage;

                if (r.IncludeValueAddedTax == true) {
                    var $vatRow = $sourceRow.next('tr');
                    if (!$vatRow.length || $vatRow.find('.IncludeValueAddedTax').val() != 'true') {
                        $vatRow = appendDetailRowAfter($sourceRow, {
                            includeVat: true,
                            departmentId: departmentId,
                            debit: TaxDebit,
                            credit: TaxCredit
                        });
                    } else {
                        $vatRow.find('.txtDebit').val(TaxDebit);
                        $vatRow.find('.txtCredit').val(TaxCredit);
                    }

                    fillAccountSelect($vatRow, r.TaxAccount ? r.TaxAccount.TaxAccountId : '');
                    setRowAccountCode($vatRow, r.TaxAccount ? r.TaxAccount.TaxAccountId : '');
                    if (UseCostCenter == 'True') {
                        fillCostCentersForRow($vatRow);
                    }
                    $vatRow.find('.IncludeValueAddedTax').val('true');
                    $vatRow.find('.AccountId').val(r.TaxAccount ? r.TaxAccount.TaxAccountId : '');
                    $vatRow.find('.DetailDepartmentId').val(departmentId).trigger('change.select2');
                }
                else {
                    if ($sourceRow.next('tr').find('.IncludeValueAddedTax').val() == 'true') {
                        $sourceRow.next('tr').remove();
                    }
                }

                ensureTrailingBlankRow();
                calculateTotalDebit();
                calculateTotalCredit();
                calculateDifference();
            });
        }
        else {
             Swal.fire({
                    title: '@MyERP.Properties.Resources.DepartmentRequired',
                    text: " ",
                    icon: 'info',
                    showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    confirmButtonColor: '#3085d6'
            });
        }
    }


