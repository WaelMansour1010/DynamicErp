@model MyERP.Models.JournalEntry
@{
    UICulture = Session["lang"] != null?Session["lang"].ToString():"ar";
    ViewBag.Title = MyERP.Properties.Resources.JournalEntries;
}
<script src="~/Scripts/SaveAndNew.js"></script>

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                @if (Model.Id > 0)
                {
                    if (Model.IsDeleted == false)
                    {
                        if (ViewBag.Previous > 0)
                        {
                            <a href="@Url.Action("AddEdit",new {id= ViewBag.First })" class="btn btn-info">@MyERP.Properties.Resources.First</a>
                            <a href="@Url.Action("AddEdit",new { id=ViewBag.Previous })" class=" btn btn-info">&#8250;</a>
                        }
                        if (ViewBag.Next > 0)
                        {
                            <a href="@Url.Action("AddEdit",new { id=ViewBag.Next })" class="btn btn-info">&#8249;</a>
                            <a href="@Url.Action("AddEdit",new {id=ViewBag.Last })" class="btn btn-info">@MyERP.Properties.Resources.Last</a>
                        }
                    }
                }
                <a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
            </div>
            <div class="hed page-title">@MyERP.Properties.Resources.JournalEntryDetails:</div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="form-horizontal needs-validation" role="form" id="form">
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">
                                <input type="hidden" id="Id" value="@Model.Id" />

                                <div class="form-group row">
                                    <label class="col-sm-1 control-label">@MyERP.Properties.Resources.VoucherNo</label>
                                    <div class="col-sm-5">
                                        <input type="text" class="form-control" name="DocumentNumber" value="@Model.DocumentNumber" id="DocumentNumber" placeholder=@MyERP.Properties.Resources.VoucherNo disabled required hidden>
                                        <input id="DocumentNumbers" class="form-control" placeholder=@MyERP.Properties.Resources.Code required readonly />
                                    </div>
                                    <label class="col-sm-1 control-label">@MyERP.Properties.Resources.Date </label>
                                    <div class="col-sm-5">
                                        <input type="datetime-local" class="form-control" name="Date" id="Date" value="@ViewBag.Date" required>
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>

                                </div>
                                <div class="form-group row">
                                    <label class="col-sm-1 control-label">@MyERP.Properties.Resources.Branch</label>
                                    <div class="col-sm-5">
                                        @Html.DropDownList("DepartmentId", null, null, htmlAttributes: new { @class = "form-control", id = "DepartmentId", @required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>

                                    </div>

                                </div>

                                @if (Model.SourceId != null && Model.SourcePageId != null)
                                {
                                    <div class="form-group row">
                                        <label class="col-sm-1 control-label">@MyERP.Properties.Resources.MainDoc</label>
                                        <div class="col-sm-5">
                                            <input type="text" class="form-control" value="@Model.SystemPage.ArName" name="SourcePageId" id="SourcePageId" placeholder=@MyERP.Properties.Resources.MainDoc disabled>
                                        </div>
                                        <label class="col-sm-1 control-label">@MyERP.Properties.Resources.MainDocNo</label>
                                        <div class="col-sm-5">
                                            @*<input type="text" class="form-control" name="SourceId" value="@Model.SourceId" id="SourceId" placeholder=@MyERP.Properties.Resources.MainDocNo disabled>*@
                                            <input type="text" class="form-control" name="SourceId" value="@ViewBag.SourceId" id="SourceId" placeholder=@MyERP.Properties.Resources.MainDocNo disabled>
                                        </div>
                                    </div>
                                }

                                <div class="form-group row">
                                    <label class="col-sm-1 control-label">@MyERP.Properties.Resources.Notes</label>
                                    <div class="col-sm-5">
                                        @Html.TextAreaFor(model => model.Notes, htmlAttributes: new { @class = "form-control", placeholder = @MyERP.Properties.Resources.Notes })
                                    </div>
                                    <label class="col-sm-1 control-label">@MyERP.Properties.Resources.Deported</label>
                                    <div class="col-sm-5">
                                        @if (Model.IsPosted == true)
                                        {
                                            <input type="checkbox" class="form-control" id="IsPosted" name="IsPosted" style="width:15px;" checked>
                                        }
                                        else
                                        {
                                            <input type="checkbox" class="form-control" id="IsPosted" name="IsPosted" style="width:15px;">
                                        }

                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">
                                <div class="subHid header-title">@MyERP.Properties.Resources.JournalEntryDetails :</div>
                                <div class="form-horizontal needs-validation" role="form">
                                    <div class="table-responsive">
                                        <table class="table table-centered mb-0" dir="rtl">
                                            <thead>
                                                <tr>
                                                    <th>@MyERP.Properties.Resources.Department</th>
                                                    <th>@MyERP.Properties.Resources.AccountNo</th>
                                                    <th>@MyERP.Properties.Resources.Account</th>
                                                    <th>@MyERP.Properties.Resources.Debit</th>
                                                    <th>@MyERP.Properties.Resources.Credit</th>
                                                    <th>@MyERP.Properties.Resources.Explanation</th>
                                                    <th style="width:220px;">Vendor</th>
                                                    @if (ViewBag.UseCostCenter)
                                                    {
                                                        <th>
                                                            @MyERP.Properties.Resources.CostCenters
                                                        </th>
                                                    }
                                                    <th>@MyERP.Properties.Resources.Delete</th>
                                                </tr>
                                            </thead>
                                            <tbody id="JEDetails">
                                                @if (Model.Id != 0)
                                                {
                                                    foreach (var jED in Model.JournalEntryDetails)
                                                    {
                                                        <tr>
                                                            <td class="tabledit-edit-mode">
                                                                <select class="DetailDepartmentId form-control tabledit-input form-control-sm" data-department-id="@(jED.DepartmentId ?? Model.DepartmentId)">
                                                                    <option value="">@MyERP.Properties.Resources.Select</option>
                                                                </select>
                                                            </td>
                                                            <td class="tabledit-edit-mode">
                                                                <input type="text" class="form-control AccountCode tabledit-input tabledit-input form-control-sm" value="@(jED.ChartOfAccount != null ? jED.ChartOfAccount.Code : "")" readonly />
                                                            </td>
                                                            <td class="tabledit-edit-mode">
                                                                <select class="AccountId form-control tabledit-input form-control-sm" required>
                                                                    @if (jED.AccountId != null)
                                                                    {
                                                                        <option value="@jED.AccountId">@jED.ChartOfAccount.Code - @jED.ChartOfAccount.ArName</option>
                                                                    }
                                                                </select>
                                                            </td>

                                                            <td class="tabledit-edit-mode">
                                                                <input type="text" class="money form-control txtDebit tabledit-input form-control-sm" value="@jED.Debit" required />
                                                            </td>
                                                            <td class="tabledit-edit-mode">
                                                                <input type="text" class="money form-control txtCredit tabledit-input form-control-sm" value="@jED.Credit" required />
                                                            </td>
                                                            <td class="tabledit-edit-mode">
                                                                <input type="text" class="form-control txtNotes tabledit-input form-control-sm" value="@jED.Notes" />
                                                            </td>

                                                            <td class="tabledit-edit-mode">
                                                                <select class="PartyId form-control tabledit-input form-control-sm"
                                                                        data-party-id="@jED.PartyId"
                                                                        data-party-type="@jED.PartyType">
                                                                    <option value="">@MyERP.Properties.Resources.Select</option>
                                                                </select>
                                                            </td>

                                                            @if (ViewBag.UseCostCenter)
                                                            {
                                                                <td class="tabledit-edit-mode">
                                                                    <select class="CostCenterId form-control tabledit-input form-control-sm">
                                                                        @if (jED.CostCenterId.HasValue)
                                                                        {
                                                                            <option value="@jED.CostCenterId"></option>
                                                                        }
                                                                    </select>
                                                                </td>
                                                            }

                                                            @if (Model.SourceId == null && Model.SourcePageId == null)
                                                            {
                                                                <td class="tabledit-edit-mode"><a href="javascript:void(0);" class="DelBtn"><i class="fas fa-trash-alt"></i></a></td>
                                                            }
                                                            else
                                                            {
                                                                <td><a href="javascript:void(0);" onclick="Swal.fire({title: '@MyERP.Properties.Resources.TheAutomaticJournalEntryCannotBeDeleted', text: ' ', icon: 'info', showCancelButton: false, confirmButtonText: '@MyERP.Properties.Resources.Ok', confirmButtonColor: '#3085d6'})"><i class="fas fa-trash-alt"></i></a></td>
                                                            }
                                                        </tr>
                                                    }
                                                }

                                                <!-- الصف الافتراضي الفارغ بنفس ترتيب الأعمدة -->
                                                <tr>
                                                    <td class="tabledit-edit-mode">
                                                        <select class="DetailDepartmentId form-control tabledit-input form-control-sm">
                                                            <option value="">@MyERP.Properties.Resources.Select</option>
                                                        </select>
                                                    </td>
                                                    <td class="tabledit-edit-mode">
                                                        <input type="text" class="form-control AccountCode tabledit-input form-control-sm" readonly />
                                                    </td>
                                                    <td class="tabledit-edit-mode">
                                                        <select class="AccountId form-control tabledit-input form-control-sm" required>
                                                            <option value="">@MyERP.Properties.Resources.Select</option>
                                                        </select>
                                                    </td>
                                                    <td class="tabledit-edit-mode">
                                                        <input type="text" class="money form-control txtDebit tabledit-input form-control-sm" required />
                                                    </td>
                                                    <td class="tabledit-edit-mode">
                                                        <input type="text" class="money form-control txtCredit tabledit-input form-control-sm" required />
                                                    </td>
                                                    <td class="tabledit-edit-mode">
                                                        <input type="text" class="form-control txtNotes tabledit-input form-control-sm" />
                                                    </td>
                                                    <td class="tabledit-edit-mode">
                                                        <select class="PartyId form-control tabledit-input form-control-sm">
                                                            <option value="">@MyERP.Properties.Resources.Select</option>
                                                        </select>
                                                    </td>
                                                    @if (ViewBag.UseCostCenter)
                                                    {
                                                        <td class="tabledit-edit-mode">
                                                            <select class="CostCenterId form-control tabledit-input form-control-sm"></select>
                                                        </td>
                                                    }
                                                    <td class="tabledit-edit-mode">
                                                        <a href="javascript:void(0);" class="DelBtn"><i class="fas fa-trash-alt"></i></a>
                                                    </td>
                                                </tr>
                                            </tbody>

                                           
                                        </table>
                                    </div>
                                </div>

                                <div class="form-group row">
                                    <div class="col-sm-3">
                                        <label class="col-sm-6 control-label">@MyERP.Properties.Resources.TotalDebit</label>
                                        <input type='text' class='TotalDebit col-sm-6' value="" disabled>
                                    </div>
                                    <div class="col-sm-3">
                                        <label class="col-sm-6 control-label">@MyERP.Properties.Resources.TotalCredit</label>
                                        <input type='text' class='TotalCredit col-sm-6' value="" disabled>

                                    </div>
                                    <div class="col-sm-3">
                                        <label class="col-sm-6 control-label">@MyERP.Properties.Resources.Subtraction</label>

                                        <input type='text' class='money difference col-sm-6' value="" disabled>
                                    </div>
                                </div>

                                <br />
                                <br />
                                <div class="row">
                                    <div class="col-sm-offset-2">
                                        <input id="new" name="newBtn" hidden />

                                        @if (Model.SourceId == null && Model.SourcePageId == null)
                                        {
                                            if (Model.Id == 0)
                                            {
                                    <button type="button" id="save" class="btn btn-success" onclick="saveJE()">
                                        @MyERP.Properties.Resources.Save
                                    </button>
                                    <button type="button" id="newbtn" onclick="saveJE('new')" class="btn btn-success">
                                        @MyERP.Properties.Resources.SaveAndNew
                                    </button>
                                    <button type="button" onclick="saveJE('report')" class="btn btn-success">
                                        @MyERP.Properties.Resources.SaveAndPrint
                                    </button>
                                    <a class="btn btn-danger" href="@Url.Action("Index")" role="button"> @MyERP.Properties.Resources.Back</a>
                                            }
                                            else if (Model.IsDeleted == false)
                                            {
                                    <button type="button" id="save" onclick="saveJE()" class="btn btn-success">
                                        @MyERP.Properties.Resources.Save
                                    </button>
                                    <a class="btn btn-success" target="_blank" href="@Url.Action("JournalEntryDetails","Report",new { id=Model.Id})" role="button"> @MyERP.Properties.Resources.Print</a>

                                    <a class="btn btn-danger" href="@Url.Action("Index")" role="button"> @MyERP.Properties.Resources.Back</a>
                                    <button class="btn btn-danger" onclick="Delete(@Model.Id)"> @MyERP.Properties.Resources.Delete</button>

                                            }
                                        }

                                        else
                                        {
                                            if (Model.Id == 0)
                                            {
                                    <button type="button" class="btn btn-success" onclick="Swal.fire({title: '@MyERP.Properties.Resources.TheAutomaticJournalEntryCannotBeEdited',text: ' ',icon: 'info',showCancelButton: false,confirmButtonText: '@MyERP.Properties.Resources.Ok',confirmButtonColor: '#3085d6'})">
                                        @MyERP.Properties.Resources.Save
                                    </button>
                                                <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                                            }
                                            else
                                            {
                                                if (Model.IsDeleted == false)
                                                {
                                    <button type="button" class="btn btn-success" onclick="Swal.fire({title: '@MyERP.Properties.Resources.TheAutomaticJournalEntryCannotBeEdited',text: ' ',icon: 'info',showCancelButton: false,confirmButtonText: '@MyERP.Properties.Resources.Ok',confirmButtonColor: '#3085d6'})">
                                        @MyERP.Properties.Resources.Save
                                    </button>
                                    <a class="btn btn-success" target="_blank" href="@Url.Action("JournalEntryDetails","Report",new { id=Model.Id})" role="button">@MyERP.Properties.Resources.Print</a>

                                    <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                                    <button class="btn btn-danger" onclick="Swal.fire({title: '@MyERP.Properties.Resources.TheAutomaticJournalEntryCannotBeDeleted',text: ' ',icon: 'info',showCancelButton: false,confirmButtonText: '@MyERP.Properties.Resources.Ok',confirmButtonColor: '#3085d6'})">@MyERP.Properties.Resources.Delete</button>

                                                }
                                            }

                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>

    let UseCostCenter = '@ViewBag.UseCostCenter';
    let TotalCredit;
    let TotalDebit;
    var taxPercentage = 0.15;
    let Accounts = [];
    let costCenterOptions = '';
     var RES_SELECT   = '@MyERP.Properties.Resources.Select';
    var Departments = @Html.Raw(ViewBag.DepartmentsJson ?? "[]");
    var getPartiesUrl = '@Url.Action("GetPartiesByAccount","Helper", new { area = "" })';

    function getDepartmentLabel(dep) {
        if (!dep) return '';
        if (dep.Code && dep.ArName) return dep.Code + ' - ' + dep.ArName;
        return dep.ArName || dep.EnName || dep.Code || '';
    }

    function fillDepartmentSelect($row, selectedId) {
        var $dep = $row.find('.DetailDepartmentId');
        if (!$dep.length) return;
        var current = selectedId || $dep.attr('data-department-id') || $('#DepartmentId').val() || '';
        $dep.empty().append('<option value="">' + RES_SELECT + '</option>');
        (Departments || []).forEach(function (dep) {
            $dep.append(new Option(getDepartmentLabel(dep), dep.Id, false, false));
        });
        if (current) {
            $dep.val(current);
        }
        if ($.fn.select2 && !$dep.hasClass('select2-hidden-accessible')) {
            $dep.select2();
        }
        if (current) {
            $dep.trigger('change.select2');
        }
    }

    function getAccountById(accountId) {
        if (!accountId) return null;
        for (var i = 0; i < Accounts.length; i++) {
            if (String(Accounts[i].Id) === String(accountId)) return Accounts[i];
        }
        return null;
    }

    function setRowAccountCode($row, accountId) {
        var acc = getAccountById(accountId);
        $row.find('.AccountCode').val(acc ? (acc.Code || '') : '');
    }

    function fillAccountSelect($row, selectedId) {
        var $acc = $row.find('.AccountId');
        if (!$acc.length) return;

        var current = selectedId || $acc.val() || '';
        $acc.empty().append('<option value="">' + RES_SELECT + '</option>');
        for (var i = 0; i < Accounts.length; i++) {
            $acc.append(new Option((Accounts[i].Code ? Accounts[i].Code + ' - ' : '') + Accounts[i].ArName, Accounts[i].Id, false, false));
        }
        if (current) {
            $acc.val(current);
        }
        if ($.fn.select2 && !$acc.hasClass('select2-hidden-accessible')) {
            $acc.select2();
        }
        if (current) {
            $acc.trigger('change.select2');
        }
        setRowAccountCode($row, current);
    }

    function fillCostCentersForRow($row) {
        if (UseCostCenter != 'True') return;
        $row.find('.CostCenterId').empty().append(costCenterOptions);
    }

    function initRowPlugins($row) {
        $row.find('.money').inputmask({
            alias: 'numeric',
            groupSeparator: ',',
            autoGroup: true,
            digits: 2,
            digitsOptional: false,
            allowMinus: false,
            placeholder: '0'
        });

        $row.find('select').each(function () {
            if ($.fn.select2 && !$(this).hasClass('select2-hidden-accessible')) {
                $(this).select2();
            }
        });
    }

    function appendDetailRowAfter($afterRow, options) {
        options = options || {};
        var markup = buildDetailRowMarkup(options);
        if ($afterRow && $afterRow.length) {
            $afterRow.after(markup);
        } else {
            $('#JEDetails').append(markup);
        }
        var $row = $afterRow && $afterRow.length ? $afterRow.next('tr') : $('#JEDetails tr').last();
        fillDepartmentSelect($row, options.departmentId);
        fillAccountSelect($row, options.accountId);
        fillCostCentersForRow($row);
        setRowAccountCode($row, options.accountId);

        if (options.notes !== undefined) {
            $row.find('.txtNotes').val(options.notes);
        }
        if (options.debit !== undefined) {
            $row.find('.txtDebit').val(options.debit);
        }
        if (options.credit !== undefined) {
            $row.find('.txtCredit').val(options.credit);
        }
        if (options.partyId !== undefined) {
            $row.find('.PartyId').attr('data-party-id', options.partyId || '').data('party-id', options.partyId || '');
        }
        if (options.partyType !== undefined) {
            $row.find('.PartyId').attr('data-party-type', options.partyType || '').data('party-type', options.partyType || '');
        }
        if (options.includeVat) {
            $row.find('.IncludeValueAddedTax').val('true');
        }
        initRowPlugins($row);
        return $row;
    }

    function buildDetailRowMarkup(options) {
        options = options || {};
        var accountId = options.accountId || '';
        var departmentId = options.departmentId || '';
        var accountCode = options.accountCode || '';
        var debit = options.debit || '';
        var credit = options.credit || '';
        var notes = options.notes || '';
        var partyId = options.partyId || '';
        var partyType = options.partyType || '';
        var costCenterId = options.costCenterId || '';
        var includeVat = options.includeVat ? 'true' : '';
        var removable = options.removable !== false;
        var requiredAttr = options.required ? ' required' : '';

        var html = '<tr' + (includeVat ? ' class="vat-row"' : '') + '>';
        html += '<td class="tabledit-edit-mode"><select class="DetailDepartmentId form-control tabledit-input form-control-sm" data-department-id="' + departmentId + '"><option value="">' + RES_SELECT + '</option></select></td>';
        html += '<td class="tabledit-edit-mode"><input type="text" class="form-control AccountCode tabledit-input form-control-sm" value="' + accountCode + '" readonly /></td>';
        html += '<td class="tabledit-edit-mode"><select class="AccountId form-control tabledit-input form-control-sm"' + requiredAttr + '><option value="">' + RES_SELECT + '</option></select></td>';
        html += '<td class="tabledit-edit-mode"><input type="text" class="money form-control txtDebit tabledit-input form-control-sm" value="' + debit + '"' + requiredAttr + ' /></td>';
        html += '<td class="tabledit-edit-mode"><input type="text" class="money form-control txtCredit tabledit-input form-control-sm" value="' + credit + '"' + requiredAttr + ' /></td>';
        html += '<td class="tabledit-edit-mode"><input type="text" class="form-control txtNotes tabledit-input form-control-sm" value="' + notes + '" /></td>';
        html += '<td class="tabledit-edit-mode"><select class="PartyId form-control tabledit-input form-control-sm" data-party-id="' + partyId + '" data-party-type="' + partyType + '"><option value="">' + RES_SELECT + '</option></select></td>';
        if (UseCostCenter == 'True') {
            html += '<td class="tabledit-edit-mode"><select class="CostCenterId form-control tabledit-input form-control-sm" data-cost-center-id="' + costCenterId + '"></select></td>';
        }
        html += '<td class="tabledit-edit-mode">';
        html += removable ? '<a href="javascript:void(0);" class="DelBtn"><i class="fas fa-trash-alt"></i></a>' : '';
        html += '<input type="hidden" class="IncludeValueAddedTax" value="' + includeVat + '" />';
        html += '</td>';
        html += '</tr>';
        return html;
    }

    function ensureTrailingBlankRow() {
        var $last = $('#JEDetails tr').last();
        if (!$last.length) return;

        var hasAcc = $last.find('.AccountId').val();
        var hasDebit = parseFloat($last.find('.txtDebit').inputmask('unmaskedvalue') || 0) > 0;
        var hasCredit = parseFloat($last.find('.txtCredit').inputmask('unmaskedvalue') || 0) > 0;
        var isVat = $last.find('.IncludeValueAddedTax').val() == 'true';
        if (hasAcc || hasDebit || hasCredit || isVat) {
            appendDetailRowAfter($last, { departmentId: $last.find('.DetailDepartmentId').val() || $('#DepartmentId').val() });
        }
    }

    function neutralizeTrailingBlankRowValidation() {
        var $last = $('#JEDetails tr').last();
        if (!$last.length) return;

        var hasAcc = $last.find('.AccountId').val();
        var hasDebit = parseFloat($last.find('.txtDebit').inputmask('unmaskedvalue') || 0) > 0;
        var hasCredit = parseFloat($last.find('.txtCredit').inputmask('unmaskedvalue') || 0) > 0;
        var isVat = $last.find('.IncludeValueAddedTax').val() == 'true';
        if (!hasAcc && !hasDebit && !hasCredit && !isVat) {
            $last.find('.AccountId, .txtDebit, .txtCredit').removeAttr('required');
        }
    }

    function updateVatRowFromSource($sourceRow) {
        var $vatRow = $sourceRow.next('tr');
        if (!$vatRow.length || $vatRow.find('.IncludeValueAddedTax').val() != 'true') return;

        var debit = parseFloat($sourceRow.find('.txtDebit').inputmask('unmaskedvalue') || 0) || 0;
        var credit = parseFloat($sourceRow.find('.txtCredit').inputmask('unmaskedvalue') || 0) || 0;
        $vatRow.find('.txtDebit').val(debit * taxPercentage);
        $vatRow.find('.txtCredit').val(credit * taxPercentage);
        $vatRow.find('.DetailDepartmentId').val($sourceRow.find('.DetailDepartmentId').val() || $('#DepartmentId').val()).trigger('change.select2');
    }

    function syncAccountSelection($accountSelect) {
        var $row = $accountSelect.closest('tr');
        setRowAccountCode($row, $accountSelect.val());
        CheckValueAddedTaxes($accountSelect[0]);
        updateVatRowFromSource($row);
        ensureTrailingBlankRow();
    }

    $(document).ready(function () {
        $.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
            $("input[type|='datetime-local']").prop('min', r.PeriodStart).prop('max', r.PeriodEnd);
        });

        if ($('#Id').val()>0) {
            getCostCenters().then(function () {
                $('.CostCenterId').each(function () {
                    let selectedItem = $(this).val();
                    $(this).empty().append(costCenterOptions);
                    if (selectedItem)
                        $(this).val(selectedItem).trigger('change');
                });
            });
            $(".txtCredit").last().removeAttr('required');
            $(".txtDebit").last().removeAttr('required');
            $(".AccountId").last().removeAttr('required');
            var code = $('#DocumentNumber').val();
            $('#DocumentNumbers').val(code.replaceAll("-", ""))
            $("#DepartmentId").prop('disabled', true);
            $("#Date").prop('disabled', true);
        } else {
            setDocNum();
            getCostCenters().then(() => $('.CostCenterId').empty().append(costCenterOptions));
        }
        GetCurrentTaxPercentage();
        calculateTotalDebit();
        calculateTotalCredit();
        calculateDifference();

        $.when(getAccounts(), getVendors()).done(function () {
            $('#JEDetails tr').each(function () {
                var $row = $(this);
                fillDepartmentSelect($row, $row.find('.DetailDepartmentId').attr('data-department-id') || $('#DepartmentId').val());
                fillAccountSelect($row, $row.find('.AccountId').val());
                fillCostCentersForRow($row);
                setRowAccountCode($row, $row.find('.AccountId').val());
                initRowPlugins($row);
            });

            // لو فتحنا سجل قديم: حمّل الأطراف لكل صف بحسب الحساب المخزَّن
            $('#JEDetails tr').each(function () {
                var $acc = $(this).find('.AccountId');
                if ($acc.val()) loadRowParties($acc);
            });

            neutralizeTrailingBlankRowValidation();
        });





        TotalCredit = $(".TotalCredit").inputmask('unmaskedvalue');
        TotalDebit = $(".TotalDebit").inputmask('unmaskedvalue');
    });

