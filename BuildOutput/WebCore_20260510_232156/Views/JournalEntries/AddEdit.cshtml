    // ==== Vendors (الموردين) ====
// ===== Vendors =====
let vendors = [];                // علشان نكاشي النتيجة
let vendorsOptionString = '';    // خيارات الكومبو

// لو عندك requestData جاهز—كويس. لو مش موجود، استبدله بـ $.get
function getVendors() {
  // كاش: لو اتحمّلوا قبل كده، رجّع Deferred محلول
  if (vendors.length) return $.Deferred().resolve(vendors);

  return requestData('/Helper/Vendors').done(function (r) {
    vendors = Array.isArray(r) ? r : [];
    vendorsOptionString = '<option value="">' + '@MyERP.Properties.Resources.Select' + '</option>';
    for (var i = 0; i < vendors.length; i++) {
      var v = vendors[i];
      var name = v.ArName || v.EnName || ('Vendor #' + v.Id);
      vendorsOptionString += '<option value="' + v.Id + '">' + name + '</option>';
    }
  }).fail(function (xhr) {
    console.error('getVendors failed:', xhr?.status, xhr?.responseText);
    vendors = [];
    vendorsOptionString = '<option value="">' + '@MyERP.Properties.Resources.Select' + '</option>';
  });
}

// يملا أي كومبو Vendor داخل سكوب معيّن (صف جديد مثلاً)
function fillVendors($scope) {
  ($scope || $(document)).find('select.PartyId').each(function () {
    var sel = $(this).val(); // احتفظ بالقيمة الحالية لو موجودة
    $(this).html(vendorsOptionString);
    if (sel) $(this).val(sel);
    // فعّل select2 بعد ما الكومبو يبقى فيه عناصر
    if ($.fn.select2 && !$(this).hasClass('select2-hidden-accessible')) {
      $(this).select2();
    }
  });
}

    function fillPartySelect($row, items, partyType) {
        var $party = $row.find('select.PartyId');

        var savedId = $party.attr('data-party-id');    // اللي جاي من Razor
        var savedType = $party.attr('data-party-type');  // اللي جاي من Razor

        var html = '<option value="">' + RES_SELECT + '</option>';
        (items || []).forEach(function (it) {
            var name = it.Name || it.ArName || it.EnName || ('#' + it.Id);
            html += '<option value="' + it.Id + '">' + name + '</option>';
        });

        // اكتب النوع على data + attr (للدebug)، وارجّع الاختيار القديم لو موجود
        var finalType = partyType || savedType || null;

        $party.html(html)
            .prop('disabled', false)
            .data('party-type', finalType)              // ← المهم
            .attr('data-party-type', finalType || '')   // اختياري
            .val(savedId || '')                         // رجّع اختيار السجل
            .trigger('change');

        if ($.fn.select2 && !$party.hasClass('select2-hidden-accessible')) $party.select2();
    }


    function loadRowParties($accountSelect) {
        var $row = $accountSelect.closest('tr');
        var depId = $row.find('.DetailDepartmentId').val() || $('#DepartmentId').val();
        var accId = $accountSelect.val();
        var $party = $row.find('select.PartyId');

        var savedId = $party.attr('data-party-id');    // من الداتابيز
        var savedType = $party.attr('data-party-type');  // من الداتابيز

        if (!depId || !accId) {
            $party.html('<option value="">' + RES_SELECT + '</option>').prop('disabled', false);
            return;
        }

        // loading state
        $party.prop('disabled', true).html('<option value="">…</option>').trigger('change');

        $.get(getPartiesUrl, { departmentId: depId, accountId: accId })
            .done(function (r) {
                fillPartySelect($row, (r && r.items) || [], r && r.type);
            })
            .fail(function () {
                $party.html('<option value="">' + RES_SELECT + '</option>').prop('disabled', false).trigger('change');
            });
    }



