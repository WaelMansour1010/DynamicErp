@model IEnumerable<MyERP.Models.Maintenance>


@{
    ViewBag.Title = " الصيانات";
}
<div style="text-align: left;padding-bottom: 23px;">
</div>

<div class="panel panel-widget forms-panel">
    <div class="forms">
        <div class=" form-grids form-grids-right">
            <div class="widget-shadow " data-example-id="basic-forms">
                <div class="tables">
                    <div class="form-title">
                        <a class="btn btn-info" href="@Url.Action("AddEdit")" role="button" style="float:left;">إضافة جديد</a>

                        <div class="hed">الصيانات</div>
                    </div>
                    <div class="form-body">

                        <form class="form-horizontal">
                            <div class="form-group">
                                <div class="col-sm-12">
                                    <input type="text" class="form-control searchtxt" value="@Html.Raw(ViewBag.searchWord)" placeholder="بحث">
                                    <button type="button" class="btn btn-success btnSearch" onclick="searchWord = $('.searchtxt').val(); paging();">
                                        <i class="fa fa-search"></i>
                                    </button>
                                    <button type="button" class="btn btn-info btnSearch" onclick="pageNo = 1; searchWord=''; paging();">
                                        <i class="fa fa-refresh"></i>
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>


                </div>
            </div>
        </div>
    </div>
</div>

<div class="panel panel-widget forms-panel">
    <div class="forms">
        <div class=" form-grids form-grids-right">
            <div class="widget-shadow " data-example-id="basic-forms">
                <div class="tables">
                    <table class="table table-hover">
                        <thead>
                            <tr>

                                <th>
                                    السريال
                                </th>
                                <th>
                                    التاريخ
                                </th>



                                <th>
                                    تاريخ فاتورة المبيعات
                                </th>

                                <th>
                                    تاريخ المشتريات
                                </th>

                                <th>
                                    اسم العميل
                                </th>
                                <th>
                                    الصنف التالف
                                </th>


                                <th>
                                    اسم المورد
                                </th>

                                <th>
                                    نشط
                                </th>

                                <th>
                                    تعديل
                                </th>
                                <th>
                                    حذف
                                </th>

                                @*<th>
                                        @Html.DisplayNameFor(model => model.PurchaseInvoice.DocumentNumber)
                                    </th>
                                    <th>
                                        @Html.DisplayNameFor(model => model.PurchaseInvoice1.DocumentNumber)
                                    </th>*@

                            </tr>
                        </thead>


                        @foreach (var item in Model)
                        {
                            <tr>

                                <td>
                                    @Html.DisplayFor(modelItem => item.SerialNumber)
                                </td>

                                <td>
                                    @Html.DisplayFor(modelItem => item.Date)
                                </td>



                                <td>
                                    @Html.DisplayFor(modelItem => item.SalesInvoiceDate)
                                </td>

                                <td>
                                    @Html.DisplayFor(modelItem => item.PurchaseDate)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.Customer.ArName)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.Item.ArName)
                                </td>


                                <td>
                                    @Html.DisplayFor(modelItem => item.Vendor.ArName)
                                </td>
                                <td>
                                    <label class="switch">
                                        @if (item.IsActive == true)
                                        {
                                            <input class="switch-input" type="checkbox" checked="checked" onclick="ActivateAndDeactivate(@item.Id)" />
                                        }
                                        else
                                        {
                                            <input class="switch-input" type="checkbox" onclick="ActivateAndDeactivate(@item.Id)" />
                                        }

                                        <span class="switch-label" data-on="نشط" data-off="غير نشط"></span>
                                        <span class="switch-handle"></span>
                                    </label>
                                </td>

                                <td>
                                    <a href="@Url.Action("AddEdit","Maintenances",new { id=item.Id })" onclick="$('#preloader, #status').fadeIn();">
                                        <i class="fa fa-edit"></i>
                                    </a>
                                </td>

                                <td>
                                    <a href="javascript:void(0);" onclick="Delete(@item.Id)">
                                        <i class="fas fa-trash-alt"></i>
                                    </a>

                                </td>
                            </tr>
                        }

                    </table>
                </div>

            </div>
        </div>
    </div>
</div>

<div style="text-align:center;margin-bottom: 50px;">

    <div class="form-group row">
        <div class="col-sm-4">
            <select id="ShowByPage" class="form-control" style="width:70px;float:left;" onchange="paging()">
                <option value="10">10</option>
                <option value="30">30</option>
                <option value="50">50</option>
                <option value="100">100</option>
                <option value="200">200</option>
                <option value="@ViewBag.Count">الكل</option>
            </select>
            <span style="font-size:12px;float:right;"> عدد النتائج : <span id="RowsCount">@ViewBag.Count</span></span>
        </div>
        <div class="col-sm-2">
            <lablel class="col-sm-8"> رقم الصفحة: </lablel>
        </div>
        <div class="col-sm-2">
            <select id="pagination" class="pagination form-control" style="width:70px;float:left;">
            </select>
        </div>
    </div>
</div>

<script>
    var pageNo = 1;
    var searchWord = '@Html.Raw(ViewBag.searchWord)';
    $('#ShowByPage').val(@ViewBag.wantedRowsNo);

    function paging() {

        var link = '/maintenances/Index?' + 'pageIndex=' + pageNo + '&wantedRowsNo=' + $('#ShowByPage').val() + '&searchWord=' + searchWord;
        window.location.replace(link);
    }

    function setPages() {
        var count =@ViewBag.Count;
        for (var i = 0; i < Math.ceil(count / $('#ShowByPage').val()); i++)
            $('#pagination').append('<option onchange="pageNo=' + (i + 1) + '; paging();" id="pg' + (i + 1) + '">' + (i + 1) + '</option>');
    }

    setPages();
   $('#pg' +@ViewBag.PageIndex).attr('selected', 'selected')

    $('#pagination').on('change', function () {
        pageNo = $('#pagination').val();
         paging();
    })

    function Delete(id) {
        if (confirm('هل تريد الحذف؟')) {

            $('#preloader, #status').fadeIn();
            $.ajax(
                {

                    url: '/maintenances/Delete',
                    type: 'POST',
                    data: {
                        "Id": id,
                    },
                    error: function (e) {

                    },
                    success: function (r) {
                        if (r == 'true') {
                            window.location.reload();
                        }
                    }
                });
        }
    }

    function ActivateAndDeactivate(id) {
        $.ajax({
            url: '/maintenances/ActivateDeactivate',
            type: 'POST',
            data: {
                "Id": id,
            },
            error: function (e) {

            },
            success: function (r) {
                if (r == 'true') {
                    alert('تم تغير حالة التنشيط!')
                }
            }
        });
    }
</script>