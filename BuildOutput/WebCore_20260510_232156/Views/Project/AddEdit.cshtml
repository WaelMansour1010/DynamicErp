                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.GuaranteeStartDate</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.GuaranteeStartDate, new { htmlAttributes = new { @class = "form-control", @type = "datetime-local", @required = "required" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label class="col-sm-2 control-label">@MyERP.Properties.Resources.GuaranteeEndDate</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.GuaranteeEndDate, new { htmlAttributes = new { @class = "form-control", @type = "datetime-local", @required = "required" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
