                                </div>
                                <div class="form-group row">
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.Paid</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.Paid, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.Paid } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.Remain</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.Remain, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.Remain } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.RemainingTime</label>
                                    <div class="col-sm-3">
                                        @Html.EditorFor(model => model.RemainingTime, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.RemainingTime, @type = "text" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <span class="col-sm-1">  @MyERP.Properties.Resources.Day </span>
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.Time</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.Time, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.Time, @type = "text" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.Secretarial</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownListFor(model => model.SecretarialId, null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.Municipality</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownListFor(model => model.MunicipalityId, null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.ExecutiveCharge</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownListFor(model => model.ExecutiveChargeId, null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.GuaranteeBank</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownListFor(model => model.GuaranteeBankId, null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
