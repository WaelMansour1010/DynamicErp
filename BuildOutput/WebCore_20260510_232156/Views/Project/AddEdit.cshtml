<script>

    //--------------- Variables Declarations -------------------//
    let ItemUnitOptions = "";

    //*********************************************************//
    //--------------- Ready Function -------------------//
    $(document).ready(function () {
        getItemUnit();
        if ($('#Id').val() > 0) {
            $('.ItemUnitId').not(':last').each(function () {
                let selectedItem = $(this).val();
                $(this).empty().append(ItemUnitOptions).val(selectedItem);
            });
            $('.UnitId').not(':last').each(function () {
                let selectedItem = $(this).val();
                $(this).empty().append(ItemUnitOptions).val(selectedItem);
            });
        }
        else {
            setCodeNum();
        }
        $('#StartDate').val('@ViewBag.StartDate');
        $('#EndDate').val('@ViewBag.EndDate');
        $('#GuaranteeStartDate').val('@ViewBag.GuaranteeStartDate');
        $('#GuaranteeEndDate').val('@ViewBag.GuaranteeEndDate');
        $('#NearestEnd').val('@ViewBag.NearestEnd');
    });
    //*********************************************************//
    //--------------- Event Functions -------------------//

    //$(document).on('change', "DepartmentId", function () {
    //    setCodeNum();
    //});
    $(document).on('change', ".ItemNo:last,  .ItemCode:last, .ItemSelection:last, .ItemDescription:last, .RelatedToItem:last,.ItemUnitId:last", function () {
        AddToProjectDetails();
    });
    $(document).on('change', ".Operation:last,  .Count:last, .UnitId:last", function () {
        AddToProjectItemOperations();
    });
    //*********************************************************//
     //--------------- Other Functions -------------------//
    function setCodeNum() {
        var doc = $.get('/Project/SetCodeNum').done(function (r) {
            $('#Code').val(r);
        });
    }
    function zeroPadded(val) {
        if (val >= 10)
            return val;
        else
            return '0' + val;
    }
    function getItemUnit() {
        ItemUnitOptions = '';
        $('.ItemUnitId').last().find('option').each(function () {
            ItemUnitOptions += '<option value="' + $(this).val() + '">' + $(this).text() + '</option>';
        });
        $('.UnitId').last().find('option').each(function () {
            ItemUnitOptions += '<option value="' + $(this).val() + '">' + $(this).text() + '</option>';
        });
    }
    function AddToProjectDetails() {
        let valid = true;
        if ($('#ProjectDetails .ItemNo:last').val() || $('#ProjectDetails .ItemCode:last').val() || $('#ProjectDetails .ItemSelection:last').val() || $('#ProjectDetails .ItemDescription:last').val() || $('#ProjectDetails .RelatedToItem:last').val() || $('#ProjectDetails .ItemUnitId:last').val()) {
                $('#ProjectDetails').find('.ItemNo,  .ItemCode, .ItemSelection, .ItemDescription, .RelatedToItem,.ItemUnitId').prop('required', true);
            }
        if ($('#ProjectDetails .form-control:invalid').length > 0) {
            $('#ProjectDetails').closest('.form-horizontal').addClass('was-validated');
            $('html, body').animate({
                scrollTop: $("#ProjectDetails").find(".form-control:invalid").eq(0).offset().top - 80
            }, 500);
            valid = false;
        }
        else {
            if (valid = true) {
                let tr = '<tr><td class="tabledit-edit-mode" ><input type="text" class="ItemNo form-control tabledit-input form-control-sm" value="" /></td ><td class="tabledit-edit-mode"><input type="text" class="ItemCode form-control tabledit-input form-control-sm" value="" /></td><td class="tabledit-edit-mode"><input type="text" class="ItemSelection form-control tabledit-input form-control-sm" value="" /></td><td class="tabledit-edit-mode"><input type="text" class="ItemDescription form-control tabledit-input form-control-sm" value="" /></td><td class="tabledit-edit-mode"><input type="text" class="RelatedToItem form-control tabledit-input form-control-sm" value="" /></td><td class="tabledit-edit-mode"><input type="text" class="Notes form-control tabledit-input form-control-sm" value="" /></td><td class="tabledit-edit-mode"><select class="ItemUnitId form-control tabledit-input form-control-sm"></select></td><td><a href="javascript:void(0);" onclick="deleteElement(this)"><i class="fas fa-trash-alt"></i></a></td></tr>';
                if (!ItemUnitOptions.length) {
                    getItemUnit();
                }
                $('#ProjectDetails').append(tr);
                $('.ItemUnitId').last().append(ItemUnitOptions).select2();
            }

        }
    }
    function ItemOperation() {
        $('#operationDiv').show();
    }
    function AddToProjectItemOperations() {
        let valid = true;
        if ( $('#ProjectItemOperations .Operation:last').val() || $('#ProjectItemOperations .UnitId:last').val() || $('#ProjectItemOperations .Count:last').val()) {
            $('#ProjectItemOperations').find('.Operation, .Count,.UnitId').prop('required', true);
        }
        if ($('#ProjectItemOperations .form-control:invalid').length > 0) {
            $('#ProjectItemOperations').closest('.form-horizontal').addClass('was-validated');
            $('html, body').animate({
                scrollTop: $("#ProjectItemOperations").find(".form-control:invalid").eq(0).offset().top - 80
            }, 500);
            valid = false;
        }
        else {
            if (valid = true) {
                let tr = '<tr><td class="tabledit-edit-mode"><input type="text" class="Operation form-control tabledit-input form-control-sm" /></td><td class="tabledit-edit-mode"><input type="text" class="Count form-control tabledit-input form-control-sm" /></td><td class="tabledit-edit-mode"><select class= "UnitId form-control tabledit-input form-control-sm"></select></td><td class="tabledit-edit-mode"><input type="text" class="IdealDuration form-control tabledit-input form-control-sm" /></td><td class="tabledit-edit-mode"><input type="text" class="ActualDuration form-control tabledit-input form-control-sm" /></td><td class="tabledit-edit-mode"><input type="text" class="PreviousActivity form-control tabledit-input form-control-sm" /></td> <td class="tabledit-edit-mode"><input type = "text" class="GracePeriod form-control tabledit-input form-control-sm" /></td ><td class="tabledit-edit-mode"><input type="datetime-local" class="StartDate form-control tabledit-input form-control-sm" /></td><td class="tabledit-edit-mode"><input type="datetime-local" class="EndDate form-control tabledit-input form-control-sm" /></td><td class="tabledit-edit-mode"><input type="datetime-local" class="NearestStart form-control tabledit-input form-control-sm" /></td><td class="tabledit-edit-mode"><input type="datetime-local" class="LastStart form-control tabledit-input form-control-sm" /></td><td class="tabledit-edit-mode"><input type="datetime-local" class="NearestEnd form-control tabledit-input form-control-sm" /></td><td class="tabledit-edit-mode"><input type="datetime-local" class="LastEnd form-control tabledit-input form-control-sm" /></td><td class="tabledit-edit-mode"><input type="text" class="Position form-control tabledit-input form-control-sm" /></td><td class="tabledit-edit-mode"><input type="text" class="ToolId form-control tabledit-input form-control-sm" /></td><td class="tabledit-edit-mode"><input type="text" class="EquipmentId form-control tabledit-input form-control-sm" /></td><td class="tabledit-edit-mode"><input type="text" class="EmploymentId form-control tabledit-input form-control-sm" /></td><td class="tabledit-edit-mode"><input type="text" class="ExpensesId form-control tabledit-input form-control-sm" /></td><td><a href="javascript:void(0);" onclick="deleteElement(this)"><i class="fas fa-trash-alt"></i></a></td></tr > ';
                if (!ItemUnitOptions.length) {
                    getItemUnit();
                }
                $('#ProjectItemOperations').append(tr);
                $('.UnitId').last().append(ItemUnitOptions).select2();
            }

        }
    }
    function deleteElement(e) {
        let tr = $(e).closest('tr');
        if ($(tr).index() == 0 && $(tr).closest('tbody').children('tr').length == 1) {
            $(tr).find("input").val('');
            $(tr).find("label").text('');
            $(tr).find('input, select').removeAttr('required');
            // $(tr).find('select').empty();
            $(tr).find('select').prop('selectedIndex', 0);
            $(tr).find('select').select2();
        }
        else if ($(tr).index() < $(tr).closest('tbody').children('tr').length - 1)
            e.parentNode.parentNode.parentNode.removeChild(e.parentNode.parentNode);
        else if ($(tr).index() == $(tr).closest('tbody').children('tr').length - 1) {
            $(tr).find("input").val('');
            $(tr).find('input, select').removeAttr('required');
           // $(tr).find('select').empty();
            $(tr).find('select').prop('selectedIndex', 0);
            $(tr).find('select').select2();
            $(tr).find("label").text('');
        }
    }
    //*********************************************************//
    function addEdit(n) {
        let valid = true;
        if ($('.form-horizontal').first().find('.form-control:invalid').length > 0) {
            $('.form-horizontal').first().addClass('was-validated');
            $('html, body').animate({
                scrollTop: $('.form-horizontal').first().find(".form-control:invalid").eq(0).offset().top - 100
            }, 500);
            valid = false;
            console.log($(".form-control:invalid"));
        }

        let ProjectDetails = [];
        $('#ProjectDetails tr').each(function () {
                var td = $(this);
            var ProjectDetail = {
                MainDocId: $('#Id').val(),
                ItemNo: td.find('.ItemNo').val(),
                ItemCode: td.find('.ItemCode').val(),
                ItemSelection: td.find('.ItemSelection').val(),
                ItemDescription: td.find('.ItemDescription').val(),
                RelatedToItem: td.find('.RelatedToItem').val(),
                Notes: td.find('.Notes').val(),
                ItemUnitId: td.find('.ItemUnitId').val(),
                IsDeleted: $('#IsDeleted').val(),
            };
            if (td.find('.ItemNo').val() && td.find('.ItemCode').val() && td.find('.ItemUnitId').val() )
            ProjectDetails.push(ProjectDetail);
        });
        if ($('#ProjectDetails tr').length ==1 && !$('#ProjectDetails tr:last input').val()>0) {
            alert('@MyERP.Properties.Resources.AllDetailsRequired');
            valid = false;
        }

        let ProjectItemOperations = [];
        $('#ProjectItemOperations tr').each(function () {
            var td = $(this);
            var ProjectItemOperation = {
                ProjectId: $('#Id').val(),
                IsDeleted: $('#IsDeleted').val(),
                Operation: td.find('.Operation').val(),
                Count: td.find('.Count').val(),
                UnitId: td.find('.UnitId').val(),
                IdealDuration: td.find('.IdealDuration').val(),
                ActualDuration: td.find('.ActualDuration').val(),
                PreviousActivity: td.find('.PreviousActivity').val(),
                GracePeriod: td.find('.GracePeriod').val(),
                StartDate: td.find('.StartDate').val(),
                EndDate: td.find('.EndDate').val(),
                NearestStart: td.find('.NearestStart').val(),
                LastStart: td.find('.LastStart').val(),
                NearestEnd: td.find('.NearestEnd').val(),
                LastEnd: td.find('.LastEnd').val(),
                Position: td.find('.Position').val(),
                ToolId: td.find('.ToolId').val(),
                EquipmentId: td.find('.EquipmentId').val(),
                EmploymentId: td.find('.EmploymentId').val(),
                ExpensesId: td.find('.ExpensesId').val(),
            };
            if (td.find('.Operation').val() && td.find('.Count').val() && td.find('.UnitId').val())
            ProjectItemOperations.push(ProjectItemOperation);
        });

        var Project = {
            Id: $('#Id').val(),
            Code: $('#Code').val(),
            ArName: $('#ArName').val(),
            EnName: $('#EnName').val(),
            DepartmentId: $('#DepartmentId').val(),
            CurrencyId: $('#CurrencyId').val(),
            Total: $('#Total').val(),
            UserId: $('#UserId').val(),
            IsActive: $('#IsActive').val(),
            IsDeleted: $('#IsDeleted').val(),
            Notes: $('#Notes').val(),
            Image: $('#Image').val(),
            ProjectStatusId: $('#ProjectStatusId').val(),
            ContractTypeId: $('#ContractTypeId').val(),
            ContractNo: $('#ContractNo').val(),
            ProjectValue: $('#ProjectValue').val(),
            DiscountValue: $('#DiscountValue').val(),
            DiscountPerc: $('#DiscountPerc').val(),
            ProjectValueAfterDiscount: $('#ProjectValueAfterDiscount').val(),
            StartDate: $('#StartDate').val(),
            EndDate: $('#EndDate').val(),
            NearestEnd: $('#NearestEnd').val(),
            ProjectDuration: $('#ProjectDuration').val(),
            BasedOn: $('#BasedOn').val(),
            EndCustomerId: $('#EndCustomerId').val(),
            SubCustomerId: $('#SubCustomerId').val(),
            CustomerRepId: $('#CustomerRepId').val(),
            SiteManagerId: $('#SiteManagerId').val(),
            HrDepartmentId: $('#HrDepartmentId').val(),
            Executor: $('#Executor').val(),
            ExecutorPerc: $('#ExecutorPerc').val(),
            Paid: $('#Paid').val(),
            Remain: $('#Remain').val(),
            RemainingTime: $('#RemainingTime').val(),
            Time: $('#Time').val(),
            MunicipalityId: $('#MunicipalityId').val(),
            SecretarialId: $('#SecretarialId').val(),
            ExecutiveChargeId: $('#ExecutiveChargeId').val(),
            GuaranteeNo: $('#GuaranteeNo').val(),
            GuaranteeValue: $('#GuaranteeValue').val(),
            GuaranteeStartDate: $('#GuaranteeStartDate').val(),
            GuaranteeEndDate: $('#GuaranteeEndDate').val(),
            GuaranteeExtension: $('#GuaranteeExtension').val(),
            GuaranteeBankId: $('#GuaranteeBankId').val(),
            ProjectDetails: ProjectDetails,
            ProjectItemOperations: ProjectItemOperations,
        }

        if (valid && confirm('@MyERP.Properties.Resources.AreYouSureYouWantToSave')) {
            $('#preloader, #status').fadeIn();
            $('#newbtn').prop('disabled', true);
            $('#save').prop('disabled', true);
            $.ajax({
                type: "POST", contentType: "application/json",
                url: "/Project/AddEdit",
                data: JSON.stringify( Project ),
                success: function (r) {
                    if (r.success == true) {
                        alert("@MyERP.Properties.Resources.Saved");
                        if (n == "new") {
                            window.location.replace("/Project/AddEdit");
                        } else {
                            window.location.replace("/Project");
                        }
                    }
                    else {
                        alert("@MyERP.Properties.Resources.NotSaved");
                    }
                    $('#preloader, #status').fadeOut();
                    $('#newbtn').prop('disabled', false);
                    $('#save').prop('disabled', false);
                },
                error: function (r) {
                    alert("@MyERP.Properties.Resources.NotSaved");
                    $('#preloader, #status').fadeOut();
                    $('#newbtn').prop('disabled', false);
                    $('#save').prop('disabled', false);
                }
            });
        }
    }
    function Delete(id) {
        if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToDelete')) {
            $('#preloader, #status').fadeIn();
            $.ajax(
                {
                    url: '/Project/Delete',
                    type: 'POST',
                    data: {
                        "Id": id,
                    },
                    error: function (e) {
                        $('#preloader, #status').fadeOut();
                        alert('@MyERP.Properties.Resources.DeleteDoesNotSucceeded');
                    },
                    success: function (r) {
                        if (r == 'true') {
                            window.location.replace('/Project');
                        } else
                            alert('@MyERP.Properties.Resources.DeleteDoesNotSucceeded');
                    }
                });
        }
    }

</script>


