            </div>

            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal needs-validation" role="form">
                        <div class="card">
                            <div class="card-body">
                                <div class="header-title">
                                    @MyERP.Properties.Resources.ProjectDetails
                                </div>
                                <div class="table-responsive">
                                    <table class="table table-centered mb-0">
                                        <thead>
                                            <tr>
                                                <td>
                                                    @MyERP.Properties.Resources.ItemNo
                                                </td>
                                                <td>
                                                    @MyERP.Properties.Resources.ItemCode
                                                </td>
                                                <td>@MyERP.Properties.Resources.ItemSelection</td>
                                                <td>@MyERP.Properties.Resources.ItemDescription</td>
                                                <td>
                                                    @MyERP.Properties.Resources.RelatedToItem
                                                </td>
                                                <td>@MyERP.Properties.Resources.Notes</td>
                                                <td>@MyERP.Properties.Resources.ItemUnit</td>
                                                <td>@MyERP.Properties.Resources.Delete</td>
                                            </tr>
                                        </thead>
                                        <tbody id="ProjectDetails">
                                            @if (Model != null)
                                            {
                                                foreach (var item in Model.ProjectDetails)
                                                {
                                                    <tr>
                                                        <td class="tabledit-edit-mode">
                                                            <input type="text" class="ItemNo form-control tabledit-input form-control-sm" value="@item.ItemNo" />
                                                        </td>
                                                        <td class="tabledit-edit-mode">
                                                            <input type="text" class="ItemCode form-control tabledit-input form-control-sm" value="@item.ItemCode" />
                                                        </td>
                                                        <td class="tabledit-edit-mode">
                                                            <input type="text" class="ItemSelection form-control tabledit-input form-control-sm" value="@item.ItemSelection" />
                                                        </td>
                                                        <td class="tabledit-edit-mode">
                                                            <input type="text" class="ItemDescription form-control tabledit-input form-control-sm" value="@item.ItemDescription" />
                                                        </td>
                                                        <td class="tabledit-edit-mode">
                                                            <input type="text" class="RelatedToItem form-control tabledit-input form-control-sm" value="@item.RelatedToItem" />
                                                        </td>
                                                        <td class="tabledit-edit-mode">
                                                            <input type="text" class="Notes form-control tabledit-input form-control-sm" value="@item.Notes" />
                                                        </td>
                                                        <td class="tabledit-edit-mode">
                                                            <select class="ItemUnitId form-control tabledit-input form-control-sm">
                                                                <option value="@item.ItemUnitId"></option>
                                                            </select>
                                                        </td>
                                                        <td><a href="javascript:void(0);" onclick="deleteElement(this)"><i class="fas fa-trash-alt"></i></a></td>
                                                    </tr>
                                                }
                                            }
                                            <tr>
                                                <td class="tabledit-edit-mode">
                                                    <input type="text" class="ItemNo form-control tabledit-input form-control-sm" value="" />
                                                </td>
                                                <td class="tabledit-edit-mode">
                                                    <input type="text" class="ItemCode form-control tabledit-input form-control-sm" value="" />
                                                </td>
                                                <td class="tabledit-edit-mode">
                                                    <input type="text" class="ItemSelection form-control tabledit-input form-control-sm" value="" />
                                                </td>
                                                <td class="tabledit-edit-mode">
                                                    <input type="text" class="ItemDescription form-control tabledit-input form-control-sm" value="" />
                                                </td>
                                                <td class="tabledit-edit-mode">
                                                    <input type="text" class="RelatedToItem form-control tabledit-input form-control-sm" value="" />
                                                </td>
                                                <td class="tabledit-edit-mode">
                                                    <input type="text" class="Notes form-control tabledit-input form-control-sm" value="" />
                                                </td>
                                                <td class="tabledit-edit-mode">
                                                    @Html.DropDownList("ItemUnitId", null, htmlAttributes: new { @class = "ItemUnitId form-control tabledit-input form-control-sm", id = "", name = "" })
                                                </td>
                                                <td><a href="javascript:void(0);" onclick="deleteElement(this)"><i class="fas fa-trash-alt"></i></a></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-sm-offset-2">
                    @if (Model == null)
                    {
                        <button onclick="addEdit('new');" class="btn btn-success" id="newbtn">
                            @MyERP.Properties.Resources.SaveAndNew
                        </button>
                        <button onclick="addEdit();" class="btn btn-success" id="save">
                            @MyERP.Properties.Resources.Save
                        </button>
                        <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                    }
                    else if (Model.IsDeleted == false)
                    {
                        <button onclick="addEdit();" class="btn btn-success" id="save">
                            @MyERP.Properties.Resources.Save
                        </button>
