@model  ChurchMembershipVisitInPeriod_Report
@{
    if (ViewBag.ShowReport == true)
    {
        Layout = null;
    }
    else
    {
        Layout = "~/Views/Shared/_Layout.cshtml";
    }
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.VisitsInPeriod;
}

<meta name="viewport" content="width=device-width" />
<title>@MyERP.Properties.Resources.VisitsInPeriod</title>

@if (ViewBag.ShowReport == true)
{
    @Html.DevExpress().GetStyleSheets(
                 new StyleSheet { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
                 new StyleSheet { ExtensionSuite = ExtensionSuite.Editors },
                 new StyleSheet { ExtensionSuite = ExtensionSuite.Report }
             )
    @Html.DevExpress().GetScripts(
                 new Script { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
                 new Script { ExtensionSuite = ExtensionSuite.Editors },
                 new Script { ExtensionSuite = ExtensionSuite.Report }
             )

    @Html.DevExpress().WebDocumentViewer(settings =>
    {
        settings.Name = "WebDocumentViewer";
    }).Bind(new DevExpress.XtraReports.Web.CachedReportSourceWeb(new ChurchMembershipVisitInPeriod_Report(@ViewBag.From, @ViewBag.To))).GetHtml()

}
else
{
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <div class="form-horizontal needs-validation" role="form">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.VisitsInPeriod
                                    </h5>

                                    <div class="form-group row">
                                        <label for="DateFrom" class="control-label col-sm-1">@MyERP.Properties.Resources.FromDate</label>
                                        <div class="col-sm-5">
                                            <input id="DateFrom" name="DateFrom" class="form-control" type="date" required />
                                        </div>
                                        <label for="DateTo" class="control-label col-sm-1">@MyERP.Properties.Resources.ToDate</label>
                                        <div class="col-sm-5">
                                            <input id="DateTo" name="DateTo" class="form-control" type="date" required />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-offset-2">
                        <button class="btn btn-success" onclick="search()">
                            @MyERP.Properties.Resources.ShowReport
                        </button>
                        <button class="btn btn-success" onclick="ShowData()">
                            @MyERP.Properties.Resources.ShowData
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!--------------------------------ShowData Table --------------------------------------->
    <div class="row" id="AllTable" style="display:none">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <div class="form-horizontal needs-validation" role="form">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.ReportData
                                    </h5>

                                    <div class="table-responsive">
                                        <table class="table table-striped table-centered mb-0">
                                            <thead>
                                                <tr>
                                                    <th>
                                                        @MyERP.Properties.Resources.Code
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.MemberName
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Mobile
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Phone
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Address
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Area
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.VisitDate
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Visitor
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Notes
                                                    </th>
                                                </tr>
                                            </thead>
                                            <tbody id="ShowDataTable"></tbody>
                                        </table>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!--***********************************************************************************************-->
}

<script>
    var pageNo = 1;
        $('#ShowByPage').val('@ViewBag.wantedRowsNo');

        function JsDate(val) {
        var date = new Date(val);
        var dd = date.getDate();
        var mm = date.getMonth() + 1; //January is 0!
        var yyyy = date.getFullYear();

        if (dd < 10) {
            dd = '0' + dd;
        }

        if (mm < 10) {
            mm = '0' + mm;
        }

        return date = yyyy + '-' + mm + '-' + dd;
    }
    $(document).ready(function () {
        //$.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
        //    var from = JsDate(r.PeriodStart);
        //    var to = JsDate(r.PeriodEnd);
        //    $('#DateFrom').prop('min', from);
        //    $('#DateFrom').prop('max', to);
        //    $('#DateFrom').val(from);
        //    $('#DateTo').prop('min', from);
        //    $('#DateTo').prop('max', to);
        //    $('#DateTo').val(to);
        //});
    });


    function search() {
        window.open("/Report/ChurchMembershipVisitInPeriod?From=" + $('#DateFrom').val() + "&To=" + $('#DateTo').val() + '&showReport=' + true, "blank");
    }

    function ShowData() {
        $('#ShowDataTable').empty();
        $('#preloader, #status').fadeIn();

        $.get("/Helper/ChurchMembershipVisitInPeriod?From=" + $('#DateFrom').val() + "&To=" + $('#DateTo').val()).done(function (r) {
            $('#AllTable').show();
            for (var i = 0; i < r.length; i++) {
                r[i].Code = r[i].Code == null ? "" : r[i].Code;
                r[i].ArName = r[i].ArName == null ? "" : r[i].ArName;
                r[i].Mobile = r[i].Mobile == null ? "" : r[i].Mobile;
                r[i].Phone = r[i].Phone == null ? "" : r[i].Phone;
                r[i].Address = r[i].Address == null ? "" : r[i].Address;
                r[i].Date = r[i].Date == null ? "" : convertToJavaScriptDate( r[i].Date);
                r[i].ConfessionFather = r[i].ConfessionFather == null ? "" : r[i].ConfessionFather;
                r[i].Notes = r[i].Notes == null ? "" : r[i].Notes;
                r[i].Area = r[i].Area == null ? "" : r[i].Area;
                

                let tr = '<tr><td><label class="control-label">' +
                    r[i].Code + '</label></td><td><label class="control-label">' +
                    r[i].ArName + '</label></td><td><label class="control-label">' +
                    r[i].Mobile + '</label></td><td><label class="control-label">' +
                    r[i].Phone + '</label></td><td><label class="control-label">' +
                    r[i].Address + '</label></td><td><label class="control-label">' +
                    r[i].Area + '</label></td><td><label class="control-label">' +
                    r[i].Date + '</label></td><td><label class="control-label">' +
                    r[i].ConfessionFather + '</label></td><td><label class="control-label">' +
                    r[i].Notes + '</label></td></tr>';
                $('#ShowDataTable').append(tr);
            }
            $('#preloader, #status').fadeOut();
        });
    }

    function convertToJavaScriptDate(value) {
        if (value === null)
            return null;
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        return ((dt.getMonth() + 1 + "/" + dt.getDate() + "/" + dt.getFullYear()));
    }

</script>
