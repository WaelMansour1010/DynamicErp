@model  EmployeesStatement_Report
@{
    if (ViewBag.ShowReport == true)
    {
        Layout = null;
    }
    else
    {
        Layout = "~/Views/Shared/_Layout.cshtml";
    }
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.EmployeesStatement;
}


<meta name="viewport" content="width=device-width" />
<title>@MyERP.Properties.Resources.EmployeesStatement</title>
@if (ViewBag.ShowReport == true)
{
    @Html.DevExpress().GetStyleSheets(
            new StyleSheet { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
            new StyleSheet { ExtensionSuite = ExtensionSuite.Editors },
            new StyleSheet { ExtensionSuite = ExtensionSuite.Report }
        )
    @Html.DevExpress().GetScripts(
            new Script { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
            new Script { ExtensionSuite = ExtensionSuite.Editors },
            new Script { ExtensionSuite = ExtensionSuite.Report }
        )


    @Html.DevExpress().WebDocumentViewer(settings =>
{
    settings.Name = "WebDocumentViewer";
}).Bind(new DevExpress.XtraReports.Web.CachedReportSourceWeb(new EmployeesStatement_Report(ViewBag.DepartmentId, ViewBag.WorkStatusId, ViewBag.HrDepartmentId, ViewBag.JobId, ViewBag.ContractsTypeId, ViewBag.NationalityId, ViewBag.ActivityId, ViewBag.CompanyId))).GetHtml()

}
else
{
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <div class="form-horizontal needs-validation" role="form">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.EmployeesStatement
                                    </h5>
                                    <div class="form-group row">
                                        <label class=" col-sm-1 control-label">@MyERP.Properties.Resources.Department</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("DepartmentId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                        <label class=" col-sm-1 control-label">@MyERP.Properties.Resources.Nationality</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("NationalityId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class=" col-sm-1 control-label">@MyERP.Properties.Resources.ContractsType</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("ContractsTypeId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>

                                        <label class=" col-sm-1 control-label">@MyERP.Properties.Resources.WorkStatus</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("WorkStatusId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class=" col-sm-1 control-label">@MyERP.Properties.Resources.HrDepartment</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("HrDepartmentId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                        <label class=" col-sm-1 control-label">@MyERP.Properties.Resources.Job</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("JobId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class=" col-sm-1 control-label">@MyERP.Properties.Resources.Activity</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("ActivityId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                        <label class=" col-sm-1 control-label">@MyERP.Properties.Resources.Company</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("CompanyId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-offset-2">
                        <button class="btn btn-success" onclick="DownloadReport()">
                            @MyERP.Properties.Resources.ShowReport
                        </button>
                        <button class="btn btn-success" onclick="ShowData()">
                            @MyERP.Properties.Resources.ShowData
                        </button>
                        <button class="btn btn-success" onclick="ShowReport()">
                            @MyERP.Properties.Resources.ShowDesign
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!--------------------------------ShowData Table --------------------------------------->
    <div class="row" id="AllTable" style="display:none">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <div class="form-horizontal needs-validation" role="form">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.ReportData
                                    </h5>

                                    <div class="table-responsive">
                                        <table class="table table-striped table-centered mb-0">
                                            <thead>
                                                <tr>
                                                    <th>
                                                        @MyERP.Properties.Resources.Employee
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Mobile
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Email
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Nationality
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Religion
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Department
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.HireDate
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Job
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.JobGrade
                                                    </th>  
                                                    <th>
                                                        @MyERP.Properties.Resources.WorkStatus
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.ContractsType
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.HrDepartment
                                                    </th>
                                                </tr>
                                            </thead>
                                            <tbody id="ShowDataTable"></tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!--***********************************************************************************************-->

}

<script>
    function JsDate(val) {
        var date = new Date(val);
        var dd = date.getDate();
        var mm = date.getMonth() + 1; //January is 0!
        var yyyy = date.getFullYear();

        if (dd < 10) {
            dd = '0' + dd;
        }

        if (mm < 10) {
            mm = '0' + mm;
        }

        return date = yyyy + '-' + mm + '-' + dd;
    }
    $(document).ready(function () {
        $.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
            var from = JsDate(r.PeriodStart);
            var to = JsDate(r.PeriodEnd);
            $('#DateFrom').prop('min', from);
            $('#DateFrom').prop('max', to);
            $('#DateFrom').val(from);
            $('#DateTo').prop('min', from);
            $('#DateTo').prop('max', to);
            $('#DateTo').val(to);
        });
    });

    function ShowReport() {
        window.open('/Report/EmployeesStatement?DepartmentId=' + $('#DepartmentId').val() + '&WorkStatusId=' + $('#WorkStatusId').val()
            + '&HrDepartmentId=' + $('#HrDepartmentId').val() + '&JobId=' + $('#JobId').val()
            + '&ContractsTypeId=' + $('#ContractsTypeId').val() + '&NationalityId=' + $('#NationalityId').val()
            + '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val()
            + '&showReport=' + true + '&print=' + false, "blank");
    }
    function DownloadReport() {
        window.open('/Report/EmployeesStatement?DepartmentId=' + $('#DepartmentId').val() + '&WorkStatusId=' + $('#WorkStatusId').val() 
            + '&HrDepartmentId=' + $('#HrDepartmentId').val() + '&JobId=' + $('#JobId').val() 
            + '&ContractsTypeId=' + $('#ContractsTypeId').val() + '&NationalityId=' + $('#NationalityId').val()
            + '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val()
            + '&showReport=' + false + '&print=' + true, "blank");
    }

    function ShowData() {
        $('#ShowDataTable').empty();
        $('#preloader, #status').fadeIn();
        $.get('/Helper/GetEmployeesStatement?DepartmentId=' + $('#DepartmentId').val() + '&WorkStatusId=' + $('#WorkStatusId').val() 
            + '&HrDepartmentId=' + $('#HrDepartmentId').val() + '&JobId=' + $('#JobId').val()
            + '&ContractsTypeId=' + $('#ContractsTypeId').val() + '&NationalityId=' + $('#NationalityId').val()
            + '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val()
        ).done(function (r) {
            $('#AllTable').show();
            for (var i = 0; i < r.length; i++) {
                r[i].ArName = r[i].ArName == null ? "" : r[i].ArName;
                r[i].MobileNumber = r[i].MobileNumber == null ? "" : r[i].MobileNumber;
                r[i].Email = r[i].Email == null ? "" : r[i].Email;
                r[i].Nationality = r[i].Nationality == null ? "" : r[i].Nationality;
                r[i].Religion = r[i].Religion == null ? "" : r[i].Religion;
                r[i].Department = r[i].Department == null ? "" : r[i].Department;
                r[i].HireDate = r[i].HireDate == null ? "" : convertToJavaScriptDate(r[i].HireDate);
                r[i].Job = r[i].Job == null ? "" : r[i].Job;
                r[i].JobGrade = r[i].JobGrade == null ? "" : r[i].JobGrade;
                r[i].WorkStatus = r[i].WorkStatus == null ? "" : r[i].WorkStatus;
                r[i].ContractsType = r[i].ContractsType == null ? "" : r[i].ContractsType;
                r[i].HrDepartment = r[i].HrDepartment == null ? "" : r[i].HrDepartment;

                let tr = '<tr><td><label class="control-label">' +
                    r[i].ArName + '</label></td><td><label class="control-label">' +
                    r[i].MobileNumber + '</label></td><td><label class="control-label">' +
                    r[i].Email + '</label></td><td><label class="control-label">' +
                    r[i].Nationality + '</label></td><td><label class="control-label">' +
                    r[i].Religion + '</label></td><td><label class="control-label">' +
                    r[i].Department + '</label></td><td><label class="control-label">' +
                    r[i].HireDate + '</label></td><td><label class="control-label">' +
                    r[i].Job + '</label></td><td><label class="control-label">' +
                    r[i].JobGrade + '</label></td><td><label class="control-label">' +
                    r[i].WorkStatus + '</label></td><td><label class="control-label">' +
                    r[i].ContractsType + '</label></td><td><label class="control-label">' +
                    r[i].HrDepartment + '</label></td></tr>';
                $('#ShowDataTable').append(tr);
            }
            $('#preloader, #status').fadeOut();
        });
    }


    function convertToJavaScriptDate(value) {
        if (value === null)
            return null;
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        return ((dt.getMonth() + 1 + "/" + dt.getDate() + "/" + dt.getFullYear()));
    }

</script>
