
@{
    if (ViewBag.ShowReport == true)
    {
        Layout = null;
    }
    else
    {
        Layout = "~/Views/Shared/_Layout.cshtml";
    }
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = MyERP.Properties.Resources.Items;
}


<meta name="viewport" content="width=device-width" />
<title> @MyERP.Properties.Resources.Items </title>

@if (ViewBag.ShowReport == true)
{
    @Html.DevExpress().GetStyleSheets(
                new StyleSheet { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
                new StyleSheet { ExtensionSuite = ExtensionSuite.Editors },
                new StyleSheet { ExtensionSuite = ExtensionSuite.Report }
                )
    @Html.DevExpress().GetScripts(
                new Script { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
                new Script { ExtensionSuite = ExtensionSuite.Editors },
                new Script { ExtensionSuite = ExtensionSuite.Report })
    <div>
        @Html.DevExpress().WebDocumentViewer(settings =>
   {
       settings.Name = "WebDocumentViewer1";
   }).Bind(new DevExpress.XtraReports.Web.CachedReportSourceWeb(new Items_Report(ViewBag.DepartmentId, ViewBag.GroupId, ViewBag.CategoryId, ViewBag.ActivityId, ViewBag.CompanyId))).GetHtml()
    </div>
}
else
{
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <div class="form-horizontal needs-validation" role="form">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.Items
                                    </h5>
                                    <div class="form-group row">
                                        <label class=" col-sm-1 control-label" for="Code">@MyERP.Properties.Resources.Department</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("DepartmentId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                            {
                                                @class = "form-control",
                                                required = "required"
                                            })
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class=" col-sm-1 control-label" for="Code">@MyERP.Properties.Resources.Group</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("GroupId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                            {
                                                @class = "form-control",
                                                required = "required"
                                            })
                                        </div>
                                        <label class=" col-sm-1 control-label" for="Code">@MyERP.Properties.Resources.Category</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("CategoryId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                            {
                                                @class = "form-control",
                                                required = "required"
                                            })
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class=" col-sm-1 control-label">@MyERP.Properties.Resources.Activity</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("ActivityId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                        <label class=" col-sm-1 control-label">@MyERP.Properties.Resources.Company</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("CompanyId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>

                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-offset-2">
                        <button class="btn btn-success" onclick="DownloadReport()">
                            @MyERP.Properties.Resources.ShowReport
                        </button>
                        <button class="btn btn-success" onclick="ShowData()">
                            @MyERP.Properties.Resources.ShowData
                        </button>
                        <button class="btn btn-success" onclick="ShowReport()">
                            @MyERP.Properties.Resources.ShowDesign
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!--------------------------------ShowData Table --------------------------------------->
    <div class="row" id="AllTable" style="display:none">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <div class="form-horizontal needs-validation" role="form">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.ReportData
                                    </h5>

                                    <div class="table-responsive">
                                        <table class="table table-striped table-centered mb-0">
                                            <thead>
                                                <tr>
                                                    <th>
                                                        @MyERP.Properties.Resources.Code
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.ArName
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.EnName
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Department
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Group
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Type
                                                    </th>
                                                </tr>
                                            </thead>
                                            <tbody id="ShowDataTable">
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!--***********************************************************************************************-->
}
<script>
    function ShowReport() {
        window.open('/Report/Items?DepartmentId=' + $('#DepartmentId').val() + '&GroupId=' + $('#GroupId').val() + '&CategoryId=' + $('#CategoryId').val()+ '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val() + '&showReport=' + true + '&print=' + false, "blank");
    }

    function DownloadReport() {
        window.open('/Report/Items?DepartmentId=' + $('#DepartmentId').val() + '&GroupId=' + $('#GroupId').val() + '&CategoryId=' + $('#CategoryId').val()+ '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val() + '&showReport=' + false + '&print=' + true, "blank");
    }

    function ShowData() {
            $('#ShowDataTable').empty();
            $('#preloader, #status').fadeIn();

            $.get('/Helper/GetItems?DepartmentId=' + $('#DepartmentId').val() + '&GroupId=' + $('#GroupId').val() + '&CategoryId=' + $('#CategoryId').val()+ '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val()).done(function (r) {
                $('#AllTable').show();
                for (var i = 0; i < r.length; i++) {

                    r[i].Code = r[i].Code == null ? "" : r[i].Code;
                    r[i].ArName = r[i].ArName == null ? "" : r[i].ArName;
                    r[i].EnName = r[i].EnName == null ? "" : r[i].EnName;
                    r[i].Department = r[i].Department == null ? "" : r[i].Department;
                    r[i].ItemGroup = r[i].ItemGroup == null ? "" : r[i].ItemGroup;
                    r[i].Itemtype = r[i].Itemtype == null ? "" : r[i].Itemtype;

                    let tr = '<tr><td><label class="control-label Debit">' +
                        r[i].Code + '</label></td><td><label class="control-label Credit">' +
                        r[i].ArName + '</label></td><td><label class="control-label DebitBalance">' +
                        r[i].EnName + '</label></td><td><label class="control-label CreditBalance">' +
                        r[i].Department + '</label></td><td><label class="control-label ArName">' +
                        r[i].ItemGroup + '</label></td><td><label class="control-label DocumentNumber">' +
                        r[i].Itemtype + '</label></td></tr>';

                    $('#ShowDataTable').append(tr);
                }
                $('#preloader, #status').fadeOut();
            });
        
    }

</script>