@model ReservedRooms_Report

@{
    if (ViewBag.ShowReport == true)
    {
        Layout = null;
    }
    else
    {
        Layout = "~/Views/Shared/_Layout.cshtml";
    }
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = MyERP.Properties.Resources.ReservedRoomsInPeriod;
}

<!DOCTYPE html>

@*<html>
    <head>*@
<meta name="viewport" content="width=device-width" />
<title>@MyERP.Properties.Resources.ReservedRoomsInPeriod</title>
@if (ViewBag.ShowReport == true)
{
    @Html.DevExpress().GetStyleSheets(
            new StyleSheet { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
            new StyleSheet { ExtensionSuite = ExtensionSuite.Editors },
            new StyleSheet { ExtensionSuite = ExtensionSuite.Report }
            )
    @Html.DevExpress().GetScripts(
            new Script { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
            new Script { ExtensionSuite = ExtensionSuite.Editors },
            new Script { ExtensionSuite = ExtensionSuite.Report }
            )
    @*</head>
        <body>*@

    @Html.DevExpress().WebDocumentViewer(settings =>
{
    settings.Name = "WebDocumentViewer";
}).Bind(new DevExpress.XtraReports.Web.CachedReportSourceWeb(new ReservedRooms_Report(ViewBag.BuildingId, ViewBag.RoomId, ViewBag.DateFrom, ViewBag.DateTo))).GetHtml()
    @*</body>

        </html>*@
}
else
{

    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <div class="form-horizontal needs-validation" role="form">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.ReservedRoomsInPeriod

                                    </h5>
                                    <div class="form-group row">
                                        <label class=" col-sm-2 control-label" for="Code">@MyERP.Properties.Resources.Building</label>
                                        <div class="col-sm-4">
                                            @Html.DropDownList("BuildingId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                         //  ,required = "required"
                                       })
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>
                                        <label class=" col-sm-2 control-label" for="Code">@MyERP.Properties.Resources.Room</label>
                                        <div class="col-sm-4">
                                            @Html.DropDownList("RoomId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                         //  ,required = "required"
                                       })
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label for="DateFrom" class="control-label col-sm-2">@MyERP.Properties.Resources.FromDate</label>
                                        <div class="col-sm-4">
                                            <input id="DateFrom" name="DateFrom" class="form-control" type="datetime-local" required />
                                        </div>
                                        <label for="DateTo" class="control-label col-sm-2">@MyERP.Properties.Resources.ToDate</label>
                                        <div class="col-sm-4">
                                            <input id="DateTo" name="DateTo" class="form-control" type="datetime-local" required />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-offset-2">
                        <button class="btn btn-success" onclick="ShowReport()">
                            @MyERP.Properties.Resources.ShowReport
                        </button>
                        <button class="btn btn-success" onclick="ShowData()">
                            @MyERP.Properties.Resources.ShowData
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!--------------------------------ShowData Table --------------------------------------->
    <div class="row" id="AllTable" style="display:none">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <div class="form-horizontal needs-validation" role="form">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.ReportData
                                    </h5>

                                    <div class="table-responsive">
                                        <table class="table table-striped table-centered mb-0">
                                            <thead>
                                                <tr>
                                                    <th>
                                                        @MyERP.Properties.Resources.ReservationNumber
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Building
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Room
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Customer
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Mobile
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.BookingStartDate
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.BookingEndDate
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.NightsNumber
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Total
                                                    </th>

                                                    <th>
                                                        @MyERP.Properties.Resources.Discount
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.TotalAfterDiscount
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Tax
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.TotalAfterTaxes
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Insurance
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Paid
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Remain
                                                    </th>

                                                </tr>
                                            </thead>
                                            <tbody id="ShowDataTable">
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>


                @*<div class="row">
                    <div class="col-12">
                        <div class="form-group row">
                            <label for="NightsNumber" class="control-label col-sm-2">@MyERP.Properties.Resources.NightsNumber</label>
                            <div class="col-sm-4">
                                <input id="NightsNumber" class="form-control" disabled />
                            </div>
                            <label for="RoomNumbers" class="control-label col-sm-2">@MyERP.Properties.Resources.RoomsNumber</label>
                            <div class="col-sm-4">
                                <input id="RoomNumbers" class="form-control" disabled />
                            </div>
                        </div>
                    </div>
                </div>*@
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-12">
            <div style="text-align:center;margin-bottom: 50px;">
                <div class="form-group row">
                    <div class="col-sm-6">
                        <select id="ShowByPage" class="form-control" style="width:70px;float:left;" onchange="ShowData()">
                            <option value="100">100</option>
                            <option value="200">200</option>
                            <option value="300">300</option>
                            <option value="@ViewBag.Count">@MyERP.Properties.Resources.All</option>
                        </select>
                        <span style="font-size:12px;float:right;"> @MyERP.Properties.Resources.NoOfResults: <span id="RowsCount">@ViewBag.Count</span></span>
                    </div>
                    <div class="col-sm-6">
                        <select id="pagination" class="pagination form-control col-sm-4" style="width:70px;float:left;">
                        </select>
                        <lablel class="col-sm-2"> @MyERP.Properties.Resources.PageNo: </lablel>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <!--***********************************************************************************************-->
}

<script>
    function JsDate(val) {
        var date = new Date(val);
        var dd = date.getDate();
        var mm = date.getMonth() + 1; //January is 0!
        var yyyy = date.getFullYear();

        if (dd < 10) {
            dd = '0' + dd;
        }

        if (mm < 10) {
            mm = '0' + mm;
        }

       return date = yyyy + '-' + mm + '-' + dd;
    }
    $(document).ready(function () {
        //$.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
        //    var from = JsDate(r.PeriodStart);
        //    var to = JsDate(r.PeriodEnd);
        //    $('#DateFrom').prop('min', from);
        //    $('#DateFrom').prop('max', to);
        //    $('#DateFrom').val(from);
        //    $('#DateTo').prop('min', from);
        //    $('#DateTo').prop('max', to);
        //    $('#DateTo').val(to);
        //});
    });

    var pageNo = 1;
        $('#ShowByPage').val('@ViewBag.wantedRowsNo');

    function ShowReport() {
        window.open('/Report/ReservedRooms?BuildingId=' + $('#BuildingId').val() + '&RoomId=' + $('#RoomId').val() + '&showReport=' + true + '&DateFrom=' + $('#DateFrom').val() + '&DateTo=' + $('#DateTo').val(), "blank");
    }

    function ShowData() {
        $('#ShowDataTable').empty();
        $('#RoomNumbers').val('')
        $('#NightsNumber').val('')
        $('#preloader, #status').fadeIn();
        $.get('/Helper/GetReservedRooms?BuildingId=' + $('#BuildingId').val() + '&RoomId=' + $('#RoomId').val() + '&DateFrom=' + $('#DateFrom').val() + '&DateTo=' + $('#DateTo').val() + '&pageIndex=' + pageNo + '&wantedRowsNo=' + $('#ShowByPage').val()).done(function (r) {
            if (r.length > 0) {
                $('#AllTable').show();
                for (var i = 0; i < r.length; i++) {
                    r[i].BookingStartDate = r[i].BookingStartDate == null ? "" : /*convertToJavaScriptDate(*/r[i].BookingStartDate/*)*/;
                    r[i].BookingEndDate = r[i].BookingEndDate == null ? "" : /*convertToJavaScriptDate(*/r[i].BookingEndDate/*)*/;
                    r[i].RoomNumber = r[i].RoomNumber == null ? "" : r[i].RoomNumber;
                    r[i].BuildingArName = r[i].BuildingArName == null ? "" : r[i].BuildingArName;
                    r[i].CustomerArName = r[i].CustomerArName == null ? "" : r[i].CustomerArName;
                    r[i].NightsNumber = r[i].NightsNumber == null ? 0 : r[i].NightsNumber;
                    r[i].RoomNumbers = r[i].RoomNumbers == null ? 1 : r[i].RoomNumbers;

                    r[i].ReservationNo = r[i].ReservationNo == null ? "" : r[i].ReservationNo.toString().replaceAll('-','');
                    r[i].CustomerMobile = r[i].CustomerMobile == null ? "" : r[i].CustomerMobile;
                    r[i].Total = r[i].Total == null ? 0 : r[i].Total;
                    r[i].Discount = r[i].Discount == null ? 0 : r[i].Discount;
                    r[i].TotalAfterDiscount = r[i].TotalAfterDiscount == null ? 0 : r[i].TotalAfterDiscount;
                    r[i].Tax = r[i].Tax == null ? 0 : r[i].Tax;
                    r[i].TotalAfterTaxes = r[i].TotalAfterTaxes == null ? 0 : r[i].TotalAfterTaxes;
                    r[i].Insurance = r[i].Insurance == null ? 0 : r[i].Insurance;
                    r[i].Paid = r[i].Paid == null ? 0 : r[i].Paid;
                    r[i].Remain = r[i].Remain == null ? 0 : r[i].Remain;

                    

                    let tr = '<tr><td><label class="control-label ReservationNo">' +
                        r[i].ReservationNo + '</label></td><td><label class="control-label BuildingArName">' +
                        r[i].BuildingArName + '</label></td><td><label class="control-label RoomNumber">' +
                        r[i].RoomNumber + '</label></td><td><label class="control-label CustomerArName">' +
                        r[i].CustomerArName + '</label></td><td><label class="control-label CustomerMobile">' +
                        r[i].CustomerMobile + '</label></td><td><label class="control-label BookingStartDate">' +
                        r[i].BookingStartDate + '</label></td><td><label class="control-label BookingEndDate">' +
                        r[i].BookingEndDate + '</label></td><td><label class="control-label NightsNumber">' +
                        r[i].NightsNumber + '</label></td><td><label class="control-label Total">' +
                        r[i].Total + '</label></td><td><label class="control-label Discount">' +
                        r[i].Discount + '</label></td><td><label class="control-label TotalAfterDiscount">' +
                        r[i].TotalAfterDiscount + '</label></td><td><label class="control-label Tax">' +
                        r[i].Tax + '</label></td><td><label class="control-label TotalAfterTaxes">' +
                        r[i].TotalAfterTaxes + '</label></td><td><label class="control-label Insurance">' +
                        r[i].Insurance + '</label></td><td><label class="control-label Paid">' +
                        r[i].Paid + '</label></td><td><label class="control-label Remain">' +
                        r[i].Remain + '</label></td></tr>';
                    $('#ShowDataTable').append(tr);

                }
                //$('#RoomNumbers').val(r[0].RoomNumbers)
                //$('#NightsNumber').val(r[0].NightsNumber)
            }
        });
        $('#preloader, #status').fadeOut();
    }

    function setPages() {
        var count ='@ViewBag.Count';
        for (var i = 0; i < Math.ceil(count / $('#ShowByPage').val()); i++)
   $('#pagination').append('<option onchange="pageNo=' + (i + 1) + '; paging();" id="pg' + (i + 1) + '">' + (i + 1) + '</option>');
    }

    setPages();

    $('#pg' +'@ViewBag.PageIndex').attr('selected', 'selected');

    $('#pagination').on('change', function () {
        pageNo = $('#pagination').val();
        ShowData();
    });

    function convertToJavaScriptDate(value) {
        if (value === null)
            return null;
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        return ((dt.getMonth() + 1 + "/" + dt.getDate() + "/" + dt.getFullYear()));
    }

</script>


