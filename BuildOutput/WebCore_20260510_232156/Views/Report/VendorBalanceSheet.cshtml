@model VendorBalanceSheet_Report
@{
    if (ViewBag.ShowData == false)
    {
        Layout = "~/Views/Shared/_Layout.cshtml";
    }
    else
    {
        Layout = null;
    }
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = MyERP.Properties.Resources.VendorBalanceSheet;
}

<!DOCTYPE html>

@*<html>
    <head>*@
<meta name="viewport" content="width=device-width" />
<title>@MyERP.Properties.Resources.VendorBalanceSheet</title>


@if (ViewBag.ShowData == true)
{
    @Html.DevExpress().GetStyleSheets(
                new StyleSheet { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
                new StyleSheet { ExtensionSuite = ExtensionSuite.Editors },
                new StyleSheet { ExtensionSuite = ExtensionSuite.Report }
            )
    @Html.DevExpress().GetScripts(
                new Script { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
                new Script { ExtensionSuite = ExtensionSuite.Editors },
                new Script { ExtensionSuite = ExtensionSuite.Report }
            )
    <div>
        @Html.DevExpress().WebDocumentViewer(settings =>
{
   settings.Name = "WebDocumentViewer";
}).Bind(new DevExpress.XtraReports.Web.CachedReportSourceWeb(Model)).GetHtml()
    </div>
}
else
{

    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <div class="form-horizontal needs-validation" role="form">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.VendorBalanceSheet
                                    </h5>
                                    <div class="form-group row">
                                        <label class=" col-sm-1 control-label" for="Code">@MyERP.Properties.Resources.Vendor</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("VendorId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", required = "required" })
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>

                                        <label class=" col-sm-1 control-label" for="ArName">@MyERP.Properties.Resources.Department</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("DepartmentId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", required = "required" })
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label for="DateFrom" class="control-label col-sm-1">@MyERP.Properties.Resources.FromDate</label>
                                        <div class="col-sm-5">
                                            <input id="DateFrom" name="DateFrom" class="form-control" type="date" required />
                                        </div>
                                        <label for="DateTo" class="control-label col-sm-1">@MyERP.Properties.Resources.ToDate</label>
                                        <div class="col-sm-5">
                                            <input id="DateTo" name="DateTo" class="form-control" type="date" required />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-offset-2">
                        <button class="btn btn-success" onclick="DownloadReport()">
                            @MyERP.Properties.Resources.ShowReport
                        </button>
                        <button class="btn btn-success" onclick="ShowData()">
                            @MyERP.Properties.Resources.ShowData
                        </button>
                        <button class="btn btn-success" onclick="ShowReport()">
                            @MyERP.Properties.Resources.ShowDesign
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>



    <!--------------------------------ShowData Table --------------------------------------->
    <div class="row" id="AllTable" style="display:none">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <div class="form-horizontal needs-validation" role="form">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.ReportData
                                    </h5>

                                    <div class="table-responsive">
                                        <table class="table table-striped table-centered mb-0">
                                            <thead>
                                                <tr>
                                                    <th>
                                                        @MyERP.Properties.Resources.InvoiceNo
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.InvoiceType
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.VendorName
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.JournalEntrieNo
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Date
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Credit
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.CreditBalance
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Debit
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.DebitBalance
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.VendorInvoiceReceiptNumber
                                                    </th>
                                                    <th class="Currency-th" style="display:none;">@MyERP.Properties.Resources.Currency</th>
                                                    <th class="Currency-th" style="display:none;">@MyERP.Properties.Resources.CurrencyEquivalent</th>
                                                </tr>
                                            </thead>
                                            <tbody id="ShowDataTable">
                                            </tbody>
                                        </table>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>


                    <div style="text-align:center;margin-bottom: 50px;">

                        <div class="form-group row">
                            <div class="col-sm-6">
                                <select id="ShowByPage" class="form-control" style="width:70px;float:left;" onchange="ShowData()">
                                    <option value="100">100</option>
                                    <option value="200">200</option>
                                    <option value="300">300</option>
                                    <option value="@ViewBag.Count">@MyERP.Properties.Resources.All</option>
                                </select>
                                <span style="font-size:12px;float:right;"> @MyERP.Properties.Resources.NoOfResults: <span id="RowsCount">@ViewBag.Count</span></span>
                            </div>
                            <div class="col-sm-6">
                                <select id="pagination" class="pagination form-control col-sm-4" style="width:70px;float:left;">
                                </select>
                                <lablel class="col-sm-2"> @MyERP.Properties.Resources.PageNo: </lablel>
                            </div>
                           
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!--***********************************************************************************************-->

}
@*</body>



    </html>*@
<script>

    let UseDifferentCurrencies = '@ViewBag.UseDifferentCurrencies';

    var pageNo = 1;
        $('#ShowByPage').val('@ViewBag.wantedRowsNo');
    //$(document).ready(function () {
    //    $.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
    //        $("input[type|='datetime-local']").not('#DueDate').prop('min', r.PeriodStart).prop('max', r.PeriodEnd);
    //    });
    //});


    function JsDate(val) {
        var date = new Date(val);
        var dd = date.getDate();
        var mm = date.getMonth() + 1; //January is 0!
        var yyyy = date.getFullYear();

        if (dd < 10) {
            dd = '0' + dd;
        }

        if (mm < 10) {
            mm = '0' + mm;
        }

        return date = yyyy + '-' + mm + '-' + dd;
    }
    $(document).ready(function () {
        $.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
            var from = JsDate(r.PeriodStart);
            var to = JsDate(r.PeriodEnd);
            $('#DateFrom').prop('min', from);
            $('#DateFrom').prop('max', to);
            $('#DateFrom').val(from);
            $('#DateTo').prop('min', from);
            $('#DateTo').prop('max', to);
            $('#DateTo').val(to);
        });
    });


    function ShowReport() {
        if (!$('#VendorId').val())
            Swal.fire({
                title: '@MyERP.Properties.Resources.Vendor' + ' ' + '@MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        else {
            // window.location.replace("/Report/VendorBalanceSheet?vendorId=2");
            window.open("/Report/VendorBalanceSheet?vendorId=" + $('#VendorId').val() + "&departmentId=" + $('#DepartmentId').val() + "&dateFrom=" + $('#DateFrom').val() + "&dateTo=" + $('#DateTo').val() + '&print='+false, "blank");
        }
    }
    function DownloadReport() {
        if (!$('#VendorId').val())
            Swal.fire({
                title: '@MyERP.Properties.Resources.Vendor' + ' ' + '@MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        else {
            // window.location.replace("/Report/VendorBalanceSheet?vendorId=2");
            window.open("/Report/VendorBalanceSheet?vendorId=" + $('#VendorId').val() + "&departmentId=" + $('#DepartmentId').val() + "&dateFrom=" + $('#DateFrom').val() + "&dateTo=" + $('#DateTo').val()+'&print='+true, "blank");
        }
    }

    var CurrencyId='@ViewBag.CurrencyId';
    var CurrencyName='@ViewBag.CurrencyName';
    var CurrencyEquivalent = '@ViewBag.CurrencyEquivalent';


    function GetVendorCurrency() {
        if (UseDifferentCurrencies == 'True') {
            $.get('/Helper/GetVendorCurrency?VendorId=' + $('#VendorId').val()).done(function (r) {
                $('.Currency-th').show();
                CurrencyId = r.CurrencyId != null ? r.CurrencyId : '@ViewBag.CurrencyId' != null ? '@ViewBag.CurrencyId' : 0;
                CurrencyName = r.CurrencyName != null ? r.CurrencyName : '@ViewBag.CurrencyName' != null ? '@ViewBag.CurrencyName' : "";
                CurrencyEquivalent = r.CurrencyEquivalent != null ? parseFloat(r.CurrencyEquivalent) : '@ViewBag.CurrencyEquivalent' != null ? '@ViewBag.CurrencyEquivalent' : 1;

            });
        }
        else {
            $('.Currency-th').show();
            CurrencyId = CurrencyId > 0 ? CurrencyId : 0;
            CurrencyName = CurrencyName != null ? CurrencyName : "";
            CurrencyEquivalent = CurrencyEquivalent > 0 ? CurrencyEquivalent : 1;
        }
    }
    $('#VendorId').on('change', function () {
        GetVendorCurrency();
    });

    function ShowData() {
        if (!$('#VendorId').val()) {
             Swal.fire({
                title: '@MyERP.Properties.Resources.Vendor' + ' ' + '@MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        }
        else {

            $('#ShowDataTable').empty();
            $('#preloader, #status').fadeIn();

            $.get('/Helper/GetVendorOB?VendorId=' + $('#VendorId').val() + '&DepartmentId=' + $('#DepartmentId').val() + '&DateFrom=' + $('#DateFrom').val() + '&DateTo=' + $('#DateTo').val() + 'pageIndex=' + pageNo + '&wantedRowsNo=' + $('#ShowByPage').val()).done(function (r) {
                $('#AllTable').show();
                for (var i = 0; i < r.length; i++) {
                    r[i].VendorReceiptNumber = r[i].VendorReceiptNumber != null ? r[i].VendorReceiptNumber : "";
                    let tr = '<tr><td ><label class="control-label InvoiceNo">' +
                        r[i].DocumentNumber + '</label></td><td><label class="control-label InvoiceType">' +
                        r[i].ArName + '</label></td><td><label class="control-label VendorName">' +
                        r[i].VendorArName + '</label></td><td><label class="control-label JournalEntrieNo">' +
                        r[i].JournalDocNum + '</label></td><td><label class="control-label Date">' +
                        convertToJavaScriptDate(r[i].Date) + '</label></td><td><label class="control-label Credit">' +
                        r[i].Credit + '</label></td><td><label class="control-label CreditBalance">' +
                        r[i].CreditBalance + '</label></td><td><label class="control-label Debit">' +
                        r[i].Debit + '</label></td><td><label class="control-label DebitBalance">' +
                        r[i].DebitBalance + '</label></td><td><label class="control-label DebitBalance">' +
                        r[i].VendorReceiptNumber + '</label></td><td class="tabledit-edit-mode Currency-th" style="display:none;"><input class="CurrencyId form-control tabledit-input form-control-sm" type = "text" readonly hidden value="' +
                        CurrencyId + '" /><label class="CurrencyName control-label tabledit-input">' +
                        CurrencyName + '</label></td ><td class="tabledit-edit-mode Currency-th" style="display:none;"><label style="padding: 0.2rem;" class="CurrencyEquivalent control-label tabledit-input" >' +
                        CurrencyEquivalent + '</label></td></tr>';
                    $('#ShowDataTable').append(tr);
                }
               // if (UseDifferentCurrencies == 'True') {
                    $('.Currency-th').show();
               // }
                $('#preloader, #status').fadeOut();

            });
        }
    }


    function setPages() {
        var count ='@ViewBag.Count';
        for (var i = 0; i < Math.ceil(count / $('#ShowByPage').val()); i++)
   $('#pagination').append('<option onchange="pageNo=' + (i + 1) + '; paging();" id="pg' + (i + 1) + '">' + (i + 1) + '</option>');
    }

    setPages();

    $('#pg' +'@ViewBag.PageIndex').attr('selected', 'selected');



    $('#pagination').on('change', function () {
        pageNo = $('#pagination').val();
        ShowData();

    })

    function convertToJavaScriptDate(value) {
        if (value === null)
            return null;
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        return ((dt.getMonth() + 1 + "/" + dt.getDate() + "/" + dt.getFullYear()));
    }

</script>
