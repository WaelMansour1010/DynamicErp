@model MyERP.Models.RoomLeavePermission

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.RoomLeavePermission;
}
<script src="~/Scripts/SaveAndNew.js"></script>
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                @if (Model != null)
                {
                    if (Model.IsDeleted == false)
                    {
                        if (ViewBag.Previous > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.First })" class="btn btn-info">@MyERP.Properties.Resources.First</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Previous })" class=" btn btn-info">&#8250;</a>
                        }
                        if (ViewBag.Next > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Next })" class="btn btn-info">&#8249;</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Last })" class="btn btn-info">@MyERP.Properties.Resources.Last</a>
                        }
                        <a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                    }
                }
                else
                {<a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>}
            </div>
            <h4 class="page-title"> @MyERP.Properties.Resources.RoomLeavePermission </h4>
        </div>
    </div>
</div>


<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal needs-validation" role="form">
                        <div class="card">
                            <div class="card-body">
                                @Html.AntiForgeryToken()
                                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                @if (Model != null)
                                {
                                    @Html.HiddenFor(model => model.Id)
                                    @Html.HiddenFor(model => model.UserId)
                                    @Html.HiddenFor(model => model.IsDeleted)
                                    @Html.HiddenFor(model => model.Image)
                                    @Html.HiddenFor(model => model.CurrencyId)
                                    @Html.HiddenFor(model => model.CurrencyEquivalent)
                                }
                                <h5 class="header-title">
                                    @MyERP.Properties.Resources.MainData
                                </h5>
                                <div class="form-group row">
                                    <label class=" col-sm-2 control-label" for="Id">@MyERP.Properties.Resources.DocNo</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.DocumentNumber, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly", placeholder = @MyERP.Properties.Resources.DocNo, required = "required", hidden = "hidden" } })
                                        <input id="DocumentNumbers" class="form-control" placeholder=@MyERP.Properties.Resources.Code required readonly />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.Date</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.VoucherDate, new { htmlAttributes = new { @class = "form-control", @type = "datetime-local", @required = "required" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.Department</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownListFor(model => model.DepartmentId, null, null, htmlAttributes: new { @class = "form-control", required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.CashBox</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownListFor(model => model.CashBoxId, null, null, htmlAttributes: new { @class = "form-control", required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <div class="col-sm-2"></div>
                                    <div class="col-sm-4">
                                        <button class="btn btn-primary" data-toggle="modal" data-target="#CustomerReservationModal">@MyERP.Properties.Resources.FindCustomerReservation</button>
                                    </div>
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.ReservationNumber</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownListFor(model => model.RoomBookingId, null, null, htmlAttributes: new { @class = "form-control", required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>

                                <div class="form-group row">
                                    <label class=" col-sm-2 control-label">@MyERP.Properties.Resources.Customer</label>
                                    <div class="col-sm-4">
                                        @if (Model != null && Model.CustomerId > 0)
                                        {
                                            <input type="text" value="@Model.CustomerId" id="CustomerId" class="form-control" required readonly hidden />
                                            <input type="text" id="CustomerArName" class="form-control" required readonly value="@(Model.Customer.Code+" - "+Model.Customer.ArName)" />
                                        }
                                        else
                                        {
                                            <input type="text" id="CustomerId" class="form-control" required readonly hidden />
                                            <input type="text" id="CustomerArName" class="form-control" required readonly />
                                        }
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label class=" col-sm-2 control-label">@MyERP.Properties.Resources.CustomerTel</label>
                                    <div class="col-sm-4">
                                        @if (Model != null && Model.CustomerId > 0)
                                        {
                                            <input type="text" id="CustomerMobile" class="form-control" required value="@(Model.Customer.Mobile)" />
                                        }
                                        else
                                        {
                                            <input type="text" id="CustomerMobile" class="form-control" required />
                                        }
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>

                                <div class="form-group row">
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.Building</label>
                                    <div class="col-sm-4">
                                        @if (Model != null && Model.BuildingId > 0)
                                        {
                                            <input type="text" value="@Model.BuildingId" id="BuildingId" class="form-control" required readonly hidden />
                                            <input type="text" id="BuildingArName" class="form-control" required readonly value="@(Model.Building.Code + " - " + Model.Building.ArName)" />
                                        }
                                        else
                                        {
                                            <input type="text" id="BuildingId" class="form-control" required readonly hidden />
                                            <input type="text" id="BuildingArName" class="form-control" required readonly />
                                        }
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label class=" col-sm-2 control-label" for="Id">@MyERP.Properties.Resources.Room</label>
                                    <div class="col-sm-4">
                                        @if (Model != null && Model.RoomId > 0)
                                        {
                                            <input type="text" value="@Model.RoomId" id="RoomId" class="form-control" required readonly hidden />
                                            <input type="text" id="RoomNumber" class="form-control" required readonly value="@(Model.Room.Code + " - " + Model.Room.RoomNumber)" />
                                        }
                                        else
                                        {
                                            <input type="text" id="RoomId" class="form-control" required readonly hidden />
                                            <input type="text" id="RoomNumber" class="form-control" required readonly />
                                        }
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.Insurance</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.Insurance, new { htmlAttributes = new { @class = "form-control money", @type = "text", @required = "required", @readonly = "readonly" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.InsuranceDeduction</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.InsuranceDeduction, new { htmlAttributes = new { @class = "form-control money", @type = "text", @required = "required", @Value = 0.00 } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.RemainingToCustomer</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.Remain, new { htmlAttributes = new { @class = "form-control money", @type = "text", @required = "required", @readonly = "readonly" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label class="control-label col-sm-2" for="ResponsibleEmployeeId">@MyERP.Properties.Resources.ResponsibleEmployee</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownListFor(model => model.ResponsibleEmployeeId, null, null, htmlAttributes: new { @class = "form-control", required = "required" })
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="control-label col-sm-2" for="Notes">@MyERP.Properties.Resources.Notes</label>
                                    <div class="col-sm-4">
                                        <textarea id="Notes" name="Notes" class="form-control" rows="5" cols="5">@if (Model != null) { @Model.Notes; }</textarea>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-sm-offset-2">
                    @if (Model == null)
                    {
                        <button onclick="addEdit('new');" class="btn btn-success" id="newbtn">
                            @MyERP.Properties.Resources.SaveAndNew
                        </button>
                        <button onclick="addEdit();" class="btn btn-success" id="save">
                            @MyERP.Properties.Resources.Save
                        </button>
                        <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                    }
                    else if (Model.IsDeleted == false)
                    {
                        <button onclick="addEdit();" class="btn btn-success" id="save">
                            @MyERP.Properties.Resources.Save
                        </button>
                        <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                        <a href="javascript:void(0);" class="btn btn-danger" onclick="Delete(@Model.Id)" role="button">@MyERP.Properties.Resources.Delete</a>
                    }
                </div>
            </div>
            <!-------------------------------------------------------------------------------------------------------->
        </div>
    </div>
</div>
<!------------------------ Journal Entry ------------------------->
@if (Model != null)
{
    if (ViewBag.JE != null)
    {
        <div class="card">
            <div class="card-body">
                <h5 class="header-title">@MyERP.Properties.Resources.JournalEntries</h5>
                <div class="form-horizontal">
                    <div class="form-group row">
                        <label for="inputtext3" class="col-sm-2 control-label">@MyERP.Properties.Resources.VoucherNo</label>
                        <div class="col-sm-4">
                            <input type="text" class="form-control" name="txtDocNo" value="@ViewBag.JE.DocumentNumber" id="txtDocNo" placeholder=@MyERP.Properties.Resources.VoucherNo disabled>

                        </div>
                        <label for="inputtext3" class="col-sm-2 control-label">@MyERP.Properties.Resources.Date </label>
                        <div class="col-sm-4">
                            <input type="datetime-local" class="form-control" name="dtDate" value="@ViewBag.Date" id="dtDate" placeholder=@MyERP.Properties.Resources.ReleaseDate required disabled>
                        </div>

                    </div>
                    <div class="form-group row">

                        <label for="inputtext3" class="col-sm-2 control-label">@MyERP.Properties.Resources.Branch</label>
                        <div class="col-sm-4">
                            @Html.DropDownList("DepartmentId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", id = "DepartmentId", @required = "required", @disabled = "disabled" })
                        </div>

                    </div>
                    <div class="form-group row">
                        <label for="inputtext3" class="col-sm-2 control-label">@MyERP.Properties.Resources.Notes</label>
                        <div class="col-sm-4">
                            <textarea type="text" class="form-control validate[required]" id="txtNotes" value="@ViewBag.JE.Notes" name="txtNotes" placeholder=@MyERP.Properties.Resources.Notes disabled></textarea>
                        </div>

                    </div>
                    <div class="card">
                        <div class="card-body">
                            <h5 class="header-title"> @MyERP.Properties.Resources.JournalEntryDetails</h5>
                            <div class="table-responsive">
                                <table class="table table-centered mb-0">
                                    <thead>
                                        <tr>
                                            <th>@MyERP.Properties.Resources.Debit</th>
                                            <th>@MyERP.Properties.Resources.Credit</th>
                                            <th>@MyERP.Properties.Resources.Account</th>
                                            <th>@MyERP.Properties.Resources.CostCenter</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model.Id != 0)
                                        {
                                            foreach (var jED in ViewBag.JEDetails)
                                            {
                                                <tr>
                                                    <td>
                                                        <label>@jED.Debit</label>
                                                        <input type='text' class='txtDebit' value="@jED.Debit" hidden>
                                                    </td>
                                                    <td>
                                                        <label>@jED.Credit</label>
                                                        <input type='text' class='txtCredit ' value="@jED.Credit" hidden>
                                                    </td>
                                                    <td>
                                                        @if (jED.AccountId != null)
                                                        {
                                                            <label>@jED.ChartOfAccount.ArName</label>
                                                            <input type='number' class='AccountId' value="@jED.AccountId" hidden>
                                                        }

                                                    </td>
                                                    <td>
                                                        @Html.Raw(jED.CostCenter != null ? jED.CostCenter.ArName : null)
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
}
<!-------------------------------------------------------------------------------------------------------->
<!--- Modal Section ---->
<div class="modal fade bs-example-modal-lg" id="CustomerReservationModal" tabindex="-1" role="dialog" aria-labelledby="salesInvoicesModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-scrollable modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title" id="salesInvoicesModalTitle">@MyERP.Properties.Resources.CustomerRoomReservation</h4>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="row form-group">
                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.Customer</label>
                    <div class="col-sm-4">
                        @Html.DropDownList("CustomerIdPopUp", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })
                    </div>
                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.CustomerTel</label>
                    <div class="col-sm-4">
                        <input type="text" class="form-control" id="CustomerMobilePopUp" />
                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-12">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>@MyERP.Properties.Resources.ReservationNumber</th>
                                    <th>@MyERP.Properties.Resources.BookingStartDate</th>
                                    <th>@MyERP.Properties.Resources.BookingEndDate</th>
                                    <th>@MyERP.Properties.Resources.Building</th>
                                    <th>@MyERP.Properties.Resources.Room</th>
                                    <th>@MyERP.Properties.Resources.Add</th>
                                </tr>
                            </thead>
                            <tbody id="CustomerReservation">
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="modal-footer" id="Footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">@MyERP.Properties.Resources.Close</button>
            </div>
        </div>
    </div>
</div>
<!-------------------------------------------------------------------------------------------------------->

<script>

    //--------------- Variables Declarations -------------------//

    //*********************************************************//
    //--------------- Ready Function -------------------//
    $(document).ready(function () {
        $('#VoucherDate').val('@ViewBag.VoucherDate');
        $.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
            $("input[type|='datetime-local']").prop('min', r.PeriodStart).prop('max', r.PeriodEnd);
        });
        if ($('#Id').val()) {
            var code = $('#DocumentNumber').val();
            $('#DocumentNumbers').val(code.replaceAll("-", ""));
            $("#DepartmentId").prop('disabled', true);
            $("#VoucherDate").prop('disabled', true);
            $("#RoomBookingId").prop('disabled', true);
           // $('#CustomerIdPopUp').trigger('change');
        }
        else {
            SetDocNum();
            cashBoxByDepartment();
            GetRoomBookingDetails();
        }
    });
    //*********************************************************//
    //--------------- Event Functions -------------------//

    $(document).on('change', "#DepartmentId", function () {
        SetDocNum();
        cashBoxByDepartment();
    });
    $(document).on('change', "#RoomBookingId", function () {
        GetRoomBookingDetails();
    });
    $(document).on('change', "#InsuranceDeduction", function () {
        var Insurance = $('#Insurance').inputmask('unmaskedvalue');
        var InsuranceDeduction = $('#InsuranceDeduction').inputmask('unmaskedvalue');
        var Remain = Insurance - InsuranceDeduction;
        Remain = Remain > 0 ? Remain : 0.00;
        $('#Remain').val(Remain);
    });

    $(document).on('change', "#CustomerIdPopUp", function () {
        let customerId = $(this).val();
        GetCustomerDetails(customerId,null);
    });
    $(document).on('keydown', '#CustomerMobilePopUp', function (e) {
        if (e.which == 13 || e.keyCode == 13) {
            let mobileNo = $(this).val();
            GetCustomerDetails(null, mobileNo);
        }
    });
    $(document).on('change', '#VoucherDate', function () {
        if (!$('#Id').val()) {
            SetDocNum();
        }
    });
    //*********************************************************//
     //--------------- Other Functions -------------------//
    function SetDocNum() {
        var doc = $.get('/RoomLeavePermission/SetDocNum?id=' + $('#DepartmentId').val() + '&VoucherDate=' + $('#VoucherDate').val()).done(function (r) {
            $('#DocumentNumber').val(r);
            $('#DocumentNumbers').val(r.replaceAll("-", ""));
        });
    }
    function zeroPadded(val) {
        if (val >= 10)
            return val;
        else
            return '0' + val;
    }
    function convertToJavaScriptDate(value) {
        if (value === null)
            return null;
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        return ((dt.getMonth() + 1 + "/" + dt.getDate() + "/" + dt.getFullYear()));
    }
    function deleteElement(e) {
        let tr = $(e).closest('tr');
        if ($(tr).index() == 0 && $(tr).closest('tbody').children('tr').length == 1) {
            $(tr).find("input").val('');
            $(tr).find("label").text('');
            $(tr).find('input, select').removeAttr('required');
            // $(tr).find('select').empty();
            $(tr).find('select').prop('selectedIndex', 0);
            $(tr).find('select').select2();
        }
        else if ($(tr).index() < $(tr).closest('tbody').children('tr').length - 1)
            e.parentNode.parentNode.parentNode.removeChild(e.parentNode.parentNode);
        else if ($(tr).index() == $(tr).closest('tbody').children('tr').length - 1) {
            $(tr).find("input").val('');
            $(tr).find('input, select').removeAttr('required');
           // $(tr).find('select').empty();
            $(tr).find('select').prop('selectedIndex', 0);
            $(tr).find('select').select2();
            $(tr).find("label").text('');
        }
    }
    function cashBoxByDepartment() {
        $.get('/Helper/CashBoxByDepartment/' + $('#DepartmentId').val()).done(function (r) {
            $('#CashBoxId').empty();
          //  $('#CashBoxId').append('<option value>'+'@MyERP.Properties.Resources.Select' +'</option>');
            for (var i = 0; i < r.length; i++) {
                $('#CashBoxId').append($('<option>', {
                    value: r[i].Id,
                    text: r[i].ArName
                }));
            }
        });
    }
    function GetRoomBookingDetails() {
        $.get('/RoomLeavePermission/GetRoomBookingDetails?RoomBookingId=' + $('#RoomBookingId').val()).done(function (r) {
            $('#BuildingArName').val(r.BuildingArName);
            $('#BuildingId').val(r.BuildingId);
            $('#CustomerArName').val(r.CustomerArName);
            $('#CustomerMobile').val(r.CustomerMobile);
            $('#CustomerId').val(r.CustomerId);
            $('#RoomId').val(r.RoomId);
            $('#RoomNumber').val(r.RoomNumber);
            $('#Insurance').val(r.Insurance);
            //$('#InsuranceDeduction').val(r.Insurance);
            $('#InsuranceDeduction').trigger('change');
        });
    }
    let CustomerDetails = [];
    function GetCustomerDetails(CustomerId, MobileNo) {
        $('#CustomerReservation').empty();
        $('#CustomerMobilePopUp').empty();

        $.get('/RoomLeavePermission/GetCustomerDetails?CustomerId=' + CustomerId + '&MobileNo=' + MobileNo).done(function (r) {
            if (r.length > 0) {
                CustomerDetails = r;
                for (var i = 0; i < r.length; i++) {
                    $('#CustomerMobilePopUp').val(r[0].CustomerMobile);
                    r[i].BookingStartDate = r[i].BookingStartDate != null ? convertToJavaScriptDate(r[i].BookingStartDate) : "";
                    r[i].BookingEndDate = r[i].BookingEndDate != null ? convertToJavaScriptDate(r[i].BookingEndDate) : "";
                    let tr = ' <tr><td><label class="control-label RoomBookingDocumentNumber">' +
                        r[i].RoomBookingDocumentNumber + '</label></td><td><label class="control-label BookingStartDate">' +
                        r[i].BookingStartDate + '</label></td><td><label class="control-label BookingEndDate">' +
                        r[i].BookingEndDate + '</label></td><td><label class="control-label BuildingArName">' +
                        r[i].BuildingArName + '</label></td><td><label class="control-label RoomNumber">' +
                        r[i].RoomNumber + '</label></td><td><button class="btn btn-primary" onclick="AddCustomerDetails(' + r[i].RoomBookingId + ')"> @MyERP.Properties.Resources.Add </button></td></tr>';
                    $('#CustomerReservation').append(tr);
                }
            }
            else {
                Swal.fire({
                    title: '@MyERP.Properties.Resources.ThereIsNoRoomReservationForThisCustomer',
                    text: " ",
                    icon: 'info',
                    showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    confirmButtonColor: '#3085d6'
                });
            }
        });
    }
    function AddCustomerDetails(RoomBookingId) {
        let RoomBooking = CustomerDetails.filter(function (i) { return i.RoomBookingId == RoomBookingId })[0];
        $('#BuildingArName').val(RoomBooking.BuildingArName);
        $('#BuildingId').val(RoomBooking.BuildingId);
        $('#CustomerArName').val(RoomBooking.CustomerArName);
        $('#CustomerMobile').val(RoomBooking.CustomerMobile);
        $('#CustomerId').val(RoomBooking.CustomerId);
        $('#RoomId').val(RoomBooking.RoomId);
        $('#RoomNumber').val(RoomBooking.RoomNumber);
        $('#Insurance').val(RoomBooking.Insurance);
        //$('#InsuranceDeduction').val(RoomBooking.Insurance);
        $('#InsuranceDeduction').trigger('change');
        $('#CustomerReservationModal').modal('hide');
    }
    //*********************************************************//
    function addEdit(n) {
        let valid = true;
        if ($('.form-horizontal').first().find('.form-control:invalid').length > 0) {
            $('.form-horizontal').first().addClass('was-validated');
            $('html, body').animate({
                scrollTop: $('.form-horizontal').first().find(".form-control:invalid").eq(0).offset().top - 100
            }, 500);
            valid = false;
            console.log($(".form-control:invalid"));
        }

        var RoomLeavePermission = {
            Id: $('#Id').val(),
            DocumentNumber: $('#DocumentNumber').val(),
            VoucherDate: $('#VoucherDate').val(),
            RoomBookingId: $('#RoomBookingId').val(),
            DepartmentId: $('#DepartmentId').val(),
            CashBoxId: $('#CashBoxId').val(),
            CustomerId: $('#CustomerId').val(),
