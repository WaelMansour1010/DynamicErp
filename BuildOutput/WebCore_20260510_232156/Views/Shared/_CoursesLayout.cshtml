    <script>
        var requestCache = {};

        function requestData(apiUrl) {
            if (!requestCache[apiUrl]) {
                requestCache[apiUrl] = $.get(apiUrl);
            }
            return requestCache[apiUrl];
        }
        @*function GetCourses() {
            $('#CoursesDiv').empty();
            $.get('/Courses/GetCourses').done(function (r) {
                if (r.length) {
                    for (var i = 0; i < r.length; i++) {
                        r[i].ArName = r[i].ArName != null ? r[i].ArName : "";
                        r[i].Notes = r[i].Notes != null ? r[i].Notes : "";
                        r[i].NoOfLessons = r[i].NoOfLessons != null ? r[i].NoOfLessons : "";
                        r[i].Image = r[i].Image != null ? "<img src ='" + r[i].Image + "' alt='' style='height:300px;' />" : "<img src ='/assets/images/users/Avatar_User.png' alt='' style='height:300px;' />";
                        let elem = '<div class="properties pb-20"><div class="properties__card" ><div class="properties__img overlay1"><a href="/Courses/Course?Id=' +
                            r[i].Id + '">' +
                            r[i].Image + '</a></div><div class="properties__caption"><h3 class="course-name" > <a href="/Courses/Course?Id=' +
                            r[i].Id + '">' +
                            r[i].ArName + '</a></h3><p>' +
                            r[i].Notes + '</p><div class="properties__footer d-flex justify-content-between align-items-center"><div class="price lecture-number"><h3>@MyERP.Properties.Resources.NoOfLectures</h3><p><span> ' +
                            r[i].NoOfLessons + ' </span><span>@MyERP.Properties.Resources._Lecture</span></p></div></div><a href="/Courses/Course?Id=' +
                            r[i].Id + '" class="border-btn border-btn2">@MyERP.Properties.Resources.ShowAllDetails</a></div ></div ></div > ';
                        $('#CoursesDiv').append(elem);
                    }
                }
            });
        }*@


        function changeLaguage() {
            requestData('/Helper/ChangeLanguage').done(function (r) {
                window.location.reload();
            });

        }
        let UseItemUnitSession = [];
        let Modules = [];
        //---------- to get active modules and shown them in sidemenue
        $.get('/Helper/GetNotActiveModules').done(function (r) {
            Modules = r;
            $('#side-menu li').each(function () {
                if ($(this).find('input').val() > 0) {//skip dashboard
                    var InputValue = $(this).find('input').val();
                    let module = Modules.filter(function (i) { return i.Id == InputValue; })[0];
                    if (module != undefined) {

                        if (InputValue == module.Id) {
                            $(this).show();
                        }
                    }
                    else {
                        $(this).hide();
                    }
                }
            })
        });
        function searchSideMenu() {
            var name = $('#side-menu-search').val();

            $('#side-menu > li > a').each(function () {
                if ($(this).text().indexOf(name.trim()) > -1) {
                    $(this).show();

                } else {
                    $(this).hide();
                }
            });
            $('#side-menu > li > ul > li >  a').each(function () {
                if ($(this).text().indexOf(name.trim()) > -1) {
                    $(this).show();
                    $(this).closest('#find > li').find('a:first').show();
                } else {
                    $(this).hide();
                }

            });
            $('#side-menu > li > ul > li > ul > li > a').each(function () {
                if ($(this).text().indexOf(name.trim()) > -1) {
                    $(this).show();
                    $(this).closest('#side-menu > li > ul > li').find('a:first').show();
                    $(this).closest('#side-menu > li').find('a:first').show();
                } else {
                    $(this).hide();
                }
            });
        }

        function matchCustom(params, data) {
            if ($.trim(params.term) === '') {
                return data;
            }
            if (typeof data.text === 'undefined') {
                return null;
            }
            var termCount = params.term.trim().split(' ').length;
            var matchCount = 0;
            for (var i = 0; i < termCount; i++) {
                var term = params.term.trim().split(' ')[i];
                for (var j = 0; j < data.text.trim().split(' ').length; j++) {
                    if (data.text.trim().split(' ')[j].toUpperCase().indexOf(term.toUpperCase()) > -1) {
                        matchCount++;
                        if (matchCount == termCount)
                            return data;
                    }
                }
            }
            return null;
        }
        $('[data-plugin="switchery"]').each(function (t, e) { new Switchery($(this)[0], $(this).data()) });
        $("select:not(#ShowByPage):not(#pagination)").select2({
            matcher: matchCustom
        });

        $('.money').inputmask({
            alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, 'allowMinus': false, digitsOptional: false, 'placeholder': '0'
        });

        $("form button[type|='submit']:not(.search)").on('click', function () {
            let form = $(this).closest('form');
            if (form.find('input:invalid, select:invalid').length == 0)
                if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToSave')) {
                    return true;
                    $('#preloader, #status').fadeIn();
                } else {
                    return false;
                }
            else
                $('html, body').animate({
                    scrollTop: form.find(".form-control:invalid").eq(0).offset().top - 100
                }, 500);
        });
        $("form").submit(function () {
            $('.money').each(function () {
                var val = $(this).inputmask('unmaskedvalue');
                $(this).inputmask('remove');
                $(this).val(val);
            });
        });

        $(document).on('focus', 'input[type=number]', function (e) {
            $(this).on('mousewheel.disableScroll', function (e) {
                e.preventDefault()
            })
        });
        $(document).on('blur', 'input[type=number]', function (e) {
            $(this).off('mousewheel.disableScroll')
        });

        //mask for input type number
        $('input[type=number]').not('#IdentityNumber').not('#InstallmentPaymentCount').not('#txtPoints').not('#servicesPrice').removeProp('oninput').prop('type', 'text').inputmask({
            alias: 'numeric', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
        });
        $('input.small-number').not('#InstallmentPaymentCount').not('#txtPoints').not('#servicesPrice').removeProp('oninput').prop('type', 'text').inputmask({
            alias: 'numeric', autoGroup: true, digits: 4, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
        });
        setInterval(function () {
            getNotifications();
            getOnlineUsers();
        }, 5000);

        function getNotifications() {
            $.get('/OccuredNotifications/Notifications').done(function (r) {
                $('#user-notifications').empty().append(r.notifications);
                if (r.count * 1 > 0)
                    $('#user-notifications').closest('li').find('.noti-icon-badge').text(r.count).show();
                $('#user-notifications').height(68 * r.count);

                $('#UnAcceptedCount').closest('li').find('.noti-icon-badge').text(r.UnAcceptedTransferCount).show();
                $('#UnAcceptedCount').text(r.UnAcceptedTransferCount);
            });
        }
        getNotifications();

        function notificationRead(id) {
            $.post('/OccuredNotifications/NotificationRead/' + id);
            getNotifications();
        }
        function getOnlineUsers() {
            $.get('/LogIn/OnlineUsers').done(function (result) {
                $("#OnlineUser").empty();
                for (var i = 0; i < result.length; i++) {
                    if (result[i].userimage == null) {
                        $("#OnlineUser").append("<div class='row'style='padding: 5%;'><img style='border-radius: 30%;width: 30px; height: 30px;' src='/assets/images/users/Avatar_User.png'/><div class='col-md-6'><span class='col-md-4' style='text-align:center;'>" + result[i].UserName + "</span><br/><span>" + result[i].EmployeeName + "</span></div></div>");
                    } else {
                        $('#UserPhoto').src =
                            $("#OnlineUser").append("<div class='row'style='padding: 5%;'><img style='border-radius: 30%;width: 30px; height: 30px;'src='" + result[i].userimage + "'/><div class='col-md-6'><span class='col-md-4' style='text-align:center;'>" + result[i].UserName + "</span><br/><span>" + result[i].EmployeeName + "</span></div></div>");
                    }
                }
            });
        }

        $.get('/Helper/GetSystemSetting').done(function (result) {
            UseItemUnitSession = result.UseItemUnit;
            window.sessionStorage.setItem("UseItemUnit", UseItemUnitSession);
        });
        $(document).ready(() => {
            requestData('/Helper/GetUserImage').done(function (r) {
                if (r != null)
                    $('#UserImage').attr('src', r);
            });

            requestData('/Helper/GetSystemSetting').done(function (r) {
                if (r.AllowSalesOrderInPos != true) {
                    $('.salesOrder').hide();
                }
                if (r.WorkingWithTheEgyptianVacationSystem != true) {
                    $('.WorkingWithTheEgyptianVacationSystem').hide();
                }
            });
        });
        ////adjust paging appearance
        $('.pagination').css("display", "flex");
        $('.pagination').css("flex-wrap", "wrap");
    </script>


