@model IEnumerable<MyERP.Models.StockTransferVoucher>

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";

    ViewBag.Title = MyERP.Properties.Resources.StockTransferVoucher;
}

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <a class="btn btn-info" href="@Url.Action("AddEdit")" role="button" style="float:left;">@MyERP.Properties.Resources.AddNew</a>
            </div>
            <div class="page-title">@MyERP.Properties.Resources.StockTransferVoucher</div>
        </div>
    </div>
</div>
<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal" role="form">
                        <div class="form-group row">
                            <div class="col-xs-12 col-sm-6 col-lg-3">
                                <input type="text" class="form-control searchtxt" value="@Html.Raw(ViewBag.searchWord)" placeholder=@MyERP.Properties.Resources.Search>
                            </div>
                            <div class="col-xs-12 col-sm-3 col-lg-3">
                                <button type="button" class="btn btn-success btnSearch" onclick="searchWord = $('.searchtxt').val(); paging();">
                                    <i class="fa fa-search"></i>
                                </button>
                                <button type="button" class="btn btn-info btnSearch" onclick="pageNo = 1; searchWord=''; paging();">
                                    <i class="fe-refresh-ccw"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-12">
                    <div class="table-responsive">
                        <table class="table table-striped table-centered mb-0">
                            <thead>
                                <tr>
                                    <th>
                                        @MyERP.Properties.Resources.DocNo
                                    </th>
                                    <th>
                                        @MyERP.Properties.Resources.Date
                                    </th>

                                    @if ((bool)ViewBag.ShowCost)
                                    {
                                        <th>
                                            @MyERP.Properties.Resources.TotalCost
                                        </th>
                                    }
                                    <th>
                                        @MyERP.Properties.Resources.FromWarehouse
                                    </th>
                                    <th>
                                        @MyERP.Properties.Resources.ToWarehouse
                                    </th>
                                    <th>
                                        @MyERP.Properties.Resources.View
                                    </th>
                                    <th>
                                        @MyERP.Properties.Resources.Edit
                                    </th>
                                    <th>
                                        @MyERP.Properties.Resources.Delete
                                    </th>
                                    <th> @MyERP.Properties.Resources.HasBeenApproved</th>
                                    <th> @MyERP.Properties.Resources.Print</th>
                                </tr>
                            </thead>
                            <tbody id="Details">
                                @foreach (var item in Model)
                                {
                                <tr>
                                    <td>
                                        @*@Html.DisplayFor(modelItem => item.DocumentNumber)*@
                                        @Html.Raw(item.DocumentNumber.ToString().Replace("-", ""))
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.VoucherDate)
                                    </td>
                                    @if ((bool)ViewBag.ShowCost)
                                    {
                                        <td>
                                            @Html.DisplayFor(modelItem => item.TotalCostPrice)
                                        </td>
                                    }

                                    <td>
                                        @Html.DisplayFor(modelItem => item.Warehouse.ArName)
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.Warehouse1.ArName)
                                    </td>
                                    <td>
                                       
                                        <a href="#" onclick="ShowDetails(@item.Id)">
                                            <i class="fa fa-eye"></i>
                                        </a>
                                    </td>
                                        <td>
                                            <a href="@Url.Action("AddEdit","StockTransferVoucher",new { id=item.Id })" onclick="$('#preloader, #status').fadeIn();">
                                                <i class="fa fa-edit"></i>
                                            </a>
                                        </td>
                                        <td>
                                            <a href="javascript:void(0);" onclick="DeleteFunc(@item.Id)">
                                                <i class="fas fa-trash-alt"></i>
                                            </a>
                                        </td>
                                        <td>
                                            @if (item.IsAccepted == true)
                                            {
                                                <i class="fe-check-circle"></i>
                                            }
                                        </td>
                                        <td>
                                            <a href="@Url.Action("StockTransferVoucher","Report",new { id=item.Id,print=true})" target="_blank">
                                                <i class="remixicon-printer-fill"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<div style="text-align:center;margin-bottom: 50px;">

    <div class="form-group row">
        <div class="col-sm-4">
            <select id="ShowByPage" class="form-control" style="width:70px;float:left;" onchange="paging()">
                <option value="10">10</option>
                <option value="30">30</option>
                <option value="50">50</option>
                <option value="100">100</option>
                <option value="200">200</option>
                <option value="@ViewBag.Count"> @MyERP.Properties.Resources.All</option>
            </select>
            <span style="font-size:12px;float:right;"> @MyERP.Properties.Resources.NoOfResults : <span id="RowsCount">@ViewBag.Count</span></span>
        </div>
        <div class="col-sm-2">
            <lablel class="col-sm-8">  @MyERP.Properties.Resources.PageNo: </lablel>
        </div>
        <div class="col-sm-2">
            <select id="pagination" class="pagination form-control" style="width:70px;float:left;">
            </select>
        </div>
    </div>
</div>


<div class="modal fade" id="DetailsModal" tabindex="-1" role="dialog"
     aria-labelledby="DetailsModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title" id="DetailsModalTitle">@MyERP.Properties.Resources.Details</h4>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-group row">
                    <label class=" col-sm-2 control-label">@MyERP.Properties.Resources.DocNo</label>
                    <div class="col-sm-4">
                        <label class=" col-sm-12 control-label" id="DocNo"></label>
                    </div>
                </div>
                <div class="form-group row">
                    <label class=" col-sm-2 control-label">@MyERP.Properties.Resources.FromWarehouse</label>
                    <div class="col-sm-4">
                        <label class=" col-sm-12 control-label" id="From"></label>
                    </div>
                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.ToWarehouse</label>
                    <div class="col-sm-4">
                        <label class="control-label col-sm-12" id="To"></label>
                    </div>
                </div>
                <table class="table table-centered mb-0">
                    <thead>
                        <tr>
                            <th>
                                @MyERP.Properties.Resources.Item
                            </th>
                            <th>
                                @MyERP.Properties.Resources.Qty
                            </th>
                            <th>
                                @MyERP.Properties.Resources.Unit
                            </th>
                        </tr>
                    </thead>
                    <tbody id="DetailsBody">
                    </tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">@MyERP.Properties.Resources.Close</button>
                <div id="AcceptBtn">
                </div>
            </div>
        </div>
    </div>
</div>


<script>
    var pageNo = 1;
    var searchWord = '@Html.Raw(ViewBag.searchWord)';
    $('#ShowByPage').val(@ViewBag.wantedRowsNo);

    function paging() {

        var link = '/StockTransferVoucher/Index?' + 'pageIndex=' + pageNo + '&wantedRowsNo=' + $('#ShowByPage').val() + '&searchWord=' + searchWord;
        window.location.replace(link);
    }

    function setPages() {
        var count =@ViewBag.Count;
        for (var i = 0; i < Math.ceil(count / $('#ShowByPage').val()); i++)
            $('#pagination').append('<option onchange="pageNo=' + (i + 1) + '; paging();" id="pg' + (i + 1) + '">' + (i + 1) + '</option>');
    }

    setPages();
   $('#pg' +@ViewBag.PageIndex).attr('selected', 'selected')

    $('#pagination').on('change', function () {
        pageNo = $('#pagination').val();
         paging();
    })

    function DeleteFunc(id) {
        Swal.fire({
            title: '@MyERP.Properties.Resources.AreYouSureYouWantToDelete',
            text: " ",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: '@MyERP.Properties.Resources.Ok',
            cancelButtonText: '@MyERP.Properties.Resources.Cancel',
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                $('#preloader, #status').fadeIn();
                $.ajax({
                    url: '/StockTransferVoucher/Delete',
                    type: 'POST',
                    data: {
                        "Id": id,
                    },
                    error: function (e) {
                        $('#preloader, #status').fadeOut();

                    },
                    success: function (r) {
                        if (r == 'true') {
                            window.location.reload();
                        }
                    }
                });
            }
            else { result.dismiss; }
        });

        @*if (confirm(' @MyERP.Properties.Resources.AreYouSureYouWantToDelete')) {
            $('#preloader, #status').fadeIn();
            $.ajax(
                {
                    url: '/StockTransferVoucher/Delete',
                    type: 'POST',
                    data: {
                        "Id": id,
                    },
                    error: function (e) {
                        $('#preloader, #status').fadeOut();

                    },
                    success: function (r) {
                        if (r == 'true') {
                            window.location.reload();
                        }
                    }
                });
        }*@
    }

    function acceptTransferVoucher(id) {
        Swal.fire({
            title: '@MyERP.Properties.Resources.YouWantToAccept',
            text: " ",
            icon: 'info',
            showCancelButton: true,
            confirmButtonText: '@MyERP.Properties.Resources.Ok',
            cancelButtonText: '@MyERP.Properties.Resources.Cancel',
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                $('#preloader, #status').fadeIn();
                $.post('/StockTransferVoucher/AcceptTransferVoucher?id=' + id).done(function (r) {
                    if (r.success == 'false' && r.cause == 'unauthorized') {
                        // alert('@MyERP.Properties.Resources.YouDoNotHavePermission' + '!');
                        Swal.fire({
                            title: '@MyERP.Properties.Resources.YouDoNotHavePermission' + '!',
                            text: " ",
                            icon: 'error',
                            showCancelButton: false,
                            confirmButtonText: '@MyERP.Properties.Resources.Ok',
                            confirmButtonColor: '#3085d6'
                        });
                    } else if (r.success == 'true') {
                        window.location.replace("/StockTransferVoucher");
                    } else
                        // alert("@MyERP.Properties.Resources.NotApproved" + "!");
                        Swal.fire({
                            title: '@MyERP.Properties.Resources.NotApproved' + '!',
                            text: " ",
                            icon: 'error',
                            showCancelButton: false,
                            confirmButtonText: '@MyERP.Properties.Resources.Ok',
                            confirmButtonColor: '#3085d6'
                        });
                    $('#preloader, #status').fadeOut();
                }).fail(function (r) {
                    $('#preloader, #status').fadeOut();
                    // alert("@MyERP.Properties.Resources.NotApproved" + "!");
                    Swal.fire({
                        title: '@MyERP.Properties.Resources.NotApproved' + '!',
                        text: " ",
                        icon: 'error',
                        showCancelButton: false,
                        confirmButtonText: '@MyERP.Properties.Resources.Ok',
                        confirmButtonColor: '#3085d6'
                    });
                });
            }
            else {
                result.dismiss;
                $('#preloader, #status').fadeOut();
                $('#DetailsModal').modal('hide');
            }
        });


        @*if (confirm('@MyERP.Properties.Resources.YouWantToAccept')) {
            $.post('/StockTransferVoucher/AcceptTransferVoucher?id=' + id).done(function (r) {
                if (r.success == 'false' && r.cause == 'unauthorized') {
                    alert('@MyERP.Properties.Resources.YouDoNotHavePermission' + '!');
                } else if (r.success == 'true') {
                    window.location.replace("/StockTransferVoucher");
                } else
                    alert("@MyERP.Properties.Resources.NotApproved" + "!");
                $('#preloader, #status').fadeOut();
            }).fail(function (r) {
                $('#preloader, #status').fadeOut();
                alert("@MyERP.Properties.Resources.NotApproved" + "!");
            });
        }
        else {
            $('#preloader, #status').fadeOut();
            $('#DetailsModal').modal('hide');
        }*@

    }

    function ShowDetails(id) {
        $('#DetailsBody').empty();
        $('#AcceptBtn').empty();
        $.get('/StockTransferVoucher/GetDetails?id=' + id).done(function (r) {
            var accept = r.Accept;
            r = r.details;
            for (var i = 0; i < r.length; i++) {
                let tr = '<tr><td>' + r[i].Item + '</td><td>' + r[i].Qty + '</td><td>' + r[i].Unit + '</td></tr >';
                $('#DetailsBody').append(tr);
            }
            if (r[0].IsAccepted != true && accept == "True") {
                    let btn = '<button class="btn btn-success" onclick="acceptTransferVoucher(' + id + ')">@MyERP.Properties.Resources.Accept</button>'
                    $('#AcceptBtn').append(btn);
                }
                $('#DocNo').text(r[0].DocumentNumber);
                $('#From').text(r[0].From);
                $('#To').text(r[0].To);
        });
        $('#DetailsModal').modal('show');
    }
</script>
