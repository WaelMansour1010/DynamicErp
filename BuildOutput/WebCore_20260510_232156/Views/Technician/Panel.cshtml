@model IEnumerable<MyERP.Models.GetTechnicianOrders_Result>

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = MyERP.Properties.Resources.TechnicianDistributionPanel;
}



<div class="row">
    <div class="col-12">
        <div class="page-title-box">

            <h4 class="page-title">@MyERP.Properties.Resources.TechnicianDistributionPanel</h4>
        </div>
    </div>
</div>



<!-- //**** NEW Code ****// -->
<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal needs-validation" role="form">
                        <div class="card">
                            <div class="card-body">
                                <h5 class="header-title">
                                    @MyERP.Properties.Resources.TechnicianDistributionPanel
                                </h5>
                                <div class="form-group row">
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.FromDate</label>
                                    <div class="col-sm-4">
                                        <input id="DateFrom" class="form-control" type="datetime-local" required />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.ToDate </label>
                                    <div class="col-sm-4">
                                        <input id="DateTo" class="form-control" type="datetime-local" required />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>


                                <div class="form-group row">
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.Technician</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("TechanicianId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <div class="col-sm-6">
                                        <button type="button" class="btn btn-success btnSearch" onclick="Panel()">
                                            <i class="fa fa-search"></i>
                                        </button>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>

                    <!-- Details Tablle  -->

                    <div class="card">
                        <div class="card-body">
                            <div id="accordion">
                                <h5 class=" pb-3 header-title">
                                    <a data-toggle="collapse" data-parent="#accordion" href="#collapse5">
                                        @MyERP.Properties.Resources.Details
                                    </a>
                                </h5>
                            </div>
                            <div id="collapse5">
                                <div class="row">
                                    <div class="col-12">
                                        <div class="table-responsive">
                                            <table class="table table-striped table-centered mb-0">
                                                <thead>
                                                    <tr>
                                                        <th>@MyERP.Properties.Resources.Technician</th>
                                                        <th>@MyERP.Properties.Resources.OrdersCount</th>
                                                        <th>@MyERP.Properties.Resources.View</th>

                                                    </tr>
                                                </thead>
                                                <tbody id="Details">
                                                    @if (Model != null)
                                                    {
                                                        foreach (var item in Model)
                                                        {
                                                    <tr>

                                                        <td> @item.EmployeeName </td>
                                                        <td> @item.OrderCount </td>
                                                        <td>
                                                            <a href="" data-toggle="modal" data-target="#OrderModel" onclick="ShowOrderDetails(@item.EmployeeId)">
                                                                <i class="fa fa-eye"></i>
                                                            </a>
                                                        </td>
                                                    </tr>
                                                        }
                                                    }
                                                </tbody>


                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ------------------ End Of Details Tablle --------------------  -->



                </div>
            </div>
        </div>
    </div>
</div>
