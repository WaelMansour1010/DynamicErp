<!--****************************************************************************-->

<script>
    function ShowOrderDetails(Id) {

        $('#OrderDetails').empty();
        $.get('/Technician/GetOrderDetails?TechanicianId=' + Id + '&DateFrom=' + $('#DateFrom').val() + '&DateTo=' + $('#DateTo').val()).done(function (r) {
            if (r.length > 0) {
                for (var i = 0; i < r.length; i++) {
                    r[i].MaintenanceDate = r[i].MaintenanceDate != null ? convertToJavaScriptDate(r[i].MaintenanceDate) : null;
                    r[i].CustomerName = r[i].CustomerName != null ? r[i].CustomerName : "";
                    r[i].CustomerAddress = r[i].CustomerAddress != null ? r[i].CustomerAddress : "";
                    r[i].CustomerMobile = r[i].CustomerMobile != null ? r[i].CustomerMobile : "";
                    r[i].OrderStatus = r[i].OrderStatus != null ? r[i].OrderStatus : "";

                    let tr = ' <tr><td hidden class="OrderId" >'+
                    r[i].OrderId+'</td><td class="OrderNumber">'+
                    r[i].OrderNumber+'</td><td class="MaintenanceDate">'+
                    r[i].MaintenanceDate+'</td><td class="OrderStatus" > '+
                    r[i].OrderStatus + '</td><td class="CustomerName">' +
                    r[i].CustomerName+'</td><td class="CustomerMobile">'+
                    r[i].CustomerMobile+'</td><td class="CustomerAddress">'+
                    r[i].CustomerAddress+'</td></tr>';
                    $('#OrderDetails').append(tr);

                }
            }
        });
    }
    //--------------- Variables Declarations -------------------//
    //*********************************************************//
    //--------------- Ready Function -------------------//
    $(document).ready(function () {
        $('#DateFrom').val('@ViewBag.DateFrom');
        $('#DateTo').val('@ViewBag.DateTo');
        $.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
            $("input[type|='datetime-local']").prop('min', r.PeriodStart).prop('max', r.PeriodEnd);
        });
        if ($('#Id').val()) {}else {}

    });
    //*********************************************************//
    //--------------- Event Functions -------------------//

    //*********************************************************//
    //--------------- Other Functions -------------------//
    function Panel() {
        var link = '/Technician/Panel?TechanicianId=' + $('#TechanicianId').val() + '&DateFrom=' + $('#DateFrom').val() + '&DateTo=' + $('#DateTo').val()+ '&Search=true';
        window.location.replace(link);
    }
    //------------------- ConvertDate-------------
    function convertToJavaScriptDate(value) {
        if (value === null)
            return null;
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        return ((dt.getMonth() + 1 + "/" + dt.getDate() + "/" + dt.getFullYear()));
    }
</script>
