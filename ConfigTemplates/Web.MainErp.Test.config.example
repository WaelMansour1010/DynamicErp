<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <connectionStrings>
    <add name="MainErp_ConnectionString"
         connectionString="Data Source=&lt;SQL_SERVER&gt;;Initial Catalog=&lt;MAINERP_TEST_DB&gt;;Integrated Security=True;MultipleActiveResultSets=True;TrustServerCertificate=True"
         providerName="System.Data.SqlClient" />
  </connectionStrings>
  <appSettings>
    <add key="EnableKishnyPos" value="false" />
    <add key="EnableMainErpMigration" value="true" />
    <add key="EnableDevStart" value="false" />
    <add key="EnableRunModeSelector" value="false" />
    <add key="EnableDevMasterPassword" value="false" />
  </appSettings>
  <system.web>
    <compilation targetFramework="4.8" debug="false" />
  </system.web>
</configuration>
