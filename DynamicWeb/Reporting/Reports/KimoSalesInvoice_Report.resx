  <data name="customSqlQuery1.Sql" xml:space="preserve">
    <value>select "SalesInvoiceDetails"."MainDocId",
	"SalesInvoiceDetails"."ItemId",
       "Item"."Code" as "ItemCode",
       "Item"."ArName" as "Item",
       "SalesInvoiceDetails"."Price"-ISNULL("SalesInvoiceDetails"."DiscountValue",0) "Price",
       "SalesInvoiceDetails"."Qty"  from "dbo"."SalesInvoiceDetails"
       "SalesInvoiceDetails"
  left join "dbo"."Item" "Item"
       on ("Item"."Id" = "SalesInvoiceDetails"."ItemId")
</value>
  </data>
  <data name="customSqlQuery2.Sql" xml:space="preserve">
    <value>select "PaymentMethod"."Id","SalesInvoicePaymentMethods"."SalesInvoiceId",
       "PaymentMethod"."ArName",
       "SalesInvoicePaymentMethods"."Amount"
  from ("dbo"."SalesInvoicePaymentMethods"
       "SalesInvoicePaymentMethods"
  left join "dbo"."PaymentMethod" "PaymentMethod"
       on ("PaymentMethod"."Id" = "SalesInvoicePaymentMethods"."PaymentMethodId"))</value>
  </data>
  <data name="customSqlQuery3.Sql" xml:space="preserve">
    <value>select  Sum ("SalesInvoicePaymentMethods"."Amount") as paid
  from ("dbo"."SalesInvoicePaymentMethods"
       "SalesInvoicePaymentMethods"
  left join "dbo"."PaymentMethod" "PaymentMethod"
       on ("PaymentMethod"."Id" = "SalesInvoicePaymentMethods"."PaymentMethodId"))
 
 where "PaymentMethod"."Id" in (1,3,4) and 
"SalesInvoiceId"=@id
</value>
  </data>
  <data name="customSqlQuery4.Sql" xml:space="preserve">
    <value>select  Sum ("SalesInvoicePaymentMethods"."Amount") as RestAmount
  from ("dbo"."SalesInvoicePaymentMethods"
       "SalesInvoicePaymentMethods"
  left join "dbo"."PaymentMethod" "PaymentMethod"
       on ("PaymentMethod"."Id" = "SalesInvoicePaymentMethods"."PaymentMethodId"))
 
 where "PaymentMethod"."Id" =2 and "SalesInvoiceId"=@id</value>
  </data>
