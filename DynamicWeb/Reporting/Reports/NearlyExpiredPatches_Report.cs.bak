    public NearlyExpiredPatches_Report(int? DaysNo, int? WarehouseId, DateTime? From, DateTime? To, int? DepartmentId, int? ActivityId, int? CompanyId)
    {

        InitializeComponent();
        User.Text = HttpContext.Current.User.Identity.Name;
        UserId.Value = int.Parse(((ClaimsIdentity)HttpContext.Current.User.Identity).FindFirst("Id").Value);

        var systemSetting = db.SystemSettings.FirstOrDefault();
        var numberOfDays = systemSetting.DaysNo;

        if (numberOfDays != null)
        {
            this.DaysNo.Value = numberOfDays;
        }
        else
        {
            this.DaysNo.Value = DaysNo;
        }
        this.DepId.Value = DepartmentId;
        this.WarehouseId.Value = WarehouseId;
        var helper = new HelperController().GetOpenPeriodBeginningEndingForReports();
        this.DateFrom.ValueInfo = /*From != null ?*/ From.ToString() /*: helper.start*/;
        this.DateTo.ValueInfo = /*To != null ?*/ To.ToString() /*: helper.end*/;
        this.ActivityId.Value = ActivityId;
        this.CompanyId.Value = CompanyId;
        //
        // TODO: Add constructor logic here
        //
    }

