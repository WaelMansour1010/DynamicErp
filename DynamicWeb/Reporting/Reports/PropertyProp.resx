  <data name="customSqlQuery2.Sql" xml:space="preserve">
    <value>WITH PropertyDetailAgg AS (
    SELECT 
        "MainDocId",
        COUNT(*) AS "TotalApartments",
        SUM(CASE WHEN "StatusId" &lt;&gt; 1 THEN 1 ELSE 0 END) AS "FreeApartments",
        MAX("RoomsNo") AS "RoomsNo"
    FROM "dbo"."PropertyDetail"
    GROUP BY "MainDocId"
),
PropertyContractAgg AS (
    SELECT 
        "PropertyId",
        MAX("RentValue") AS "RentValue"  -- Pick the highest rent value
    FROM "dbo"."PropertyContract"
    GROUP BY "PropertyId"
)
SELECT 
    P."ArName",
    P."ContractValueWithoutTax",
    COALESCE(PCA."RentValue", 0) AS "RentValue",
    P."PropertyStatusId",
    P."DepartmentId",
    COALESCE(PDA."RoomsNo", 0) AS "RoomsNo",
    COALESCE(PDA."TotalApartments", 0) AS "TotalApartments",
    COALESCE(PDA."FreeApartments", 0) AS "FreeApartments"
FROM "dbo"."Property" P
LEFT JOIN PropertyContractAgg PCA ON PCA."PropertyId" = P."Id"
LEFT JOIN PropertyDetailAgg PDA ON PDA."MainDocId" = P."Id"
ORDER BY P."ArName";</value>
  </data>
  <data name="customSqlQuery3.Sql" xml:space="preserve">
    <value>-- Declare the variables
DECLARE @RenterId INT;
DECLARE @OwnerId INT;
DECLARE @PropertyId INT;

-- Set the variables to NULL (or assign specific values if needed)
SET @RenterId = NULL;
SET @OwnerId = NULL;
SET @PropertyId = NULL;

-- CTE to calculate TotalRent for each building
WITH TotalRentCTE AS (
    SELECT 
        c.PropertyId,
        SUM(ISNULL(c.RentValue, 0)) AS TotalRent -- Calculate TotalRent for each building
    FROM PropertyContract c
    WHERE c.IsDeleted = 0
    GROUP BY c.PropertyId
),
-- CTE for PropertyDetailAgg
PropertyDetailAgg AS (
    SELECT 
        "MainDocId",
        COUNT(*) AS "TotalApartments",
        SUM(CASE WHEN "StatusId" &lt;&gt; 1 THEN 1 ELSE 0 END) AS "FreeApartments",
        MAX("RoomsNo") AS "RoomsNo"
    FROM "dbo"."PropertyDetail"
    GROUP BY "MainDocId"
),
-- CTE for PropertyContractAgg
PropertyContractAgg AS (
    SELECT 
        "PropertyId",
        MAX("RentValue") AS "RentValue",  -- Pick the highest rent value
        SUM("RentValue") AS "TotalRent"   -- Calculate TotalRent for each property
    FROM "dbo"."PropertyContract"
    GROUP BY "PropertyId"
)
-- Main query (keep all existing data and add TotalRent)
SELECT 
    P."ArName" AS Building,
    P."ContractValueWithoutTax",
    COALESCE(PCA."RentValue", 0) AS "RentValue",
    P."PropertyStatusId",
    P."DepartmentId",
    COALESCE(PDA."RoomsNo", 0) AS "RoomsNo",
    COALESCE(PDA."TotalApartments", 0) AS "TotalApartments",
    COALESCE(PDA."FreeApartments", 0) AS "FreeApartments",
    COALESCE(TR.TotalRent, 0) AS "TotalRent" -- Add TotalRent from the first query
FROM "dbo"."Property" P
LEFT JOIN PropertyContractAgg PCA ON PCA."PropertyId" = P."Id"
LEFT JOIN PropertyDetailAgg PDA ON PDA."MainDocId" = P."Id"
LEFT JOIN TotalRentCTE TR ON TR.PropertyId = P."Id" -- Join the TotalRentCTE to get TotalRent
WHERE P.IsDeleted = 0 
AND (@RenterId IS NULL OR EXISTS (
    SELECT 1 
    FROM PropertyContract c 
    WHERE c.PropertyId = P.Id 
    AND c.PropertyRenterId = @RenterId
))
AND (@OwnerId IS NULL OR EXISTS (
    SELECT 1 
    FROM PropertyContract c 
    WHERE c.PropertyId = P.Id 
    AND c.PropertyOwnerId = @OwnerId
))
AND (@PropertyId IS NULL OR P.Id = @PropertyId)
ORDER BY P."ArName";</value>
