@{
    UICulture = Session["lang"] != null?Session["lang"].ToString():"ar";
    ViewBag.Title = @MyERP.Properties.Resources.AccountStatement;
}
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <button class="btn btn-info " target="_blank" onclick="OpenReport()" role="button" style="float:left;">@MyERP.Properties.Resources.Print</button>
            </div>
            <div class="hed page-title">@MyERP.Properties.Resources.AccountStatement</div>
        </div>
    </div>
</div>
<div class="card-box">
    <div class="row">
        <div class="col-12">
            <div class="form-horizontal" role="form">
                <div class="form-group row">
                    <label for="AccountId" class="control-label col-sm-1"> @MyERP.Properties.Resources.Account</label>
                    <div class="col-sm-5">
                        @Html.DropDownList("AccountId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })
                    </div>
                </div>
                @*من غير تاريخ عشان الحسابات ممكن تيقى غلط*@
                @*<div class="form-group">
                        <label class="col-sm-1 control-label " for="DateFrom">من تاريخ</label>
                        <div class="col-sm-5">
                            <input id="DateFrom" class="form-control" type="datetime-local" />
                        </div>

                        <label class="col-sm-1 control-label " for="DateTo">الى تاريخ</label>
                        <div class="col-sm-5">
                            <input id="DateTo" class="form-control" type="datetime-local" />
                        </div>
                    </div>*@
                <div class="form-group">
                    <div class="col-sm-6">
                        <button class="btn btn-success" id="hideDetails">@MyERP.Properties.Resources.Total</button>

                        <button class="btn btn-success" id="showDetails">@MyERP.Properties.Resources.Detailed</button>

                    </div>

                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="table-responsive">
                <table class="table table-striped table-centered mb-0">
                    <thead>
                        <tr>
                            <th>
                                @MyERP.Properties.Resources.DebitOB
                            </th>
                            <th>
                                @MyERP.Properties.Resources.CreditOB
                            </th>
                            <th>
                                @MyERP.Properties.Resources.DebitPeriodBalance
                            </th>
                            <th>
                                @MyERP.Properties.Resources.CreditPeriodBalance
                            </th>
                            <th>
                                @MyERP.Properties.Resources.DebitBalance
                            </th>
                            <th>
                                @MyERP.Properties.Resources.CreditBalance
                            </th>
                        </tr>
                    </thead>
                    <tbody id="AccountStatement"></tbody>
                </table>
            </div>
        </div>
    </div>


    <div class="form-group">
        <label id="accountName" class="control-label col-sm-12"></label>
    </div>

    <div class="row AccountStatementDetails" style="display:none;">
        <div class="col-12">
            <div class="table-responsive">
                <table class="table table-striped table-centered mb-0">
                    <thead>
                        <tr>
                            <th>
                                @MyERP.Properties.Resources.Debit
                            </th>
                            <th>
                                @MyERP.Properties.Resources.Credit
                            </th>
                            <th>
                                @MyERP.Properties.Resources.TransactionType
                            </th>

                            <th>
                                @MyERP.Properties.Resources.VoucherNo
                            </th>
                            <th>
                                @MyERP.Properties.Resources.Date
                            </th>
                            <th>
                                @MyERP.Properties.Resources.TransactionNo
                            </th>

                        </tr>
                    </thead>
                    <tbody id="AccountStatementDetails"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>
<script>
    function zeroPadded(val) {
        if (val >= 10)
            return val;
        else
            return '0' + val;
    }

    $(document).ready(function () {
        $('#DateFrom').removeAttr('min').removeAttr('max');
        $('#DateTo').removeAttr('min').removeAttr('max');

        var d = new Date();
        $('#DateFrom').val('@ViewBag.DateFrom');
    $('#DateTo').val(d.getFullYear() + "-" + zeroPadded(d.getMonth() + 1) + "-" + zeroPadded(d.getDate()) + "T" + zeroPadded(d.getHours()) + ":" + zeroPadded(d.getMinutes()));
    });

    function GETAccountStatement() {
        $('#preloader, #status').fadeIn();
        var accStatement = $.get("/AccountStatement/GETAccountStatement?accId=" + $('#AccountId').val())
            .done(function () {
                $('#AccountStatement').html('');
                newHTML = '';
                accStatement = accStatement.responseJSON;
                for (var i = 0; i < accStatement.length; i++) {
                    newHTML += '<tr>' +
                        '<td>' + (accStatement[i].ObDebit?accStatement[i].ObDebit:'') + '</td>' +
                        '<td>' + (accStatement[i].ObCredit?accStatement[i].ObCredit:'') + '</td>' +
                        '<td>' + (accStatement[i].Debit?accStatement[i].Debit:'') + '</td>' +
                        '<td>' + (accStatement[i].Credit?accStatement[i].Credit:'') + '</td>' +
                        '<td>' + (accStatement[i].PostponedDebit?accStatement[i].PostponedDebit:'') + '</td>' +
                        '<td>' + (accStatement[i].PostponedCredit?accStatement[i].PostponedCredit:'') + '</td>' +

                        '</tr>';
                }
                $('#AccountStatement').append(newHTML);
                $('#preloader, #status').fadeOut();
            });

    }
    function OpenReport() {
        window.open("/Report/AccountStatementDetails/" + $('#AccountId').val())

    }
    function GETAccountStatementDetails() {
        $('#preloader, #status').fadeIn();
        $.get("/AccountStatement/GETAccountStatementDetails?accId=" + $('#AccountId').val())
            .done(function (r) {
                $('#AccountStatementDetails').empty().append(r);
                $('#preloader, #status').fadeOut();
            });

    }

    GETAccountStatement();
    GETAccountStatementDetails();

    $('#DateFrom').on('change', function () {
        GETAccountStatement();
        GETAccountStatementDetails();
    });

    $('#DateTo').on('change', function () {
        GETAccountStatement();
        GETAccountStatementDetails();
    });

    $('#AccountId').on('change', function () {
        GETAccountStatement();
        GETAccountStatementDetails();
        if($('#AccountId').val()>0)
            $('#accountName').val($('#AccountId option:selected').text());
    });

    $('#hideDetails').click(function () {
        $('.AccountStatementDetails').hide();
    });

    $('#showDetails').click(function () {
        $('.AccountStatementDetails').show();
    });
</script>