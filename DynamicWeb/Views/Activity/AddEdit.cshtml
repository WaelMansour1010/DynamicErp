@model MyERP.Models.Activity

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.Activities;
}
<script src="~/Scripts/SaveAndNew.js"></script>

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                @if (Model != null)
                {
                    if (Model.IsDeleted == false)
                    {
                        if (ViewBag.Previous > 0)
                        {
                            <a href="@Url.Action("AddEdit",new {id= ViewBag.First })" class="btn btn-info">@MyERP.Properties.Resources.First</a>
                            <a href="@Url.Action("AddEdit",new { id=ViewBag.Previous })" class=" btn btn-info">&#8250;</a>
                        }
                        if (ViewBag.Next > 0)
                        {
                            <a href="@Url.Action("AddEdit",new { id=ViewBag.Next })" class="btn btn-info">&#8249;</a>
                            <a href="@Url.Action("AddEdit",new {id=ViewBag.Last })" class="btn btn-info">@MyERP.Properties.Resources.Last</a>
                        }
                    }
                }
                <a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
            </div>
            <div class="hed page-title">@MyERP.Properties.Resources.Activities :</div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card-box">
            <form action="/Activity/AddEdit" class="form-horizontal needs-validation" novalidate method="post" enctype="multipart/form-data" id="FormId">
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">
                                <div class="form-group row">
                                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                    @Html.AntiForgeryToken()
                                    @if (Model != null)
                                    {

                                        @Html.HiddenFor(model => model.Id)
                                        @Html.HiddenFor(model => model.IsActive)
                                        @Html.HiddenFor(model => model.UserId)
                                        @Html.HiddenFor(model => model.Image)
                                        @Html.HiddenFor(model => model.IsDeleted)
                                    }

                                    <label for="inputtext3" class="col-sm-2 control-label">@MyERP.Properties.Resources.Code</label>
                                    <div class="col-sm-4">

                                        @if (Model != null)
                                        {
                                            @Html.EditorFor(model => model.Code, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.Code, @readonly = "readonly", required = "required" } })
                                        }
                                        else
                                        {
                                            @Html.EditorFor(model => model.Code, new { htmlAttributes = new { @class = "form-control", @Value = ViewBag.Code, placeholder = @MyERP.Properties.Resources.Code, @readonly = "readonly", required = "required" } })
                                        }
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.CodeRequired
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="inputtext3" class="col-sm-2 control-label"> @MyERP.Properties.Resources.ArName</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.ArName, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.ArName, required = "required" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.ArNameRequired
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="inputtext3" class="col-sm-2 control-label"> @MyERP.Properties.Resources.EnName</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.EnName, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.EnName } })
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="inputtext3" class="col-sm-2 control-label"> @MyERP.Properties.Resources.ResponsibleName</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.ResponsibleName, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.ResponsibleName, required = "required" } })
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="inputtext3" class="col-sm-2 control-label">@MyERP.Properties.Resources.Notes</label>
                                    <div class="col-sm-4">
                                        @Html.TextAreaFor(a => a.Notes, new { @class = "form-control", placeholder = @MyERP.Properties.Resources.Notes })
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    @* مكان الصورة *@
                                    @if (Model != null)
                                    {
                                        <div class="row p-3">
                                            <div class="col-md-6">
                                                <div class="form-group">
                                                    <div class="row text-center">
                                                        <label for="inputtext3" class="control-label">
                                                            @MyERP.Properties.Resources.CurrentPhoto
                                                        </label>
                                                    </div>
                                                    <div class="row">
                                                        <div class="col-sm-4">
                                                            @if (Model.Image != null)
                                                            {
                                                                <img style='height:100px;width:100px;border-radius: 50px;' class="imgold" src='@Model.Image' />

                                                            }

                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group">
                                                    <div class="row">
                                                        <label for="inputtext3" class="control-label">

                                                            @MyERP.Properties.Resources.SelectNew
                                                        </label>
                                                    </div>
                                                    <div class="row">
                                                        <div class="col-sm-4">
                                                            <input type="file" style="display: inline" onchange="readURL(this)" name="upload" class="photo" id="img" />
                                                            <img style='height:100px; width: 100px;  border-radius: 50px;' id="blah" src="#" alt="" class="hidden imgnew" />
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="form-group row">
                                            <label for="inputtext3" class="col-sm-4 control-label">
                                                @MyERP.Properties.Resources.SelectNew
                                            </label>
                                            <div class="col-sm-8">
                                                <input type="file" style="display: inline" onchange="readURL(this)" name="upload" photo" id="img" />
                                                <img style='height:100px;width:100px;border-radius: 50px;' id="blah" src="#" alt="" class="hidden imgnew" />
                                            </div>
                                        </div>
                                    }
                                </div>


                            </div>
                        </div>
                    </div>

                    <div class="row" style="float:left;">
                        <input id="new" name="newBtn" hidden />
                        <div>
                            @if (Model == null)
                            {
                                <input id="new" name="newBtn" hidden />
                                <button type="submit" id="newbtn" class="btn btn-success saveBtns">
                                    @MyERP.Properties.Resources.SaveAndNew
                                </button>
                                <button type="submit" class="btn btn-success saveBtns">
                                    @MyERP.Properties.Resources.Save
                                </button>
                                <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                            }
                            else
                            {
                                if (Model.IsDeleted == false)
                                {
                                    <button type="submit" class="btn btn-success">
                                        @MyERP.Properties.Resources.Save
                                    </button>
                                    <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                                    <a href="javascript:void(0);" class="btn btn-danger" onclick="Delete(@Model.Id)" role="button">@MyERP.Properties.Resources.Delete</a>
                                }
                            }
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<!--------------------------------------------- Modal Section ---------------------------------------------------------------->
<div class="modal fade" id="CheckPassWordModal" tabindex="-1" role="dialog" aria-labelledby="DiscountModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-scrollable" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title" id="DiscountModalTitle">@MyERP.Properties.Resources.ConfirmPassword</h4>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-group row">
                    <label class=" col-sm-6 control-label" for="EnName">@MyERP.Properties.Resources.PassWord </label>
                    <div class="col-sm-6">
                        <input type="password" class="form-control" id="Password" />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">@MyERP.Properties.Resources.Close</button>
                <button type="button" class="btn btn-primary waves-effect waves-light" data-dismiss="modal" onclick="CheckPassword()">@MyERP.Properties.Resources.Send</button>
            </div>
        </div>
    </div>
</div>
<!--------------------------------------------- End Of Modal Section ---------------------------------------------------------------->


<script>

//--------------- Variables Declarations -------------------//
    //*********************************************************//
    //--------------- Ready Function -------------------//
    $(document).ready(function () {
        if (!$('#Id').val()) {

            setCodeNum();
            $('#CheckPassWordModal').modal('show');
            $('.saveBtns').hide();
        }
    });
    //*********************************************************//
    //--------------- Event Functions -------------------//
    //*********************************************************//
     //--------------- Other Functions -------------------//
        function CheckPassword() {
        var Password = $('#Password').val();
        if (Password.length > 0) {
            $.get('/Helper/CheckCurrentUserPassWord?Password=' + Password).done(function (r) {
                if (r.success == "PasswordIncorrect") {
                    Swal.fire({
                        title: '@MyERP.Properties.Resources.PassWordNotMatched',
                        text: " ",
                        icon: 'info',
                        showCancelButton: false,
                        confirmButtonText: '@MyERP.Properties.Resources.Ok',
                        confirmButtonColor: '#3085d6'
                    });
                }
                else {
                    $('.saveBtns').show();
                }
            });
        }
        else {
            Swal.fire({
                title: '@MyERP.Properties.Resources.PassWordRequired',
                text: " ",
                icon: 'error',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        }
        $('#Password').val('');
    }
    function setCodeNum() {
        $.get('/Activity/SetCodeNum').done(function (r) {
            $('#Code').val(r);
        });
    }
    function Delete(id) {
        if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToDelete')) {
            $('#preloader, #status').fadeIn();
            $.ajax(
                {
                    url: '/Activity/Delete',
                    type: 'POST',
                    data: {
                        "Id": id,
                    },
                    error: function (e) {

                    },
                    success: function (r) {
                        if (r == 'true') {
                            window.location.replace('/Activity');
                        } else
                            alert('@MyERP.Properties.Resources.DeleteDoesNotSucceeded');
                        $('#preloader, #status').fadeOut();
                    }
                });
        }
    }

    //*********************************************************//
    $(".photo").change(function () {
        $(".imgold").addClass("hidden");
    });
    function readURL(input) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();

            reader.onload = function (e) {
                $(".imgnew").removeClass("hidden");

                $('#blah')
                    .attr('src', e.target.result)

            };

            reader.readAsDataURL(input.files[0]);
        }
    }
</script>

