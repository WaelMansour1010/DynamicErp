@model MyERP.Models.AttendAndLeaveApproval

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.AttendAndLeaveApproval;
}
<script src="~/js/DeleteFunctionForAddEditView.js"></script>
<script src="~/Scripts/SaveAndNew.js"></script>




@Html.AntiForgeryToken()
@Html.ValidationSummary(true, "", new { @class = "text-danger" })
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <a class="btn btn-info" href="@Url.Action("Index")" role="button" style="float:left;">@MyERP.Properties.Resources.Back</a>
            </div>
            <div class="hed page-title">
                @MyERP.Properties.Resources.AttendAndLeaveApproval:
            </div>
        </div>
    </div>
</div>
<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="form-horizontal needs-validation" role="form">
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">
                                <div class="form-group row">
                                    @if (Model != null)
                                    {
                                        @Html.HiddenFor(model => model.Id)
                                        @Html.HiddenFor(model => model.UserId)
                                        @Html.HiddenFor(model => model.Image)
                                        @Html.HiddenFor(model => model.IsPosted)
                                    }

                                    <label class=" col-sm-2 control-label" for="DocumentNumber">@MyERP.Properties.Resources.DocNo</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.DocumentNumber, new
                                       {
                                           htmlAttributes = new
                                           {
                                               @class = "form-control",
                                               @readonly = "readonly",
                                               required = "required"
                                          ,
                                                hidden = "hidden"
                                            }
                                        })
                                        <input id="DocumentNumbers" class="form-control" placeholder=@MyERP.Properties.Resources.DocNo required readonly />
                                    </div>
                                    <label class=" col-sm-2 control-label" for="Date">@MyERP.Properties.Resources.Date</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.Date, new { htmlAttributes = new { @class = "form-control Gregorian", required = "required", @type = "datetime-local" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class=" col-sm-2 control-label" for="Date">@MyERP.Properties.Resources.FromDate</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.DateFrom, new
                                   {
                                       htmlAttributes = new
                                       {
                                           @class = "form-control",
                                                required = "required",
                                                @type = "datetime-local"
                                       }
                                   })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label class=" col-sm-2 control-label" for="Date">@MyERP.Properties.Resources.ToDate</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.DateTo, new
                                   {
                                       htmlAttributes = new
                                       {
                                           @class = "form-control",
                                                required = "required",
                                                @type = "datetime-local"
                                       }
                                   })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class=" col-sm-2 control-label" for="DepartmentId">@MyERP.Properties.Resources.Department</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownListFor(a => a.DepartmentId, null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label class=" col-sm-2 control-label" for="EmployeeId">@MyERP.Properties.Resources.Employee</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownListFor(a => a.EmployeeId, null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>
                        <br />
                        <div class="card">
                            <div class="card-body">
                                <div class="table-responsive">
                                    <table class="table table-striped table-centered">
                                        <thead>
                                            <tr>
                                                <th>
                                                    @MyERP.Properties.Resources.Date
                                                </th>

                                                <th>
                                                    @MyERP.Properties.Resources.AttendTime
                                                </th>

                                                <th>
                                                    @MyERP.Properties.Resources.LeaveTime
                                                </th>

                                                <th>
                                                    @MyERP.Properties.Resources.Shift
                                                </th>

                                                <th>
                                                    @MyERP.Properties.Resources.FromTime
                                                </th>
                                                <th>
                                                    @MyERP.Properties.Resources.ToTime
                                                </th>

                                                <th>
                                                    @MyERP.Properties.Resources.Lateness
                                                </th>
                                                <th>
                                                    @MyERP.Properties.Resources.EarlyLeave
                                                </th>
                                                <th>
                                                    @MyERP.Properties.Resources.Absence
                                                </th>
                                                <th>
                                                    @MyERP.Properties.Resources.OverTime (@MyERP.Properties.Resources.Equi)
                                                </th>
                                                <th>
                                                    @MyERP.Properties.Resources.Rewards (@MyERP.Properties.Resources.Equi)
                                                </th>
                                                <th>
                                                    @MyERP.Properties.Resources.Penalties (@MyERP.Properties.Resources.Equi)
                                                </th>
                                                <th>
                                                    @MyERP.Properties.Resources.Action
                                                </th>
                                            </tr>
                                        </thead>
                                        <tbody id="AttendAndLeaveApprovalDetails">
                                            @if (Model != null)
                                            {
                                                foreach (var item in Model.AttendAndLeaveApprovalDetails)
                                                {
                                                    <tr>
                                                        <td>
                                                            <input class="EmployeeAttendAndLeaveId" hidden value="@item.EmployeeAttendAndLeaveId" />
                                                            <label class="EmployeeAttendAndLeaveDate">@item.EmployeeAttendAndLeaveDate</label>
                                                            <input hidden class="From-Time form-control EmployeeAttendAndLeaveDate1" value="@item.EmployeeAttendAndLeaveDate" />
                                                        </td>
                                                        <td>
                                                            <label class="EmployeeAttendTime">@item.EmployeeAttendTime</label>
                                                            <input class="From-Time form-control EmployeeAttendTime1" type="time" hidden value="@item.EmployeeAttendTime" />
                                                        </td>
                                                        <td>
                                                            <label class="EmployeeLeaveTime">@item.EmployeeLeaveTime</label>
                                                            <input hidden class="From-Time form-control EmployeeLeaveTime1" type="time" value="@item.EmployeeLeaveTime" />
                                                        </td>
                                                        <td>
                                                            <input hidden value="@item.ShiftId" class="ShiftId" />
                                                            <label class="ShiftArName">@item.ShiftArName</label>
                                                        </td>
                                                        <td>
                                                            <label class="ShiftStartTime">@item.ShiftStartTime</label>
                                                            <input class="From-Time form-control ShiftStartTime1" type="time" hidden value="@item.ShiftStartTime" />
                                                        </td>
                                                        <td>
                                                            <label class="ShiftEndTime">@item.ShiftEndTime</label>
                                                            <input hidden class="From-Time form-control ShiftEndTime1" type="time" value="@item.ShiftEndTime" />
                                                        </td>
                                                        <td>
                                                            <input class="EmployeeLatenessId" hidden value="@item.EmployeeLatenessId" />
                                                            <label class="EmployeeLateness">@item.EmployeeLatenessMinutes</label>
                                                        </td>
                                                        <td>
                                                            <label class="EmployeeEarlyLeaveMinutes">@item.EmployeeEarlyLeaveMinutes</label>
                                                        </td>
                                                        <td>
                                                            <input class="EmployeeAbsenceId" hidden value="@item.EmployeeAbsenceId" />
                                                            <input class="IsAbsence" type="checkbox" hidden @Html.Raw(Model != null && item.IsAbsence == true ? "checked" : "") />
                                                            @if (item.IsAbsence == true)
                                                            {
                                                                <i class="fe-check-circle"></i>
                                                            }
                                                        </td>
                                                        <td>
                                                            <input class="OvertimeIssueId" hidden value="@item.OvertimeIssueId" />
                                                            <input class="OvertimeIssueDetailsId" hidden value="@item.OvertimeIssueDetailsId" />
                                                            @if (Model.AttendAndLeaveApprovalDetails.Count > 0 && item.OvertimeIssueMinutes != null)
                                                            {
                                                                <label class="OvertimeIssueMinutes">@item.OvertimeIssueMinutes</label>
                                                            }
                                                            else
                                                            {
                                                                <label class="OvertimeIssueMinutes"> </label>
                                                            }
                                                        </td>
                                                        <td>
                                                            <input hidden value="@item.RewardIssueId" class="RewardIssueId" />
                                                            <input class="RewardIssueDetialsId" hidden value="@item.RewardIssueDetialsId" />
                                                            @if (Model.AttendAndLeaveApprovalDetails.Count > 0 && item.RewardIssueDetial !=null && item.RewardIssueDetial.Equivalent>0)
                                                            {
                                                                <label class="RewardIssueEquivalent">@item.RewardIssueDetial.Equivalent</label>
                                                            }
                                                            else
                                                            {
                                                                <label class="RewardIssueEquivalent"> </label>
                                                            }
                                                        </td>
                                                        <td>
                                                            <input hidden value="@item.PenaltyIssueId" class="PenaltyIssueId" />
                                                            <input class="PenaltyIssueDetialsId" hidden value="@item.PenaltyIssueDetialsId" />
                                                            @if (Model.AttendAndLeaveApprovalDetails.Count > 0 && item.PenaltyIssueDetail!= null && item.PenaltyIssueDetail.Equivalent>0)
                                                            {
                                                                <label class="PenaltyIssueEquivalent">@item.PenaltyIssueDetail.Equivalent</label>
                                                            }
                                                            else
                                                            {
                                                                <label class="PenaltyIssueEquivalent"> </label>
                                                            }
                                                        </td>

                                                        <td>
                                                            @if (item.IsIgnored == true)
                                                            {
                                                                <select required class="ActionId form-control">
                                                                    <option value="1"> @MyERP.Properties.Resources.Approval</option>
                                                                    <option value="2" selected>@MyERP.Properties.Resources.Ignore</option>
                                                                </select>
                                                            }
                                                            else if (item.IsApproved == true)
                                                            {
                                                                <select required class="ActionId form-control">
                                                                    <option value="1" selected> @MyERP.Properties.Resources.Approval</option>
                                                                    <option value="2">@MyERP.Properties.Resources.Ignore</option>
                                                                </select>
                                                            }

                                                        </td>
                                                        <td hidden>
                                                            <input class="IsIgnored" type="checkbox" @Html.Raw(Model != null && item.IsIgnored == true ? "checked" : "") />
                                                            <input class="IsApproved" type="checkbox" @Html.Raw(Model != null && item.IsApproved == true ? "checked" : "") />
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>

                            </div>
                        </div>
                        <input id="new" name="newBtn" hidden />
                        <div style="float:left;">
                            @if (Model == null)
                            {
                                <button onclick="addEdit('new')" id="newbtn" class="btn btn-success">
                                    @MyERP.Properties.Resources.SaveAndNew
                                </button>
                                <button onclick="addEdit()" class="btn btn-success">
                                    @MyERP.Properties.Resources.Save
                                </button>
                                <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                            }
                            else
                            {
                                if (Model.IsDeleted == false)
                                {
                                    @*<button onclick="addEdit()" class="btn btn-success">
                                        @MyERP.Properties.Resources.Save
                                    </button>*@
                                    <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                                    @*<a class="btn btn-danger" onclick="Delete(@Model.Id,'AttendAndLeaveApproval')" role="button">@MyERP.Properties.Resources.Delete</a>*@

                                }
                            }

                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<script>

    //----------------------Variable Declaration----------------------------//
    $(document).ready(function () {
        //$.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
        //    $("input[type|='datetime-local']").not('.ExpiryDate').prop('min', r.PeriodStart).prop('max', r.PeriodEnd);
        //});
        if (!$('#Id').val()) {
            setDocNum();
        } else {
            var code = $('#DocumentNumber').val();
            $('#DocumentNumbers').val(code.replaceAll("-", ""))
            $("#DepartmentId").prop('disabled', true);
            $("#Date").prop('disabled', true);
           /* $('#AttendAndLeaveApprovalDetails tr').each(function () {
                let td = $(this);
                if (td.find('.IsApproved') == true && td.find('.IsIgnored') ==false) {
                    td.find('.ActionId').prop("selectedIndex", 0)
                  //  td.find('.ActionId').val($(".ActionId option:first").val());
                }
                else  {
                    td.find('.ActionId').prop("selectedIndex", 1)
                   // td.find('.ActionId').val($(".ActionId option:last").val());
                }
            })*/
        }
    });

    function setDocNum() {
        if ($('#DepartmentId').val()) {
            $.get('/AttendAndLeaveApproval/SetDocNum?id=' + $('#DepartmentId').val() + '&VoucherDate=' + $('#Date').val()).done(function (r) {
                $('#DocumentNumber').val(r);
                $('#DocumentNumbers').val(r.replaceAll("-", ""));
            });
        }
    }

    function zeroPadded(val) {
        if (val >= 10)
            return val;
        else
            return '0' + val;
    }

    if ($('#Id').val() > 0) {
        $('#Date').val('@ViewBag.Date');
        $('#DateFrom').val('@ViewBag.DateFrom');
        $('#DateTo').val('@ViewBag.DateTo');
    }
    else
    {
        var d = new Date();
        $('#Date').val(d.getFullYear() + "-" + zeroPadded(d.getMonth() + 1) + "-" + zeroPadded(d.getDate()) + "T" + zeroPadded(d.getHours()) + ":" + zeroPadded(d.getMinutes()));
    }

    function convertToJavaScriptDate(value) {
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        return (dt.getMonth() + 1) + "/" + dt.getDate() + "/" + dt.getFullYear();
    }

    function convertToJavaScriptFullDate(value) {
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        var hours = dt.getHours();
        var minutes = dt.getMinutes();
        var seconds = dt.getSeconds();
        var ampm = hours >= 12 ? 'PM' : 'AM';
        hours = hours % 12;
        hours = hours ? hours : 12; // the hour '0' should be '12'
        minutes = minutes < 10 ? '0' + minutes : minutes;
        seconds = seconds < 10 ? '0' + seconds : seconds;
        var strTime = hours + ':' + minutes + ":" + seconds /*+ ' ' + ampm*/;
        return ((dt.getMonth() + 1 + "/" + dt.getDate() + "/" + dt.getFullYear()) + "" + strTime);
    }

    function ConvertToTimeString(time) {
        var hours = time.Hours;
        var minutes = time.Minutes;
        var seconds = time.Seconds;
        var ampm = hours >= 12 ? 'PM' : 'AM';
        hours = hours % 12;
        hours = hours ? hours : 12; // the hour '0' should be '12'
        minutes = minutes < 10 ? '0' + minutes : minutes;
        seconds = seconds < 10 ? '0' + seconds : seconds;
        var strTime = hours + ':' + minutes + ":" + seconds + ' ' + ampm;
        return strTime;
    }

    function ConvertToTimeString24(time) {
        var hours = time.Hours;
        var minutes = time.Minutes;
        var seconds = time.Seconds;
        hours = hours < 10 ? '0' + hours : hours;
        minutes = minutes < 10 ? '0' + minutes : minutes;
        seconds = seconds < 10 ? '0' + seconds : seconds;
        var strTime = hours + ':' + minutes + ":" + seconds;
        return strTime;
    }

    function GetTimeFromDate(date) {
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(date);
        var dt = new Date(parseFloat(results[1]));
        var hours = dt.getHours();
        var minutes = dt.getMinutes();
        var seconds = dt.getSeconds();
        hours = hours < 10 ? '0' + hours : hours;
        minutes = minutes < 10 ? '0' + minutes : minutes;
        seconds = seconds < 10 ? '0' + seconds : seconds;
        var strTime = hours + ':' + minutes + ":" + seconds;
        return strTime;
       /* return (dt.toLocaleTimeString(navigator.language, {
            hour: '2-digit',
            minute: '2-digit',
            second: '2-digit'
        }));*/
    }

    $(document).on('change', '#DepartmentId', function () {
        if ($('#DepartmentId').val()) {
            setDocNum();
        }
    });
    $('#Date').on('change', function () {
        setDocNum();
    });
    $(document).on('change', '#EmployeeId', function () {
        if ($('#DepartmentId').val() > 0) {
            GetAttendAndLeaveApproval();
        }
        else {
            Swal.fire({
                title: '@MyERP.Properties.Resources.DepartmentRequired',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        }
    });
    $(document).on('change', '#DateFrom,#DateFrom', function () {
        if ($('#EmployeeId').val() > 0 && $('#DepartmentId').val() > 0) {
            GetAttendAndLeaveApproval();
        }
    });

    $(document).on('change', '.ActionId', function () {
        let td = $(this).closest('tr');
        if (td.find('.ActionId').val() == 1) {
            td.find('.IsApproved').prop('checked', true);
            td.find('.IsIgnored').prop('checked', false);
        }
        else if (td.find('.ActionId').val() == 2) {
            td.find('.IsIgnored').prop('checked', true);
            td.find('.IsApproved').prop('checked', false);
        }
    });

    function GetAttendAndLeaveApproval() {
        $('#preloader, #status').fadeIn();
        $.get('/AttendAndLeaveApproval/GetAttendAndLeaveApproval?EmployeeId=' + $('#EmployeeId').val() + '&DepartmentId=' + $('#DepartmentId').val() + '&DateFrom=' + $('#DateFrom').val() + '&DateTo=' + $('#DateTo').val()).done(function (r) {
            $('#AttendAndLeaveApprovalDetails').empty();
            var EmployeeAttendTime;
            var EmployeeLeaveTime;
            var EmployeeEarlyLeaveMinutes;
            var ShiftEndTime;
            var LeaveTime;
            var EmployeeEarlyLeaveMinutes;
            var EmployeeLatenessHours;
            var OvertimeIssueMinutes;
            var EmployeeAttendAndLeaveDate;
            var EmployeeDate;

            for (var i = 0; i < r.length; i++) {
                if (r[i].In_Out == 0) {
                    EmployeeAttendTime = GetTimeFromDate(r[i].EmployeeAttendAndLeaveDate);
                    EmployeeLeaveTime = "";
                    EmployeeEarlyLeaveMinutes = "";
                    EmployeeLatenessHours = r[i].EmployeeLatenessHours == null ? "" : r[i].EmployeeLatenessHours;
                    OvertimeIssueMinutes = "";
                }
                else if (r[i].In_Out == 1) {
                    EmployeeLeaveTime = GetTimeFromDate(r[i].EmployeeAttendAndLeaveDate);
                    EmployeeAttendTime = "";
                    EmployeeLatenessHours = "";
                    ShiftEndTime = new Date(new Date().toDateString() + ' ' + ConvertToTimeString(r[i].ShiftEndTime));
                    LeaveTime = new Date(new Date().toDateString() + ' ' + EmployeeLeaveTime);
                    OvertimeIssueMinutes = r[i].OvertimeIssueMinutes == null ? "" : r[i].OvertimeIssueMinutes;
                    if (r[i].OvertimeIssueMinutes == null) {
                        EmployeeEarlyLeaveMinutes = (ShiftEndTime.getHours() - LeaveTime.getHours()) * 60 + (ShiftEndTime.getMinutes() - LeaveTime.getMinutes());
                        EmployeeEarlyLeaveMinutes = EmployeeEarlyLeaveMinutes == 0 ? "" : EmployeeEarlyLeaveMinutes;
                    }
                    else {
                        EmployeeEarlyLeaveMinutes = "";
                    }
                }
                else {
                    EmployeeAttendTime = "";
                    EmployeeLeaveTime = "";
                }
                if (r[i].EmployeeAttendAndLeaveDate != null) {
                    EmployeeAttendAndLeaveDate = convertToJavaScriptFullDate(r[i].EmployeeAttendAndLeaveDate);
                    r[i].EmployeeAttendAndLeaveDate = convertToJavaScriptDate(r[i].EmployeeAttendAndLeaveDate);
                }
                else {
                    EmployeeAttendAndLeaveDate = "";
                    r[i].EmployeeAttendAndLeaveDate = "";
                }
                if (r[i].EmployeeAbsenceId > 0) {
                    $('.IsAbsence').prop('checked', true);
                    EmployeeDate = convertToJavaScriptDate(r[i].AbsenceDate);
                    EmployeeEarlyLeaveMinutes = "";
                    EmployeeLatenessHours = "";
                    OvertimeIssueMinutes = "";
                }
                else {
                    $('.IsAbsence').prop('checked', false);
                    EmployeeDate = r[i].EmployeeAttendAndLeaveDate;
                }
                r[i].PenaltyIssueEquivalent=r[i].PenaltyIssueEquivalent == null ? "" : r[i].PenaltyIssueEquivalent;
                r[i].RewardIssueEquivalent = r[i].RewardIssueEquivalent == null ? "" : r[i].RewardIssueEquivalent;

                r[i].EmployeeAttendAndLeaveId = r[i].EmployeeAttendAndLeaveId == null ? "" : r[i].EmployeeAttendAndLeaveId;
                r[i].ShiftId = r[i].ShiftId == null ? "" : r[i].ShiftId;
                r[i].EmployeeLatenessId = r[i].EmployeeLatenessId == null ? "" : r[i].EmployeeLatenessId;
                r[i].EmployeeAbsenceId = r[i].EmployeeAbsenceId == null ? "" : r[i].EmployeeAbsenceId;
                r[i].OvertimeIssueDetialsId = r[i].OvertimeIssueDetialsId == null ? "" : r[i].OvertimeIssueDetialsId;
                r[i].OvertimeIssueId = r[i].OvertimeIssueId == null ? "" : r[i].OvertimeIssueId;
                r[i].RewardIssueId = r[i].RewardIssueId == null ? "" : r[i].RewardIssueId;
                r[i].RewardIssueDetialsId = r[i].RewardIssueDetialsId == null ? "" : r[i].RewardIssueDetialsId;
                r[i].PenaltyIssueId = r[i].PenaltyIssueId == null ? "" : r[i].PenaltyIssueId;
                r[i].PenaltyIssueDetialsId = r[i].PenaltyIssueDetialsId == null ? "" : r[i].PenaltyIssueDetialsId;


                var tr = '<tr><td><input class="EmployeeAttendAndLeaveId" hidden value="' + r[i].EmployeeAttendAndLeaveId + '" /><label class="EmployeeAttendAndLeaveDate">' + EmployeeDate + '</label><input class="From-Time form-control EmployeeAttendAndLeaveDate1" hidden value="' + r[i].EmployeeAttendAndLeaveDate/*EmployeeAttendAndLeaveDate*/
                    + '"/></td><td><label class="EmployeeAttendTime">' + EmployeeAttendTime + '</label><input class="From-Time form-control EmployeeAttendTime1" type="time" hidden value="' + EmployeeAttendTime
                    + '"/></td><td><label class="EmployeeLeaveTime">' + EmployeeLeaveTime + '</label><input class="From-Time form-control EmployeeLeaveTime1" type="time" hidden value="' + EmployeeLeaveTime
                    + '"/></td><td><input hidden value="' + r[i].ShiftId + '" class="ShiftId"/><label class="ShiftArName">' + r[i].ShiftArName + '</label></td><td><label class="ShiftStartTime">' + ConvertToTimeString24(r[i].ShiftStartTime) + '</label><input class="From-Time form-control ShiftStartTime1" hidden type="time" value="' + ConvertToTimeString24(r[i].ShiftStartTime)
                    + '"/></td><td><label class="ShiftEndTime">' + ConvertToTimeString24(r[i].ShiftEndTime) + '</label><input hidden class="From-Time form-control ShiftEndTime1" type="time" value="' + ConvertToTimeString24(r[i].ShiftEndTime)
                    + '"/></td><td><input class="EmployeeLatenessId" hidden value="' + r[i].EmployeeLatenessId + '"/><label class="EmployeeLateness">' + EmployeeLatenessHours + '</label></td><td><label class="EmployeeEarlyLeaveMinutes">' + EmployeeEarlyLeaveMinutes + '</label></td><td><i class="fe-check-circle Absence" style="display:none;"></i><input class="EmployeeAbsenceId" hidden value="' + r[i].EmployeeAbsenceId + '" /><input class="IsAbsence" type="checkbox" hidden value="' +
                    r[i].IsAbsence + '" /></td><td><input class="OvertimeIssueId" hidden value="' + r[i].OvertimeIssueId + '" /><input class="OvertimeIssueDetailsId" hidden value="' + r[i].OvertimeIssueDetialsId + '" /><label class="OvertimeIssueMinutes">' + OvertimeIssueMinutes + '</label></td><td><input hidden value="' +
                    r[i].RewardIssueId + '" class="RewardIssueId"/><input class="RewardIssueDetialsId" hidden value="' + r[i].RewardIssueDetialsId + '" /><label class="RewardIssueEquivalent">' + r[i].RewardIssueEquivalent + '</label></td><td><input hidden value="' + r[i].PenaltyIssueId + '" class="PenaltyIssueId"/><input class="PenaltyIssueDetialsId" hidden value="' + r[i].PenaltyIssueDetialsId + '" /><label class="PenaltyIssueEquivalent">' + r[i].PenaltyIssueEquivalent + '</label></td><td> <select required class="ActionId form-control"><option value="1">' + " @MyERP.Properties.Resources.Approval" + ' </option><option value="2">' + "@MyERP.Properties.Resources.Ignore" + '</option></select></td><td hidden ><input class="IsIgnored" type="checkbox"  value="' + r[i].IsIgnored + '" /><input class="IsApproved" type="checkbox"  value="' +
                    r[i].IsApproved + '" /></td></tr> ';
                $('#AttendAndLeaveApprovalDetails').append(tr);

                $('#AttendAndLeaveApprovalDetails tr').each(function () {
                    let td = $(this);
                    td.find('.ActionId').trigger('change');
                    if (td.find('.EmployeeAbsenceId').val() > 0) {
                        $('.IsAbsence').prop('checked', true);
                        td.find('.Absence').show();
                    }
                });
            }
            $('#preloader, #status').fadeOut();
        })
    }

    function addEdit(n) {
        if ($(".form-control:invalid").length > 0) {
            console.log($(".form-control:invalid"));
            $('.form-horizontal').addClass('was-validated');
            $('html, body').animate({
                scrollTop: $(".form-control:invalid").eq(0).offset().top - 100
            }, 500);
        }
        else {
            var attendAndLeaveApprovalDetails = [];
            $('#AttendAndLeaveApprovalDetails tr').each(function () {
                var td = $(this);
                var attendAndLeaveApprovalDetail = {
                    MainDocId: $('#Id').val(),
                    EmployeeAttendAndLeaveId: td.find('.EmployeeAttendAndLeaveId').val(),
                    EmployeeAttendAndLeaveDate: td.find('.EmployeeAttendAndLeaveDate1').val(),
                    EmployeeAttendTime: td.find('.EmployeeAttendTime1').val(),
                    EmployeeLeaveTime: td.find('.EmployeeLeaveTime1').val(),
                    ShiftStartTime: td.find('.ShiftStartTime1').val(),
                    ShiftEndTime: td.find('.ShiftEndTime1').val(),
                    ShiftId: td.find('.ShiftId').val(),
                    ShiftArName: td.find('.ShiftArName').text(),
                    EmployeeLatenessId: td.find('.EmployeeLatenessId').val(),
                    EmployeeLatenessMinutes: td.find('.EmployeeLateness').text(),
                    EmployeeEarlyLeaveMinutes: td.find('.EmployeeEarlyLeaveMinutes').text(),
                    EmployeeAbsenceId: td.find('.EmployeeAbsenceId').val(),
                    IsAbsence: td.find('.IsAbsence').prop('checked'),
                    OvertimeIssueId: td.find('.OvertimeIssueId').val(),
                    OvertimeIssueMinutes: td.find('.OvertimeIssueMinutes').text(),
                    IsApproved: td.find('.IsApproved').prop('checked'),
                    IsIgnored: td.find('.IsIgnored').prop('checked'),
                    IsDeleted: false,
                    OvertimeIssueDetailsId: td.find('.OvertimeIssueDetailsId').val(),
                    RewardIssueId: td.find('.RewardIssueId').val(),
                    PenaltyIssueId: td.find('.PenaltyIssueId').val(),
                    RewardIssueDetialsId: td.find('.RewardIssueDetialsId').val(),
                    PenaltyIssueDetialsId: td.find('.PenaltyIssueDetialsId').val(),
                };
                attendAndLeaveApprovalDetails.push(attendAndLeaveApprovalDetail);
            });
            var attendAndLeaveApproval =
            {
                Id: $('#Id').val(),
                DocumentNumber: $('#DocumentNumber').val(),
                Date: $('#Date').val(),
                DepartmentId: $('#DepartmentId').val(),
                EmployeeId: $('#EmployeeId').val(),
                DateFrom: $('#DateFrom').val(),
                DateTo: $('#DateTo').val(),
                IsActive: true,
                IsDeleted: false,
                AttendAndLeaveApprovalDetails: attendAndLeaveApprovalDetails,
            };

            Swal.fire({
                title: '@MyERP.Properties.Resources.AreYouSureYouWantToSave',
                text: " ",
                icon: 'info',
                showCancelButton: true,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                cancelButtonText: '@MyERP.Properties.Resources.Cancel',
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        type: "POST",
                        url: "/AttendAndLeaveApproval/AddEdit",
                        data: attendAndLeaveApproval,
                        success: function (r) {
                            if (r.success == "true") {
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.Saved',
                                    text: " ",
                                    icon: 'success',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                                if (n == "new") {
                                    window.location.replace("/AttendAndLeaveApproval/AddEdit");
                                } else {
                                    window.location.replace("/AttendAndLeaveApproval");
                                }
                            }
                            else
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.NotSaved !',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                }); $('#preloader, #status').fadeOut();
                        },
                        error: function (r) {
                            $('#preloader, #status').fadeOut();
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.NotSaved !',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                        }
                    });
                }
                else { result.dismiss; }
            });
        }
    }

    function Delete(id) {
        Swal.fire({
            title: '@MyERP.Properties.Resources.AreYouSureYouWantToDelete',
            text: " ",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: '@MyERP.Properties.Resources.Ok',
            cancelButtonText: '@MyERP.Properties.Resources.Cancel',
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                $('#preloader, #status').fadeIn();
                $.ajax({
                    url: '/AttendAndLeaveApproval/Delete',
                    type: 'POST',
                    data: {
                        "Id": id,
                    },
                    error: function (e) {
                        Swal.fire({
                                title: '@MyERP.Properties.Resources.DeleteDoesNotSucceeded',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                        $('#preloader, #status').fadeOut();
                    },
                    success: function (r) {
                        if (r == 'true') {
                            window.location.replace('/AttendAndLeaveApproval');
                        } else {Swal.fire({
                                title: '@MyERP.Properties.Resources.DeleteDoesNotSucceeded',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                        $('#preloader, #status').fadeOut();}

                    }
                });
            }
            else { result.dismiss; }
        });
    }

</script>
