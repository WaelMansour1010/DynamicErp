    function syncWidthChange() {
        // Get all cells with the 'adjustWidth' class
        const cells = document.querySelectorAll('.adjustWidth');

        // Find the maximum width among all 'adjustWidth' cells
        const maxWidth = Math.max(...Array.from(cells).map(cell => cell.offsetWidth));

        // Apply the maximum width to all 'adjustWidth' cells
        cells.forEach(cell => {
            cell.style.width = `${maxWidth}px`;
        });
    }

