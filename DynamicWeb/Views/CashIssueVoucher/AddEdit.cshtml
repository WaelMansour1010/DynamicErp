        tableBody.append(newRow);
        var newPropertyList = tableBody.find('.PropertyList:last');
        loadProperties(newPropertyList);
    }

    function removeIssueAnalysisDetailRow(button) {
        // Remove the current row
        const row = button.closest('tr');
        const tableBody = row.parentElement;
        row.remove();
    }

    function deleteIssueAnalysisRow(e) {
        // Find the parent <td> of the clicked element
        var tdElement = $(e).closest('td')[0];

        // Find the hidden input within the same <td>
        var hiddenInput = tdElement.querySelector('.issueAnalysisId');

        // Get the value of the hidden input
        var issueAnalysisId = hiddenInput.value;
        let tr = tdElement.closest('tr');
        if (issueAnalysisId > 0) {
            tr = $(".issueAnalysisId_" + issueAnalysisId);
            tr.remove();
        }
        else {
            // Find the closest <tr> with a class that starts with "issueAnalysisId_"
            //tr = tdElement.closest('tr'); // Start from the closest <tr>
            //while (tr && !Array.from(tr.classList).some(cls => cls.startsWith("issueAnalysisId_"))) {
            //    tr = tr.parentElement.closest('tr'); // Move to the next closest <tr>
            //}
            let $tr = $(tr);
            let isLastRow = $tr.index() === $tr.closest('tbody').children('tr').length - 1;

            if (!isLastRow) {
                $tr.remove();
            } else {
                $tr.find("input").val('');
                $tr.find('input, select').removeAttr('required');
                $tr.find('select').prop('selectedIndex', 0).select();
                $tr.find("label").text('');
            }
        }

        CalculateValue();
    }

