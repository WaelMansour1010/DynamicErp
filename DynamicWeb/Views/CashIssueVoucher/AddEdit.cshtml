<script>
    //---------------------- Variable Declaration -----------------------//
        var EditAmount = 0;
        var sum = 0;
        var EmployeeSalary = [];
    let IssueAnalysisAccountOptions = '';
    //let IssueAnalysisVendorOptions = '';
    var taxPercentage = 0.15;

    //********************************************************************//

    //----------------------  Ready Finction -----------------------//
    $(document).ready(function () {
        $.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
            $("input[type|='datetime-local']").not('#TransactionDate').prop('min', r.PeriodStart).prop('max', r.PeriodEnd);
            $('#Date').val('@ViewBag.Date');
            $('#TransactionDate').val('@ViewBag.TransactionDate');
            if ($('#Id').val() > 0) {
                $('#dtDate').val($('#Date').val());
            }
        });
        if (!$('#Id').val()) {
            setDocNum();
            GetCurrentTaxPercentage();
            GetIssueAnalysisAccountDetails();
            cashBoxByDepartment();
        }
        else {
            var code = $('#DocumentNumber').val();
            $('#DocumentNumbers').val(code.replaceAll("-", ""))
            $("#DepartmentId").prop('disabled', true);
            $("#Date").prop('disabled', true);

            if ($('#SourceTypeId').val() == 3) {
                $('.BorrowReceipt').show();
            }
            else {
                $('.BorrowReceipt').hide();
                $('#BorrowRequestId').val(0);
            }
            //if ($('#BorrowReceipt').prop('checked') == true) {
            //    $('#DepartmentId').attr('disabled', true);
            //    $('#EmployeeId').attr('disabled', true);
            //    $('#SourceTypeId').attr('disabled', true);
            //    $('#MoneyAmount').attr('disabled', true);
            //}
            if ($('#CashIssuePaymentMethodId').val() == 2) {
                var FeesAmount = parseFloat($('#FeesAmount').val() > 0 ? $('#FeesAmount').val() : 0.00);
                var MoneyAmount = parseFloat($('#MoneyAmount').inputmask('unmaskedvalue'));
                var ValueAddedTaxesAmount = parseFloat($('#ValueAddedTaxesAmount').val() > 0 ? $('#ValueAddedTaxesAmount').val() : 0.00);
                var total = MoneyAmount - (FeesAmount + ValueAddedTaxesAmount);
                $('#MoneyAmount').val(total);
                //GetPurchaseInvoiceActualPayment();
                $('#MoneyAmount').trigger('change');

            }
        }

        if ($('#IsInvoiceSelected').prop("checked") == true && $('#SourceTypeId').val() == 2) {
            $('#IsInvoiceSelected').prop('disabled', false);
            $('#IsInvoiceSelected').prop('readonly', false);
            $('#PurchaseInvoiceActualPayment').show();
        }
        else {
            $('#PurchaseInvoiceActualPayment').hide();
        }
        sourceTypeChange();
        GetPurchaseInvoiceActualPayment();
        CalculateFees();
        $('#CashIssuePaymentMethodId').trigger('change');

        initiatePropertyUnitsForDetailsTable();
        syncWidthChange();
    });
    //********************************************************************//

    //----------------------  Event Functions -----------------------//
    $('#SourceTypeId').on('change', function () {
        if ($(this).val() == 3) {
            $('.BorrowReceipt').show();
        }
        else {
            $('.BorrowReceipt').hide();
            $('#BorrowReceipt').prop('checked',false);
            $('#BorrowRequestId').val(0);
            if ($(this).val() != 13) {
                $('#MoneyAmount').val(0);
                $('#MoneyAmount').trigger('change');
            }
        }
        sourceTypeChange();
    });
    $(document).on('change', '#EmployeeId', function () {
        GetEmployeeBorrowRequest();

    });
    $(document).on('change', '#DepartmentId', function () {
        if ($('#DepartmentId').val()) {
            setDocNum();
            cashBoxByDepartment();
            GetPurchaseInvoiceActualPayment();
        }
    });
    $(document).on('click', '#IsInvoiceSelected', function () {
        if ($('#IsInvoiceSelected').prop("checked") == true && $('#SourceTypeId').val() == 2) {
            GetPurchaseInvoiceActualPayment();
            if ($('#MoneyAmount').val() > 0) {
                $('#MoneyAmount').val(0)
            }
            $('#PurchaseInvoiceActualPayment').show();
            $('#MoneyAmount').prop('disabled', true).prop('readonly', true).attr('placeholder', '0.00');
        }
        else {
            $('#PurchaseInvoiceActualPayment').hide();
            $('#MoneyAmount').prop('disabled', false).prop('readonly', false).attr('placeholder','@MyERP.Properties.Resources.Amount');
        }
    });
    $(document).on('change', '.ActualPaymentPaidAmount', function () {
        // استخدم غير المقنّع في الحسابات
        var remain = parseFloat($(this).closest('tr').find('.ActualPaymentRemain').text() || 0);
        var paidRaw = $(this).inputmask('unmaskedvalue');
        var paidAmount = parseFloat(paidRaw || 0);

        ReCalculateMoneyAmount();

        var NetRequired = remain - (isNaN(paidAmount) ? 0 : paidAmount);
        $(this).closest('tr').find('.ActualPaymentNetRequired').text(NetRequired.toFixed(2));
    });

    $('#MoneyAmount').on('change', function () {
        var money = $(this).val();
        $('#PurchaseInvoiceActualPaymentTable tr').each(function () {
            var td = $(this);
            var NetRequired;// td.find('.ActualPaymentNetRequired').text();
            var Amount = td.find('.ActualPaymentPaidAmount').val();
            var TotalRemain = parseFloat(td.find('.ActualPaymentRemain').text());
            if (money > 0) {
                if (money > TotalRemain) {
                    money -= TotalRemain;
                    money = money.toFixed(2);
                    td.find('.ActualPaymentPaidAmount').val(TotalRemain);
                    Amount = td.find('.ActualPaymentPaidAmount').val();
                    NetRequired = (Amount - TotalRemain).toFixed(2);
                    td.find('.ActualPaymentNetRequired').text(NetRequired);
                }
                else if (money <= TotalRemain) {
                    td.find('.ActualPaymentPaidAmount').val(money);
                    NetRequired = Math.abs(TotalRemain - money).toFixed(2);
