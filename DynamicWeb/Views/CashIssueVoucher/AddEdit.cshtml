    function updateTotalAmountWhenBatchChange() {
        var sum = 0;
        // هنا التعديل، خليناه يجمع من عمود "المدفوع" اللي الكلاس بتاعه Paid
        $('.Paid').each(function () {
            var paidValue = $(this).val();
            // نتأكد إن القيمة مش فاضية وإنها رقم قبل ما نجمعها
            if (paidValue && !isNaN(parseFloat(paidValue))) {
                sum += parseFloat(paidValue);
            }
        });
        $('#MoneyAmount').val(sum.toFixed(2));
    }

