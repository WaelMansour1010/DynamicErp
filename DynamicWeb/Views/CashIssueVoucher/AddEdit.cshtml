    function updateBatchCalculations(tr) {
        var AddValue = parseFloat(tr.find('.AddValue').val());
        var Discount = parseFloat(tr.find('.Discount').val());
        var taxPercentage = parseFloat(tr.find('.BatchTaxPercentage').val());
        var initialBatchVal = parseFloat(tr.find('.BatchValueBeforeDiscountAddtionAndTax').val());
        var newCalcTaxValue = (initialBatchVal + AddValue - Discount) * taxPercentage / 100;
        tr.find('.BatchTaxValue').val(newCalcTaxValue);
        var newCalcBatchAfterAddDisountTax = (initialBatchVal + AddValue - Discount) + newCalcTaxValue;
        tr.find('.TotalBatchValue').val(newCalcBatchAfterAddDisountTax);
        var totalPaid = parseFloat(tr.find('.TotalPaid').val());
        var newCalcRemain = newCalcBatchAfterAddDisountTax - totalPaid;
        tr.find('.Remain').val(newCalcRemain.toFixed(2));
    }

