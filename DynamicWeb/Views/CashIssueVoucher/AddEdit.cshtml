    function AddToIssueAnalysisTable() {
        let valid = true;
        if ($('#IssueAnalysis .Value:last').val() || $('#IssueAnalysis .IssueAnalysisAccountId:last').val() || $('#IssueAnalysis .Reason:last').val() || $('#IssueAnalysis .Total:last').val()) {
            $('#IssueAnalysis').find('.Value, .IssueAnalysisAccountId, .Reason').prop('required', true);
        }
        if ($('#IssueAnalysis .form-control:invalid').length > 0) {
            $('#IssueAnalysis').closest('.form-horizontal').addClass('was-validated');
            $('html, body').animate({
                scrollTop: $("#IssueAnalysis").find(".form-control:invalid").eq(0).offset().top - 80
            }, 500);
            valid = false;
        }
        else {
            if (valid == true) {
                if (!IssueAnalysisAccountOptions.length) {
                    getIssueAnalysisAccount();
                }
                loadIssueAnalysisPartialView();
                //$('.IssueAnalysisAccountId').last().append(IssueAnalysisAccountOptions).select2();

                $('#IssueAnalysis input[type=number]').removeProp('oninput').prop('type', 'text').inputmask({
                   alias: 'numeric', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
                });
                //GetIssueAnalysisAccountDetails($('#IssueAnalysis .IssueAnalysisAccountId:last'));
                syncWidthChange();
            }

        }
    }

    function addIssueAnalysisDetailRow(button) {
