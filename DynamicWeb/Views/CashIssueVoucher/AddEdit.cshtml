    function loadProperties(propList) {
        $.getJSON("/CashIssueVoucher/GetProperties", function (data) {
            var items = "";
            $.each(data, function (i, TL_Properties) {
                items += "<option value='" + TL_Properties.Value + "'>" + TL_Properties.Text + "</option>";
            });
            $(propList).empty().append(items).select();
        });
    }

    function onChangePropertyList(e) {

        $.getJSON("/CashIssueVoucher/GetPropertyUnits?PropertyId=" + $(e).val() /*$("#PropertyList > option:selected").attr("value")*/, function (data) {
            var items = "";
            $.each(data, function (i, TL_Units) {
                items += "<option value='" + TL_Units.Value + "'>" + TL_Units.Text + "</option>";
            });
            //$("#PropertyUnitList").html(items);
            $(e).closest('tr').find('.PropertyUnitList').empty().append(items).select();
        });
    }

