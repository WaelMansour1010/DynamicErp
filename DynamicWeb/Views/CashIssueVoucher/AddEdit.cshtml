    function addEdit(n) {
            let valid = true;
            var sum = 0;
            if ($(".form-control:invalid").length > 0) {
                $('.form-horizontal').addClass('was-validated');
                $('html, body').animate({
                    scrollTop: $(".form-control:invalid").eq(0).offset().top - 80
                }, 500);
                console.log($(".form-control:invalid"));
                valid = false;
            }

            if ($('#CashIssuePaymentMethodId').val() == 1) { //نقدى
                $('#TransactionNo').val('').attr('required', false);
                $('#TransactionDate').val('').attr('required', false);
                $('#FeesAmount').val('').attr('required', false);
                $('#ValueAddedTaxesAmount').val('').attr('required', false);
            }
            else if ($('#CashIssuePaymentMethodId').val() == 2) { //حوالة بنكية
                if (!$('#TransactionNo').val()) {
                    $('#TransactionNo').attr('required', true);
                    $('#TransactionDate').attr('required', true);
                    $('#FeesAmount').attr('required', true);
                    $('#ValueAddedTaxesAmount').attr('required', true);
                    valid = false;
                }

            }
            else if ($('#CashIssuePaymentMethodId').val() == 3) { // شيك مصدق
                if (!$('#TransactionNo').val()) {
                    $('#TransactionNo').attr('required', true);
                    $('#TransactionDate').attr('required', true);
                    $('#FeesAmount').val('').attr('required', false);
                    $('#ValueAddedTaxesAmount').val('').attr('required', false);
                    valid = false;
                }
            }
            else if ($('#CashIssuePaymentMethodId').val() == 4) { //الحساب
                $('#TransactionNo').val('').attr('required', false);
                $('#TransactionDate').val('').attr('required', false);
                $('#FeesAmount').val('').attr('required', false);
                $('#ValueAddedTaxesAmount').val('').attr('required', false);
            }

            if ($('#SourceTypeId').val() != 3 && $('#BorrowReceipt').prop('checked') == false) {
                $('#BorrowReceipt').prop('checked', false);
                $('#BorrowRequestId').val(0);
