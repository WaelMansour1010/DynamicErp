    function CalculateIssueAnalysisTotals(e) {
            var Totals = $(e).closest('tr').find('.Total').inputmask('unmaskedvalue');
            var TaxesPrecentage = $(e).closest('tr').find('.TaxesPrecentage').val();
            var Taxes = Totals * TaxesPrecentage;
            $(e).closest('tr').find('.Taxes').val(Taxes);
            var NetTotal = Totals - Taxes;
            $(e).closest('tr').find('.Value').val(NetTotal);

        }
    function ReCalculateIssueAnalysisTotals() {
          //  GetCurrentTaxPercentage();
            $('#IssueAnalysis tr').each(function () {
                var td = $(this);
                if (td.find('.IssueAnalysisIncludeValueAddedTax').prop('checked') == true) {
                    td.find('.TaxesPrecentage').val(taxPercentage);
                    var Totals = td.find('.Total').inputmask('unmaskedvalue');
                    var TaxesPrecentage = td.find('.TaxesPrecentage').val();
                    var Taxes = Totals * TaxesPrecentage;
                    td.find('.Taxes').val(Taxes);
                    var NetTotal = Totals - Taxes;
                    td.find('.Value').val(NetTotal);
                }
            });
        }
