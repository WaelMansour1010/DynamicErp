@model MyERP.Models.CashIssueVoucher

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";

    ViewBag.Title = MyERP.Properties.Resources.CashIssueVoucher;
}


<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                @if (Model != null)
                {
                    if (Model.IsDeleted == false)
                    {
                        if (ViewBag.Previous > 0)
                        {
                            <a href="@Url.Action("AddEdit",new {id= ViewBag.First })" class="btn btn-info">@MyERP.Properties.Resources.First</a>
                            <a href="@Url.Action("AddEdit",new { id=ViewBag.Previous })" class=" btn btn-info">&#8250;</a>
                        }
                        if (ViewBag.Next > 0)
                        {
                            <a href="@Url.Action("AddEdit",new { id=ViewBag.Next })" class="btn btn-info">&#8249;</a>
                            <a href="@Url.Action("AddEdit",new {id=ViewBag.Last })" class="btn btn-info">@MyERP.Properties.Resources.Last</a>
                        }
                    }
                }
                <a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
            </div>
            <div class="hed page-title">@MyERP.Properties.Resources.CashIssueVoucher :</div>
        </div>
    </div>
</div>
<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="form-horizontal needs-validation" role="form">

                @*<form action="/CashIssueVoucher/AddEdit" class="form-horizontal needs-validation" novalidate method="post">*@
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">
                                <div class="form-group row">
                                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                    @Html.AntiForgeryToken()
                                    @if (Model != null)
                                    {
                                        @Html.HiddenFor(model => model.Id)
                                        @Html.HiddenFor(model => model.IsActive)
                                        @Html.HiddenFor(model => model.IsLinked)
                                        @Html.HiddenFor(model => model.IsPosted)
                                        @Html.HiddenFor(model => model.UserId)
                                        @Html.HiddenFor(model => model.Image)
                                        @Html.HiddenFor(model => model.IsDeleted)
                                        @Html.HiddenFor(model => model.IsSynced)
                                        @Html.HiddenFor(model => model.IsUpdateSynced)
                                    }
                                    @Html.HiddenFor(model => model.BorrowRequestId)

                                    <label class=" col-sm-2 control-label" for="DocumentNumber">@MyERP.Properties.Resources.VoucherNo</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.DocumentNumber, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly", placeholder = @MyERP.Properties.Resources.VoucherNo, hidden = "hidden" } })
                                        <input id="DocumentNumbers" class="form-control" placeholder=@MyERP.Properties.Resources.Code required readonly />
                                    </div>

                                    <label for="DepartmentId" class="control-label col-sm-2">@MyERP.Properties.Resources.Branch</label>
                                    <div class="col-sm-4">

                                        @Html.DropDownList("DepartmentId", null, null, htmlAttributes: new { @class = "form-control", @required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>

                                <div class="form-group row">
                                    <label class="col-sm-2 control-label " for="MoneyAmount">@MyERP.Properties.Resources.Amount</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.MoneyAmount, new { htmlAttributes = new { @class = "form-control money", placeholder = @MyERP.Properties.Resources.Amount, @required = "required" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label class="col-sm-2 control-label " for="Date">@MyERP.Properties.Resources.Date</label>
                                    <div class="col-sm-4">
                                        <input type="datetime-local" name="Date" id="Date" class="form-control" value="@ViewBag.Date" required />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>

                                <div class="form-group row">
                                    <label class="col-sm-2 control-label " for="SourceTypeId">@MyERP.Properties.Resources.Source</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("SourceTypeId", null, htmlAttributes: new { @class = "form-control", @required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>

                                    <label for="CustomerId" class="CustomerId control-label col-sm-2">@MyERP.Properties.Resources.Customer</label>
                                    <div class="CustomerId col-sm-4">
                                        @Html.DropDownList("CustomerId", null, htmlAttributes: new { @class = "CustomerId form-control" })
                                    </div>

                                    <label for="PropertyOwnerId" class="PropertyOwnerId control-label col-sm-2">@MyERP.Properties.Resources.Owner</label>
                                    <div class="PropertyOwnerId col-sm-4">
                                        @Html.DropDownList("PropertyOwnerId", null, htmlAttributes: new { @class = "PropertyOwnerId form-control" })
                                    </div>

                                    <label for="PropertyId" class="PropertyId control-label col-sm-2">@MyERP.Properties.Resources.Property</label>
                                    <div class="PropertyId col-sm-4">
                                        @Html.DropDownList("PropertyId", null, htmlAttributes: new { @class = "PropertyId form-control" })
                                    </div>




                                    <label class="col-sm-2 control-label AccountId" for="AccountId">@MyERP.Properties.Resources.Account</label>
                                    <div class="col-sm-4 AccountId">
                                        @Html.DropDownList("AccountId", null, htmlAttributes: new { @class = " AccountId form-control" })
                                    </div>

                                    <label for="TechnicianId" class="TechnicianId control-label col-sm-2">@MyERP.Properties.Resources.Technician</label>
                                    <div class="TechnicianId col-sm-4">
                                        @Html.DropDownList("TechnicianId", null, htmlAttributes: new { @class = "TechnicianId form-control" })
                                    </div>

                                    <label for="VendorId" class="VendorId control-label col-sm-2">@MyERP.Properties.Resources.Supplier</label>
                                    <div class="VendorId col-sm-4">
                                        @Html.DropDownList("VendorId", null, htmlAttributes: new { @class = "VendorId form-control" })
                                    </div>

                                    <label for="ShareholderId" class="ShareholderId control-label col-sm-2">@MyERP.Properties.Resources.Contributor</label>
                                    <div class="ShareholderId col-sm-4">
                                        @Html.DropDownList("ShareholderId", null, htmlAttributes: new { @class = "ShareholderId form-control" })
                                    </div>

                                    <label for="EmployeeId" class="EmployeeId control-label col-sm-2">@MyERP.Properties.Resources.Employee</label>
                                    <div class="EmployeeId col-sm-4">
                                        @Html.DropDownList("EmployeeId", null, htmlAttributes: new { @class = "EmployeeId form-control" })
                                    </div>

                                    <label for="DirectExpensesId" class="DirectExpensesId control-label col-sm-2">@MyERP.Properties.Resources.DirectExpenses</label>
                                    <div class="DirectExpensesId col-sm-4">
                                        @Html.DropDownList("DirectExpensesId", null, htmlAttributes: new { @class = "DirectExpensesId form-control" })
                                    </div>

                                    <label for="DoctorId" class="DoctorId control-label col-sm-2">@MyERP.Properties.Resources.Doctor</label>
                                    <div class="DoctorId col-sm-4">
                                        @Html.DropDownList("DoctorId", null, htmlAttributes: new { @class = "DoctorId form-control" })
                                    </div>
                                    <label for="PrepaidExpenseDetailId" class="PrepaidExpenseDetailId control-label col-sm-2">@MyERP.Properties.Resources.PrepaidExpense</label>
                                    <div class="PrepaidExpenseDetailId col-sm-4">
                                        @Html.DropDownList("PrepaidExpenseDetailId", null, htmlAttributes: new { @class = "PrepaidExpenseDetailId form-control" })
                                    </div>

                                </div>

                                <div class="form-group row">
                                    <label for="CashIssuePaymentMethodId" class="CashIssuePaymentMethodId control-label col-sm-2">@MyERP.Properties.Resources.PaymentMethod</label>
                                    <div class="CashIssuePaymentMethodId col-sm-4">
                                        @Html.DropDownList("CashIssuePaymentMethodId", null, htmlAttributes: new { @class = "CashBoxId form-control" })
                                    </div>

                                    <label for="CashBoxId" class="CashBoxId CashBoxDiv control-label col-sm-2">@MyERP.Properties.Resources.CashBox</label>
                                    <div class="CashBoxId CashBoxDiv col-sm-4">
                                        @Html.DropDownList("CashBoxId", null, htmlAttributes: new { @class = "CashBoxId form-control" })
                                    </div>
                                    <label for="ChartOfAccountId" class="ChartOfAccountId ChartOfAccountDiv control-label col-sm-2">@MyERP.Properties.Resources.Account</label>
                                    <div class="ChartOfAccountId ChartOfAccountDiv col-sm-4">
                                        @Html.DropDownList("ChartOfAccountId", null, htmlAttributes: new { @class = "ChartOfAccountId form-control" })
                                    </div>
                                    <label for="BankAccountId" class="BankAccountId BankAccountDiv control-label col-sm-2">@MyERP.Properties.Resources.BankAccount</label>
                                    <div class="BankAccountId BankAccountDiv col-sm-4">
                                        @Html.DropDownList("BankAccountId", null, htmlAttributes: new { @class = "BankAccountId form-control" })
                                    </div>
                                </div>

                                <div class="form-group row" id="TransactionDiv" style="display:none;">
                                    <label class="col-sm-2 control-label " id="TransactionNoLabel" for="TransactionNo">@MyERP.Properties.Resources.TransactionNumber</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.TransactionNo, new { htmlAttributes = new { @class = "form-control" } })
                                    </div>
                                    <label class="col-sm-2 control-label " id="TransactionDateLabel" for="TransactionDate">@MyERP.Properties.Resources.TransactionDate </label>
                                    <div class="col-sm-4">
                                        @if (Model != null)
                                        {
                                            <input type="datetime-local" name="TransactionDate" id="TransactionDate" class="form-control" value="@Model.TransactionDate" />
                                        }
                                        else
                                        {
                                            <input type="datetime-local" name="TransactionDate" id="TransactionDate" class="form-control" />
                                        }
                                    </div>
                                </div>

                                <div class="form-group row Fees" style="display:none;">
                                    <label class="col-sm-2 control-label " for="FeesAmount">@MyERP.Properties.Resources.Fees</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.FeesAmount, new { htmlAttributes = new { @class = "form-control money" } })
                                    </div>

                                    <label class="col-sm-2 control-label " for="IncludeValueAddedTax">@MyERP.Properties.Resources.IncludeValueAddedTax</label>
                                    <div class="col-sm-4">
                                        <input type="checkbox" id="IncludeValueAddedTax" style="width:15px;">
                                    </div>
                                </div>

                                <div class="form-group row Fees" style="display:none;">
                                    <label class="col-sm-2 control-label " for="ValueAddedTaxesAmount">@MyERP.Properties.Resources.ValueAddedTax</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.ValueAddedTaxesAmount, new { htmlAttributes = new { @class = "form-control money" } })
                                    </div>

                                    <label for="CostCenterId" class="control-label col-sm-2">@MyERP.Properties.Resources.TotalServiceFeesAndTaxes : </label>
                                    <div class="col-sm-4">
                                        <label for="TotalFeesPaid" id="TotalFeesPaid" class="control-label col-sm-2"> </label>
                                    </div>
                                </div>

                                @*<div class="AccountId form-group row"></div>
                                    <div class="TechnicianId form-group row"></div>
                                    <div class="VendorId form-group row"></div>
                                    <div class="ShareholderId form-group row"></div>
                                    <div class="EmployeeId form-group row"></div>
                                    <div class="DirectExpensesId form-group row"></div>*@

                                @if (ViewBag.UseCostCenter == true)
                                {
                                    <div class="form-group row">
                                        <label for="CostCenterId" class="control-label col-sm-2">@MyERP.Properties.Resources.CostCenter </label>

                                        <div class="col-sm-4">
                                            @Html.DropDownList("CostCenterId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })
                                        </div>
                                    </div>
                                }

                                <div class="form-group row" id="SalaryDiv" style="display:none;">
                                    <label class=" col-sm-2 control-label" for="Year">@MyERP.Properties.Resources.Year</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("Year", null, htmlAttributes: new { @class = "form-control" })
                                    </div>
                                    <label class=" col-sm-2 control-label" for="Month">@MyERP.Properties.Resources.Month</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("Month", null, htmlAttributes: new { @class = "form-control" })
                                    </div>
                                </div>
                                <div class="form-group row" id="SelectEmployeesBtn" style="display:none;">
                                    <button class="btn btn-primary" onclick="GetDepartmentEmployeeSalary()"> @MyERP.Properties.Resources.SelectAnEmployee</button>
                                </div>
                                <div class="form-group row">
                                    <label class="control-label col-sm-2" for="Notes">@MyERP.Properties.Resources.Notes</label>
                                    <div class="col-sm-4">
                                        <textarea id="Notes" name="Notes" class="form-control" rows="5" cols="5">@if (Model != null) { @Model.Notes; }</textarea>
                                        @Html.ValidationMessageFor(model => model.Notes, "", new { @class = "text-danger" })
                                    </div>
                                    <div class="col-sm-6 BorrowReceipt" style="display:none;">
                                        <div class="col-sm-4">
                                            <input type="checkbox" name="BorrowReceipt" @Html.Raw(Model != null && Model.BorrowReceipt == true ? "checked" : "") @Html.Raw(Model != null ? "disabled" : "") id="BorrowReceipt" />
                                            <label class="col-sm-10 control-label" for="BorrowReceipt">
                                                @MyERP.Properties.Resources.BorrowReceipt
                                            </label>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>


                        <div class="row" id="CashIssueVoucherEmployeePayrollIssuesTable" style="display:none;">
                            <div class="col-12">
                                <div class="card-box">
                                    <div class=" table-responsive">
                                        <table class="table table-striped table-centered mb-0">
                                            <thead>
                                                <tr>
                                                    <th>
                                                        @MyERP.Properties.Resources.Employee
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.EmployeeSalary
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Month
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Year
                                                    </th>
                                                </tr>
                                            </thead>
                                            <tbody id="CashIssueVoucherEmployeePayrollIssues">

                                                @if (Model != null && Model.CashIssueVoucherEmployeePayrollIssues.Count() > 0)
                                                {
                                                    foreach (var item in Model.CashIssueVoucherEmployeePayrollIssues)
                                                    {
                                                        <tr>
                                                            <td>
                                                                <input hidden class="employeeId" value="@item.EmployeeId" />
                                                                <label class="control-label">
                                                                    @item.Employee.ArName
                                                                </label>
                                                            </td>
                                                            <td>
                                                                <input class="form-control NetSalary" disabled value="@item.NetSalary">
                                                            </td>
                                                            <td>
                                                                <input class="form-control month" disabled value="@item.Month">
                                                            </td>
                                                            <td>
                                                                <input class="form-control year" disabled value="@item.Year">
                                                            </td>
                                                        </tr>
                                                    }
                                                }
                                            </tbody>

                                        </table>
                                    </div>

                                </div>
                            </div>
                        </div>


                        <!-- Actual Payment-->
                        <div class="card">
                            <div class="card-body">
                                <div class="form-group row">
                                    <label class="control-label col-sm-2" for="Notes">@MyERP.Properties.Resources.InvoiceSelected</label>
                                    <div class="col-sm-4">
                                        <input type="checkbox" id="IsInvoiceSelected" @Html.Raw(Model != null && Model.IsInvoiceSelected == true ? "checked" : "") style="width:15px;">
                                    </div>
                                </div>
                                <div class="row" id="PurchaseInvoiceActualPayment" style="display:none;">
                                    <div class="col-12">
                                        <div class="card-box">
                                            <div class=" table-responsive">
                                                <table class="table table-striped table-centered mb-0">
                                                    <thead>
                                                        <tr>
                                                            <th>
                                                                @MyERP.Properties.Resources.InvoiceNo
                                                            </th>
                                                            <th>
                                                                @MyERP.Properties.Resources.VoucherDate
                                                            </th>
                                                            <th>
                                                                @MyERP.Properties.Resources.DueDate
                                                            </th>
                                                            <th>
                                                                @MyERP.Properties.Resources.Department
                                                            </th>
                                                            <th>
                                                                @MyERP.Properties.Resources.Total
                                                                @*إجمالى الفاتورة*@
                                                            </th>
                                                            <th>
                                                                @MyERP.Properties.Resources.Paid
                                                                @*مسدد سابقا*@
                                                            </th>
                                                            <th>
                                                                @*متبقى*@
                                                                @MyERP.Properties.Resources.Remain
                                                            </th>
                                                            <th>
                                                                <i class="fe-check-circle"></i>
                                                            </th>
                                                            <th>
                                                                @*مسدد الحركة*@
                                                                @MyERP.Properties.Resources.PaidAmount
                                                            </th>
                                                            <th>@MyERP.Properties.Resources.NetRequired</th>
                                                            @*الصافى المستحق*@
                                                        </tr>
                                                    </thead>
                                                    <tbody id="PurchaseInvoiceActualPaymentTable">
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
