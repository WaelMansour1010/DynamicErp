        updateBatchCalculations($(this).closest('tr'));
        updateTotalAmountWhenBatchChange();
    });

    $(document).on('change', '.BatchTaxPercentage', function (e) {
        updateBatchCalculations($(this).closest('tr'));
        updateTotalAmountWhenBatchChange();
    });


    $(document).on('change', '.Paid', function (e) {
        // هنجيب الصف اللي بنعدل فيه
        var $row = $(this).closest('tr');

        // هنجيب القيم الأصلية اللي خزنّاها في الخطوة الأولى
        var originalTotalPaid = parseFloat($row.data('original-total-paid'));
        var totalBatchValue = parseFloat($row.data('total-batch-value'));

        // هنجيب القيمة الجديدة اللي اتكتبت في خانة "المدفوع"
        var currentPaid = parseFloat($(this).val()) || 0; // لو الخانة فاضية هتبقى قيمتها صفر

        // 1. حساب "إجمالي المدفوع" الجديد = الأصلي + المدفوع حالياً
        var newTotalPaid = originalTotalPaid + currentPaid;

        // 2. حساب "المتبقي" الجديد = قيمة الدفعة الكاملة - إجمالي المدفوع الجديد
        var newRemain = totalBatchValue - newTotalPaid;

        // 3. تحديث الخانات بالقيم الصحيحة
        $row.find('.TotalPaid').val(newTotalPaid.toFixed(2));
        $row.find('.Remain').val(newRemain.toFixed(2));

        // 4. تحديث حالة التسليم (checkbox)
        if (newRemain <= 0) {
            $row.find('.IsDelivered').prop('checked', true);
        } else {
            $row.find('.IsDelivered').prop('checked', false);
        }

        // 5. تحديث الإجمالي الكلي فوق
        updateTotalAmountWhenBatchChange();
    });

