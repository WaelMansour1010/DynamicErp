                        <div class="card" id="IssueAnalysisTable" style="display:none;">
                            <div class="card-body">
                                <div class="form-group row">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.IssueAnalysis
                                    </h5>
                                </div>
                                <div>
                                    <div class="col-12">
                                        <div class="card-box">
                                            <div class="table-responsive">
                                                <table class="table table-striped table-centered FixedCells mb-0">
                                                    <thead>
                                                        <tr style="text-align: center;">
                                                            <th style="width:10%;">
                                                                @MyERP.Properties.Resources.Reasons
                                                            </th>
                                                            <th class="adjustWidth">
                                                                @MyERP.Properties.Resources.Account
                                                            </th>
                                                            <th>
                                                                @MyERP.Properties.Resources.TotalPrice
                                                            </th>
                                                            <th>
                                                                @MyERP.Properties.Resources.Value
                                                            </th>
                                                            <th>
                                                                @MyERP.Properties.Resources.VATPercentage
                                                            </th>
                                                            <th>
                                                                @MyERP.Properties.Resources.VATValue
                                                            </th>
                                                            <th>
                                                                @MyERP.Properties.Resources.Vendor
                                                            </th>
                                                            <th>
                                                                @MyERP.Properties.Resources.Notes
                                                            </th>
                                                            <th>
                                                                @MyERP.Properties.Resources.Delete
                                                            </th>
                                                            <th>
                                                                
                                                            </th>
                                                        </tr>
                                                    </thead>
                                                    <tbody id="IssueAnalysis">
                                                        @if (Model != null && Model.SourceTypeId == 10 && Model.IssueAnalysis.Count() > 0)
                                                        {
                                                            foreach (var item in Model.IssueAnalysis)
                                                            {
                                                                <tr class="issueAnalysisId_@item.Id" style="border: 1px solid; color: darkgray">
                                                                    <td colspan="10" style="text-align: center;">
                                                                        @Html.Partial("_IssueAnalysis", item)
                                                                    </td>
                                                                </tr>
                                                            }
                                                        }
                                                        <tr class="issueAnalysisId_-1" style="border: 1px solid; color: darkgray">
                                                            <td colspan="10" style="text-align: center;">
                                                                @{ 
                                                                    var emptyIssueAnalysis = new MyERP.Models.IssueAnalysis() { Id = -1 };
                                                                }
                                                                @Html.Partial("_IssueAnalysis", emptyIssueAnalysis)
                                                            </td>
                                                        </tr>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

