    function SelectEmployee(id) {
            let month = $('#Month').val();
            let year = $('#Year').val();
            let valid = true;
            $('#CashIssueVoucherEmployeePayrollIssues tr').each(function () {
                var td = $(this);
                if (id == td.find('.employeeId').val()) {
                    valid = false;
                }
            });
            if (valid == false)
                Swal.fire({
        title: '@MyERP.Properties.Resources.ThisEmployeeWasPreviouslyAdded',
        text: " ",
        icon: 'info',
        showCancelButton: false,
        confirmButtonText: '@MyERP.Properties.Resources.Ok',
        confirmButtonColor: '#3085d6'
    });
            else {
                let Emp = EmployeeSalary.filter(function (i) { return i.Id == id; })[0];
                let tr = '<tr><td><input hidden class="employeeId" value="' +
                    Emp.Id + '" /><label class="control-label">' +
                    Emp.ArName + '</label></td><td><input class="form-control NetSalary" disabled value="' +
                    Emp.ItemValue + '"></td><td><input class="form-control month" disabled value="' +
                    month + '"></td><td><input class="form-control year" disabled value="' +
                    year + '"></td></tr > ';
                $('#CashIssueVoucherEmployeePayrollIssues').append(tr);
                sum += Emp.ItemValue;
                $('#MoneyAmount').val(sum);
                $('#MoneyAmount').trigger('change');
            }
        }
