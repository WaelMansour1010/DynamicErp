@model IEnumerable<MyERP.Models.ChartOfAccount>

@{

    UICulture = Session["lang"] != null?Session["lang"].ToString():"ar";
    ViewBag.Title = MyERP.Properties.Resources.ChartsOfAccounts;

}
<link rel="stylesheet" href="https://kendo.cdn.telerik.com/2018.2.516/styles/kendo.common-material.min.css" />
<link rel="stylesheet" href="https://kendo.cdn.telerik.com/2018.2.516/styles/kendo.material.min.css" />
<link rel="stylesheet" href="https://kendo.cdn.telerik.com/2018.2.516/styles/kendo.material.mobile.min.css" />
<script src="https://kendo.cdn.telerik.com/2018.2.516/js/kendo.all.min.js"></script>


<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <a class="btn btn-info" href="@Url.Action("AddEdit")" role="button" style="float:left;">@MyERP.Properties.Resources.AddNew</a>
            </div>
            <div class="hed page-title"> @MyERP.Properties.Resources.AccountsGuide</div>
        </div>
    </div>
</div>

<div class="card-box">
    <div class="row">
        <div class="col-12">
            <div class="form-horizontal" role="form">
                <div class="form-group row">
                    <div class="col-xs-12 col-sm-6 col-lg-3">
                        <input type="text" class="form-control searchtxt" value="@Html.Raw(ViewBag.searchWord)" placeholder= @MyERP.Properties.Resources.Search>
                    </div>
                    <div class="col-xs-12 col-sm-3 col-lg-3">
                        <button type="button" class="btn btn-success btnSearch" onclick="searchWord = $('.searchtxt').val(); paging();">
                            <i class="fa fa-search"></i>
                        </button>
                        <button type="button" class="btn btn-info btnSearch" onclick="pageNo = 1; searchWord=''; paging();">
                            <i class="fe-refresh-ccw"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="form-group">
        <div class="col-sm-6">
            <button class="btn btn-success" id="treeCollapse"> @MyERP.Properties.Resources.Menu</button>

            <button class="btn btn-success" id="treeExpand"> @MyERP.Properties.Resources.Tree</button>
        </div>

    </div>


    <div class="row">
        <div class="col-12">
            <div class="table-responsive">
                <table class="table table-striped table-centered mb-0">
                    <thead>
                        <tr>
                            <th> @MyERP.Properties.Resources.Code</th>
                            <th> @MyERP.Properties.Resources.ArName</th>
                            <th> @MyERP.Properties.Resources.EnName</th>
                            <th> @MyERP.Properties.Resources.Active</th>
                            <th> @MyERP.Properties.Resources.Edit</th>

                            <th> @MyERP.Properties.Resources.Delete</th>
                        </tr>
                    </thead>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @Html.DisplayFor(modelItem => item.Code)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.ArName)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.EnName)
                            </td>
                            <td>

                                <input type="checkbox" data-plugin="switchery" data-color="#00b19d" data-secondary-color="#ED5565" data-size="small" @Html.Raw(item.IsActive == true ? "checked" : "") onchange="ActivateDeactivate(@item.Id)" />
                            </td>
                            <td>
                                <a href="@Url.Action("AddEdit","ChartOfAccounts",new { id=item.Id })" onclick="$('#preloader, #status').fadeIn();">
                                    <i class="fa fa-edit"></i>
                                </a>
                            </td>
                            <td>
                                <a href="javascript:void(0);" onclick="DeleteFunc(@item.Id)">
                                    <i class="fas fa-trash-alt"></i>
                                </a>

                            </td>
                        </tr>
                    }

                </table>
            </div>
        </div>
    </div>
</div>

