@model IEnumerable<MyERP.Models.ChurchMeeting>
@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.Confessions;
}

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <a class="btn btn-info" href="@Url.Action("AddEdit")" role="button" style="float:left;">@MyERP.Properties.Resources.AddNew</a>
            </div>
            <div class="hed page-title"> @MyERP.Properties.Resources.Confessions </div>
        </div>
    </div>
</div>

<div class="card-box">
    <div class="row">
        <div class="col-12">
            <div class="form-horizontal" role="form">
                <div class="form-group row">
                    @*<div class="col-xs-12 col-sm-6 col-lg-3">
                            <input type="text" class="form-control searchtxt" value="@Html.Raw(ViewBag.searchWord)" placeholder="@MyERP.Properties.Resources.Search">
                        </div>*@
                    <div class="col-xs-12 col-sm-6 col-lg-6 form-group row">
                        <label for="DateFrom" class="control-label col-sm-2">@MyERP.Properties.Resources.FromDate</label>
                        <div class="col-sm-4">
                            <input id="DateFrom" name="DateFrom" class="form-control" type="date" required />
                        </div>
                        <label for="DateTo" class="control-label col-sm-2">@MyERP.Properties.Resources.ToDate</label>
                        <div class="col-sm-4">
                            <input id="DateTo" name="DateTo" class="form-control" type="date" required />
                        </div>
                    </div>
                    <div class="col-xs-12 col-sm-6 col-lg-3">
                        @Html.DropDownList("FatherId", null, @MyERP.Properties.Resources.Father, htmlAttributes: new { @class = "form-control searchtxt" })
                    </div>
                    <div class="col-xs-12 col-sm-3 col-lg-3">
                        <button type="button" class="btn btn-success btnSearch" onclick="searchWord = $('.searchtxt').val(); paging('search');">
                            <i class="fa fa-search"></i>
                        </button>
                        @*<button type="button" class="btn btn-info btnSearch" onclick="pageNo = 1; searchWord=''; paging();">
                                <i class="fe-refresh-ccw"></i>
                            </button>*@
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="table-responsive">
                <table class="table table-striped table-centered mb-0">
                    <thead>
                        <tr>

                            <th>
                                @MyERP.Properties.Resources.Code
                            </th>
                            <th>
                                @MyERP.Properties.Resources.Date
                            </th>
                            <th>
                                @MyERP.Properties.Resources.ArName
                            </th>
                            <th>
                                @MyERP.Properties.Resources.Mobile
                            </th>
                            @*<th>
                                    @MyERP.Properties.Resources.Address
                                </th>*@
                            <th>
                                @MyERP.Properties.Resources.ConfessionFather
                            </th>
                            <th>
                                @MyERP.Properties.Resources.Area
                            </th>
                            <th>
                                @MyERP.Properties.Resources.Notes
                            </th>
                            <th>
                                @MyERP.Properties.Resources.Image
                            </th>
                            @*<th>
                                    @MyERP.Properties.Resources.Active
                                </th>*@
                            <th>
                                @MyERP.Properties.Resources.Edit
                            </th>
                            <th>
                                @MyERP.Properties.Resources.Delete
                            </th>
                            <th>
                                @MyERP.Properties.Resources.Send
                            </th>
                        </tr>
                    </thead>
                    <tbody id="MeetingData">
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    @Html.DisplayFor(modelItem => item.Code)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.Date)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.ChurchMembership.ArName)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.ChurchMembership.Mobile)
                                </td>
                                @*<td>
                                        @Html.DisplayFor(modelItem => item.ChurchMembership.Address)
                                    </td>*@
                                <td>
                                    @Html.DisplayFor(modelItem => item.ChurchFather.ArName)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.ChurchMembership.Area.ArName)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.Notes)
                                </td>
                                <td>
                                    @if (item.ChurchMembership.Image != null)
                                    {
                                        <a class="my_images" href="@(item.ChurchMembership.Image)" target="_blank">
                                            <img src="@(item.ChurchMembership.Image)" alt="" class="MemberImage" style="width:50px;height:50px;border-radius: 50px;" />
                                        </a>
                                    }
                                    else
                                    {
                                        <a class="my_images" href="~/assets/images/users/Avatar_User.png" target="_blank">
                                            <img src="~/assets/images/users/Avatar_User.png" alt="" class="MemberImage" style="width:50px;height:50px;border-radius: 50px;" />
                                        </a>
                                    }
                                </td>
                                @*<td>
                                        <input type="checkbox" data-plugin="switchery" data-color="#00b19d" data-secondary-color="#ED5565" data-size="small" @Html.Raw(item.IsActive == true ? "checked" : "") onchange="ActivateDeactivate(@item.Id)" />
                                    </td>*@
                                <td>
                                    <a href="@Url.Action("AddEdit", "ChurchMeeting", new { id = item.Id })" onclick="$('#preloader, #status').fadeIn();">
                                        <i class="fa fa-edit"></i>
                                    </a>
                                </td>
                                <td>
                                    <a href="javascript:void(0);" onclick="Delete(@item.Id)">
                                        <i class="fas fa-trash-alt"></i>
                                    </a>
                                </td>
                                <td>
                                    @*<a href="https://api.whatsapp.com/send?phone=@item.ChurchMembership.Mobile&text=@ViewBag.domainName/ChurchMeeting/AddEdit?id=@item.Id" target="_blank">*@
                                    <a onclick="Send(@item.Id,'@item.ChurchMembership.Mobile')" href="javascript:void(0);">
                                        <i class="fab fa-whatsapp"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>

<div style="text-align:center;margin-bottom: 50px;">

    <div class="form-group row">
        <div class="col-sm-4">
            <select id="ShowByPage" class="form-control" style="width:70px;float:left;" onchange="paging()">
                <option value="10">10</option>
                <option value="30">30</option>
                <option value="50">50</option>
                <option value="100">100</option>
                <option value="200">200</option>
                <option value="@ViewBag.Count">@MyERP.Properties.Resources.All</option>
            </select>
            <span style="font-size:12px;float:right;"> @MyERP.Properties.Resources.NoOfResults : <span id="RowsCount">@ViewBag.Count</span></span>
        </div>
        <div class="col-sm-2">
            <lablel class="col-sm-8"> @MyERP.Properties.Resources.PageNo : </lablel>
        </div>
        <div class="col-sm-2">
            <select id="pagination" class="pagination form-control" style="width:70px;float:left;">
            </select>
        </div>
    </div>
</div>

<script>
     var pageNo = 1;
    var searchWord = '@Html.Raw(ViewBag.searchWord)';
    $('#ShowByPage').val(@ViewBag.wantedRowsNo);
    function paging(n) {
        if (n === 'search' || $('#DateFrom').val() || $('#DateTo').val()) {
            $('#MeetingData').empty();

            var link = $.get('/ChurchMeeting/Index?' + 'pageIndex=' + pageNo + '&wantedRowsNo=' + $('#ShowByPage').val() + '&DateFrom=' + $('#DateFrom').val() + '&DateTo=' + $('#DateTo').val() + '&IsSearch=true' + '&FatherId=' + $('#FatherId').val()).done(function (r) {
                var PrevMeetings = r.PrevMeetings;
              //  console.log("Result : ", PrevMeetings)

                $('#DateTo').val(convertToJavaScriptDate2(r.DateTo)) ;
                $('#DateFrom').val(convertToJavaScriptDate2(r.DateFrom)) ;
                if (PrevMeetings.length > 0) {

                $('#ShowByPage').val(r.wantedRowsNo);
                    $('#RowsCount').text(r.Count);
                for (var i = 0; i < Math.ceil(r.Count / $('#ShowByPage').val()); i++)
                    $('#pagination').append('<option onchange="pageNo=' + (i + 1) + '; paging();" id="pg' + (i + 1) + '">' + (i + 1) + '</option>');
                $('#pg' + r.PageIndex).attr('selected', 'selected')
                    for (var i = 0; i < PrevMeetings.length; i++) {
                        PrevMeetings[i].Date=PrevMeetings[i].Date != null ? convertToJavaScriptDate(PrevMeetings[i].Date) : "";
                        PrevMeetings[i].IsActive = PrevMeetings[i].IsActive == true ? "checked" : "";
                        PrevMeetings[i].Mobile = PrevMeetings[i].Mobile != null ? PrevMeetings[i].Mobile : "";
                        PrevMeetings[i].Address = PrevMeetings[i].Address != null ? PrevMeetings[i].Address : "";
                        PrevMeetings[i].AreaName = PrevMeetings[i].AreaName != null ? PrevMeetings[i].AreaName : "";
                        PrevMeetings[i].Notes = PrevMeetings[i].Notes != null ? PrevMeetings[i].Notes : "";
                        PrevMeetings[i].Image = PrevMeetings[i].Image != null ?"<img src ='"+
                            PrevMeetings[i].Image + "' alt='' class='MemberImage' style='width:50px;height:50px;border-radius:50px;' />" : "<img src ='/assets/images/users/Avatar_User.png' alt='' class='MemberImage' style='width:50px;height:50px;border-radius: 50px;' />";
                        PrevMeetings[i].FatherName = PrevMeetings[i].FatherName != null ? PrevMeetings[i].FatherName : "";
                        let tr = '<tr><td>' +
                            PrevMeetings[i].Code + '</td><td>' +
                            PrevMeetings[i].Date + '</td><td>' +
                            PrevMeetings[i].ArName + '</td><td>' +
                            PrevMeetings[i].Mobile + '</td><td>' +
                            PrevMeetings[i].FatherName + '</td><td>' +
                            PrevMeetings[i].AreaName+'</td><td>' +
                            PrevMeetings[i].Notes + '</td><td>' + PrevMeetings[i].Image +'</td><td><a href="ChurchMeeting/AddEdit?id=' +
                            PrevMeetings[i].Id + '" onclick="$("#preloader, #status").fadeIn();"><i class="fa fa-edit"></i></a></td><td><a href="javascript:void(0);" onclick="Delete(' +
                            PrevMeetings[i].Id + ')"><i class="fas fa-trash-alt"></i></a></td><td><a href="javascript:void(0);" onclick = "Send(\'' + PrevMeetings[i].Id + '\',\'' + PrevMeetings[i].Mobile + '\')"><i class="fab fa-whatsapp"></i></a></td></tr>';
                        $('#MeetingData').append(tr);
                    }
                    $('[data-plugin="switchery"]').each(function (t, e) { new Switchery($(this)[0], $(this).data()) });

                                    }
            });//+ '&searchWord=' + searchWord ;
        }
        else {
            var link = '/ChurchMeeting/Index?' + 'pageIndex=' + pageNo + '&wantedRowsNo=' + $('#ShowByPage').val() + '&DateFrom=' + $('#DateFrom').val() + '&DateTo=' + $('#DateTo').val() + '&IsSearch=false' + '&FatherId=' + $('#FatherId').val();
            window.location.replace(link);
        }
    }

    function convertToJavaScriptDate(value) {
        if (value === null)
            return null;
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        var month = (dt.getMonth() + 1) < 10 ? '0' + (dt.getMonth() + 1) : (dt.getMonth() + 1);
        var day = dt.getDate() < 10 ? '0' + dt.getDate() : dt.getDate();
        var hours = dt.getHours();
        var minutes = dt.getMinutes();
        var seconds = dt.getSeconds();
        var ampm = hours >= 12 ? 'PM' : 'AM';
        hours = hours % 12;
        hours = hours ? hours : 12; // the hour '0' should be '12'
        hours = hours < 10 ? '0' + hours : hours;
        minutes = minutes < 10 ? '0' + minutes : minutes;
        seconds = seconds < 10 ? '0' + seconds : seconds;
        var strTime = hours + ':' + minutes + ":" + seconds + ' ' + ampm;
        return ((month + "/" + day + "/" + dt.getFullYear() ) + " " + strTime);

        //2022 - 01 - 18T20: 23
    }
    function convertToJavaScriptDate2(value) {
        if (value === null)
            return null;
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        var month = (dt.getMonth() + 1) < 10 ? '0' + (dt.getMonth() + 1) : (dt.getMonth() + 1);
        var day = dt.getDate() < 10 ? '0' + dt.getDate() : dt.getDate();
        var hours = dt.getHours();
        var minutes = dt.getMinutes();
        var seconds = dt.getSeconds();
        var ampm = hours >= 12 ? 'PM' : 'AM';
        hours = hours % 12;
        hours = hours ? hours : 12; // the hour '0' should be '12'
        hours = hours < 10 ? '0' + hours : hours;
        minutes = minutes < 10 ? '0' + minutes : minutes;
        seconds = seconds < 10 ? '0' + seconds : seconds;
        var strTime = hours + ':' + minutes /*+ ":" + seconds + ' ' + ampm*/;
        return ((dt.getFullYear() + "-" + month + "-" + day));

        //2022 - 01 - 18T20: 23
    }


    function setPages() {
        var count =@ViewBag.Count;
        for (var i = 0; i < Math.ceil(count / $('#ShowByPage').val()); i++)
   $('#pagination').append('<option onchange="pageNo=' + (i + 1) + '; paging();" id="pg' + (i + 1) + '">' + (i + 1) + '</option>');
    }
    setPages();
   $('#pg' +@ViewBag.PageIndex).attr('selected', 'selected')
    $('#pagination').on('change', function () {
        pageNo = $('#pagination').val();
         paging();
    })
    function Delete(id) {
        if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToDelete')) {
            $('#preloader, #status').fadeIn();
            $.ajax(
                {
                    url: '/ChurchMeeting/Delete',
                    type: 'POST',
                    data: {
                        "Id": id,
                    },
                    error: function (e) {
                    },
                    success: function (r) {
                        if (r == 'true') {
                            window.location.reload();
                        }
                    }
                });
        }
    }
    function ActivateDeactivate(id) {
        $.ajax({
            url: '/ChurchMeeting/ActivateDeactivate',
            type: 'POST',
            data: {
                "Id": id,
            },
            error: function (e) {
                alert('@MyERP.Properties.Resources.TheActivationStateNotChanged')
            },
            success: function (r) {
                if (r == 'true') {
                    alert('@MyERP.Properties.Resources.TheActivationStateHasChanged')
                }
            }
        });
    }
    function Send(id, mobile) {
        if (mobile != null) {
            var Checker = mobile.toString().slice(0, 3);
            if (Checker == 10 || Checker == 11 || Checker == 12 || Checker == 15) {
                mobile = "+2" + mobile
            }
        }
         var link = "https://api.whatsapp.com/send?phone=" + mobile + "&text=" + '@ViewBag.domainName' + "/ChurchMeeting/AddEdit?id=" + id;
            window.open(link, "_blank");
    }

</script>