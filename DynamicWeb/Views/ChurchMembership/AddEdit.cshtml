                                                        <input hidden class="MemberArNameVal" value="@item.ArName" />
                                                        <input hidden class="MemberRelativeVal" value="@item.Relative" />
                                                        <input hidden class="MemberMobileVal" value="@item.Mobile" />
                                                        <input hidden class="MemberNotesVal" value="@item.Notes" />
                                                        <label class="control-label MemberArName"> @item.ArName </label>
                                                    </td>
                                                    <td>
                                                        <label class="control-label Relative"> @item.Relative </label>
                                                    </td>
                                                    <td>
                                                        <label class="control-label MemberBirthDate">@item.BirthDate.Value.ToString("MM/dd/yyyy") </label>
                                                    </td>
                                                    <td>
                                                        <label class="control-label MemberMobile"> @item.Mobile </label>
                                                    </td>
                                                    <td>
                                                        <label class="control-label MemberEmail"> @item.Email </label>
                                                        <input hidden class="MemberEmailVal" value="@item.Email" />
                                                        <input hidden class="MemberPasswordVal" value="@item.Password" />
                                                    </td>
                                                    <td>
                                                        <label class="control-label MemberChurchFatherName"> @(item.ChurchFather!=null?item.ChurchFather.ArName:"") </label>
                                                        <input hidden class="MemberChurchFatherId" value="@item.ChurchFatherId" />
                                                    </td>
                                                    <td>
                                                        <input type="checkbox" class="MemberIsAlive" disabled @Html.Raw(item.IsAlive != null && item.IsAlive == true ? "checked" : "") />
                                                    </td> 
                                                    <td>
                                                        <input type="checkbox" class="MemberFollowUp" disabled @Html.Raw(item.FollowUp != null && item.FollowUp == true ? "checked" : "") />
                                                    </td>
                                                    <td>
                                                        <label class="control-label MemberNotes"> @item.Notes </label>
                                                    </td>
                                                    <td>
                                                        <img src="@item.Image" alt="" class="MemberImage" style="max-width:100px;max-height:100px;border-radius:50px;" />
                                                        <input hidden class="MemberImageVal" value="@item.Image" />
                                                    </td>
                                                    <td>
                                                        <a href="javascript:void(0);" onclick="EditMember(this)">
                                                            <i class="fa fa-edit"></i>
                                                        </a>
                                                    </td>
                                                    <td>
                                                        <a href="javascript:void(0);" onclick="DeleteMember(this)">
                                                            <i class="fas fa-trash-alt"></i>
                                                        </a>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>



