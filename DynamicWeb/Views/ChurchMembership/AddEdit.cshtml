    function addEdit(n) {
        let valid = true;
        if ($('.form-horizontal').first().find('.form-control:invalid').length > 0) {
            $('.form-horizontal').first().addClass('was-validated');
            $('html, body').animate({
                scrollTop: $('.form-horizontal').first().find(".form-control:invalid").eq(0).offset().top - 100
            }, 500);
            valid = false;
            console.log($(".form-control:invalid"));
        }
        var member = FamilyMembers.filter(function (i) { return i.Mobile == $('#Mobile').val(); })[0];
        if (member && parseInt($('#Id').val()) !== member.Id) {
                alert('@MyERP.Properties.Resources.ThisMobileNoExistsBefore');
                $('#Mobile').val('');
                valid = false;
            }

        let churchMemberships = [];
        $('#ChurchMembershipFamilyMembers tr').each(function () {
            var td = $(this);
            var ChurchMembershipFamilyMember = {
                Id: td.find('.MemberId').val(),
                Code: td.find('.MemberCode').val(),
                ParentId: $('#Id').val(),
                ArName: td.find('.MemberArNameVal').val(),
                BirthDate: td.find('.MemberBirthDate').text(),
                Relative: td.find('.MemberRelativeVal').val(),
                ConfessionFather: td.find('.MemberConfessionFather').text(),
                Mobile: td.find('.MemberMobileVal').val(),
                IsAlive: td.find('.MemberIsAlive').prop('checked'),
                FollowUp: td.find('.MemberFollowUp').prop('checked'),
                Notes: td.find('.MemberNotesVal').val(),
                IsDeleted: false,
                IsActive: true,
                UserId: $('#UserId').val(),
                Image: td.find('.MemberImageVal').val(),
                Email: td.find('.MemberEmailVal').val(),
                Password: td.find('.MemberPasswordVal').val(),
                ChurchFatherId: td.find('.MemberChurchFatherId').val(),
                AreaId: $('#AreaId').val(),
                Address: $('#Address').val(),

            };
            churchMemberships.push(ChurchMembershipFamilyMember);
        });

        @*if ($('#ChurchMembershipFamilyMembers .card-body').length == 0 ) {
             alert('@MyERP.Properties.Resources.InsertFamilyMembers');
            valid = false;
        }*@

        let ChurchMembershipVisits = [];
        $('#ChurchMembershipVisits tr').each(function () {
            var td = $(this);
            var ChurchMembershipVisit = {
                MainDocId: $('#Id').val(),
                Date: td.find('.VisitDate').text(),
                ConfessionFather: td.find('.VisitConfessionFather').text(),
                Notes: td.find('.VisitNotes').text(),
                IsDeleted: false,
                IsActive: true,
                UserId: $('#UserId').val(),

            };
            if (td.find('.VisitDate').text() /*&& td.find('.VisitConfessionFather').text()*/) {
                ChurchMembershipVisits.push(ChurchMembershipVisit);
            }
        });
        @*if ($('#ChurchMembershipVisits tr').length == 0) {
            alert('@MyERP.Properties.Resources.InsertVisit');
            valid = false;
        }*@
        var churchMembership = {
            Id: $('#Id').val(),
            Code: $('#Code').val(),
            ArName: $('#ArName').val(),
            EnName: $('#EnName').val(),
            BirthDate: $('#BirthDate').val(),
            ConfessionFather: $('#ConfessionFather').val(),
            ChurchFatherId: $('#ChurchFatherId').val(),
            AreaId: $('#AreaId').val(),
            Address: $('#Address').val(),
            Phone: $('#Phone').val(),
            Email: $('#Email').val(),
            Password: $('#Password').val(),
            Mobile: $('#Mobile').val(),
            IsAlive: $('#IsAlive').prop('checked'),
            UserId: $('#UserId').val(),
            IsActive: $('#IsActive').val(),
            IsDeleted: $('#IsDeleted').val(),
            Notes: $('#Notes').val(),
            Image: Imgdata == "" ? $('#Image').val() : Imgdata,
            ParentId: null,
            Relative: null,
            IsUseApplication: $('#IsUseApplication').prop('checked'),
            FollowUp: $('#FollowUp').prop('checked'),
            TopicsForDiscussion: $('#TopicsForDiscussion').val(),
            //ChurchMembershipFamilyMembers: ChurchMembershipFamilyMembers,
            ChurchMembership1: churchMemberships,
            ChurchMembershipVisits: ChurchMembershipVisits,
        }
        if (valid && confirm('@MyERP.Properties.Resources.AreYouSureYouWantToSave')) {
            $('#preloader, #status').fadeIn();
            $('#newbtn').prop('disabled', true);
            $('#save').prop('disabled', true);
            $.ajax({
                type: "POST",
                contentType: "application/json",
                url: "/ChurchMembership/AddEdit",
                data: JSON.stringify(churchMembership ),
                success: function (r) {
                    if (r.success == true) {
                        alert("@MyERP.Properties.Resources.Saved");
                        if (n == "new") {
                            window.location.replace("/ChurchMembership/AddEdit");
                        } else {
                            window.location.replace("/ChurchMembership");
                        }
                    }
                    else {
                        alert("@MyERP.Properties.Resources.NotSaved");
                    }
                    $('#preloader, #status').fadeOut();
                    $('#newbtn').prop('disabled', false);
                    $('#save').prop('disabled', false);
                },
                error: function (r) {
                    alert("@MyERP.Properties.Resources.NotSaved");
                    $('#preloader, #status').fadeOut();
                    $('#newbtn').prop('disabled', false);
                    $('#save').prop('disabled', false);
                }
            });
        }
    }
    function Delete(id) {
        if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToDelete')) {
            $('#preloader, #status').fadeIn();
            $.ajax(
                {
                    url: '/ChurchMembership/Delete',
                    type: 'POST',
                    data: {
                        "Id": id,
                    },
                    error: function (e) {
                        $('#preloader, #status').fadeOut();
                        alert('@MyERP.Properties.Resources.DeleteDoesNotSucceeded');
                    },
                    success: function (r) {
                        if (r == 'true') {
                            window.location.replace('/ChurchMembership');
                        } else
                            alert('@MyERP.Properties.Resources.DeleteDoesNotSucceeded');
                    }
                });
        }
    }
