<script>

    //--------------- Variables Declarations -------------------//
    var Imgdata = "";
    var FamilyMembers = [];
    //*********************************************************//

    //--------------- Ready Function -------------------//
    $(document).ready(function () {
        $('#BirthDate').val('@ViewBag.BirthDate');
        GetMembers();
        if ($('#Id').val() > 0) {
        }
        else {
            setCodeNum();
        }
    });
    //*********************************************************//

    //--------------- Event Functions -------------------//
    //$(document).on('change', ".MemberArName:last,  .Relative:last, .MemberConfessionFather:last, .MemberMobile:last, .MemberBirthDate:last", function () {
    //    AddToChurchMembershipFamilyMembers();
    //});
    //$(document).on('change', ".VisitDate:last,  .VisitConfessionFather:last", function () {
    //    AddToChurchMembershipVisits();
    //});
    $(document).on('click', '#AddFamilyMemberBtn', function () {
        $('#AddFamilyMemberModal').modal("show");
    });
    $(document).on('click', '#AddVisitBtn', function () {
        $('#AddVisitModal').modal("show");
    });
    $(document).on('keydown', '#Mobile', function (e) {
        if (e.which == 13 || e.keyCode == 13) {
            $.get('/ChurchMembership/SearchByMobileNo?Mobile=' + $(this).val()).done(function (r) {
                if (r > 0 && confirm('@MyERP.Properties.Resources.ThisMemberExistBeforeDoYouWantToRedirect ?')) {
                    window.location.replace("/ChurchMembership/AddEdit?id=" + r);
                }
                else {
                    $('#Mobile').val('');
                }

            });
        }
    });

    $(document).on('keydown', '#MemberMobilePopUp', function (e) {
        if (e.which == 13 || e.keyCode == 13) {
            $.get('/ChurchMembership/SearchFamilyMemberByMobileNo?Mobile=' + $(this).val()).done(function (r) {
                if (r) {
                    r = r[0];
                    r.BirthDate = r.BirthDate != null ? convertToJavaScriptDate(r.BirthDate) : null;
                    $("#Membergallery").html('<img style="max-width: 200px;max-height: 200px;margin-left: 2%;margin-bottom: 2%;" src="' + r.Image + '" alt="" /><i class="fas fa-trash-alt" style="cursor:pointer;" onclick="DeleteMemberIMG(\'' + r.Image + '\');$(this).prev().remove();$(this).remove();"></i>');
                    $('#PopUpMemberImage').val(r.Image);
                    $('#MemberIdPopUp').val(r.Id);
                    $('#MemberCodePopUp').val(r.Code);
                    $('#MemberArNamePopUp').val(r.ArName);
                    $('#RelativePopUp').val(r.Relative);
                    $('#MemberBirthDatePopUp').val(r.BirthDate);
                    $('#MemberConfessionFatherPopUp').val(r.ConfessionFather);
                   // $('#MemberMobilePopUp').val(r.Mobile);
                    $('#MemberEmailPopUp').val(r.Email);
                    $('#MemberPasswordPopUp').val(r.Password);
                    $('#MemberNotesPopUp').val(r.Notes);
                    $('#MemberIsAlivePopUp').prop('checked', r.IsAlive);
                    $('#MemberFollowUpPopUp').prop('checked', r.FollowUp);
                }
            });
        }
    });
    //*********************************************************//

     //--------------- Other Functions -------------------//
    function GetMembers() {
        return requestData('/ChurchMeeting/GetMembers').done(function (r) {
            FamilyMembers = r;
        });
    }
    function convertToJavaScriptDate(value) {
        if (value === null)
            return null;
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        var month = (dt.getMonth() + 1) < 10 ? '0' + (dt.getMonth() + 1) : (dt.getMonth() + 1);
        var day = dt.getDate() < 10 ? '0' + dt.getDate() : dt.getDate();
        var hours = dt.getHours();
        var minutes = dt.getMinutes();
        var seconds = dt.getSeconds();
        var ampm = hours >= 12 ? 'PM' : 'AM';
        hours = hours % 12;
        hours = hours ? hours : 12; // the hour '0' should be '12'
        hours = hours < 10 ? '0' + hours : hours;
        minutes = minutes < 10 ? '0' + minutes : minutes;
        seconds = seconds < 10 ? '0' + seconds : seconds;
        var strTime = hours + ':' + minutes /*+ ":" + seconds + ' ' + ampm*/;
        return ((dt.getFullYear() + "-" + month + "-" + day) + "T" + strTime);

        //2022 - 01 - 18T20: 23
    }

    function previewImage() {
        var reader = new FileReader();
        let valid = true;

        reader.addEventListener("load", function () {

            $("#gallery").html('<img style="max-width: 200px;max-height: 200px;margin-left: 2%;margin-bottom: 2%;" src="' + reader.result + '" alt="" /><i class="fas fa-trash-alt" style="cursor:pointer;" onclick="DeleteIMG(\'' + reader.result + '\');$(this).prev().remove();$(this).remove();"></i>');
            $("#Image").val(reader.result);
            Imgdata = reader.result;
        }, false);
        for (var i = 0; i < $("#BrowseImage")[0].files.length; i++) {
            if ($("#BrowseImage")[0].files[i]) {
                reader.readAsDataURL($("#BrowseImage")[0].files[i]);
                if ($("#BrowseImage")[0].files[i].size > 1000000) {
                    alert('@MyERP.Properties.Resources.PictureSizeIsTooLargeChooseAnotherOne');
                    valid = false;
                }
            }
           
        }
        reader.addEventListener("loadend", function () {
            if (valid == false) {
                DeleteIMG();
            }
        });
       
    }
    function DeleteIMG(url) {
        $("#gallery").empty();
        $("#BrowseImage").val('');
        $("#Image").val('');
    }
    function DeleteMemberIMG(url) {
        $("#Membergallery").empty();
        $("#PopUpMemberImage").val('');
    }
    function MemberpreviewImage() {
        var reader = new FileReader();
        reader.addEventListener("load", function () {

            $("#Membergallery").html('<img style="max-width: 200px;max-height: 200px;margin-left: 2%;margin-bottom: 2%;" src="' + reader.result + '" alt="" /><i class="fas fa-trash-alt" style="cursor:pointer;" onclick="DeleteMemberIMG(\'' + reader.result + '\');$(this).prev().remove();$(this).remove();"></i>');
            $("#PopUpMemberImage").val(reader.result);
        }, false);

        for (var i = 0; i < $("#MemberBrowseImage")[0].files.length; i++) {
            if ($("#MemberBrowseImage")[0].files[i]) {
                reader.readAsDataURL($("#MemberBrowseImage")[0].files[i]);
            }
        }
    }

    function setCodeNum() {
        var doc = $.get('/ChurchMembership/SetCodeNum').done(function (r) {
            $('#Code').val(r);
        });
    }
    function zeroPadded(val) {
        if (val >= 10)
            return val;
        else
            return '0' + val;
    }

    function ChangeDateFormat(value) {
        if (value === null) {
            return null;
        }
        //var dt = new Date(parseFloat(value));
        var dt = new Date(value);
        var month = (dt.getMonth() + 1) < 10 ? '0' + (dt.getMonth() + 1) : (dt.getMonth() + 1);
        var day = dt.getDate() < 10 ? '0' + dt.getDate() : dt.getDate();
        var hours = dt.getHours();
        var minutes = dt.getMinutes();
        var seconds = dt.getSeconds();
        var ampm = hours >= 12 ? 'PM' : 'AM';
        hours = hours % 12;
        hours = hours ? hours : 12; // the hour '0' should be '12'
        hours = hours < 10 ? '0' + hours : hours;
        minutes = minutes < 10 ? '0' + minutes : minutes;
        seconds = seconds < 10 ? '0' + seconds : seconds;
        var strTime = hours + ':' + minutes /*+ ":" + seconds + ' ' + ampm*/;
        return ((dt.getFullYear() + "-" + month + "-" + day) + "T" + strTime);

        //2022 - 01 - 18T20: 23
    }

    function DeleteMember(e) {
        //let DivElement = $(e).closest('.card-body');
        //DivElement.remove();
        deleteElement(e);
    }

    function EditMember(e) {
        //let DivElement = $(e).closest('.card-body');
        let DivElement = $(e).closest('tr');
        let MemberId = DivElement.find('.MemberId').val();
        let MemberCode = DivElement.find('.MemberCode').val();
        let MemberArName = DivElement.find('.MemberArNameVal').val();
        let Relative = DivElement.find('.MemberRelativeVal').val();
        let MemberBirthDate = DivElement.find('.MemberBirthDate').text();
        MemberBirthDate = MemberBirthDate != null ? ChangeDateFormat(MemberBirthDate.replace('T', ' ')) : "";
        let MemberConfessionFather = DivElement.find('.MemberConfessionFather').text();
        let MemberMobile = DivElement.find('.MemberMobileVal').val();
        let MemberNotes = DivElement.find('.MemberNotesVal').val();
        let MemberIsAlive = DivElement.find('.MemberIsAlive').prop('checked') == true ? true : false;
        let MemberFollowUp = DivElement.find('.MemberFollowUp').prop('checked') == true ? true : false;
        let MemberImage = DivElement.find('.MemberImageVal').val();
        let MemberEmail = DivElement.find('.MemberEmailVal').val();
        let MemberPassword = DivElement.find('.MemberPasswordVal').val();
        let MemberChurchFatherId = DivElement.find('.MemberChurchFatherId').val();

        $('#AddFamilyMemberModal').modal("show");
        if (MemberId > 0) {
            $('#MemberPasswordPopUp').attr('hidden', true);
        }
        $("#Membergallery").html('<img style="max-width: 200px;max-height: 200px;margin-left: 2%;margin-bottom: 2%;" src="' + MemberImage + '" alt="" /><i class="fas fa-trash-alt" style="cursor:pointer;" onclick="DeleteMemberIMG(\'' + MemberImage + '\');$(this).prev().remove();$(this).remove();"></i>');
        $('#PopUpMemberImage').val(MemberImage);
        $('#MemberIdPopUp').val(MemberId);
        $('#MemberCodePopUp').val(MemberCode);
        $('#MemberArNamePopUp').val(MemberArName);
        $('#RelativePopUp').val(Relative);
        $('#MemberBirthDatePopUp').val(MemberBirthDate);
        $('#MemberConfessionFatherPopUp').val(MemberConfessionFather);
        $('#MemberMobilePopUp').val(MemberMobile);
        $('#MemberEmailPopUp').val(MemberEmail);
        $('#MemberPasswordPopUp').val(MemberPassword);
        $('#MemberNotesPopUp').val(MemberNotes);
        $('#PopUpMemberChurchFatherId').val(MemberChurchFatherId).select2();
        $('#MemberIsAlivePopUp').prop('checked', MemberIsAlive);
        $('#MemberFollowUpPopUp').prop('checked', MemberFollowUp);
        // To Replace Old Div With New Edited in Case Of Save
        $('#AddFamilyMemberModal .modal-footer button').on('click', function (event) {
            var $button = $(event.target); // The clicked button
            // Fire if the button element To check Which btn is clicked
            if ($button.text() == '@MyERP.Properties.Resources.Save') {
                DivElement.remove();
            }
        });
    }


    function AddFamilyMember() {
        let i = 0;
        if ($('#Id').val() > 0 && $('#MemberCodePopUp').val() > 0) {
            i = $('#MemberCodePopUp').val();
        }
        else {
            if ($('#ChurchMembershipFamilyMembers tr').length == 0) {

                i = $('#MemberCodeRes').val();
            }
            else {
                i = parseInt($('#ChurchMembershipFamilyMembers tr:last').find('.MemberCode').val()) + 1;
            }
        }

        let MemberIdPopUp =$('#MemberIdPopUp').val()>0? parseInt( $('#MemberIdPopUp').val()):0;
        let MemberArName = $('#MemberArNamePopUp').val();
        let Relative = $('#RelativePopUp').val();
        let MemberBirthDate = $('#MemberBirthDatePopUp').val();
        MemberBirthDate = MemberBirthDate != null ? (new Date(MemberBirthDate)).toLocaleString().split(',')[0] : null;
        let MemberConfessionFather = $('#MemberConfessionFatherPopUp').val();
        let MemberMobile = $('#MemberMobilePopUp').val();
        let MemberEmail = $('#MemberEmailPopUp').val();
        let MemberPassword = $('#MemberPasswordPopUp').val();
        let MemberNotes = $('#MemberNotesPopUp').val();
        let MemberImage = $('#PopUpMemberImage').val();
        let MemberChurchFatherId = $('#PopUpMemberChurchFatherId').val();
        let MemberChurchFatherName = $('#PopUpMemberChurchFatherId').val()>0?$('#PopUpMemberChurchFatherId option:selected').text():"";
        let MemberIsAlive = $('#MemberIsAlivePopUp').prop('checked') == true ? "checked" : "checked";
        let MemberFollowUp = $('#MemberFollowUpPopUp').prop('checked') == true ? "checked" : "";

        let valid = true;
        if ($('#MemberArNamePopUp').val()=="" || $('#RelativePopUp').val()=="" || $('#MemberConfessionFatherPopUp').val()=="" || $('#MemberMobilePopUp').val()=="" || $('#MemberBirthDatePopUp').val()=="") {

            $('#MemberArNamePopUp').prop('required', 'required');
           // $('#RelativePopUp').prop('required',  'required');
           // $('#MemberMobilePopUp').prop('required',  'required');
           // $('#MemberBirthDatePopUp').prop('required',  'required');
           // $('#MemberConfessionFatherPopUp').prop('required',  'required');
        }

        var member = FamilyMembers.filter(function (i) { return i.Mobile == $('#MemberMobilePopUp').val(); })[0];
        if (member && MemberIdPopUp !== member.Id) {
                alert('@MyERP.Properties.Resources.ThisMobileNoExistsBefore');
                $('#MemberMobilePopUp').val('');
                valid = false;
            }

        if ($('#AddFamilyMemberModal').find(".form-control:invalid").length > 0) {
            $('#AddFamilyMemberModal').find('.form-horizontal').addClass('was-validated');
                $('html, body').animate({
                    scrollTop: $(".form-control:invalid").eq(0).offset().top - 80
                }, 500);
            valid = false;
        }
