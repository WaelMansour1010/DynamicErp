                $('#VisitDatePopUp').val('@ViewBag.BirthDate');
                $('#VisitConfessionFatherPopUp').val('');
                $('#VisitNotesPopUp').val('');
                $('#AddVisitModal').modal("hide");
            }
        }

    }



