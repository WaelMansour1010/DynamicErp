                @if (Model != null && Model.Id > 0 && Model.Password != null)
                {
                    <input type="text" class="form-control" name="Password" id="Password" value="@Model.Password" hidden  />
                }
                else
                {
                    <input type="text" class="form-control" name="Password" id="Password"  />
                }
                <div class="invalid-feedback">
                    @MyERP.Properties.Resources.Required
                </div>
            </div>*@
                                </div>

                                <div class="form-group row">
                                    <label for="PhoneNumber" class="control-label col-sm-2">@MyERP.Properties.Resources.Tel </label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.Phone, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.Tel } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label for="MobileNumber" class="control-label col-sm-2"> @MyERP.Properties.Resources.Mobile</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.Mobile, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.Mobile } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <div class="col-sm-6">
                                        <input type="checkbox" name="IsUseApplication" @Html.Raw(Model != null && Model.IsUseApplication == true ? "checked" : "") id="IsUseApplication" />
                                        <label class="col-sm-10 control-label" for="IsUseApplication">
                                            @MyERP.Properties.Resources.IsUseApplication
                                        </label>
                                    </div>
                                    <div class="col-sm-6">
                                        <input type="checkbox" name="FollowUp" @Html.Raw(Model != null && Model.FollowUp == true ? "checked" : "") id="FollowUp" />
                                        <label class="col-sm-10 control-label" for="FollowUp">
                                            @MyERP.Properties.Resources.FollowUp
                                        </label>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <div class="col-sm-6">
                                        <input type="checkbox" name="IsAlive" @Html.Raw(Model != null && Model.IsAlive == true ? "checked" : Model == null ? "checked" : "") id="IsAlive" />
                                        <label class="col-sm-10 control-label" for="IsAlive">
                                            @MyERP.Properties.Resources.IsAlive
                                        </label>
                                    </div>
                                    <div class="row">
                                        @* مكان الصورة *@
                                        <div class="col-sm-6">
                                            <div class="tab-pane" id="5">
                                                <label class="col-sm-8 control-label">@MyERP.Properties.Resources.Image</label>
                                                <div id="gallery" style="width: 100%;margin: 20px;">

                                                    @if (Model != null && Model.Image != null)
                                                    {
                                                        <img src="@Model.Image" alt="" class="img_@Model.Id" style="max-width: 200px;max-height: 200px;" />
                                                        <i class="fas fa-trash-alt img_@Model.Id" style="cursor:pointer;" onclick="DeleteIMG('@Model.Id');$(this).prev().remove();$(this).remove();"></i>
                                                    }
                                                </div>
                                                <input type="file" id="BrowseImage" onchange="previewImage()" value="Browse" />
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                
                                <div class="form-group row">
                                    <label class="control-label col-sm-2" for="Address">@MyERP.Properties.Resources.Address</label>
                                    <div class="col-sm-4">
                                        <textarea id="Address" name="Address" class="form-control" rows="5" cols="5">@if (Model != null) { @Model.Address; }</textarea>
                                    </div>
                                    <label class="control-label col-sm-2" for="Notes">@MyERP.Properties.Resources.Notes</label>
                                    <div class="col-sm-4">
                                        <textarea id="Notes" name="Notes" class="form-control" rows="5" cols="5">@if (Model != null) { @Model.Notes; }</textarea>
                                    </div>
                                </div>
                                <div class="form-group row">

                                    <label class="control-label col-sm-2" for="TopicsForDiscussion">@MyERP.Properties.Resources.TopicsForDiscussion</label>
                                    <div class="col-sm-4">
                                        <textarea id="TopicsForDiscussion" name="TopicsForDiscussion" class="form-control" rows="5" cols="5">@if (Model != null) { @Model.TopicsForDiscussion; }</textarea>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

