@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.MembersBirthDay;
}
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
            </div>
            <h4 class="page-title"> @MyERP.Properties.Resources.MembersBirthDay </h4>
        </div>
    </div>
</div>


<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal needs-validation" role="form">
                        <div class="card">
                            <div class="card-body">
                                @Html.AntiForgeryToken()
                                @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                                <h5 class="header-title">
                                    @MyERP.Properties.Resources.MembersBirthDay
                                </h5>
                                <div class="form-group row">
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.Date</label>
                                    <div class="col-sm-4">
                                        @Html.Editor("Date", new { htmlAttributes = new { @class = "form-control", @type = "date" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <button type="button" class="btn btn-success" onclick="MembersBirthDay()">
                                        <i class="fa fa-search"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                        <div class="card">
                            <div class="card-body">

                                <div class="row">
                                    <div class="col-12">
                                        <div class="table-responsive">
                                            <table class="table table-striped table-centered mb-0">
                                                <thead>
                                                    <tr>
                                                        <th>
                                                            @MyERP.Properties.Resources.Name
                                                        </th>
                                                        <th>
                                                            @MyERP.Properties.Resources.BirthDate
                                                        </th>
                                                        <th>
                                                            @MyERP.Properties.Resources.Mobile
                                                        </th> 
                                                        <th>
                                                            @MyERP.Properties.Resources.Area
                                                        </th> 
                                                        <th>
                                                            @MyERP.Properties.Resources.Image
                                                        </th>
                                                        <th>
                                                            @MyERP.Properties.Resources.Send
                                                        </th>
                                                    </tr>
                                                </thead>
                                                <tbody id="Details">
                                                    @*<tr>
                                                        <td><a href="https://api.whatsapp.com/send?phone=01226932465&text=hi" target="_blank"><i class="fab fa-whatsapp"></i></a></td>
                                                    </tr>*@
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>


                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-------------------------------------------------------------------------------------------------------------------------------------------------------------------->
            <div class="row">
                <div class="col-sm-offset-2">
                    <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                </div>
            </div>
        </div>
    </div>
</div>


<!------------------------------------------------------------------------------------------------------------------------------------------------------------------>

<script>

    //--------------- Variables Declarations -------------------//

    //*********************************************************//

    //--------------- Ready Function -------------------//
    $(document).ready(function () {
        $('#Date').val('@ViewBag.Date');
        if ($('#Id').val() > 0) {
        }
        else {
        }
    });
    //*********************************************************//

    //--------------- Event Functions -------------------//
    //$(document).on('change', '#Date', function () {
    //    MembersBirthDay()
    //});
    //*********************************************************//
    //--------------- Other Functions -------------------//
    function MembersBirthDay() {
        $('#Details').empty();
        $.ajax({
            url: '/ChurchMembership/MembersBirthDay?Date=' + $('#Date').val(),
            type: 'Get',
            //data: {
            //    "Date": $('#Date').val(),
            //},
            success: function (r) {
                if (r) {
                   
                for (var i = 0; i < r.length; i++) {
                    r[i].BirthDate = r[i].BirthDate != null ? convertToJavaScriptDate(r[i].BirthDate) : "";
                    r[i].Mobile = r[i].Mobile != null ? r[i].Mobile : "";
                    r[i].Area = r[i].Area != null ? r[i].Area : "";
                    r[i].Image = r[i].Image != null ? "<img src ='" +
                        r[i].Image + "' alt='' style='width:50px;height:50px;border-radius:50px;' />"
                        : "<img src ='/assets/images/users/Avatar_User.png' alt='' style='width:50px;height:50px;border-radius: 50px;' />";

                    //let txt = "HaPpY BirthDay !";
                    let tr = '<tr><td><label class="control-label ArName">' +
                        r[i].ArName + '</label></td><td><label class="control-label BirthDate">' +
                        r[i].BirthDate + '</label></td><td><label class="control-label Mobile">' +
                        r[i].Mobile + '</label></td><td><label class="control-label Area">' +
                        r[i].Area + '</label></td><td>' + r[i].Image +'</td><td><a href="https://api.whatsapp.com/send?phone=' +
                        r[i].Mobile + '&text=HaPpY BirthDay !" target="_blank"><i class="fab fa-whatsapp"></i></a></td></tr>';
                    $('#Details').append(tr);
                }
                 }
            }
        });
    }

    function convertToJavaScriptDate(value) {
        if (value === null)
            return null;
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        var month = (dt.getMonth() + 1) < 10 ? '0' + (dt.getMonth() + 1) : (dt.getMonth() + 1);
        var day = dt.getDate() < 10 ? '0' + dt.getDate() : dt.getDate();
        var hours = dt.getHours();
        var minutes = dt.getMinutes();
        var seconds = dt.getSeconds();
        var ampm = hours >= 12 ? 'PM' : 'AM';
        hours = hours % 12;
        hours = hours ? hours : 12; // the hour '0' should be '12'
        hours = hours < 10 ? '0' + hours : hours;
        minutes = minutes < 10 ? '0' + minutes : minutes;
        seconds = seconds < 10 ? '0' + seconds : seconds;
        var strTime = hours + ':' + minutes /*+ ":" + seconds + ' ' + ampm*/;
        return ((dt.getFullYear() + "-" + month + "-" + day)/* + "T" + strTime*/);

        //2022 - 01 - 18T20: 23
    }

    //*********************************************************//

</script>




