@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.Correction;
    Layout = "~/Views/Shared/_ActivityLayout.cshtml";
}
<script src="~/Scripts/SaveAndNew.js"></script>

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="hed page-title">@MyERP.Properties.Resources.Correction :</div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="form-horizontal needs-validation" role="form">
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">
                                <div class="form-group row">
                                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                    @Html.AntiForgeryToken()

                                </div>


                                <div class="form-group row">
                                    <label for="Date" class="control-label col-sm-2">@MyERP.Properties.Resources.Date</label>
                                    <div class="col-sm-4">
                                        <input id="Date" class="form-control" type="datetime-local" required />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>

                                </div>


                                <div class="row">
                                    <div class="col-12">
                                        <div class="table-responsive">
                                            <table class="table table-striped table-centered mb-0">
                                                <thead>
                                                    <tr>
                                                        <th>@MyERP.Properties.Resources.Date</th>
                                                        <th>@MyERP.Properties.Resources.Competitor</th>
                                                        <th>@MyERP.Properties.Resources.Question</th>
                                                        <th>@MyERP.Properties.Resources.Answer</th>
                                                        <th>@MyERP.Properties.Resources.Correction</th>
                                                    </tr>
                                                </thead>
                                                <tbody id="AnswerDiv">

                                                    
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>









                                @*<div class="row">
                                        <div class="col-12">
                                            <div class="card">
                                                <div class="card-body" id="AnswerDiv">

                                                </div>
                                            </div>
                                        </div>
                                    </div>*@

                            </div>
                        </div>
                    </div>


                </div>
            </div>
            @*</form>*@
            <!---------------------------------------------- Saves Buttons ----------------------------------------------------------->
            <div class="row">
                <div class="col-sm-offset-2">
                   
                        <button onclick="Correction();" class="btn btn-success" id="save">
                            @MyERP.Properties.Resources.Send
                        </button>
                       
                </div>
            </div>
            <!----------------------------------------------------------------------------------------------------------------------------------------->


        </div>
    </div>
</div>



<script>
    //--------------- Variables Declarations -------------------//

    //*********************************************************//
    //--------------- Ready Function -------------------//
    $(document).ready(function () {
        $('#Date').val('@ViewBag.Date');
        if ($('#Id').val() == 0) {
        }
       // GetAnswersToCorrect();
    });

    //*********************************************************//
    //--------------- Event Functions -------------------//
    $(document).on('change', '#Date', function () {
        GetAnswersToCorrect();
    });
    //*********************************************************//
     //--------------- Other Functions -------------------//

    function GetAnswersToCorrect() {
        $("#AnswerDiv").empty()
        $.get('/CompetitorAnswer/GetAnswersToCorrect?Date=' + $('#Date').val()).done(function (r) {
            for (var i = 0; i < r.length; i++) {
                r[i].IsTrue = r[i].IsTrue == true ? "checked" : "";
                r[i].UserName = r[i].UserName != null ? r[i].UserName : "";
                r[i].CompetitorId = r[i].CompetitorId != null ? r[i].CompetitorId : null;
                r[i].Date = r[i].Date != null ? convertToJavaScriptDate(r[i].Date) : "";
                let tr = '<tr><td><label class="control-label">' +
                    r[i].Date + '</label></td ><td><label class="control-label">' +
                    r[i].UserName + '</label></td ><td><input class="QuestionId" hidden value="' +
                    r[i].Id + '" /><input class="CompetitorId" hidden  value="' +
                    r[i].CompetitorId + '" /><label class="control-label">' +
                    r[i].Question + '</label></td><td><label class="control-label Answer">' +
                    r[i].Answer + '</label></td><td><input class="IsTrue" type="checkbox" ' +
                    r[i].IsTrue + ' /></td></tr > ';
                $("#AnswerDiv").append(tr);

                //var Div = '<div class="form-group" ><label class="col-sm-6 control-label"> ' +
                //    r[i].Question + ' </label><input class="QuestionId" hidden value="' +
                //    r[i].Id + '" /><div class="col-sm-6"><textarea readonly class="form-control Answer">' +
                //    r[i].Answer + '</textarea><input class="IsTrue" type="checkbox" ' +
                //    r[i].IsTrue + ' /></div></div >';
                //$("#AnswerDiv").append(Div);
            }
        });
    }
    function convertToJavaScriptDate(value) {
        if (value === null)
            return null;
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        return ((dt.getMonth() + 1 + "/" + dt.getDate() + "/" + dt.getFullYear()));
        // return (dt)
    }
    function zeroPadded(val) {
        if (val >= 10)
            return val;
        else
            return '0' + val;
    }
//***********************************************************************************************************************************//
    function Correction(n) {
        let valid = true;
        if ($('.form-horizontal').first().find('.form-control:invalid').length > 0) {
            $('.form-horizontal').first().addClass('was-validated');
            $('html, body').animate({
                scrollTop: $('.form-horizontal').first().find(".form-control:invalid").eq(0).offset().top - 100
            }, 500);
            valid = false;
            console.log($(".form-control:invalid"));
        }
        var competitorAnswers = [];
        if (valid) {
            $('#AnswerDiv tr').each(function () {
                var td = $(this);
                var CompetitorAnswer = {
                    CompetitorId: td.find('.CompetitorId').val() ,
                    Date: $('#Date').val(),
                    QuestionId: td.find('.QuestionId').val(),
                    IsDeleted: false,
                    IsActive: true,
                    Answer: td.find('.Answer').text(),
                    Notes: td.find('.Notes').text(),
                    IsTrue: td.find('.IsTrue').prop('checked'),
                };
                competitorAnswers.push(CompetitorAnswer);
            });
        }


        if (valid) {
            $('#preloader, #status').fadeIn();
            $('#newbtn').prop('disabled', true);
            $('#save').prop('disabled', true);
            $.ajax({
                type: "POST", contentType: "application/json",
                url: "/CompetitorAnswer/Correction",
                data: JSON.stringify(competitorAnswers),
                success: function (r) {
                    if (r.success == true) {
                        Swal.fire({
                            title: '@MyERP.Properties.Resources.Saved',
                            text: " ",
                            icon: 'success',
                            showCancelButton: false,
                            confirmButtonText: '@MyERP.Properties.Resources.Ok',
                            confirmButtonColor: '#3085d6'
                        });

                        window.location.replace("/CompetitorAnswer/Correction");

                    }
                    else {
                        Swal.fire({
                            title: '@MyERP.Properties.Resources.NotSaved !',
                            text: " ",
                            icon: 'error',
                            showCancelButton: false,
                            confirmButtonText: '@MyERP.Properties.Resources.Ok',
                            confirmButtonColor: '#3085d6'
                        });
                    }
                    $('#preloader, #status').fadeOut();
                    $('#newbtn').prop('disabled', false);
                    $('#save').prop('disabled', false);
                },
                error: function (r) {
                    Swal.fire({
                        title: '@MyERP.Properties.Resources.NotSaved !',
                        text: " ",
                        icon: 'error',
                        showCancelButton: false,
                        confirmButtonText: '@MyERP.Properties.Resources.Ok',
                        confirmButtonColor: '#3085d6'
                    });
                    $('#preloader, #status').fadeOut();
                    $('#newbtn').prop('disabled', false);
                    $('#save').prop('disabled', false);
                }
            });
        }
    }

    //*********************************************************//
</script>