
@{
    UICulture = Session["lang"] != null?Session["lang"].ToString():"ar";

    ViewBag.Title = MyERP.Properties.Resources.CostCenterTrialBalance;
}

<link rel="stylesheet" href="https://kendo.cdn.telerik.com/2018.2.516/styles/kendo.common-material.min.css" />
<link rel="stylesheet" href="https://kendo.cdn.telerik.com/2018.2.516/styles/kendo.material.min.css" />
<link rel="stylesheet" href="https://kendo.cdn.telerik.com/2018.2.516/styles/kendo.material.mobile.min.css" />
<script src="https://kendo.cdn.telerik.com/2018.2.516/js/kendo.all.min.js"></script>

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title">@MyERP.Properties.Resources.CostCenterTrialBalance</div>
        </div>
    </div>
</div>

<div class="card-box">
    <div class="row">
        <div class="col-12">
            <div class="form-horizontal" role="form">
                <div class="form-group row">
                    <label for="DepartmentId" class="control-label col-sm-1">@MyERP.Properties.Resources.Branch</label>
                    <div class="col-sm-5">
                        @Html.DropDownList("DepartmentId", null, @MyERP.Properties.Resources.All, htmlAttributes: new { @class = "form-control" })
                    </div>
                </div>
                <div class="form-group row">
                    <label class="col-sm-1 control-label " for="DateFrom">@MyERP.Properties.Resources.FromDate</label>
                    <div class="col-sm-5">
                        <input id="DateFrom" class="form-control" type="datetime-local" />
                    </div>

                    <label class="col-sm-1 control-label " for="DateTo">@MyERP.Properties.Resources.ToDate</label>
                    <div class="col-sm-5">
                        <input id="DateTo" class="form-control" type="datetime-local" />
                    </div>
                </div>
                <div class="form-group">
                    <div class="col-sm-6">
                        <button class="btn btn-success" id="treeCollapse">@MyERP.Properties.Resources.Total</button>

                        <button class="btn btn-success" id="treeExpand" style="">@MyERP.Properties.Resources.Detailed</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<div id="treelist"></div>
<script>
    function zeroPadded(val) {
        if (val >= 10)
            return val;
        else
            return '0' + val;
    }

    var d = new Date();
    $('#DateFrom').val('@ViewBag.DateFrom');
    $('#DateTo').val(d.getFullYear() + "-" + zeroPadded(d.getMonth() + 1) + "-" + zeroPadded(d.getDate()) + "T" + zeroPadded(d.getHours()) + ":" + zeroPadded(d.getMinutes()));

    function getCostCenterTrialBalance() {

        $("#treelist").kendoTreeList({
            pageable: {
                pageSize: 15,
                alwaysVisible: true,
                pageSizes: true
            },
            dataSource: {
                    transport: {
                        read: {
                            url: "/CostCenterTrialBalance/GETTrialBalance?from=" + $('#DateFrom').val() + "&to=" + $('#DateTo').val() +"&depId=" + $('#DepartmentId').val(),
                            dataType: "json"
                        }
                    },
                    schema: {
                        model: {
                            id: "Id",
                            parentId: "ParentId",
                            fields: {
                                ParentId: { field: "ParentId", nullable: true },
                                Code: { field: "Code", nullable: true },
                                ArName: { field: "ArName", nullable: true },
                                ObDebit: { field: "ObDebit", type: "number" },
                                ObCredit: { field: "ObCredit", type: "number" },
                                Debit: { field: "Debit", type: "number" },
                                Credit: { field: "Credit", type: "number" },
                                TotalDebit: { field: "TotalDebit", type: "number" },
                                TotalCredit: { field: "TotalCredit", type: "number" },
                                BalanceDebit: { field: "BalanceDebit", type: "number" },
                                BalanceCredit: { field: "BalanceCredit", type: "number" }
                            },
                            expanded: true
                        }
                    }
                },
                scrollable: true,
                columns: [{
                    field: "Code", title: "@MyERP.Properties.Resources.Code", width: 100, headerAttributes: {
                        style: "text-align: right; font-size:small; color:black; font-weight:bold"
                    } },
                    {
                        field: "ArName", title: "@MyERP.Properties.Resources.ArName", width: 150, headerAttributes: {
                            style: "text-align: right; font-size:small; color:black; font-weight:bold"
                        } },
                    {
                        field: "ObDebit", title: "@MyERP.Properties.Resources.DebitOB", width: 130, headerAttributes: {
                            style: "text-align: right; font-size:small; color:black; font-weight:bold"
                        } },
                    {
                        field: "ObCredit", title: "@MyERP.Properties.Resources.CreditOB", width: 130, headerAttributes: {
                            style: "text-align: right; font-size:small; color:black; font-weight:bold"
                        } },
                    {
                        field: "Debit", title: "@MyERP.Properties.Resources.DebitTransaction", width: 130, headerAttributes: {
                            style: "text-align: right; font-size:small; color:black; font-weight:bold"
                        } },
                    {
                        field: "Credit", title: "@MyERP.Properties.Resources.CreditTransaction", width: 130, headerAttributes: {
                            style: "text-align: right; font-size:small; color:black; font-weight:bold"
                        } },
                    {
                        field: "TotalDebit", title: "@MyERP.Properties.Resources.TotalDebit", width: 130, headerAttributes: {
                            style: "text-align: right; font-size:small; color:black; font-weight:bold"
                        } },
                    {
                        field: "TotalCredit", title: "@MyERP.Properties.Resources.TotalCredit", width: 130, headerAttributes: {
                            style: "text-align: right; font-size:small; color:black; font-weight:bold"
                        } },
                    {
                        field: "BalanceDebit", title: "@MyERP.Properties.Resources.DebitBalance", width: 130, headerAttributes: {
                            style: "text-align: right; font-size:small; color:black; font-weight:bold"
                        }},
                    {
                        field: "BalanceCredit", title: "@MyERP.Properties.Resources.CreditBalance", width: 130, headerAttributes: {
                            style: "text-align: right; font-size:small; color:black; font-weight:bold"
                        }
                    }]
            });

    }
    $(document).ready(function () {
        getCostCenterTrialBalance();
    });

    $('#DateFrom').on('change', function () {
        $('#treelist').empty();
        getCostCenterTrialBalance();
    });

    $('#DateTo').on('change', function () {
        $('#treelist').empty();
        getCostCenterTrialBalance();
    });

    $('#DepartmentId').on('change', function () {
        $('#treelist').empty();

        getCostCenterTrialBalance();
    });

    $("#treeCollapse").click(function () {
        var treeList = $("#treelist").data("kendoTreeList");
        treeList.collapse($("#treelist tbody>tr:eq(0)"));
    });

    $("#treeExpand").click(function () {
        var treeList = $("#treelist").data("kendoTreeList");
        treeList.expand($("#treelist tbody>tr:eq(0)"));
    });
</script>