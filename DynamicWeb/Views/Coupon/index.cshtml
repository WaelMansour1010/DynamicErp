@model IEnumerable<MyERP.Models.Coupon>
@{
    if (System.Web.Configuration.WebConfigurationManager.AppSettings["ECommerce"] == "true")
    {
        Layout = "~/Views/Shared/_EcommerceLayout.cshtml";
    }
}
@{
    ViewBag.Title = "كوبونات الخصم";

}

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <a class="btn btn-info" href="@Url.Action("AddEdit")" role="button" style="float:left;">إضافة جديد</a>
            </div>
            <div class="hed page-title">@ViewBag.Title</div>
        </div>
    </div>
</div>









<div class="card-box">
    <div class="row">
        <div class="col-12">
            <div class="form-horizontal" role="form">
                <div class="form-group row">
                    <div class="col-xs-12 col-sm-6 col-lg-3">
                        <input type="text" class="form-control searchtxt" value="@Html.Raw(ViewBag.searchWord)" placeholder="بحث">
                    </div>
                    <div class="col-xs-12 col-sm-3 col-lg-3">
                        <button type="button" class="btn btn-success btnSearch" onclick="searchWord = $('.searchtxt').val(); paging();">
                            <i class="fa fa-search"></i>
                        </button>
                        <button type="button" class="btn btn-info btnSearch" onclick="pageNo = 1; searchWord=''; paging();">
                            <i class="fe-refresh-ccw"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="table-responsive">
                <table class="table table-striped table-centered mb-0">
                    <thead>
                        <tr>

                            <th>
                                الكود
                            </th>

                            <th>
                                التفاصيل باللغة العربية
                            </th>

                            <th>
                                نشط
                            </th>
                            <th>
                                تعديل
                            </th>
                            <th>
                                حذف
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    @Html.DisplayFor(modelItem => item.CouponCode)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.NoteAr)
                                </td>
                                <td>
                                    <input type="checkbox" data-plugin="switchery" data-color="#00b19d" data-secondary-color="#ED5565" data-size="small" @Html.Raw(item.IsActive == true ? "checked" : "") onchange="ActivateDeactivate(@item.Id)" />
                                </td>
                                <td>
                                    <a href="@Url.Action("AddEdit", "Coupon", new { id = item.Id })" onclick="$('#preloader, #status').fadeIn();">
                                        <i class="fa fa-edit"></i>
                                    </a>
                                </td>
                                <td>
                                    <a href="javascript:void(0);" onclick="Delete(@item.Id)">
                                        <i class="fas fa-trash-alt"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>

