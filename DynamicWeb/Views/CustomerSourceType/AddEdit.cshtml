@model MyERP.Models.CustomerSourceType

@{
    ViewBag.Title = "مصادر العملاء";
}
<script src="~/js/DeleteFunctionForAddEditView.js"></script>

@Html.AntiForgeryToken()
@Html.ValidationSummary(true, "", new { @class = "text-danger" })

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                @if (Model != null)
                {
                    @Html.HiddenFor(model => model.Id)
                    @Html.HiddenFor(model => model.IsActive)
                    @Html.HiddenFor(model => model.IsDeleted)
                    @Html.HiddenFor(model => model.UserId)
                }

                @if (Model != null)
                {
                    if (Model.IsDeleted == false)
                    {
                        <a class="btn btn-info" href="@Url.Action("Index")" role="button" style="float:left;">رجوع</a>
                        if (ViewBag.Previous > 0)
                        {
                            <a href="@Url.Action("AddEdit",new {id= ViewBag.First })" class="btn btn-info" >الأول</a>
                            <a href="@Url.Action("AddEdit",new { id=ViewBag.Previous })" class=" btn btn-info" >&#8250;</a>
                        }
                        if (ViewBag.Next > 0)
                        {
                            <a href="@Url.Action("AddEdit",new { id=ViewBag.Next })" class="btn btn-info" >&#8249;</a>
                            <a href="@Url.Action("AddEdit",new {id=ViewBag.Last })" class="btn btn-info" >الأخير</a>
                        }
                    }
                }
                else
                {<a class="btn btn-info" href="@Url.Action("Index")" role="button" style="float:left;">رجوع</a>}
            </div>
            <h4 class="page-title">مصادر العملاء :</h4>
        </div>
    </div>
</div>
<div class="row">
    <div class="col-12">
        <div class="card-box">
            <form action="/CustomerSourceType/AddEdit" class="form-horizontal needs-validation" novalidate method="post">
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">
                                <div class="form-group row">
                                    <label class=" col-sm-2 control-label" for="ArName">الاسم بالعربية</label>
                                    <div class="col-sm-5">
                                        @Html.EditorFor(model => model.ArName, new { htmlAttributes = new { @class = "form-control", placeholder = "الاسم بالعربية", required = "required" } })
                                        @*<span class="Asterisks">*</span>*@
                                        @Html.ValidationMessageFor(model => model.ArName, "", new { @class = "text-danger" })
                                    </div>
                                </div>

                                <div class="form-group row">
                                    <label class="col-sm-2 control-label" for="EnName">الاسم بالانجليزية</label>
                                    <div class="col-sm-5">
                                        @Html.EditorFor(model => model.EnName, new { htmlAttributes = new { @class = "form-control", placeholder = "الاسم بالانجليزية" } })

                                        @Html.ValidationMessageFor(model => model.EnName, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <input id="new" name="newBtn" hidden />

                    <div style="float:left;">
                        @if (Model == null)
                        {
                            <button type="submit" id="newbtn" class="btn btn-success">
                                حفظ و جديد
                            </button>
                            <button type="submit" class="btn btn-success">
                                حفظ
                            </button>
                            <a class="btn btn-danger" href="@Url.Action("Index")" role="button">رجوع</a>
                        }
                        else
                        {
                            if (Model.IsDeleted == false)
                            {
                                <button type="submit" class="btn btn-success">
                                    حفظ
                                </button>
                                <a class="btn btn-danger" href="@Url.Action("Index")" role="button">رجوع</a>
                                <a class="btn btn-danger" onclick="Delete(@Model.Id,'CustomerSourceType')" role="button">حذف</a>

                            }
                        }
                    </div>

                </div>
            </form>
        </div>
    </div>
</div>

