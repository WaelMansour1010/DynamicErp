<script>
    let Employees = [];
    let Customers = [];

    $(document).ready(function () {
        $.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
            $("input[type|='datetime-local']").prop('min', r.PeriodStart).prop('max', r.PeriodEnd);
        });
        if (!$('#AllowCreditLimit').prop('checked')) {
            $('#CreditLimitAmount').prop('readonly', 'readonly');
        }

        // Get Employees To Use it In Rows appended in Details Table
        $.get('/Helper/GetAllEmployees').done(function (e) {
            Employees = e;
            addToCustomerReps();
        });
        if (!$('#Id').val()) {
            setCodeNum();
            $('#DepartmentId').attr('disabled', 'disabled');
        } else {
            $('#FieldsCodingId').prop('disabled', true);

            if ($('#IsBranch').prop('checked')) {
                $('#DepartmentId').attr('required', 'required');
                $('#DepartmentId').removeAttr('disabled');
            } else {
                $('#DepartmentId').attr('disabled', 'disabled');
            }

            if ($('#InsuranceCompany').prop('checked') == true) {
                $('.InsuranceCompanyPercentage').show();
            }
        }

    });
    //------------------------------------------------------------//
    function setCodeNum() {
        $.get('/Customers/SetCodeNum?FieldsCodingId=' + $('#FieldsCodingId').val()).done(function (r) {
            $('#Code').val(r);
        });
    }
    $('#FieldsCodingId').on('change', function () {
        if (!$('#Id').val()) {
            setCodeNum();
        }
    });
    $('#IsBranch').on('change', function () {
        if ($(this).prop('checked')) {
            $('#DepartmentId').attr('required', 'required');
            $('#DepartmentId').removeAttr('disabled');
        } else
            $('#DepartmentId').attr('disabled', 'disabled');
    });

    $(document).on('click', '#AllowCreditLimit', function () {
        if ($(this).prop('checked')) {
            $('#CreditLimitAmount').removeAttr('readonly');
        } else {
            $('#CreditLimitAmount').prop('readonly', 'readonly');
            $('#CreditLimitAmount').val(0);
        }
    });

    $(document).on('click', '#InsuranceCompany', function () {
        if ($(this).prop('checked')==true) {
            $('.InsuranceCompanyPercentage').show();
            $('#InsuranceCompanyPercentage').prop("required",true);

        } else {
            $('.InsuranceCompanyPercentage').hide();
            $('#InsuranceCompanyPercentage').prop("required", false);
            $('#InsuranceCompanyPercentage').val(0);
        }
    });




    function Delete(id) {
        if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToDelete')) {

            $('#preloader, #status').fadeIn();
            $.ajax(
                {
                    url: '/Customers/Delete',
                    type: 'POST',
                    data: {
                        "Id": id,
                    },
                    error: function (e) {
                        alert('@MyERP.Properties.Resources.DeleteDoesNotSucceeded');
                    },
                    success: function (r) {
                        if (r == 'true') {
                            window.location.replace('/Customers');
                        }
                        else if (r == 'False') {
                                    $('#preloader, #status').fadeOut();
                                    alert('@MyERP.Properties.Resources.DeleteDoesNotSucceededBecauseCustomerUsedInOtherTransactions');
                                }
                        else if (r == 'hasBalance') {
                          alert('@MyERP.Properties.Resources.CanNotDeleteCustomerAsHeHasOB');
                        } else
                            alert('@MyERP.Properties.Resources.DeleteDoesNotSucceeded');
                        $('#preloader, #status').fadeOut();
                    }
                });
        }
    }

    function deleteElement(e) {
        var tr = $(e).closest('tr');

        if ($(tr).index() > 0) {
            e.parentNode.parentNode.parentNode.removeChild(e.parentNode.parentNode);
        } else if ($(tr).index() == 0 && $(tr).closest('tbody').children('tr').length > 1) {
            e.parentNode.parentNode.parentNode.removeChild(e.parentNode.parentNode);

        } else if ($(tr).index() == 0 && $(tr).closest('tbody').children('tr').length == 1) {
            $(tr).children("input[type|='text']").each(function () {
                $(this).empty();
            });
        }
    }

    //---------------------------------------- Add New ROw---------------------------
    function addToCustomerReps() {
        if ($('#Id').val() > 0) {
          //  $('#CustomerReps').find('.isDefault').attr('checked', true);
        }
        else {
            $('#CustomerReps tr:first').find('.isDefault').attr('checked', true);
        }

        if ($('.EmployeeId').last().val()) {
            $('#CustomerReps').find().prop('required', 'required');
        }

        if ($('#CustomerReps .form-control:invalid').length > 0) {
            $('#CustomerReps').closest('.form-horizontal').addClass('was-validated');
            $('html, body').animate({
                scrollTop: $("#CustomerReps").find(".form-control:invalid").eq(0).offset().top - 80
            }, 500);
        }

        if ($('#CustomerReps .EmployeeId:last').val() != 0) {
            let tr = '<tr><td class="p-0 tabledit-edit-mode" style="width:15%"><select style="height:40px" class=" p-0 form-control EmployeeId" required="required"></select></td><td class="tabledit-edit-mode"><input class="isDefault" name="isDefault" type="radio" /></td><td><input type="checkbox"  class="IsActiveRep" data-plugin="switchery" data-color="#00b19d" data-secondary-color="#ED5565" data-size="small"  /></td><td><a href="javascript:void(0);" onclick="deleteElement(this)"><i class="fas fa-trash-alt"></i></a></td></tr>';
            $('#CustomerReps').append(tr);
            let EmployeesDropdown = $('#CustomerReps tr:last').find('.EmployeeId');

            EmployeesDropdown.append(new Option('@MyERP.Properties.Resources.Select', '0'));
            for (var i = 0; i < Employees.length; i++) {

                var EmpOption = $('<option></option>').attr("value", Employees[i].Id).text(Employees[i].ArName);
                EmployeesDropdown.append(EmpOption);
            }
            EmployeesDropdown.select2();
        }
    };

    $(document).on('change', '.EmployeeId', function () {
        addToCustomerReps();
        $(this).closest('tr').find('.IsActiveRep').prop('checked', true);
    });

    $('#CountryId').on('change', function () {
        getCities($(this).val()).then(function () {
            $("#CityId").empty().append(CitiesOptions);
        });
    });

    var CitiesOptions = '';

    function getCities(governorateId) {
        // $('#CityId').empty();

        if (governorateId != "" && governorateId != null) {
            CitiesOptions = '';

            return requestData('/Helper/getCitiesInGovernorate?governorateId=' + governorateId).done(function (r) {

                for (var i = 0; i < r.length; i++) {
                    CitiesOptions += '<option value="' + r[i].Id + '">' + r[i].ArName + '</option>';

                    //$('#CityId').append($('<option>', {
                    //    value: r[i].Id,
                    //    text: r[i].ArName
                    //}));
                }

                // $('#CityId').trigger('change');
            });
        }
    }

    //--------------------------------------- ADD EDIT---------------------------//
    function addEdit(n) {
        if ($(".form-control:invalid").length > 0) {
            console.log($(".form-control:invalid"));
            $('.form-horizontal').addClass('was-validated');
            $('html, body').animate({
                scrollTop: $(".form-control:invalid").eq(0).offset().top - 100
            }, 500);
            valid = false;
        }
        else {

            var Reps = [];

            $('#CustomerReps tr').each(function () {
                var td = $(this);
                if (td.find('.EmployeeId').val() > 0) {
                    var Rep = {
                        CustomerId: $('#Id').val(),
                        IsActive: td.find('.IsActiveRep').prop('checked'),
                        IsDefault: td.find('.isDefault').prop('checked'),
                        EmployeeId: td.find('.EmployeeId').val()
                    };
                    Reps.push(Rep);
                }
            });

            var Customers =
            {
                Id: $('#Id').val(),
                Code: $('#Code').val(),
                ArName: $('#ArName').val(),
                EnName: $('#EnName').val(),
                CustomersGroupId: $('#CustomersGroupId').val(),
                IsActive: true,
                IsDeleted: false,
                Mobile: $('#Mobile').val(),
                PhoneNo: $('#PhoneNo').val(),
                Email: $('#Email').val(),
                Address: $('#Address').val(),
                NationalId: $('#NationalId').val(),
                IsBlocked: $('#IsBlocked').prop('checked'),
                BuildingNo: $('#BuildingNo').val(),
                Notes: $('#Notes').val(),
                TaxNumber: $('#TaxNumber').val(),
                WorkNature: $('#WorkNature').val(),
                AllowCreditLimit: $('#AllowCreditLimit').prop('checked'),
                CreditLimitAmount: $('#CreditLimitAmount').inputmask('unmaskedvalue'),
                CreditLimitPeriod: $('#CreditLimitPeriod').val(),
                IncludeFees: $('#IncludeFees').prop('checked'),
                IsBranch: $('#IsBranch').prop('checked'),
                DepartmentId: $('#DepartmentId').val(),
                CountryId: $('#CountryId').val(),
                CityId: $('#CityId').val(),
                PostOfficeBox: $('#PostOfficeBox').val(),
                VATNumber: $('#VATNumber').val(),
                ContactPerson: $('#ContactPerson').val(),
                CustomerReps: Reps,
                FieldsCodingId: $('#FieldsCodingId').val(),
                InsuranceCompanyPercentage: $('#InsuranceCompanyPercentage').inputmask('unmaskedvalue'),
                InsuranceCompany: $('#InsuranceCompany').prop('checked'),
            };

            if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToSave')) {
                $('#newbtn').prop('disabled', true);
                $('#save').prop('disabled', true);
                $('#preloader, #status').fadeIn();
                $.ajax({
                    type: "POST",
                    url: "/Customers/AddEdit",
                    data: Customers,
                    success: function (r) {
                        if (r.success == "true") {
                            if (n == "new") {
                                window.location.replace("/Customers/AddEdit");
                            } else {
                                window.location.replace("/Customers");
                            }
                        }
                        else {
                            alert('@MyERP.Properties.Resources.NotSaved');
                            $('#preloader, #status').fadeOut();
                            $('#newbtn').prop('disabled', false);
                            $('#save').prop('disabled', false);
                        }
                    },
                    error: function (r) {
                        $('#preloader, #status').fadeOut();
                        $('#newbtn').prop('disabled', false);
                        $('#save').prop('disabled', false);
                        alert(' @MyERP.Properties.Resources.NotSaved');
                    }
                });

            }
        }
    }

</script>
