                        {
                        <button type="button" onclick="addEdit('new')" id="newbtn" class="btn btn-success">
                            @MyERP.Properties.Resources.SaveAndNew
                        </button>
                        <button type="button" onclick="addEdit()" id="save" class="btn btn-success">
                            @MyERP.Properties.Resources.Save
                        </button>
