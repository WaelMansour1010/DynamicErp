@model IEnumerable<MyERP.Models.CustomerOB_Get_Result>

@{
    Layout = "~/Views/Shared/_blankLayout.cshtml" ;
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.CustomerBalanceSheet;
}

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="hed page-title">@MyERP.Properties.Resources.CustomerBalanceSheet :  @ViewBag.CustomerName</div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <input hidden id="Id" value="@ViewBag.Id" />
                    <div class="table-responsive">
                        <table class="table table-striped table-centered mb-0">
                            <thead>
                                <tr>
                                    <th>@MyERP.Properties.Resources.Debit</th>
                                    <th>@MyERP.Properties.Resources.Credit</th>
                                    <th>@MyERP.Properties.Resources.DebitBalance </th>
                                    <th>@MyERP.Properties.Resources.CreditBalance</th>
                                    <th>@MyERP.Properties.Resources.TransactionType</th>
                                    <th>@MyERP.Properties.Resources.TransactionNo</th>
                                    <th>@MyERP.Properties.Resources.JournalEntrieNo</th>
                                    <th>@MyERP.Properties.Resources.Date</th>

                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null)
                                {
                                    foreach (var item in Model)
                                    {
                                <tr>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.Debit)
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.Credit)
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.DebitBalance)
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.CreditBalance)
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.ArName)
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.DocumentNumber)
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.JournalDocNum)
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.Date)
                                    </td>
                                </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <br />
            <div class="row">
                <div class="col-12">
                    <div class="form-group row">
                        <label for="TotalDebit" class="control-label col-sm-1">@MyERP.Properties.Resources.TotalDebit</label>
                        <div class="col-sm-5">
                            <input id="TotalDebit" name="TotalDebit" class="form-control" disabled value="@ViewBag.SumDebit" />
                        </div>
                        <label for="TotalCredit" class="control-label col-sm-1">@MyERP.Properties.Resources.TotalCredit</label>
                        <div class="col-sm-5">
                            <input id="TotalCredit" name="TotalCredit" class="form-control" disabled value="@ViewBag.SumCredit" />
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="TotalDebitBalance" class="control-label col-sm-1">@MyERP.Properties.Resources.TotalDebitBalance</label>
                        <div class="col-sm-5">
                            <input id="TotalDebitBalance" name="TotalDebitBalance" class="form-control" disabled value="@ViewBag.SumDebitBalance" />
                        </div>
                        <label for="TotalCreditBalance" class="control-label col-sm-1">@MyERP.Properties.Resources.TotalCreditBalance</label>
                        <div class="col-sm-5">
                            <input id="TotalCreditBalance" name="TotalCreditBalance" class="form-control" disabled value="@ViewBag.SumCreditBalance" />
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<div style="text-align:center;margin-bottom: 50px;">
    <div class="form-group row">
        <div class="col-sm-4">
            <select id="ShowByPage" class="form-control" style="width:70px;float:left;" onchange="paging()">
                <option value="10">10</option>
                <option value="30">30</option>
                <option value="50">50</option>
                <option value="100">100</option>
                <option value="200">200</option>
                <option value="@ViewBag.Count">@MyERP.Properties.Resources.All</option>
            </select>
            <span style="font-size:12px;float:right;"> @MyERP.Properties.Resources.NoOfResults : <span id="RowsCount">@ViewBag.Count</span></span>
        </div>
        <div class="col-sm-2">
            <lablel class="col-sm-8">@MyERP.Properties.Resources.PageNo: </lablel>
        </div>
        <div class="col-sm-2">
            <select id="pagination" class="pagination form-control" style="width:70px;float:left;">
            </select>
        </div>
    </div>
</div>

<script>
    var pageNo = 1;
    $('#ShowByPage').val(@ViewBag.wantedRowsNo);

    function paging() {

        var link = '/Customers/CustomerBalanceSheet?' + 'pageIndex=' + pageNo + '&wantedRowsNo=' + $('#ShowByPage').val()+'&_id='+$('#Id').val();
        window.location.replace(link);
    }

    function setPages() {
        var count =@ViewBag.Count;
        for (var i = 0; i < Math.ceil(count / $('#ShowByPage').val()); i++)
     $('#pagination').append('<option onchange="pageNo=' + (i + 1) + '; paging();" id="pg' + (i + 1) + '">' + (i + 1) + '</option>');
    }

    setPages();
   $('#pg' +@ViewBag.PageIndex).attr('selected', 'selected')

    $('#pagination').on('change', function () {
        pageNo = $('#pagination').val();
         paging();

    })
</script>