@model IEnumerable<MyERP.Models.Customer>
@{
    bool isECommerce = System.Web.Configuration.WebConfigurationManager.AppSettings["ECommerce"] == "true" ? true : false;
    if (System.Web.Configuration.WebConfigurationManager.AppSettings["ECommerce"] == "true")
    {
        Layout = "~/Views/Shared/_EcommerceLayout.cshtml";
    }
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.Customers;

}
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                @if (!isECommerce)
                {
                    <a class="btn btn-info" href="@Url.Action("AddEdit")" role="button" style="float:left;">
                        @MyERP.Properties.Resources.AddNew
                    </a>
                }
                <a class="btn btn-primary" style="margin-left: 0.5rem;" href="@Url.Action("ImportExcelFile")" role="button">@MyERP.Properties.Resources.ImportExcelSheet </a>
            </div>
            <div class="hed page-title">@MyERP.Properties.Resources.Customers</div>
        </div>
    </div>
</div>
<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal" role="form">
                        <div class="form-group row">
                            <div class="col-xs-12 col-sm-6 col-lg-3">
                                <input type="text" class="form-control searchtxt" value="@Html.Raw(ViewBag.searchWord)" placeholder=@MyERP.Properties.Resources.Search>
                            </div>
                            <div class="col-xs-12 col-sm-3 col-lg-3">
                                <button type="button" class="btn btn-success btnSearch" onclick="searchWord = $('.searchtxt').val(); paging();">
                                    <i class="fa fa-search"></i>
                                </button>
                                <button type="button" class="btn btn-info btnSearch" onclick="pageNo = 1; searchWord=''; paging();">
                                    <i class="fe-refresh-ccw"></i>
                                </button>

                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-12">
                    <div class="table-responsive">
                        <table class="table table-striped table-centered mb-0">
                            <thead>
                                <tr>

                                    @if (isECommerce)
                                    {

                                        <th> @MyERP.Properties.Resources.ArName</th>
                                        <th>@MyERP.Properties.Resources.Mobile </th>
                                        <th>@MyERP.Properties.Resources.Email </th>
                                        <th>@MyERP.Properties.Resources.Active</th>
                                        <th>@MyERP.Properties.Resources.Delete</th>
                                    }
                                    else
                                    {
                                        <th>@MyERP.Properties.Resources.Code</th>
                                        <th>@MyERP.Properties.Resources.ArName</th>
                                        <th>@MyERP.Properties.Resources.Mobile </th>
                                        <th>@MyERP.Properties.Resources.Active</th>
                                        <th>@MyERP.Properties.Resources.Edit</th>
                                        <th>@MyERP.Properties.Resources.Delete</th>
                                        <th>@MyERP.Properties.Resources.Print</th>
                                        <th>@MyERP.Properties.Resources.Send</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                <tr>
                                    @if (isECommerce)
                                    {

                                        <td>
                                            @Html.DisplayFor(modelItem => item.ArName)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.Mobile)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.Email)
                                        </td>
                                        <td>
                                            <input type="checkbox" data-plugin="switchery" data-color="#00b19d" data-secondary-color="#ED5565" data-size="small" @Html.Raw(item.IsActive == true ? "checked" : "") onchange="ActivateAndDeactivate(@item.Id)" />
                                        </td>
                                        <td>
                                            <a href="javascript:void(0);" onclick="Delete(@item.Id)">
                                                <i class="fas fa-trash-alt"></i>
                                            </a>
                                        </td>
                                    }
                                    else
                                    {
                                        <td>
                                            @Html.DisplayFor(modelItem => item.Code)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.ArName)
                                        </td>

                                        <td>
                                            @Html.DisplayFor(modelItem => item.Mobile)
                                        </td>
                                        <td>
                                            <input type="checkbox" data-plugin="switchery" data-color="#00b19d" data-secondary-color="#ED5565" data-size="small" @Html.Raw(item.IsActive == true ? "checked" : "") onchange="ActivateAndDeactivate(@item.Id)" />
                                        </td>
                                        <td>
                                            <a href="@Url.Action("AddEdit","Customers",new { id=item.Id })" onclick="$('#preloader, #status').fadeIn();">
                                                <i class="fa fa-edit"></i>
                                            </a>
                                        </td>
                                        <td>
                                            <a href="javascript:void(0);" onclick="Delete(@item.Id)">
                                                <i class="fas fa-trash-alt"></i>
                                            </a>
                                        </td>
                                        <td>
                                            <button class="btn btn-success" onclick="CustomerBalanceSheet2(@item.Id, @item.DepartmentId)"> @MyERP.Properties.Resources.CustomerBalanceSheet </button>
                                        </td>
                                        <td>
                                            @*<a href="https://api.whatsapp.com/send?phone=@item.Mobile&text=@ViewBag.domainName/Report/CustomerBalanceSheet/@item.Id" target="_blank">
                    <i class="fab fa-whatsapp"></i>
                </a>*@
                                            <button class="btn btn-success" onclick="CustomerBalanceSheet(@item.Id,@item.Mobile)">
                                                <i class="fab fa-whatsapp"></i>
                                            </button>
                                        </td>
                                    }

                                </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@*<div style="text-align:center;margin-bottom: 50px;">
        <select id="ShowByPage" class="form-control" style="width:70px;float:left;" onchange="paging()">
            <option value="10">10</option>
            <option value="30">30</option>
            <option value="50">50</option>
            <option value="100">100</option>
            <option value="200">200</option>
            <option value="@ViewBag.Count">الكل</option>
        </select>

        <ul class="pagination pagination-rounded justify-content-center" style="margin: 0px;"></ul>

        <span style="font-size:12px;float:right;"> عدد النتائج : <span id="RowsCount">@ViewBag.Count</span></span>
    </div>*@
<div style="text-align:center;margin-bottom: 50px;">

    <div class="form-group row">
        <div class="col-sm-4">
            <select id="ShowByPage" class="form-control" style="width:70px;float:left;" onchange="paging()">
                <option value="10">10</option>
                <option value="30">30</option>
                <option value="50">50</option>
                <option value="100">100</option>
                <option value="200">200</option>
                <option value="@ViewBag.Count">@MyERP.Properties.Resources.All</option>
            </select>
            <span style="font-size:12px;float:right;"> @MyERP.Properties.Resources.NoOfResults : <span id="RowsCount">@ViewBag.Count</span></span>
        </div>
        <div class="col-sm-2">
            <lablel class="col-sm-8">@MyERP.Properties.Resources.PageNo: </lablel>
        </div>
        <div class="col-sm-2">
            <select id="pagination" class="pagination form-control" style="width:70px;float:left;">
            </select>
        </div>
    </div>

    @*<ul class="pagination pagination-rounded justify-content-center" style="margin: 0px;"></ul>*@
</div>

<script>

    function CustomerBalanceSheet(id,mobile) {
        $.get('/Customers/EncodeCustomerId?id=' + id).done(function (r) {
            var report = "https://api.whatsapp.com/send?phone=" + mobile + "&text=@ViewBag.domainName/Customers/CustomerBalanceSheet?_id=" + r;
            window.open(report, "_blank");
        });

    }
    function CustomerBalanceSheet2(CustomerId, DepartmentId) {
        window.open("/Report/CustomerBalanceSheet?CustomerId=" + CustomerId +
             "&departmentId=" + DepartmentId +
            "&dateFrom=" + null + "&dateTo=" + null +
             '&showReport=' + true, "blank");

    }

             var pageNo = 1;
    var searchWord = '@Html.Raw(ViewBag.searchWord)';

    $('#ShowByPage').val(@ViewBag.wantedRowsNo);

    function paging() {

        var link = '/Customers/Index?' + 'pageIndex=' + pageNo + '&wantedRowsNo=' + $('#ShowByPage').val() + '&searchWord=' + searchWord;
        window.location.replace(link);
    }

    function setPages() {
        var count =@ViewBag.Count;
        for (var i = 0; i < Math.ceil(count / $('#ShowByPage').val()); i++)
        //    $('.pagination').append('<li class="pageNo page-item" id="pg' + (i + 1) + '"><a class="page-link" href="javascript:void(0);" onclick="pageNo=' + (i + 1) + '; paging();">' + (i + 1) + '</a></li>');
     $('#pagination').append('<option onchange="pageNo=' + (i + 1) + '; paging();" id="pg' + (i + 1) + '">' + (i + 1) + '</option>');
    }

    setPages();
   $('#pg' +@ViewBag.PageIndex).attr('selected', 'selected')

    $('#pagination').on('change', function () {
        pageNo = $('#pagination').val();
         paging();

    })

   // $('#pg' +ViewBag.PageIndex).addClass('disabled');
    function Delete(id) {
        if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToDelete')) {

            $('#preloader, #status').fadeIn();
            $.ajax(
                {
                    url: '/Customers/Delete',
                    type: 'POST',
                    data: {
                        "Id": id,
                    },
                    error: function (e) {
                        alert('@MyERP.Properties.Resources.DeleteDoesNotSucceeded');
                    },
                    success: function (r) {
                        if (r == 'true') {
                            window.location.reload();
                        }
                        else if (r == 'hasBalance') {
                            alert('@MyERP.Properties.Resources.CanNotDeleteCustomerAsHeHasOB');
                        }
                        else if (r == 'False') {
                                    $('#preloader, #status').fadeOut();
                                    alert('@MyERP.Properties.Resources.DeleteDoesNotSucceededBecauseCustomerUsedInOtherTransactions');
                                    window.location.reload();
                                }
                        $('#preloader, #status').fadeOut();
                    }
                });
        }
    }

    function ActivateAndDeactivate(id) {
        $.ajax({
            url: '/Customers/ActivateDeactivate',
            type: 'POST',
            data: {
                "Id": id,
            },
            error: function (e) {

            },
            success: function (r) {
                if (r == 'true') {
                    alert('@MyERP.Properties.Resources.TheActivationStateHasChanged')
                }
            }
        });
    }

    $(document).on('change', '#CustomerName', function () {
        searchWord = $(this).val();
        paging();
    });
</script>