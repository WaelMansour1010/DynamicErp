    function addEdit(n) {
        let valid = true;
        if ($('.form-horizontal').first().find('.form-control:invalid').length > 0) {
            $('.form-horizontal').first().addClass('was-validated');
            $('html, body').animate({
                scrollTop: $('.form-horizontal').first().find(".form-control:invalid").eq(0).offset().top - 100
            }, 500);
            valid = false;
            console.log($(".form-control:invalid"));
        }

        var DayUseReservation = {
            Id: $('#Id').val(),
            DocumentNumber: $('#DocumentNumber').val(),
            RegistrationDate: $('#RegistrationDate').val(),
            VoucherDate: $('#VoucherDate').val(),
            PeopleNumber: $('#PeopleNumber').val(),
            CustomerId: $('#CustomerId').val(),
            Amount: $('#Amount').val(),
            Total: $('#Total').inputmask('unmaskedvalue'),
            Discount: $('#Discount').inputmask('unmaskedvalue'),
            TotalAfterDiscount: $('#TotalAfterDiscount').inputmask('unmaskedvalue'),
            UserId: $('#UserId').val(),
            IsDeleted: $('#IsDeleted').val(),
            Notes: $('#Notes').val(),
            Image: $('#Image').val(),
            DepartmentId: $('#DepartmentId').val(),
            CashBoxId: $('#CashBoxId').val(),
            Paid: $('#Paid').inputmask('unmaskedvalue'),
            Remain: $('#Remain').inputmask('unmaskedvalue'),
            CurrencyId: $('#CurrencyId').val(),
            CurrencyEquivalent: $('#CurrencyEquivalent').val(),
        }
        if (valid) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.AreYouSureYouWantToSave',
                text: " ",
                icon: 'info',
                showCancelButton: true,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                cancelButtonText: '@MyERP.Properties.Resources.Cancel',
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    $('#preloader, #status').fadeIn();
                $('#newbtn').prop('disabled', true);
                $('#save').prop('disabled', true);
                $.ajax({
                    type: "POST", contentType: "application/json",
                    url: "/DayUseReservation/AddEdit",
                    data: JSON.stringify(DayUseReservation),
                    success: function (r) {
                        if (r.success == true) {
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.Saved',
                                text: " ",
                                icon: 'success',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                            if (n == "new") {
                               // window.open("/Report/DayUseReservationReceipt?print=true&id=" + r.id, "_blank");
                                EncodeId(r.id)
                                window.location.replace("/DayUseReservation/AddEdit");
                            } else {
                                //window.open("/Report/DayUseReservationReceipt?print=true&id=" + r.id, "_blank");
                                EncodeId(r.id)
                                window.location.replace("/DayUseReservation");
                            }
                        }
                        else {
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.NotSaved !',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });                        }
                        $('#preloader, #status').fadeOut();
                        $('#newbtn').prop('disabled', false);
                        $('#save').prop('disabled', false);
                    },
                    error: function (r) {
                        Swal.fire({
                            title: '@MyERP.Properties.Resources.NotSaved !',
                            text: " ",
                            icon: 'error',
                            showCancelButton: false,
                            confirmButtonText: '@MyERP.Properties.Resources.Ok',
                            confirmButtonColor: '#3085d6'
                        });                        $('#preloader, #status').fadeOut();
                        $('#newbtn').prop('disabled', false);
                        $('#save').prop('disabled', false);
                    }
                });
                }
                else { result.dismiss; }
            });


        }
    }
    function Delete(id) {
        Swal.fire({
            title: '@MyERP.Properties.Resources.AreYouSureYouWantToDelete',
            text: " ",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: '@MyERP.Properties.Resources.Ok',
            cancelButtonText: '@MyERP.Properties.Resources.Cancel',
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                $('#preloader, #status').fadeIn();
                $.ajax(
                    {
                        url: '/DayUseReservation/Delete',
                        type: 'POST',
                        data: {
                            "Id": id,
                        },
                        error: function (e) {
                            $('#preloader, #status').fadeOut();
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.DeleteDoesNotSucceeded',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                        },
                        success: function (r) {
                            if (r == 'true') {
                                window.location.replace('/DayUseReservation');
                            } else
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.DeleteDoesNotSucceeded',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                        }
                    });
            }
            else { result.dismiss; }
        });
    }
    function EncodeId(id, mobile) {
        $.get('/Helper/EncodeId?id=' + id).done(function (r) {
            var report = "/Report/DayUseReservationReceipt?id=" + r + "&print=True";
            window.open(report, "_blank");
        });
    }
