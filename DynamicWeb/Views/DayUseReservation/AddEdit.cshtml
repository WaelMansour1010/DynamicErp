@model MyERP.Models.DayUseReservation

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.DayUseReservation;
}
<script src="~/Scripts/SaveAndNew.js"></script>
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                @if (Model != null)
                {
                    if (Model.IsDeleted == false)
                    {
                        if (ViewBag.Previous > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.First })" class="btn btn-info">@MyERP.Properties.Resources.First</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Previous })" class=" btn btn-info">&#8250;</a>
                        }
                        if (ViewBag.Next > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Next })" class="btn btn-info">&#8249;</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Last })" class="btn btn-info">@MyERP.Properties.Resources.Last</a>
                        }
                        <a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                    }
                }
                else
                {<a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>}
            </div>
            <h4 class="page-title"> @MyERP.Properties.Resources.DayUseReservation </h4>
        </div>
    </div>
</div>


<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal needs-validation" role="form">
                        <div class="card">
                            <div class="card-body">
                                @Html.AntiForgeryToken()
                                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                @if (Model != null)
                                {
                                    @Html.HiddenFor(model => model.Id)
                                    @Html.HiddenFor(model => model.UserId)
                                    @Html.HiddenFor(model => model.IsDeleted)
                                    @Html.HiddenFor(model => model.Image)
                                    @Html.HiddenFor(model => model.CurrencyId)
                                    @Html.HiddenFor(model => model.CurrencyEquivalent)
                                }
                                <h5 class="header-title">
                                    @MyERP.Properties.Resources.MainData
                                </h5>
                                <div class="form-group row">
                                    <label class=" col-sm-2 control-label" for="Id">@MyERP.Properties.Resources.TransactionNo</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.DocumentNumber, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly", placeholder = @MyERP.Properties.Resources.DocNo, required = "required", hidden = "hidden" } })
                                        <input id="DocumentNumbers" class="form-control" placeholder=@MyERP.Properties.Resources.Code required readonly />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>

                                <div class="form-group row">
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.Date</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.VoucherDate, new { htmlAttributes = new { @class = "form-control", @type = "datetime-local", @required = "required" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.BookingDate</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.RegistrationDate, new { htmlAttributes = new { @class = "form-control", @type = "datetime-local", @required = "required" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.Department</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownListFor(model => model.DepartmentId, null, null, htmlAttributes: new { @class = "form-control", required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.CashBox</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownListFor(model => model.CashBoxId, null, null, htmlAttributes: new { @class = "form-control", required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>

                                <div class="col-sm-12" style=" padding:1px;background-color: white;">
                                    <div style="background-color:white;">
                                        <div class="row form-group">
                                            <label class="control-label col-sm-2 PosCustomerIdDiv">@MyERP.Properties.Resources.Customer </label>
                                            <div class="col-sm-4 PosCustomerIdDiv">
                                                <div class="row ">
                                                    <div class="col-sm-10">
                                                        <select class="form-control" id="CustomerId">
                                                            @if (Model != null)
                                                            {
                                                                <option value="@Model.CustomerId"></option>
                                                            }
                                                        </select>

                                                        <div class="invalid-feedback">
                                                            @MyERP.Properties.Resources.Select
                                                        </div>
                                                    </div>

                                                    <div class="col-sm-2 pos-customer-model-btn" style="padding: 0;margin-right: -10px;">
                                                        <button class="btn btn-success  btn-sm" id="posCustomerAddBtn" data-toggle="modal"><i class="remixicon-user-add-fill"></i></button>
                                                    </div>
                                                </div>
                                            </div>


                                            <label class="PosCustomerDetailsDiv col-sm-2 control-label" for="Address">@MyERP.Properties.Resources.CustomerAddress</label>
                                            <div class="PosCustomerDetailsDiv col-sm-4">
                                                <label type="text" class="label control-label" id="pos-customer-address" readonly> </label>
                                            </div>
                                        </div>

                                        <div class="row form-group">
                                            <label class="PosCustomerDetailsDiv col-sm-2 control-label" for="Phone">@MyERP.Properties.Resources.CustomerTel</label>
                                            <div class="PosCustomerDetailsDiv col-sm-4">
                                                <input type="text" class="form-control" id="pos-customer-mobile" />
                                            </div>
                                            <label class="PosCustomerDetailsDiv col-sm-2 control-label" for="IdentityNumber">@MyERP.Properties.Resources.NationalID</label>
                                            <div class="PosCustomerDetailsDiv col-sm-4">
                                                <input type="text" class="form-control" id="IdentityNumber" />
                                            </div>
                                        </div>
                                    </div>
                                </div>


                                <div class="form-group row">
                                    <label for="Total" class="control-label col-sm-2">@MyERP.Properties.Resources.PeopleNumber:</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.PeopleNumber, new { htmlAttributes = new { @class = "form-control", type = "text", @required = "required" } })
                                    </div>
                                    <label for="Discount" class="control-label col-sm-2">@MyERP.Properties.Resources.Amount: </label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.Amount, new { htmlAttributes = new { @class = "form-control money", type = "text", value = "0", @required = "required" } })
                                    </div>
                                </div>

                                <div class="form-group row">
                                    <label for="Total" class="control-label col-sm-2">@MyERP.Properties.Resources.Total:</label>
                                    <div class="col-sm-2">
                                        @Html.EditorFor(model => model.Total, new { htmlAttributes = new { @class = "form-control money", type = "text", @readonly = "readonly" } })
                                    </div>
                                    <label for="Discount" class="control-label col-sm-2">@MyERP.Properties.Resources.DiscountValue: </label>
                                    <div class="col-sm-2">
                                        @Html.EditorFor(model => model.Discount, new { htmlAttributes = new { @class = "form-control money", type = "text", value = "0" } })
                                    </div>
                                    <label for="TotalAfterDiscount" class="control-label col-sm-2">@MyERP.Properties.Resources.TotalAfterDiscount: </label>
                                    <div class="col-sm-2">
                                        @Html.EditorFor(model => model.TotalAfterDiscount, new { htmlAttributes = new { @class = "form-control", value = "0", @readonly = "readonly" } })
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="Total" class="control-label col-sm-2">@MyERP.Properties.Resources.Paid:</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.Paid, new { htmlAttributes = new { @class = "form-control money", type = "text", value = "0", @required = "required" } })
                                    </div>
                                    <label for="Discount" class="control-label col-sm-2">@MyERP.Properties.Resources.Remain: </label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.Remain, new { htmlAttributes = new { @class = "form-control money", type = "text", value = "0", @required = "required", @readonly = "readonly" } })
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="control-label col-sm-2" for="Notes">@MyERP.Properties.Resources.Notes</label>
                                    <div class="col-sm-4">
                                        <textarea id="Notes" name="Notes" class="form-control" rows="5" cols="5">@if (Model != null) { @Model.Notes; }</textarea>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-sm-offset-2">
                    @if (Model == null)
                    {
                        <button onclick="addEdit('new');" class="btn btn-success" id="newbtn">
                            @MyERP.Properties.Resources.SaveAndNew
                        </button>
                        <button onclick="addEdit();" class="btn btn-success" id="save">
                            @MyERP.Properties.Resources.Save
                        </button>
                        <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                    }
                    else if (Model.IsDeleted == false)
                    {
                        <button onclick="addEdit();" class="btn btn-success" id="save">
                            @MyERP.Properties.Resources.Save
                        </button>
                        <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                        <a href="javascript:void(0);" class="btn btn-danger" onclick="Delete(@Model.Id)" role="button">@MyERP.Properties.Resources.Delete</a>
                    }
                </div>
            </div>
            <!-------------------------------------------------------------------------------------------------------->
        </div>
    </div>
</div>

<!---------- Journal Entry ----------------->
@if (Model != null)
{
    if (ViewBag.JE != null)
    {
        <div class="card">
            <div class="card-body">
                <h5 class="header-title">@MyERP.Properties.Resources.JournalEntries</h5>
                <div class="form-horizontal">
                    <div class="form-group row">
                        <label for="inputtext3" class="col-sm-2 control-label">@MyERP.Properties.Resources.VoucherNo</label>
                        <div class="col-sm-4">
                            <input type="text" class="form-control" name="txtDocNo" value="@ViewBag.JE.DocumentNumber" id="txtDocNo" placeholder=@MyERP.Properties.Resources.VoucherNo disabled>

                        </div>
                        <label for="inputtext3" class="col-sm-2 control-label">@MyERP.Properties.Resources.Date </label>
                        <div class="col-sm-4">
                            <input type="datetime-local" class="form-control" name="dtDate" value="@ViewBag.VoucherDate" id="dtDate" placeholder=@MyERP.Properties.Resources.ReleaseDate required disabled>
                        </div>

                    </div>
                    <div class="form-group row">

                        <label for="inputtext3" class="col-sm-2 control-label">@MyERP.Properties.Resources.Branch</label>
                        <div class="col-sm-4">
                            @Html.DropDownList("DepartmentId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", id = "DepartmentId", @required = "required", @disabled = "disabled" })
                        </div>

                    </div>
                    <div class="form-group row">
                        <label for="inputtext3" class="col-sm-2 control-label">@MyERP.Properties.Resources.Notes</label>
                        <div class="col-sm-4">
                            <textarea type="text" class="form-control validate[required]" id="txtNotes" value="@ViewBag.JE.Notes" name="txtNotes" placeholder=@MyERP.Properties.Resources.Notes disabled></textarea>
                        </div>

                    </div>
                    <div class="card">
                        <div class="card-body">
                            <h5 class="header-title"> @MyERP.Properties.Resources.JournalEntryDetails</h5>
                            <div class="table-responsive">
                                <table class="table table-centered mb-0">
                                    <thead>
                                        <tr>
                                            <th>@MyERP.Properties.Resources.Debit</th>
                                            <th>@MyERP.Properties.Resources.Credit</th>
                                            <th>@MyERP.Properties.Resources.Account</th>
                                            <th>@MyERP.Properties.Resources.CostCenter</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model.Id != 0)
                                        {
                                            foreach (var jED in ViewBag.JEDetails)
                                            {
                                                <tr>
                                                    <td>
                                                        <label>@jED.Debit</label>
                                                        <input type='text' class='txtDebit' value="@jED.Debit" hidden>
                                                    </td>
                                                    <td>
                                                        <label>@jED.Credit</label>
                                                        <input type='text' class='txtCredit ' value="@jED.Credit" hidden>
                                                    </td>
                                                    <td>
                                                        @if (jED.AccountId != null)
                                                        {
                                                            <label>@jED.ChartOfAccount.ArName</label>
                                                            <input type='number' class='AccountId' value="@jED.AccountId" hidden>
                                                        }

                                                    </td>
                                                    <td>
                                                        @Html.Raw(jED.CostCenter != null ? jED.CostCenter.ArName : null)
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
}
<!----------------------------------------------------------------------------------->

<!-- Modal Section -->
<div id="pos-customer-modal" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true" style="display: none;">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">@MyERP.Properties.Resources.CustomerData</h4>
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">×</button>
            </div>
            <div class="modal-body p-4">
                <div class="form-horizontal needs-validation" role="form">
                    <input hidden id="posCustomerIdInput" name="posCustomerIdInput" />
                    <input hidden id="posCustomerCodeInput" name="posCustomerCodeInput" />
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="ArName" class="control-label">@MyERP.Properties.Resources.ArName</label>
                                <input type="text" class="form-control" id="PosCustomerArName" placeholder=@MyERP.Properties.Resources.ArName>
                            </div>
                            <div class="invalid-feedback">
                                @MyERP.Properties.Resources.Required
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="EnName" class="control-label">@MyERP.Properties.Resources.EnName</label>
                                <input type="text" class="form-control" id="PosCustomerEnName" placeholder=@MyERP.Properties.Resources.EnName>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="Mobile1" class="control-label">@MyERP.Properties.Resources.Mobile 1</label>
                                <input type="text" class="form-control" id="Mobile1" placeholder="@MyERP.Properties.Resources.Mobile 1">
                            </div>
                        </div>
                        @*<div class="col-md-6">
                                <div class="form-group">
                                    <label for="Mobile2" hidden class="control-label">@MyERP.Properties.Resources.Mobile 2</label>
                                    <input hidden type="text" class="form-control" id="Mobile2" placeholder="@MyERP.Properties.Resources.Mobile 2">
                                </div>
                            </div>*@
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="GroupId" class="control-label">@MyERP.Properties.Resources.Group</label>
                                @Html.DropDownList("GroupId", null, null, htmlAttributes: new { @class = "form-control", required = "required" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="IdentityNumber" class="control-label">@MyERP.Properties.Resources.NationalID</label>
                                <input type="text" class="form-control" id="NationalId" placeholder="@MyERP.Properties.Resources.NationalID">
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <input type="checkbox" id="IsBlocked">
                                <label for="IsBlocked" class="control-label col-sm-8">@MyERP.Properties.Resources.Blocked</label>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class=" control-label" for="">@MyERP.Properties.Resources.Country</label>
                                <select class="form-control" id="GovernorateId" name="GovernorateId"></select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="control-label" for="">@MyERP.Properties.Resources.City</label>
                                <select class="form-control" id="CityId" name="CityId"></select>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group">
                                <label for="Address" class="control-label">@MyERP.Properties.Resources.Address</label>
                                <input type="text" class="form-control" id="PosCustomerAddress" placeholder=@MyERP.Properties.Resources.Address>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group no-margin">
                                <label for="Notes" class="control-label">@MyERP.Properties.Resources.Notes</label>
                                <textarea class="form-control" id="PosCustomerNotes" placeholder=@MyERP.Properties.Resources.Notes></textarea>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary waves-effect" data-dismiss="modal">@MyERP.Properties.Resources.Close</button>
                <button type="button" class="btn btn-info waves-effect waves-light" onclick="addPosCustomer();">@MyERP.Properties.Resources.Save</button>
            </div>
        </div>
    </div>
</div>
<!------------------------------------------------------------------------------------------------------->

<script>

    //--------------- Variables Declarations -------------------//
    let posCustomers = [];
    let RoomOptions = "";
    var Room = '@ViewBag.Room';
    //*********************************************************//
    //--------------- Ready Function -------------------//
    $(document).ready(function () {
        $('#RegistrationDate').val('@ViewBag.RegistrationDate');
        $('#VoucherDate').val('@ViewBag.VoucherDate');
        $.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
            $("input[type|='datetime-local']").prop('min', r.PeriodStart).prop('max', r.PeriodEnd);
        });
        if ($('#Id').val()) {
            var code = $('#DocumentNumber').val();
            $('#DocumentNumbers').val(code.replaceAll("-", ""));
            $("#DepartmentId").prop('disabled', true);
            $("#VoucherDate").prop('disabled', true);

            let CustomerId = $('#CustomerId').val();
            appendPosCustomerOptions(true).then(function () { $('#CustomerId').val(CustomerId).trigger('change') });
        }
        else {
            SetDocNum();
            appendPosCustomerOptions(true);
            $('#BuildingId').trigger('change');
            cashBoxByDepartment();
        }

        getGovernorates();
        getCities();
        getAreas();

    });
    //*********************************************************//
    //--------------- Event Functions -------------------//

    $('#CustomerId').on('change', function () {
        //CalculateTotals($('#NetTotal').inputmask('unmaskedvalue') * 1);
        let customer = posCustomers.filter(function (i) { return i.Id == $('#CustomerId').val() })[0];
        if (customer) {
            if (customer.IsBlocked == true) {
                Swal.fire({
                    title: '@MyERP.Properties.Resources.BlockedCustomerCantBeSelected',
                    text: " ",
                    icon: 'info',
                    showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    confirmButtonColor: '#3085d6'
                });
                $('#CustomerId').prop('selectedIndex', 0)
            }
            else {
                $('#pos-customer-address').text(customer.Address);
                $('#pos-customer-mobile').val(customer.Mobile);
                $("#IdentityNumber").val(customer.NationalId);
                $("#IsBlocked").prop("checked", customer.IsBlocked);
            //$("#GroupId").val(customer.CustomersGroupId);
            //$("#GroupId").text(customer.CustomerGroupArName);
            //$("#GovernorateId").val(customer.GovernorateId).trigger('change');
            //$("#CityId").val(customer.CityId).trigger('change');
            }


        }
    });
    $(document).on('keydown', '#pos-customer-mobile', function (e) {
        if (e.which == 13 || e.keyCode == 13) {
            let elem = $(this);
            let mobileNo = elem.val();
            GetCustomerByIdentityNumberOrMobileNumber(null, mobileNo);        }
    });
    $(document).on('keydown', '#IdentityNumber', function (e) {
        if (e.which == 13 || e.keyCode == 13) {
            let elem = $(this);
            let IdentityNumber = elem.val();
            GetCustomerByIdentityNumberOrMobileNumber(IdentityNumber,null);
        }
    });
    $(document).on('click', '#posCustomerAddBtn', function () {
        getGovernorates();
        $('#pos-customer-modal').modal("show");
    });
    $(document).on('change', "#RegistrationDate", function () {
    });
    $(document).on('change', "#Discount", function () {
        CalculateTotals();
    });
    $(document).on('change', "#PeopleNumber", function () {
        CalculateTotals();
    });
    $(document).on('change', "#Amount", function () {
        CalculateTotals();
    });
    $(document).on('change', "#DepartmentId", function () {
        cashBoxByDepartment();
        SetDocNum();
    });
    $(document).on('change', "#Paid", function () {
        CalculateTotals();
    });
    $(document).on('change', '#VoucherDate', function () {
        if (!$('#Id').val()) {
            SetDocNum();
        }
    });
    //*********************************************************//
     //--------------- Other Functions -------------------//
    function cashBoxByDepartment() {
        $.get('/Helper/CashBoxByDepartment/' + $('#DepartmentId').val()).done(function (r) {
            $('#CashBoxId').empty();
          //  $('#CashBoxId').append('<option value>'+'@MyERP.Properties.Resources.Select' +'</option>');
            for (var i = 0; i < r.length; i++) {
                $('#CashBoxId').append($('<option>', {
                    value: r[i].Id,
                    text: r[i].ArName
                }));
            }
        });
    }
    function CalculateTotals() {
        var PeopleNumber = $('#PeopleNumber').inputmask('unmaskedvalue') > 0 ? $('#PeopleNumber').inputmask('unmaskedvalue') : 0;
        var Amount = $('#Amount').inputmask('unmaskedvalue') > 0 ? $('#Amount').inputmask('unmaskedvalue') : 0;
        var Total = PeopleNumber * Amount;
        $('#Total').val(Total);
        var Discount = $('#Discount').inputmask('unmaskedvalue') > 0 ? $('#Discount').inputmask('unmaskedvalue') : 0;
        //var Total = $('#Total').inputmask('unmaskedvalue');
        var TotalAfterDiscount = Total - Discount;
        $('#TotalAfterDiscount').val(TotalAfterDiscount);
        var Paid = $('#Paid').inputmask('unmaskedvalue');
        var Remain = TotalAfterDiscount - Paid;
        $('#Remain').val(Remain);
    }

    function checkCustomerType() {
        $(".PosCustomerIdDiv").hide();
        $(".PosCustomerDetailsDiv").hide();
    }
    function addPosCustomer() {
        let valid = true;
        if ($("#PosCustomerArName").val() == "") {
            $("#PosCustomerArName").prop('required', true);
        }
        if ($("#pos-customer-modal").find(".form-control:invalid").length > 0) {
            $("#pos-customer-modal").find('.form-horizontal').addClass('was-validated');
            $('html, body').animate({
                scrollTop: $(".form-control:invalid").eq(0).offset().top - 80
            }, 500);
        } else {
            $('#preloader, #status').fadeIn();
            $.ajax(
                {
                    url: '/Customers/AddEdit', contentType: "application/json",
                    type: 'POST',
                    data: JSON.stringify({
                        Id: $("#posCustomerIdInput").val() != "" ? $("#posCustomerIdInput").val() : 0,
                        Code: $("#posCustomerCodeInput").val(),
                        ArName: $("#PosCustomerArName").val(),
                        EnName: $('#PosCustomerEnName').val(),
                        Address: $('#PosCustomerAddress').val(),
                        Mobile: $('#Mobile1').val(),
                        //Mobile2: $('#Mobile2').val(),
                        Notes: $('#PosCustomerNotes').val(),
                        CountryId: $('#GovernorateId').val(),
                        CityId: $('#CityId').val(),
                        //AreaId: $('#AreaId').val(),
                        NationalId: $('#NationalId').val(),
                        IsBlocked: $('#IsBlocked').prop('checked'),
                        CustomersGroupId: $('#GroupId').val(),
                    }),
                    error: function (e) {
                        $('#preloader, #status').fadeOut();
                    },
                    success: function (r) {
                        appendPosCustomerOptions(true).then(function () { $('#CustomerId').val(r.Id).trigger('change'); });
                        $('#pos-customer-modal').modal('hide');
                        $('#preloader, #status').fadeOut();

                    }
                });
        }
    }
    function showPosCustomerModal(posCustomer, isNew, mobileNo,identityNo) {
        if (posCustomer!=null&&posCustomer.IsBlocked == true) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.BlockedCustomerCantBeSelected',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
            $('#CustomerId').prop('selectedIndex', 0)
            $('#CustomerId').trigger('change')
        }
        else {
        if (posCustomer != null && isNew == false) {
            $("#posCustomerIdInput").val(posCustomer.PosCustomerId);
            $("#posCustomerCodeInput").val(posCustomer.PosCustomerCode);
            $("#PosCustomerArName").val(posCustomer.ArName);
            $("#PosCustomerEnName").val(posCustomer.EnName);
            $("#PosCustomerAddress").val(posCustomer.Address);
            $("#PosCustomerNotes").val(posCustomer.Notes);
            $("#Mobile1").val(posCustomer.Mobile);
            $("#Mobile2").val(posCustomer.Mobile2);
            $("#NationalId").val(posCustomer.NationalId);
            $("#IsBlocked").prop("checked", posCustomer.IsBlocked);
            $("#GroupId").val(posCustomer.CustomersGroupId).select2();
            $("#GovernorateId").val(posCustomer.GovernorateId).trigger('change');
            $("#CityId").val(posCustomer.CityId).trigger('change');

        }
        else {
            if (mobileNo != "" && mobileNo != null)
                $("#Mobile1").val(mobileNo);
            else
                $("#Mobile1").val("");


            if (identityNo != "" && identityNo != null)
                $("#NationalId").val(identityNo);
            else
                $("#NationalId").val("");

            $("#PosCustomerArName").val("");
            $("#PosCustomerEnName").val("");
            $("#PosCustomerAddress").val("");
            $("#PosCustomerNotes").val("");
        }
            $('#pos-customer-modal').modal("show");
        }
    }
    function appendPosCustomerOptions(refill) {
        return getPosCustomers(refill).then(function () {
            // let custumerType = $('#CustomerType').val();
            let posCustomerOptions = '';

            for (var i = 0; i < posCustomers.length; i++) {
                posCustomerOptions += '<option value="' + posCustomers[i].Id + '">' + posCustomers[i].ArName + ' - ' + posCustomers[i].Code + '</option>';
            }
            $('#CustomerId').empty().append(posCustomerOptions);
            $('#CustomerId').trigger('change');
        });
    }
    function getPosCustomers(refill) {
        if (refill == true)
            requestCache['/Helper/GetCustomers'] = null;
        return requestData('/Helper/GetCustomers').done(function (r) {
            posCustomers = r;
        });
    }
    function GetCustomerByIdentityNumberOrMobileNumber(IdentityNo, MobileNo) {
        $.get('/Helper/GetCustomerByIdentityNumberOrMobileNumber?identityNo=' + IdentityNo + '&mobileNo=' + MobileNo).done(function (r) {
            if (r.posCustomer != null) {
                $("#CustomerId").val(r.posCustomer.PosCustomerId).trigger('change');
                showPosCustomerModal(r.posCustomer, false, null, null);
            }
            else {
                Swal.fire({
                    title: '@MyERP.Properties.Resources.ThereIsNoCustomerWithThisNoDoYouWantToAdd',
                    text: " ",
                    icon: 'info',
                    showCancelButton: true,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    cancelButtonText: '@MyERP.Properties.Resources.Cancel',
                    confirmButtonColor: '#3085d6',
                    cancelButtonColor: '#d33',
                    reverseButtons: true
                }).then((result) => {
                    if (result.isConfirmed) {
                        showPosCustomerModal(null, true, MobileNo, IdentityNo);
                    }
                    else { result.dismiss; }
                });
            }
        });

    }

    function getGovernorates() {
        $.get('/Helper/GetGovernorates/').done(function (r) {
            $('#GovernorateId').empty();
            for (var i = 0; i < r.length; i++) {
                $('#GovernorateId').append($('<option>', {
                    value: r[i].Id,
                    text: r[i].ArName
                }));
            }
            $('#GovernorateId').trigger('change');
