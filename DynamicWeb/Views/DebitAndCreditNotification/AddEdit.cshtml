                        <script>
(function () {
  if (typeof $ === 'undefined') { alert('jQuery غير محمّل'); return; }

  // ربط الحدث حتى لو المودال ديناميك
  $(document).on('submit', '#excelImportForm', function (e) {
    e.preventDefault();

    var form = this;
    var $form = $(form);
    var $btn  = $form.find('button[type="submit"]');
    var fileInput = $form.find('#excelFile')[0];

    if (!fileInput || !fileInput.files || fileInput.files.length === 0) {
      alert('يرجى اختيار ملف إكسل أولاً.');
      return;
    }

    var fd = new FormData(form);

    // ضمِّن التوكن الموجود داخل نفس الفورم
    var tokenInput = $form.find('input[name="__RequestVerificationToken"]');
    var tokenVal   = tokenInput.length ? tokenInput.val() : null;
    if (tokenVal) fd.set('__RequestVerificationToken', tokenVal);

    // تأكيد القيم الموجودة بعناصر المودال
    var depSel  = document.getElementById('departmentId');
    var dateInp = form.querySelector('input[name="dateOverride"]');
    if (depSel)  fd.set('departmentId', depSel.value || '');
    if (dateInp) fd.set('dateOverride', dateInp.value || '');

    if ($btn.length) {
      $btn.data('_txt', $btn.text());
      $btn.prop('disabled', true).text('جارٍ الاستيراد...');
    }

    $.ajax({
      url: '@Url.Action("ImportExcel","DebitAndCreditNotification")',
      type: 'POST',
      data: fd,
      processData: false,
      contentType: false,
      beforeSend: function (xhr) {
        if (tokenVal) xhr.setRequestHeader('RequestVerificationToken', tokenVal);
      },
      success: function (res) {
        if (typeof res === 'string' && /<!DOCTYPE|<html/i.test(res)) {
          alert('الرد جاء صفحة HTML (قد تكون الجلسة انتهت). حدِّث الصفحة وحاول ثانية.');
          return;
        }
        if (res && res.success) {
          var msg = 'تم الاستيراد بنجاح: ' + (res.inserted || 0) + ' صف.';
          if (res.skipped) msg += ' — تم تخطّي: ' + res.skipped + ' صف.';
          if (res.errors && res.errors.length) {
            msg += '\nأخطاء:\n' + res.errors.map(function (e) {
              return 'سطر ' + (e.row || '?') + ': ' + (e.message || 'خطأ غير محدد');
            }).join('\n');
          }
          alert(msg);
          $('#importExcelModal').modal('hide');
        } else {
          alert((res && res.message) ? res.message : 'فشل الاستيراد.');
        }
      },
      error: function (xhr) {
        var details = xhr && (xhr.responseText || xhr.statusText) ? ('\n' + (xhr.responseText || xhr.statusText)) : '';
        alert('خطأ غير متوقع أثناء الرفع/المعالجة.' + details);
      },
      complete: function () {
        if ($btn.length) {
          $btn.prop('disabled', false).text($btn.data('_txt') || 'ابدأ الاستيراد');
        }
      }
    });
  });
})();
                        </script>


