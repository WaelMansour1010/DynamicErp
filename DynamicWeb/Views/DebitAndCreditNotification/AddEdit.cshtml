@model MyERP.Models.DebitAndCreditNotification

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";

    ViewBag.Title = MyERP.Properties.Resources.DebitAndCreditNotification;
}
<script src="~/Scripts/SaveAndNew.js"></script>

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                @if (Model != null)
                {
                    if (Model.IsDeleted == false)
                    {

                        if (ViewBag.Previous > 0)
                        {
                            <a href="@Url.Action("AddEdit",new {id= ViewBag.First })" class="btn btn-info">@MyERP.Properties.Resources.First</a>
                            <a href="@Url.Action("AddEdit",new { id=ViewBag.Previous })" class=" btn btn-info">&#8250;</a>
                        }
                        if (ViewBag.Next > 0)
                        {
                            <a href="@Url.Action("AddEdit",new { id=ViewBag.Next })" class="btn btn-info">&#8249;</a>
                            <a href="@Url.Action("AddEdit",new {id=ViewBag.Last })" class="btn btn-info">@MyERP.Properties.Resources.Last</a>
                        }
                    }
                }
                <a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
            </div>
            <div class="hed page-title">@MyERP.Properties.Resources.DebitAndCreditNotification :</div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="form-horizontal needs-validation" role="form">
                @*<form action="/DebitAndCreditNotification/AddEdit" class="form-horizontal needs-validation" novalidate method="post">*@
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">
                                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                @Html.AntiForgeryToken()
                                @if (Model != null)
                                {
                                    @Html.HiddenFor(model => model.Id)
                                    @Html.HiddenFor(model => model.IsActive)
                                    @Html.HiddenFor(model => model.IsLinked)
                                    @Html.HiddenFor(model => model.IsPosted)
                                    @Html.HiddenFor(model => model.UserId)
                                    @Html.HiddenFor(model => model.Image)
                                    @Html.HiddenFor(model => model.IsDeleted)
                                }
                                <div class="form-group row">
                                    <label class=" col-sm-2 control-label" for="DocumentNumber">@MyERP.Properties.Resources.DocNo</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.DocumentNumber, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly", placeholder = @MyERP.Properties.Resources.VoucherNo, hidden = "hidden" } })
                                        <input id="DocumentNumbers" class="form-control" placeholder=@MyERP.Properties.Resources.Code required readonly />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label class="col-sm-2 control-label " for="Date">@MyERP.Properties.Resources.Date</label>
                                    <div class="col-sm-4">
                                        <input id="Date" name="Date" class="form-control" type="datetime-local" required value="@ViewBag.Date" />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>

                                </div>

                                <div class="form-group row">
                                    <label for="DepartmentId" class="control-label col-sm-2">@MyERP.Properties.Resources.Department</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("DepartmentId", null, null, htmlAttributes: new { @class = "form-control", @required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label for="DepartmentId" class="control-label col-sm-2">@MyERP.Properties.Resources.NotificationType</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("DebitAndCreditNotificationTypeId", null, null, htmlAttributes: new { @class = "form-control", @required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>

                                <div class="form-group row">
                                    <label class="col-sm-2 control-label " for="SourceTypeId">@MyERP.Properties.Resources.Source</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("SourceTypeId", null, htmlAttributes: new { @class = "form-control", @required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label for="CustomerId" class="CustomerId control-label col-sm-2">@MyERP.Properties.Resources.Customer</label>
                                    <div class="CustomerId col-sm-4">
                                        @Html.DropDownList("CustomerId", null, htmlAttributes: new { @class = "CustomerId form-control" })
                                    </div>

                                    <label class="col-sm-2 control-label AccountId" for="AccountId">@MyERP.Properties.Resources.Account</label>
                                    <div class="col-sm-4 AccountId">
                                        @Html.DropDownList("AccountId", null, htmlAttributes: new { @class = " AccountId form-control" })
                                    </div>

                                    <label for="VendorId" class="VendorId control-label col-sm-2">@MyERP.Properties.Resources.Supplier</label>
                                    <div class="VendorId col-sm-4">
                                        @Html.DropDownList("VendorId", null, htmlAttributes: new { @class = "VendorId form-control" })
                                    </div>

                                    <label for="ShareholderId" class="ShareholderId control-label col-sm-2">@MyERP.Properties.Resources.Contributor</label>
                                    <div class="ShareholderId col-sm-4">
                                        @Html.DropDownList("ShareholderId", null, htmlAttributes: new { @class = "ShareholderId form-control" })

                                    </div>

                                    <label for="EmployeeId" class="EmployeeId control-label col-sm-2">@MyERP.Properties.Resources.Employee</label>
                                    <div class="EmployeeId col-sm-4">
                                        @Html.DropDownList("EmployeeId", null, htmlAttributes: new { @class = "EmployeeId form-control" })
                                    </div>

                                    <label for="TechId" class="TechId control-label col-sm-2">@MyERP.Properties.Resources.Technician</label>
                                    <div class="TechId col-sm-4">
                                        @Html.DropDownList("TechnicianId", null, htmlAttributes: new { @class = "TechId form-control" })
                                    </div>

                                    <label for="DirectRevenueId" class="DirectRevenueId control-label col-sm-2">@MyERP.Properties.Resources.DirectRevenue</label>
                                    <div class="DirectRevenueId col-sm-4">
                                        @Html.DropDownList("DirectRevenueId", null, htmlAttributes: new { @class = "DirectRevenueId form-control" })
                                    </div>

                                    <label for="ChildrenId" class="ChildrenId control-label col-sm-2">@MyERP.Properties.Resources.Students</label>
                                    <div class="ChildrenId col-sm-4">
                                        @Html.DropDownList("ChildrenId", null, htmlAttributes: new { @class = "ChildrenId form-control" })
                                    </div>

                                    <label for="ElderId" class="ElderId control-label col-sm-2">@MyERP.Properties.Resources.Elder</label>
                                    <div class="ElderId col-sm-4">
                                        @Html.DropDownList("ElderId", null, htmlAttributes: new { @class = "ElderId form-control" })
                                    </div>
                                    <label for="RenterId" class="RenterId control-label col-sm-2">@MyERP.Properties.Resources.Renter</label>
                                    <div class="RenterId col-sm-4">
                                        @Html.DropDownList("RenterId", null, htmlAttributes: new { @class = "RenterId form-control" })
                                    </div>
                                </div>

                                <div class="form-group row" id="Month_Year" style="display:none;">
                                    <label for="Month" class="control-label col-sm-2">@MyERP.Properties.Resources.Month</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("Month", null, htmlAttributes: new { @class = "form-control" })
                                    </div>
                                    <label for="Year" class="control-label col-sm-2">@MyERP.Properties.Resources.Year</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("Year", null, htmlAttributes: new { @class = "form-control" })
                                    </div>
                                </div>

                                <div class="form-group row">
                                    <label class="col-sm-2 control-label ">@MyERP.Properties.Resources.TotalAmount</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.TotalMoneyAmount, new { htmlAttributes = new { @class = "form-control money", placeholder = @MyERP.Properties.Resources.TotalAmount, @required = "required" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label class="col-sm-2 control-label ">@MyERP.Properties.Resources.Value</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.MoneyAmount, new { htmlAttributes = new { @class = "form-control money", placeholder = @MyERP.Properties.Resources.Value, @required = "required" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="col-sm-2 control-label ">@MyERP.Properties.Resources.VATValue</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.VATValue, new { htmlAttributes = new { @class = "form-control ", placeholder = @MyERP.Properties.Resources.VATValue, @required = "required", @readonly = "readonly" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label class="col-sm-2 control-label ">@MyERP.Properties.Resources.VATPercentage</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.VATPercentage, new { htmlAttributes = new { @class = "form-control ", placeholder = @MyERP.Properties.Resources.VATPercentage, @required = "required", @readonly = "readonly" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>

                                <div class="form-group row">
                                    <label for="RepId" class="control-label col-sm-2">@MyERP.Properties.Resources.Debit</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("DebitId", null, null, htmlAttributes: new { @class = "form-control" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label for="RepId" class="control-label col-sm-2">@MyERP.Properties.Resources.Credit</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("CreditId", null, null, htmlAttributes: new { @class = "form-control" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>


                                <div class="form-group row">
                                    <label for="RepId" class="control-label col-sm-2">@MyERP.Properties.Resources.Representative</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("RepId", null, null, htmlAttributes: new { @class = "form-control" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label class="col-sm-2 control-label ">@MyERP.Properties.Resources.InvoiceNo</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.InvoiceNo, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.InvoiceNo } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="control-label col-sm-2" for="Notes">@MyERP.Properties.Resources.Notes</label>
                                    <div class="col-sm-4">
                                        <textarea id="Notes" name="Notes" class="form-control" rows="5" cols="5">@if (Model != null) { @Model.Notes; }</textarea>

                                    </div>

                                    @if (ViewBag.UseCostCenter == true)
                                    {
                                        <label for="CostCenterId" class="control-label col-sm-2">@MyERP.Properties.Resources.CostCenter </label>

                                        <div class="col-sm-4">
                                            @Html.DropDownList("CostCenterId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>


                        <!-------------------------------------------------------------------------------------------------------------->
                        <div class="row">
                            <div class="col-sm-offset-2">

                                @if (Model == null)
                                {
                                    <button type="button" id="btnSavePrint" class="btn btn-success" onclick="addEdit('report')">
                                        @MyERP.Properties.Resources.SaveAndPrint
                                    </button>

                                    <button type="button" id="newbtn" class="btn btn-success" onclick="addEdit('new')">
                                        @MyERP.Properties.Resources.SaveAndNew
                                    </button>

                                    <button type="button" id="save" class="btn btn-success" onclick="addEdit()">
                                        @MyERP.Properties.Resources.Save
                                    </button>

                                    <a class="btn btn-danger" href="@Url.Action("Index")" role="button">
                                        @MyERP.Properties.Resources.Back
                                    </a>
                                    @* <button class="btn btn-info balance-details-btn" data-toggle="modal" data-target="#BalanceDetails">@MyERP.Properties.Resources.Balance</button> *@
                                }
                                else if (Model.IsDeleted == false)
                                {
                                    <button type="button" id="btnSavePrint" class="btn btn-success" onclick="addEdit('report')">
                                        @MyERP.Properties.Resources.SaveAndPrint
                                    </button>

                                    <button type="button" id="save" class="btn btn-success" onclick="addEdit()">
                                        @MyERP.Properties.Resources.Save
                                    </button>

                                    <a class="btn btn-danger" href="@Url.Action("Index")" role="button">
                                        @MyERP.Properties.Resources.Back
                                    </a>

                                    <button type="button" id="btnDelete" class="btn btn-danger" onclick="DeleteFunc(@Model.Id)">
                                        @MyERP.Properties.Resources.Delete
                                    </button>

                                    @* <button class="btn btn-info balance-details-btn" data-toggle="modal" data-target="#BalanceDetails">@MyERP.Properties.Resources.Balance</button> *@
                                }

                                <!-- زر استيراد من إكسل -->
                                <button type="button" id="btnImportExcel" class="btn btn-info" data-toggle="modal" data-target="#importExcelModal">
                                    استيراد من إكسل
                                </button>

                                <!-- نافذة المودال للاستيراد -->
                                <div class="modal fade" id="importExcelModal" tabindex="-1" role="dialog" aria-labelledby="importExcelLabel" aria-hidden="true">
                                    <div class="modal-dialog" role="document">
                                        <div class="modal-content">

                                            <form id="excelImportForm" enctype="multipart/form-data">
                                                @* مهم: المودال له فورم مستقل خاص بالاستيراد *@
                                                @Html.AntiForgeryToken()
                                                <div class="modal-header">
                                                    <h4 class="modal-title" id="importExcelLabel">استيراد إشعارات من ملف إكسل</h4>
                                                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                                        <span aria-hidden="true">×</span>
                                                    </button>
                                                </div>

                                                <div class="modal-body">
                                                    <div class="form-group">
                                                        <label for="excelFile">ملف الإكسل (.xls / .xlsx)</label>
                                                        <input type="file" name="file" id="excelFile" accept=".xls,.xlsx" class="form-control" required />
                                                    </div>

                                                    <div class="form-group">
                                                        <label for="departmentId">القسم (افتراضي عند غياب العمود)</label>
                                                        @Html.DropDownList("departmentId", (SelectList)ViewBag.DepartmentId, "-- اختر --", new { @class = "form-control", @id = "departmentId" })
                                                    </div>

                                                    <div class="form-group">
                                                        <label for="dateOverride">تاريخ افتراضي</label>
                                                        <input type="datetime-local" name="dateOverride" id="dateOverride" class="form-control" value="@ViewBag.Date" />
                                                    </div>

                                                    <div class="mb-2">
                                                        <a href="@Url.Action("DownloadCreditNotesTemplate","DebitAndCreditNotification")" class="btn btn-link">
                                                            تحميل نموذج إكسل
                                                        </a>
                                                    </div>

                                                    <small class="text-muted d-block">
                                                        يدعم الأعمدة: Date, DepartmentCode/Id, DebitCode/Id, CreditCode/Id, TypeId,
                                                        SourceTypeId, RepCode/Id, TotalMoneyAmount, MoneyAmount, VATValue, VATPercentage,
                                                        CurrencyCode/Id, CostCenterCode/Id, Notes, InvoiceNo, CustomerCode/Id, VendorCode/Id, ... إلخ.
                                                    </small>
                                                </div>

                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-default" data-dismiss="modal">إغلاق</button>
                                                    <button type="submit" class="btn btn-primary">ابدأ الاستيراد</button>
                                                </div>
                                            </form>

                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>



                        @if (Model != null)
                        {
                            if (ViewBag.JE != null)
                            {
                                <div class="card">
                                    <div class="card-body">
                                        <h5 class="header-title">@MyERP.Properties.Resources.JournalEntries</h5>
                                        <div class="form-horizontal">
                                            <div class="form-group row">
                                                <label for="inputtext3" class="col-sm-2 control-label">@MyERP.Properties.Resources.VoucherNo</label>
                                                <div class="col-sm-4">
                                                    <input type="text" class="form-control" name="txtDocNo" value="@ViewBag.JE.DocumentNumber" id="txtDocNo" placeholder=@MyERP.Properties.Resources.VoucherNo disabled>

                                                </div>
                                                <label for="inputtext3" class="col-sm-2 control-label">@MyERP.Properties.Resources.Date </label>
                                                <div class="col-sm-4">
                                                    <input type="datetime-local" class="form-control" name="dtDate" value="@ViewBag.Date" id="dtDate" placeholder=@MyERP.Properties.Resources.ReleaseDate required disabled>
                                                </div>

                                            </div>
                                            <div class="form-group row">

                                                <label for="inputtext3" class="col-sm-2 control-label">@MyERP.Properties.Resources.Branch</label>
                                                <div class="col-sm-4">
                                                    @Html.DropDownList("DepartmentId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", id = "DepartmentId", @required = "required", @disabled = "disabled" })
                                                </div>

                                            </div>
                                            <div class="form-group row">
                                                <label for="inputtext3" class="col-sm-2 control-label">@MyERP.Properties.Resources.Notes</label>
                                                <div class="col-sm-11">
                                                    <textarea type="text" class="form-control validate[required]" id="txtNotes" value="@ViewBag.JE.Notes" name="txtNotes" placeholder=@MyERP.Properties.Resources.Notes disabled></textarea>
                                                </div>
                                                <label for="inputtext3" class="col-sm-2 control-label">@MyERP.Properties.Resources.Deported</label>
                                                <div class="col-sm-4">
                                                    @if (Model.IsPosted == true)
                                                    {
                                                        <input type="checkbox" class="form-control" id="chkIsPosted" name="chkIsPosted" style="width:15px;" checked disabled>
                                                    }
                                                    else
                                                    {
                                                        <input type="checkbox" class="form-control" id="chkIsPosted" name="chkIsPosted" style="width:15px;" disabled>
                                                    }

                                                </div>
                                            </div>
                                            <div class="card">
                                                <div class="card-body">
                                                    <h5 class="header-title"> @MyERP.Properties.Resources.JournalEntryDetails</h5>
                                                    <div class="table-responsive">
                                                        <table class="table table-centered mb-0">
                                                            <thead>
                                                                <tr>
                                                                    <th>@MyERP.Properties.Resources.Debit</th>
                                                                    <th>@MyERP.Properties.Resources.Credit</th>
                                                                    <th>@MyERP.Properties.Resources.Account</th>
                                                                    <th>@MyERP.Properties.Resources.Explanation</th>
                                                                    <th>@MyERP.Properties.Resources.CostCenter</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @if (Model.Id != 0)
                                                                {
                                                                    foreach (var jED in ViewBag.JEDetails)
                                                                    {
                                                                        <tr>
                                                                            <td>
                                                                                <label>@jED.Debit</label>
                                                                                <input type='text' class='txtDebit' value="@jED.Debit" hidden>
                                                                            </td>
                                                                            <td>
                                                                                <label>@jED.Credit</label>
                                                                                <input type='text' class='txtCredit ' value="@jED.Credit" hidden>
                                                                            </td>
                                                                            <td>
                                                                                @if (jED.AccountId != null)
                                                                                {
                                                                                    <label>@jED.ChartOfAccount.ArName</label>
                                                                                    <input type='number' class='AccountId' value="@jED.AccountId" hidden>
                                                                                }

                                                                            </td>
                                                                            <td>
                                                                                <label>@jED.Notes</label>
                                                                            </td>
                                                                            <td>
                                                                                @Html.Raw(jED.CostCenter != null ? jED.CostCenter.ArName : null)
                                                                            </td>
                                                                        </tr>
                                                                    }
                                                                }
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        }


