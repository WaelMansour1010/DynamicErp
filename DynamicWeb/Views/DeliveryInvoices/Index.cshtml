@model IEnumerable<MyERP.Models.SalesInvoice>
@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";

    ViewBag.Title = MyERP.Properties.Resources.DeliveryInvoices;
}

<div class="card-box">
    <div class="form-group form-row">
        <label class=" col-sm-4 control-label" for="DepartmentId">@MyERP.Properties.Resources.Branch</label>
        <div class="col-sm-8">
            @Html.DropDownList("DepartmentId", null, htmlAttributes: new { @class = "form-control" })
        </div>
    </div>
    <div class="row">
        <div class="col-12" id="UnpaidInvoicesTable">


        </div>
    </div>
</div>

<script>

    $(document).ready(function () {
        showUnpaidInvoices();

    });
    $(document).on("change", "#DepartmentId", function () {
        showUnpaidInvoices();
    });

    function getDrivers() {
        return requestData('/Helper/GetDriversByDep?depId='+$("#DepartmentId").val()).done(function (r) {
            console.log(r)
            $('.DriverId').empty();
            $('.DriverId').append($('<option>', {
                value: "",
                text: '@MyERP.Properties.Resources.Select'
            }));
            for (var i = 0; i < r.length; i++) {
                $('.DriverId').append($('<option>', {
                    value: r[i].Id,
                    text: r[i].ArName
                }));
            }

            //$('#GovernorateId').trigger('change');
        });
    }

    function showUnpaidInvoices() {
        var depId = $("#DepartmentId").val();
        getUnpaidInvoices(depId);

    }

    function getSalesInvoiceDetails(id) {
        // User must be cashier
        if ('@ViewBag.IsCashier' == 'True') {
            window.open("/PointOfSale/AddEdit?Id=" + id + "&showPaymentMethods=true", '_blank');
        }
        else {
            Swal.fire({
                title: '@MyERP.Properties.Resources.UserShouldBeCashierToPayInvoice',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        }
    }

    function getUnpaidInvoices(depId) {
        $('#UnpaidInvoicesTable').empty().append('<div class="col-sm-12"><div class="d-flex align-items-center"><div class="spinner-border ml-auto" role="status" aria-hidden="true"></div></div></div>');
        $.get('/PointOfSale/UnpaidSalesInvoicesByDepartment?id=' + depId).done(function (r) {
            $('#UnpaidInvoicesTable').empty().append(r);
        });
    }

    $(document).on('click', '.saveDeliveryData', function () {
        $("#DepartmentId").trigger('change');
    });
</script>


