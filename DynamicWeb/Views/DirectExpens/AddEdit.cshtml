@model MyERP.Models.DirectExpens

@{
    UICulture = Session["lang"] != null?Session["lang"].ToString():"ar";
    ViewBag.Title = @MyERP.Properties.Resources.DirectExpenses;
}
<script src="~/js/DeleteFunctionForAddEditView.js"></script>

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">

                @if (Model != null)
                {
                    if (Model.IsDeleted == false)
                    {
                        if (ViewBag.Previous > 0)
                        {
                            <a href="@Url.Action("AddEdit",new {id= ViewBag.First })" class="btn btn-info">@MyERP.Properties.Resources.First</a>
                            <a href="@Url.Action("AddEdit",new { id=ViewBag.Previous })" class=" btn btn-info">&#8250;</a>
                        }
                        if (ViewBag.Next > 0)
                        {
                            <a href="@Url.Action("AddEdit",new { id=ViewBag.Next })" class="btn btn-info">&#8249;</a>
                            <a href="@Url.Action("AddEdit",new {id=ViewBag.Last })" class="btn btn-info">@MyERP.Properties.Resources.Last</a>
                        }
                    }
                }
                <a class="btn btn-info" href="@Url.Action("Index")" role="button" style="float:left;">@MyERP.Properties.Resources.Back</a>
            </div>

            <div class="hed page-title">@MyERP.Properties.Resources.DirectExpenses :</div>
        </div>
    </div>
</div>
<div class="row">
    <div class="col-12">
        <div class="card-box">
            <form action="/DirectExpens/AddEdit" class="form-horizontal needs-validation" novalidate method="post">
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">
                                @Html.AntiForgeryToken()
                                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                @if (Model != null)
                                {
                                    @Html.HiddenFor(model => model.Id)
                                    @Html.HiddenFor(model => model.IsActive)
                                    @Html.HiddenFor(model => model.UserId)
                                    @Html.HiddenFor(model => model.Image)
                                    @Html.HiddenFor(model => model.IsLinked)
                                    @Html.HiddenFor(model => model.IsPosted)
                                }
                                <div class="form-group row">
                                    <label class=" col-sm-2 control-label" for="Code">@MyERP.Properties.Resources.Code</label>
                                    <div class="col-sm-2">
                                        @Html.EditorFor(model => model.Code, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.Code, @readonly = "readonly", required = "required" } })
                                        @Html.ValidationMessageFor(model => model.Code, "", new { @class = "text-danger" })
                                    </div>
                                    <div class="col-sm-2">
                                        @Html.DropDownListFor(model => model.FieldsCodingId, null, null, htmlAttributes: new { @class = "form-control" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label class=" col-sm-2 control-label" for="ArName">
                                        @MyERP.Properties.Resources.ArName
                                    </label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.ArName, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.ArName, required = "required" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.ArNameRequired
                                        </div>
                                    </div>
                                </div>
                            <div class="form-group row">
                                <label class=" col-sm-2 control-label" for="EnName">@MyERP.Properties.Resources.EnName</label>
                                <div class="col-sm-4">
                                    @Html.EditorFor(model => model.EnName, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.EnName } })
                                </div>

                                <label class=" col-sm-2 control-label" for="AccountId"> @MyERP.Properties.Resources.Account </label>
                                <div class="col-sm-4">
                                    @Html.DropDownList("AccountId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", @required = "required" })
                                    <div class="invalid-feedback">
                                        @MyERP.Properties.Resources.Required
                                    </div>
                                </div>
                            </div>
                            <div class="form-group row">
                                <label class="col-sm-2 control-label" for="Notes">@MyERP.Properties.Resources.Notes</label>
                                <div class="col-sm-4">
                                    <textarea id="Notes" name="Notes" class="form-control" rows="5" cols="5">@if (Model!=null){ @Model.Notes; }</textarea>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-offset-2">
                        @if (Model == null)
                        {
                            <input id="new" name="newBtn" hidden />
                            <button type="submit" id="newbtn" class="btn btn-success">
                                @MyERP.Properties.Resources.SaveAndNew
                            </button>
                            <button type="submit" class="btn btn-success">
                                @MyERP.Properties.Resources.Save
                            </button>
                            <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                        }
                        else if (Model.IsDeleted == false)
                        {
                    <button type="submit" class="btn btn-success">
                        @MyERP.Properties.Resources.Save
                    </button>
                    <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                    <a class="btn btn-danger" onclick="Delete(@Model.Id)" role="button" href="javascript:void(0);">@MyERP.Properties.Resources.Delete</a>

                        }
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
</div>

<script>
    $(document).ready(function () {
        if (!$('#Id').val()) {
            setCodeNum();
        }
        else {
            $('#FieldsCodingId').prop('disabled', true);
        }
    });

    function setCodeNum() {
        $.get('/DirectExpens/SetCodeNum?FieldsCodingId=' + $('#FieldsCodingId').val()).done(function (r) {
            $('#Code').val(r);
        });
    }

    $('#FieldsCodingId').on('change', function () {
        if (!$('#Id').val()) {
            setCodeNum();
        }
    });

    // disable gives Null with form Submit so we have to reverse it in submin
    $("form").submit(function () {
        $("#FieldsCodingId").prop('disabled', false);
    });

    function Delete(id) {
        if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToDelete')) {
            $('#preloader, #status').fadeIn();
            $.ajax(
                {
                    url: '/DirectExpens/Delete',
                    type: 'POST',
                    data: {
                        "Id": id,
                    },
                    error: function (e) {
                        $('#preloader, #status').fadeOut();

                    },
                    success: function (r) {
                        if (r == 'true') {
                            window.location.replace('/DirectExpens');
                        }
                    }
                });
        }
    }
</script>
