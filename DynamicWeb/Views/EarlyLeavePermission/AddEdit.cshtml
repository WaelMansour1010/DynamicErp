@model MyERP.Models.EarlyLeavePermission

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.EarlyLeavePermission;
}


<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                @if (Model != null)
                {
                    if (Model.IsDeleted == false)
                    {
                        if (ViewBag.Previous > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.First })" class="btn btn-info">@MyERP.Properties.Resources.First</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Previous })" class=" btn btn-info">&#8250;</a>
                        }
                        if (ViewBag.Next > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Next })" class="btn btn-info">&#8249;</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Last })" class="btn btn-info">@MyERP.Properties.Resources.Last</a>
                        }
                    }
                }
                <a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
            </div>
            <h4 class="page-title"> @MyERP.Properties.Resources.EarlyLeavePermission:</h4>
        </div>
    </div>
</div>


@if (Model != null)
{
    @Html.HiddenFor(model => model.Id)
    @Html.HiddenFor(model => model.IsDeleted)
    @Html.HiddenFor(model => model.UserId)
    @Html.HiddenFor(model => model.Image)
    @Html.HiddenFor(model => model.IsApproved)
}
<div class="row">
    <div class="col-12">
        <div class="card-box">

            <div class="row">
                <div class="col-12">
                    @*<form action="/EarlyLeavePermission/AddEdit" class="form-horizontal needs-validation" novalidate method="post">*@
                    <div class="form-horizontal needs-validation" role="form">
                        <div class="card">
                            <div class="card-body">

                                <div class="form-group row">
                                    <label class=" col-sm-2 control-label" for="DocumentNumber"> @MyERP.Properties.Resources.TransactionNo </label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.DocumentNumber, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly", placeholder = @MyERP.Properties.Resources.TransactionNo, required = "required", hidden = "hidden" } })
                                        <input id="DocumentNumbers" class="form-control" placeholder=@MyERP.Properties.Resources.DocNo required readonly />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label for="Date" class="control-label col-sm-2">@MyERP.Properties.Resources.Date </label>
                                    <div class="col-sm-4">
                                        @if (Model != null)
                                        {
                                            @Html.Editor("Date", new { htmlAttributes = new { @class = "form-control", required = "required", type = "datetime-local" } })

                                        }
                                        else
                                        {
                                            @Html.Editor("Date", new { htmlAttributes = new { @Value = DateTime.Now, @class = "form-control", required = "required", type = "datetime-local" } })

                                        }
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="DepartmentId" class="col-sm-2 control-label"> @MyERP.Properties.Resources.Department </label>
                                    <div class="col-sm-4">
                                        @Html.DropDownListFor(a => a.DepartmentId, null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", @required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label for="DepartmentId" class="col-sm-2 control-label"> @MyERP.Properties.Resources.Employee </label>
                                    <div class="col-sm-4">
                                        @Html.DropDownListFor(a => a.EmployeeId, null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", @required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="DepartmentId" class="col-sm-2 control-label"> @MyERP.Properties.Resources.Shift </label>
                                    <div class="col-sm-4">
                                        @Html.DropDownListFor(a => a.ShiftId, null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", @required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>

                                    <label class=" col-sm-2 control-label" for="DocumentNumber"> @MyERP.Properties.Resources.NoOfHours </label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.NoOfHours, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.NoOfHours, required = "required" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="PermissionDate" class="control-label col-sm-2">@MyERP.Properties.Resources.PermissionDate</label>
                                    <div class="col-sm-4">
                                        @if (Model != null)
                                        {
                                            @Html.Editor("PermissionDate", new { htmlAttributes = new { @class = "form-control", required = "required", type = "datetime-local" } })

                                        }
                                        else
                                        {
                                            @Html.Editor("PermissionDate", new { htmlAttributes = new { @class = "form-control", required = "required", type = "datetime-local" } })

                                        }
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    @*<label for="IsApproved" class="control-label col-sm-2">@MyERP.Properties.Resources.IsApproved</label>
                                        <div class="col-sm-1">
                                            <input type="checkbox" name="IsApproved" @Html.Raw(Model != null && Model.IsApproved == true ? "checked" : "") id="IsApproved" />
                                        </div>*@
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-12">
                                <div class="card">
                                    <!--    Save Buttons      -->
                                    <div class="card-body">
                                        <input id="new" name="newBtn" hidden />
                                        <div style="float:right;">
                                            <div class="row">
                                                <div class="col-sm-offset-2">
                                                    @if (Model == null)
                                                    {
                                                        <button onclick="addEdit('new')" class="btn btn-success" id="newbtn">
                                                            @MyERP.Properties.Resources.SaveAndNew
                                                        </button>
                                                        <button class="btn btn-success" onclick="addEdit()" id="save">
                                                            @MyERP.Properties.Resources.Save
                                                        </button>
                                                        <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                                                    }
                                                    else if (Model.IsDeleted == false)
                                                    {

                                                        <button class="btn btn-success" onclick="addEdit()" id="save">
                                                            @MyERP.Properties.Resources.Save
                                                        </button>

                                                        //-------------- Acceptance Btn ---------------//
                                                        <input type="checkbox" name="IsApproved" id="IsApproved" hidden @Html.Raw(Model != null && Model.IsApproved == true ? "checked" : "") />
                                                        <button class="btn btn-success" id="AcceptBtn" onclick="Accept()">
                                                            @MyERP.Properties.Resources.Accept
                                                        </button>

                                                        //------------------------//
                                                        <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                                                        <button class="btn btn-danger" onclick="Delete(@Model.Id)">
                                                            @MyERP.Properties.Resources.Delete
                                                        </button>
                                                    }
                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>
                        @*</form>*@
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>
<script>
    //----------- variable Declaration -----------


//----------------------- On Ready -------------
    $(document).ready(function () {
        if ($('#Id').val() > 0) {
            if ($('#IsApproved').val() == 'True') {
                $('#IsApproved').prop('checked', 'checked');
                $('#AcceptBtn').prop('disabled', true);
            }
            var code = $('#DocumentNumber').val();
            $('#DocumentNumbers').val(code.replaceAll("-", ""))
            $("#DepartmentId").prop('disabled', true);
            $("#Date").prop('disabled', true);
        }
        else {
            setDocNum();
        }
    });

//-------------------------- DocNum---------------------------------//
    function setDocNum() {
        if ($('#DepartmentId').val())
            $.get('/EarlyLeavePermission/SetDocNum?id=' + $('#DepartmentId').val() + '&VoucherDate=' + $('#Date').val()).done(function (r) {
                $('#DocumentNumber').val(r);
                $('#DocumentNumbers').val(r.replaceAll("-", ""));
            });
    }
   
    $(document).on('change', '#DepartmentId', function () {
        if ($('#DepartmentId').val()) {
            setDocNum();
        }
    });
    $('#Date').on('change', function () {
        setDocNum();
    });
//------------------------------- ShowDate------------------------------//
    function zeroPadded(val) {
        if (val >= 10)
            return val;
        else
            return '0' + val;
    }
    if ($('#Id').val() > 0) {
        $('#Date').val('@ViewBag.Date');
        $('#PermissionDate').val('@ViewBag.PermissionDate');
    }
    else
    {
        var d = new Date();
        $('#Date').val(d.getFullYear() + "-" + zeroPadded(d.getMonth() + 1) + "-" + zeroPadded(d.getDate()) + "T" + zeroPadded(d.getHours()) + ":" + zeroPadded(d.getMinutes()));
        //$('#PermissionDate').val(d.getFullYear() + "-" + zeroPadded(d.getMonth() + 1) + "-" + zeroPadded(d.getDate()) + "T" + zeroPadded(d.getHours()) + ":" + zeroPadded(d.getMinutes()));
        }

    //------------------- ConvertDate-------------
    function convertToJavaScriptDate(value) {
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        return (dt)
    }


    function Accept() {
        Swal.fire({
            title: '@MyERP.Properties.Resources.YouWantToAccept',
            text: " ",
            icon: 'info',
            showCancelButton: true,
            confirmButtonText: '@MyERP.Properties.Resources.Ok',
            cancelButtonText: '@MyERP.Properties.Resources.Cancel',
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                $('#IsApproved').prop('checked', 'checked');
                $('#AcceptBtn').prop('disabled', true);
            }
            else { result.dismiss; }
        });
    }
    //--------------------------------------- ADD EDIT---------------------------//
    function addEdit(n) {
        if ($(".form-control:invalid").length > 0) {
            console.log($(".form-control:invalid"));
            $('.form-horizontal').addClass('was-validated');
            $('html, body').animate({
                scrollTop: $(".form-control:invalid").eq(0).offset().top - 100
            }, 500);
            valid = false;
        }
        else {
            var EarlyLeavePermission =
            {
                Id: $('#Id').val(),
                DocumentNumber: $('#DocumentNumber').val(),
                DepartmentId: $('#DepartmentId').val(),
                EmployeeId: $('#EmployeeId').val(),
                ShiftId: $('#ShiftId').val(),
                Date: $('#Date').val(),
                PermissionDate: $('#PermissionDate').val(),
                IsDeleted: false,
                IsApproved: $('#IsApproved').prop('checked'),
                NoOfHours: $('#NoOfHours').val()
            };
            Swal.fire({
                title: '@MyERP.Properties.Resources.AreYouSureYouWantToSave',
                text: " ",
                icon: 'info',
                showCancelButton: true,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                cancelButtonText: '@MyERP.Properties.Resources.Cancel',
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    $('#newbtn').prop('disabled', true);
                    $('#save').prop('disabled', true);
                    $('#preloader, #status').fadeIn();
                    $.ajax({
                        type: "POST",
                        url: "/EarlyLeavePermission/AddEdit",
                        data: EarlyLeavePermission,
                        success: function (r) {
                            if (r.success == "true") {
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.Saved',
                                    text: " ",
                                    icon: 'success',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                                if (n == "new") {
                                    window.location.replace("/EarlyLeavePermission/AddEdit");
                                } else {
                                    window.location.replace("/EarlyLeavePermission");
                                }
                            }
                            else
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.NotSaved !',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                            $('#preloader, #status').fadeOut();
                            $('#newbtn').prop('disabled', false);
                            $('#save').prop('disabled', false);
                        },
                        error: function (r) {
                            $('#preloader, #status').fadeOut();
                            $('#newbtn').prop('disabled', false);
                            $('#save').prop('disabled', false);
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.NotSaved !',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                        }
                    });
                }
                else { result.dismiss; }
            });
        }
    }

        function Delete(id) {
        Swal.fire({
            title: '@MyERP.Properties.Resources.AreYouSureYouWantToDelete',
            text: " ",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: '@MyERP.Properties.Resources.Ok',
            cancelButtonText: '@MyERP.Properties.Resources.Cancel',
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                $('#preloader, #status').fadeIn();
                $.ajax(
                    {
                        url: '/EarlyLeavePermission/Delete',
                        type: 'POST',
                        data: {
                            "Id": id,
                        },
                        error: function (e) {
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.DeleteDoesNotSucceeded',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                            $('#preloader, #status').fadeOut();
                        },
                        success: function (r) {
                            if (r == 'true') {
                                window.location.replace("/EarlyLeavePermission");
                            }
                            else {
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.DeleteDoesNotSucceeded',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                                $('#preloader, #status').fadeOut();
                            }
                        }
                    });
            }
            else { result.dismiss; }
        });
    }

</script>
