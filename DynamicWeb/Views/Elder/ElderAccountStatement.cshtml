@model IEnumerable<MyERP.Models.GetElderAccountStatement_Result>

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.ElderAccountStatement;
}

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="hed page-title">@MyERP.Properties.Resources.ElderAccountStatement :</div>
        </div>
    </div>
</div>


<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal needs-validation" role="form">
                        <div class="card">
                            <div class="card-body">
                                <h5 class="header-title">
                                    @MyERP.Properties.Resources.ElderAccountStatement
                                </h5>
                                <div class="form-group row">
                                    <label class=" col-sm-1 control-label" for="ArName">@MyERP.Properties.Resources.Year</label>
                                    <div class="col-sm-5">
                                        @Html.DropDownList("Year", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })
                                    </div>
                                    <label class=" col-sm-1 control-label" for="ArName">@MyERP.Properties.Resources.Month</label>
                                    <div class="col-sm-5">
                                        @Html.DropDownList("Month", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-sm-offset-2">
                    <button class="btn btn-success" onclick="ElderAccountStatement()">
                        <i class="fa fa-search"></i>
                    </button>
                </div>
            </div>
        </div>

    </div>
</div>

<!--------------------------------ShowData Table --------------------------------------->
<div class="row" id="AllTable">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal needs-validation" role="form">
                        <div class="card">
                            <div class="card-body">
                                <h5 class="header-title">
                                    @MyERP.Properties.Resources.ElderAccountStatement
                                </h5>

                                <div class="table-responsive">
                                    <table class="table table-striped table-centered mb-0">
                                        <thead>
                                            <tr>
                                                <th>
                                                    @MyERP.Properties.Resources.Students
                                                </th>
                                                <th>
                                                    @MyERP.Properties.Resources.MonthlySubscription
                                                </th>
                                                <th>
                                                    @MyERP.Properties.Resources.SubscriptionStartDate
                                                </th>
                                                <th>
                                                    @MyERP.Properties.Resources.CashReceiptVoucherNo
                                                </th>
                                                <th>
                                                    @MyERP.Properties.Resources.CashReceiptVoucherDate
                                                </th>
                                                <th>
                                                    @MyERP.Properties.Resources.IsPaid
                                                </th>
                                                <th>
                                                    @MyERP.Properties.Resources.MoneyAmount
                                                </th>
                                            </tr>
                                        </thead>
                                        <tbody id="ShowDataTable">
                                            @if (Model != null && Model.Count() > 0)
                                            {
                                                foreach (var item in Model)
                                                {
                                                    <tr>
                                                        <td>
                                                            @Html.DisplayFor(modelItem => item.ArName)
                                                        </td>
                                                        <td>
                                                            @Html.DisplayFor(modelItem => item.MonthlySubscription)
                                                        </td>
                                                        <td>
                                                            @Html.DisplayFor(modelItem => item.SubscriptionStartDate)
                                                        </td>
                                                        <td>
                                                            @Html.Raw(item.DocumentNumber != null ? item.DocumentNumber.ToString().Replace("-", "") : "")
                                                        </td>
                                                        <td>
                                                            @Html.DisplayFor(modelItem => item.Date)
                                                        </td>
                                                        <td>
                                                            @if (item.CashReceiptVoucherId > 0)
                                                            {
                                                                <i class="fe-check-circle"></i>
                                                            }
                                                        </td>
                                                        <td>
                                                            @Html.DisplayFor(modelItem => item.MoneyAmount)
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<!--***********************************************************************************************-->

<script>

    function ElderAccountStatement() {
        var link = '/Elder/ElderAccountStatement?Year=' + $('#Year').val() + '&Month=' + $('#Month').val();
        window.location.replace(link);
    }

</script>