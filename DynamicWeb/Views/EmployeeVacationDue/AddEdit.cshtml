<script>
//----------- variable Declaration -----------
        var sum = 0;
        let vacationReq = [];
        let requestDetails = [];
        var total = 0;
        let TotalDutyDays = 0;
        let days = 0;
        let months = 0;
        let years = 0;
        let VacationDays = 0;
//----------------------- On Ready -------------
    $(document).ready(function () {
        //   GetEmployeeData();
        CalculateTotalDueAmount();
        CalculateTotalDeductionAmount();
        CalculateNetDueAmount();

        if ($('#EmployeeId').val()) {
            GetEmployeeData();
            EmployeeVacationDueDetails()
        }
        if ($('#Id').val() > 0) {
            if ($('#VacationRequestId').val() > 0) {
                $('#VacationRequestId').trigger('change')
            }
            $('#Date').val('@ViewBag.Date');
            $('#AdjustmentDate').val('@ViewBag.AdjustmentDate');
            var code = $('#DocumentNumber').val();
            $('#DocumentNumbers').val(code.replaceAll("-", ""))
            $("#DepartmentId").prop('disabled', true);
            $("#Date").prop('disabled', true);
        }
        else {
            setDocNum();
            var d = new Date();
            $('#Date').val(d.getFullYear() + "-" + zeroPadded(d.getMonth() + 1) + "-" + zeroPadded(d.getDate()) + "T" + zeroPadded(d.getHours()) + ":" + zeroPadded(d.getMinutes()));
            $('#AdjustmentDate').val(d.getFullYear() + "-" + zeroPadded(d.getMonth() + 1) + "-" + zeroPadded(d.getDate()) + "T" + zeroPadded(d.getHours()) + ":" + zeroPadded(d.getMinutes()));
        }
    });

//------------------------- On Change ----------
        $('#EmployeeId').on('change', function () {
            GetEmployeeData();
            EmployeeVacationDueDetails();
            GetEmployeeVacationRequest();
        });

        $('#VacationRequestId').on('change', function () {
            GetEmployeeVacationRequestDetails();
        });
        $(document).on('change', '#CurrentSalaryAmount,#PreviousSalaryAmount,#OtherAdditionalAmount,#VariableAdditionalAmount,#VacationSalaryDueAmount,#VariableDeductionAmount,#InsuranceAmount,#LoanDueAmount,#OtherPenaltyAmount', function () {
            CalculateTotalDeduction_Due();
        });
//-------------------------- DocNum---------------------------------//
    function setDocNum() {
        if ($('#DepartmentId').val())
            $.get('/EmployeeVacationDue/SetDocNum?id=' + $('#DepartmentId').val() + '&VoucherDate=' + $('#Date').val()).done(function (r) {
                $('#DocumentNumber').val(r);
                $('#DocumentNumbers').val(r.replaceAll("-", ""));
            });
    }

    $(document).on('change', '#DepartmentId', function () {
        if ($('#DepartmentId').val()) {
            setDocNum();
        }
    });
    $(document).on('change', '#Date', function () {
            setDocNum();
    });

//------------------------------- ShowDate------------------------------//
    function zeroPadded(val) {
        if (val >= 10)
            return val;
        else
            return '0' + val;
    }

    //------------------- ConvertDate-------------
    function convertToJavaScriptDate(value) {
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        return (dt)
    }

    //-------------------- Get Employee Data -----------
    function GetEmployeeData() {

        let id = $('#EmployeeId').val();
        $.ajax({
            type: "GET",
            dataType: "json",
            contentType: "application/json",
            url: "/EmployeeVacationDue/GetEmployeeData/" + id,
            success: function (r) {
                if ($('#EmployeeId').val() == r[0].Id) {
                    $('#DepartmentArName').val(r[0].DepartmentArName);
                    $('#JobArName').val(r[0].JobArName)
                    $('#AdministrativeDepartmentArName').val(r[0].AdministrativeDepartmentArName)
                    var d = convertToJavaScriptDate(r[0].HireDate)
                    $('#HireDate').val(d.getFullYear() + "-" + zeroPadded(d.getMonth() + 1) + "-" + zeroPadded(d.getDate()) + "T" + zeroPadded(d.getHours()) + ":" + zeroPadded(d.getMinutes()));

                    //--------------------------- اجازة بدون مرتب -----------------------------//
                    var total = r[0].vacationWithoutSalaryBalance + r[0].vacationwithoutSalaryRecord;
                    CalcTotalVacationWithOutSalary(total);
                    //----------------- بدون راتب ------------------
                    $('#TotalDaysOFVacationWithoutSalary').val(total)

                }
            },
            error: function () {
                Swal.fire({
                    title: '@MyERP.Properties.Resources.NotLinked !',
                    text: " ",
                    icon: 'error',
                    showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    confirmButtonColor: '#3085d6'
                });
            }
        });
    }

    //-------------------- Get Employee Vacation DueDetails -----------
    function EmployeeVacationDueDetails() {
        let id = $('#EmployeeId').val();
        $.ajax({
            type: "GET",
            dataType: "json",
            contentType: "application/json",
            url: "/EmployeeVacationDue/EmployeeVacationDueGetDetails/" + id,
            success: function (r) {
                $('#Details').empty();
                sum = 0;
                for (var i = 0; i < r.length; i++) {
                    sum += r[i].ItemValue;
                    $('#TotalSalary').val(sum);

                    $('#Details').append('<tr><td><label class=" col-sm-2 control-label SalaryItemId" hidden id="SalaryItemId"> ' + r[i].SalaryItemId + ' </label><label class=" col-sm-4 control-label SalaryItemArName" id="SalaryItemArName"> ' + r[i].SalaryItemArName + ' </label></td><td><input id="SalaryItemValue" disabled class="SalaryItemValue form-control col-sm-4" value="' + r[i].ItemValue + '" /></td></tr>')
                }

            },
            error: function () {
                Swal.fire({
                    title: '@MyERP.Properties.Resources.NotLinked !',
                    text: " ",
                    icon: 'error',
                    showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    confirmButtonColor: '#3085d6'
                });
            }
        });
    }

    //-------------- Get Employee Vacation Request
    function GetEmployeeVacationRequest() {
            let id = $('#EmployeeId').val();
            $.ajax({
                type: "GET",
                dataType: "json",
                contentType: "application/json",
                url: "/EmployeeVacationDue/GetVacationRequest/" + id,
                success: function (r) {
                    $('#VacationRequestId').empty();
                    if (r.length == 0) {
                        Swal.fire({
                            title: '@MyERP.Properties.Resources.NoVacationRequest',
                            text: " ",
                            icon: 'info',
                            showCancelButton: false,
                            confirmButtonText: '@MyERP.Properties.Resources.Ok',
                            confirmButtonColor: '#3085d6'
                        });
                    }
                    vacationReq = r;
                    $('#VacationRequestId').append(new Option('@MyERP.Properties.Resources.Select', '0'));
                    for (var i = 0; i < vacationReq.length; i++) {
                        $('#VacationRequestId').append('<option value="' + vacationReq[i].Id + '">' + vacationReq[i].Code.replaceAll('-','') + '</option>');
                    }
                },
                error: function () {
                     Swal.fire({
                    title: '@MyERP.Properties.Resources.NotLinked !',
                    text: " ",
                    icon: 'error',
                    showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    confirmButtonColor: '#3085d6'
                });
                }
            });
        }

    //-------------- Get Employee Vacation Request Detaild
    function GetEmployeeVacationRequestDetails() {
            let id = $('#VacationRequestId').val();
        $.ajax({
            type: "GET",
            dataType: "json",
            contentType: "application/json",
            url: "/EmployeeVacationDue/GetVacationRequestDetails?id=" + id + "&date=" + $('#Date').val(),
            success: function (r) {
                requestDetails = r;
                var d = convertToJavaScriptDate(r[0].VacationEndDate)
                $('#VacationEndDate').val(d.getFullYear() + "-" + zeroPadded(d.getMonth() + 1) + "-" + zeroPadded(d.getDate()) + "T" + zeroPadded(d.getHours()) + ":" + zeroPadded(d.getMinutes()));
                var d = convertToJavaScriptDate(r[0].VacationStartDate)
                $('#VacationStartDate').val(d.getFullYear() + "-" + zeroPadded(d.getMonth() + 1) + "-" + zeroPadded(d.getDate()) + "T" + zeroPadded(d.getHours()) + ":" + zeroPadded(d.getMinutes()));
                var d = convertToJavaScriptDate(r[0].lastVacation)
                $('#lastVacation').val(d.getFullYear() + "-" + zeroPadded(d.getMonth() + 1) + "-" + zeroPadded(d.getDate()) + "T" + zeroPadded(d.getHours()) + ":" + zeroPadded(d.getMinutes()));
                $('#NumberOfVacationDays').val(r[0].NumberOfVacationDays);
                // ------------- Financial Dues ------------- //
                var adjustmentDate = (new Date($('#AdjustmentDate').val())).getDate();
                //r[0].CurrentSalaryAmount = r[0].CurrentSalaryAmount > 0 || r[0].CurrentSalaryAmount != null ? r[0].CurrentSalaryAmount : 0;
                //r[0].VariableAdditionalAmount = r[0].VariableAdditionalAmount > 0 || r[0].VariableAdditionalAmount!=null ? r[0].VariableAdditionalAmount : 0;
                //r[0].VacationSalaryDueAmount = r[0].VacationSalaryDueAmount > 0 || r[0].VacationSalaryDueAmount!=null ? r[0].VacationSalaryDueAmount : 0;
                //r[0].PreviousSalaryAmount = r[0].PreviousSalaryAmount > 0 || r[0].PreviousSalaryAmount!=null ? r[0].PreviousSalaryAmount : 0;
                //r[0].LoanDueAmount = r[0].LoanDueAmount > 0 || r[0].LoanDueAmount!=null ? r[0].LoanDueAmount : 0;
                //r[0].VariableDeductionAmount = r[0].VariableDeductionAmount > 0 || r[0].VariableDeductionAmount!=null ? r[0].VariableDeductionAmount: 0;
                //r[0].InsuranceAmount = r[0].InsuranceAmount > 0 || r[0].InsuranceAmount!=null ? r[0].InsuranceAmount : 0;
                var additional = $('#OtherAdditionalAmount').val();
                additional = additional != null || additional > 0 ? additional : 0;
                $('#OtherAdditionalAmount').val(additional);
                var penalty = $('#OtherPenaltyAmount').val();
                penalty = penalty != null || penalty > 0 ? penalty : 0;
                $('#OtherPenaltyAmount').val(penalty);
                $('#CurrentSalaryAmount').val(r[0].CurrentSalaryAmount * adjustmentDate);
                $('#VariableAdditionalAmount').val(r[0].VariableAdditionalAmount);
                $('#VacationSalaryDueAmount').val(r[0].VacationSalaryDueAmount);
                $('#PreviousSalaryAmount').val(r[0].PreviousSalaryAmount);
                $('#LoanDueAmount').val(r[0].LoanDueAmount);
                $('#VariableDeductionAmount').val(r[0].VariableDeductionAmount);
                $('#InsuranceAmount').val(r[0].InsuranceAmount);
                //------------------------ مدة الغياب -----------------------------//
                let TotalAbsenceDays = r[0].AbsenceDays;
                CalcEquivalent(TotalAbsenceDays);
                $('#Absence_Days').val(days);
                $('#Absence_Months').val(months);
                $('#Absence_Years').val(years);

                //-------------------------- مدة الخدمة ---------------------------//
                let ToDate = convertToJavaScriptDate(r[0].VacationStartDate);
                let FromDate = new Date($('#HireDate').val());
                CalcTotalDutyPeriod(FromDate, ToDate);

                //-------------------------------- مدة العمل ---------------------//
                let TotalWorkDays = TotalDutyDays - (TotalAbsenceDays + TotalDaysOFVacationWithoutSalary);

                CalcEquivalent(TotalWorkDays);
                $('#Work_Days').val(days);
                $('#Work_Months').val(months);
                $('#Work_Years').val(years);

                //-------------------------------- الرصيد المرحل -----------------//
                $('#CarryOverBalance').val(r[0].CarryOverBalanceDays);

                //------------------------------ صافى مدة العمل ------------------//
                let DeductionDays = $('#DeductionDays').val();
                let NetWorkDays = TotalWorkDays - DeductionDays;
                CalcEquivalent(NetWorkDays);
                $('#NetWork_Days').val(days);
                $('#NetWork_Months').val(months);
                $('#NetWork_Years').val(years);
                //----------------------------------ايام الاجازة المستحقة قبل الخصم ------------------
                $('#VacationDaysBeforeDeduction').val(r[0].NumberOfVacationDays);

                ////----------------------------  ايام الغياب  -----------
                $('#TotalAbsenceDays').val(r[0].AbsenceDays);

                //---------------------------- صافى الغياب ----------------------
                let NetAbsenceDay = TotalAbsenceDays - $('#TotalDaysOFVacationWithoutSalary').val();
                $('#NetAbsenceDay').val(NetAbsenceDay);

                //---------------------------- ايام الاجازة المستحقة--------------------
                let VacationDues = VacationDays - NetAbsenceDay;
                $('#VacationDues').val(VacationDues);

                CalculateTotalDeduction_Due();

            },
            error: function () {
                 Swal.fire({
                    title: '@MyERP.Properties.Resources.NotLinked !',
                    text: " ",
                    icon: 'error',
                    showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    confirmButtonColor: '#3085d6'
                });
            }
        });


        }


        function CalculateTotalDeduction_Due() {
            var CurrentSalaryAmount = parseFloat( $('#CurrentSalaryAmount').val() > 0 ? $('#CurrentSalaryAmount').val() : 0.00);
            var PreviousSalaryAmount = parseFloat($('#PreviousSalaryAmount').val() > 0 ? $('#PreviousSalaryAmount').val() : 0.00);
            var OtherAdditionalAmount = parseFloat($('#OtherAdditionalAmount').val() > 0 ? $('#OtherAdditionalAmount').val() : 0.00);
            var VariableAdditionalAmount = parseFloat($('#VariableAdditionalAmount').val() > 0 ? $('#VariableAdditionalAmount').val() : 0.00);
            var VacationSalaryDueAmount = parseFloat($('#VacationSalaryDueAmount').val() > 0 ? $('#VacationSalaryDueAmount').val() : 0.00);

            var TotalDueAmount = CurrentSalaryAmount + PreviousSalaryAmount + OtherAdditionalAmount + VariableAdditionalAmount + VacationSalaryDueAmount;
            $('#TotalDueAmount').val(TotalDueAmount);

            var VariableDeductionAmount = parseFloat($('#VariableDeductionAmount').val() > 0 ? $('#VariableDeductionAmount').val() : 0.00);
            var InsuranceAmount = parseFloat($('#InsuranceAmount').val() > 0 ? $('#InsuranceAmount').val() : 0.00);
            var LoanDueAmount = parseFloat($('#LoanDueAmount').val() > 0 ? $('#LoanDueAmount').val() : 0.00);
            var OtherPenaltyAmount = parseFloat($('#OtherPenaltyAmount').val() > 0 ? $('#OtherPenaltyAmount').val() : 0.00);

            var TotalDeductionAmount = VariableDeductionAmount + InsuranceAmount + LoanDueAmount + OtherPenaltyAmount;
            $('#TotalDeductionAmount').val(TotalDeductionAmount);
            var NetDueAmount = TotalDueAmount - TotalDeductionAmount;
            $('#NetDueAmount').val(NetDueAmount);
        }


        function CalcTotalDutyPeriod(FromDate, ToDate) {
            let Duty_years = ToDate.getFullYear() - FromDate.getFullYear();
            $('#DutyYears').val(Duty_years);
            let Duty_months = (ToDate.getMonth() + 1) - (FromDate.getMonth() + 1);
            $('#DutyMonths').val(Duty_months);
            let Duty_days = (ToDate.getDate() - FromDate.getDate());
            $('#DutyDays').val(Duty_days);
        }

        function CalcTotalVacationWithOutSalary(total) {
            let years = 0;
            let months = 0;
            let days = 0;
            if (total > 30 && total < 365) {
                months = parseInt(total / 30);
                days = total - (months * 30);
            }
            else {
                if (total > 365) {
                    years = parseInt(total / 365);
                    months = parseInt(((total - (years * 365))) / 30);
                    days = total - ((years * 365) + (months * 30));
                }
                else {
                    days = total;
                }
            }
            $('#VacationWithoutSalary_Days').val(days);
            $('#VacationWithoutSalary_Months').val(months);
            $('#VacationWithoutSalary_Years').val(years);
        }

        function CalcEquivalent(total) {
            if (total > 30 && total < 365) {
                months = parseInt(total / 30);
                days = total - (months * 30);
            }
            else {
                if (total > 365) {
                    years = parseInt(total / 365);
                    months = parseInt(((total - (years * 365))) / 30);
                    days = total - ((years * 365) + (months * 30));
                }
                else {
                    days = total;
                }
            }

        }



    //--------- Calculate TotalDueAmount------
    function CalculateTotalDueAmount() {
        var Current = $('#CurrentSalaryAmount').val();
        var Additional = $('#VariableAdditionalAmount').val();
        var SalaryDue = $('#VacationSalaryDueAmount').val();
        var Previous = $('#PreviousSalaryAmount').val();
        var Other = $('#OtherAdditionalAmount').val();
        TotalDueAmount = parseInt(Current) + parseInt(Additional) + parseInt(SalaryDue) + parseInt(Previous) + parseInt(Other);
        $('#TotalDueAmount').val(TotalDueAmount);
    }

    //--------- Calculate TotalDeductionAmount ------
    function CalculateTotalDeductionAmount() {
        var LoanDueAmount = $('#LoanDueAmount ').val();
        var OtherPenaltyAmount = $('#OtherPenaltyAmount ').val();
        var VariableDeductionAmount = $('#VariableDeductionAmount ').val();
        var InsuranceAmount = $('#InsuranceAmount ').val();
        TotalDeductionAmount = parseInt(LoanDueAmount) + parseInt(OtherPenaltyAmount) + parseInt(VariableDeductionAmount) + parseInt(InsuranceAmount);
        $('#TotalDeductionAmount ').val(TotalDeductionAmount);
    }

    //--------- Calculate NetDueAmount ------
    function CalculateNetDueAmount() {
        var TotalDueAmount = $('#TotalDueAmount').val();
        var TotalDeductionAmount = $('#TotalDeductionAmount').val();
        NetDueAmount = parseInt(TotalDueAmount) - parseInt(TotalDeductionAmount);
        $('#NetDueAmount').val(NetDueAmount);

        }

    //--------------------------------------- ADD EDIT---------------------------//
    function addEdit(n) {
        if ($(".form-control:invalid").length > 0) {
            console.log($(".form-control:invalid"));
