            $('html, body').animate({
                scrollTop: $(".form-control:invalid").eq(0).offset().top - 100
            }, 500);
            valid = false;
        }
        else {
            CalculateTotalDueAmount();
            CalculateTotalDeductionAmount();
            CalculateNetDueAmount();
            var EmployeeVacationDueDetails = [];

            $('#Details tr').each(function () {
                var td = $(this);
