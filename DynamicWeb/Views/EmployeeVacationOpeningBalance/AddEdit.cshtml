    function deleteElement(e)
    {
        let tr = $(e).closest('tr');
        if ($(tr).index() == 0 && $(tr).closest('tbody').children('tr').length == 1)
            $(tr).find("input").val('');
        else if ($(tr).index() < $(tr).closest('tbody').children('tr').length - 1)
            e.parentNode.parentNode.parentNode.removeChild(e.parentNode.parentNode);
        else if ($(tr).index() == $(tr).closest('tbody').children('tr').length - 1)
        {
            $(tr).find("input").val('');
            $(tr).find('input, select').removeAttr('required');
            //$(tr).find('select').empty();
        }
        //CalculateTotals();
        //addToSalesInvoiceDetails();
    }

    //-------------------------------------------------------------- add/edit ------------------------------------------//
    function addEdit(n) {
        let valid = true;
        if ($(".form-control:invalid").length > 0) {
            $('.form-horizontal').addClass('was-validated');
            $('html, body').animate({
                scrollTop: $(".form-control:invalid").eq(0).offset().top - 80
            }, 500);
            console.log($(".form-control:invalid"));
            valid = false;
        }

        var EmployeeVacationOpeningBalanceDetails = [];
        if (valid) {
            $('#EmployeeVacationOpeningBalanceDetails tr').each(function () {
                var tr = $(this);
                if (tr.find('.EmployeeId').val() > 0) {
                    var EmployeeVacationOpeningBalanceDetail =
                    {
                        EmployeeId: tr.find('.EmployeeId').val(),
                        MainDocId: $('#Id').val(),
                        StartDate: tr.find('.StartDate').val(),
                        EndDate: tr.find('.EndDate').val(),
                        StartDateHijri: tr.find('.StartDateHijri').text(),
                        EndDateHijri: tr.find('.EndDateHijri').text(),
                        VacationBalance: tr.find('.VacationBalance').val(),
                        VacationWithoutSalary: tr.find('.VacationWithoutSalary').val(),
                        Absence: tr.find('.Absence').val(),
                        IsDeleted: false,
                    };
                    EmployeeVacationOpeningBalanceDetails.push(EmployeeVacationOpeningBalanceDetail);
                }
            });
            valid = EmployeeVacationOpeningBalanceDetails.length > 0 ? true : false;
            valid == false ? Swal.fire({
                title: '@MyERP.Properties.Resources.AllDetailsRequired',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            }) : null;
        }
        if (valid) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.AreYouSureYouWantToSave',
                text: " ",
                icon: 'info',
                showCancelButton: true,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                cancelButtonText: '@MyERP.Properties.Resources.Cancel',
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    $('#preloader, #status').fadeIn();
                    $.ajax({
                        type: "POST", contentType: "application/json",
                        url: "/EmployeeVacationOpeningBalance/AddEdit",
                        data:
                            JSON.stringify({
                                Id: $('#Id').val(),
                                DocumentNumber: $('#DocumentNumber').val(),
                                Date: $('#Date').val(),
                                DepartmentId: $('#DepartmentId').val(),
                                InputMethodId: $('#InputMethods option:selected').val(),
                                Notes: $('#Notes').val(),
                                EmployeeVacationOpeningBalanceDetails: EmployeeVacationOpeningBalanceDetails,
                                IsActive: true,
                                IsDeleted: false,
                            }),
                        success: function (r) {
                            if (r.success == "true") {
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.Saved',
                                    text: " ",
                                    icon: 'success',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                                $('#preloader, #status').fadeOut();
                                if (n == "new") {
                                    window.location.replace("/EmployeeVacationOpeningBalance/AddEdit");
                                }
                                else {
                                    if (n == "report") {
                                        window.open("/Report/EmployeeVacationOpeningBalance/" + r.id);
                                        window.location.replace("/EmployeeVacationOpeningBalance");
                                    }
                                    else {
                                        window.location.replace("/EmployeeVacationOpeningBalance");
                                    }
                                }
                            }
                            else {
                                $('#preloader, #status').fadeOut();
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.NotSaved !',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                            }
                        },
                        error: function (r) {
                            $('#preloader, #status').fadeOut();
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.NotSaved !',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                        }
                    });
                }
                else { result.dismiss; }
            });
        }
    }

    function Delete(id) {
        Swal.fire({
            title: '@MyERP.Properties.Resources.AreYouSureYouWantToDelete',
            text: " ",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: '@MyERP.Properties.Resources.Ok',
            cancelButtonText: '@MyERP.Properties.Resources.Cancel',
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                $('#preloader, #status').fadeIn();
                $.ajax(
                    {
                        url: '/EmployeeVacationOpeningBalance/Delete',
                        type: 'POST',
                        data: {
                            "Id": id,
                        },
                        error: function (e) {
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.DeleteDoesNotSucceeded',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            }); $('#preloader, #status').fadeOut();
                        },
                        success: function (r) {
                            if (r == 'true') {
                                window.location.replace('/EmployeeVacationOpeningBalance');
                            } else
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.DeleteDoesNotSucceeded',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                }); $('#preloader, #status').fadeOut();
                        }
                    });
            }
            else { result.dismiss; }
        });
    }

</script>