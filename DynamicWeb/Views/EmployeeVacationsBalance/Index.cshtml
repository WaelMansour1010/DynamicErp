<script>

    $(document).ready(function () {
        GetEmployeeData();
        setTimeout(() => {
            $('#EmployeeData tr').each(function () {
                let td = $(this);
                if (parseInt(td.closest('tr').find('.OpeningBalanceEG').val())>0) {
                    CalculateRemainingBalance(td);
                }
            });
        }, "2000");
    });

    $(document).on('change', '.OpeningBalanceEG', function () {
        CalculateRemainingBalance($(this));
    });
    $(document).on('change', '.CurrentYearBalanceEG', function () {
        CalculateRemainingBalance($(this));
    });

    function CalculateRemainingBalance(e) {
        let OpeningBalanceEG = parseInt($(e).closest('tr').find('.OpeningBalanceEG').val());
        let CurrentYearBalanceEG = parseInt($(e).closest('tr').find('.CurrentYearBalanceEG').val());
        let PreviousVacationsEG = parseInt($(e).closest('tr').find('.PreviousVacationsEG').val());
        let RemainingBalanceEG = (OpeningBalanceEG + CurrentYearBalanceEG) - PreviousVacationsEG;
        $(e).closest('tr').find('.RemainingBalanceEG').val(RemainingBalanceEG)
    }
    function GetEmployeeData() {
        $('#EmployeeData').empty();
        $('#preloader, #status').fadeIn();

        $.get('/EmployeeVacationsBalance/GetEmployeeData').done(function (r) {
            if (r.length) {
                for (var i = 0; i < r.length; i++) {
                    r[i].OpeningBalanceEG = r[i].OpeningBalanceEG != null ? r[i].OpeningBalanceEG : 0;
                    r[i].CurrentYearBalanceEG = r[i].CurrentYearBalanceEG != null ? r[i].CurrentYearBalanceEG : 0;
                    r[i].PreviousVacationsEG = r[i].PreviousVacationsEG != null ? r[i].PreviousVacationsEG : 0;
                    r[i].RemainingBalanceEG = r[i].RemainingBalanceEG != null ? r[i].RemainingBalanceEG : 0;

                    let tr = '<tr><td><label class="control-label ArName"> ' +
                        r[i].ArName + '</label><input hidden class="EmployeeId" value="' +
                        r[i].Id + '" /></td><td><input class="form-control OpeningBalanceEG" value="' +
                        r[i].OpeningBalanceEG + '" /></td><td><input class="form-control CurrentYearBalanceEG" value="' +
                        r[i].CurrentYearBalanceEG + '" /></td><td><input disabled class="form-control PreviousVacationsEG" value="' +
                        r[i].PreviousVacationsEG + '" /></td><td><input disabled class="form-control RemainingBalanceEG" value="' +
                        r[i].RemainingBalanceEG + '" /></td></tr>';
                    $('#EmployeeData').append(tr);
                }
            }
        });
        $('#preloader, #status').fadeOut();
    }

    function VacationsDeportation() {
        var EmployeeVacationsBalances = [];
        $('#EmployeeData tr').each(function () {
            let td = $(this);
            if (parseInt(td.closest('tr').find('.OpeningBalanceEG').val()) > 0) {
                let RemainingBalanceEG = parseInt(td.closest('tr').find('.RemainingBalanceEG').val());
                td.closest('tr').find('.OpeningBalanceEG').val(RemainingBalanceEG);
                td.closest('tr').find('.PreviousVacationsEG').val(0);

                
                let OpeningBalanceEG = parseInt(td.closest('tr').find('.OpeningBalanceEG').val());
                let CurrentYearBalanceEG = parseInt(td.closest('tr').find('.CurrentYearBalanceEG').val());
                //let VacationsDeportation = OpeningBalanceEG + RemainingBalanceEG;
                RemainingBalanceEG = (OpeningBalanceEG + CurrentYearBalanceEG)
                td.closest('tr').find('.RemainingBalanceEG').val(RemainingBalanceEG);

                var EmployeeVacationsBalance =
                {
                    EmployeeId: td.find('.EmployeeId').val(),
                    OpeningBalanceEG: td.find('.OpeningBalanceEG').val(),
                    CurrentYearBalanceEG: td.find('.CurrentYearBalanceEG').val(),
                    PreviousVacationsEG: td.find('.PreviousVacationsEG').val(),
                    RemainingBalanceEG: td.find('.RemainingBalanceEG').val(),
                    IsDeported: true
                };
                EmployeeVacationsBalances.push(EmployeeVacationsBalance);
            }
        });
        $.ajax({
            type: "POST",
            contentType: "application/json",
            url: "/EmployeeVacationsBalance/Index",
            data: JSON.stringify(EmployeeVacationsBalances),
            success: function (r) {
                if (r.success == "true") {
                    window.location.replace("/EmployeeVacationsBalance");
                }
                else
                    Swal.fire({
                        title: '@MyERP.Properties.Resources.NotSaved !',
                        text: " ",
                        icon: 'error',
                        showCancelButton: false,
                        confirmButtonText: '@MyERP.Properties.Resources.Ok',
                        confirmButtonColor: '#3085d6'
                    }); $('#preloader, #status').fadeOut();
                $('#newbtn').prop('disabled', false);
                $('#save').prop('disabled', false);
            },
            error: function (r) {
                $('#preloader, #status').fadeOut();
                $('#newbtn').prop('disabled', false);
                $('#save').prop('disabled', false);
                Swal.fire({
                    title: '@MyERP.Properties.Resources.NotSaved !',
                    text: " ",
                    icon: 'error',
                    showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    confirmButtonColor: '#3085d6'
                });
            }
        });
    }


        function addEdit(n) {
        if ($(".form-control:invalid").length > 0) {
            console.log($(".form-control:invalid"));
            $('.form-horizontal').addClass('was-validated');
            $('html, body').animate({
                scrollTop: $(".form-control:invalid").eq(0).offset().top - 100
            }, 500);
            valid = false;
        }
        else {
            var EmployeeVacationsBalances = [];
            $('#EmployeeData tr').each(function () {
                let td = $(this);
                var EmployeeVacationsBalance =
                {
                    EmployeeId: td.find('.EmployeeId').val(),
                    OpeningBalanceEG: td.find('.OpeningBalanceEG').val(),
                    CurrentYearBalanceEG: td.find('.CurrentYearBalanceEG').val(),
                    PreviousVacationsEG: td.find('.PreviousVacationsEG').val(),
                    RemainingBalanceEG: td.find('.RemainingBalanceEG').val(),
                };
                EmployeeVacationsBalances.push(EmployeeVacationsBalance);
            });
            Swal.fire({
                title: '@MyERP.Properties.Resources.AreYouSureYouWantToSave',
                text: " ",
                icon: 'info',
                showCancelButton: true,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                cancelButtonText: '@MyERP.Properties.Resources.Cancel',
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    $('#newbtn').prop('disabled', true);
                    $('#save').prop('disabled', true);
                    $('#preloader, #status').fadeIn();
                    $.ajax({
                        type: "POST",
                        contentType: "application/json",
                        url: "/EmployeeVacationsBalance/Index",
                        data: JSON.stringify(EmployeeVacationsBalances),
                        success: function (r) {
                            if (r.success == "true") {
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.Saved',
                                    text: " ",
                                    icon: 'success',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                                    window.location.replace("/EmployeeVacationsBalance");
                            }
                            else
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.NotSaved !',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                }); $('#preloader, #status').fadeOut();
                            $('#newbtn').prop('disabled', false);
                            $('#save').prop('disabled', false);
                        },
                        error: function (r) {
                            $('#preloader, #status').fadeOut();
                            $('#newbtn').prop('disabled', false);
                            $('#save').prop('disabled', false);
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.NotSaved !',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                        }
                    });
                }
                else { result.dismiss; }
            });
        }
    }





