    function CalcTotalServicePeriod(salaryitem) {
        if ($('#EmployeeId').val()) {
            const start = new Date($('#WorkStartDate').val());
            const end = new Date($('#WorkEndDate').val());
            let years = 0;
            let months = 0;
            let days = 0;
            var total = Math.round((end - start) / (1000 * 60 * 60 * 24))
            if (total > 30 && total < 365) {
                months = parseInt(total / 30);
                days = total - (months * 30);
            }
            else {
                if (total > 365) {
                    years = parseInt(total / 365);
                    months = parseInt(((total - (years * 365))) / 30);
                    days = total - ((years * 365) + (months * 30));
                }
                else {
                    days = total;
                }
            }

            $('#Day').val(days);
            $('#Month').val(months);
            $('#Year').val(years);

            var YearSalary = (salaryitem / 2) * ($('#Year').val());
            var MonthSalary = ((salaryitem / 2) / 12) * ($('#Month').val());
            var DaySalary = (((salaryitem / 2) / 12) / 30) * ($('#Day').val());
            var total = YearSalary + MonthSalary + DaySalary;
            var diff = total - parseFloat(salaryitem);
            var currentSalary = $('#RealSalary').val() * (end.getDate());
            $('#CurrentMonthSalaryAmount').val(currentSalary.toFixed(2));
                $('#EndOfServiceDifference').val(diff.toFixed(2));
                $('#TotalEndOfServiceDue').val(total.toFixed(2));

        }
        else {
Swal.fire({
        title: '@MyERP.Properties.Resources.SelectAnEmployee',
        text: " ",
        icon: 'info',
        showCancelButton: false,
        confirmButtonText: '@MyERP.Properties.Resources.Ok',
        confirmButtonColor: '#3085d6'
    });        }
    }
    function CalcNetDues() {
        var totalDeduction = 0;
        var totalDue = 0;
        $('.deduction').each(function () {
            if ($(this).val()) {
                totalDeduction += parseFloat($(this).val());
            }
        });
        $('.due').each(function () {
            if ($(this).val()) {
                totalDue += parseFloat($(this).val());
            }
        });
        $('#TotalDeductions').val(totalDeduction.toFixed(2));
        $('#TotalDues').val(totalDue.toFixed(2));
        var diff = totalDue - totalDeduction;
        $('#NetDues').val(diff.toFixed(2));
    }
    function convertToJavaScriptFullDate(value) {
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        var month = (dt.getMonth() + 1) < 10 ? '0' + (dt.getMonth() + 1) : (dt.getMonth() + 1);
        var day = dt.getDate() < 10 ? '0' + dt.getDate() : dt.getDate();
        var hours = dt.getHours();
        var minutes = dt.getMinutes();
        var seconds = dt.getSeconds();
        var ampm = hours >= 12 ? 'PM' : 'AM';
        hours = hours % 12;
        hours = hours ? hours : 12; // the hour '0' should be '12'
        minutes = minutes < 10 ? '0' + minutes : minutes;
        seconds = seconds < 10 ? '0' + seconds : seconds;
        var strTime = hours + ':' + minutes /*+ ":" + seconds + ' ' + ampm*/;
        //return ((dt.getMonth() + 1 + "/" + dt.getDate() + "/" + dt.getFullYear()) + "T" + strTime);
        return ((dt.getFullYear() + "-" +month + "-" + day )+  "T" + strTime);
    }
    function zeroPadded(val) {
        if (val >= 10)
            return val;
        else
            return '0' + val;
    }

