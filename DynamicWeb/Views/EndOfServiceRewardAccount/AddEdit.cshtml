@model MyERP.Models.EndOfServiceRewardAccount

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.EndOfServiceRewardAccount;
}
<script src="~/js/DeleteFunctionForAddEditView.js"></script>
<script src="~/Scripts/SaveAndNew.js"></script>

@*@Html.AntiForgeryToken()*@
@Html.ValidationSummary(true, "", new { @class = "text-danger" })
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <a class="btn btn-info" href="@Url.Action("Index")" role="button" style="float:left;">@MyERP.Properties.Resources.Back</a>
            </div>
            <div class="hed page-title">  @MyERP.Properties.Resources.EndOfServiceRewardAccount :</div>
        </div>
    </div>
</div>
<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal needs-validation" role="form">
                        @*<form action="/EndOfServiceRewardAccount/AddEdit" class="form-horizontal needs-validation" novalidate method="post" enctype="multipart/form-data">*@
                        @* panal 1 *@
                        <div class="card">
                            <div class="card-body">
                                <div id="accordion">
                                    <h5 class=" pb-3 header-title">
                                        <a data-toggle="collapse" data-parent="#accordion" href="#collapse1">
                                            @MyERP.Properties.Resources.EndOfServiceRewardAccount
                                        </a>
                                    </h5>
                                </div>
                                <div id="collapse1">
                                    <div class="form-group row">
                                        @if (Model != null)
                                        {
                                            @Html.HiddenFor(model => model.Id)
                                            @Html.HiddenFor(model => model.UserId)
                                            @Html.HiddenFor(model => model.Image)
                                            @Html.HiddenFor(model => model.IsDeleted)
                                        }
                                        <label class=" col-sm-2 control-label" for="Id">@MyERP.Properties.Resources.DocNo</label>
                                        <div class="col-sm-4">
                                            @Html.EditorFor(model => model.DocumentNumber, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.DocNo, @readonly = "readonly", required = "required", hidden = "hidden" } })
                                            <input id="DocumentNumbers" class="form-control" placeholder=@MyERP.Properties.Resources.DocNo required readonly />
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>
                                        <label class=" col-sm-2 control-label" for="Sequence">@MyERP.Properties.Resources.Date</label>
                                        <div class="col-sm-4">
                                            @Html.EditorFor(model => model.VoucherDate, new { htmlAttributes = new { @class = "form-control", @type = "datetime-local", required = "required" } })
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class="control-label col-sm-2">@MyERP.Properties.Resources.Department</label>
                                        <div class="col-sm-4">
                                            @Html.DropDownListFor(model => model.DepartmentId, null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", required = "required" })
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>
                                        <label class="control-label col-sm-2">@MyERP.Properties.Resources.Employee</label>
                                        <div class="col-sm-4">
                                            @Html.DropDownListFor(model => model.EmployeeId, null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", required = "required" })
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class="control-label col-sm-2">@MyERP.Properties.Resources.Job</label>
                                        <div class="col-sm-4">
                                            @if (Model != null && Model.JobId > 0)
                                            {
                                                <input hidden id="JobId" required value="@Model.JobId"  />
                                                <input class="form-control" id="JobName" required value="@Model.Job.ArName" />
                                            }
                                            else
                                            {
                                                <input hidden id="JobId" required value="" />
                                                <input class="form-control" id="JobName" required value="" />
                                            }
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>
                                        <label class="control-label col-sm-2">@MyERP.Properties.Resources.EndOfServiceType</label>
                                        <div class="col-sm-4">
                                            @Html.DropDownListFor(model => model.EndOfServiceTypeId, null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", required = "required" })
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label for="ContractStartTime" class="control-label col-sm-2">@MyERP.Properties.Resources.WorkStartingDate</label>
                                        <div class="col-sm-4">
                                            @Html.EditorFor(model => model.WorkStartDate, new { htmlAttributes = new { @class = "form-control", @type = "datetime-local", @required = "required", @disabled = "disabled" } })
                                            @Html.ValidationMessageFor(model => model.WorkStartDate, "", new { @class = "text-danger" })
                                        </div>
                                        <label for="ContractStartTime" class="control-label col-sm-2">@MyERP.Properties.Resources.WorkingEndDate</label>
                                        <div class="col-sm-4">
                                            @Html.EditorFor(model => model.WorkEndDate, new { htmlAttributes = new { @class = "form-control", @type = "datetime-local", @required = "required" } })
                                            @Html.ValidationMessageFor(model => model.WorkEndDate, "", new { @class = "text-danger" })
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class="control-label col-sm-2">@MyERP.Properties.Resources.Terminator</label>
                                        <div class="col-sm-4">
                                            @Html.DropDownListFor(model => model.TerminatorEmployeeId, null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>
                                        <label for="ContractStartTime" class="control-label col-sm-2">@MyERP.Properties.Resources.EmployeeSalaryItems</label>
                                        <div class="col-sm-4">
                                            @Html.EditorFor(model => model.TotalSalaryItems, new { htmlAttributes = new { @class = "form-control", @type = "text",@disabled="disabled" } })
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class="control-label col-sm-2" for="Notes">@MyERP.Properties.Resources.Notes</label>
                                        <div class="col-sm-4">
                                            <textarea id="Notes" name="Notes" class="form-control" rows="2" cols="5">@if (Model != null) { @Model.Notes; }</textarea>
                                        </div>
                                    </div>
                                    <div class="card">
                                        <div class="card-body">
                                            <div class="form-group row">
                                                <label for="ServicePeriod" class="control-label col-sm-1">@MyERP.Properties.Resources.ServicePeriod:</label>
                                                <div class="col-sm-5 row">
                                                    <div class="form-group col-xs-4 col-md-4">
                                                        <label for="Day" class="control-label">@MyERP.Properties.Resources.Day</label>
                                                        @Html.EditorFor(model => model.Day, new { htmlAttributes = new { @class = "form-control", @type = "text",@disabled="disabled" } })
                                                    </div>
                                                    <div class="form-group col-xs-4 col-md-4">
                                                        <label for="Month" class="control-label">@MyERP.Properties.Resources.Month</label>
                                                        @Html.EditorFor(model => model.Month, new { htmlAttributes = new { @class = "form-control", @type = "text",@disabled="disabled" } })
                                                    </div>
                                                    <div class="form-group col-xs-4 col-md-4">
                                                        <label for="Year" class="control-label">@MyERP.Properties.Resources.Year</label>
                                                        @Html.EditorFor(model => model.Year, new { htmlAttributes = new { @class = "form-control", @type = "text",@disabled="disabled" } })
                                                    </div>
                                                </div>
                                                <div class="col-sm-6 row">
                                                    <div class="form-group col-xs-6 col-md-6">
                                                        <label for="ContractStartTime" class="control-label">@MyERP.Properties.Resources.AbsenceDays:</label>
                                                        @Html.EditorFor(model => model.NoOfAbsenceDays, new { htmlAttributes = new { @class = "form-control", @type = "text",@disabled="disabled" } })
                                                    </div>
                                                    <div class="form-group col-xs-6 col-md-6">
                                                        <label for="ContractStartTime" class="control-label">@MyERP.Properties.Resources.NoOfVacationDaysWithoutSalary:</label>
                                                        @Html.EditorFor(model => model.NoOfVacationDaysWithoutSalary, new { htmlAttributes = new { @class = "form-control", @type = "text", @disabled = "disabled" } })
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @* panal 3 *@
                        <div class="card">
                            <div class="card-body">
                                <div id="accordion">
                                    <h5 class=" pb-3 header-title">
                                        <a data-toggle="collapse" data-parent="#accordion" href="#collapse3">
                                            @MyERP.Properties.Resources.EndOfServiceDues
                                        </a>
                                    </h5>
                                </div>
                                <div id="collapse3">
                                    <!-- المستحقات المالية -->
                                    <div class="row">
                                        <div class="col-sm-6">
                                            <div class="card">
                                                <div class="card-body">
                                                    <h5 class="control-label ">
                                                        @MyERP.Properties.Resources.FinancialDues
                                                    </h5>

                                                    <div class="table-responsive">
                                                        <table class="table table-striped table-centered mb-0">
                                                            <thead>
                                                                <tr>
                                                                    <th></th>
                                                                    <th style="text-align: center">
                                                                        @MyERP.Properties.Resources.DueSalaryAmount
                                                                    </th>
                                                            </thead>
                                                            <tbody>
                                                                <tr>
                                                                    <td>
                                                                        <label for="ContractStartTime" class="control-label col-sm-12">@MyERP.Properties.Resources.MonthCurrentSalary</label>
                                                                    </td>
                                                                    <td>
                                                                        @Html.EditorFor(model => model.CurrentMonthSalaryAmount, new { htmlAttributes = new { @class = "form-control due", @type = "text", @disabled = "disabled" } })
                                                                   <input hidden id="RealSalary" />
                                                                    </td>
                                                                </tr>
                                                                <tr>
                                                                    <td>
                                                                        <label for="ContractStartTime" class="control-label col-sm-12">@MyERP.Properties.Resources.TotalEndOfServiceDue</label>
                                                                    </td>
                                                                    <td>
                                                                        @Html.EditorFor(model => model.TotalEndOfServiceDue, new { htmlAttributes = new { @class = "form-control", @type = "text", @disabled = "disabled" } })
                                                                    </td>
                                                                </tr>
                                                                <tr>
                                                                    <td>
                                                                        <label for="ContractStartTime" class="control-label col-sm-12">@MyERP.Properties.Resources.EndOfServiceDifference</label>
                                                                    </td>
                                                                    <td>
                                                                        @Html.EditorFor(model => model.EndOfServiceDifference, new { htmlAttributes = new { @class = "form-control due", @type = "text", @disabled = "disabled" } })
                                                                    </td>
                                                                </tr>
                                                                <tr>
                                                                    <td>
                                                                        <label for="ContractStartTime" class="control-label col-sm-12">@MyERP.Properties.Resources.EndOfServiceAllocation</label>
                                                                    </td>
                                                                    <td>
                                                                        @Html.EditorFor(model => model.EndOfServiceAllocation, new { htmlAttributes = new { @class = "form-control due", @type = "text", @disabled = "disabled" } })
                                                                    </td>
                                                                </tr>
                                                                <tr>
                                                                    <td>
                                                                        <label for="ContractStartTime" class="control-label col-sm-12">@MyERP.Properties.Resources.VacationAllocation</label>
                                                                    </td>
                                                                    <td>
                                                                        @Html.EditorFor(model => model.VacationAllocation, new { htmlAttributes = new { @class = "form-control due", @type = "text", @disabled = "disabled" } })
                                                                    </td>
                                                                </tr>
                                                                <tr>
                                                                    <td>
                                                                        <label for="ContractStartTime" class="control-label col-sm-12">@MyERP.Properties.Resources.TicketAllocation</label>
                                                                    </td>
                                                                    <td>
                                                                        @Html.EditorFor(model => model.TicketAllocation, new { htmlAttributes = new { @class = "form-control due", @type = "text", @disabled = "disabled" } })
                                                                    </td>
                                                                </tr>
                                                                <tr>
                                                                    <td>
                                                                        <label for="ContractStartTime" class="control-label col-sm-12">@MyERP.Properties.Resources.OtherAddition</label>
                                                                    </td>
                                                                    <td>
                                                                        @Html.EditorFor(model => model.OtherAdditional, new { htmlAttributes = new { @class = "form-control due", @type = "text" } })
                                                                    </td>
                                                                </tr>
                                                            </tbody>
                                                        </table>
                                                    </div>

                                                </div>
                                            </div>
                                        </div>

                                        <!-- الاستقطاعات المالية -->
                                        <div class="col-sm-6">
                                            <div class="card">
                                                <div class="card-body">
                                                    <h5 class="control-label">
                                                        @MyERP.Properties.Resources.FinancialDeductions
                                                    </h5>

                                                    <div class="table-responsive">
                                                        <table class="table table-striped table-centered mb-0">
                                                            <thead>
                                                                <tr>
                                                                    <th></th>
                                                                    <th style="text-align: center">
                                                                        @MyERP.Properties.Resources.DueSalaryAmount
                                                                    </th>
                                                            </thead>
                                                            <tbody>
                                                                <tr>
                                                                    <td>
                                                                        <label for="ContractStartTime" class="control-label col-sm-12">@MyERP.Properties.Resources.TotalBorrow</label>
                                                                    </td>
                                                                    <td>
                                                                        @Html.EditorFor(model => model.TotalBorrow, new { htmlAttributes = new { @class = "form-control deduction", @type = "text", @disabled = "disabled" } })
                                                                    </td>
                                                                </tr>
                                                                <tr>
                                                                    <td>
                                                                        <label for="ContractStartTime" class="control-label col-sm-12">@MyERP.Properties.Resources.TotalCustody</label>
                                                                    </td>
                                                                    <td>
                                                                        @Html.EditorFor(model => model.TotalCustody, new { htmlAttributes = new { @class = "form-control deduction", @type = "text", @disabled = "disabled" } })
                                                                    </td>
                                                                </tr>
                                                                <tr>
                                                                    <td>
                                                                        <label for="ContractStartTime" class="control-label col-sm-12">@MyERP.Properties.Resources.OtherDeduction</label>
                                                                    </td>
                                                                    <td>
                                                                        @Html.EditorFor(model => model.OtherDeduction, new { htmlAttributes = new { @class = "form-control deduction", @type = "text" } })
                                                                    </td>
                                                                </tr>
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <!-- اجمالى المستحقات-->
                                    <div class="card">
                                        <div class="card-body">

                                            <div class="form-group row">
                                                <label for="NetDueAmount" class="col-sm-2 control-label">
                                                    @MyERP.Properties.Resources.TotalDues
                                                </label>
                                                <div class="col-sm-4">
                                                    @Html.EditorFor(model => model.TotalDues, new { htmlAttributes = new { @class = "form-control", @type = "text", @disabled = "disabled" } })
                                                </div>
                                                <label for="RecommendedPaymentAmount" class="col-sm-2 control-label">
                                                    @MyERP.Properties.Resources.TotalDeduction
                                                </label>
                                                <div class="col-sm-4">
                                                    @Html.EditorFor(a => a.TotalDeductions, new { htmlAttributes = new { @class = "form-control", @type = "text", @disabled = "disabled" } })
                                                </div>
                                            </div>
                                            <div class="form-group row">

                                                <label for="RecommendedPaymentAmount" class="col-sm-2 control-label">
                                                    @MyERP.Properties.Resources.NetDues
                                                </label>
                                                <div class="col-sm-4">
                                                    @Html.EditorFor(a => a.NetDues, new { htmlAttributes = new { @class = "form-control", @type = "text", @disabled = "disabled" } })
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>

                    @*</form>*@
                </div>
                <!--    Save Buttons      -->
                <div class="card-body">
                    <input id="new" name="newBtn" hidden />
                    <div style="float:right;">
                        <div class="row">
                            <div class="col-sm-offset-2">
                                @if (Model == null)
                                {
                                    <button onclick="addEdit('new')" class="btn btn-success" id="newbtn">
                                        @MyERP.Properties.Resources.SaveAndNew
                                    </button>
                                    <button class="btn btn-success" onclick="addEdit()" id="save">
                                        @MyERP.Properties.Resources.Save
                                    </button>
                                    <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                                }
                                else if (Model.IsDeleted == false)
                                {

                                    <button class="btn btn-success" onclick="addEdit()" id="save">
                                        @MyERP.Properties.Resources.Save
                                    </button>
                                    <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                                    <a href="javascript:void(0);" class="btn btn-danger" onclick="Delete(@Model.Id)" role="button">@MyERP.Properties.Resources.Delete</a>
                                }
                            </div>
                        </div>
                    </div>

                </div>


            </div>
        </div>
    </div>
</div>


<script>
    //--------------- Variables Declarations -------------------//
    //*********************************************************//
    //--------------- Ready Function -------------------//
    $(document).ready(function () {
         $.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
             $("input[type|='datetime-local']").not('#WorkStartDate,#WorkEndDate').prop('min', r.PeriodStart).prop('max', r.PeriodEnd);
        });
        if ($('#Id').val() > 0) {
            $('#VoucherDate').val('@ViewBag.VoucherDate');
            $('#WorkStartDate').val('@ViewBag.WorkStartDate');
            $('#WorkEndDate').val('@ViewBag.WorkEndDate');
            $('#WorkEndDate').prop("disabled",true);
            $('#EmployeeId').prop("disabled", true);
            //$('#EndOfServiceTypeId').prop("disabled", true);
            var code = $('#DocumentNumber').val();
            $('#DocumentNumbers').val(code.replaceAll("-", ""))
            $("#DepartmentId").prop('disabled', true);
            $("#VoucherDate").prop('disabled', true);
        }
        else {
            if ($('#DepartmentId').val()) {
                setDocNum();
            }
            $('#EndOfServiceTypeId').val(5);
            $('#EndOfServiceTypeId').select2();
            var d = new Date();
            $('#VoucherDate').val(d.getFullYear() + "-" + zeroPadded(d.getMonth() + 1) + "-" + zeroPadded(d.getDate()) + "T" + zeroPadded(d.getHours()) + ":" + zeroPadded(d.getMinutes()));
          //  $('#WorkStartDate').val(d.getFullYear() + "-" + zeroPadded(d.getMonth() + 1) + "-" + zeroPadded(d.getDate()) + "T" + zeroPadded(d.getHours()) + ":" + zeroPadded(d.getMinutes()));
            $('#WorkEndDate').val(d.getFullYear() + "-" + zeroPadded(d.getMonth() + 1) + "-" + zeroPadded(d.getDate()) + "T" + zeroPadded(d.getHours()) + ":" + zeroPadded(d.getMinutes()));
        }
    });
    //*********************************************************//
    //--------------- Event Functions -------------------//
    $(document).on('change', '#DepartmentId', function () {
        if ($('#DepartmentId').val()) {
            setDocNum();
        }
    });
    $(document).on('change', '#VoucherDate', function () {
        if ($('#DepartmentId').val()) {
            setDocNum();
        }
    });

    $(document).on('change', '#EmployeeId', function () {
        if ($('#EmployeeId').val()) {
            GetEmployeeContractSalaryItem();
        }
        else {
            $("input").not('#WorkEndDate,#VoucherDate').val('');
            $('select').select2();
        }
    });
    $(document).on('change', '#OtherAdditional,#OtherDeduction', function () {
        CalcNetDues();
    });
    $(document).on('change', '#WorkEndDate', function () {
        CalcTotalServicePeriod($('#TotalSalaryItems').val());
    });
    $(document).on('change', '#EndOfServiceTypeId', function () {
        if ($('#EmployeeId').val() > 0) {
            GetEmployeeContractSalaryItem();
        }
        else {
            Swal.fire({
        title: '@MyERP.Properties.Resources.SelectAnEmployee',
        text: " ",
        icon: 'info',
        showCancelButton: false,
        confirmButtonText: '@MyERP.Properties.Resources.Ok',
        confirmButtonColor: '#3085d6'
    });
        }
    });
    //*********************************************************//
     //--------------- Other Functions -------------------//
    function setDocNum() {
        $.get('/EndOfServiceRewardAccount/SetDocNum?id=' + $('#DepartmentId').val() + '&VoucherDate=' + $('#VoucherDate').val()).done(function (r) {
            $('#DocumentNumber').val(r);
            $('#DocumentNumbers').val(r.replaceAll("-", ""));
        });
    }
    var PrevEndOfServiceEmployees = false;
    function GetEmployeeContractSalaryItem() {
        $.get('/EndOfServiceRewardAccount/GetEmployeeContractSalaryItem?employeeId=' + $('#EmployeeId').val()).done(function (r) {
            $('#preloader, #status').fadeIn();
            PrevEndOfServiceEmployees = r.prev > 0 ? true : false;
            if (PrevEndOfServiceEmployees == true && !$('#Id').val()) {
                Swal.fire({
                    title: '@MyERP.Properties.Resources.TheEmployeeHasAlreadyTerminatedHisService',
                    text: " ",
                    icon: 'info',
                    showCancelButton: true,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    cancelButtonText: '@MyERP.Properties.Resources.Cancel',
                    confirmButtonColor: '#3085d6',
                    cancelButtonColor: '#d33',
                    reverseButtons: true
                }).then((result) => {
                    if (result.isConfirmed) {
                        window.location.replace("/EndOfServiceRewardAccount/AddEdit?id=" + r.prev);
                    }
                    else {
                        result.dismiss;
                        $("input").not('#WorkEndDate,#VoucherDate').val('');
                        $('select').prop('selectedIndex', 0);
                        $('select').select2();
                    }
                });
            }
            else {
                if (r.WorkStartDate == null) {
                    Swal.fire({
        title: '@MyERP.Properties.Resources.ThisEmployeeDoesnotHaveHireDate',
        text: " ",
        icon: 'info',
        showCancelButton: false,
        confirmButtonText: '@MyERP.Properties.Resources.Ok',
        confirmButtonColor: '#3085d6'
    });
                   // window.location.reload();
                    $("input").not('#WorkEndDate,#VoucherDate').val('');
                    $('select').select2();
                }
                else {
                    $('#WorkStartDate').val(r.WorkStartDate);
                   // $('#WorkStartDate').val(convertToJavaScriptFullDate(r.WorkStartDate));
                    $('#NoOfAbsenceDays').val(r.NoOfAbsenceDays);
                    $('#NoOfVacationDaysWithoutSalary').val(r.VacationWithoutSalaryDay);
                    $('#TotalVacationWithoutSalary').val(r.VacationWithoutSalaryDay);
                    $('#RealSalary').val(r.CurrentSalaryAmount);
                    $('#TotalSalaryItems').val(r.employeeSalaryItem.toFixed(2));
                    $('#CurrentMonthSalaryAmount').val((r.CurrentSalaryAmount * (new Date($('#WorkEndDate').val())).getDate()).toFixed(2));

                    if ($('#EndOfServiceTypeId').val() == 4) {
                        $('#EndOfServiceAllocation').val((parseFloat(r.endOfServiceAllocationDue) / 3).toFixed(2));
                        $('#VacationAllocation').val((parseFloat(r.vacationAllocationDue) / 3).toFixed(2));
                        $('#TicketAllocation').val((parseFloat(r.ticketAllocationDue) / 3).toFixed(2));
                        $('#TotalBorrow').val((parseFloat(r.TotalBorrow) / 3).toFixed(2));
                        $('#TotalCustody').val((parseFloat(r.TotalCustody) / 3).toFixed(2));
                    } else {
                        $('#EndOfServiceAllocation').val(parseFloat(r.endOfServiceAllocationDue).toFixed(2));
                        $('#VacationAllocation').val(parseFloat(r.vacationAllocationDue).toFixed(2));
                        $('#TicketAllocation').val(parseFloat(r.ticketAllocationDue).toFixed(2));
                        $('#TotalBorrow').val(parseFloat(r.TotalBorrow).toFixed(2));
                        $('#TotalCustody').val(parseFloat(r.TotalCustody).toFixed(2));
                    }

                    if (r.EmployeeJob.length > 0) {
                        $('#JobId').val(r.EmployeeJob[0].Id);
