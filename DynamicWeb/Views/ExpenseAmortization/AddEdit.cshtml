                                                {
                                                    if (item.Debit > 0 || item.Credit > 0)
                                                    {
                                                        <tr>
                                                            <td>@item.Debit</td>
                                                            <td>@item.Credit</td>
                                                            <td>
                                                                @Html.Raw(item.ChartOfAccount != null ? item.ChartOfAccount.ArName : null)
                                                                <input type="hidden" class="JournalAccountId" value="@item.AccountId" />
                                                            </td>
                                                            <td>
                                                                @Html.Raw(item.CostCenter != null ? item.CostCenter.ArName : null)
                                                            </td>
                                                        </tr>
                                                    }
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

        </div>
    </div>
</div>

<script>
//--------------- Variables Declarations -------------------//

//*********************************************************//
//--------------- Ready Function -------------------//
    $(document).ready(function () {
        $('#VoucherDate').val('@ViewBag.VoucherDate');
        $('#StartDate').val('@ViewBag.StartDate');
        $('#EndDate').val('@ViewBag.EndDate');

        if ($('#IsAllDepartmentsSelected').prop('checked') == true) {
            $('#DepartmentId').prop('selectedIndex', 0).select2();
            $('#DepartmentId').prop('disabled', true);
        }
        else {
            $('#DepartmentId').prop('disabled', false);
        }

        $.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
            $("input[type|='datetime-local']").not('#FromDate,#ToDate').prop('min', r.PeriodStart).prop('max', r.PeriodEnd);
        });
        if ($('#Id').val() > 0) {
            var code = $('#DocumentNumber').val();
            $('#DocumentNumbers').val(code.replaceAll("-", ""))
        }
        else {
            setDocNum();
        }
    });
//*********************************************************//

    //--------------- Event Functions -------------------//
    $(document).on('change', '#IsAllDepartmentsSelected', function () {
        if ($('#IsAllDepartmentsSelected').prop('checked') == true) {
            $('#DepartmentId').prop('selectedIndex', 0).select2();
            $('#DepartmentId').prop('disabled', true);
        }
        else {
            $('#DepartmentId').prop('disabled', false);
        }
    });
    //*********************************************************//
     //--------------- Other Functions -------------------//
    function setDocNum() {
        $.get('/ExpenseAmortization/SetDocNum').done(function (r) {
            $('#DocumentNumber').val(r);
        });
    }
    function deleteElement(e) {
        let tr = $(e).closest('tr');
        e.parentNode.parentNode.parentNode.removeChild(e.parentNode.parentNode);
        //if ($(tr).index() == 0 && $(tr).closest('tbody').children('tr').length == 1) {
        //    $(tr).find("input").val('');
        //    $(tr).find("label").text('');
        //    $(tr).find('input, select').removeAttr('required');
        //    $(tr).find('select').empty();
        //    $(tr).find('.Add-Button').prop('hidden', false);
        //    $(tr).find('.popupCell').attr('onclick', 'showSearchModal()');
        //}
        //else if ($(tr).index() < $(tr).closest('tbody').children('tr').length - 1)
        //    e.parentNode.parentNode.parentNode.removeChild(e.parentNode.parentNode);
        //else if ($(tr).index() == $(tr).closest('tbody').children('tr').length - 1) {
        //    $(tr).find("input").val('');
        //    $(tr).find('input, select').removeAttr('required');
        //    $(tr).find('select').empty();
        //    $(tr).find("label").text('');
        //    $(tr).find('.Add-Button').prop('hidden', false);
        //    $(tr).find('.popupCell').attr('onclick', 'showSearchModal()');
        //}
    }
    function convertToJavaScriptDate(value) {
        if (value === null)
            return null;
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        var month = (dt.getMonth() + 1) < 10 ? '0' + (dt.getMonth() + 1) : (dt.getMonth() + 1);
        var day = dt.getDate() < 10 ? '0' + dt.getDate() : dt.getDate();
        var hours = dt.getHours();
        var minutes = dt.getMinutes();
        var seconds = dt.getSeconds();
        var ampm = hours >= 12 ? 'PM' : 'AM';
        hours = hours % 12;
        hours = hours ? hours : 12; // the hour '0' should be '12'
        hours = hours < 10 ? '0' + hours : hours;
        minutes = minutes < 10 ? '0' + minutes : minutes;
        seconds = seconds < 10 ? '0' + seconds : seconds;
        var strTime = hours + ':' + minutes /*+ ":" + seconds + ' ' + ampm*/;
        return ((dt.getFullYear() + "-" + month + "-" + day) /*+ "T" + strTime*/);
    }
    function zeroPadded(val) {
        if (val >= 10)
            return val;
        else
            return '0' + val;
    }
    function GetUnSelectedExpenseAmortization() {
        $('#PrepaidExpenseDetails').empty();
        $.get('/ExpenseAmortization/GetUnSelectedExpenseAmortization?Month=' + $('#Month').val() + '&Year=' + $('#Year').val() + '&DepartmentId=' + $('#DepartmentId').val()).done(function (r) {
            if (r.length) {
                for (var i = 0; i < r.length; i++) {
                    r[i].IsSelectedAmortization = "";// r[i].IsSelectedAmortization == true ? "checked" : "";
                    r[i].FromDate = r[i].FromDate != null ? convertToJavaScriptDate(r[i].FromDate) : "";
                    r[i].ToDate = r[i].ToDate != null ? convertToJavaScriptDate(r[i].ToDate) : "";
                    r[i].IsSelectedProof = r[i].IsSelectedProof == true ? "checked" : "";
                    let tr = '<tr><td class="tabledit-edit-mode" hidden><input type="text" class="Id form-control tabledit-input form-control-sm" value="' +
                        r[i].Id + '" hidden /><input type="text" class="MainDocId form-control tabledit-input form-control-sm" value="' +
                        r[i].MainDocId + '" hidden /><input type="text" class="ExpenseAmortizationId form-control tabledit-input form-control-sm" value="' +
                        r[i].ExpenseAmortizationId + '" hidden /><input type="text" class="ExpenseProofId form-control tabledit-input form-control-sm" value="' +
