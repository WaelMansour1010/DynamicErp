                                                            <div class="invalid-feedback">
                                                                @MyERP.Properties.Resources.Required
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="form-group row">
                                                        <label for="DepartmentId" class="control-label col-sm-2">@MyERP.Properties.Resources.Department</label>
                                                        <div class="col-sm-4">
                                                            @Html.DropDownList("DepartmentId", null, MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })
                                                            <div class="invalid-feedback">
                                                                @MyERP.Properties.Resources.Required
                                                            </div>
                                                        </div>
                                                        <div class="col-sm-1">
                                                            <input type="checkbox" id="IsAllDepartmentsSelected" @(Model != null && Model.IsAllDepartmentsSelected == true ? "checked" : Model == null ? "checked" : "") />
                                                        </div>
                                                        <label for="IsAllDepartmentsSelected" class="control-label col-sm-2">@MyERP.Properties.Resources.AllDepartments</label>
                                                    </div>
                                                    <div class="form-group row">
                                                        <label for="Month" class="control-label col-sm-2">@MyERP.Properties.Resources.Month</label>
                                                        <div class="col-sm-4">
                                                            @Html.DropDownList("Month", null, MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })
                                                            <div class="invalid-feedback">
                                                                @MyERP.Properties.Resources.Required
                                                            </div>
                                                        </div>
                                                        <label for="Year" class="control-label col-sm-2">@MyERP.Properties.Resources.Year</label>
                                                        <div class="col-sm-4">
                                                            @Html.DropDownList("Year", null, MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })
                                                            <div class="invalid-feedback">
                                                                @MyERP.Properties.Resources.Required
                                                            </div>
                                                        </div>
                                                    </div>
                                                    @*<div class="form-group row">
                                                        <label class="control-label col-sm-2">@MyERP.Properties.Resources.StartDate</label>
                                                        <div class="col-sm-4">
                                                            @Html.EditorFor(model => model.StartDate, new { htmlAttributes = new { @class = "form-control Gregorian", @type = "datetime-local", @required = "required" } })
                                                            <div class="invalid-feedback">
                                                                @MyERP.Properties.Resources.Required
                                                            </div>
                                                        </div>
                                                        <label class="control-label col-sm-2">@MyERP.Properties.Resources.EndDate</label>
                                                        <div class="col-sm-4">
                                                            @Html.EditorFor(model => model.EndDate, new { htmlAttributes = new { @class = "form-control Gregorian", @type = "datetime-local", @required = "required" } })
                                                            <div class="invalid-feedback">
                                                                @MyERP.Properties.Resources.Required
                                                            </div>
                                                        </div>
                                                    </div>*@
                                                    <div class="form-group row">
                                                        <label class="control-label col-sm-2" for="Notes">@MyERP.Properties.Resources.Notes</label>
                                                        <div class="col-sm-4">
                                                            <textarea id="Notes" name="Notes" class="form-control" rows="3" cols="3">@if (Model != null) { @Model.Notes; }</textarea>
                                                        </div>
