                                                                        <input type="text" class="TotalValue form-control tabledit-input form-control-sm" value="@item.Value" hidden />
                                                                        <label class="TotalValueTxt control-label control-label">
                                                                            @item.Value
                                                                        </label>
                                                                    </td>
                                                                    <td class="tabledit-edit-mode">
                                                                        <input type="text" class="CostCenterId form-control tabledit-input form-control-sm" value="@item.CostCenterId" hidden />
                                                                        <label class="CostCenterCode control-label control-label">
                                                                            @(item.CostCenter!=null?item.CostCenter.Code:"")
                                                                        </label>
                                                                    </td>
                                                                    <td class="tabledit-edit-mode">
                                                                        <label class="CostCenterName control-label control-label">
                                                                            @(item.CostCenter!=null?item.CostCenter.ArName:"")
                                                                        </label>
                                                                    </td>
                                                                    <td class="tabledit-edit-mode">
                                                                        <input type="text" class="ProjectId form-control tabledit-input form-control-sm" value="@item.ProjectId" hidden />
                                                                        <label class="ProjectCode control-label control-label">
                                                                            @(item.Project!=null?item.Project.Code:"")
                                                                        </label>
                                                                    </td>
                                                                    <td class="tabledit-edit-mode">
                                                                        <label class="ProjectName control-label control-label">
                                                                            @(item.Project!=null?item.Project.ArName:"")
                                                                        </label>
                                                                    </td>
                                                                </tr>
                                                            }
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                            <!------------------------------------------------------------------------------------>                                           
                                        </div>
                                        
                                    </div>
                                </div>
                                @* Panel 2 *@
                                <div class="card">
                                    <div class="card-body">
                                        <div id="accordion">
                                            <h5 class=" pb-3 header-title">
                                                <a data-toggle="collapse" data-parent="#accordion" href="#collapse2">
                                                    @MyERP.Properties.Resources.ExpenseAmortizationDistribution
                                                </a>
                                            </h5>
                                        </div>
                                        <div id="collapse2">
                                            <div class="card">
                                                <div class="card-body">

                                                    <!--Details Table-->
                                                    <div class="row">
                                                        <div class="col-12">
                                                            <div class="form-horizontal needs-validation" role="form">
                                                                <div class="card">
                                                                    <div class="card-body">
                                                                        <div class="header-title">
                                                                            @MyERP.Properties.Resources.ExpenseAmortizationDistribution
                                                                        </div>
                                                                        <div class="table-responsive">
                                                                            <table class="table table-centered mb-0">
                                                                                <thead>
                                                                                    <tr>
                                                                                        <td>
                                                                                            @MyERP.Properties.Resources.Month
                                                                                        </td>
                                                                                        <td>
                                                                                            @MyERP.Properties.Resources.Value
                                                                                        </td>
                                                                                        <td>
                                                                                            @MyERP.Properties.Resources.Choose
                                                                                        </td>
                                                                                    </tr>
                                                                                </thead>
                                                                                <tbody id="ExpenseAmortizationDistributions">
                                                                                    @if (Model != null && Model.ExpenseAmortizationDistributions != null )
                                                                                    {
                                                                                        foreach (var item in Model.ExpenseAmortizationDistributions)
                                                                                        {
                                                                                            <tr>
                                                                                                <td class="tabledit-edit-mode" hidden>
                                                                                                    <input class="PrepaidExpenseDetailId" value="@item.PrepaidExpenseDetailId" />
                                                                                                    <input class="ExpenseAmortizationId" value="@item.ExpenseAmortizationId" />
                                                                                                </td>
                                                                                                <td class="tabledit-edit-mode">
                                                                                                    <input type="text" class="Month form-control tabledit-input form-control-sm" value="@item.Month" disabled readonly />
                                                                                                </td>
                                                                                                <td class="tabledit-edit-mode">
                                                                                                    <input type="number" step="any" class="Value form-control tabledit-input form-control-sm" value="@item.Value" disabled readonly />
                                                                                                </td>
                                                                                                <td class="tabledit-edit-mode">
                                                                                                    <input type="checkbox" class="IsSelectedAmortizationDistribution" @(item.IsSelectedAmortization == true ? "checked disabled" : "") />
                                                                                                </td>
                                                                                            </tr>
                                                                                        }
                                                                                    }

                                                                                </tbody>
                                                                            </table>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <!--End Of Details Table-->
                                                </div>
                                            </div>
                                        </div>
                                        
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!---------------------------------------------- Saves Buttons ----------------------------------------------------------->
            <div class="row">
                <div class="col-sm-offset-2">
                    @if (Model == null)
                    {
                        <button onclick="addEdit('new');" class="btn btn-success" id="newbtn">
                            @MyERP.Properties.Resources.SaveAndNew
                        </button>
                        <button onclick="addEdit();" class="btn btn-success" id="save">
                            @MyERP.Properties.Resources.Save
                        </button>
                        <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                    }
                    else if (Model.IsDeleted == false)
                    {
                        <button onclick="addEdit();" class="btn btn-success" id="save">
                            @MyERP.Properties.Resources.Save
                        </button>
                        <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                        <a href="javascript:void(0);" class="btn btn-danger" onclick="Delete(@Model.Id)" role="button">@MyERP.Properties.Resources.Delete</a>
                    }
                </div>
            </div>
            <!----------------------------------------------------------------------------------------------------------------------------------------->
            @if (Model != null && ViewBag.Journal != null)
            {
                <div class="card">
                    <div class="card-body">
                        <h5 class="header-title">@MyERP.Properties.Resources.JournalEntry</h5>
                        <div class="form-horizontal">
                            <div class="form-group row">
                                <label for="JournalDocNo" class="col-sm-1 control-label">@MyERP.Properties.Resources.JournalEntrieNo</label>
                                <div class="col-sm-5">
                                    <input type="text" class="form-control" name="JournalDocNo" value="@ViewBag.JournalDocumentNumber" id="JournalDocNo" placeholder=@MyERP.Properties.Resources.JournalEntrieNo readonly>

                                </div>
                                <label for="JournalDate" class="col-sm-1 control-label">@MyERP.Properties.Resources.Date </label>
                                <div class="col-sm-5">
                                    <input type="datetime-local" class="form-control" name="JournalDate" value="@ViewBag.VoucherDate" id="JournalDate" placeholder=@MyERP.Properties.Resources.Date readonly>

                                </div>
                            </div>
                            <div class="form-group row">
                                <label for="JournalNotes" class="col-sm-1 control-label">@MyERP.Properties.Resources.Notes</label>
                                <div class="col-sm-5">
                                    <textarea class="form-control" id="JournalNotes" value="@ViewBag.Journal.Notes" readonly name="JournalNotes" placeholder=@MyERP.Properties.Resources.Notes></textarea>
                                </div>

                                @*<label for="JournalIsPosted" class="col-sm-1 control-label">@MyERP.Properties.Resources.Posted</label>
                            <div class="col-sm-5">
                                <input type="checkbox" id="JournalIsPosted" name="JournalIsPosted" disabled @Html.Raw(Model.IsPosted == true ? "checked" : null)>

                            </div>*@
                            </div>
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="header-title"> @MyERP.Properties.Resources.JournalEntryDetails</h5>
                                    <div class="table-responsive">
                                        <table class="table table-centered mb-0">
                                            <thead>
                                                <tr>
                                                    <th>@MyERP.Properties.Resources.Debit</th>
                                                    <th>@MyERP.Properties.Resources.Credit</th>
                                                    <th>@MyERP.Properties.Resources.Account</th>
                                                    <th> @MyERP.Properties.Resources.CostCenter</th>
                                                </tr>
                                            </thead>
                                            <tbody id="JournalEntryDetails-tbody">
