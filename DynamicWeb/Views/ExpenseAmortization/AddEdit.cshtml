                                                                    <td class="tabledit-edit-mode">
                                                                        <input type="text" class="DepartmentId form-control tabledit-input form-control-sm" value="@item.DepartmentId" hidden />
                                                                        <label class="DepartmentName control-label control-label">
                                                                            @item.Department.ArName
                                                                        </label>
                                                                    </td>
                                                                    <td class="tabledit-edit-mode">
                                                                        <input type="text" class="ExpenseTypeId form-control tabledit-input form-control-sm" value="@item.ExpenseTypeId" hidden />
                                                                        <label class="ExpenseTypeName control-label control-label">
                                                                            @(item.ExpenseTypeId==1? "موظف" : "حساب")
                                                                        </label>
                                                                    </td>
                                                                    <td class="tabledit-edit-mode">
                                                                        <input type="text" class="ExpenseAccountId form-control tabledit-input form-control-sm" value="@item.ExpenseAccountId" hidden />
                                                                        <label class="ExpenseAccountName control-label control-label">
                                                                            @item.ChartOfAccount.ArName
                                                                        </label>
                                                                    </td>
                                                                    <td class="tabledit-edit-mode">
                                                                        <input type="text" class="PrePaymentAccountId form-control tabledit-input form-control-sm" value="@item.PrePaymentAccountId" hidden />
                                                                        <label class="PrePaymentAccountName control-label control-label">
                                                                            @item.ChartOfAccount1.ArName
                                                                        </label>
                                                                    </td>
                                                                    <td class="tabledit-edit-mode">
                                                                        <input type="text" class="Value form-control tabledit-input form-control-sm" value="@item.Value" hidden />
