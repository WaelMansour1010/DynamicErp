    $(document).on('change', '.IsSelectedAmortization', function () {
        var PrepaidExpenseDetailId = $(this).closest('tr').find('.Id').val();

        if ($(this).prop('checked') == true) {
            CalculateDistributionValue(this);
        }
        else {
            $('#ExpenseAmortizationDistributions tr').each(function () {
                if ($(this).find('.PrepaidExpenseDetailId').val() == PrepaidExpenseDetailId)
                $(this).closest('tr').remove();
            });
        }
    });


    function CalculateDistributionValue(e) {
        $('#preloader, #status').fadeIn();
        var PrepaidExpenseDetailId = $(e).closest('tr').find('.Id').val();

        $.get('/ExpenseAmortization/GetDistributionDetails?PrepaidExpenseDetailId=' + PrepaidExpenseDetailId).done(function (r) {
            if (r.length) {
                for (var i = 0; i < r.length; i++) {
                    r[i].IsSelectedAmortization = r[i].IsSelectedAmortization == true ? "checked disabled" : "";
                    r[i].ExpenseAmortizationId = r[i].ExpenseAmortizationId != null ? r[i].ExpenseAmortizationId : null;
                    let tr = '<tr><td class="tabledit-edit-mode" hidden><input class="PrepaidExpenseDetailId" value="' +
                        r[i].PrepaidExpenseDetailId + '" /><input class="ExpenseAmortizationId" value="' + r[i].ExpenseAmortizationId+'" /></td><td class="tabledit-edit-mode"><input type = "text" class="Month form-control tabledit-input form-control-sm" value = "' +
                        r[i].Month + '" disabled readonly /></td><td class="tabledit-edit-mode"><input type="number" step="any" class="Value form-control tabledit-input form-control-sm" value="' +
                        r[i].Value + '" disabled readonly /></td><td class="tabledit-edit-mode"><input type="checkbox" class="IsSelectedAmortizationDistribution"' + r[i].IsSelectedAmortization+' /></td></tr>';
                    $('#ExpenseAmortizationDistributions').append(tr);
                }
            }
            else {
                var Value = $(e).closest('tr').find('.Value').val();
                var FromDate = $(e).closest('tr').find('.FromDate').val();
                var ToDate = $(e).closest('tr').find('.ToDate').val();
                const monthDiff = (d1, d2) => {
                    let months;
                    months = (d2.getFullYear() - d1.getFullYear()) * 12;
                    months -= d1.getMonth();
                    months += d2.getMonth();
                    return months <= 0 ? 0 + 1 : parseInt(months) + 1;
                }
                const start = new Date(FromDate);
                const end = new Date(ToDate);
                var diff = monthDiff(start, end);
                var NoOfDaysBetweenDates = Math.floor((end.getTime() - start.getTime()) / 86400000);
                var currentDate = new Date(start.getTime())
                var between = [];

                while (currentDate <= end) {
                    //var res = new Date(currentDate).getDate() + "/" + (parseInt( new Date(currentDate).getMonth()) + 1 )+ "/" + new Date(currentDate).getFullYear();

                    if (between.length > 0 && between.length != parseInt(diff) - 1) {
                        currentDate.setDate(1);
                    }
                    else {
                        if (between.length == 0) {
                            currentDate.setDate(currentDate.getDate());
                        }
                        else {
                            currentDate.setDate(end.getDate());
                        }
                    }
                    between.push(new Date(currentDate));
                    currentDate.setMonth(currentDate.getMonth() + 1);
                }
                for (var i = 0; i < between.length; i++) {
                    const getDays = (year, month) => new Date(year, month + 1, 0).getDate()
                    var DaysOfMonth = getDays(between[i].getFullYear(), between[i].getMonth());
                    var ValuePerDay = Value / NoOfDaysBetweenDates;
                    var TotalValue = 0;
                    if (between.length == 1) {
                        TotalValue = parseFloat(Value);
                    }
                    else {
                        if (between[i].getDate() == 1) {//1/1/2023
                            TotalValue = ValuePerDay * DaysOfMonth;
                        }
                        else if (DaysOfMonth - (between[i].getDate()) != 0) {//10/1/2023
                            TotalValue = ValuePerDay * (DaysOfMonth - (between[i].getDate()));
                        }
                        else {
                            TotalValue = ValuePerDay * DaysOfMonth;
                        }
                    }

                    let Month = parseInt(between[i].getMonth()) + 1;
                    let tr = '<tr><td class="tabledit-edit-mode" hidden><input class="PrepaidExpenseDetailId" value="' +
                        PrepaidExpenseDetailId + '" /><input class="ExpenseAmortizationId" /></td><td class="tabledit-edit-mode"><input type = "text" class="Month form-control tabledit-input form-control-sm" value = "' +
                        Month + '" disabled readonly /></td><td class="tabledit-edit-mode"><input type="number" step="any" class="Value form-control tabledit-input form-control-sm" value="' +
                        TotalValue.toFixed(2) + '" disabled readonly /></td><td class="tabledit-edit-mode"><input type="checkbox" class="IsSelectedAmortizationDistribution" /></td></tr>';
                    $('#ExpenseAmortizationDistributions').append(tr);
                }
            }
        });
        $('#preloader, #status').fadeOut();
    }
