                                                                @MyERP.Properties.Resources.Search
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <!-------------- PrepaidExpenseDetails Table ---------------->
                                            <div class="table-responsive">
                                                <table class="table table-centered mb-0">
                                                    <thead>
                                                        <tr>
                                                            <td>
                                                                @MyERP.Properties.Resources.Choose
                                                            </td>
                                                            <td>
                                                                @MyERP.Properties.Resources.Name
                                                            </td>
                                                            <td>
