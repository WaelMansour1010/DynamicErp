                                                        {
                                                            foreach (var item in Model.PrepaidExpenseDetails)
                                                            {
                                                                <tr>
                                                                    <td class="tabledit-edit-mode" hidden>
                                                                        <input type="text" class="Id form-control tabledit-input form-control-sm" value="@item.Id" hidden />
                                                                        <input type="text" class="MainDocId form-control tabledit-input form-control-sm" value="@item.MainDocId" hidden />
