                                                            </td>
                                                            <td>
                                                                @MyERP.Properties.Resources.ProjectCode
                                                            </td>
                                                            <td>
                                                                @MyERP.Properties.Resources.ProjectName
                                                            </td>
                                                        </tr>
                                                    </thead>
                                                    <tbody id="PrepaidExpenseDetails">
