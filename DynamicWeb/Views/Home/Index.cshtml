    function addEdit(n, id) {

        let valid = true;

        if ($(".form-control:invalid").length > 0) {
            $('.form-horizontal').addClass('was-validated');
            $('html, body').animate({
                scrollTop: $(".form-control:invalid").eq(0).offset().top - 80
            }, 500);
            console.log($(".form-control:invalid"));
            valid = id > 0 ? true : false;
        }

        if (valid && confirm('@MyERP.Properties.Resources.AreYouSureYouWantToSave')) {
            // $('#preloader, #status').fadeIn();

            $.ajax({
                type: "POST", contentType: "application/json",
                url: "/UserTask/AddEdit",
                data:
                    JSON.stringify({
                        Id: id > 0 ? id : 0,
                        Code: $('#Code').val(),
                        CreatedDate: $('#CreatedDate').val(),
                        ArName: id > 0 ? $('#ArNameEdit').val() : $('#ArName').val(),
                        AssignedTo: id > 0 ? $('#ErpUser').val() : $('#ErpUsers').val(),
                        StatusId: id > 0 ? $('#Status').val() : 1, //قيد الانتظار
                        Notes: id > 0 ? $('#Note').val() : $('#Notes').val(),
                        IsDeleted: false,
                    }),
                success: function (r) {
                    if (r.success == "true") {
                        alert("@MyERP.Properties.Resources.Saved");
                        $('#NewTask').hide();
                        $('.modal-backdrop.show').css("opacity", "0"); //عشان احل مشكلة ال fadein
                        //   $('#preloader, #status').fadeOut();
                        Refresh(n); // بيفضل faded !!
                        window.location.replace('/Home');
                    }
                    else {
                        //  $('#preloader, #status').fadeOut();
                        alert("@MyERP.Properties.Resources.NotSaved");
                    }
                },
                error: function (r) {
                    //$('#preloader, #status').fadeOut();
                        alert("@MyERP.Properties.Resources.NotSaved");
                }
            });
        }
    }

