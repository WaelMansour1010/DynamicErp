    //--------- for date Converting -------
    function convertToJavaScriptDate(value) {
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));

        var hours = dt.getHours();
        var minutes = dt.getMinutes();
        var seconds = dt.getSeconds();
        var ampm = hours >= 12 ? 'PM' : 'AM';
        hours = hours % 12;
        hours = hours ? hours : 12; // the hour '0' should be '12'
        minutes = minutes < 10 ? '0' + minutes : minutes;
        seconds = seconds < 10 ? '0' + seconds : seconds;
        var strTime = hours + ':' + minutes + ":" + seconds + ' ' + ampm;
        return ((dt.getMonth() + 1 + "/" + dt.getDate() + "/" + dt.getFullYear()) + " " + strTime);
    }

    //------------ Add Task to Drow DropDown of PopUp + -------------
    function AddTask(taskStatusId, s) {
        //-- For ErpUsers in PopUp
        $('#ErpUsers').empty();
        //--  $('#ErpUsers').append('<option value="0"> اختر المستخدم </option>');
        for (var e = 0; e < ERPUsers.length; e++) {
            $('#ErpUsers').append($('<option>', {
                value: ERPUsers[e].Id,
                text: ERPUsers[e].UserName
            }));
        }

        //-- For Status in <<<another>>> PopUp
        $('#Status').empty();
        //--  $('#Status').append('<option value="0"> اختر الحالة </option>');
        for (var t = 0; t < TaskStatus.length; t++) {
            // console.log(TaskStatus[t].Id,"TaskStatus[t].Id")

            if (TaskStatus[t].Id == taskStatusId) {
                var option = '<option selected value="' + taskStatusId + '">' + TaskStatus[t].ArName + '</option>';
                $('#Status').append(option);
                //$('#Status').append($('<option selected>', {
                //    value: TaskStatus[t].Id,
                //    text: TaskStatus[t].ArName
                //}));
            }
            else {
                if (s == "TO" && TaskStatus[t].Id != 6) {
                    $('#Status').append($('<option>', {
                        value: TaskStatus[t].Id,
                        text: TaskStatus[t].ArName
                    }));
                }
                else if (s == "BY") {
                    $('#Status').append($('<option>', {
                        value: TaskStatus[t].Id,
                        text: TaskStatus[t].ArName
                    }));
                }

            }
        }

        // For ErpUser in  <<<another>>> PopUp
        $('#ErpUser').empty();
        //--  $('#ErpUser').append('<option value="0"> اختر المستخدم </option>');
        for (var e = 0; e < ERPUsers.length; e++) {
            $('#ErpUser').append($('<option>', {
                value: ERPUsers[e].Id,
                text: ERPUsers[e].UserName
            }));
        }
    }

