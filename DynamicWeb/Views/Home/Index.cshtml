                                                else if (item.StatusId == 2)
                                                {
                                                    <span class="badge badge-light-primary">
                                                        @item.TaskStatu.ArName
                                                    </span>
                                                }
                                                else if (item.StatusId == 3)
                                                {
                                                    <span class="badge badge-light-secondary">
                                                        @item.TaskStatu.ArName
                                                    </span>
                                                }
                                                else if (item.StatusId == 4)
                                                {
                                                    <span class="badge badge-light-success">
                                                        @item.TaskStatu.ArName
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-light-danger">
                                                        @item.TaskStatu.ArName
                                                    </span>
                                                }

                                            </td>
                                            <td>
                                                @item.ERPUser.UserName
                                            </td>

                                            <td>
                                                @item.CreatedDate
                                            </td>
                                            @if (item.SystemPage != null)
                                            {
                                                <td>
                                                    <a href="javascript: void(0);" data-toggle="modal" data-target="#ShowTask" onclick="ShowTaskDetails(this,'BY','@item.SystemPage.ControllerName' ,@item.SelectedId)"><i class="mdi mdi-eye"></i></a>
                                                </td>
                                            }
                                            else
                                            {
                                                <td>
                                                    <a href="javascript: void(0);" data-toggle="modal" data-target="#ShowTask" onclick="ShowTaskDetails(this,'BY','' ,@item.SelectedId)"><i class="mdi mdi-eye"></i></a>
                                                </td>
                                            }


                                            @*  <td>
                                                    <div class="btn-group dropleft">
                                                        <a href="#" class="dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                                            <i class="mdi mdi-dots-horizontal"></i>
                                                        </a>
                                                        <div class="dropdown-menu">
                                                            <!-- Dropdown menu links -->
                                                            @if (ViewBag.TaskStatus != null)
                                                            {
                                                                foreach (var statu in (List<MyERP.Models.TaskStatu>)ViewBag.TaskStatus)
                                                                {
                                                                    <input hidden value="@statu.Id" />
                                                                    <a href="javascript:void(0);" class="dropdown-item" onclick="changeStatue(@statu.Id,@item.Id)" style="min-width:25%;min-height:25%;">@statu.ArName</a>
                                                                }
                                                            }
                                                        </div>
                                                    </div>
                                                </td>*@
                                        </tr>
                                    }
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div> <!-- end card-box -->
        </div> <!-- end col -->

    </div>

}

