@if (ViewBag.ShowUserTasks == true)
{
    <div class="row">
        <div class="col-xl-6" style="max-height:60vh;overflow-x:scroll;">
            <div class="card-box">
                <h4 class="header-title mb-3">@MyERP.Properties.Resources.UserOrientedTasks</h4>

                <div class="table-responsive">
                    <table class="table table-borderless table-hover table-centered m-0">

                        <thead class="thead-light">
                            <tr>
                                <th>@MyERP.Properties.Resources.Task</th>
                                <th>@MyERP.Properties.Resources.Status</th>
                                <th>@MyERP.Properties.Resources.DirectedFrom</th>
                                <th>@MyERP.Properties.Resources.DateCreated</th>
                                <th>@MyERP.Properties.Resources.View</th>
                                @*<th>تغيير الحالة</th>*@
                                <th>
                                    <a href="#" onclick="Refresh()" style="float:left;">
                                        <i class="fas fa-sync-alt"></i>
                                    </a>
                                </th>
                            </tr>
                        </thead>
                        <tbody id="AssignedToUser">
                            @if (ViewBag.AssignedToUser != null)
                            {
                                foreach (var item in (List<MyERP.Models.UserTask>)ViewBag.AssignedToUser)
                                {
                                    if (item.StatusId != 6)
                                    {
                                        <tr>
                                            <td hidden>
                                                @*<input class="AssignToID" value="@item.Id" />*@
                                                <input class="TaskID" value="@item.Id" />
                                                <input hidden class="taskStatusId" value="@item.StatusId" />

                                            </td>
                                            <td>
                                                @item.ArName

                                            </td>

                                            <td>
                                                @if (item.StatusId == 1)
                                                {
                                                    <span class="badge badge-light-warning">
                                                        @item.TaskStatu.ArName
                                                    </span>
                                                }
                                                else if (item.StatusId == 2)
                                                {
                                                    <span class="badge badge-light-primary">
                                                        @item.TaskStatu.ArName
                                                    </span>
                                                }
                                                else if (item.StatusId == 3)
                                                {
                                                    <span class="badge badge-light-secondary">
                                                        @item.TaskStatu.ArName
                                                    </span>
                                                }
                                                else if (item.StatusId == 4)
                                                {
                                                    <span class="badge badge-light-success">
                                                        @item.TaskStatu.ArName
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-light-danger">
                                                        @item.TaskStatu.ArName
                                                    </span>
                                                }

                                            </td>
                                            <td>
                                                @item.ERPUser.UserName
                                            </td>

                                            <td>
                                                @item.CreatedDate
                                            </td>
                                            @if (item.SystemPage != null)
                                            {
                                                <td>
                                                    <a href="javascript: void(0);" data-toggle="modal" data-target="#ShowTask" onclick="ShowTaskDetails(this,'TO','@item.SystemPage.ControllerName',@item.SelectedId)"><i class="mdi mdi-eye"></i></a>
                                                </td>
                                            }
                                            else
                                            {
                                                <td>
                                                    <a href="javascript: void(0);" data-toggle="modal" data-target="#ShowTask" onclick="ShowTaskDetails(this,'TO','',@item.SelectedId)"><i class="mdi mdi-eye"></i></a>
                                                </td>
                                            }
                                            @*<td>
                                                    <div class="btn-group dropleft">
                                                        <a href="#" class="dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                                            <i class="mdi mdi-dots-horizontal"></i>
                                                        </a>
                                                        <div class="dropdown-menu">-->
                                                            <!-- Dropdown menu links -->
