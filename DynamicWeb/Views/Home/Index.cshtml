                                        <tr>
                                            <td hidden>
                                                @*<input class="CreatedByID" value="@item.Id"/>*@
                                                <input class="TaskID" value="@item.Id" />
                                                <input hidden class="taskStatusId" value="@item.StatusId" />

                                            </td>
                                            <td>
                                                @item.ArName

                                            </td>

                                            <td>
                                                @if (item.StatusId == 1)
                                                {
                                                    <span class="badge badge-light-warning">
                                                        @item.TaskStatu.ArName
                                                    </span>
