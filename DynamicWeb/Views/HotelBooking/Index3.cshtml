@model IEnumerable<MyERP.Models.RoomType>

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = MyERP.Properties.Resources.HotelBooking;
    Layout = "~/Views/Shared/_HotelBookingLayout.cshtml";
}


<section class="ftco-section ftco-no-pb ftco-room">
    <div class="container-fluid px-0">
        <div class="row no-gutters justify-content-center mb-5 pb-3">
            <div class="col-md-7 heading-section text-center ftco-animate">
                <span class="subheading" style="font-size:20px">@MyERP.Properties.Resources.FunTimesChalets</span>
                @*<h2 class="mb-4">@MyERP.Properties.Resources.HotelMasterRooms</h2>*@
            </div>
        </div>
        <div class="row no-gutters">
            @foreach (var item in Model)
            {
                <div class="col-lg-6" style="padding-bottom:1%;">
                    <div class="room-wrap d-md-flex ftco-animate">
                        <a href="#" class="img" style="background-image: url(@(item.RoomTypeImages.FirstOrDefault()!=null?item.RoomTypeImages.FirstOrDefault().Image:null));"></a>
                        <div class="half left-arrow d-flex align-items-center">
                            <div class="text p-4 text-center">
                                @*<p class="star mb-0"><span class="ion-ios-star"></span><span class="ion-ios-star"></span><span class="ion-ios-star"></span><span class="ion-ios-star"></span><span class="ion-ios-star"></span></p>*@
                                <p class="mb-0"><span class="price mr-1">@item.Price.Value.ToString("0.00")</span> <span class="per">@MyERP.Properties.Resources.PerNight</span></p>
                                <h3 class="mb-3"><a href="rooms.html">@item.ArName</a></h3>
                                <p class="pt-1"><a href="/HotelBooking/Index2?ParentId=@item.Id" class="btn-custom px-3 py-2 rounded">@MyERP.Properties.Resources.ViewDetails <span class="icon-long-arrow-right"></span></a></p>
                            </div>
                        </div>
                    </div>
                </div>
            }

           
        </div>
    </div>
</section>