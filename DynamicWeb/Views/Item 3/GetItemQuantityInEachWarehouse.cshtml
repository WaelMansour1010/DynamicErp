@model IEnumerable<MyERP.Models.GetItemQuantityInEachWarehouse_Result>
@{
    UICulture = Session["lang"] != null?Session["lang"].ToString():"ar";
}
@if (ViewBag.ShowItemDetails)
{
<div class="row" style="overflow-y:scroll;">
    <table class="table table-striped">
        <thead>
            <tr>
                <th>@MyERP.Properties.Resources.WareHouse</th>
                <th>@MyERP.Properties.Resources.Qty (@ViewBag.DefaultUnit)</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@Html.DisplayFor(modelItem => item.WarehouseArName)</td>

                    <td>@Html.DisplayFor(modelItem => item.Quantity)</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="form-group " style="width:100%">
        @if (ViewBag.LastPrice != null && ViewBag.ShowPurchasePrice == true)
        {
            <div id="showlastpice" class="hidden">


                <label class="control-label col-sm-12" style="text-align: center;">@MyERP.Properties.Resources.LatestPurchasePrice</label>
                <hr />
                <table class="table table-striped">

                    <thead>

                        <tr>
                            <th>@MyERP.Properties.Resources.Price</th>
                            <th>@MyERP.Properties.Resources.Date</th>
                            <th>@MyERP.Properties.Resources.Supplier</th>
                            <th>@MyERP.Properties.Resources.Qty</th>
                        </tr>
                    </thead>

                    @foreach (var item in (List<MyERP.Controllers.itemData>)ViewBag.LastPrice)
                    {
                        <tr>
                            <td>@Math.Round(item.Price.Value, 2)</td>
                            <td>@item.VoucherDate</td>
                            <td>@item.VendorName</td>
                            <td>@item.qty</td>
                        </tr>
                    }

                </table>

                @*<div class="col-sm-4"><input type="text" readonly class="form-control" value="Math.Round(ViewBag.LastPrice,2)" /></div>*@
            </div>


            /* <label class="control-label col-sm-2">آخر سعر شراء (@ViewBag.DefaultUnit)</label>
             <div class="col-sm-4">
                 <input type="text" readonly class="form-control" value="@Math.Round(ViewBag.LastPrice,2)" />
             </div>*/
        }
        @if (ViewBag.AVGCost != null && ViewBag.ShowCost == true)
        {
            <div class="form-group row">
                <label class="control-label col-sm-4">@MyERP.Properties.Resources.AverageCost  (@ViewBag.DefaultUnit)</label>
                <div class="col-sm-6">
                    <div class="col-sm-8"><input type="text" readonly class="form-control" value="@Math.Round(ViewBag.AVGCost, 2)" /></div>

                </div>
            </div>

        }
    </div>

    <hr />
    <br />
    <div class="form-group " style="width:100%" id="WarrantyDetailsBody">
    </div>
</div>
}
<style>
    #showlastpice tbody td {
        padding: 0px;
    }
</style>
<script>
    var itemid = '@ViewBag.ItemId';
    showItemWarranty(itemid);
        function showItemWarranty(itemid) {
        let item = items.filter(function (i) { return i.Id == itemid; })[0];
        $('#WarrantyDetailsBody').empty();
        if (item && item.HasWarranty == true) {
             let body = '<div class="form-group" > <label class="control-label col-sm-3">@MyERP.Properties.Resources.WarrantyPeriod :</label><div class="col-sm-12 row"><div class="col-sm-4"><label class="control-label col-sm-3">@MyERP.Properties.Resources.Day</label><div class="col-sm-12"><input type="text" disabled value="' +
                item.WarrantyDays + '" class="form-control col-sm-12" id="WarrantyDay"></div></div><div class="col-sm-4"><label class="control-label col-sm-3">@MyERP.Properties.Resources.Month</label><div class="col-sm-12"><input type="text" disabled value="' +
                item.WarrantyMonths + '" class="form-control col-sm-12" id="WarrantyMonth"></div></div><div class="col-sm-4"><label class="control-label col-sm-3">@MyERP.Properties.Resources.Year</label><div class="col-sm-12"><input type="text" disabled value="' +
                item.WarrantyYears + '" class="form-control col-sm-12" id="WarrantyYear"></div></div></div></div>';

            $('#WarrantyDetailsBody').append(body);
          //  WarrantyTypeChange();
        }
        else {
             Swal.fire({
                        title: '@MyERP.Properties.Resources.ItemHasNoWarranty',
                        text: " ",
                        icon: 'info',
                        showCancelButton: false,
                        confirmButtonText: '@MyERP.Properties.Resources.Ok',
                        confirmButtonColor: '#3085d6'
             });
            $('#itemWarranty').modal('hide');

        }
    }


  //  $('.table td, .table th').css("min-width", "0vh");
</script>