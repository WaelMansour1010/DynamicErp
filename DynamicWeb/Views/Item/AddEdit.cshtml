@model MyERP.Models.Item
@{
    if (System.Web.Configuration.WebConfigurationManager.AppSettings["ECommerce"] == "true")
    {
        Layout = "~/Views/Shared/_EcommerceLayout.cshtml";
    }
    var EnterItemCodeManually = ViewBag.EnterItemCodeManually;

}
@{
    UICulture = Session["lang"] != null?Session["lang"].ToString():"ar";

    ViewBag.Title = MyERP.Properties.Resources.Items;
    bool isECommerce = System.Web.Configuration.WebConfigurationManager.AppSettings["ECommerce"] == "true" ? true : false;
    bool PricingDependOnCustGroups = ViewBag.PricingDependOnCustGroups==true?true:false;
    string AmazonS3Server = string.IsNullOrEmpty(System.Web.Configuration.WebConfigurationManager.AppSettings["AmazonS3Server"]) ? "" : System.Web.Configuration.WebConfigurationManager.AppSettings["AmazonS3Server"];
    bool ProjectName= System.Web.Configuration.WebConfigurationManager.AppSettings["ProjectName"] == "Genoise";
}
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                @if (Model != null)
                {
                    if (Model.IsDeleted == false)
                    {
                        if (ViewBag.Previous > 0)
                        {
                <a href="@Url.Action("AddEdit", new { id = ViewBag.First })" class="btn btn-info">@MyERP.Properties.Resources.First</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Previous })" class=" btn btn-info">&#8250;</a>
                        }
                        if (ViewBag.Next > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Next })" class="btn btn-info">&#8249;</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Last })" class="btn btn-info">@MyERP.Properties.Resources.Last</a>
                        }
                    }
                }
                <a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
            </div>
            <h4 class="page-title">@MyERP.Properties.Resources.Items :</h4>
        </div>
    </div>
</div>
@if (Model != null)
{
    @Html.HiddenFor(model => model.Id)
    @Html.HiddenFor(model => model.IsActive)
    @Html.HiddenFor(model => model.UserId)
    @Html.HiddenFor(model => model.IsLinked)
    @Html.HiddenFor(model => model.IsPosted)
    @Html.HiddenFor(model => model.IsDeleted)
    @Html.HiddenFor(model => model.Image)
}
<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal needs-validation" role="form">
                        <div class="card">
                            <div class="card-body">
                                <h5 class="header-title">
                                    @MyERP.Properties.Resources.MainData
                                </h5>
                                <div class="form-group row">
                                    <label class=" col-sm-2 control-label" for="Code">@MyERP.Properties.Resources.Code</label>
                                    <div class="col-sm-2">
                                        @if (EnterItemCodeManually == true)
                                        {
                                            @Html.EditorFor(model => model.Code, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.Code, required = "required" } })
                                        }
                                        else
                                        {
                                            @Html.EditorFor(model => model.Code, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.Code, @readonly = "readonly", required = "required" } })
                                        }
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <div class="col-sm-2">
                                        @Html.DropDownList("FieldsCodingId", null, null, htmlAttributes: new { @class = "form-control" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>

                                    <label class=" col-sm-2 control-label" for="ArName">@MyERP.Properties.Resources.ArName</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.ArName, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.ArName, required = "required", onkeyup = "itemAutoComplete()" } })

                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.EnterItemName
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class=" col-sm-2 control-label" for="EnName">@MyERP.Properties.Resources.EnName</label>
                                    <div class="col-sm-4">
                                        @(isECommerce ?
                   Html.EditorFor(model => model.EnName, new { htmlAttributes = new { @class = "form-control", required = "required", placeholder = @MyERP.Properties.Resources.EnName } }) :
                                       Html.EditorFor(model => model.EnName, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.EnName } }))
                                        @(isECommerce ? Html.Raw("<div class='invalid-feedback'>"+ @MyERP.Properties.Resources.EnterItemName+ "</div>") : null)
                                    </div>


                                    <label class=" col-sm-2 control-label" for="EnName">@(isECommerce ? @MyERP.Properties.Resources.KurdishName : @MyERP.Properties.Resources.ReOrderLimit)</label>
                                    <div class="col-sm-4">
                                        @(isECommerce ? Html.EditorFor(model => model.KrName, new { htmlAttributes = new { @class = "form-control", required = "required", placeholder = @MyERP.Properties.Resources.KurdishName } })
:
Html.EditorFor(model => model.OrderLimit, new { htmlAttributes = new { @class = "form-control", value = "0", @placeholder = @MyERP.Properties.Resources.ReOrderLimit} })

                                        )
                                        @(isECommerce ? Html.Raw("<div class='invalid-feedback'>"+ @MyERP.Properties.Resources.EnterItemName+ "</div>") : null)
                                    </div>


                                </div>

                                <div class="form-group row">
                                    <label for="ItemGroupId" class="control-label col-sm-2">@MyERP.Properties.Resources.Group</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("ItemGroupId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", required = "required" })

                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Select
                                        </div>
                                    </div>

                                    <label for="ItemTypeId" class="control-label col-sm-2">@MyERP.Properties.Resources.Type</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("ItemTypeId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Select
                                        </div>
                                    </div>
                                </div>

                                <div class="form-group row">
                                    <label for="HasWarranty" class="control-label col-sm-2">@MyERP.Properties.Resources.HasGuarantee</label>
                                    <div class="col-sm-4">
                                        <div class="custom-control custom-checkbox">
                                            <input type="checkbox" class="custom-control-input" name="HasWarranty" id="HasWarranty" @Html.Raw(Model == null ? "" : Model.HasWarranty == null ? "" : (bool)Model.HasWarranty ? "checked" : "") />
                                            <label class="custom-control-label" for="HasWarranty"></label>
                                        </div>
                                    </div>

                                    <label for="HasExpiry" class="control-label col-sm-2">@MyERP.Properties.Resources.HasExpirationDate</label>
                                    <div class="col-sm-4">

                                        <div class="custom-control custom-checkbox">
                                            <input type="checkbox" class="custom-control-input" name="HasExpiry" id="HasExpiry" @Html.Raw(Model == null ? "" : Model.HasExpiry == null ? "" : (bool)Model.HasExpiry ? "checked" : "") />
                                            <label class="custom-control-label" for="HasExpiry"></label>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="HasAccessory" class="control-label col-sm-2">@MyERP.Properties.Resources.HasAccessory</label>
                                    <div class="col-sm-4">
                                        <div class="custom-control custom-checkbox">
                                            <input type="checkbox" class="custom-control-input" name="HasAccessory" id="HasAccessory" @Html.Raw(Model == null ? "" : Model.HasAccessory == null ? "" : (bool)Model.HasAccessory ? "checked" : "") />
                                            <label class="custom-control-label" for="HasAccessory"></label>
                                        </div>
                                    </div>

                                    <label for="IsAccessory" class="control-label col-sm-2">@MyERP.Properties.Resources.IsAccessory</label>
                                    <div class="col-sm-4">

                                        <div class="custom-control custom-checkbox">
                                            <input type="checkbox" class="custom-control-input" name="IsAccessory" id="IsAccessory" @Html.Raw(Model == null ? "" : Model.IsAccessory == null ? "" : (bool)Model.IsAccessory ? "checked" : "") />
                                            <label class="custom-control-label" for="IsAccessory"></label>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="NotIncludeValueAddedTax" class="control-label col-sm-2">@MyERP.Properties.Resources.NotIncludeValueAddedTax</label>
                                    <div class="col-sm-4">
                                        <div class="custom-control custom-checkbox">
                                            <input type="checkbox" class="custom-control-input" name="NotIncludeValueAddedTax" id="NotIncludeValueAddedTax" @Html.Raw(Model == null ? "" : Model.NotIncludeValueAddedTax == null ? "" : (bool)Model.NotIncludeValueAddedTax ? "checked" : "") />
                                            <label class="custom-control-label" for="NotIncludeValueAddedTax"></label>
                                        </div>
                                    </div>

                                    <label style="display:none;" class="control-label col-sm-2 TaxPercentage">@MyERP.Properties.Resources.TaxPercentage</label>
                                    <div class="col-sm-3 TaxPercentage" style="display:none;">
                                        @Html.EditorFor(model => model.TaxPercentage, new { htmlAttributes = new { @class = "form-control" } })
                                    </div>
                                    <span class="TaxPercentage control-label" style="display:none;"> % </span>
                                </div>

                                <div class="form-group WarrantyDetails" id="WarrantyDetails">
                                    <div class="panel panel-default WarrantyDetails">
                                        <div class="panel-heading WarrantyDetails">@MyERP.Properties.Resources.WarrantyInformation</div>
                                        <div class="panel-body WarrantyDetails">
                                            <label for="WarrantyDays" class="control-label col-sm-1">@MyERP.Properties.Resources.Days</label>
                                            <div class="col-sm-3">
                                                @Html.EditorFor(model => model.WarrantyDays, new { htmlAttributes = new { @class = "form-control", @min = "0" } })

                                            </div>

                                            <label for="WarrantyMonths" class="control-label col-sm-1 WarrantyDetails">@MyERP.Properties.Resources.Months</label>
                                            <div class="col-sm-3 WarrantyDetails">
                                                @Html.EditorFor(model => model.WarrantyMonths, new { htmlAttributes = new { @class = "form-control", @min = "0" } })
                                            </div>

                                            <label for="WarrantyYears" class="control-label col-sm-1 WarrantyDetails">@MyERP.Properties.Resources.Years</label>
                                            <div class="col-sm-3 WarrantyDetails">
                                                @Html.EditorFor(model => model.WarrantyYears, new { htmlAttributes = new { @class = "form-control", @min = "0" } })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="ItemCategoryId" class="control-label col-sm-2">@MyERP.Properties.Resources.ItemCategory</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("ItemCategoryId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })

                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>


                                </div>

                                <div class="form-group row">
                                    <label class="control-label col-sm-2" for="Notes">@MyERP.Properties.Resources.ArNotes</label>
                                    <div class="col-sm-4">
                                        <textarea id="Notes" name="Notes" class="form-control" rows="5" cols="5">@if (Model != null) { @Model.Notes; }</textarea>

                                    </div>

                                    @if (isECommerce)
                                    {
                                        <label for="OrderLimit" class="control-label col-sm-2">@MyERP.Properties.Resources.ReOrderLimit</label>
                                        <div class="col-sm-4">
                                            @Html.EditorFor(model => model.OrderLimit, new { htmlAttributes = new { @class = "form-control", value = "0", @placeholder = @MyERP.Properties.Resources.ReOrderLimit } })
                                        </div>
                                    }
                                </div>
                                @if (isECommerce)
                                {
                                    <div class="form-group row">
                                        <label class="control-label col-sm-2" for="Notes">@MyERP.Properties.Resources.EnNotes</label>
                                        <div class="col-sm-4">
                                            <textarea id="ArNotes" name="ArNotes" class="form-control" rows="5" cols="5">@if (Model != null) { @Model.ArNotes; }</textarea>

                                        </div>

                                    </div>

                                    <div class="form-group row">
                                        <label class="control-label col-sm-2" for="Notes">@MyERP.Properties.Resources.KrNotes</label>
                                        <div class="col-sm-4">
                                            <textarea id="KrNotes" name="KrNotes" class="form-control" rows="5" cols="5">@if (Model != null)
                                            { @Model.KrNotes;
                                            }</textarea>
                                        </div>


                                    </div>


                                    <div class="form-group row">
                                        <label class="control-label col-sm-2" for="Notes">@MyERP.Properties.Resources.ArDetails</label>
                                        <div class="col-sm-4">
                                            <textarea id="ArDetails" name="ArDetails" class="form-control" rows="5" cols="5">@if (Model != null) { @Model.ArDetails; }</textarea>

                                        </div>

                                    </div>

                                    <div class="form-group row">
                                        <label class="control-label col-sm-2" for="Notes">@MyERP.Properties.Resources.EnDetails</label>
                                        <div class="col-sm-4">
                                            <textarea id="EnDetails" name="EnDetails" class="form-control" rows="5" cols="5">@if (Model != null) { @Model.EnDetails; }</textarea>

                                        </div>

                                    </div>

                                    <div class="form-group row">
                                        <label class="control-label col-sm-2" for="Notes">@MyERP.Properties.Resources.KrDetails</label>
                                        <div class="col-sm-4">
                                            <textarea id="KrDetails" name="KrDetails" class="form-control" rows="5" cols="5">@if (Model != null){@Model.KrDetails;}</textarea>

                                        </div>


                                    </div>
                                }


                                <div class="tab-pane" id="5">
                                    <div id="gallery" style="width: 100%;margin: 20px;">

                                        @{ if (Model != null)
                                            {
                                                if (isECommerce == true && Model.ItemImages != null)
                                                {
                                                    foreach (MyERP.Models.ItemImage img in Model.ItemImages)
                                                    {
                                                        <img src="@AmazonS3Server/items/@img.Image" alt="" class="img_@img.Id" style="max-width: 200px;max-height: 200px;" />
                                                        <i class="fas fa-trash-alt img_@img.Id" style="cursor:pointer;" onclick="DeleteIMG('@img.Id');$(this).prev().remove();$(this).remove();"></i>
                                                    }
                                                }
                                                else
                                                {
                                                    if (Model.Image != null)
                                                    {
                                                        <img src="@Model.Image" alt="" class="img_@Model.Id" style="max-width: 200px;max-height: 200px;" />
                                                    }
                                                }
                                            }
                                        }
                                    </div>


                                    <input type="file" id="BrowseImage" onchange="previewFile()" value="Browse" @*multiple*@ />
                                    @*<input type="button" id="GetImage" value="GetImage" />*@

                                    <div style="display:none;">
                                        @Html.ListBoxFor(i => i.ItemURLImages, new SelectList(Model == null ? new List<MyERP.Models.ItemImage>() : Model.ItemImages, "Id", "Image", Model == null ? null : Model.ItemURLImages), new { @class = "form-control1", placeholder = "Item Photos" })
                                    </div>
                                    @*<div id="UploadImage" style="height:600px;width:600px;">

                                </div>*@
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="header-title">@MyERP.Properties.Resources.Prices</h5>
                            <div class="form-horizontal needs-validation" role="form">
                                <div class="table-responsive">
                                    <table class="table table-centered mb-0">
                                        <thead>
                                            <tr>
                                                <th>@MyERP.Properties.Resources.Barcode</th>
                                                @*@if (isECommerce)
                                            {*@
                                                <th class="PriceBeforeDiscountTd" style="display:none;">@MyERP.Properties.Resources.PriceBeforeDiscount</th>
                                                @*}*@
                                                <th>@(isECommerce? @MyERP.Properties.Resources.Price: @MyERP.Properties.Resources.SellingPriceOfBranches) </th>
                                                <th>@MyERP.Properties.Resources.Unit</th>
                                                <th>@MyERP.Properties.Resources.Equivalent</th>
                                                <th class="price-toleranceQty-th" style="display:@Html.Raw(Model!=null && (Model.ItemTypeId==2 || Model.ItemTypeId==3)? "block;":"none;")"> @MyERP.Properties.Resources.AllowAmount</th>

                                                @if (isECommerce)
                                                {
                                                    <th>@MyERP.Properties.Resources.Supplier</th>

                                                }
                                                else if (System.Web.Configuration.WebConfigurationManager.AppSettings["ProjectName"] == "Genoise")
                                                {
                                                    <th>@MyERP.Properties.Resources.FactorySalePrice</th>
                                                }
                                                @if (PricingDependOnCustGroups == true)
                                                {
                                                    <th>@MyERP.Properties.Resources.CustomersGroups</th>
                                                }
                                                <th>@MyERP.Properties.Resources.Default</th>
                                                <th>@MyERP.Properties.Resources.Delete</th>
                                            </tr>
                                        </thead>
                                        <tbody id="itemPrices">
                                            @if (Model != null)
                                            {
                                                foreach (var item in Model.ItemPrices)
                                                {
                                                    <tr>
                                                        <td class="tabledit-edit-mode">
                                                            <input class="barcode form-control tabledit-input form-control-sm" type="text" value="@item.Barcode" />
                                                            <input type="hidden" class="item-price-id" value="@item.Id" />
                                                        </td>
                                                        @*@if (isECommerce)
                                                    {*@
                                                        <td class="tabledit-edit-mode PriceBeforeDiscountTd" style="display:none;"><input type="text" class="money PriceBeforeDiscount form-control tabledit-input form-control-sm" value="@item.PriceBeforeDiscount" /></td>
                                                        @*}*@
                                                        <td class="tabledit-edit-mode"><input type="text" class="money price form-control tabledit-input form-control-sm" value="@item.Price" required /></td>
                                                        <td class="tabledit-edit-mode"><select class="itemUnit form-control tabledit-input form-control-sm" required><option value="@item.ItemUnitId">@item.ItemUnit.ArName</option></select></td>
                                                        <td class="tabledit-edit-mode"><input class="unit-equavalent form-control tabledit-input form-control-sm" type="number" step="any" value="@item.Equivalent" required @Html.Raw(item.IsDefault == true ? "readonly" : "") /></td>
                                                        <td class="tabledit-edit-mode" style="display:@Html.Raw(Model.ItemTypeId==2 || Model.ItemTypeId==3? "block;":"none;")"><input class="price-toleranceQty form-control tabledit-input form-control-sm" type="number" step="any" value="@item.ToleranceQty" style="display:@Html.Raw(Model.ItemTypeId==2 || Model.ItemTypeId==3? "block;":"none;")" @Html.Raw(Model.ItemTypeId == 2 || Model.ItemTypeId == 3 ? "required" : "") /></td>



                                                        @if (isECommerce == true)
                                                        {
                                                            <td class="tabledit-edit-mode">
                                                                <select id="VendorPrice" class="vendor form-control tabledit-input form-control-sm" required>
                                                                    <option value="@item.VendorId">@(item.Vendor == null ? "" : item.Vendor.ArName) </option>
                                                                </select>
                                                            </td>
                                                        }
                                                        else if (System.Web.Configuration.WebConfigurationManager.AppSettings["ProjectName"] == "Genoise")
                                                        {
                                                            <td class="tabledit-edit-mode">
                                                                <input type="text" class="money factory-price form-control tabledit-input form-control-sm" value="@item.FactoryPrice" required />
                                                            </td>
                                                        }
                                                        @if (PricingDependOnCustGroups == true)
                                                        {
                                                            <td class="tabledit-edit-mode">

                                                                <select id="customersgroups" class="customersgroups form-control tabledit-input form-control-sm" required><option value="@item.CustomerGroupId">@(item.CustomersGroup == null ? "" : item.CustomersGroup.ArName) </option></select>
                                                            </td>
                                                        }
                                                        <td class="tabledit-edit-mode"><input class="isDefault" name="isDefault" type="radio" @Html.Raw(item.IsDefault == null ? "" : (bool)item.IsDefault ? "checked" : "") /></td>
                                                        <td>
                                                            <a href="javascript:void(0);" onclick="deleteElement(this)">
                                                                <i class="fas fa-trash-alt"></i>
                                                            </a>
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                            else
                                            {
                                                <tr>
                                                    <td class="tabledit-edit-mode"><input class="barcode form-control tabledit-input form-control-sm" type="text" /></td>
                                                    @*  @if (isECommerce)
                                                {*@
                                                    <td class="tabledit-edit-mode PriceBeforeDiscountTd" style="display:none;"><input type="text" class="money PriceBeforeDiscount form-control tabledit-input form-control-sm" /></td>
                                                    @*}*@
                                                    <td class="tabledit-edit-mode"><input type="text" class="money price form-control tabledit-input form-control-sm" required /></td>
                                                    <td class="tabledit-edit-mode"><select class="itemUnit form-control tabledit-input form-control-sm" required></select></td>
                                                    <td class="tabledit-edit-mode"><input class="unit-equavalent form-control tabledit-input form-control-sm" type="number" step="any" required readonly value="1" /></td>
                                                    <td class="tabledit-edit-mode" style="display:none;"><input class="price-toleranceQty form-control tabledit-input form-control-sm" type="number" step="any" style="display:none;" /></td>

                                                    @if (isECommerce == true)
                                                    {
                                                        <td class="tabledit-edit-mode">

                                                            <select id="VendorPrice" class="vendor form-control tabledit-input form-control-sm" required></select>
                                                        </td>
                                                    }
                                                    else if (System.Web.Configuration.WebConfigurationManager.AppSettings["ProjectName"] == "Genoise")
                                                    {
                                                        <td class="tabledit-edit-mode">

                                                            <input type="text" class="money factory-price form-control tabledit-input form-control-sm" required />
                                                        </td>
                                                    }
                                                    @if (PricingDependOnCustGroups == true)
                                                    {
                                                        <td class="tabledit-edit-mode">

                                                            <select id="customersgroups" class="customersgroups form-control tabledit-input form-control-sm" required></select>

                                                        </td>
                                                    }
                                                    <td class="tabledit-edit-mode"><input class="isDefault" name="isDefault" type="radio" checked /></td>
                                                    <td>
                                                        <a href="javascript:void(0);" onclick="deleteElement(this)">
                                                            <i class="fas fa-trash-alt"></i>
                                                        </a>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                            <div class="row justify-content-end">
                                <button class="btn btn-success" onclick="addToItemPrices()">
                                    @MyERP.Properties.Resources.AddPrice
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            @if (!isECommerce)
            {
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">
                                <h5 class="header-title">@MyERP.Properties.Resources.Branches</h5>
                                <div class="form-horizontal needs-validation" role="form">

                                    @{ Html.RenderAction("ItemDepartments", new { itemId = Model != null ? (int?)Model.Id : null });}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
            @if (!isECommerce)
            {
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">
                                <h5 class="header-title">@MyERP.Properties.Resources.Suppliers</h5>
                                <div class="form-horizontal needs-validation" role="form">
                                    <div class="table-responsive">
                                        <table class="table table-centered mb-0">
                                            <tbody id="itemVendors">
                                                @if (Model != null && Model.ItemVendors.Count() > 0)
                                                {
                                                    foreach (var item in Model.ItemVendors)
