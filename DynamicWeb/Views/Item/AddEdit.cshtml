    function ItemTypeChange() {
        if ($('#ItemTypeId').val() && $('#ItemTypeId').val() == 2 || $('#ItemTypeId').val() == 3) {
            $('#itemComponents').closest('.row').show();
            $('#itemComponents select, #itemComponents input').attr('required', 'required');
            $('.price-toleranceQty').show().attr('required', 'required');
            $('.price-toleranceQty').closest('td').show();
            $('.price-toleranceQty-th').show();
        } else {
            $('#itemComponents').closest('.row').hide();
            $('#itemComponents select, #itemComponents input').removeAttr('required');
            $('.price-toleranceQty').val('').hide().removeAttr('required');
            $('.price-toleranceQty').closest('td').hide();
            $('.price-toleranceQty-th').hide();
        }
    }

