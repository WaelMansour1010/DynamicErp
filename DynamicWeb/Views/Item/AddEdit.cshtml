    function calculateComponentQuantities() {
        let virtualQty = $('#VirtualQuantity').inputmask('unmaskedvalue') * 1;
        $('.comp-virtual-qty').each(function () {
            $(this).closest('tr').find('.quantity').val($(this).inputmask('unmaskedvalue') / virtualQty);
        });
