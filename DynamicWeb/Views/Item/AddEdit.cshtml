    function Delete(id) {
        if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToDelete')) {
            $('#preloader, #status').fadeIn();
            $.ajax(
                {
                    url: '/Item/Delete',
                    type: 'POST',
                    data: {
                        "Id": id,
                    },
                    error: function (e) {
                        $('#preloader, #status').fadeOut();
                        alert("@MyERP.Properties.Resources.DeleteDoesNotSucceeded");
                    },
                    success: function (r) {
                        if (r == 'true') {
                            window.location.replace("/Item/Index");
                        }
                        else if (r == 'False') {
                            alert('@MyERP.Properties.Resources.DeleteDoesNotSucceededBecauseItemUsedInOtherTransactions');
                            $('#preloader, #status').fadeOut();
                        }
                        else
                            alert("@MyERP.Properties.Resources.DeleteDoesNotSucceeded");
                        $('#preloader, #status').fadeOut();
                    }
                });
        }
    }
