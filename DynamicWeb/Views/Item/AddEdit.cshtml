    $(document).on('change', '.componentItem', function () {
        if ($(this).val() && fetchComponentUnits == true) {
            let compItem = this;
            getItemUnits().then(function () {
                $(compItem).closest('tr').find('.item-componenet-unit').empty().append(itemUnitsOptionString);
            });
        } else if (!$(this).val())
            $(this).closest('tr').find('.item-componenet-unit').empty();
        fetchComponentUnits = true;
    });

    $(document).on('change', '.component-unit-equav, .unit-equavalent', function () {
        if ($(this).inputmask('unmaskedvalue') * 1 == 0) {
            $(this).val('');
        }
    });

    $(document).on('keydown paste', '#itemComponents .quantity', function (e) {
        e.preventDefault();
    });

    $(document).on('click', '.isDefault', function () {
        $('.unit-equavalent').removeAttr('readonly');
