                $("#gallery").html('<img style="max-width: 200px;max-height: 200px;margin-left: 2%;margin-bottom: 2%;" src="' + reader.result + '" alt="" /><i class="fas fa-trash-alt" style="cursor:pointer;" onclick="DeleteSingleIMG(\'' + reader.result + '\');$(this).prev().remove();$(this).remove();"></i>');
