<script>
    $(document).on('click', '#NotIncludeValueAddedTax', function () {
        if ($('#NotIncludeValueAddedTax').prop('checked') == true) {
            $('.TaxPercentage').hide();
            $('#TaxPercentage').val(0);
        }
        else {
            $('.TaxPercentage').show();
            $('#TaxPercentage').val(taxPercentage);
        }

    });

    function GetLastTaxPercentage() {
        $.get('/Item/GetLastTaxPercentage').done(function (r) {
            taxPercentage = r/*/100*/;
            if (!$('#Id').val()) {
                $('#TaxPercentage').val(taxPercentage);
            }
        });
    }
    GetLastTaxPercentage();


    //-------------- Variable Declaration ----------------------//
    let isRepeat = '@ViewBag.IsRepeat';
    let CanChangeBarcode ='@ViewBag.CanChangeBarcode';
    let CanChangeItemName ='@ViewBag.CanChangeItemName';
    let CanChangeProductNumber = '@ViewBag.CanChangeProductNumber';
    let itemUnits=[];
    let itemUnitsOptionString = '';
    let vendors;
    let customersgroups;
    let vendorsOptionString = '';
    let customersgroupsOptionString = '';
    let ComponentItemId;
    let ComponentItemOptionString = '';
    let fetchComponentUnits = true;
    let imageData = "";
    var taxPercentage = 0.15;
    var AddItemBarcodeBasedOnItemCode = '@ViewBag.AddItemBarcodeBasedOnItemCode';
    var EnterItemCodeManually = '@ViewBag.EnterItemCodeManually';
    //----------------- Ready ---------------------
    $(document).ready(function () {
        //------- Item CustomersGroup ------------------//
     //  getcustomersgroups();
        //----------------------------------------------//
        if ($('#Id').val()) {
            if (EnterItemCodeManually != 'True') {
                $('#FieldsCodingId').prop('disabled', true);
            }
        }
        else {
            if (EnterItemCodeManually != 'True') {
                setCodeNum();
            }
        }
        if ($('#NotIncludeValueAddedTax').prop('checked') == true) {
            $('.TaxPercentage').hide();
        }
        else {
            $('.TaxPercentage').show();
            if (!$('#TaxPercentage').val()) {
                $('#TaxPercentage').val(taxPercentage)
            }
        }
        if ($('#Id').val() || isRepeat == 'True') {
            GetComponentItems().then(function () {
                $('.componentItem').each(function () {
                    fetchComponentUnits = false;
                    let selectedItem = $(this).val();
                    let unit = $(this).closest('tr').find('.item-componenet-unit');
                    $(this).empty().append(ComponentItemOptionString).val(selectedItem).trigger('change');
                    getItemUnits().then(function () {
                        let unitId = unit.val();
                        unit.empty().append(itemUnitsOptionString).val(unitId).trigger('change');
                    })
                });
            });
            getItemUnits().then(function () {
                $('.itemUnit:valid').each(function () {
                    let precedingUnitsString = '<option value>' + '@MyERP.Properties.Resources.Select' + '</option>';
                    let succeedingUnitsString = '';
                    let selectedItem = $(this).val();
                    for (var i = 0; i < itemUnits.length; i++) {
                        if (itemUnits[i].Id < selectedItem)
                            precedingUnitsString += '<option value="' + itemUnits[i].Id + '">' + itemUnits[i].ArName + '</option>';
                        else if (itemUnits[i].Id > selectedItem)
                            succeedingUnitsString += '<option value="' + itemUnits[i].Id + '">' + itemUnits[i].ArName + '</option>';
                    }
                    $(this).prepend(precedingUnitsString);
                    $(this).append(succeedingUnitsString);
                });
            });
            getVendors().then(function () {
                $('.vendor').each(function () {
                    let selectedVendor = $(this).val();
                    $(this).empty().append(vendorsOptionString).val(selectedVendor).trigger('change');
                });
            });
            getcustomersgroups().then(function () {
                $('.customersgroups').append(customersgroupsoptionstring);
            })
             /*getcustomersgroups().then(function () {
                 $('.customersgroups').each(function () {
                     let selectedcustomersgroups = $(this).val();
                     $(this).empty().append(customersgroupsOptionString).val(selectedcustomersgroups).trigger('change');
                 });
        });*/
        } else {
            GetComponentItems().then(function () {
                $('.componentItem').empty().append(ComponentItemOptionString);
            });
            getItemUnits().done(function () {
                $('.itemUnit').empty().append(itemUnitsOptionString);
            });
            getVendors().done(function () {
                $('.vendor').empty().append(vendorsOptionString);
            });
            getcustomersgroups().then(function () {
                $('.customersgroups').append(customersgroupsoptionstring);
            })
            /*getcustomersgroups().done(function () {
                $('.customersgroups').empty().append(customersgroupsOptionString);

            });*/
        }
        let virtualQty = $('#VirtualQuantity').inputmask('unmaskedvalue') * 1;

        $('.quantity').each(function () {
            $(this).closest('tr').find('.comp-virtual-qty').val($(this).inputmask('unmaskedvalue') * virtualQty);
        });
    });
//----------------------------------------------------------------------------------------//
 //----------------------------- Set Code Number ----------------------------//
    function setCodeNum() {
        $.get('/Item/SetCodeNum?FieldsCodingId=' + $('#FieldsCodingId').val()).done(function (r) {
            $('#Code').val(r);
            if (AddItemBarcodeBasedOnItemCode == 'True') {
                $('#itemPrices tr:first').find('.barcode').val(r)
                $('#Code').val($(this).val());
            }
        });


    }

    //-----------------------------------------------------------//

    //-------------------------------- if Checks --------------------------//
    if ('@isECommerce' == 'True') {
        $('.PriceBeforeDiscountTd').show();
        $('.VendorTd').show();
        $('.vendor').attr('required', 'required');
    }

    if ('@ProjectName' == 'True') {
        $('.FactoryPriceTd').show();
        $('.factory-price').attr('required','required');
    }

    if (isRepeat == 'True') {
        $('#Id, #repeatLink, button.btn.btn-danger').remove();
    }

    if (CanChangeItemName == 'False') {
        $('#ArName, #EnName').prop('readonly', 'readonly');
    }

    if (CanChangeProductNumber == 'False') {
        $('#ProductNo').prop('readonly', 'readonly');
    }

    if (CanChangeBarcode == 'False') {
        $('.barcode').prop('readonly', 'readonly');
    }

    $("#ItemURLImages option").attr('selected', 'selected');
    $("#ItemURLImages").hide();
    ItemTypeChange();
    chechHasWarranty();
    //---------------------------------------------------------------//

    //---------------- On Change -----------------------//

    $('#FieldsCodingId').on('change', function () {
        if (!$('#Id').val()) {
            if (EnterItemCodeManually != 'True') {
                setCodeNum();
            }
        }
    });

    $('#DepartmentId').on('change', function () {
        GetComponentItems().then(function () {
            $('.componentItem').empty().append(ComponentItemOptionString);
        });
    });
    $("#GetImage").click(function () {
        $("#GetImage").fadeOut();
        $('#UploadImage').photobooth().on("image", function (event, dataUrl) {
            $("#gallery").append('<img style="max-width: 200px;max-height: 200px;margin-left: 2%;margin-bottom: 2%;" src="' + dataUrl + '" alt="" /><i class="fa fa-trash-o" style="cursor:pointer;position: absolute;" onclick="DeleteIMG("' + dataUrl + '");;$(this).prev().remove();$(this).remove();"></i>');
            $("#ItemURLImages").append("<option style='float: left;' selected=selected>" + dataUrl + "</option>");
        });
    });
    $('#HasWarranty').on('change', function () {
        chechHasWarranty();
    });
    $('#ItemTypeId').on('change', function () {
        ItemTypeChange();
    });

    $(document).on('change', '.itemUnit', function () {
        let unit = $(this);
        let isDefault = $(this).closest('tr').find('.isDefault').is(':checked');
        if (unit.val() && itemUnits.length && !isDefault) {
            getItemUnits().then(function () {
                let equiv = itemUnits.filter(function (i) { return i.Id == unit.val(); })[0].Equivalent;
                unit.closest('tr').find('.unit-equavalent').val(equiv);
            });
        } else if (isDefault)
            unit.closest('tr').find('.unit-equavalent').val(1);
        else {
            unit.closest('tr').find('.unit-equavalent').val('');
        }

        @* //-------- to prevent repetetion of CustomerGp and ItemUnit ---------------//
        let unitId = $(this).val();
        let index = $(this).index('.itemUnit');
        let customerGroup = $(this).closest('tr').find('.customersgroups').val();
        let vendor = $(this).closest('tr').find('.vendor').val();

        if (customerGroup > 0)
            $('.itemUnit').each(function (i, elem) {
                if (index != i && $(this).val() == unitId && $(this).closest('tr').find('.customersgroups').val() == customerGroup) {
                    $('.itemUnit').eq(index).val(0).trigger('change');
                    alert('@MyERP.Properties.Resources.ItIsNotPossibleToChooseTheSameUnitWithTheSameGroupOfClientsMoreThanOnce'+'!');
                }
            });*@

        @*//-------- to prevent repetetion of Vendors and ItemUnit ---------------//
        if (vendor > 0)
            $('.itemUnit').each(function (i, elem) {
                if (index != i && $(this).val() == unitId && $(this).closest('tr').find('.vendor').val() == vendor) {
                    $('.itemUnit').eq(index).val(0).trigger('change');
                    alert('@MyERP.Properties.Resources.ItIsNotPossibleToChooseTheSameUnitWithTheSameGroupOfSuppliersMoreThanOnce'+'!');
                }
            });
        //-------------------------------------------------------------//*@

        //-------------------------------------------------------------//
    });

    @*$(document).on('change', '.customersgroups', function () {
        //-------- to prevent repetetion of CustomerGp and ItemUnit ---------------//
        let customerGroup = $(this).val();
        let index = $(this).index('.customersgroups');
        let itemUnit = $(this).closest('tr').find('.itemUnit').val();
        let vendor = $(this).closest('tr').find('.vendor').val();
        if ($(this).val() > 0)
            $('.customersgroups').each(function (i, elem) {
                if (index != i && $(this).val() == customerGroup && $(this).closest('tr').find('.itemUnit').val() == itemUnit) {
                    $('.customersgroups').eq(index).val(0).trigger('change');
                    alert('@MyERP.Properties.Resources.ItIsNotPossibleToSelectTheSameGroupOfClientsWithTheSameUnitMoreThanOnce'+'!');
                }
            });

        //-------- to prevent repetetion of Vendors and ItemUnit ---------------//
        if (vendor > 0)
            $('.itemUnit').each(function (i, elem) {
                if (index != i && $(this).val() == itemUnit && $(this).closest('tr').find('.vendor').val() == vendor) {
                    $('.itemUnit').eq(index).val(0).trigger('change');
                    alert('@MyERP.Properties.Resources.ItIsNotPossibleToChooseTheSameGroupOfSuppliersWithTheSameUnitMoreThanOnce'+'!');
                }
            });
        //-------------------------------------------------------------//

    });*@

