    {
         for (var i = 0; i < $('#ItemURLImages option').length; i++) {
             if ($('#ItemURLImages option')[0].value == url)
                    $('#ItemURLImages option')[0].remove();
         }
        //$("img[src='" + url + "']").remove();
         $("#BrowseImage").val('');
