                        </div>
                        <div class="col-sm-6">
                            <input class="form-control text-box single-line" type="password" id="confirmPassword" name="confirmPassword" onkeyup="check();" placeholder=" @MyERP.Properties.Resources.ConfirmPassword" required>
                        </div>
                    </div>

                    <div class="form-group row">
                        <div class="col-sm-12" style="text-align:center;">
