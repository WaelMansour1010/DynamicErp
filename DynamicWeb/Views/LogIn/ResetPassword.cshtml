                        <div class="col-sm-12">
                            <input class="form-control text-box single-line" type="password" id="currpassword" name="currentPassword" placeholder="@MyERP.Properties.Resources.CurrentPassWord" required>
                        </div>
                    </div>

                    <div class="form-group row">
