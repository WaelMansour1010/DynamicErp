        //    $('#preloader, #status').fadeIn();
        //    $.ajax(
        //        {
        //            url: '/ManufacturingOrder/Delete',
        //            type: 'POST',
        //            data: {
        //                "Id": id,
        //            },
        //            error: function (e) {
        //                 alert('لم يتم الحذف!');
        //                    $('#preloader, #status').fadeIn();
        //            },
        //            success: function (r) {
        //                if (r == 'true') {
        //                    window.location.reload();
        //                } else {
        //                    alert('لم يتم الحذف!');
        //                    $('#preloader, #status').fadeIn();
        //                }
        //            }
        //        });
        //}
    }

</script>


