    function makeManufacturingOrder(isProcess1, id, btn) {
        Swal.fire({
            title: '@MyERP.Properties.Resources.AreYouSureYouWantToCreateManufacturingOrder',
            text: " ",
            icon: 'info',
            showCancelButton: true,
            confirmButtonText: '@MyERP.Properties.Resources.Ok',
            cancelButtonText: '@MyERP.Properties.Resources.Cancel',
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                $('#preloader, #status').fadeIn();
                $.ajax({
                    type: "POST", contentType: "application/json",
                    url: "/ManufacturingRequest/MakeManufacturingOrder",
                    data:
                        JSON.stringify({
                            isProcess1: isProcess1, manuRequestId: id
                        }),
                    success: function (r) {
                        $(btn).closest('.row').remove();
                        $('.save-btn').remove();
                        $('#preloader, #status').fadeOut();
                        if (r == 'exists')
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.ThereIsManufacturingOrderForThisStage',
                                text: " ",
                                icon: 'info',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                        else if (r == 'noWarehouse')
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.TheChefHasNoWareHouse',
                                text: " ",
                                icon: 'info',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                        else
                            Swal.fire(
                                {
                                    title: '@MyERP.Properties.Resources.ManufacturingOrderCreated',
                                    text: " ",
                                    icon: 'success',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                    },
                    error: function () {
                        $('#preloader, #status').fadeOut();
                        Swal.fire({
                            title: '@MyERP.Properties.Resources.ManufacturingOrderNotCreated',
                            text: " ",
                            icon: 'error',
                            showCancelButton: false,
                            confirmButtonText: '@MyERP.Properties.Resources.Ok',
                            confirmButtonColor: '#3085d6'
                        });
                    }
                });
            }
            else { result.dismiss; }
        });
        @*if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToCreateManufacturingOrder')) {
