    function showPRDetials(e) {
        $('#PRBody').empty();

        $('#preloader, #status').fadeIn();
        $.get('/PurchaseRequest/PurchaseRequestDetails/' + e + '?ForView=true').done(function (r) {
            $('#PRBody').append(r.view);
            $('#preloader, #status').fadeOut();
        });

        $('#PRDetails').fadeIn();
    }

    $('#purchaseRequestsModal').on('show.bs.modal', function () {
        $('#purchaseRequestsModal').find('.modal-body').empty().append('<div class="d-flex align-items-center"><div class="spinner-border ml-auto" role="status" aria-hidden="true"></div></div>');
