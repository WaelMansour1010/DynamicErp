    //date
    function zeroPadded(val) {
        if (val >= 10)
            return val;
        else
            return '0' + val;
    }

    function setOrderNum() {
        var doc = $.get('/Order/SetOrderNum?id=' + $('#DepartmentId').val() + '&VoucherDate=' + $('#Date').val()).done(function (r) {
            $('#orderNumber').val(r);
            $('#orderNumbers').val(r.replaceAll("-", ""));
        });
    }

    function CheckForDiscount() {

        //checkif this first service or not
        if ($("#detailsServiceBody").children().length > 1) {
            $("#AllowDiscount").val(true);
        }
        else {
            $("#AllowDiscount").val(false);
        }

    }
    function setServicePrice() {

        CheckForDiscount();
        $.get('/Order/SetServicePrice?serviceId=' + $('#ServiceId').val() + '&AllowDiscount=' + $("#AllowDiscount").val()).done(function (price) {
            if (price > 0 || price < 0)  {
                $('#servicesPrice').val(price);
                $('#servicesPrice').prop('readonly', 'readonly');
                $('#ZeroservicesPrice').val(0);

            }
            else {
                $('#servicesPrice').val(0);
                $('#ZeroservicesPrice').val(1);
                $('#servicesPrice').removeProp('readonly', 'readonly');
            }

        }).fail(function () {
            $('#servicesPrice').val(0);
            $('#ZeroservicesPrice').val(1);
        });
    }
    function setServicePriceForWrittenPrice() {
        $("#WrittenPrice").val($("#servicesPrice").val())
        CheckForDiscount();
        $.get('/Order/setServicePriceForWrittenPrice?serviceId=' + $('#ServiceId').val() + '&AllowDiscount=' + $("#AllowDiscount").val() + '&price=' + $("#servicesPrice").val()).done(function (price) {
            if (price > 0 || price < 0) {

                $('#servicesPrice').val(price);
                $('#servicesPrice').prop('readonly', 'readonly');
            }
            else {
                $('#servicesPrice').val(0);
                $('#servicesPrice').removeProp('readonly', 'readonly');
            }
            setServiceCompanyFeesForWrittenPrice();
        }).fail(function () {
            $('#servicesPrice').val(0);
        });
    }

    function setServiceCompanyFees() {
        CheckForDiscount();
        $.get('/Order/SetServiceCompanyFees?serviceId=' + $('#ServiceId').val() + '&AllowDiscount=' + $("#AllowDiscount").val()).done(function (price) {

            if (price > 0 || price < 0) { $('#companyFees').val(price) }
            else {

                $('#companyFees').val(0);
            }
        }).fail(function () {
            $('#companyFees').val(0);
        });
    }

    function setServiceCompanyFeesForWrittenPrice() {
        CheckForDiscount();
        $.get('/Order/setServiceCompanyFeesForWrittenPrice?serviceId=' + $('#ServiceId').val() + '&AllowDiscount=' + $("#AllowDiscount").val() + '&price=' + $("#WrittenPrice").val()).done(function (price) {
            if (price > 0 || price < 0) {

                $('#companyFees').val(price)
            } else {
                $('#companyFees').val(0);
            }
            setServiceOrderFeesForWrittenPrice();
        }).fail(function () {
            $('#companyFees').val(0);
        });
    }
    function setServiceOrderFees() {
        CheckForDiscount();
        $.get('/Order/SetServiceOrderFees?serviceId=' + $('#ServiceId').val()+'&AllowDiscount='+$("#AllowDiscount").val()).done(function (price) {
            if (price > 0 || price < 0) {

                $('#OrderFeesForServ').val(price)
            }
            else {
                $('#OrderFeesForServ').val(0);
            }
        }).fail(function () {
            $('#OrderFeesForServ').val(0);
            });
    }
    function setServiceOrderFeesForWrittenPrice() {
        CheckForDiscount();
        $.get('/Order/SetServiceOrderFeesForWrittenPrice?serviceId=' + $('#ServiceId').val() + '&AllowDiscount=' + $("#AllowDiscount").val() + '&price=' + + $("#WrittenPrice").val()).done(function (price) {

            if (price > 0 || price < 0) {
                $('#OrderFeesForServ').val(price)
            } else {
                $('#OrderFeesForServ').val(0);
            }
            if ($("#ServiceId").val() == 0 || $("#servicesPrice").val() == 0)
                alert(" البيانات غير مكتملة ");
            else {

                var name = $("#ServiceId").find(":selected").text();
                var price = $("#servicesPrice").inputmask('unmaskedvalue');
                var id = $("#ServiceId").val();
                var OrderFeesForServ = $("#OrderFeesForServ").val();
                var companyFees = $('#companyFees').val();

                var markup = "<tr>\
           <td>\
           <label>" +
                    name +
                    "</label>\
           <input   type='text' class='servId ' value=" +
                    id +
                    " hidden></td>\
          <td>\
            <label>" +
                    price +
                    "</label>\
            <input type='text' class='ServPrice money ' value= " +
                    price +
                    " hidden>\
            <input type='text' class='orderFeesForServ form- control' value=" +
                    OrderFeesForServ +
                    " hidden>\
            <input   type='text' class='companyFees form- control' value=" +
                    companyFees +
                    " hidden></td>\
          <td>\
          <button name='record' class='btnDelete1 btn btn-danger'>حذف</button>\
          </td></tr>";
                $("#detailsServiceBody").append(markup);
                calculateTotalOrderFees();
                calculateServicesCost();
                calculateTotalCost();
            }
            $("#servicesPrice").val('');
            $("#OrderFeesForServ").val('');
            $("#companyFees").val('');
        }).fail(function () {
            $('#OrderFeesForServ').val(0);
        });
    }


