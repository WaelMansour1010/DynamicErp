                                        <label for="inputtext3" class="col-sm-2 control-label"> الصنف </label>
                                        <div class="col-sm-4">
                                            @Html.DropDownList("OrderItemId", null, "اختر", htmlAttributes: new
                                            {
                                                @class = "form-control"@*, @required = "required"*@})
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>
                                        <div class="col-sm-6">
                                            <input type="button" value="إضافة" onclick="GetItemPrice()" class="add-row b btn btn-success" />
                                        </div>
                                    </div>

                                    <div class="table-responsive">
                                        <table class="table table-centered mb-0">
                                            <thead>
                                                <tr>
                                                    <th>الاسم</th>
                                                    <th>السعر</th>
                                                    <th>حذف</th>
                                                </tr>
                                            </thead>
                                            <tbody id="OrderItems">
                                                @if (Model != null && Model.Id > 0)
                                                {
                                                    foreach (var item in Model.OrderItems)
                                                    {
                                                        <tr>
                                                            <td class="tabledit-edit-mode">
                                                                <input type="hidden" class="ItemId form-control tabledit-input form-control-sm" value="@item.ItemId" />
                                                                <label class="ItemArName control-label tabledit-input form-control-sm"> @item.Item.ArName </label>
                                                            </td>
                                                            <td class="tabledit-edit-mode">
                                                                <input class="ItemPrice money form-control tabledit-input form-control-sm col-sm-4" type="text" value="@item.Price" required />
                                                            </td>
                                                            <td>
                                                                <a href="javascript:void(0);" onclick="deleteElement(this)">
                                                                    <i class="fas fa-trash-alt"></i>
                                                                </a>
                                                            </td>
                                                        </tr>
                                                    }
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
