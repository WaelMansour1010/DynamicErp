    function calculateServicesCost() {
        var sum = 0;


        $(".ServPrice").each(function () {

            sum += $(this).inputmask('unmaskedvalue') * 1;

        });

        $("#ServicesCost").val(sum).inputmask({
            alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
        });
        calculateTotalCompanyFees();
    }
    // calc sum of CompanyFees For all services in order
    function calculateTotalCompanyFees() {

        var sum = 0;


        $(".companyFees").each(function () {

            sum += $(this).val() * 1;

        });

        $("#CompanyFees").val(sum).inputmask({
            alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
        });

        $('#TechnicianFees').val($("#ServicesCost").inputmask('unmaskedvalue') * 1 + $("#OrderFees").inputmask('unmaskedvalue') * 1 - $("#CompanyFees").inputmask('unmaskedvalue') * 1);


    }
    // calc sum of orderFees For all services in order
    function calculateTotalOrderFees() {

        var sum = 0;


        $(".orderFeesForServ").each(function () {

            sum += $(this).val() * 1;

        });

        $("#OrderFees").val(sum).inputmask({
            alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
        });


    }
    //calculate Total Cost


    function calculateTotalCost() {

        var sum = 0;


        $(".cost").each(function () {

            sum += $(this).inputmask('unmaskedvalue') * 1;

        });


        $("#TotalMoneyAmount").val(sum + $("#OrderFees").inputmask('unmaskedvalue') * 1).inputmask({
            alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
        });


    }
    var resetFieldToDefault = function () {
        $("#ServiceId").refresh();
    };
</script>
