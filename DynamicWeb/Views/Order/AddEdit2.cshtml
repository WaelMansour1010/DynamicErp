    function CheckItemWarrantyAndInvoiceDate(itemId) {
        $.get('/Order/CheckItemWarrantyAndInvoiceDate?ItemId=' + itemId + '&invoiceId=' + $('#InvoiceNo').val()).done(function (r) {
            var ItemWarranty = r.items[0];
            var Invoice = r.invoice[0];
            if (ItemWarranty != null && Invoice != null && ItemWarranty.HasWarranty == true) {
                var warrantyDays = ItemWarranty.WarrantyDays != null ? parseInt(ItemWarranty.WarrantyDays) : 0;
                var warrantyMonths = ItemWarranty.WarrantyMonths != null ? parseInt(ItemWarranty.WarrantyMonths) : 0;
                var warrantyYears = ItemWarranty.WarrantyYears != null ? parseInt(ItemWarranty.WarrantyYears) : 0;
                var TotalWarrantyDays = warrantyDays + (warrantyMonths * 30) + (warrantyYears * 365); // اجمالي عدد ايام الضمان

                var InvoiceDate = Invoice.VoucherDate != null ? new Date(convertToJavaScriptDate(Invoice.VoucherDate)) : null;
                var Today = new Date();
                let difference = Today.getTime() - InvoiceDate.getTime(); // الفرق بين تاريخ الفاتورة و تاريخ اليوم

                let TotalDays = Math.ceil(difference / (1000 * 3600 * 24));
                // لو الفرق بين تاريخ الفاتورة و تاريخ النهارده اقل من عدد ايام الضمان يبقى "داخل الضمان"
                if (TotalDays < TotalWarrantyDays) {
                    $('#WarrantyTypeId').val(2);
                    $('#WarrantyTypeId').select2();
                }
            }
        });
    }

    function convertToJavaScriptDate(value) {
        if (value === null)
            return null;
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        var month = (dt.getMonth() + 1) < 10 ? '0' + (dt.getMonth() + 1) : (dt.getMonth() + 1);
        var day = dt.getDate() < 10 ? '0' + dt.getDate() : dt.getDate();
        var hours = dt.getHours();
        var minutes = dt.getMinutes();
        var seconds = dt.getSeconds();
        var ampm = hours >= 12 ? 'PM' : 'AM';
        hours = hours % 12;
        hours = hours ? hours : 12; // the hour '0' should be '12'
        hours = hours < 10 ? '0' + hours : hours;
        minutes = minutes < 10 ? '0' + minutes : minutes;
        seconds = seconds < 10 ? '0' + seconds : seconds;
        var strTime = hours + ':' + minutes /*+ ":" + seconds + ' ' + ampm*/;
        return ((dt.getFullYear() + "-" + month + "-" + day) + "T" + strTime);

        //2022 - 01 - 18T20: 23
    }

