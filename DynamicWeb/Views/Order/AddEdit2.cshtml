
@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.Orders;
}
<script src="~/Scripts/SaveAndNew.js"></script>
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
            </div>
            <h4 class="page-title"> @MyERP.Properties.Resources.Orders </h4>
        </div>
    </div>
</div>


<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal needs-validation" role="form">
                        <div class="card">
                            <div class="card-body">
                                @Html.AntiForgeryToken()
                                @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                                <h5 class="header-title">
                                    @MyERP.Properties.Resources.MainData
                                </h5>
                                <div class="form-group row">
                                    <label class=" col-sm-2 control-label"> @MyERP.Properties.Resources.RequestNo </label>
                                    <div class="col-sm-4">
                                        @Html.Editor("OrderNumber", new { htmlAttributes = new { @class = "form-control", @readonly = "readonly", @required = "required", @id = "orderNumber", @placeholder = @MyERP.Properties.Resources.RequestNo, hidden = "hidden" } })
                                        <input id="orderNumbers" class="form-control" placeholder=@MyERP.Properties.Resources.RequestNo required readonly />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label for="Date" class="control-label col-sm-2">@MyERP.Properties.Resources.Date</label>
                                    <div class="col-sm-4">
                                        @Html.Editor("Date", new { htmlAttributes = new { @class = "form-control", type = "datetime-local", @required = "required" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>

                                <div class="form-group row">
                                    <label for="mainServiceCat" class="col-sm-2 control-label"> @MyERP.Properties.Resources.Department </label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("DepartmentId", null, htmlAttributes: new { @class = "form-control", @required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    @*<label for="MaintenanceDate" class="control-label col-sm-2">@MyERP.Properties.Resources.MaintenanceDate</label>
                                        <div class="col-sm-4">
                                            @Html.Editor("MaintenanceDate", new { htmlAttributes = new { @class = "form-control", type = "datetime-local", @required = "required" } })
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>*@
                                </div>
                                <div class="form-group row">
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.WarrantyType</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("WarrantyTypeId", null, null, htmlAttributes: new { @class = "form -control", required = "required", @disabled = "disabled" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label class="control-label col-sm-2 HiddenItem" @*style="display:none;"*@>@MyERP.Properties.Resources.Item</label>
                                    <div class="col-sm-4 HiddenItem" @*style="display:none;"*@>
                                        @Html.DropDownList("ItemId", null, MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form -control" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row CustomerResult">
                                    <label class="PosCustomerDetailsDiv col-sm-2 control-label" for="Phone">@MyERP.Properties.Resources.CustomerTel</label>
                                    <div class="PosCustomerDetailsDiv col-sm-4">
                                        <input type="text" class="form-control" id="pos-customer-mobile" />
                                    </div>
                                    <label class="PosCustomerDetailsDiv col-sm-2 control-label" for="Address">@MyERP.Properties.Resources.CustomerAddress</label>
                                    <div class="PosCustomerDetailsDiv col-sm-4">
                                        <label type="text" class="label control-label" id="pos-customer-address" readonly> </label>
                                    </div>
                                </div>
                                <div class="col-sm-12 CustomerResult" style=" padding:1px;background-color: white;">
                                    <div style="background-color:white;">
                                        <div class="row form-group">
                                            <label class="control-label col-sm-2 PosCustomerIdDiv">@MyERP.Properties.Resources.Customer </label>
                                            <div class="col-sm-4 PosCustomerIdDiv">
                                                <div class="row ">
                                                    <div class="col-sm-10">
                                                        @Html.DropDownList("CustomerId", null, MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form -control" })
                                                        <div class="invalid-feedback">
                                                            @MyERP.Properties.Resources.Select
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-2 pos-customer-model-btn" style="padding: 0;margin-right: -10px;">
                                                        <button class="btn btn-success  btn-sm" id="posCustomerAddBtn" data-toggle="modal"><i class="remixicon-user-add-fill"></i></button>
                                                    </div>
                                                </div>
                                            </div>
                                            <label class="control-label col-sm-2">@MyERP.Properties.Resources.SalesInvoiceNo</label>
                                            <div class="col-sm-4">
                                                <div class="row ">
                                                    <div class="col-sm-8">
                                                        <select class="form-control" id="InvoiceNo"></select>
                                                        <div class="invalid-feedback">
                                                            @MyERP.Properties.Resources.Select
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-4" style="padding: 0;margin-right: -10px;">
                                                        <button class="btn btn-success  btn-sm" id="ItemAddBtn" data-toggle="modal">@MyERP.Properties.Resources.ShowItems</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!----------------------------------- Renter Result ------------------------------------------------->
                                <div class="form-group row SearchResult" style="display:none;">
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.ContractNo</label>
                                    <div class="col-sm-4">
                                        <input type="text" class="form-control" id="ContractNo" value="@(Model!=null && Model.Id>0 && Model.PropertyContract!=null?Model.PropertyContract.DocumentNumber:"")" />
                                        <input type="text" class="form-control" id="ContractId" hidden value="@(Model!=null && Model.Id>0 && Model.PropertyContract!=null?Model.PropertyContractId:0)" />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.UnifiedContractNumber</label>
                                    <div class="col-sm-4">
                                        <input type="text" class="form-control" id="UnifiedContractNumber" value="@(Model!=null&&Model.Id>0&& Model.PropertyContract!=null?Model.PropertyContract.UnifiedContractNumber:"")" />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row SearchResult" style="display:none;">
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.Renter</label>
                                    <div class="col-sm-4">
                                        <input type="text" class="form-control" id="Renter" value="@(Model!=null&&Model.Id>0&& Model.PropertyRenter!=null?Model.PropertyRenter.ArName:"")" />
                                        <input type="text" class="form-control" id="RenterId" hidden value="@(Model!=null&&Model.Id>0&& Model.PropertyRenter!=null?Model.RenterId:0)" />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.Property</label>
                                    <div class="col-sm-4">
                                        <input type="text" class="form-control" id="Property" value="@(Model!=null&&Model.Id>0&& Model.PropertyContract!=null?Model.PropertyContract.Property.ArName:"")" />
                                        <input type="text" class="form-control" id="PropertyId" hidden value="@(Model!=null&&Model.Id>0&& Model.PropertyContract!=null?Model.PropertyContract.PropertyId:0)" />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row SearchResult" style="display:none;">
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.PropertyUnitType</label>
                                    <div class="col-sm-4">
                                        <input type="text" class="form-control" id="UnitTypeId" hidden value="@(Model!=null&&Model.Id>0&& Model.PropertyContract!=null?Model.PropertyContract.PropertyUnitTypeId:0)" />
                                        <input type="text" class="form-control" id="UnitType" value="@(Model!=null&&Model.Id>0&& Model.PropertyContract!=null?Model.PropertyContract.PropertyUnitType.ArName:"")" />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.UnitNo </label>
                                    <div class="col-sm-4">
                                        <input type="text" class="form-control" id="UnitId" hidden value="@(Model!=null&&Model.Id>0&& Model.PropertyContract!=null?Model.PropertyContract.PropertyUnitId:0)" />
                                        <input type="text" class="form-control" id="UnitCode" value="@(Model!=null&&Model.Id>0&& Model.PropertyContract!=null?ViewBag.UnitCode:"")" />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row SearchResult" style="display:none;">
                                    <label class=" col-sm-2 control-label" for="TerminationDate">@MyERP.Properties.Resources.ContractStartDate</label>
                                    <div class="col-sm-4">
                                        <input id="ContractStartDate" class="form-control Gregorian" type="datetime" value="@(Model!=null&&Model.Id>0&& Model.PropertyContract!=null?Model.PropertyContract.ContractStartDate.Value.ToString("yyyy-MM-dd"):"")" />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.ContractEndDate</label>
                                    <div class="col-sm-4">
                                        <input id="ContractEndDate" class="form-control Gregorian" type="datetime" value="@(Model!=null&&Model.Id>0&& Model.PropertyContract!=null?Model.PropertyContract.ContractEndDate.Value.ToString("yyyy-MM-dd"):"")" />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>

                                <!----------------------------------------------------------------------------------------------------------------->

                                <div class="form-group row">
                                    <label class=" col-sm-2 control-label"> @MyERP.Properties.Resources.ProblemDescription </label>
                                    <div class="col-sm-4">
                                        @Html.TextArea("Problems", htmlAttributes: new { @class = "form-control" })
                                    </div>
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.Address</label>
                                    <div class="col-sm-4">
                                        <textarea class="form-control" name="Address" id="AddressId" placeholder="@MyERP.Properties.Resources.Address"> </textarea>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-sm-offset-2">
                    <button onclick="addEdit();" class="btn btn-success" id="save">
                        @MyERP.Properties.Resources.GoToMaintenanceDepartment
                    </button>
                    <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                </div>
            </div>
            <!-------------------------------------------------------------------------------------------------------->
        </div>
    </div>
</div>


<!-------------------------------------------------------------------------------------->
<!-- Modal Section -->
<div id="pos-customer-modal" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true" style="display: none;">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">@MyERP.Properties.Resources.CustomerData</h4>
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">×</button>
            </div>
            <div class="modal-body p-4">
                <div class="form-horizontal needs-validation" role="form">
                    <input hidden id="posCustomerIdInput" name="posCustomerIdInput" />
                    <input hidden id="posCustomerCodeInput" name="posCustomerCodeInput" />
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="ArName" class="control-label">@MyERP.Properties.Resources.ArName</label>
                                <input type="text" class="form-control" id="PosCustomerArName" placeholder=@MyERP.Properties.Resources.ArName>
                            </div>
                            <div class="invalid-feedback">
                                @MyERP.Properties.Resources.Required
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="EnName" class="control-label">@MyERP.Properties.Resources.EnName</label>
                                <input type="text" class="form-control" id="PosCustomerEnName" placeholder=@MyERP.Properties.Resources.EnName>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="Mobile1" class="control-label">@MyERP.Properties.Resources.Mobile 1</label>
                                <input type="text" class="form-control" id="Mobile1" placeholder="@MyERP.Properties.Resources.Mobile 1">
                            </div>
                        </div>
                        @*<div class="col-md-6">
                                <div class="form-group">
                                    <label for="Mobile2" hidden class="control-label">@MyERP.Properties.Resources.Mobile 2</label>
                                    <input hidden type="text" class="form-control" id="Mobile2" placeholder="@MyERP.Properties.Resources.Mobile 2">
                                </div>
                            </div>*@
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="GroupId" class="control-label">@MyERP.Properties.Resources.Group</label>
                                @Html.DropDownList("GroupId", null, null, htmlAttributes: new { @class = "form-control", required = "required" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="IdentityNumber" class="control-label">@MyERP.Properties.Resources.NationalID</label>
                                <input type="text" class="form-control" id="NationalId" placeholder="@MyERP.Properties.Resources.NationalID">
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class=" control-label" for="">@MyERP.Properties.Resources.Country</label>
                                <select class="form-control" id="GovernorateId" name="GovernorateId"></select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="control-label" for="">@MyERP.Properties.Resources.City</label>
                                <select class="form-control" id="CityId" name="CityId"></select>
                            </div>
                        </div>
                    </div>
                    @*<div class="row">
                            <div class="col-12">
                                <div class="form-group">
                                    <label class="control-label" for="">@MyERP.Properties.Resources.District</label>
                                    <select class="form-control" id="AreaId" name="AreaId"></select>
                                </div>
                            </div>
                        </div>*@
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group">
                                <label for="Address" class="control-label">@MyERP.Properties.Resources.Address</label>
                                <input type="text" class="form-control" id="PosCustomerAddress" placeholder=@MyERP.Properties.Resources.Address>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group no-margin">
                                <label for="Notes" class="control-label">@MyERP.Properties.Resources.Notes</label>
                                <textarea class="form-control" id="PosCustomerNotes" placeholder=@MyERP.Properties.Resources.Notes></textarea>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary waves-effect" data-dismiss="modal">@MyERP.Properties.Resources.Close</button>
                <button type="button" class="btn btn-info waves-effect waves-light" onclick="addPosCustomer();">@MyERP.Properties.Resources.Save</button>
            </div>
        </div>
    </div>
</div>

<div id="ItemModal" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true" style="display: none;">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">@MyERP.Properties.Resources.Item</h4>
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">×</button>
            </div>

            <div class="modal-body">
                <table class="table table-condensed">
                    <thead>
                        <tr>
                            <th>@MyERP.Properties.Resources.ItemName</th>
                            <th>@MyERP.Properties.Resources.Add</th>
                        </tr>
                    </thead>
                    <tbody id="OrderItems"></tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-danger waves-effect" data-dismiss="modal">@MyERP.Properties.Resources.Close</button>
            </div>

        </div>
    </div>
</div>

<!---------------------------------------- Search Modal ------------------------------------------------->
<div class="modal fade" id="SearchModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:700px;" role="document">
        <div class="modal-content">
            <div class="modal-header">
                @*<h5 class="modal-title" id="exampleModalLongTitle"> @MyERP.Properties.Resources.UseMultiWarehousesToExchangeItems</h5>*@
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-horizontal needs-validation" role="form">

                    <div class="form-group row">
                        <div class="col-sm-6">
                            <input type="radio" name="CustomerOrRenter" checked="checked" value="1">
                            <label class="control-label">@MyERP.Properties.Resources.Customer</label>
                        </div>
                        <div class="col-sm-6">
                            <input type="radio" name="CustomerOrRenter" value="2">
                            <label class="control-label">@MyERP.Properties.Resources.Renter</label>
                        </div>
                    </div>

                    <div class="form-group row RenterSelected" style="display:none;">
                        <div class="col-sm-6">
                            <input id="SearchText" class="form-control" type="text" placeholder="@MyERP.Properties.Resources.Search" />
                        </div>
                        <div class="col-sm-6">
                            <button type="button" onclick="GetPropertyContractTerminationDetails()" class="btn btn-primary"><i class="fa fa-search"></i></button>
                        </div>
                    </div>
                    <div class="table-responsive RenterSelected" style="overflow-y: scroll;display: none;">
                        <table class="table table-centered mb-0">
                            <thead>
                                <tr>
                                    <td>
                                        @MyERP.Properties.Resources.Renter
                                    </td>
                                    <td>
                                        @MyERP.Properties.Resources.Mobile
                                    </td>
                                    <td>
                                        @MyERP.Properties.Resources.ContractNo
                                    </td>
                                    <td>
                                        @MyERP.Properties.Resources.Property
                                    </td>
                                    <td>
                                        @MyERP.Properties.Resources.PropertyUnitType
                                    </td>
                                    <td>
                                        @MyERP.Properties.Resources.UnitNo
                                    </td>
                                    <td> </td>
                                </tr>
                            </thead>
                            <tbody id="ShowResultDetails">
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-dismiss="modal">@MyERP.Properties.Resources.Ok</button>
                <button type="button" class="btn btn-secondary" data-dismiss="modal">@MyERP.Properties.Resources.Close</button>
            </div>
        </div>
    </div>
</div>
<!---------------------------------------- End Of Modal Section ------------------------------------------------->
<!------------------------------------------------------------------------------------------------------->

<script>

    //--------------- Variables Declarations -------------------//
    let posCustomers = [];


    //*********************************************************//
    //--------------- Ready Function -------------------//
    $(document).ready(function () {
        if ('@ViewBag.IsPropertyManagement'== 'True') {
            $('#SearchModal').modal('show');
        }

        $.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
            $("input[type|='datetime-local']").prop('min', r.PeriodStart).prop('max', r.PeriodEnd);
        });

        setOrderNum();
        //appendPosCustomerOptions(true);
        GetCustomerSalesInvoice();
        getGovernorates();
        getCities();
        getAreas();
        getPosCustomers()
        //    .done(function () {
        //    $('#CustomerId').trigger('change');
        //});
    });
    //*********************************************************//
    //--------------- Event Functions -------------------//
    $(document).on('change', 'input:radio[name=CustomerOrRenter]:checked', function () {
        if ($(this).val() == 2)// Renter
        {
            $('.RenterSelected').show();
            $('#CustomerId').val('');
        }
        else {
            $('.RenterSelected').hide();
            $('#ContractId').val('');
            $('#RenterId').val('');

        }
    });

    $('#CustomerId').on('change', function () {
        let customer = posCustomers.filter(function (i) { return i.Id == $('#CustomerId').val() })[0];
        $('#pos-customer-mobile').val(customer.Mobile);
        $('#pos-customer-address').text(customer.Address);
        GetCustomerSalesInvoice();
    });
    $(document).on('click', '#posCustomerAddBtn', function () {
        getGovernorates();
        $('#pos-customer-modal').modal("show");
    });
     $('#InvoiceNo').on('change', function () {
         GetCustomerSalesInvoiceDetails();
     });
    $(document).on('click', '#ItemAddBtn', function () {
        $('#ItemModal').modal("show");
    });
    $('#ItemId').on('change', function () {
        $('#InvoiceNo').val(0);
        $('#InvoiceNo').select2();
        $('#OrderItems').empty();
    });
    $(document).on('keydown', '#pos-customer-mobile', function (e) {
        if (e.which == 13 || e.keyCode == 13) {
            let elem = $(this);
            let mobileNo = elem.val();
            GetCustomerByIdentityNumberOrMobileNumber(null, mobileNo);
        }
    });
    $(document).on('change', '#DepartmentId', function () {
        setOrderNum();
    });
    $(document).on('change', '#Date', function () {
        setOrderNum();
    });
    //*********************************************************//
     //--------------- Other Functions -------------------//
     function AddToDetails(contractId) {
        $('#preloader, #status').fadeIn();
        $('#PropertyContractTerminationDetails').empty();
        var contract = ContractDetails.filter(function (i) { return i.ContractId == contractId })[0];
        if (contract != null) {
            $('#SearchModal').modal('hide');
            $('.SearchResult').show();
            $('.CustomerResult').hide();
            $('#CustomerId').attr('required',false);
            $('#ContractId').val(contract.ContractId);
            contract.ContractEndDate = contract.ContractEndDate != null ? convertToJavaScriptDate(contract.ContractEndDate) : '';
            contract.ContractStartDate = contract.ContractStartDate != null ? convertToJavaScriptDate(contract.ContractStartDate) : '';
            $('#ContractEndDate').val(contract.ContractEndDate);
            $('#ContractStartDate').val(contract.ContractStartDate);
            $('#ContractNo').val(contract.ContractNo);
            $('#UnifiedContractNumber').val(contract.UnifiedContractNumber);
            $('#PropertyId').val(contract.PropertyId);
            $('#Property').val(contract.Property);
            $('#RenterId').val(contract.RenterId);
            $('#Renter').val(contract.Renter);
            $('#UnitId').val(contract.UnitId);
            $('#UnitCode').val(contract.UnitCode);
            $('#UnitTypeId').val(contract.UnitTypeId);
            $('#UnitType').val(contract.UnitType);
            //for (var i = 0; i < contract.Details.length; i++) {
            //    contract.Details[i].BatchDate = contract.Details[i].BatchDate != null ? convertToJavaScriptDate(contract.Details[i].BatchDate) : "";
            //    var HijryBatchDate = new Intl.DateTimeFormat('ar-sa').format(new Date(contract.Details[i].BatchDate)).toString();
