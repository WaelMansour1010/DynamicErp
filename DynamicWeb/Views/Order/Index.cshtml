@model IEnumerable<MyERP.Models.Order>


@{
    ViewBag.Title = "الطلبات";
}

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <a class="btn btn-info" href="@Url.Action("AddEdit2")" role="button" style="float:left;">إضافة جديد</a>
            </div>
            <h4 class="page-title">الطلبات</h4>
        </div>
    </div>
</div>
<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal" role="form">
                        <div class="form-group row">
                            <div class="col-sm-2">
                                @Html.DropDownList("StatusId", null, "إختر الحالة", htmlAttributes: new { @class = "form-control" })
                            </div>
                            <div class="col-sm-2">
                                @Html.DropDownList("EmployeeId", null, "إختر الفني ", htmlAttributes: new { @class = "form-control" })
                            </div>
                            <label for="DateFrom" class="col-sm-1 control-label">التاريخ من</label>
                            <div class="col-sm-3">
                                <input type="datetime-local" id="DateFrom" class="form-control" value="@Html.Raw(ViewBag.DateFrom)">
                            </div>
                            <label for="DateTo" class="col-sm-1 control-label">التاريخ إلى</label>
                            <div class="col-sm-3">
                                <input type="datetime-local" id="DateTo" class="form-control" value="@Html.Raw(ViewBag.DateTo)">
                            </div>
                        </div>
                        <div class="form-group row">
                            <div class="col-sm-4">
                                <input type="text" class="form-control searchtxt" value="@Html.Raw(ViewBag.searchWord)" placeholder="بحث">
                            </div>
                            <div class="col-sm-2">
                                <button type="button" class="btn btn-success btnSearch" onclick="searchWord = $('.searchtxt').val(); paging();">
                                    <i class="fa fa-search"></i>
                                </button>
                                <button type="button" class="btn btn-info btnSearch" onclick="pageNo = 1; searchWord=''; paging();">
                                    <i class="fe-refresh-ccw"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-12">
                    <div class="table-responsive">
                        <table class="table table-striped table-centered mb-0">
                            <thead>
                                <tr>
                                    <th>رقم الطلب</th>
                                    <th>التاريخ </th>
                                    <th>العميل</th>
                                    <th>الفنى </th>
                                    <th>الحالة </th>

                                    <th>الاجمالى</th>
                                    <th>تعديل</th>

                                    <th>حذف</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            @*@Html.DisplayFor(modelItem => item.OrderNumber)*@
                                            @Html.Raw(item.OrderNumber.ToString().Replace("-", ""))
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.Date)
                                        </td>

                                        <td>
                                            @Html.DisplayFor(modelItem => item.Customer.ArName)
                                        </td>
                                        <td>
                                            @*@Html.DisplayFor(modelItem => item.Techanician.ArName)*@
                                            @Html.DisplayFor(modelItem => item.Employee.ArName)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.OrderStatu.ArName)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.TotalMoneyAmount)
                                        </td>

                                        <td>
                                            <a href="@Url.Action("AddEdit","Order",new { id=item.Id })" onclick="$('#preloader, #status').fadeIn();">
                                                <i class="fa fa-edit"></i>
                                            </a>
                                        </td>
                                        <td>
                                            <a href="javascript:void(0);" onclick="Delete(@item.Id)">
                                                <i class="fas fa-trash-alt"></i>
                                            </a>

                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div style="text-align:center;margin-bottom: 50px;">

    <div class="form-group row">
        <div class="col-sm-4">
            <select id="ShowByPage" class="form-control" style="width:70px;float:left;" onchange="paging()">
                <option value="10">10</option>
                <option value="30">30</option>
                <option value="50">50</option>
                <option value="100">100</option>
                <option value="200">200</option>
                <option value="@ViewBag.Count">الكل</option>
            </select>
            <span style="font-size:12px;float:right;"> عدد النتائج : <span id="RowsCount">@ViewBag.Count</span></span>
        </div>
        <div class="col-sm-2">
            <lablel class="col-sm-8"> رقم الصفحة: </lablel>
        </div>
        <div class="col-sm-2">
            <select id="pagination" class="pagination form-control" style="width:70px;float:left;">
            </select>
        </div>
    </div>
</div>


<script>
    var pageNo = 1;
    var searchWord = '@Html.Raw(ViewBag.searchWord)';
    $('#ShowByPage').val(@ViewBag.wantedRowsNo);
    function paging() {
        var link = '/Order/Index?' + 'pageIndex=' + pageNo + '&wantedRowsNo=' + $('#ShowByPage').val() + '&searchWord=' + searchWord + '&statId=' + $('#StatusId').val() + '&EmployeeId=' + $('#EmployeeId').val() + '&DateFrom=' + $('#DateFrom').val() + '&DateTo=' + $('#DateTo').val();
        window.location.replace(link);
    }

    function setPages() {
        var count =@ViewBag.Count;
        for (var i = 0; i < Math.ceil(count / $('#ShowByPage').val()); i++)
            $('#pagination').append('<option onchange="pageNo=' + (i + 1) + '; paging();" id="pg' + (i + 1) + '">' + (i + 1) + '</option>');
    }

    setPages();
   $('#pg' +@ViewBag.PageIndex).attr('selected', 'selected')

    $('#pagination').on('change', function () {
        pageNo = $('#pagination').val();
         paging();
    })

    function Delete(id) {
        if (confirm('هل تريد الحذف؟')) {

            $('#preloader, #status').fadeIn();
            $.ajax(
                {

                    url: '/Order/Delete',
                    type: 'POST',
                    data: {
                        "Id": id,
                    },
                    error: function (e) {

                    },
                    success: function (r) {
                        if (r == 'true') {
                            window.location.reload();
                        }
                    }
                });
        }
    }


</script>
