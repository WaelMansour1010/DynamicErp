    // Test
    function drawTablesRow(arr) {

        var tablesTbl = $("#TablesDiv");
        var tr = '<div class="col-sm-2" style="text-align:center">';
        for (var i = 0; i < arr.length; i++) {

            var imgPath = arr[i].IsWait == true ? "/assets/images/dinning-table-yellow.png" : arr[i].IsReserved ? "/assets/images/dinning-table-red.svg" : "/assets/images/dinning-table-blue.svg";
            var insertWaiter = '<div style="text-align:center" class="form-group waiterdiv"><label class="control-label waitertxt">' + arr[i].WaitersName + ' </label></div > ';
            @*< div > <input type="text" autocomplete="false" class="form-control InsertWaiter" name="InsertWaiter" for="InsertWaiter" placeholder="@MyERP.Properties.Resources.Waiter" /></div>*@
            var Cancel = '<button class="btn btn-danger" data-toggle="tooltip" data-placement="top" title="'+'@MyERP.Properties.Resources.CancelReservation'+'" style="margin:5px;" onclick="Cancel(this)" tableId="' + arr[i].Id + '" invoiceId="' + (arr[i].LastSalesInvoice != null ? arr[i].LastSalesInvoice.Id : "") + '">X</button>';
            var changeTable = '<button class="btn btn-purple" data-toggle="tooltip" data-placement="top" title="'+'@MyERP.Properties.Resources.changeTable'+'" style="margin:5px;" onclick="ChangeTable(this)" tableId="' + arr[i].Id + '" invoiceId="' + (arr[i].LastSalesInvoice != null ? arr[i].LastSalesInvoice.Id : "") + '"><i class="fe-refresh-ccw"></i></button>';
            var reservedOptions = '<div style="text-align:center;">' + (arr[i].LastSalesInvoice != null&&"@ViewBag.Iswaiter"!="True" ? '<button class="btn btn-info printReceiptBtn col-sm-3" data-toggle="tooltip" data-placement="top" title="' + '@MyERP.Properties.Resources.PrintReceipt' + '" tableName="' + arr[i].Code + '-' + arr[i].ArName + '" tableId= "' + arr[i].Id + '" invoiceId ="' + (arr[i].LastSalesInvoice != null ? arr[i].LastSalesInvoice.Id : null) + '"><i class="remixicon-printer-fill"></i></button>' : "") +
                '<button class="btn btn-success addOrderBtn col-sm-3" data-toggle="tooltip" data-placement="top" title="'+'@MyERP.Properties.Resources.AddOrder'+'" payInvoice=false tableName="' + arr[i].Code + '-' + arr[i].ArName +'" tableId="' + arr[i].Id + '" invoiceId="' + (arr[i].LastSalesInvoice != null ? arr[i].LastSalesInvoice.Id : "") + '"><i class="fas fa-plus"></i></button>'
                + (arr[i].LastSalesInvoice != null && "@ViewBag.Iswaiter" != "True" ? '<button class="btn btn-primary payTableInvoice col-sm-3" data-toggle="tooltip" data-placement="top" title="' + '@MyERP.Properties.Resources.PayInvoice' + '" payInvoice=true tableName="' + arr[i].Code + '-' + arr[i].ArName + '" tableId="' + arr[i].Id + '" invoiceId="' + (arr[i].LastSalesInvoice != null ? arr[i].LastSalesInvoice.Id : "") + '"><i class="fas fa-money-bill"></i></button>' : "") + '</div><div style="text-align:center">' + ("@ViewBag.Iswaiter" != "True" ? changeTable : "") + (arr[i].LastSalesInvoice == null ? Cancel : "") +'</div> <div style="text-align:center;">' + '@MyERP.Properties.Resources.OccupancyTime ' + secondsToHMS(Math.abs(new Date(Date.now()) - convertToJavaScriptDate(arr[i].ReservationDateTime)) / 1000) + '</div>';
            reservedOptions = reservedOptions  + '<div style="text-align:center;">' + '@MyERP.Properties.Resources.Total ' + (arr[i].LastSalesInvoice != null && arr[i].LastSalesInvoice != undefined ? arr[i].LastSalesInvoice.TotalAfterTaxes : 0) + '</div>' + insertWaiter ;
            tr += '<div class="form-group reserve" table-id="' + arr[i].Id + '" tableName="' /*+ arr[i].Code + '-'*/ + arr[i].ArName + '" is-reserved=' + arr[i].IsReserved + ' style="text-align:center"><img id="TableStatusImg" class="m-2 img-responsive" style="width:15vh;" src="' + imgPath + '" /><div style="text-align:center; font-size:large;">' /*+arr[i].Code+'-'*/ + arr[i].ArName + '</div>';
            tr = tr + (arr[i].IsReserved ? reservedOptions + '</div></div>' : '</div></div>');
        }
        tr += '</div>';
        tablesTbl.append(tr);
    }

    function ChangeTable(e) {
        var OldTableId = $(e).attr('tableId');
        $('#OldTableId').val(OldTableId);
        var OldInvoiceId = $(e).attr('invoiceId');
        $('#OldInvoiceId').val(OldInvoiceId);
        $("#TablesDiv").empty();
        GetTableByHallId(true,);
        $('#PosCustomerId').trigger('change');
    }
    function Cancel(e) {
        var tableId = $(e).attr('tableId');
        $.get('/PointOfSale/CancelTableReservation?id=' + tableId).done(function (r) {
            if (r == true) {
                Swal.fire({
                    title: '@MyERP.Properties.Resources.Saved',
                    text: " ",
                    icon: 'success',
                    showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    confirmButtonColor: '#3085d6'
                });
                $('#tablesModal').modal("hide");
            }
            else {
                Swal.fire({
                    title: '@MyERP.Properties.Resources.AnErrorOccurredTryAgain',
                    text: " ",
                    icon: 'error',
                    showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    confirmButtonColor: '#3085d6'
                });
            }
        });
    }

    //$("#TablesTable").on('click', '.reserve', function () {
    $("#TablesDiv").on('click', '.reserve', function () {
        var table = $(this);
        var OldInvoiceId = $("#OldInvoiceId").val();
        var NewTableId = table.attr("table-id");
        var OldTableId = $("#OldTableId").val();
        if (table.attr("is-reserved") != "true") {
            //$('#CustomerType>option:eq(2)').attr('selected', true);
            Swal.fire({
                title: '@MyERP.Properties.Resources.AreYouSureYouWantToReserveThisTable',
                text: " ",
                icon: 'info',
                showCancelButton: true,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                cancelButtonText: '@MyERP.Properties.Resources.Cancel',
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '/Helper/ReserveTable?Id=' + table.attr("table-id") + '&OldTableId=' + OldTableId + '&OldInvoiceId=' + OldInvoiceId,
                        method: 'POST',
                        success: function () {
                            $('#tablesModal').modal("hide");
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.Reserved',
                                text: " ",
                                icon: 'success',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                            selectTable(table.attr("tableName"), table.attr("table-id"));
                            checkCustomerType();
                        },
                        error: function () {
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.NotReserved',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                        }
                    });
                }
                else { result.dismiss; }
            });
            @*if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToReserveThisTable')) {
                $.ajax({
                    url: '/Helper/ReserveTable?Id=' + table.attr("table-id"),
                    method: 'POST',
                    success: function () {
                        $('#tablesModal').modal("hide");
                        alert('@MyERP.Properties.Resources.Reserved');
                        selectTable(table.attr("tableName"), table.attr("table-id"));
                        checkCustomerType();
                    },
                    error: function () {

                        alert('@MyERP.Properties.Resources.NotReserved');
                    }
                });
            }*@
        }
    });

    function print(id) {

        @*window.open('@Url.Action("CashierInvoice/10", "Report")', "PrintingFrame");*@
        //window.open("/Report/CashierInvoice/" + id,"_blank");
        ////     window.open("/Report/CashierInvoice/" + r.id + "?print=true");
        //var frameElement = document.getElementById("FrameToPrint");

        //window.onafterprint = function (e) {
        //    window.location.replace("/PointOfSale/AddEdit");
        //};

        //frameElement.addEventListener("load", function (e) {
        //    if (frameElement.contentDocument.contentType !== "text/html")
        //        frameElement.contentWindow.print();
        //});

        var frameElement = window.open("/Report/CashierInvoice/" + id + "?print=true","_blank");
        frameElement.addEventListener("load", function (e) {
            if (frameElement.document.contentType !== "text/html")
                frameElement.print();
            if (UseThermalPrinterToPrintInvoices != 'True') {
                window.location.replace("/PointOfSale/AddEdit");
            }
        })
    }
    function Delete(id) {
        Swal.fire({
            title: '@MyERP.Properties.Resources.AreYouSureYouWantToDelete',
            text: " ",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: '@MyERP.Properties.Resources.Ok',
            cancelButtonText: '@MyERP.Properties.Resources.Cancel',
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                $('#preloader, #status').fadeIn();
                $.ajax(
                    {
                        url: '/SalesInvoice/Delete',
                        type: 'POST',
                        data: {
                            "Id": id,
                        },
                        error: function (e) {
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.DeleteDoesNotSucceeded',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                            $('#preloader, #status').fadeOut();
                        },
                        success: function (r) {
                            if (r == 'true') {
                                getSalesInvoices();
                            }
                            else if (r == 'Cannot Be Deleted') {
                                $('#preloader, #status').fadeOut();
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.TheInvoiceHasBeenGeneratedAndCannotBeDeleted',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                            }
                            else {
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.DeleteDoesNotSucceeded',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                            }
                            $('#preloader, #status').fadeOut();
                        }
                    });
            }
            else { result.dismiss; }
        });


