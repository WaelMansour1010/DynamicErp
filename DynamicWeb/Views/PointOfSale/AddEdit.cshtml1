    function SendToKitchen() {
        addEdit(null,"SendToKitchen");
    }
    function Payinvoice() {
        var _PaymentAmount = $('.PaymentAmount').eq(1).val();
        /*$('#TotalAfterTaxes').inputmask('unmaskedvalue') * 1 == $('#Paid').inputmask('unmaskedvalue') * 1 && */
