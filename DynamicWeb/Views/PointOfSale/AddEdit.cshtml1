    </div>
</div>-->
@if (Model != null)
{
    @Html.HiddenFor(x => x.Id)
    @Html.HiddenFor(x => x.IsClosed)
    @Html.HiddenFor(x => x.IsCollected)
    @Html.HiddenFor(x => x.WaiterId)
}
@*<input type="hidden" id="CashBoxId" value="@ViewBag.CashBoxId" />*@
<div class="row">

    @*<div class="card-box">*@
    @*<div class="form-horizontal needs-validation" role="form">

        </div>*@
    <div class="col-sm-6" style=" padding: 1px;background-color: white;">
        <div class="form-group row" style="margin-bottom:0">
            @*<label class=" col-sm-1 control-label" for="DocumentNumber">@MyERP.Properties.Resources.InvoiceNo</label>
                <div class="col-sm-1">
                    @Html.EditorFor(model => model.DocumentNumber, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly", placeholder = @MyERP.Properties.Resources.DocNo, required = "required" } })
                    <div class="invalid-feedback">
                        @MyERP.Properties.Resources.Required
                    </div>
                </div>
                <label for="VoucherDate" class="control-label col-sm-1">@MyERP.Properties.Resources.InvoiceDate</label>
                <div class="col-sm-2">
                    <input id="VoucherDate" name="VoucherDate" class="form-control" type="datetime-local" value="@ViewBag.VoucherDate" required readonly />
                    <div class="invalid-feedback">
                        @MyERP.Properties.Resources.EnterDate
                    </div>
                </div>

                <label for="CustomerType" class="control-label col-sm-1">@MyERP.Properties.Resources.CustomerType </label>
                <div class="col-sm-1">
                    @Html.DropDownList("CustomerType", null, htmlAttributes: new { @class = "form-control", @required = "required", @disabled = "disabled" })
                </div>*@

            @*Old code
                <label for="VendorOrCustomerId" class="control-label col-sm-1">@MyERP.Properties.Resources.Customer </label>*@



            @*<div id="tableNameDiv">*@

            @*</div>*@

        </div>
        <div style="background-color:white;">
            <div class="row form-group " style="margin-bottom:0">


                @*<label for="DepartmentId" class="control-label col-sm-1">@MyERP.Properties.Resources.Branch</label>
                    <div class="col-sm-1">
                        @Html.DropDownList("DepartmentId", null, htmlAttributes: new { @class = "form-control", @required = "required" })
                        <div class="invalid-feedback">
                            @MyERP.Properties.Resources.Select
                        </div>
                    </div>

                    <label for="WarehouseId" class="control-label col-sm-1">@MyERP.Properties.Resources.WareHouse</label>
                    <div class="col-sm-2">
                        @Html.DropDownList("WarehouseId", null, htmlAttributes: new { @class = "form-control", @required = "required" })
                        <div class="invalid-feedback">
                            @MyERP.Properties.Resources.Select
                        </div>
                    </div>*@

                @*<label class="control-label col-sm-6" ></label>
                    <label class="control-label col-sm-6" id="customer-mobile"></label>*@


                <label class="control-label col-sm-1 VendorOrCustomerIdDiv">@MyERP.Properties.Resources.Customer </label>
                <label class="control-label col-sm-1 PosCustomerIdDiv">@MyERP.Properties.Resources.Customer </label>
                <div class="col-sm-2 VendorOrCustomerIdDiv">
                    <div class="row ">
                        <div class="col-sm-10">
                            <select class="form-control" id="VendorOrCustomerId">
                                @if (Model != null)
                                {
                                    <option value="@Model.VendorOrCustomerId"></option>
                                }
                            </select>

                            @if (Model != null)
                            {
                                <input hidden class="VendorOrCustomerId" value='@Model.VendorOrCustomerId' />

                            }
                            else
                            {
                                <input hidden class="VendorOrCustomerId" />

                            }

                            <div class="invalid-feedback">
                                @MyERP.Properties.Resources.Select
                            </div>
                        </div>
                        <div class="col-sm-2 customer-model-btn" style="padding: 0;margin-right: -10px;">
                            <button class="btn btn-success btn-sm" data-toggle="modal" data-target="#customer-modal"><i class="remixicon-user-add-fill"></i></button>
                        </div>
                    </div>
                </div>

                <div class="col-sm-3 PosCustomerIdDiv">
                    <div class="row ">
                        <div class="col-sm-10">
                            <select class="form-control" disabled id="PosCustomerId">
                                @if (Model != null)
                                {
                                    <option value="@Model.PosCustomerId"></option>
                                }
                            </select>

                            <div class="invalid-feedback">
                                @MyERP.Properties.Resources.Select
                            </div>
                        </div>

                        <div class="col-sm-2 pos-customer-model-btn" style="padding: 0;margin-right: -10px;">
                            <button class="btn btn-success  btn-sm" id="posCustomerAddBtn" data-toggle="modal"><i class="remixicon-user-add-fill"></i></button>
                        </div>
                    </div>
                </div>

                <label class="control-label tableDiv col-sm-1">@MyERP.Properties.Resources.Table </label>
                <div class="col-sm-3 tableDiv">
                    @if (Model != null)
                    {
                        if (Model.Table != null)
                        {
                            <input class="form-control" readonly id="tableName" value="@Html.Raw((Model.Table.Code != null ? Model.Table.Code : "") + "-" + (Model.Table.ArName != null ? Model.Table.ArName : ""))" />
                            <input class="form-control" readonly id="selectedTableId" value="@Model.Table.Id" hidden />
                        }

                    }
                    else
                    {
                        <input class="form-control" readonly id="tableName" value='@ViewBag.SelectedTableName' />
                        <input class="form-control" readonly id="selectedTableId" value='@ViewBag.SelectedTableId' hidden />
                    }
                </div>
                <label class=" VendorOrCustomerDetailsDiv col-sm-1 ml-2 control-label" for="Phone">@MyERP.Properties.Resources.CustomerTel</label>
                <div class=" VendorOrCustomerDetailsDiv col-sm-3">
                    <input type="text" class="form-control" id="customer-mobile" readonly />
                </div>
                <label class="VendorOrCustomerDetailsDiv col-sm-1 control-label" for="Address">@MyERP.Properties.Resources.CustomerAddress</label>
                <div class="VendorOrCustomerDetailsDiv col-sm-3">
                    <input type="text" class="form-control" id="customer-address" readonly />
                </div>
                <label class="PosCustomerDetailsDiv col-sm-2 ml-2 control-label" for="Phone">@MyERP.Properties.Resources.CustomerTel</label>
                <div class="PosCustomerDetailsDiv col-sm-3">
                    <input type="text" class="form-control" id="pos-customer-mobile" />
                </div>
            </div>
            <div class="form-group row">
                <label class="PosCustomerDetailsDiv col-sm-2 control-label" for="Address">@MyERP.Properties.Resources.CustomerAddress</label>
                <div class="PosCustomerDetailsDiv col-sm-3">
                    <label type="text" class="label control-label" id="pos-customer-address" readonly></label>

                </div>
            </div>
        </div>

        <div id="ItemGropDiv">

            <div class="row">

                <div id="item-groups" style="width:100%">
                    @*@Html.Partial("ItemGroups")*@
                </div>

            </div>
        </div> <!-- End of ItemGroupDiv -->
        @if (ViewBag.ShowCashBoxBalance != false)
        {
            <div class="row form-group">
                <label class="control-label">@MyERP.Properties.Resources.CashBoxBalance</label>
                <div class="col-sm-2">
                    <input class="form-control form-control-sm" id="cashBoxBalance" readonly />
                </div>
            </div>
        }
        <div class="row form-group">


        </div>

    </div>

    <div class="col-sm-6 " style="background-color: white;">

        <div class="row ml-1 mr-1 mb-1" style="border-style: solid;
        border-color: #e7eaed;
        border-width: 1px;
        border-radius: 5px;">
            <button class="btn btn-info invoiceInfoBtn ml-1 mr-1">@MyERP.Properties.Resources.InvoiceInfo</button>
            @if (ViewBag.IsCashier == true)
            {

                <a class="btn btn-success ml-1 mr-1" href="@Url.Action("AddEdit", "PosSalesReturn",new { accessoryReturn =true})" target="_blank" role="button">@MyERP.Properties.Resources.AccessoriesReturn <i class="fa fa-undo"></i></a>
                <a class="btn btn-success ml-1 mr-1" href="@Url.Action("AddEdit", "PosSalesReturn")" target="_blank" role="button">@MyERP.Properties.Resources.Return <i class="fa fa-undo-alt"></i></a>

                <a class="btn btn-success ml-1 mr-1" href="/PointOfSale/AddEdit" target="_blank" role="button">@MyERP.Properties.Resources.NewInvoice <i class="fa fa-receipt"></i></a>
                @*<a class="btn btn-success" href="@Url.Action("AddEdit")" target="_blank" role="button">@MyERP.Properties.Resources.NewInvoice <i class="fa fa-receipt"></i></a>*@
                if (ViewBag.AllowSalesOrderInPos == true)
                {
                    <a class="btn btn-success  ml-1 mr-1" href="@Url.Action("Panel","SalesOrder")" target="_blank" role="button">@MyERP.Properties.Resources.NewReservationVoucher <i class="fa fa-file-invoice"></i></a>
                }
                <a class="btn btn-danger ml-1 mr-1" href="@Url.Action("AddEdit", "PosClosing")" role="button">@MyERP.Properties.Resources.ShiftClosing <i class="fa fa-window-close"></i></a>

            }

        </div>

        <!-- Invoice Div -->
        <div id="InvoiceDiv" style="min-height: 69%;
        max-height: 70%;
        overflow-y: scroll;
        border-style: solid;
        border-color: #e7eaed;
        border-width: 1px;
        border-radius: 5px;">
            <div class="card m-1 p-1">

                <div class="form-horizontal needs-validation" role="form">
                    <div class="form-group row d-flex justify-content-between" style="height:fit-content">

                        @*<div class="col-6">*@

                        <!-- Is Cashier Buttons -->
                        <!--*********************************************-->
                        <!--<div class="row ml-1 mr-1">
                        if (ViewBag.IsCashier == true)
                        {
                            <a class="btn btn-success ml-1 mr-1" href="Url.Action("AddEdit")" target="_blank" role="button">@MyERP.Properties.Resources.NewInvoice <i class="fa fa-receipt"></i></a>-->
                        @*<a class="btn btn-success" href="@Url.Action("AddEdit")" target="_blank" role="button">@MyERP.Properties.Resources.NewInvoice <i class="fa fa-receipt"></i></a>*@
                        <!--if (ViewBag.AllowSalesOrderInPos == true)
                                {
                                    <a class="btn btn-success  ml-1 mr-1" href="@Url.Action("Panel","SalesOrder")" target="_blank" role="button">@MyERP.Properties.Resources.NewReservationVoucher <i class="fa fa-file-invoice"></i></a>
                                }
                                <a class="btn btn-danger ml-1 mr-1" href="@Url.Action("AddEdit", "PosClosing")" role="button">@MyERP.Properties.Resources.ShiftClosing <i class="fa fa-window-close"></i></a>

                            }
                        </div>-->
                        @*</div>*@

                        <!--<canvas id="canvas" class="col-3" style="max-width: 20vh; max-height: 20vh;" width="75" height="75">
                        </canvas>


                        <img id="Logo" src="@ViewBag.Logo" class="card-img col-3" alt="Logo" style="background-color: #2494be;max-width: 20vh;max-height: 20vh;">-->
                        @*<img id="Logo" src="~/assets/images/EUU6kHiUMAAcOZs.png" class="card-img col-3" alt="Logo" style="        background-color: #2494be;max-width: 20vh;max-height: 20vh;">*@

                    </div>
                    <div class="form-group">
                        <input id="SearchText" class="form-control col-sm-12" placeholder="@MyERP.Properties.Resources.Search .." />
                    </div>


                    <div class="table-responsive">
                        <table class="table table-centered table-sm mb-0">
                            <thead>
                            <tr style="background-color: #37cde6; color: white">
                                <th>@MyERP.Properties.Resources.Details</th>
                                <th>@MyERP.Properties.Resources.AlternativeItems</th>
                                <th style="width: 40%">@MyERP.Properties.Resources.Item </th>
                                <th class="text-center">@MyERP.Properties.Resources.Qty</th>
                                <th class="text-center UnitClass" style="display: none;">@MyERP.Properties.Resources.Unit</th>
                                <th class="text-center price-th">@MyERP.Properties.Resources.Price</th>
                                <th class="text-center price-th">@MyERP.Properties.Resources.Total</th>
                                <th class="ItemTax" style="display: none;">@MyERP.Properties.Resources.TaxPercentage</th>
                                <th class="ItemTax" style="display: none;">@MyERP.Properties.Resources.TaxValue</th>
                                <th>@MyERP.Properties.Resources.Notes</th>
                                <th><i class="fas fa-trash-alt"></i></th>
                                <th class="EnableAdditionalItemsOnPos"><i class="fa fa-plus" aria-hidden="true"></i></th>


                            </tr>
                            </thead>
                        </table>
                    </div>
                    @*<div class="table-responsive" style="@Html.Raw(ViewBag.ProjectName!="Genoise" ? "max-height: 35vh;overflow-y: scroll;" : "")" id="itemTable">*@
                    <div class="table-responsive" id="itemTable">

                        <table class="table table-centered table-sm mb-0">

                            <tbody id="PointOfSaleDetails">
                                @if (Model != null)
                                {
                                    foreach (var item in Model.SalesInvoiceDetails)
                                    {
                                        <tr bgcolor="@Html.Raw(item.ExtraTypeId!= null ? "Pink" : "")">
                                            <td hidden class="RowId"></td>
                                            <td hidden class="@Html.Raw(item.ExtraTypeId== null ? "Main" : "")">Main</td>
                                            <td hidden class="MainItemId"></td>
                                            <td>
                                                <button class="btn btn-info" data-toggle="modal" data-target="#itemDetails" onclick="showItemDetials(this)">@MyERP.Properties.Resources.Details</button>
                                            </td>
                                            <td>
                                                <input class="IsAltItem" type="checkbox" hidden />
                                                <a href="javascript:void(0);" onclick="AlternativeItems(this)">
                                                    <i class="fe-refresh-ccw"></i>
                                                </a>
                                            </td>

                                            <td style="width:40%" class="tabledit-edit-mode" colspan="1">
                                                <input type="hidden" class="item itemId" required value="@item.ItemId" />
                                                @if (Session["lang"] != null && Session["lang"].ToString() == "en" && item.Item.EnName != null)
                                                {
                                                    <input type="text" class="item-name form-control tabledit-input form-control-sm" required readonly value="@item.Item.EnName" />
                                                }
                                                else
                                                {
                                                    <input type="text" class="item-name form-control tabledit-input form-control-sm" required readonly value="@item.Item.ArName" />
                                                }
                                                <input type="hidden" class="barcode" required value="@item.ItemPrice.Barcode" />
                                                <input type="hidden" class="item-price-id" required value="@item.ItemPriceId" />
                                            </td>
                                            <td class="tabledit-edit-mode" colspan="1">
                                                <input class="money quantity form-control tabledit-input form-control-sm" type="text" min="0" required value="@item.Qty" />
                                            </td>
                                            <td class="tabledit-edit-mode UnitClass" style="display:none;" colspan="1">
                                                <select class="item-unit form-control tabledit-input form-control-sm" required>
                                                    @if (Session["lang"] != null && Session["lang"].ToString() == "en" && item.ItemUnit.EnName != null)
                                                    {
                                                        <option value="@item.ItemUnitId">@item.ItemUnit.EnName</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="@item.ItemUnitId">@item.ItemUnit.ArName</option>
                                                    }
                                                </select>
                                                <input class="unit-equavalent" type="hidden" required value="@item.UnitEquivalent" />
                                            </td>
                                            <td class="tabledit-edit-mode" colspan="1">
                                                <input type="text" class="money price form-control tabledit-input form-control-sm" required readonly value="@item.Price" />
                                                <input hidden type="text" class="money accessoryPrice form-control tabledit-input form-control-sm" readonly value="@item.AccessoryPrice" />
                                            </td>
                                            <td class="tabledit-edit-mode" colspan="1">
                                                <input type="text" class="money total form-control tabledit-input form-control-sm" required readonly value="@Html.Raw(item.Item.IsAccessory == true? 0 : item.Price*(decimal)item.Qty)" />

                                                <input hidden class="itemTotalAccessoryPrice" readonly value="@Html.Raw(item.AccessoryPrice*(decimal)item.Qty)" />
                                            </td>
                                            <td class="tabledit-edit-mode ItemTax" style="display:none;"><input type="text" class="ItemTaxPercentage form-control tabledit-input form-control-sm" value="@item.ItemTaxPercentage" /></td>
                                            <td class="tabledit-edit-mode ItemTax" style="display:none;"><input type="text" class="ItemTaxValue form-control tabledit-input form-control-sm money" value="@item.ItemTaxValue" /></td>
                                            <td>
                                                <a href="javascript:void(0);" onclick="AddNotes(this)"><i class="fa fa-plus"></i></a>
                                                <input hidden class="IsAdded" type="checkbox" />
                                            </td>
                                            <td>
                                                @if (ViewBag.IsWaiter != true)
                                                {
                                                    <a href="javascript:void(0);" onclick="deleteElement(this)">
                                                        <i class="fas fa-trash-alt"></i>
                                                    </a>
                                                }
                                            </td>
                                            @if (item.ExtraTypeId == null)
                                            {
                                                <td class="EnableAdditionalItemsOnPos text-center">
                                                    <a href="javascript:void(0);" onclick="ShowExtra(this)">
                                                        <i class="fa fa-plus" aria-hidden="true"></i>
                                                    </a>
                                                </td>
                                            }

                                            <td hidden><input class="ExtraTypeId" required value="@item.ExtraTypeId" /></td>
                                        </tr>
                                        if (item.Notes != null)
                                        {
                                            <tr><td class="tabledit-edit-mode"><label class="ItemNotes control-label form-control-sm">@item.Notes</label></td></tr>
                                        }

                                 
                                }
                            }
                                </tbody>
                            </table>
                        </div>



                        @*@Html.DropDownList("DriverId", (SelectList)ViewBag.DriverId, htmlAttributes: new { @class = "form-control" })*@
                        <!--<select id="DriverId" name="DriverId" class="form-control"></select>
                                            </div>
                                            Html.Hidden("CarId")
                                        </div>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary" data-dismiss="modal">MyERP.Properties.Resources.Close</button>
                                    </div>
                                </div>
                            </div>
                        </div>-->
                    </div>


                    @*<div class="row form-group m-1">
                            <label class="control-label">طريقة الدفع</label>
                            <div class="col-sm-3">
                                @Html.DropDownList("PaymentMethodId", null, htmlAttributes: new { @class = "form-control", @required = "required" })
                            </div>
                            <div class="col-sm-8">
                                @if (Model != null &&ViewBag.CanPrintInvoice==true)
                                {
                                    <a class="btn btn-success" href="@Url.Action("CashierInvoice","Report",new { id=Model.Id, print=true})" role="button" target="_blank">طباعة</a>
                                }
                                <button class="btn btn-success" id="save" onclick="addEdit()">
                                    حفظ
                                </button>
                            </div>
                        </div>*@
                </div>
            </div><!-- End Of InvoiceDiv -->
            <!-- Totals Paid  -->
            <div style="background-color: azure;
        border-style: solid;
        border-color: #e7eaed;
        border-width: 1px;
        border-radius: 5px;
       /* position: absolute;*/
        bottom: 0;
        margin-bottom: 3%;">
                @*<div id="strech" class="form-group row m-auto pt-2 totals" style="margin-top: 315px !important; margin-bottom: 0px !important;">*@
                <div id="strech" class="form-group row m-auto pt-2 totals" style="margin-bottom: 10px !important;">
                    <label for="VoucherDiscountValue" class="control-label col-sm-1">@MyERP.Properties.Resources.TotalWithoutTax: </label>
                    <div class="col-sm-3">
                        <input class="form-control money" id="TotalWithoutTax" type="text" />
                    </div>

                </div>
                <div id="strech" class="form-group row m-auto pt-2 totals" style="margin-bottom: 10px !important;">

                    <label for="VoucherDiscountValue" class="control-label col-sm-1">@MyERP.Properties.Resources.DiscountValue: </label>
                    <div class="col-sm-3">
                        @*<input class="form-control money" id="DiscountValue" type="text" />*@
                        @Html.EditorFor(model => model.VoucherDiscountValue, new { htmlAttributes = new { @class = "form-control money", id = "DiscountValue", type = "text" } })
                        <input class="form-control" type="hidden" id="Total" required />
                    </div>
                    <label for="VoucherDiscountValue" class="control-label col-sm-1">@MyERP.Properties.Resources.DiscountPercentage: </label>
                    <div class="col-sm-3">
                        <input id="VoucherDiscountPercentage" class="form-control" />
                        @*@Html.HiddenFor(x => x.VoucherDiscountPercentage)*@
                    </div>
                    <label for="NetTotal" class="control-label col-sm-1"> @MyERP.Properties.Resources.AfterDiscount:</label>
                    <div class="col-sm-3">
                        @*<input class="form-control money" type="text" readonly id="NetTotal" />*@
                        @Html.EditorFor(model => model.NetTotal, new { htmlAttributes = new { @class = "form-control money", type = "text", @readonly = "readonly" } })
                    </div>

                </div>
                <div class="form-group row m-auto totals">
                    <label for="DeliveryCost" class="control-label col-sm-1">@MyERP.Properties.Resources.DeliveryCost:</label>
                    <div class="col-sm-3">
                        @Html.EditorFor(model => model.DeliveryCost, new { htmlAttributes = new { @class = "form-control money", type = "text", @disabled = "disabled" } })
                        @*<input type="hidden" id="ServiceFeesPercentage" value="@ViewBag.ServiceFeesPercentage" />*@
                    </div>
                    <label for="ServiceFees" hidden class="control-label col-sm-1">@MyERP.Properties.Resources.ServiceFees:</label>
                    <div class="col-sm-3">
                        @Html.EditorFor(model => model.ServiceFees, new { htmlAttributes = new { @class = "form-control money", type = "text", @readonly = "readonly", @hidden = "hidden" } })
                        <input type="hidden" id="ServiceFeesPercentage" value="@ViewBag.ServiceFeesPercentage" />
                    </div>

                    <label class="control-label col-sm-1">@MyERP.Properties.Resources.IncludeTheTax</label>
                    @if (Model != null)
                    {
                        <div class="col-sm-3">
                            <input type="checkbox" id="hasTaxes" disabled @Html.Raw(Model != null && Model.SalesTaxes > 0 ? "checked" : "") />
                        </div>
                    }
                    else
                    {
                        <div class="col-sm-3">
                            <input type="checkbox" id="hasTaxes" disabled @Html.Raw(ViewBag.ApplyTaxes == true ? "checked" : "") />
                        </div>
                    }
                </div>
                <div class="form-group row m-auto">
                    <label for="SalesTaxes" class="control-label col-sm-1">@MyERP.Properties.Resources.Tax:</label>
                    <div class="col-sm-3">
                        @Html.EditorFor(model => model.SalesTaxes, new { htmlAttributes = new { @class = "form-control money", type = "text", @readonly = "readonly" } })
                        @*<input type="hidden" id="SalesTaxes" value="@ViewBag.SalesTaxes" />*@
                    </div>
                    <label for="RefundableInsurance" class="control-label col-sm-1">@MyERP.Properties.Resources.RefundableInsurance:</label>
                    <div class="col-sm-3">
                        @Html.EditorFor(model => model.RefundableInsurance, new { htmlAttributes = new { @class = "form-control money", type = "text", @readonly = "readonly" } })
                    </div>
                    @if (ViewBag.ApplySmokingTax == true)
                    {
                        <label for="SmokingTax" class="control-label col-sm-1 SmokingTax">@MyERP.Properties.Resources.SmokingTax:</label>
                        <div class="col-sm-3">
                            @Html.EditorFor(model => model.SmokingTax, new { htmlAttributes = new { @class = "form-control money SmokingTax", type = "text", @readonly = "readonly" } })
                        </div>
                    }
                </div>

                <div class="form-group row m-auto">
                    <label for="TotalAfterTaxes" class="control-label col-sm-1">@MyERP.Properties.Resources.Total:</label>
                    <div class="col-sm-3">
                        @Html.EditorFor(model => model.TotalAfterTaxes, new { htmlAttributes = new { @class = "form-control money", type = "text", @readonly = "readonly" } })
                    </div>
                    <label for="Paid" class="totals control-label col-sm-1">@MyERP.Properties.Resources.Paid:</label>
                    <div class="col-sm-3 totals ">
                        @Html.EditorFor(model => model.Paid, new { htmlAttributes = new { @class = "form-control money ", @readonly = "readonly", type = "text" } })
                    </div>

                    <label for="Remaining" class=" totals control-label col-sm-1"> @MyERP.Properties.Resources.Remain:</label>
                    <div class="col-sm-3 totals">
                        <input class="form-control" type="text" id="Remaining" readonly />
                    </div>
                    <div class="col-sm-4">

                    </div>

                </div>

            </div>
            <!--**************************************-->
        </div>
        <!-- end row -->
    </div>
