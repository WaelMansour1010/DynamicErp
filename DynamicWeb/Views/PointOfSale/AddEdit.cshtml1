    </div>
    <!--Unpaid Invoices-->
    <div class="modal fade bd-example-modal-xl" id="UnpaidInvoicesModal" tabindex="-1" role="dialog"
         aria-labelledby="UnpaidInvoicesModal" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable modal-xl" role="document" style="max-width:100%">
            <div class="modal-content">
                <div class="modal-header">
                    <h4 class="modal-title" id="UnpaidInvoicesModalTitle">@MyERP.Properties.Resources.UnpaidInvoices</h4>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="row" id="UnpaidInvoicesModalTable">

                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">@MyERP.Properties.Resources.Close</button>
                </div>
            </div>
        </div>
    </div>
    <!--Drivers Modal-->
    <div class="modal fade bs-example-modal-lg" id="DriversModal" tabindex="-1" role="dialog"
         aria-labelledby="DriversModal" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h4 class="modal-title" id="DriversModalTitle">@MyERP.Properties.Resources.Drivers</h4>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="row" id="DriversModalTable">

                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">@MyERP.Properties.Resources.Close</button>
                </div>
            </div>
        </div>
    </div>
    <div id="paymentMethodsModal" class="paymentMethodsModal modal fade bd-example-modal-xl" tabindex="-1" role="dialog" aria-labelledby="myLargeModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="form-group form-row">


                    <div class="easy-numpad-number-container m-2" style="width:45%">
                        <table>
                            <tr>
                                <td><a href="7" onclick="easynum()">7</a></td>
                                <td><a href="8" onclick="easynum()">8</a></td>
                                <td><a href="9" onclick="easynum()">9</a></td>
                                <td><a href="Del" class="del" id="del" onclick="easy_numpad_del()">Del</a></td>
                            </tr>
                            <tr>
                                <td><a href="4" onclick="easynum()">4</a></td>
                                <td><a href="5" onclick="easynum()">5</a></td>
                                <td><a href="6" onclick="easynum()">6</a></td>
                                <td><a href="Clear" class="clear" id="clear" onclick="easy_numpad_clear()">Clear</a></td>
                            </tr>
                            <tr>
                                <td><a href="1" onclick="easynum()">1</a></td>
                                <td><a href="2" onclick="easynum()">2</a></td>
                                <td><a href="3" onclick="easynum()">3</a></td>
                                <td><a href="Cancel" class="cancel" id="cancel" onclick="easy_numpad_cancel()">Cancel</a></td>
                            </tr>
                            <tr>
                                <td colspan="2" onclick="easynum()"><a href="0">0</a></td>
                                <td onclick="easynum()"><a href=".">.</a></td>
                                <td><a href="Done" class="done" id="done" onclick="easy_numpad_done()">Done</a></td>
                            </tr>
                        </table>
                    </div>


                    <div class="form-horizontal needs-validation ml-4 mt-3" role="form" style="width: 49%;">
                        <div class="table-responsive">
                            <table class="table table-centered mb-0">
                                <thead>
                                    <tr>
                                        <th>@MyERP.Properties.Resources.PaymentMethod</th>
                                        <th>@MyERP.Properties.Resources.Amount</th>
                                        <th>@MyERP.Properties.Resources.CashBox</th>
                                        @*<th>الحساب البنكى</th>*@
                                    </tr>
                                </thead>
                                <tbody id="SalesInvoicePaymentMethods">
                                    @if (Model != null && Model.Id > 0)
                                    {
                                        foreach (var method in Model.SalesInvoicePaymentMethods)
                                        {
                                            <tr>
                                                <td class="tabledit-edit-mode">
                                                    <input value="@method.PaymentMethod.Id" class="PaymentMethodId" type="hidden" />
                                                    @*@if(ViewBag.AllowSalesOrderInPos == true && method.PaymentMethod.Id != 3)*@
                                                    <label class="PaymentMethodName">
                                                        @method.PaymentMethod.ArName
                                                    </label>
                                                </td>
                                                @if (method.PaymentMethod.Id == 1)
                                                {
                                                    <td class="tabledit-edit-mode"><input class="money PaymentAmount form-control tabledit-input form-control-sm" type="text" value="@method.Amount" id="@("PayMethod"+method.PaymentMethod.Id)" /></td>
                                                    <td class="tabledit-edit-mode">
                                                        @Html.DropDownList("CashBoxId", null, htmlAttributes: new { @class = "CashBoxId form-control tabledit-input form-control-sm" })
                                                    </td>
                                                    <td></td>
                                                }
                                                else if (method.PaymentMethod.Id == 3 && ViewBag.AllowSalesOrderInPos == true)
                                                {
                                                    <td class="tabledit-edit-mode"><input class="money PaymentAmount form-control tabledit-input form-control-sm" id="@("PayMethod"+method.PaymentMethod.Id)" type="text" value="@method.Amount" readonly="readonly" /></td>
                                                    <td></td>
                                                    <td></td>
                                                }
                                                else /*if (method.PaymentMethod.Id == 2)*/
                                                {
                                                    <td class="tabledit-edit-mode"><input class="money PaymentAmount form-control tabledit-input form-control-sm" id="@("PayMethod"+method.PaymentMethod.Id)" type="text" value="@method.Amount" /></td>
                                                    <td></td>
                                                    <td></td>
                                                }


                                            </tr>
                                        }
                                    }
                                    else
                                    {

                                        foreach (var method in (List<MyERP.Models.PaymentMethod>)ViewBag.PaymentMethods)
                                        {
                                            <tr>
                                                <td class="tabledit-edit-mode">
                                                    <input value="@method.Id" class="PaymentMethodId" type="hidden" />
                                                    @if ((Session["lang"] != null ? Session["lang"].ToString() : "ar") == "en" && method.EnName != null)
                                                    {
                                                        <label class="PaymentMethodName">@method.EnName</label>
                                                    }
                                                    else
                                                    {
                                                        <label class="PaymentMethodName">@method.ArName</label>
                                                    }
                                                </td>
                                                @if (method.Id == 1)
                                                {
                                                    <td class="tabledit-edit-mode"><input class="money PaymentAmount form-control tabledit-input form-control-sm" type="text" id="@("PayMethod"+method.Id)" /></td>
                                                    <td class="tabledit-edit-mode">
                                                        @Html.DropDownList("CashBoxId", null, htmlAttributes: new { @class = "CashBoxId form-control tabledit-input form-control-sm" })
                                                    </td>
                                                    <td></td>
                                                }
                                                else if (method.Id == 3)
                                                {
                                                    <td class="tabledit-edit-mode"><input class="money PaymentAmount form-control tabledit-input form-control-sm" type="text" readonly="readonly" id="@("PayMethod"+method.Id)" /></td>
                                                    <td></td>
                                                    <td></td>
                                                }
                                                else /*if (method.PaymentMethod.Id == 2)*/
                                                {
                                                    <td class="tabledit-edit-mode"><input class="money PaymentAmount form-control tabledit-input form-control-sm" type="text" id="@("PayMethod"+method.Id)" /></td>
                                                    <td></td>
                                                    <td></td>
                                                }

                                            </tr>
                                        }

                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <!-- DiscountModal -->
    <div class="modal fade" id="DiscountModal" tabindex="-1" role="dialog" aria-labelledby="DiscountModalTitle" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h4 class="modal-title" id="DiscountModalTitle">@MyERP.Properties.Resources.ConfirmPassword</h4>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="form-group row">
                        <label class=" col-sm-6 control-label" for="EnName">@MyERP.Properties.Resources.ManagerPassword </label>
                        <div class="col-sm-6">
                            <input type="password" class="form-control" id="PosManagerPassword" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal" onclick="ResetDiscountValue()">@MyERP.Properties.Resources.Close</button>
                    <button type="button" class="btn btn-primary waves-effect waves-light" data-dismiss="modal" onclick="CheckManagerPassWord()">@MyERP.Properties.Resources.Send</button>
                </div>
            </div>
        </div>
    </div>
    <!-- AddNotesModal -->
    <div class="modal fade" id="AddNotesModal" tabindex="-1" role="dialog" aria-labelledby="AddNotesModalTitle" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h4 class="modal-title" id="AddNotesModalTitle">@MyERP.Properties.Resources.Notes</h4>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="form-group row">
                        <label class=" col-sm-6 control-label" for="EnName">@MyERP.Properties.Resources.Notes </label>
                        <div class="col-sm-6">
                            <input type="text" class="form-control" id="AddItemNotes" />
                            <input type="text" hidden class="form-control" id="AddItemNotesRowId" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">@MyERP.Properties.Resources.Close</button>
                    <button type="button" class="btn btn-primary waves-effect waves-light" data-dismiss="modal" onclick="AddNotesToTable(this)">@MyERP.Properties.Resources.Add</button>
                </div>
            </div>
        </div>
    </div>
    <!--***********************************************************************************-->
    <!--------------------- Thermal Printer ------------------------------------->
    @*<form onsubmit='return false;' id="form">*@
    <div class="container" hidden>
        <div class="wrapper">
            <div id="canvasBlock">
                <div id='canvasFrame'>
                    <canvas id='canvasPaper' width='500' height='1000' @*height='640'*@ @*style="width: 700px;"*@>
                        Your browser does not support Canvas!
                        <qrcode id="qrcode" model='model2' level='level_l' cell='3'>http://www.starmicronics.com/</qrcode>
                    </canvas>
                    @*<div id="qrcode"></div>*@
                    <div id="img_preview"> </div>
                </div>
            </div>
        </div>

        <hr>

    </div>
    @*</form>*@
    <!----------------------------------- End Of Thermal Printer ------------------------------>


    <input hidden id="IsWait" type="checkbox" />
    <input hidden id="OldTableId" />
    <input hidden id="OldInvoiceId" />

    <!-- Alternative Items Modal -->
    <div id="AlternativeItemsModal" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h4 class="modal-title" id="myModalLabel">@MyERP.Properties.Resources.AlternativeItems</h4>
                    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">×</button>
                </div>
                <div class="modal-body">
                    <h4>@MyERP.Properties.Resources.AlternativeItems</h4>
                    <hr />
                    <div class="row">
                        <div class="col-sm-12">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>@MyERP.Properties.Resources.Barcode</th>
                                        <th>@MyERP.Properties.Resources.ItemName</th>
                                        <th>@MyERP.Properties.Resources.Price</th>
                                        <th>@MyERP.Properties.Resources.Qty</th>
                                        <th>@MyERP.Properties.Resources.Replace</th>
                                    </tr>
                                </thead>
                                <tbody id="AlternativeItemsTr">
                                    <tr>
                                    </tr>


                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light waves-effect" data-dismiss="modal">@MyERP.Properties.Resources.Close</button>
                </div>
            </div><!-- /.modal-content -->
        </div><!-- /.modal-dialog -->
    </div>

    <!-- End Of Alternative Items Modal -->
    @*<input hidden id="selectedTableWaitersName" value="@ViewBag.WaitersName" />*@
<div id="itemDetails" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" style="display: none;" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title" id="myModalLabel">@MyERP.Properties.Resources.ItemDetails</h4>
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">×</button>
            </div>
            <div class="modal-body" id="itemDetailsBody">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light waves-effect" data-dismiss="modal">@MyERP.Properties.Resources.Close</button>
            </div>
        </div><!-- /.modal-content -->
    </div><!-- /.modal-dialog -->
</div>
<script>
    function showItemDetials(e) {
      
        let itemPrice = $(e).closest('tr').find('.item');
        var itemId = itemPrice.val();

      
        console.log(itemPrice);
        $('#itemDetailsBody').empty();
        if (itemId) {
            $('#itemDetailsBody').append('<div class="d-flex align-items-center"><div class="spinner-border ml-auto" role="status" aria-hidden="true"></div></div>');
            $.get('/Item/GetItemQuantityInEachWarehouse?itemId=' + itemId + '&depId=' + $('#DepartmentId').val()).done(function (r) {
                $('#itemDetailsBody').empty().append(r);
            });
        }
    }

     function AlternativeItems(e) {
        // let id = $(e).closest('tr').find('.itemId').val();
         let itemPrice = $(e).closest('tr').find('.item');
         var itemId = itemPrice.val();
        $(e).closest('tr').find('.IsAltItem').prop('checked', true);
        $('#AlternativeItemsModal').modal('show');
         GetAlternativeItems(itemId);
    }
    function GetAlternativeItems(id) {
        $('#AlternativeItemsTr').empty();
        $.get('/Helper/GetAlternativeItems?MainItemId=' + id).done(function (r) {
            if (r.length > 0) {
                for (var i = 0; i < r.length; i++) {
                    let item = items.filter(function (e) { return e.Id == r[i].ItemId })[0];
                    item.Barcode = item.Barcode != null ? item.Barcode : "";
                    let tr = '<tr><td><input class="AltMainItemId" value="' +
                        r[i].MainItemId + '" hidden /><input class="AltItemId" value="' +
                        r[i].ItemId + '" hidden /><input class="AltItemPriceId" value="' +
                        item.ItemPriceId+'" hidden /><label class="AltItemBarcode"> ' +
                        item.Barcode + '</label></td><td><label class="AltItemName">' +
                        item.ArName + '</label></td><td><label class="AltItemPrice">' +
                        item.Price + '</label></td><td><label class="AltItemQty">' +
                        item.Quantity + '</label></td><td><button class="btn btn-primary" onclick="ReplaceItem(' +
                        r[i].ItemId + ' , ' + id +')" > @MyERP.Properties.Resources.Replace</button></td></tr>';
                    $('#AlternativeItemsTr').append(tr);
                }
            }
        });
    }

    function ReplaceItem(ItemId,oid) {
         if (items.length) {
             let itemPrice = items.filter(function (i) { return i.Id === ItemId; })[0];
            
             let itmId = itemPrice.Id;
             let barcode = itemPrice.barcode;
             if (itemPrice) {
                 let itmId = itemPrice.Id;
              
                // Item Has Expire Date
             //   let ItemHasExpiry = isItemHasExpireDate(itmId);
                 $('#PointOfSaleDetails tr').each(function () {
                     let td = $(this);
                     let ritem = td.closest('tr').find('.itemId').val();
                     console.log(`${oid}-${ritem}`);
                   
                     if (ritem == oid) {
                         let quantity = td.closest('tr').find('.quantity').val();
                         var ItemTaxPercentage = itemPrice.ItemTaxPercentage;
                         var TaxValue = (parseFloat(itemPrice.Price) * parseInt(parseFloat(quantity))) * (parseFloat(ItemTaxPercentage) / 100);
                         let IsAltItem = td.find('.IsAltItem').prop('checked');
                         //  if (IsAltItem == true) {
                         td.closest('tr').find('.itemId').val(itmId);
                         td.closest('tr').find('.item-name').val(itemPrice.ArName);
                         td.closest('tr').find('.ItemTaxPercentage').val(itemPrice.ItemTaxPercentage);
                         td.closest('tr').find('.price').val(itemPrice.Price);
                         td.closest('tr').find('.ItemTaxValue').val(TaxValue);
                         /*   td.closest('tr').find('.name').text(itemPrice.itemPrice.ArName);*/
                         td.closest('tr').find('.IsAltItem').prop('checked', false);
                   
                         td.closest('tr').find('.item').val(itemPrice.ItemPriceId).trigger('change');
                         // }
                     }
                  
                });
            }
         }
        $('#AlternativeItemsModal').modal('hide');
    }





    @*<!--------------------- Auto Saved ------------------->*@
    var AutoSavedItemsCount = '@ViewBag.AutoSavedItemsCount';

    function AutoSaved() {
        if (AutoSavedItemsCount <= 9 && $('#CustomerType').val() == 1) {
            $('#Paid').removeAttr('required');
            let valid = true;
            if ($(".form-control:invalid").length > 0) {
                $('.form-horizontal').addClass('was-validated');
                $('html, body').animate({
                    scrollTop: $(".form-control:invalid").eq(0).offset().top - 80
                }, 500);
                valid = false;
                console.log($(".form-control:invalid"));
            }
            if (valid) {
                var paymentMethods = [];
                let totalPaied = 0;
                let noneCashMoney = 0;
                var creditAmount = 0;
                $('#SalesInvoicePaymentMethods tr').each(function () {
                    var td = $(this);
                    totalPaied += td.find('.PaymentAmount').inputmask('unmaskedvalue') * 1;
                    if (td.find('.PaymentMethodId').val() != 1) {
                        noneCashMoney += td.find('.PaymentAmount').inputmask('unmaskedvalue') * 1;
                    }
                    var paymentMethod = {
                        SalesInvoiceId: $('#Id').val(),
                        PaymentMethodId: td.find('.PaymentMethodId').val(),
                        CashBoxId: td.find('.PaymentAmount').inputmask('unmaskedvalue') ? td.find('.CashBoxId').val() : null,
                        Amount: td.find('.PaymentAmount').inputmask('unmaskedvalue'),
                        BankId: td.find('.PaymentAmount').inputmask('unmaskedvalue') && td.find('.BankId').val() > 0 ? td.find('.BankId').val() : null,
                        BankAccountId: td.find('.PaymentAmount').inputmask('unmaskedvalue') && td.find('.BankAccountId').val() > 0 ? td.find('.BankAccountId').val() : null
                    };
                    if (paymentMethod.PaymentMethodId == 2)
                        creditAmount = paymentMethod.Amount;
                    paymentMethods.push(paymentMethod);
                });
                paymentMethods[0].Amount = $('#TotalAfterTaxes').inputmask('unmaskedvalue') * 1 - noneCashMoney;
                let finalTotal = $('#IsInstallmentPlan').prop('checked') ? $('#TotalAfterTotalInstallment').inputmask('unmaskedvalue') : $('#TotalAfterTaxes').inputmask('unmaskedvalue');
                if (finalTotal * 1 > totalPaied) {

                    Swal.fire({
                        title: '@MyERP.Properties.Resources.TheValuePaidIsLessThanRequired',
                        text: " ",
                        icon: 'info',
                        showCancelButton: false,
                        confirmButtonText: '@MyERP.Properties.Resources.Ok',
                        confirmButtonColor: '#3085d6'
                    });
                    valid = false;
                }
                else if (finalTotal * 1 < noneCashMoney) {
                    Swal.fire({
                        title: '@MyERP.Properties.Resources.TheValueOfTheCashlessPaymentCannotBeGreaterThanTheRequiredAmount',
                        text: " ",
                        icon: 'info',
                        showCancelButton: false,
                        confirmButtonText: '@MyERP.Properties.Resources.Ok',
                        confirmButtonColor: '#3085d6'
                    });
                    valid = false;
                }
            }

            var SalesInvoiceDetails = [];
            var ItemGroupIDs = [];
            if (valid) {
                $('#PointOfSaleDetails tr').each(function () {
                    var td = $(this);
                    if (td.find('.quantity').val() * 1 != 0 && td.find('.item').val() > 0) {
                        var ItemPriceId = td.find('.item-price-id').val();
                        var ItemGroupId = items.filter(function (i) { return i.ItemPriceId == ItemPriceId })[0].ItemGroupId;
                        if ($.inArray(ItemGroupId, ItemGroupIDs) == -1) {
                            ItemGroupIDs.push(ItemGroupId);
                        }
                        var salesInvoiceDetail = {
                            ItemId: td.find('.item').val(),
                            ItemGroupId: ItemGroupId,
                            ItemPriceId: td.find('.item-price-id').val(),
                            ItemUnitId: td.find('.item-unit').val(),
                            UnitEquivalent: td.find('.unit-equavalent').val(),
                            Price: td.find('.price').inputmask('unmaskedvalue') * 1,
                            WareHouseId: $('#WarehouseId').val(),
                            Qty: td.find('.quantity').val(),
                            IsActive: true,
                            IsDeleted: false,
                            ExtraTypeId: td.find('.ExtraTypeId').val(),
                            RowId: td.find('.RowId').text(),
                            AccessoryPrice: td.find('.accessoryPrice').inputmask('unmaskedvalue') * 1,
                            Notes: td.next('tr').find('.ItemNotes').text(),
                            ItemTaxPercentage: td.find('.ItemTaxPercentage').val(),
                            ItemTaxValue: td.find('.ItemTaxValue').inputmask('unmaskedvalue'),
                            IsAdded: td.find('.IsAdded').prop('checked'),
                        };
                        SalesInvoiceDetails.push(salesInvoiceDetail);
                    }
                });
                valid = SalesInvoiceDetails.length > 0 ? true : false;
                valid == false ? Swal.fire({ title: '@MyERP.Properties.Resources.PleaseEnterFullDetails !', text: " ", icon: 'info', showCancelButton: false, confirmButtonText: '@MyERP.Properties.Resources.Ok', confirmButtonColor: '#3085d6' }) : null;
            }
            if (valid) {
                $('#preloader, #status').fadeIn();

                //$('#save').prop('disabled', true);
                //$('#SaveAndPrint').prop('disabled', true);
                $.ajax({
                    type: "POST", contentType: "application/json",
                    url: "/SalesInvoice/AddEdit",
                    data:
                        JSON.stringify({
                            Id: $('#Id').val(),
                            DocumentNumber: $('#DocumentNumber').val(),
                            BranchId: $('#BranchId').val(),
                            WarehouseId: $('#WarehouseId').val(),
                            VoucherDate: $('#VoucherDate').val(),
                            VendorOrCustomerId: $('#VendorOrCustomerId').val() ? $('#VendorOrCustomerId').val() : $('.VendorOrCustomerId').val(),
                            CurrencyId: $('#CurrencyId').val(),
                            CurrencyEquivalent: $('#CurrencyEquivalent').val(),
                            Total: $('#Total').inputmask('unmaskedvalue'),
                            SalesTaxes: $('#SalesTaxes').inputmask('unmaskedvalue'),
                            CommercialRevenueTaxAmount: $('#CommercialRevenueTaxAmount').inputmask('unmaskedvalue'),
                            TotalAfterTaxes: $('#TotalAfterTaxes').inputmask('unmaskedvalue'),
                            VoucherDiscountValue: $('#DiscountValue').inputmask('unmaskedvalue'),
                            VoucherDiscountPercentage: $('#VoucherDiscountPercentage').inputmask('unmaskedvalue'),
                            NetTotal: $('#NetTotal').inputmask('unmaskedvalue'),
                            ServiceFees: $('#ServiceFees').inputmask('unmaskedvalue'),
                            SystemPageId: SystemPageId,
                            DepartmentId: $('#DepartmentId').val(),
                            SalesInvoiceDetails: SalesInvoiceDetails,
                            IsActive: true,
                            IsDeleted: false,
                            IsLinked: isLinked,
                            SalesInvoicePaymentMethods: paymentMethods,
                            SalesOrdersSalesInvoices: salesOrderIds.map(function (i) { return { SalesInvoiceId: $('#Id').val(), SalesOrderId: i } }),
                            Paid: $('#Paid').inputmask('unmaskedvalue') * 1,
                            IsCompleted: $('#Paid').inputmask('unmaskedvalue') * 1 >= $('#TotalAfterTaxes').inputmask('unmaskedvalue') * 1,
                            CustomerType: $('#CustomerType').val(),
                            SalesInvoicePurchaseRequests: purchaseReqeustIds.map(function (i) { return { SalesInvoiceId: $('#Id').val(), PurchaseRequestId: i } }),
                            RefundableInsurance: $("#RefundableInsurance").inputmask('unmaskedvalue'),
                            TableId: $("#selectedTableId").val(),
                            PosCustomerId: $("#PosCustomerId").val(),
                            IsCollectedByCashier: false,
                            DeliveryCost: $("#DeliveryCost").inputmask('unmaskedvalue'),
                            SmokingTax: $('#SmokingTax').val(),
                            WaiterId: $('#WaiterId').val(),

                        }),
                    success: function (r) {
                        if (r.success == "true") {
                            $('#preloader, #status').fadeOut();

                            window.location.replace("/PointOfSale/AddEdit?Id=" + r.id);
                        }
                        else if (r.success == "false" && r.errors == "NotCashier") {
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.TheInvoiceCannotBeAddedOrModifiedUnlessTheUserIsCashier',
                                text: " ",
                                icon: 'info',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                            $('#preloader, #status').fadeOut();
                        }
                        else if (r.success == "Cannot Be Edited") {
                            $('#preloader, #status').fadeOut();
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.TheInvoiceHasBeenGeneratedAndCannotBeEdited',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });

                        }
                        else {
                            $('#preloader, #status').fadeOut();
                            $('#save').prop('disabled', false);
                            $('#SaveAndPrint').prop('disabled', false);
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.NotSaved !',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                        }
                        //cashBoxBalance();
                        //getSalesInvoices();
                    },
                    error: function (r) {
                        $('#preloader, #status').fadeOut();
                        $('#save').prop('disabled', false);
                        $('#SaveAndPrint').prop('disabled', false);
                        Swal.fire({
                            title: '@MyERP.Properties.Resources.AnErrorOccurredTryAgain !',
                            text: " ",
                            icon: 'error',
                            showCancelButton: false,
                            confirmButtonText: '@MyERP.Properties.Resources.Ok',
                            confirmButtonColor: '#3085d6'
                        });
                    }
                });
            }
        }

    }

    @*<!--------------------- End of Auto Saved ------------------->*@


