        $("#customer-modal").find(".form-control").val('');
    });
    function addCustomer() {
        if ($("#customer-modal").find(".form-control:invalid").length > 0) {
            $("#customer-modal").find('.form-horizontal').addClass('was-validated');
        } else {
            $('#preloader, #status').fadeIn();
            $.ajax(
                {
                    url: '/Customers/addedit', contentType: "application/json",
                    type: 'POST',
                    data: JSON.stringify({
                        ArName: $("#ArName").val(),
                        EnName: $('#EnName').val(),
                        Address: $('#Address').val(),
                        Mobile: $('#Mobile').val(),
                        Notes: $('#Notes').val(),
                        IsBranch: false,
                        IncludeFees: false
                    }),
                    error: function (e) {
                        $('#preloader, #status').fadeOut();
                    },
                    success: function (r) {
                        appendCustomerOptions(true).then(function () { $('#VendorOrCustomerId').val(r.Id).trigger('change'); });
                        $('#customer-modal').modal('hide');
                        $('#preloader, #status').fadeOut();
                    }
                });
        }
    }

    function addPosCustomer() {
        let valid = true;
        if ($("#PosCustomerArName").val() == "") {
            $("#PosCustomerArName").prop('required', true);
        }
        if ($("#pos-customer-modal").find(".form-control:invalid").length > 0) {
            $("#pos-customer-modal").find('.form-horizontal').addClass('was-validated');
            $('html, body').animate({
                scrollTop: $(".form-control:invalid").eq(0).offset().top - 80
            }, 500);
        } else {
            $('#preloader, #status').fadeIn();
            $.ajax(
                {
                    url: '/PosCustomers/addUpdate', contentType: "application/json",
                    type: 'POST',
                    data: JSON.stringify({
                        Id: $("#posCustomerIdInput").val() != "" ? $("#posCustomerIdInput").val():0,
                        Code: $("#posCustomerCodeInput").val(),

                        ArName: $("#PosCustomerArName").val(),
                        EnName: $('#PosCustomerEnName').val(),
                        Address: $('#PosCustomerAddress').val(),
                        Mobile1: $('#Mobile1').val(),
                        Mobile2: $('#Mobile2').val(),
                        Notes: $('#PosCustomerNotes').val(),
                        GovernorateId: $('#GovernorateId').val(),
                        CityId: $('#CityId').val(),
                        AreaId: $('#AreaId').val(),
                        CustomerId: $('#PosLinkedCustomerId').val(),
                    }),
                    error: function (e) {
                        $('#preloader, #status').fadeOut();
                    },
                    success: function (r) {
                        appendPosCustomerOptions(true).then(function () { $('#PosCustomerId').val(r.Id).trigger('change'); });
                        $('#pos-customer-modal').modal('hide');
                        $('#preloader, #status').fadeOut();
                    }
                });
        }
    }

