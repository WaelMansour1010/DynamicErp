            }
            else {
                $(".PosCustomerIdDiv").hide();
                $(".PosCustomerDetailsDiv").hide();
                $(".VendorOrCustomerIdDiv").hide();
                $(".VendorOrCustomerDetailsDiv").hide();
                $(".VendorOrCustomerId").val(1);
