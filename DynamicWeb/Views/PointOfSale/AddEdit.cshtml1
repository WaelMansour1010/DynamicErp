    function cashBoxByDepartment() {
        $.get('/Helper/CashBoxByDepartment/' + $('#DepartmentId').val()).done(function (r) {
            $('.CashBoxId').empty();
            for (var i = 0; i < r.length; i++) {
                $('.CashBoxId').append($('<option>', {
                    value: r[i].Id,
                    text: r[i].ArName
                }));
            }
            cashBoxBalance();
        });
    }

    let UniqueSerial = 0;   // unique part added to item id to make it easy to add additional item to it  when this item added many times //
    let newHeight = 315;
    // ---- Function that responsible for add main item to tabel of Items ------- //
    function addItem(e)
    {
        UniqueSerial++;     // unique part added to item id to make it easy to add additional item to it  when this item added many times  //
        let itemid = $(e).siblings('.item-id').val();
        let RowId = itemid + UniqueSerial.toString();   // unique part added to item id to make it easy to add additional item to it when this item added many times //

        //let isAccessory = $(e).attr("is-accessory");
        let valid = true;
        $('#PointOfSaleDetails tr').each(function ()
        {
            var td = $(this);
            if (td.find('.item').val() == itemid)
            {
                valid=false;
                var qty = $(this).closest('tr').find('.quantity').val();
                $(this).closest('tr').find('.item').closest('tr').find('.quantity').val(parseFloat(qty) + parseFloat(1));
            }
        });

        if(valid == false && '@ViewBag.AllowToAddSameItemMultipleTimes' != 'True') {
            @*Swal.fire({
                    title: '@MyERP.Properties.Resources.TheItemCannotBeAddedMoreThanOnce',
                    text: " ",
                    icon: 'error',
                    showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    confirmButtonColor: '#3085d6'
                });*@
        }else
        {
            var quantity ;
            if ('@System.Web.Configuration.WebConfigurationManager.AppSettings["ProjectName"]' == "Genoise" && $('#DepartmentId').val() == 28) {
                quantity = 0.00;
            }
            else {
                quantity = '@ViewBag.DefaultQuantityInPos';
            }

            let _item = items.filter(function (i) { return i.Id == itemid; })[0];
            var ItemTaxPercentage = _item.ItemTaxPercentage;
            var TaxValue = (parseFloat(_item.Price) * parseInt(parseFloat(quantity))) * (parseFloat(ItemTaxPercentage) / 100);
            var ItemNotes = ""; //_item.ItemNotes != null ? _item.ItemNotes : "";
            $('#preloader, #status').fadeIn();
            let tr = '<tr><td hidden class="RowId">' + RowId + '</td><td hidden class="Main">Main</td>' +
               `    <td>
                                                <button class="btn btn-info" data-toggle="modal" data-target="#itemDetails" onclick="showItemDetials(this)">@MyERP.Properties.Resources.Details</button>
                                            </td>
                                            <td>
                                                <input class="IsAltItem" type="checkbox" hidden />
                                                <a href="javascript:void(0);" onclick="AlternativeItems(this)">
                                                    <i class="fe-refresh-ccw"></i>
                                                </a>
                                            </td>`+
                '<td hidden class="MainItemId">' + itemid + '</td><td style="width:40%" class="tabledit-edit-mode" colspan="1"><input type="hidden" class="item itemId" required /><input type="text" class="item-name form-control tabledit-input form-control-sm" required readonly /><input type="hidden" class="barcode" required /><input type="hidden" class="item-price-id" required /></td><td class="tabledit-edit-mode" colspan="1"><input class="money quantity form-control tabledit-input form-control-sm" type="text" value="' +
                quantity + '"  required /></td><td class="tabledit-edit-mode UnitClass" style="display:none;" colspan="1"><select class="item-unit form-control tabledit-input form-control-sm" required></select><input class="unit-equavalent form-control tabledit-input form-control-sm small-number" type="hidden" required /></td><td class="tabledit-edit-mode" colspan="1"><input type="text" class="money price form-control tabledit-input form-control-sm" required readonly /><input hidden type="text" class="money accessoryPrice form-control tabledit-input form-control-sm" readonly /></td><td class="tabledit-edit-mode" colspan="1"><input type="text" class="money total form-control tabledit-input form-control-sm" required readonly /><input hidden class="itemTotalAccessoryPrice" readonly /></td><td class="tabledit-edit-mode ItemTax" style="display:none;"><input type="text" class="ItemTaxPercentage form-control tabledit-input form-control-sm" value="' +
                ItemTaxPercentage + '" /></td><td class="tabledit-edit-mode ItemTax" style="display:none;"><input type="text" class="ItemTaxValue form-control tabledit-input form-control-sm money" value="' +
                TaxValue + '" /></td><td><a href="javascript:void(0);" onclick="AddNotes(this)"><i class="fa fa-plus"></i></a><input hidden class="IsAdded" type="checkbox" '+'@Html.Raw(Model != null && Model.Id>0?"checked":"")'+' /></td><td><a href="javascript:void(0);" onclick="deleteElement(this)"><i class="fas fa-trash-alt"></i></a></td><td class=" EnableAdditionalItemsOnPos text-center"><a href="javascript:void(0);" onclick="ShowExtra(this)" /*data-toggle="modal" data-target="#exampleModal*/"><i class="fa fa-plus" aria-hidden="true"></i></a></td></tr><tr class="ItemNotesTr" style="display:none;"><td class="tabledit-edit-mode"><label class="ItemNotes control-label form-control-sm">' +
                ItemNotes + '</label></td></tr>';

            $('#PointOfSaleDetails').append(tr);

            //if (window.sessionStorage.getItem("UseItemUnit") == 'true') {
            //    $('.UnitClass').show();
            //}

            if (/*$('#hasTaxes').prop('checked')==true*/ ShowTaxPercentageAndValue == 'True') {
                $('.ItemTax').show();
            }
            else {
                $('.ItemTax').hide();
            }

            //    $('.table td, .table th').css("min-width", "0vh");
            newHeight = newHeight - 45;
            //if (newHeight >= 0)
            //{
            //    $('#strech').css("cssText", "margin-top:" + newHeight + "px !important;");
            //}

            if ('@ViewBag.EnableAdditionalItemsOnPos' == 'True')
                $('.EnableAdditionalItemsOnPos').show();
            else
                $('.EnableAdditionalItemsOnPos').hide();

            if ($('#DepartmentId')[0].value == 28 && DisplayFactoryPrice != 'True' && '@ViewBag.ProjectName' == "Genoise") {
                $('.price').last().closest('td').hide();
                $('.total').last().closest('td').hide();
            }
            $('.item').last().val(itemid).closest('tr').find('.item-name').val($(e).text());
            $('#PointOfSaleDetails tr:last select').select2({
                matcher: matchCustom
            });
            $('#PointOfSaleDetails tr:last .money').inputmask({
                alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, 'allowMinus': false, digitsOptional: false, 'placeholder': '0'
            });
            getItemUnits(itemid).done(function (r) {
                let units = '';
                for (var i = 0; i < r.length; i++) {
                    units += '<option value="' + r[i].Id + '">' + r[i].ArName + '</option>';
                }
                $('#preloader, #status').fadeOut();
                $('.item-unit').last().empty().append(units).trigger('change');
            });
            $('#itemTable').scrollTop(9000000);//scroll to bottom of table

            if ($(e).attr('item-has-accessory') == "true" && '@ViewBag.UseRefundableInsurancesForAccessories' != null && '@ViewBag.UseRefundableInsurancesForAccessories' == 'True') {
                Swal.fire({
                    title: '@MyERP.Properties.Resources.ThisItemHasAccessory',
                    text: " ",
                    icon: 'info',
                    showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    confirmButtonColor: '#3085d6'
                });
                if ('@ViewBag.AccessoryGroupId' != null) {
                    $(".active").removeClass("active")
                    $("#@ViewBag.AccessoryGroupId-tab").addClass("active");
                    refreshItems(@ViewBag.AccessoryGroupId);
                }
            }
        }
        $("#PosCustomerId").trigger('change');
        /* setTimeout(() => {
             if (AutoSavedItemsCount <= 9 && $('#CustomerType').val() == 1) {
                 AutoSaved();
             }
         }, "2000");
         */
    }

    $(document).on('change', '.item-unit', function () {
        let itemUnitId = $(this).val();
        let item = $(this).closest('tr').find('.item');
        let isFactoryChosen = false;
        if ($('#DepartmentId')[0].value == 28 && '@ViewBag.ProjectName' == "Genoise")
            isFactoryChosen = true;
        getItemUnits(item.val()).done(function (r) {
            let itemUnit = r.filter(function (i) { return i.Id == itemUnitId })[0];
            item.closest('tr').find('.unit-equavalent').val(itemUnit.Equivalent);

            if (item.closest('tr').find('.extra').val() == null) {

                item.closest('tr').find('.accessoryPrice').val(itemUnit.AccessoryPrice);
                item.closest('tr').find('.price').val(isFactoryChosen ? itemUnit.FactoryPrice : itemUnit.Price);


            }

            item.closest('tr').find('.barcode').val(itemUnit.Barcode);
            item.closest('tr').find('.item-price-id').val(itemUnit.ItemPriceId);
            CalculateTotals();
            $("#TotalAfterTaxes").trigger('change');
        });
    });

    function getSalesOrders() {
        if ($('#DepartmentId').val() && $('#WarehouseId').val() && $('#CustomerType').val()) {
            $('#salesOrdersModal').modal('show');
            $('#salesOrdersModal').find('.modal-body').empty().append('<div class="d-flex align-items-center"><div class="spinner-border ml-auto" role="status" aria-hidden="true"></div></div>');
            $.get('/PointOfSale/SalesOrders?depId=' + $('#DepartmentId').val() + '&warehouseId=' + $('#WarehouseId').val() + '&customerType=' + $('#CustomerType').val()).done(function (r) {
                let table = '<div class="table-responsive"><table class="table table-centered table-sm mb-0"><thead><tr><th>' + '@MyERP.Properties.Resources.ReservationVoucherNo' + ' </th><th>' + '@MyERP.Properties.Resources.Date' + '</th><th>' + '@MyERP.Properties.Resources.Customer' + '</th><th>' + '@MyERP.Properties.Resources.Add' + '</th></tr></thead><tbody>' + r + '</tbody></table></div>';
                $('#salesOrdersModal').find('.modal-body').empty().append(table);
            });
        } else if ($('#DepartmentId').closest('.form-horizontal').find(".form-control:invalid").length > 0) {
            $('#DepartmentId').closest('.form-horizontal').addClass('was-validated');
            $('html, body').animate({
                scrollTop: $('#DepartmentId').eq(0).offset().top - 120
            }, 500);
        }
    }
    let salesOrdersPaid = 0;
    let salesOrderIds = [];
    function getSalesOrderDetails() {
        $('#preloader, #status').fadeIn();
        cancelPurchaseRequest();
        salesOrderIds = $.map($('.salesOrderId:checked'), function (i) { return $(i).val(); });
        $.ajax({
            type: "POST", contentType: "application/json",
            url: "/PointOfSale/SalesOrdersDetails",
            data:
                JSON.stringify({ salesOrderIds: salesOrderIds }),
            success: function (r) {
                $('#PointOfSaleDetails').empty().append(r.view);
                $('#PointOfSaleDetails select').select2({
                    matcher: matchCustom
                });
                $('#PointOfSaleDetails .money').inputmask({
                    alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, 'allowMinus': false, digitsOptional: false, 'placeholder': '0'
                });
                let docNums = $.map($('.salesOrderId:checked'), function (i) { return $(i).attr('doc-num'); });

                $('#SalesOrderDocNum').text('@MyERP.Properties.Resources.NumberReservationVouchers' + ': ' + docNums);
                $('#cancelSalesOrder').show();
                $('#DepartmentId, #WarehouseId, #CustomerType').attr('disabled', 'disabled');
                $('#VendorOrCustomerId').val($('.salesOrderId').first().attr('customer-id')).trigger('change').attr('disabled', 'disabled');
                $('#VoucherDate').val(r.VoucherDate);
                $('#Id').remove();
                SystemPageId = 5194;
                isLinked = true;
                $('#PointOfSaleDetails').find('input, select').attr('disabled', 'disabled');
                $('.tab-pane.fade').find('button').attr('disabled', 'disabled');
                setDocNum();
                $('#Paid').val('');
                salesOrdersPaid = r.Paid;
                $('#SalesInvoicePaymentMethods tr').each(function () {
                    var td = $(this);
                    if (td.find('.PaymentMethodId').val() == 3) {//previous reservation
                        td.find('.PaymentAmount').val(salesOrdersPaid);
                    }
                });
                CalculateTotals();
                //CalculateTotalRefundableInsurance();
                $('#preloader, #status').fadeOut();
            },
            error: function () {
                $('#preloader, #status').fadeOut();
                Swal.fire({
                    title: '@MyERP.Properties.Resources.NotLinked !',
                    text: " ",
                    icon: 'error',
                    showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    confirmButtonColor: '#3085d6'
                });
            }
        });
    }

    function cancelSalesOrder() {
        $('#PointOfSaleDetails').empty();
        $('#SalesOrderDocNum').text('');
        $('#cancelSalesOrder').hide();
        //$('#DepartmentId, #WarehouseId, #CustomerType').removeAttr('disabled'); // Old code
        $('#DepartmentId, #WarehouseId').removeAttr('disabled');
        $('#VendorOrCustomerId').removeAttr('disabled').trigger('change');
        SystemPageId = null;
        isLinked = false;
        salesOrderIds = [];
        salesOrdersPaid = 0;
        $('.tab-pane.fade').find('button').removeAttr('disabled');
        CalculateTotals();
        //CalculateTotalRefundableInsurance();
    }

    $('#VoucherDate').on('change', function () {
        GetCurrentTaxPercentage();
        setDocNum();
    });

    function appendSalesInvoiceDetails(r) {
        $('#PointOfSaleDetails').empty().append(r.view);
        $('#PointOfSaleDetails select').select2({
            matcher: matchCustom
        });
        $('#PointOfSaleDetails .money').inputmask({
            alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, 'allowMinus': false, digitsOptional: false, 'placeholder': '0'
        });
        getDocNum = false;
        $('#DepartmentId').val(r.salesInvoice.DepartmentId).trigger('change').attr('disabled', 'disabled');
        setWarehouseValues().then(function () {
            $('#WarehouseId').empty().append(warehouseOptions).val(r.salesInvoice.WarehouseId).trigger('change').attr('disabled', 'disabled');
        });
        $('#PointOfSaleDetails').closest('div').append('<input type="hidden" id="Id" value="' + r.salesInvoice.Id + '"/>');
        SystemPageId = r.salesInvoice.SystemPageId;
        isLinked = r.salesInvoice.IsLinked;
        salesOrderIds = r.salesInvoice.SalesOrdersSalesInvoices;
        $('#VoucherDate').val(r.VoucherDate);
        $('#DocumentNumber').val(r.salesInvoice.DocumentNumber);
        $('#DiscountValue').val(r.salesInvoice.DiscountValue);
        $('#VoucherDiscountPercentage').val(r.salesInvoice.VoucherDiscountPercentage);
        $('#ServiceFees').val(r.salesInvoice.ServiceFees);
        $('#Total').val(r.salesInvoice.Total);
        $('#NetTotal').val(r.salesInvoice.NetTotal);
        $('#TotalAfterTaxes').val(r.salesInvoice.TotalAfterTaxes);
        $('#Paid').val(r.salesInvoice.Paid);
        $('#Remaining').val(($('#Paid').inputmask('unmaskedvalue') * 1 - r.salesInvoice.TotalAfterTaxes).toFixed(2));
    }

    function getPurchaseRequests() {
        $('#purchaseRequestModal').modal('show');
        $('#purchaseRequestModal').find('.modal-body').empty().append('<div class="d-flex align-items-center"><div class="spinner-border ml-auto" role="status" aria-hidden="true"></div></div>');
        $.get('/PointOfSale/PurchaseRqeusts').done(function (r) {
            let table = '<div class="table-responsive"><table class="table table-centered table-sm mb-0"><thead><tr><th>' + '@MyERP.Properties.Resources.PurchaseRequestNo' + '</th><th>' + '@MyERP.Properties.Resources.Date' + '</th><th>' + '@MyERP.Properties.Resources.Branch' + '</th><th>' + '@MyERP.Properties.Resources.ItemsGroup' + '</th><th>' + '@MyERP.Properties.Resources.Details' + '</th><th>' + '@MyERP.Properties.Resources.Add' + '</th></tr></thead><tbody>' + r + '</tbody></table></div>';
            $('#purchaseRequestModal').find('.modal-body').empty().append(table);
        });
    }
    let purchaseReqeustIds = [];
    function getPurchaseRqeustsDetails() {
        $('#preloader, #status').fadeIn();
        purchaseReqeustIds = $.map($('.purchaseRequestId:checked'), function (i) { return $(i).val(); });
        cancelSalesOrder();
        $.ajax({
            type: "POST", contentType: "application/json",
            url: "/PointOfSale/PurchaseRqeustsDetails",
            data:
                JSON.stringify({ purchaseReqeustIds: purchaseReqeustIds }),
            success: function (r) {
                $('#PointOfSaleDetails').empty().append(r.view);
                $('#PointOfSaleDetails select').select2({
                    matcher: matchCustom
                });
                $('#PointOfSaleDetails .money').inputmask({
                    alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, 'allowMinus': false, digitsOptional: false, 'placeholder': '0'
                });
                let docNums = $.map($('.purchaseRequestId:checked'), function (i) { return $(i).attr('doc-num'); });

                $('#PurchaseRequestDocNum').text('@MyERP.Properties.Resources.NumberPurchaseRequests' + ': ' + docNums);
                $('#cancelPurchaseRequest').show();
                $('#VoucherDate').val(r.VoucherDate);
                $('#Id').remove();
                SystemPageId = null;
                isLinked = true;
                $('#CustomerType').val(4).trigger('change');
                $('#DepartmentId')[0].value == 28;
                $('#DepartmentId').trigger('change');
                //setDocNum();
                $('#Paid').val('');
                CalculateTotals();
                //CalculateTotalRefundableInsurance();
                $('#preloader, #status').fadeOut();
            },
            error: function () {
                $('#preloader, #status').fadeOut();
                Swal.fire({
                    title: '@MyERP.Properties.Resources.NotLinked !',
                    text: " ",
                    icon: 'error',
                    showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    confirmButtonColor: '#3085d6'
                });
            }
        });
    }

    function cancelPurchaseRequest() {
        $('#PointOfSaleDetails').empty();
        $('#PurchaseRequestDocNum').text('');
        $('#cancelPurchaseRequest').hide();
        purchaseReqeustIds = [];
        SystemPageId = null;
        isLinked = false;
        CalculateTotals();
        //CalculateTotalRefundableInsurance();
    }

    $(document).on('change', '.quantity', function () {
        //----------- Item Tax Calculations ---------------//
        let itemPrice = $(this).closest('tr').find('.item-price-id');
        var item = items.filter(function (i) { return i.ItemPriceId == itemPrice.val() * 1; })[0];
        var TaxPerc = 0;
        if ($('#Id').val() > 0 && itemPrice.closest('tr').find('.ItemTaxPercentage').val() > 0) {
            TaxPerc = itemPrice.closest('tr').find('.ItemTaxPercentage').val();
        }
        else {
            TaxPerc = item.ItemTaxPercentage;
        }
        TaxPerc = TaxPerc != null ? TaxPerc : 0;
        var TaxValue = (parseFloat(itemPrice.closest('tr').find('.price').inputmask('unmaskedvalue')*1) * parseInt($(this).val())) * (parseFloat(TaxPerc) / 100);
        itemPrice.closest('tr').find('.ItemTaxPercentage').val(TaxPerc);
        itemPrice.closest('tr').find('.ItemTaxValue').val(TaxValue);
        //-------------------------------------------------------------------//

        CalculateTotals();
        //CalculateTotalRefundableInsurance();
    });

    $(document).on('change', '#DeliveryCost', function () {
        CalculateTotals();
        $('#TotalAfterTaxes').trigger('change');
        //CalculateTotalRefundableInsurance();
    });

    function deleteElement(e)
    {
        let RowId = $(e).closest('tr').find('.RowId').text();
        if ($(e).closest('tr').find('.Main').text() == "Main")
        {
            $('#PointOfSaleDetails tr').each(function ()
            {
                tr = $(this);
                if (tr.find('.RowId').text() == RowId && tr.find('.Main').text() != "Main")
                {
                    tr.remove();
                }
            });
        }
        $(e).closest('tr').remove();
        CalculateTotals();
        //CalculateTotalRefundableInsurance();
    }

    //----- Function that responsible for get Additional Items of current item and draw them in pop up  ------ //
    function ShowExtra(e)
    {

        let id = $(e).closest('tr').find('.item').val();
        let RowId = $(e).closest('tr').find('.RowId').text();
        $.ajax({
            type: "GET",
            contentType: "application/json",
            url: "/AdditionalItem/GetAdditionalItems/" + id,
            success: function (r) {
                $('#AdditionalItems').empty();
                //$('#ItemUnitId').append($("<option></option>").val(0).html("إختر الوحدة"))
                if (r == 0) {
                    //$('#exampleModal').modal("hide");
                    Swal.fire({
                        title: '@MyERP.Properties.Resources.ThereAreNoAdditivesForThisItem !',
                        text: " ",
                        icon: 'info',
                        showCancelButton: false,
                        confirmButtonText: '@MyERP.Properties.Resources.Ok',
                        confirmButtonColor: '#3085d6'
                    });
                }
                else
                {
                    for (var i = 0; i < r.length; i++)
                    {
                        $('#AdditionalItems').append('<tr><td hidden class="RowId">'+RowId+'</td><td class="ItemId" hidden>' + r[i].ItemId + '</td><td class="MainItemId" hidden>' + id + '</td><td class="ItemPriceId" hidden>' + r[i].ItemPriceId + '</td><td class="ArName">' + r[i].ArName + '</td><td class="ItemUnitId">' + r[i].ItemUnit + '</td><td hidden name="Extra" class="ExtraQuantity">' + r[i].ExtraQuantity + '</td><td><button onclick="AddExtra(this)" name="Extra" class=" btn btn-danger ExtraPrice">' + r[i].ExtraPrice + '</button></td><td hidden name="Double" class="DoubleQuantity">' + r[i].DoubleQuantity + '</td><td><button class=" btn btn-danger DoublePrice" name="Double" onclick="AddExtra(this)">' + r[i].DoublePrice + '</button></td><td><button name="NoExtra" class=" btn btn-danger NoExtraPrice" onclick="AddExtra(this)">0</button></td></tr>');
                    }

                    $('#exampleModal').modal("show");
                }
            },
            error: function () {
                Swal.fire({
                    title: '@MyERP.Properties.Resources.AnErrorOccurredTryAgain !',
                    text: " ",
                    icon: 'error',
                    showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    confirmButtonColor: '#3085d6'
                });
            }
        });
    }

    //----- Function that responsible for add Additional Item that has been chosen from the pop up to the tabel of Items with its values ------ //
    function AddExtra(e)
    {

        $('#exampleModal').modal("hide");
        let name = $(e).attr('name');
        let ItemId = $(e).closest('tr').find('.ItemId').text();
        let MainItemId = $(e).closest('tr').find('.MainItemId').text();
        let RowId = $(e).closest('tr').find('.RowId').text();



        //----------------------------- new way (Add additional items for choisen main item in order under this item) ---------------------------------------------//
        let WantedRow;
        let count = 0;
        $('#PointOfSaleDetails tr').each(function () {
            tr = $(this);
            MainItem = tr.closest('tr').find('.MainItemId').text();
            rowid = tr.closest('tr').find('.RowId').text();

            if (RowId == rowid && tr.find('.Main').text() == "Main")
            {

                WantedRow = tr;
            }
            else
            {
                if (RowId == rowid)
                {
                    count++;
                }
            }
        });
        // create variable to carry the data of Extra type id to distinguish the additional item from main item at edit time
        let ExtraTypeId;
        if (name == "Extra")
        {
            ExtraTypeId = 1;
        }
        else
        {
            if (name == "Double") {
                ExtraTypeId = 2;
            }
            else
            {
                if (name == "NoExtra")
                {
                    ExtraTypeId = 3;
                }
            }
        }

        if (count > 0)
        {
            $('#PointOfSaleDetails').find('tr.' + RowId + ':last').after('<tr class="' + RowId + '" bgcolor="pink"><td hidden class="RowId">' + RowId + '</td><td hidden class="MainItemId">' + MainItemId + '</td><td class="tabledit-edit-mode" colspan="1"><input type="hidden" class="item extra" required value="' + ItemId + '" /> <input type="text" class="item-name form-control tabledit-input form-control-sm" required readonly value="' + $(e).closest('tr').find('.ArName').text() + '" /><input type="hidden" class="barcode" required /><input type="hidden" class="item-price-id" value="' + $(e).closest('tr').find('.ItemPriceId').text() + '" required /></td > <td class="tabledit-edit-mode" colspan="1"><input class="money quantity form-control tabledit-input form-control-sm" type="text" readonly required value="' + $(e).closest('tr').find('.' + name + 'Quantity').text() + '" /></td><td class="tabledit-edit-mode" colspan="1"><select class="item-unit form-control tabledit-input form-control-sm" required></select><input class="unit-equavalent form-control tabledit-input form-control-sm small-number" type="hidden" required /></td><td class="tabledit-edit-mode" colspan="1"><input type="text" class="money price form-control tabledit-input form-control-sm" required readonly value="' + $(e).closest('tr').find('.' + name + 'Price').text() + '" /><input hidden type="text" class="money accessoryPrice form-control tabledit-input form-control-sm"  readonly value=""/></td><td class="tabledit-edit-mode" colspan="1"><input type="text" class="money total form-control tabledit-input form-control-sm" required readonly /><input hidden class="itemTotalAccessoryPrice" readonly /></td><td><a href="javascript:void(0);" onclick="deleteElement(this)"><i class="fas fa-trash-alt"></i></a></td><td hidden><input class="ExtraTypeId" required value="' + ExtraTypeId + '" /></td></tr >');

            $('#PointOfSaleDetails tr select').select2({
                matcher: matchCustom
            });

            getItemUnits(ItemId).done(function (r) {
                let units = '';
                for (var i = 0; i < r.length; i++) {
                    units += '<option value="' + r[i].Id + '">' + r[i].ArName + '</option>';
                }

                let WantedSelect = $('#PointOfSaleDetails').find('tr.' + RowId + ':eq(' + count + ')');
                WantedSelect.closest('tr').find('.item-unit').append(units).trigger('change');
            });

        }
        else
        {
            WantedRow.after('<tr class="' + RowId + '" bgcolor="pink"><td hidden class="RowId">' + RowId + '</td><td hidden  class="MainItemId">' + MainItemId + '</td><td class="tabledit-edit-mode" colspan="1"><input type="hidden" class="item extra" required value="' + ItemId + '" /> <input type="text" class="item-name form-control tabledit-input form-control-sm" required readonly value="' + $(e).closest('tr').find('.ArName').text() + '" /><input type="hidden" class="barcode" required /><input type="hidden" class="item-price-id" value="' + $(e).closest('tr').find('.ItemPriceId').text() + '" required /></td > <td class="tabledit-edit-mode" colspan="1"><input class="money quantity form-control tabledit-input form-control-sm" type="text" readonly required value="' + $(e).closest('tr').find('.' + name + 'Quantity').text() + '" /></td><td class="tabledit-edit-mode" colspan="1"><select class="item-unit form-control tabledit-input form-control-sm" required></select><input class="unit-equavalent form-control tabledit-input form-control-sm small-number" type="hidden" required /></td><td class="tabledit-edit-mode" colspan="1"><input type="text" class="money price form-control tabledit-input form-control-sm" required readonly value="' + $(e).closest('tr').find('.' + name + 'Price').text() + '" /><input hidden type="text" class="money accessoryPrice form-control tabledit-input form-control-sm"  readonly value=""/></td><td class="tabledit-edit-mode" colspan="1"><input type="text" class="money total form-control tabledit-input form-control-sm" required readonly /><input hidden class="itemTotalAccessoryPrice" readonly /></td><td><a href="javascript:void(0);" onclick="deleteElement(this)"><i class="fas fa-trash-alt"></i></a></td><td hidden><input class="ExtraTypeId" required value="' + ExtraTypeId + '" /></td></tr > ');

            $('#PointOfSaleDetails tr select').select2({
                matcher: matchCustom
            });

            getItemUnits(ItemId).done(function (r) {
                let units = '';
                for (var i = 0; i < r.length; i++)
                {
                    units += '<option value="' + r[i].Id + '">' + r[i].ArName + '</option>';
                }

                let WantedSelect = $('#PointOfSaleDetails').find('tr.' + RowId + ':eq(' + count + ')');
                WantedSelect.closest('tr').find('.item-unit').append(units).trigger('change');
            });

        }

        //----------------------------- end of new way ---------------------------------------------//

        CalculateTotals();
        // CalculateTotalRefundableInsurance();
    }

    $(document).on('change', '#DiscountValue', function () {
        let total = 0;
        let totalAccessoryPrice = 0;
        $('.price').each(function () {
            total += $(this).val() * $(this).closest('tr').find('.quantity').val();

            let accessoryPrice = $(this).closest('tr').find('.accessoryPrice').val();
            let itemTotalAccessoryPrice = accessoryPrice * $(this).closest('tr').find('.quantity').val();
            $(this).closest('tr').find('.itemTotalAccessoryPrice').val(itemTotalAccessoryPrice);

            totalAccessoryPrice += itemTotalAccessoryPrice;
        });
        if (($(this).inputmask('unmaskedvalue') / total) >= 1) {
            $(this).val(0);
        }

        var VoucherPerc = ($(this).inputmask('unmaskedvalue') * 100 / total).toFixed(2);
        $('#VoucherDiscountPercentage').val(VoucherPerc);

        var Perc = $('#VoucherDiscountPercentage').val() / 100;
        if (Perc > CashierMaximumAllowedDiscountPercentage) {
            $('#DiscountModal').modal('show');
        }
        else {
            CalculateTotals(total, totalAccessoryPrice);
        }
    });


    $(document).on('change', '#VoucherDiscountPercentage', function () {
        let total = 0;
        let totalAccessoryPrice = 0;
        $('.price').each(function () {
            total += $(this).val() * $(this).closest('tr').find('.quantity').val();

            let accessoryPrice = $(this).closest('tr').find('.accessoryPrice').val();
            let itemTotalAccessoryPrice = accessoryPrice * $(this).closest('tr').find('.quantity').val();
            $(this).closest('tr').find('.itemTotalAccessoryPrice').val(itemTotalAccessoryPrice);

            totalAccessoryPrice += itemTotalAccessoryPrice;
        });
        //if (($(this).inputmask('unmaskedvalue') / total) >= 1) {
        //    $(this).val(0);
        //}
        var value = ($(this).inputmask('unmaskedvalue') / 100 * total)
        $('#DiscountValue').val(value);

        var Perc = $($(this)).val() / 100;
        if (Perc > CashierMaximumAllowedDiscountPercentage) {
            $('#DiscountModal').modal('show');
        }
        else {
            CalculateTotals(total, totalAccessoryPrice);
        }
    });

    function ResetDiscountValue() {
        // if (!$('#PosManagerPassword').val()) {
        $('#DiscountValue').val(0);
        $('#VoucherDiscountPercentage').val(0);
        //}
    }

    $(document).on('keydown', '#pos-customer-mobile', function (e) {
        if (e.which == 13 || e.keyCode == 13) {
            let elem = $(this);
            let mobileNo = elem.val();
            searchPosCustomers(mobileNo);
        }
    });

    function searchPosCustomers(mobileNo) {
        //requestCache['/Helper/SearchPosCustomers?mobileNo=' + mobileNo] = null;

        $.get('/Helper/SearchPosCustomers?mobileNo=' + mobileNo).done(function (r) {
            if (r.posCustomer != null) {
                $("#PosCustomerId").val(r.posCustomer.PosCustomerId).trigger('change');
                showPosCustomerModal(r.posCustomer, false, null);
            }
            else {
                Swal.fire({
                    title: '@MyERP.Properties.Resources.ThereIsNoCustomerWithThisNoDoYouWantToAdd',
                    text: " ",
                    icon: 'info',
                    showCancelButton: true,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    cancelButtonText: '@MyERP.Properties.Resources.Cancel',
                    confirmButtonColor: '#3085d6',
                    cancelButtonColor: '#d33',
                    reverseButtons: true
                }).then((result) => {
                    if (result.isConfirmed) {
                        showPosCustomerModal(null, true, mobileNo);
                    }
                    else { result.dismiss; }
                });
                @*if (confirm('@MyERP.Properties.Resources.ThereIsNoCustomerWithThisNoDoYouWantToAdd'))
                 showPosCustomerModal(null, true, mobileNo);*@
            }
        });
    }

    $(document).on('change', '.PaymentAmount', function () {
        let totalPaied = 0;
        $('#SalesInvoicePaymentMethods tr').each(function () {
            var td = $(this);
            totalPaied += td.find('.PaymentAmount').inputmask('unmaskedvalue') * 1;
        });
        $('#Paid').val(totalPaied);
        $('#Remaining').val(($('#Paid').inputmask('unmaskedvalue') - $('#TotalAfterTaxes').inputmask('unmaskedvalue')).toFixed(2))
    });

    $('.PaymentAmount').on('click', function () {
        selectedPaymentMethodInput = $(this);
    });

