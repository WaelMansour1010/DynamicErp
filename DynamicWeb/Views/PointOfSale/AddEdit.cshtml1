    function getCities() {
        $('#CityId').empty();


        $.get('/Helper/getCities').done(function (r) {

            for (var i = 0; i < r.length; i++) {
                $('#CityId').append($('<option>', {
                    value: r[i].Id,
                    text: r[i].ArName
                }));
            }

            //$('#CityId').trigger('change');
        });

    }

