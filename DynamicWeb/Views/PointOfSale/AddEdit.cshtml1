                        <button onclick="SendToKitchen()" class="btn btn-success"> @MyERP.Properties.Resources.SendToKitchen </button>
                        <button onclick="Payinvoice()" class="btn btn-success"> @MyERP.Properties.Resources.PayInvoice </button>

