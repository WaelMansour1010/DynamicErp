@model MyERP.Models.SalesInvoice

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = MyERP.Properties.Resources.PointOfSales;
    if (ViewBag.IsCashier == true || ViewBag.IsWaiter == true)
    {
        Layout = "~/Views/Shared/_CashierLayout.cshtml";
    }
}
<link href="~/assets/css/easy-numpad.css" rel="stylesheet" />
<link href="~/Content/numpad-light.css" rel="stylesheet" />
<style>
    /* styel for clock */
    .clock {
        width: fit-content;
        height: fit-content;
        /*background-color: #000;*/
        color: #fff;
        /*padding: 8px;*/
        border-radius: 5px
    }
</style>
<script src="~/Scripts/numpad.js"></script>
<script src="~/assets/js/easy-numpad.js"></script>
<link href="~/assets/StarWebPrint/css/import.css" rel="stylesheet" type="text/css">
<link rel="stylesheet" href="~/assets/StarWebPrint/style.css" media="screen">

<link href="~/assets/StarWebPrintcss/style_canvasreceipt.css" rel="stylesheet" type="text/css">
<script type='text/javascript' src='~/assets/StarWebPrint/js/StarWebPrintBuilder.js'></script>
<script type='text/javascript' src='~/assets/StarWebPrint/js/StarWebPrintTrader.js'></script>
<script src="~/assets/js/QRjs/jquery.qrcode.min.js"></script>
