                    //    itemPrice.Price * itemPrice.Quantity + '" /><input hidden class="itemTotalAccessoryPrice" readonly /></td><td><a href="javascript:void(0);" onclick="deleteElement(this)"><i class="fas fa-trash-alt"></i></a></td><td class=" EnableAdditionalItemsOnPos text-center"><a href="javascript:void(0);" onclick="ShowExtra(this)" /*data-toggle="modal" data-target="#exampleModal*/"><i class="fa fa-plus" aria-hidden="true"></i></a ></td ></tr > ';
                    var ItemNotes = "";// itemPrice.ItemNotes != null ? itemPrice.ItemNotes : "";
                    let tr = '<tr><td hidden class="RowId">' + RowId + '</td><td hidden class="Main">Main</td>' +
