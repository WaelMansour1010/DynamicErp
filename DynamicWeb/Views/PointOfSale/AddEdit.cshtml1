         aria-labelledby="invoiceInfoModal" aria-hidden="true">
        <div class="modal-dialog modal-lg" style="width:fit-content">
            <div class="modal-content">
                <div class="modal-header">
                    <h4 class="modal-title" id="invoiceInfoModalTitle">@MyERP.Properties.Resources.MainData</h4>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="form-group form-row">
                        <label class=" col-sm-4 control-label" for="DocumentNumber">@MyERP.Properties.Resources.InvoiceNo</label>
                        <div class="col-sm-8">
                            @Html.EditorFor(model => model.DocumentNumber, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly", placeholder = @MyERP.Properties.Resources.DocNo, required = "required", hidden = "hidden" } })
                            <input id="DocumentNumbers" class="form-control" placeholder=@MyERP.Properties.Resources.DocNo required readonly />
                        </div>
                    </div>
                    <div class="form-group form-row">
                        <label for="VoucherDate" class=" col-sm-4 control-label">@MyERP.Properties.Resources.InvoiceDate</label>
                        <div class="col-sm-8">
                            <input id="VoucherDate" name="VoucherDate" class="form-control" type="datetime-local" value="@ViewBag.VoucherDate" required readonly />
                        </div>
                    </div>
                    <div class="form-group form-row">
                        <label class=" col-sm-4 control-label" for="CustomerType">@MyERP.Properties.Resources.InvoiceType</label>
                        <div class="col-sm-8">
                            @Html.DropDownList("CustomerType", null, htmlAttributes: new { @class = "form-control", @required = "required", @disabled = "disabled" })
                        </div>
                    </div>
                    <div class="form-group form-row">
                        <label class=" col-sm-4 control-label" for="DepartmentId">@MyERP.Properties.Resources.Branch</label>
                        <div class="col-sm-8">
                            @Html.DropDownList("DepartmentId", null, htmlAttributes: new { @class = "form-control", @required = "required" })
                        </div>
                    </div>
                    <div class="form-group form-row">
                        <label class=" col-sm-4 control-label" for="WarehouseId"> @MyERP.Properties.Resources.WareHouse</label>
                        <div class="col-sm-8">
                            @Html.DropDownList("WarehouseId", null, htmlAttributes: new { @class = "form-control", @required = "required" })
                        </div>
                    </div>

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">@MyERP.Properties.Resources.Close</button>
                </div>
            </div>
        </div>
    </div>
    <!--Invoice Type-->
    <div class="modal fade bs-example-modal-lg" id="invoiceTypeModal" tabindex="-1" role="dialog"
         aria-labelledby="invoiceTypeModal" aria-hidden="true">
        <div class="modal-dialog modal-lg" style="width:fit-content">
            <div class="modal-content">
                <div class="modal-header">
                    <h4 class="modal-title" id="invoiceTypeModalTitle">@MyERP.Properties.Resources.InvoiceType</h4>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="form-group form-row">
                        <button class="btn btn-success m-1 getForm" customerType="3">
                            @MyERP.Properties.Resources.Delivery <i class="fa fa-truck"></i>
                        </button>
                        <button class="btn btn-success m-1 getForm" customerType="1">
                            @MyERP.Properties.Resources.TakeAway <i class="fa fa-hamburger"></i>
                        </button>
                        <button class="btn btn-success m-1" id="tables" onclick="showTablesModal()" customerType="2">
                            @MyERP.Properties.Resources.Tables <i class="fa fa-utensils"></i>
                        </button>

                        <button class="btn btn-success m-1 getForm" customerType="4" id="ShowDepartmentBtn" style="display:none;">
                            @MyERP.Properties.Resources.Department <i class="fa fa-file-invoice"></i>
                        </button>
                    </div>


                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">@MyERP.Properties.Resources.Close</button>
                </div>
            </div>
        </div>
    </div>
    @*modal of extras*@
    <div class="modal fade" id="exampleModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h3 class="modal-title" id="exampleModalLabel">@MyERP.Properties.Resources.AdditionalItems</h3>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="table-responsive">
                        <table class="table table-centered table-sm mb-0">
                            <thead>
                                <tr>
                                    <th>@MyERP.Properties.Resources.Item </th>
                                    <th>@MyERP.Properties.Resources.Unit</th>
                                    <th>@MyERP.Properties.Resources.Increase</th>
                                    <th>@MyERP.Properties.Resources.Double</th>
                                    <th>@MyERP.Properties.Resources.Without</th>
                                </tr>
                            </thead>
                            <tbody id="AdditionalItems">
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer">
                    @*<button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                        <button type="button" class="btn btn-primary">Save changes</button>*@
                </div>
            </div>
        </div>
    </div>
    <!-- Tables Modal -->
    <div id="tablesModal" class="modal fade bd-example-modal-xl" tabindex="-1" role="dialog" aria-labelledby="myHugeModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-xl">
