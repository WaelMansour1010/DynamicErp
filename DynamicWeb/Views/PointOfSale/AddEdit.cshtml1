    function showPosCustomerModal(posCustomer, isNew, mobileNo) {
        if(posCustomer != null && isNew == false) {

            $("#posCustomerIdInput").val(posCustomer.PosCustomerId);
            $("#posCustomerCodeInput").val(posCustomer.PosCustomerCode);


            $("#PosCustomerArName").val(posCustomer.ArName);
            $("#PosCustomerEnName").val(posCustomer.EnName);
            $("#PosCustomerAddress").val(posCustomer.Address);
            $("#PosCustomerNotes").val(posCustomer.Notes);
            $("#Mobile1").val(posCustomer.Mobile1);
            $("#Mobile2").val(posCustomer.Mobile2);

            $("#PosLinkedCustomerId").val(posCustomer.CustomerId);
            $("#PosLinkedCustomerId").select2();

            $("#GovernorateId").val(posCustomer.GovernorateId).trigger('change');
            $("#CityId").val(posCustomer.CityId).trigger('change');
            $("#AreaId").val(posCustomer.AreaId).trigger('change');

            //$("#CityId").val(posCustomer.CityId).trigger('change')
            //$("#AreaId").val(posCustomer.AreaId).trigger('change'))
        }
        else {
            if (mobileNo != "" && mobileNo != null)
                $("#Mobile1").val(mobileNo);
            else
                $("#Mobile1").val("");

            $("#PosCustomerArName").val("");
            $("#PosCustomerEnName").val("");
            $("#PosCustomerAddress").val("");
            $("#PosCustomerNotes").val("");
        }



        $('#pos-customer-modal').modal("show");
    }

    function getGovernorates() {
        $.get('/Helper/GetGovernorates/').done(function (r) {
            $('#GovernorateId').empty();
            @*$('#GovernorateId').append($('<option>',{
                value: "",
                text: '@MyERP.Properties.Resources.Select'
            }));*@
            for (var i = 0; i < r.length; i++) {
                $('#GovernorateId').append($('<option>', {
                    value: r[i].Id,
                    text: r[i].ArName
                }));
            }

            $('#GovernorateId').trigger('change');
        });
    }

    function getDrivers() {
        return requestData('/Helper/GetDriversByDep?depId='+$("#DepartmentId").val()).done(function (r) {
            $('.DriverId').empty();
            $('.DriverId').append($('<option>', {
                value: "",
                text: '@MyERP.Properties.Resources.Select'
            }));
            for (var i = 0; i < r.length; i++) {
                $('.DriverId').append($('<option>', {
                    value: r[i].Id,
                    text: r[i].ArName
                }));
            }

            //$('#GovernorateId').trigger('change');
        });
    }

