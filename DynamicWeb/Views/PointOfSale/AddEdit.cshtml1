    function AddToSalesInvoicePrintQueue(id, status) {
        $.get('/SalesInvoice/AddToSalesInvoicePrintQueue?SalesInvoiceId=' + id + '&Status=' + status).done(function (r) {
            console.log("AddToSalesInvoicePrintQueue : ", r);
        });
    }

    $(document).on('click', '.PaymentMethodName', function () {
        var TotalAfterTaxes = $('#TotalAfterTaxes').inputmask('unmaskedvalue');
        $('.PaymentAmount').val(0);
        $(this).closest('tr').find('.PaymentAmount').val(TotalAfterTaxes);
        //$('#selectedTableWaitersName').val('');
    });



    let DepartmentHallsOptions = '';

    function GetHallsByDepartmentId() {
        DepartmentHallsOptions = '';
        $.get('/Helper/GetHallsByDepartmentId?departmentId=' + $('#DepartmentId').val()).done(function (r) {
            DepartmentHalls = r;
            for (var i = 0; i < DepartmentHalls.length; i++) {
                DepartmentHallsOptions += '<option value="' + DepartmentHalls[i].Id + '">' + DepartmentHalls[i].ArName + '</option>';
            }

            $("#DepartmentHallsId").empty().append(DepartmentHallsOptions)
        });
    }
    function getItems() {
        return requestData('/Helper/ItemsByDepId/?departmentId=' + $('#DepartmentId').val()).done(function (r) {
            items = r;
        });
    }

    var HallTables = [];
    $("#DepartmentHallsId").on('change', function () {
        //  $("#TablesTable tr").remove();
        $("#TablesDiv").empty();
        GetTableByHallId();
        $('#PosCustomerId').trigger('change');
    });

    var HallIncreasePercentage = 0;
    var HallIncreaseValue = 0;

    function GetTableByHallId(IsChange) {
        $.get('/Helper/GetTableByHallId?hallId=' + $('#DepartmentHallsId').val() + '&IsChange=' + IsChange).done(function (r) {
            HallTables = r;
            if (HallTables.length) {
                HallIncreasePercentage = HallTables[0].HallIncreasePercentage;
                HallIncreaseValue = HallTables[0].HallIncreaseValue;

                if (HallIncreasePercentage > 0) {
                    HallIncreasePercentage = parseFloat(HallIncreasePercentage/100);
                }
                else if (HallIncreaseValue > 0) {
                    HallIncreaseValue = parseFloat(HallIncreaseValue);
                }
                //  $("#TablesTable tr").remove();
                $("#TablesDiv").empty();

                //var rowCount = $('#TablesTable tr').length;

                // Draw only 5 tables in row
                if (HallTables.length > 5) {
                    var rowCount = r.length % 5 ? Math.floor((HallTables.length / 5)) + 1 : HallTables.length / 5;
                    var next = iterator(HallTables, 5);

                    for (var j = 1; j <= rowCount; j++) {
                        var tables = next();
                        var tr = '<tr>';

                        drawTablesRow(tables);

                    }
                }
                else {
                    // var rowCount = r.length;

                    drawTablesRow(r)
                }
                $('#tablesModal').modal("show");
            }
            else {
                // $("#TablesTable tr").remove();
                $("#TablesDiv").empty();
                $('#tablesModal').modal("show");
                Swal.fire({
                    title: '@MyERP.Properties.Resources.NoTablesInThisDepartment',
                    text: " ",
                    icon: 'error',
                    showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    confirmButtonColor: '#3085d6'
                });

            }
        });
    }



