                        }


                    }
                    else if (r.success == "false" && r.errors == "NotCashier") {
                        alert("@MyERP.Properties.Resources.TheInvoiceCannotBeAddedOrModifiedUnlessTheUserIsCashier");
                        $('#preloader, #status').fadeOut();
                    }
                    else {
                        $('#preloader, #status').fadeOut();
                        $('#save').prop('disabled', false);
                        $('#SaveAndPrint').prop('disabled', false);
                        alert("@MyERP.Properties.Resources.NotSaved"+"!");

                    }
                    cashBoxBalance();
                    getSalesInvoices();
                },
                error: function (r) {
                    $('#preloader, #status').fadeOut();
                    $('#save').prop('disabled', false);
                    $('#SaveAndPrint').prop('disabled', false);
                    alert("@MyERP.Properties.Resources.NotSaved"+"!");
                }
            });
        }*@
    }

    //---------------- Thermal Printer -----------------------//
    var Printer = '@ViewBag.Printer';
    function onSendMessage(GroupPrinter,type) {
        //showNowPrinting();
        var url = type == "Groups" && GroupPrinter!=null ? GroupPrinter:Printer;// document.getElementById('url').value;
        var papertype = 'normal';//document.getElementById('papertype').value;
        var trader = new StarWebPrintTrader({ url: url, papertype: papertype });
        trader.onReceive = function (response) {
            // hideNowPrinting();

            var msg = '- onReceive -\n\n';

            msg += 'TraderSuccess : [ ' + response.traderSuccess + ' ]\n';

            //      msg += 'TraderCode : [ ' + response.traderCode + ' ]\n';

            msg += 'TraderStatus : [ ' + response.traderStatus + ',\n';

            if (trader.isCoverOpen({ traderStatus: response.traderStatus })) { msg += '\tCoverOpen,\n'; }
            if (trader.isOffLine({ traderStatus: response.traderStatus })) { msg += '\tOffLine,\n'; }
            if (trader.isCompulsionSwitchClose({ traderStatus: response.traderStatus })) { msg += '\tCompulsionSwitchClose,\n'; }
            if (trader.isEtbCommandExecute({ traderStatus: response.traderStatus })) { msg += '\tEtbCommandExecute,\n'; }
            if (trader.isHighTemperatureStop({ traderStatus: response.traderStatus })) { msg += '\tHighTemperatureStop,\n'; }
            if (trader.isNonRecoverableError({ traderStatus: response.traderStatus })) { msg += '\tNonRecoverableError,\n'; }
            if (trader.isAutoCutterError({ traderStatus: response.traderStatus })) { msg += '\tAutoCutterError,\n'; }
            if (trader.isBlackMarkError({ traderStatus: response.traderStatus })) { msg += '\tBlackMarkError,\n'; }
            if (trader.isPaperEnd({ traderStatus: response.traderStatus })) { msg += '\tPaperEnd,\n'; }
            if (trader.isPaperNearEnd({ traderStatus: response.traderStatus })) { msg += '\tPaperNearEnd,\n'; }

            msg += '\tEtbCounter = ' + trader.extractionEtbCounter({ traderStatus: response.traderStatus }).toString() + ' ]\n';

            //      msg += 'Status : [ ' + response.status + ' ]\n';
            //
            //      msg += 'ResponseText : [ ' + response.responseText + ' ]\n';

            console.log(msg);
        }

        trader.onError = function (response) {
            var msg = '- onError -\n\n';

            msg += '\tStatus:' + response.status + '\n';

            msg += '\tResponseText:' + response.responseText + '\n\n';

            msg += 'Do you want to retry?\n';

            var answer = confirm(msg);

            if (answer) {
                onSendMessage(GroupPrinter, type);
            }
            //else {
            //    hideNowPrinting();
            //}
        }

        try {
            var canvas = document.getElementById('canvasPaper');
            if (canvas.getContext) {
                var context = canvas.getContext('2d');
                var builder = new StarWebPrintBuilder();
                var request = '';
                request += builder.createInitializationElement();
                request += builder.createBitImageElement({ context: context, x: 0, y: 0, width: canvas.width, height: canvas.height });
                request += builder.createCutPaperElement({ feed: true });
                trader.sendMessage({ request: request });
                window.location.replace("/PointOfSale/AddEdit");
            }
        }
        catch (e) {
            //hideNowPrinting();
            console.log(e.message);
        }
    }

    function drawReceipt(fontSize, lineSpace, receiptWidth, logoScale, obj, type) {
        var canvas = document.getElementById('canvasPaper');
        if (canvas.getContext) {
            receiptWidth = $(canvas).attr('width');
            var context = canvas.getContext('2d');

            context.clearRect(0, 0, canvas.width, canvas.height);

            context.textAlign = 'start';
            context.textBaseline = 'top';

            var font = '';

            //if (document.getElementById('italic').checked) font += 'italic ';

            font += fontSize + 'px ';

            font += 'Arial';// document.getElementById('font').value;

            context.font = font;

            leftPosition = 0;
            //      centerPosition =  canvas.width       / 2;
            centerPosition = (canvas.width - 16) / 2;
            //      rightPosition  =  canvas.width;
            rightPosition = (canvas.width - 16);

            //      cursor = 0;
            cursor = 55 * logoScale;
            cursor += lineSpace;

            var DocumentNumber = $('#DocumentNumbers').val();
            var VoucherDate = $('#VoucherDate').val();
            DrawCenterText(DocumentNumber); DrawRightText(':رقم الطلب ');
            cursor += lineSpace;
            DrawLeftText(VoucherDate); DrawRightText(':وقت الطباعة');
            cursor += lineSpace;

            context.fillRect(0, cursor - 2, receiptWidth, 2);     // Underline

            DrawLeftText('استلام');
            cursor += lineSpace;
            DrawCenterText(DocumentNumber); DrawRightText(':فاتورة');
            cursor += lineSpace;
            DrawRightText(VoucherDate);
            cursor += lineSpace;
            DrawLeftText('المنشئ:'); DrawRightText('Mohammed abdullah');
            cursor += lineSpace;

            if (type == "Groups") {
                cursor += lineSpace;
                context.fillRect(0, cursor - 2, receiptWidth, 2);     // Underline
                DrawLeftText('الصنف'); DrawRightText('الكمية');
                context.fillRect(0, cursor - 2, receiptWidth, 2);     // Underline
                cursor += lineSpace;
            }
            else {
                cursor += lineSpace;
                context.fillRect(0, cursor - 2, receiptWidth, 2);     // Underline
                DrawLeftText('الصنف'); DrawCenterText('الكمية'); DrawRightText('السعر'); cursor += lineSpace;
                context.fillRect(0, cursor - 2, receiptWidth, 2);     // Underline
                cursor += lineSpace;
            }

            context.fillRect(0, cursor - 2, receiptWidth, 2);     // Underline
            cursor += lineSpace;

            //if (obj.length > 0) {
            for (var i = 0; i < obj.length; i++) {
                var _ItemPriceId = obj[i].ItemPriceId;
                let _item = items.filter(function (i) { return i.ItemPriceId == _ItemPriceId })[0];
                var itemName = _item.ArName;
                var itemEnName = _item.EnName != null ? _item.EnName : " ";
                var Qty = obj[i].Qty;
                if (type == "Groups") {
                    DrawLeftText(itemName); DrawRightText(Qty); cursor += lineSpace;
                }
                else {
                    var Price = obj[i].Price;
                    DrawLeftText(itemName); DrawCenterText(Qty); DrawRightText(Price); cursor += lineSpace;
                }
                var GroupPrinter = _item.PrinterName;
                DrawLeftText(itemEnName);
                cursor += lineSpace;
                context.fillRect(0, cursor - 2, receiptWidth, 1);     // Underline

                //}
                if (type != "Groups") {

                    context.fillRect(0, cursor - 2, receiptWidth, 2);     // Underline
                    var NetTotal = $('#NetTotal').inputmask('unmaskedvalue');
                    var Total = $('#Total').inputmask('unmaskedvalue');
                    var SmokingTax = $('#SmokingTax').inputmask('unmaskedvalue');
                    var SalesTaxes = $('#SalesTaxes').inputmask('unmaskedvalue');
                    var TotalAfterTaxes = $('#TotalAfterTaxes').inputmask('unmaskedvalue');
                    var Paid = $('#Paid').inputmask('unmaskedvalue');
                    DrawLeftText('Subtotal'); DrawCenterText(obj.length); DrawRightText(NetTotal); cursor += lineSpace;
                    context.fillRect(0, cursor - 2, receiptWidth, 2);     // Underline

                    cursor += lineSpace;

                    DrawLeftText('المجموع الفرعي:'); DrawRightText(Total); cursor += lineSpace;
                    DrawLeftText('رسم تقديم التبغ 100 %'); DrawRightText(SmokingTax); cursor += lineSpace;
                    DrawLeftText('ضريبة القيمة المضافة 15 %'); DrawRightText(SalesTaxes); cursor += lineSpace;
                    DrawLeftText('الإجمالي:'); DrawRightText(TotalAfterTaxes); cursor += lineSpace;
                    DrawLeftText('المدفوع:'); DrawRightText(Paid); cursor += lineSpace;

                    context.fillRect(0, cursor - 2, receiptWidth, 2);     // Underline
                    DrawLeftText('عدد المنتجات:'); DrawCenterText(obj.length); cursor += lineSpace;
                    context.fillRect(0, cursor - 2, receiptWidth, 2);     // Underline

                    DrawCenterText('جميع أسعار المنتجات شاملة الضريبة'); cursor += lineSpace;
                    DrawCenterText("طريق تركى الأول - حي المحمدية"); cursor += lineSpace;

                    context.fillRect(0, cursor - 2, receiptWidth, 2);     // Underline
                    cursor += lineSpace;
                }
                @*$('#qrcode').qrcode("https://www.google.com.eg/");

                var _canvas = $('#qrcode canvas');

                var img = _canvas.get(0).toDataURL("image/png");
                var image0 = new Image();
                image0.src = img;//'/assets/StarWebPrint/img/StarLogo1.jpg' + '?' + new Date().getTime();

                image0.onload = function () {
                    //context.drawImage(image, canvas.width - image.width * logoScale, 0, image.width * logoScale, image.height * logoScale);
                    context.drawImage(image0, (canvas.width - image.width * logoScale) / 2, 0, image.width * logoScale, image.height * logoScale);

                }

                // Image Logo
                var image = new Image();
                image.src = '@ViewBag.Logo'/* '/assets/StarWebPrint/img/StarLogo1.jpg'*/ + '?' + new Date().getTime();
                image.width = 10;
                image.height = 10;
                image.onload = function () {
                    //context.drawImage(image, canvas.width - image.width * logoScale, 0, image.width * logoScale, image.height * logoScale);
                    context.drawImage(image, (canvas.width - image.width * logoScale) / 2, 0, image.width * logoScale, image.height * logoScale);
                }
                image.onerror = function () {
                    console.log('Image file was not able to be loaded.');
                }*@

                onSendMessage(GroupPrinter, type);
                //alert()
            }
        }
    }


    var cursor = 0;
    var lineSpace = 0;
    var leftPosition = 0;
    var centerPosition = 0;
    var rightPosition = 0;


    function DrawLeftText(text) {
        var canvas = document.getElementById('canvasPaper');

        if (canvas.getContext) {
            var context = canvas.getContext('2d');

            context.textAlign = 'left';

            context.fillText(text, leftPosition, cursor);

            context.textAlign = 'start';
        }
    }

    function DrawCenterText(text) {
        var canvas = document.getElementById('canvasPaper');

        if (canvas.getContext) {
            var context = canvas.getContext('2d');

            context.textAlign = 'center';

            context.fillText(text, centerPosition, cursor);

            context.textAlign = 'start';
        }
    }

    function DrawRightText(text) {
        var canvas = document.getElementById('canvasPaper');

        if (canvas.getContext) {
            var context = canvas.getContext('2d');

            context.textAlign = 'right';

            context.fillText(text, rightPosition, cursor);

            context.textAlign = 'start';
        }
    }
