                EmployeeId + '" hidden /><label class="EmployeeName control-label control-label">' +
                EmployeeName + '</label></td><td class="tabledit-edit-mode"><input type = "number" class="Value form-control tabledit-input form-control-sm" value = "' +
                Value + '" disabled readonly /></td><td class="tabledit-edit-mode"><input type="date" class="FromDate Gregorian form-control tabledit-input form-control-sm" value="' +
                FromDate + '" disabled readonly /></td><td class="tabledit-edit-mode"><input type="date" class="ToDate Gregorian form-control tabledit-input form-control-sm" value="' +
                ToDate + '" disabled readonly /></td><td class="tabledit-edit-mode"><input type="text" class="DistributionTypeId form-control tabledit-input form-control-sm" value="' +
                DistributionTypeId + '" hidden /><label class="DistributionTypeName control-label control-label">' +
                DistributionTypeName + '</label></td><td class="tabledit-edit-mode"><input type = "text" class="CostCenterId form-control tabledit-input form-control-sm" value = "' +
                CostCenterId + '" hidden /><label class="CostCenterName control-label control-label">' +
                CostCenterName + '</label></td><td class="tabledit-edit-mode"><input type="text" class="ProjectId form-control tabledit-input form-control-sm" value="' +
                ProjectId + '" hidden /><label class="ProjectName control-label control-label">' +
                ProjectName + '</label></td><td class="tabledit-edit-mode"><input type="text" class="Notes form-control tabledit-input form-control-sm" value="' +
                Notes + '" /></td><td><a href="javascript:void(0);" onclick="deleteElement(this)"><i class="fas fa-trash-alt"></i></a></td></tr>';
            $('#PrepaidExpenseDetails').append(tr);

            $('#DepartmentId').prop('selectedIndex', 0);
            $('#DepartmentId').select2();
