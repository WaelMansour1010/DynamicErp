            $('#ExpenseAccountId').select2();
            $('#PrePaymentAccountId').prop('selectedIndex', 0);
            $('#PrePaymentAccountId').select2();
            $('#Value').val('');
            $('#EmployeeId').prop('selectedIndex', 0);
            $('#EmployeeId').select2();
            $('#DistributionTypeId').prop('selectedIndex', 0);
            $('#DistributionTypeId').select2();
            $('#ProjectId').prop('selectedIndex', 0);
            $('#ProjectId').select2();
            $('#CostCenterId').prop('selectedIndex', 0);
            $('#CostCenterId').select2();
