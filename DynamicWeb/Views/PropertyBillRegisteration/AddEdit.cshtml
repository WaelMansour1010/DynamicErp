@model MyERP.ViewModels.PropertyBillRegisterationViewModel

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";

    ViewBag.Title = MyERP.Properties.Resources.BillRegisteration;
}

<script src="~/Scripts/SaveAndNew.js"></script>

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
            </div>
            <div class="hed page-title">@MyERP.Properties.Resources.BillRegisteration :</div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="form-horizontal needs-validation" role="form">
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">
                                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                @Html.AntiForgeryToken()
                                @if (Model.Id != 0)
                                {
                                    @Html.HiddenFor(model => model.Id)
                                }
                                else
                                {
                                    <input type="hidden" name="Id" id="Id" value="0" />
                                }

                                <div class="form-group row">
                                    <label class=" col-sm-2 control-label" for="TransactionNumber">@MyERP.Properties.Resources.TransactionNo</label>
                                    <div class="col-sm-4">
                                        <input id="TransactionNumber" name="TransactionNumber" class="form-control" type="text" disabled value="@(Model.TransactionNumber == 0 ? "" : Model.TransactionNumber.ToString())" />
                                    </div>

                                    <label class="col-sm-2 control-label" for="Date">@MyERP.Properties.Resources.Date</label>
                                    <div class="col-sm-4">
                                        <input id="BillRegDate" name="BillRegDate" class="form-control" type="datetime-local" required
                                               value="@(Model.BillRegDate.HasValue ? Model.BillRegDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="PropertyContractId" class="PropertyContractId control-label col-sm-2">@MyERP.Properties.Resources.ContractNo</label>
                                    <div class="PropertyContractId col-sm-4">
                                        @Html.DropDownListFor(model => model.ContractId, Model.Contracts, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control PropertyManagementAccounts", required = "required" })
                                    </div>
                                </div>
                                <div class="form-group row" id="PropertyDiv" style="display:none;">

                                    <label for="RenterId" class="RenterId control-label col-sm-2">@MyERP.Properties.Resources.Renter</label>
                                    <div class="RenterId col-sm-2">
                                        @Html.EditorFor(model => model.RenterId, new { htmlAttributes = new { @class = "form-control", hidden = "hidden" } })
                                        <input id="RenterArName" name="RenterArName" disabled="disabled" class="form-control" type="text" required value="@(Model.RenterArName ?? "")" />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>

                                    <label for="PropertyId" class="PropertyId control-label col-sm-2">@MyERP.Properties.Resources.Property</label>
                                    <div class="PropertyId col-sm-2">
                                        @Html.HiddenFor(model => model.PropertyId)
                                        <input id="PropertyArName" name="PropertyArName" disabled="disabled" class="form-control" type="text" required value="@(Model.PropertyArName ?? "")" />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>

                                    <label for="PropertyDetailId" class="PropertyDetailId control-label col-sm-2">@MyERP.Properties.Resources.Unit</label>
                                    <div class="PropertyDetailId col-sm-2">
                                        @Html.HiddenFor(model => model.PropertyDetailId)
                                        <input id="PropertyUnitNo" name="PropertyUnitNo" disabled="disabled" class="form-control" type="text" required value="@(Model.PropertyUnitNo ?? "")" />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="col-sm-2 control-label ElectricityBillValue" for="ElectricityBillValue">@MyERP.Properties.Resources.Electricity</label>
                                    <div class="col-sm-4">
                                        <input id="ElectricityBillValue" name="ElectricityBillValue" class="form-control" type="number" step="0.01" placeholder=@MyERP.Properties.Resources.Electricity value="@(Model.ElectricityBillValue == 0 ? "" : Model.ElectricityBillValue.ToString())" />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="col-sm-2 control-label GasBillValue" for="GasBillValue">@MyERP.Properties.Resources.Gas</label>
                                    <div class="col-sm-4">
                                        <input id="GasBillValue" name="GasBillValue" class="form-control" type="number" step="0.01" placeholder=@MyERP.Properties.Resources.Gas value="@(Model.GasBillValue == 0 ? "" : Model.GasBillValue.ToString())" />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="col-sm-2 control-label " for="ViolationBillValue">@MyERP.Properties.Resources.Violations</label>
                                    <div class="col-sm-4">
                                        <input id="ViolationBillValue" name="ViolationBillValue" class="form-control ViolationBillValue" type="number" step="0.01" placeholder=@MyERP.Properties.Resources.Violations value="@(Model.ViolationBillValue == 0 ? "" : Model.ViolationBillValue.ToString())" />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            @if (Model.Id == 0)
                            {
                                <div class="col-sm-8 col-sm-offset-2">
                                    <button type="submit" id="newbtn" onclick="addEdit('new')" class="btn btn-success">
                                        @MyERP.Properties.Resources.SaveAndNew
                                    </button>
                                    <button class="btn btn-success" id="save" onclick="addEdit()">
                                        @MyERP.Properties.Resources.Save
                                    </button>
                                    <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                                </div>
                                <div class="col-sm-2">
                                    <button class="btn btn-bordered-info w-75" id="openCashReceipt" onclick="openCashReceipt()" disabled>
                                        @MyERP.Properties.Resources.OpenCashReceipt
                                    </button>
                                </div>
                            }
                            else
                            {
                                <div class="col-sm-8 col-sm-offset-2">
                                    <button class="btn btn-success" id="save" onclick="addEdit()">
                                        @MyERP.Properties.Resources.Save
                                    </button>
                                    <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                                    <button class="btn btn-danger" onclick="DeleteFunc(@Model.Id)">
                                        @MyERP.Properties.Resources.Delete
                                    </button>
                                </div>
                                <div class="col-sm-2">
                                    <button class="btn btn-bordered-info w-75" id="openCashReceipt" onclick="openCashReceipt()">
                                        @MyERP.Properties.Resources.OpenCashReceipt
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card" id="JournalDiv" style="display: none">
    <div class="card">
        <div class="card-body">
            <h5 class="header-title">@MyERP.Properties.Resources.JournalEntries</h5>
            <div class="form-horizontal">
                <div class="form-group row">
                    <label for="txtDocNo" class="col-sm-2 control-label">@MyERP.Properties.Resources.VoucherNo</label>
                    <div class="col-sm-4">
                        <input type="text" class="form-control" name="txtDocNo" value="" id="txtDocNo" disabled>

                    </div>
                    <label for="dtDate" class="col-sm-2 control-label">@MyERP.Properties.Resources.Date </label>
                    <div class="col-sm-4">
                        <input type="datetime-local" class="form-control" name="dtDate" value="" id="dtDate" disabled>
                    </div>

                </div>
                <div class="form-group row">

                    <label for="DepartmentName" class="col-sm-2 control-label">@MyERP.Properties.Resources.Branch</label>
                    <div class="col-sm-4">
                        <input type="text" class="form-control" name="DepartmentName" value="" id="DepartmentName" required disabled>
                    </div>
                </div>
                <div class="form-group row">
                    <label for="txtNotes" class="col-sm-2 control-label">@MyERP.Properties.Resources.Notes</label>
                    <div class="col-sm-11">
                        <textarea type="text" class="form-control" id="txtNotes" value="" name="txtNotes" placeholder=@MyERP.Properties.Resources.Notes disabled></textarea>
                    </div>
                </div>
                <div class="card">
                    <div class="card-body">
                        <h5 class="header-title"> @MyERP.Properties.Resources.JournalEntryDetails</h5>
                        <div class="table-responsive">
                            <table class="table table-centered mb-0">
                                <thead>
                                    <tr>
                                        <th>@MyERP.Properties.Resources.Debit</th>
                                        <th>@MyERP.Properties.Resources.Credit</th>
                                        <th>@MyERP.Properties.Resources.Account</th>
                                    </tr>
                                </thead>
                                <tbody id="journalTBodyDebitCredit">
                                    
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<script>
    //---------- Ready Function --------------------//
    $(document).ready(function () {
        //Add new Bill
        if ($('#Id').val() == 0) {
            $('#PropertyDiv').hide();
        }
        else {//Edit existing bill
            $('#PropertyDiv').show();
            displayJournalDiv($('#Id').val());
        }

    });

    function displayJournalDiv(id){
        //get Journal data from DB
        $('#TransactionNumber').val(id);
        $.get('/PropertyBillRegisteration/getJournalEntry', { billRegisterationId: id }, function (JEResponse) {
            console.log('JournalEntry Data:', JEResponse);
            if (JEResponse.success) {
                $('#preloader, #status').fadeOut();
                LoadJournalDiv(JEResponse);
                $('#JournalDiv').show();
            }
        });
    }

    $('#ContractId').on('change', function () {
        contractChanged($(this).val());
    });

    function getRenterPerContract(contractId) {
        $.get('/PropertyBillRegisteration/GetRenterPerContract?ContractId=' + $('#ContractId').val()).done(function (data) {
            console.log("GetRenterPerContract : " + $('#ContractId').val() + " , data: " + data.value);
            $('#RenterId').val(data.id);
            $('#RenterArName').val(data.value);
        })
    }

    function getPropertyPerContract(contractId) {
        $.get('/PropertyBillRegisteration/GetPropertyPerContract?ContractId=' + $('#ContractId').val()).done(function (data) {
            console.log("GetPropertyPerContract : " + $('#ContractId').val() + " , data: " + data.value);
            $('#PropertyId').val(data.id);
            $('#PropertyArName').val(data.value);
        });
    }

    function getPropertyUnitPerContract(contractId) {
        $.get('/PropertyBillRegisteration/GetPropertyUnitPerContract?ContractId=' + $('#ContractId').val()).done(function (data){
           // console.log("getPropertyUnitPerContract : " + $('#ContractId').val() + " , data: " + data.value);
            $('#PropertyDetailId').val(data.id);
            $('#PropertyUnitNo').val(data.value);
        });
    }

    function contractChanged(contractId) {
        getRenterPerContract(contractId);
        getPropertyPerContract(contractId);
        getPropertyUnitPerContract(contractId);
        $('#PropertyDiv').show();
    }

    //----------------------------------------------------------//
    //*********************************************************//
    function DeleteFunc(id) {
        Swal.fire({
            title: '@MyERP.Properties.Resources.AreYouSureYouWantToDelete',
            text: " ",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: '@MyERP.Properties.Resources.Ok',
            cancelButtonText: '@MyERP.Properties.Resources.Cancel',
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                $('#preloader, #status').fadeIn();
                $.ajax({
                    url: '/PropertyBillRegisteration/Delete',
                    type: 'POST',
                    data: {
                        "Id": id,
                    },
                    error: function (e) {
                        $('#preloader, #status').fadeOut();
                        Swal.fire({
                            title: '@MyERP.Properties.Resources.DeleteDoesNotSucceeded',
                            text: " ",
                            icon: 'error',
                            showCancelButton: false,
                            confirmButtonText: '@MyERP.Properties.Resources.Ok',
                            confirmButtonColor: '#3085d6'
                        });
                    },
                    success: function (r) {
                        if (r == 'true') {
                            window.location.replace('/PropertyBillRegisteration');
                        } else {
                            $('#preloader, #status').fadeOut();
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.DeleteDoesNotSucceeded',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                        }
                    }
                });
            }
            else { result.dismiss; }
        });
    }

    function addEdit(n) {
        let valid = true;
        if ($(".form-control:invalid").length > 0) {
            $('.form-horizontal').addClass('was-validated');
            $('html, body').animate({
                scrollTop: $(".form-control:invalid").eq(0).offset().top - 80
            }, 500);
            console.log($(".form-control:invalid"));
            valid = false;
        }

        if (valid) {
            var propertyBillRegisteration = {
                Id: parseInt($('#Id').val(),10),
                TransactionNumber: parseInt($('#Id').val(),10),
                BillRegDate: $('#BillRegDate').val(),
                ContractId: parseInt($('#ContractId').val(), 10),
                RenterId: parseInt($('#RenterId').val(), 10),
                PropertyDetailId: parseInt($('#PropertyDetailId').val(), 10),
                GasBillValue: parseFloat($('#GasBillValue').val()),
                ElectricityBillValue: parseFloat($('#ElectricityBillValue').val()),
                ViolationBillValue: parseFloat($('#ViolationBillValue').val()),
            }
            Swal.fire({
                title: '@MyERP.Properties.Resources.AreYouSureYouWantToSave',
                text: " ",
                icon: 'info',
                showCancelButton: true,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                cancelButtonText: '@MyERP.Properties.Resources.Cancel',
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    $('#preloader, #status').fadeIn();
                    $('#newbtn').prop('disabled', true);
                    $('#save').prop('disabled', true);
                    $('#SaveAndPrint').prop('disabled', true);
                    $.ajax({
                        type: "POST", contentType: "application/json",
                        url: "/PropertyBillRegisteration/AddEdit",
                        data:
                            JSON.stringify({ propertyBillRegisteration }),
                        success: function (r) {
                            if (r.success == "true") {
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.Saved',
                                    text: " ",
                                    icon: 'success',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6',
                                    timer: 3000, // Close after 3 seconds (3000 milliseconds)
                                });
                                if (n == 'report') {
                                    window.open("/Report/PropertyBillRegisteration/" + r.id);
                                    window.location.replace("/PropertyBillRegisteration");
                                }
                                else if (n == 'new') {
                                    window.location.replace("/PropertyBillRegisteration/AddEdit");
                                }
                                else {
                                    $('#Id').val(r.id);
                                    $('#openCashReceipt').prop("disabled", false);
                                    displayJournalDiv(r.id);
                                }
                            } else {
                                $('#preloader, #status').fadeOut();
                                $('#newbtn').prop('disabled', false);
                                $('#save').prop('disabled', false);
                                $('#SaveAndPrint').prop('disabled', false);
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.NotSaved !',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                            }
                        },
                        error: function (r) {
                            console.error("Error during JSON serialization:", r);
                            $('#preloader, #status').fadeOut();
                            $('#newbtn').prop('disabled', false);
                            $('#save').prop('disabled', false);
                            $('#SaveAndPrint').prop('disabled', false);
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.NotSaved !',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                        }
                    });
                }
                else { result.dismiss; }
            });
        }
    }

    function convertToDateTimeLocalFormat(value) {
        if (value === null) return null;

        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));

        var year = dt.getFullYear();
        var month = (dt.getMonth() + 1).toString().padStart(2, '0');
        var day = dt.getDate().toString().padStart(2, '0');
        var hours = dt.getHours().toString().padStart(2, '0');
        var minutes = dt.getMinutes().toString().padStart(2, '0');

        return `${year}-${month}-${day}T${hours}:${minutes}`;
    }

    function LoadJournalDiv(JEntryDetails) {

        $('#JournalDiv').show(); // Show the div
        $('#txtDocNo').val(JEntryDetails.JEDocNo);

        const formattedDate = ((convertToDateTimeLocalFormat(JEntryDetails.JEDate) == null) ? "" : convertToDateTimeLocalFormat(JEntryDetails.JEDate));
       
        $('#dtDate').val(formattedDate);
        $('#DepartmentName').val(JEntryDetails.JEDepartment);
        $('#txtNotes').val(JEntryDetails.Notes);
        var JEDetails = JEntryDetails.JEDetails;
        //clear any previous journal entry details if exist
        $("#journalTBodyDebitCredit").html("");
        // Loop through JEntryDetails and populate the table
        JEDetails.forEach(entry => {
            // Create a new table row
            const row = document.createElement("tr");

            // Create a cell for the data Debit
            const cell1 = document.createElement("td");
            const label1 = document.createElement("label");
            label1.textContent = entry.Debit;
            cell1.appendChild(label1);

            // Create a cell for the data Credit
            const cell2 = document.createElement("td");
            const label2 = document.createElement("label");
            label2.textContent = entry.Credit;
            cell2.appendChild(label2);

            // Add the label for ArName
            const cell3 = document.createElement("td");
            const label3 = document.createElement("label");
            label3.textContent = entry.ArName; // Arabic name
            cell3.appendChild(label3);

            // Append the cell to the row
            row.appendChild(cell1);
            row.appendChild(cell2);
            row.appendChild(cell3);

            // Append the row to the tbody
            $('#journalTBodyDebitCredit').append(row); // Use append() for jQuery

        });
    }

    function openCashReceipt() {
        Swal.fire({
            title: '@MyERP.Properties.Resources.AreYouSureYouWantToOpenCashReceipt',
            text: " ",
            icon: 'info',
            showCancelButton: true,
            confirmButtonText: '@MyERP.Properties.Resources.Ok',
            cancelButtonText: '@MyERP.Properties.Resources.Cancel',
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                $('#preloader, #status').fadeIn();
                $('#newbtn').prop('disabled', true);
                $('#save').prop('disabled', true);
                $('#SaveAndPrint').prop('disabled', true);

                window.location.replace("/CashReceiptVoucher/AddEditForPropertyBill/" + $('#Id').val());

            }
            else { result.dismiss; }
        });
    }

</script>



