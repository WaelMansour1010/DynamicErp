    function CalculateDamageTotals() {
        var sum = 0;
        $('#PropertyContractTerminationDamages tr').each(function () {
            var td = $(this);
            var total = 0;
            if (td.find('.Price').val() && td.find('.Qty').val()) {
                total = parseFloat(td.find('.Price').val()) * parseFloat(td.find('.Qty').val());
                td.find('.total').val(total);
                sum += total;
            }
        });
        $('#TotalDamages').val(sum);
    }

    function CalculateDeficiencyAndExtraDaysTotals() {
        var TerminationDate = new Date( $('#TerminationDate').val());
        var ContractEndDate = new Date($('#ContractEndDate').val());
        var ContractStartDate = new Date($('#ContractStartDate').val());
        var diff = 0;
        var sum = 0;
        $('#PropertyContractTerminationDetails tr').each(function () {
            sum += parseFloat($(this).find('.Remain').text());
        });
        if (TerminationDate <= ContractEndDate) { // Deficiency Days
            $('#DecreaseDaysTotalValue').val(sum.toFixed(2));
            if ($('#ContractEndDate').val() != null) {
                if (TerminationDate.getFullYear() == ContractEndDate.getFullYear() && TerminationDate.getMonth() + 1 <= ContractEndDate.getMonth() + 1) {
                    diff = Math.round((TerminationDate - ContractEndDate) / (1000 * 60 * 60 * 24))
                }
                else if (TerminationDate.getFullYear() < ContractEndDate.getFullYear()) {
                    diff = Math.round((ContractEndDate - TerminationDate) / (1000 * 60 * 60 * 24))
                }
                $('#DecreaseDaysNo').val(diff.toFixed(2));
                var DayValue = (sum.toFixed(2) / diff)
                $('#DecreaseDayValue').val(DayValue.toFixed(2));
            }
            $('#IncreaseDaysNo').val('');
            $('#IncreaseDayValue').val('');
            $('#IncreaseDaysTotalValue').val('');
        }
        else if (ContractEndDate <= TerminationDate) { //Extra Days
            $('#IncreaseDaysTotalValue').val(sum.toFixed(2));
            if ($('#ContractEndDate').val() != null) {
                diff = Math.round((ContractEndDate - ContractStartDate) / (1000 * 60 * 60 * 24))
                $('#IncreaseDaysNo').val(diff.toFixed(2));
                var DayValue = (sum.toFixed(2) / diff)
                $('#IncreaseDayValue').val(DayValue.toFixed(2));
            }
            $('#DecreaseDaysNo').val('');
            $('#DecreaseDayValue').val('');
            $('#DecreaseDaysTotalValue').val('');
        }
    }

    //*********************************************************//
    function addEdit(n) {
        let valid = true;
        if ($('.form-horizontal').first().find('.form-control:invalid').length > 0) {
            $('.form-horizontal').first().addClass('was-validated');
            $('html, body').animate({
                scrollTop: $('.form-horizontal').first().find(".form-control:invalid").eq(0).offset().top - 100
            }, 500);
            valid = false;
            console.log($(".form-control:invalid"));
        }
        if ($('#PropertyContractTerminationDetails tr').length == 0)
        {
            valid = false;
            Swal.fire({
                title: '@MyERP.Properties.Resources.AllDetailsRequired',
                text: " ",
                icon: 'success',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        }
        var PropertyContractTerminationDetails = [];
        if (valid) {
            $('#PropertyContractTerminationDetails tr').each(function () {
                var td = $(this);
                var PropertyContractTerminationDetail = {
                    PropertyContractId: td.find('.PropertyContractId').val(),
                    PropertyContractBatchId: td.find('.PropertyContractBatchId').val(),
                    IsDeleted: false,
                    UserId: $('#UserId').val(),
                    Notes: td.find('.Notes').val(),
                    Image: td.find('.Image').val(),
                    SequenceNo: td.find('.DetailSequenceNo').text(),
                    Remain: parseFloat(td.find('.Remain').text()),
                };
                    PropertyContractTerminationDetails.push(PropertyContractTerminationDetail);
            });
            if (PropertyContractTerminationDetails.length == 0) {
                valid = false;
                Swal.fire({
                    title: '@MyERP.Properties.Resources.AllDetailsRequired',
                    text: " ",
                    icon: 'success',
                    showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    confirmButtonColor: '#3085d6'
                });
            }
        }
        var PropertyContractTerminationDamages = [];
        if (valid) {
            $('#PropertyContractTerminationDamages tr').each(function () {
                var td = $(this);
                var PropertyContractTerminationDamage = {
                    PropertyContractTerminationId: $('#Id').val(),
                    PropertyComponentId: td.find('.PropertyComponentId').val(),
                    IsDeleted: false,
                    UserId: $('#UserId').val(),
                    Notes: td.find('.Notes').val(),
                    Image: td.find('.Image').val(),
                    SequenceNo: td.find('.DamageSequenceNo').text(),
                    PropertyComponentDetailId: td.find('.PropertyComponentDetailId').val(),
                    Qty: td.find('.Qty').val(),
                    Price: td.find('.Price').inputmask('unmaskedvalue')
                };
                PropertyContractTerminationDamages.push(PropertyContractTerminationDamage);
            });
        }

        var PropertyContractTermination = {
            Id: $('#Id').val(),
            DocumentNumber: $('#DocumentNumber').val(),
            DepartmentId: $('#DepartmentId').val(),
            VoucherDate: $('#VoucherDate').val(),
            PropertyContractId: $('#ContractId').val(),
            PropertyId: $('#PropertyId').val(),
            PropertyUnitTypeId: $('#UnitTypeId').val(),
            PropertyRenterId: $('#RenterId').val(),
            TerminationDate: $('#TerminationDate').val(),
            LastBatchDate: $('#LastBatchDate').val(),
            IsLastBatchCalculation: $('#IsLastBatchCalculation').val(),
            IsDocumented: $('#IsDocumented').val(),
            IncreaseDayValue: $('#IncreaseDayValue').val(),
            IncreaseDaysNo: $('#IncreaseDaysNo').inputmask('unmaskedvalue')>0?parseInt($('#IncreaseDaysNo').inputmask('unmaskedvalue')):0,
            IncreaseDaysTotalValue: $('#IncreaseDaysTotalValue').val(),
            DecreaseDayValue: $('#DecreaseDayValue').val(),
            DecreaseDaysNo: $('#DecreaseDaysNo').inputmask('unmaskedvalue')>0? parseInt($('#DecreaseDaysNo').inputmask('unmaskedvalue')):0,
            DecreaseDaysTotalValue: $('#DecreaseDaysTotalValue').val() ,
            IsDeleted: $('#IsDeleted').val(),
            UserId: $('#UserId').val(),
            Notes: $('#Notes').val(),
            Image: $('#Image').val(),
            PropertyContractTerminationDetails: PropertyContractTerminationDetails,
            PropertyContractTerminationDamages: PropertyContractTerminationDamages,
        }
        if (valid) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.AreYouSureYouWantToSave',
                text: " ",
                icon: 'info',
                showCancelButton: true,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                cancelButtonText: '@MyERP.Properties.Resources.Cancel',
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    $('#preloader, #status').fadeIn();
                    $('#newbtn').prop('disabled', true);
                    $('#save').prop('disabled', true);
                    $.ajax({
                        type: "POST", contentType: "application/json",
                        url: "/PropertyContractTermination/AddEdit",
                        data: JSON.stringify(PropertyContractTermination),
                        success: function (r) {
                            if (r.success == true) {
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.Saved',
                                    text: " ",
                                    icon: 'success',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                                if (n == "new") {
                                    window.location.replace("/PropertyContractTermination/AddEdit");
                                } else {
                                    window.location.replace("/PropertyContractTermination");
                                }
                            }
                            else {
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.NotSaved !',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                            }
                            $('#preloader, #status').fadeOut();
                            $('#newbtn').prop('disabled', false);
                            $('#save').prop('disabled', false);
                        },
                        error: function (r) {
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.NotSaved !',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                            $('#preloader, #status').fadeOut();
                            $('#newbtn').prop('disabled', false);
                            $('#save').prop('disabled', false);
                        }
                    });
                }
                else { result.dismiss; }
            });
        }
    }

    function Delete(id) {
        if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToDelete')) {
            $('#preloader, #status').fadeIn();
            $.ajax(
                {
                    url: '/PropertyContractTermination/Delete',
                    type: 'POST',
                    data: {
                        "Id": id,
                    },
                    error: function (e) {
                        $('#preloader, #status').fadeOut();
                    },
                    success: function (r) {
                        if (r == 'true') {
                            window.location.replace('/PropertyContractTermination');
                        }
                    }
                });
        }
    }

</script>
