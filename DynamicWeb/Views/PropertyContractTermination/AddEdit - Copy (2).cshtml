@model MyERP.Models.PropertyContractTermination
@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.PropertyContractTermination;
}


@Html.AntiForgeryToken()
@Html.ValidationSummary(true, "", new { @class = "text-danger" })
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <a class="btn btn-info" href="@Url.Action("Index")" role="button" style="float:left;">@MyERP.Properties.Resources.Back</a>
            </div>
            <div class="hed page-title">@MyERP.Properties.Resources.PropertyContractTermination :</div>
        </div>
    </div>
</div>
<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal needs-validation" role="form">
                        <div class="card">
                            <div class="card-body">
                                @Html.AntiForgeryToken()
                                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                @if (Model != null)
                                {
                                    @Html.HiddenFor(model => model.Id)
                                    @Html.HiddenFor(model => model.UserId)
                                    @Html.HiddenFor(model => model.IsDeleted)
                                    @Html.HiddenFor(model => model.Image)
                                }

                                @* Panel 1 *@
                                <div class="card">
                                    <div class="card-body">
                                        <div id="accordion">
                                            <h5 class=" pb-3 header-title">
                                                <a data-toggle="collapse" data-parent="#accordion" href="#collapse1">
                                                    @MyERP.Properties.Resources.MainData
                                                </a>
                                            </h5>
                                        </div>
                                        <div id="collapse1">
                                            <div class="form-group row">
                                                <label class=" col-sm-2 control-label" for="Id">@MyERP.Properties.Resources.TerminationNo</label>
                                                <div class="col-sm-4">
                                                    @Html.EditorFor(model => model.DocumentNumber, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly", placeholder = @MyERP.Properties.Resources.DocNo, required = "required", hidden = "hidden" } })
                                                    <input id="DocumentNumbers" class="form-control" placeholder=@MyERP.Properties.Resources.Code required readonly />
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.Date</label>
                                                <div class="col-sm-4">
                                                    @Html.EditorFor(model => model.VoucherDate, new { htmlAttributes = new { @class = "form-control Gregorian", @type = "datetime-local", @required = "required" } })
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group row">
                                                <label for="DepartmentId" class="control-label col-sm-2">@MyERP.Properties.Resources.Department</label>
                                                <div class="col-sm-4">
                                                    @Html.DropDownList("DepartmentId", null, htmlAttributes: new { @class = "form-control", @required = "required" })
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Select
                                                    </div>
                                                </div>
                                                <div class="col-sm-6">
                                                    <button type="button" data-toggle="modal" data-target="#SearchModal" class="btn btn-success">
                                                        <i class="fa fa-search"></i>
                                                    </button>
                                                </div>
                                            </div>
                                            <div class="form-group row SearchResult" style="display:none;">
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.ContractNo</label>
                                                <div class="col-sm-4">
                                                    <input type="text" class="form-control" required id="ContractNo" value="@(Model!=null&&Model.Id>0?Model.PropertyContract.DocumentNumber:"")" />
                                                    <input type="text" class="form-control" required id="ContractId" hidden value="@(Model!=null&&Model.Id>0?Model.PropertyContractId:0)" />
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.UnifiedContractNumber</label>
                                                <div class="col-sm-4">
                                                    <input type="text" class="form-control" id="UnifiedContractNumber" value="@(Model!=null&&Model.Id>0?Model.PropertyContract.UnifiedContractNumber:"")" />
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group row SearchResult" style="display:none;">
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.Renter</label>
                                                <div class="col-sm-4">
                                                    <input type="text" class="form-control" required id="Renter" value="@(Model!=null&&Model.Id>0?Model.PropertyRenter.ArName:"")" />
                                                    <input type="text" class="form-control" required id="RenterId" hidden value="@(Model!=null&&Model.Id>0?Model.PropertyRenterId:0)" />
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.Property</label>
                                                <div class="col-sm-4">
                                                    <input type="text" class="form-control" required id="Property" value="@(Model!=null&&Model.Id>0?Model.Property.ArName:"")" />
                                                    <input type="text" class="form-control" required id="PropertyId" hidden value="@(Model!=null&&Model.Id>0?Model.PropertyId:0)" />
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group row SearchResult" style="display:none;">
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.PropertyUnitType</label>
                                                <div class="col-sm-4">
                                                    <input type="text" class="form-control" required id="UnitTypeId" hidden value="@(Model!=null&&Model.Id>0?Model.PropertyUnitTypeId:0)" />
                                                    <input type="text" class="form-control" required id="UnitType" value="@(Model!=null&&Model.Id>0?Model.PropertyUnitType.ArName:"")" />
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.UnitNo </label>
                                                <div class="col-sm-4">
                                                    @*<input type="text" class="form-control" required id="UnitId" hidden value="@(Model!=null&&Model.Id>0?Model.PropertyContract.PropertyUnitId:0)" />*@
                                                    <input type ="hidden" id="UnitId"  value="@(Model!=null&&Model.Id>0?Model.PropertyContract.PropertyUnitId:0)"/>
                                                    <input type="text" class="form-control" required id="UnitCode" value="@(Model!=null&&Model.Id>0?ViewBag.UnitCode:"")" />
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group row SearchResult" style="display:none;">
                                                <label class="control-label col-sm-2 MergedUnitsDiv">@MyERP.Properties.Resources.MergedUnits</label>
                                                <div class="col-sm-4 MergedUnitsDiv">
                                                    @{ 
                                                        if ((Model?.Id ?? 0) > 0)
                                                        {
                                                            @Html.ListBox("selectedMergedUnits", (MultiSelectList)ViewBag.selectedMergedUnits, new { @class = "form-control", size = 6, style = "width: 200px;" })
                                                        }
                                                        else
                                                        {
                                                            <select name="selectedMergedUnits" id="selectedMergedUnits" class="form-control" size="6" style="width: 200px;" multiple>
                                                            </select>
                                                        }
                                                    }
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group row SearchResult" style="display:none;">
                                                <label class=" col-sm-2 control-label" for="TerminationDate">@MyERP.Properties.Resources.ContractStartDate</label>
                                                <div class="col-sm-4">
                                                    <input id="ContractStartDate" class="form-control Gregorian" type="datetime" />
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.ContractEndDate</label>
                                                <div class="col-sm-4">
                                                    <input id="ContractEndDate" class="form-control Gregorian" type="datetime" />
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group row SearchResult" style="display:none;">
                                                <label class=" col-sm-2 control-label" for="TerminationDate">@MyERP.Properties.Resources.TerminationDate</label>
                                                <div class="col-sm-4">
                                                    @Html.EditorFor(model => model.TerminationDate, new { htmlAttributes = new { @class = "form-control Gregorian", @type = "date", @required = "required" } })
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.LastBatchDate</label>
                                                <div class="col-sm-4">
                                                    @Html.EditorFor(model => model.LastBatchDate, new { htmlAttributes = new { @class = "form-control Gregorian", @type = "date", @required = "required" } })
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                            </div>


                                            <!-------------- PropertyContractTerminationDetails Table ---------------->
                                            <div class="table-responsive SearchResult" style="display:none;">
                                                <table class="table table-centered mb-0">
                                                    <thead>
                                                        <tr>
                                                            <td>
                                                                @MyERP.Properties.Resources.Sequence
                                                            </td>
                                                            <td>
                                                                @MyERP.Properties.Resources.Date
                                                            </td>
                                                            <td>
                                                                @MyERP.Properties.Resources.HijriDate
                                                            </td>
                                                            <td>
                                                                @MyERP.Properties.Resources.RemainingRent
                                                            </td>
                                                            <td>
                                                                @MyERP.Properties.Resources.RemainingWater
                                                            </td>
                                                            <td>
                                                                @MyERP.Properties.Resources.RemainingElectricity
                                                            </td>
                                                            <td>
                                                                @MyERP.Properties.Resources.RemainingCommission
                                                            </td>
                                                            <td>
                                                                @MyERP.Properties.Resources.RemainingServices
                                                            </td>
                                                            <td>
                                                                @MyERP.Properties.Resources.Insurance
                                                            </td>
                                                            <td>
                                                                @MyERP.Properties.Resources.RemainingUnpaid
                                                            </td>

                                                            <td>
                                                                @MyERP.Properties.Resources.TotalRemaining
                                                            </td>
                                                        </tr>
                                                    </thead>
                                                    <tbody id="PropertyContractTerminationDetails">
                                                        @if (Model != null && Model.PropertyContractTerminationDetails.Count > 0)
                                                        {
                                                            foreach (var item in Model.PropertyContractTerminationDetails)
                                                            {
                                                                <tr>
                                                                    <td class="tabledit-edit-mode">
                                                                        <input hidden class="PropertyContractBatchId" value="@item.PropertyContractBatchId" />
                                                                        <input hidden class="PropertyContractId" value="@item.PropertyContractId" />
                                                                        <label class="DetailSequenceNo control-label control-label">
                                                                            @item.SequenceNo
                                                                        </label>
                                                                    </td>
                                                                    <td class="tabledit-edit-mode">
                                                                        <input type="date" class="BatchDate Gregorian form-control tabledit-input form-control-sm" value="@item.PropertyContractBatch.BatchDate.Value.ToString("yyyy-MM-dd")" disabled readonly />
                                                                    </td>
                                                                    <td class="tabledit-edit-mode">
                                                                        <label class="HijryBatchDate control-label control-label">

                                                                        </label>
                                                                    </td>
                                                                    <td class="tabledit-edit-mode">
                                                                        <label class="BatchRentValue control-label control-label">
                                                                            @(item.Remain==0?0:item.PropertyContractBatch.BatchRentValue + item.PropertyContractBatch.BatchRentValueTaxes)
                                                                        </label>
                                                                    </td>
                                                                    <td class="tabledit-edit-mode">
                                                                        <label class="BatchWaterValue control-label control-label">
                                                                            @(item.Remain==0?0:item.PropertyContractBatch.BatchWaterValue + item.PropertyContractBatch.BatchWaterValueTaxes)
                                                                        </label>
                                                                    </td>
                                                                    <td class="tabledit-edit-mode">
                                                                        <label class="BatchElectricityValue control-label control-label">
                                                                            @(item.Remain==0?0:item.PropertyContractBatch.BatchElectricityValue + item.PropertyContractBatch.BatchElectricityValueTaxes)
                                                                        </label>
                                                                    </td>
                                                                    <td class="tabledit-edit-mode">
                                                                        <label class="BatchCommissionValue control-label control-label">
                                                                            @(item.Remain==0?0:item.PropertyContractBatch.BatchCommissionValue + item.PropertyContractBatch.BatchCommissionValueTaxes)
                                                                        </label>
                                                                    </td>
                                                                    <td class="tabledit-edit-mode">
                                                                        <label class="BatchServicesValue control-label control-label">
                                                                            @(item.Remain==0?0:item.PropertyContractBatch.BatchServicesValue + item.PropertyContractBatch.BatchServicesValueTaxes)
                                                                        </label>
                                                                    </td>
                                                                    <td class="tabledit-edit-mode">
                                                                        <label class="BatchInsuranceValue control-label control-label">
                                                                            @(item.Remain==0?0:item.PropertyContractBatch.BatchInsuranceValue + item.PropertyContractBatch.BatchInsuranceValueTaxes)
                                                                        </label>
                                                                    </td>
                                                                    <td class="tabledit-edit-mode">
                                                                        <label class="Remain control-label control-label">
                                                                            @item.Remain

                                                                        </label>
                                                                    </td>
                                                                    <td class="tabledit-edit-mode">
                                                                        <label class="TotalRemain control-label control-label">
                                                                            @item.Remain

                                                                        </label>
                                                                    </td>
                                                                </tr>
                                                            }
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                            <!------------------------------------------------------------------------------------>
                                            <!------------------ Increase / Decrease Days ------------------>
                                            <div class="card SearchResult" style="display:none;">
                                                <div class="card-body">
                                                    <h5 class="header-title">
                                                        @MyERP.Properties.Resources.DeficiencyDays
                                                    </h5>
                                                    <div class="form-group row">
                                                        <label class=" col-sm-1 control-label" for="IncreaseDayValue">@MyERP.Properties.Resources.DayValue</label>
                                                        <div class="col-sm-2">
                                                            @Html.EditorFor(model => model.DecreaseDayValue, new { htmlAttributes = new { @class = "form-control" } })
                                                            <div class="invalid-feedback">
                                                                @MyERP.Properties.Resources.Required
                                                            </div>
                                                        </div>
                                                        <label class="control-label col-sm-1">@MyERP.Properties.Resources.DaysNo</label>
                                                        <div class="col-sm-2">
                                                            @Html.EditorFor(model => model.DecreaseDaysNo, new { htmlAttributes = new { @type = "text", @class = "form-control" } })
                                                            <div class="invalid-feedback">
                                                                @MyERP.Properties.Resources.Required
                                                            </div>
                                                        </div>
                                                        <label class="control-label col-sm-1">@MyERP.Properties.Resources.DeficiencyDaysValue</label>
                                                        <div class="col-sm-2">
                                                            @Html.EditorFor(model => model.DecreaseDaysTotalValue, new { htmlAttributes = new { @class = "form-control" } })
                                                            <div class="invalid-feedback">
                                                                @MyERP.Properties.Resources.Required
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="card SearchResult" style="display:none;">
                                                <div class="card-body">
                                                    <h5 class="header-title">
                                                        @MyERP.Properties.Resources.ExtraDays
                                                    </h5>
                                                    <div class="form-group row">
                                                        <label class=" col-sm-1 control-label" for="IncreaseDayValue">@MyERP.Properties.Resources.DayValue</label>
                                                        <div class="col-sm-2">
                                                            @Html.EditorFor(model => model.IncreaseDayValue, new { htmlAttributes = new { @class = "form-control" } })
                                                            <div class="invalid-feedback">
                                                                @MyERP.Properties.Resources.Required
                                                            </div>
                                                        </div>
                                                        <label class="control-label col-sm-1">@MyERP.Properties.Resources.DaysNo</label>
                                                        <div class="col-sm-2">
                                                            @Html.EditorFor(model => model.IncreaseDaysNo, new { htmlAttributes = new { @type = "text", @class = "form-control" } })
                                                            <div class="invalid-feedback">
                                                                @MyERP.Properties.Resources.Required
                                                            </div>
                                                        </div>
                                                        <label class="control-label col-sm-1">@MyERP.Properties.Resources.ExtraDaysValue</label>
                                                        <div class="col-sm-2">
                                                            @Html.EditorFor(model => model.IncreaseDaysTotalValue, new { htmlAttributes = new { @class = "form-control" } })
                                                            <div class="invalid-feedback">
                                                                @MyERP.Properties.Resources.Required
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <!------------------ End Of Increase / Decrease Days ------------------>
                                        </div>
                                    </div>
                                </div>

                                @* Panel 2 *@
                                <div class="card SearchResult" style="display:none;">
                                    <div class="card-body">
                                        <div id="accordion">
                                            <h5 class=" pb-3 header-title">
                                                <a data-toggle="collapse" data-parent="#accordion" href="#collapse2">
                                                    @MyERP.Properties.Resources.PropertyDamages
                                                </a>
                                            </h5>
                                        </div>
                                        <div id="collapse2">

                                            <div class="form-group row">
                                                <label class=" col-sm-2 control-label" for="SalaryItemId">@MyERP.Properties.Resources.PropertyComponents</label>
                                                <div class="col-sm-3">
                                                    @Html.DropDownList("PropertyComponentId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })
                                                </div>

                                                <label class=" col-sm-2 control-label" for="SalaryItemId">@MyERP.Properties.Resources.ComponentDetails </label>
                                                <div class="col-sm-3">
                                                    <select id="PropertyComponentDetailId" class="form-control">
                                                    </select>
                                                </div>
                                                <div class="col-sm-offset-2">
                                                    <button onclick="AddPropertyComponent(this)" class="btn btn-success">
                                                        @MyERP.Properties.Resources.Add
                                                    </button>
                                                </div>
                                            </div>

                                            <!-------------- PropertyContractTerminationDamages Table ---------------->
                                            <div class="table-responsive">
                                                <table class="table table-centered mb-0">
                                                    <thead>
                                                        <tr>
                                                            <td>
                                                                @MyERP.Properties.Resources.Sequence
                                                            </td>
                                                            <td>
                                                                @MyERP.Properties.Resources.Name
                                                            </td>
                                                            <td>
                                                                @MyERP.Properties.Resources.Price
                                                            </td>
                                                            <td>
                                                                @MyERP.Properties.Resources.Number
                                                            </td>
                                                            <td>
                                                                @MyERP.Properties.Resources.Total
                                                            </td>
                                                            <td>
                                                                @MyERP.Properties.Resources.Notes
                                                            </td>
                                                            <td>
                                                                @MyERP.Properties.Resources.Delete
                                                            </td>

                                                        </tr>
                                                    </thead>
                                                    <tbody id="PropertyContractTerminationDamages">
                                                        @if (Model != null)
                                                        {
                                                            foreach (var item in Model.PropertyContractTerminationDamages)
                                                            {
                                                                <tr>
                                                                    <td class="tabledit-edit-mode">
                                                                        <label class="DamageSequenceNo control-label control-label">@item.SequenceNo</label>
                                                                    </td>
                                                                    <td class="tabledit-edit-mode">
                                                                        <input type="text" class="PropertyComponentDetailId form-control tabledit-input form-control-sm" value="@item.PropertyComponentDetailId" hidden />
                                                                        <input type="text" class="PropertyComponentId form-control tabledit-input form-control-sm" value="@item.PropertyComponentId" hidden />
                                                                        <input type="text" class="form-control tabledit-input form-control-sm" value="@item.PropertyComponentDetail.ArName" />
                                                                    </td>
                                                                    <td class="tabledit-edit-mode">
                                                                        <input type="text" class="Price money form-control tabledit-input form-control-sm" value="@item.Price" />
                                                                    </td>
                                                                    <td class="tabledit-edit-mode">
                                                                        <input type="text" class="Qty form-control tabledit-input form-control-sm" value="@item.Qty" />
                                                                    </td>
                                                                    <td class="tabledit-edit-mode">
                                                                        <input type="text" class="total form-control tabledit-input form-control-sm" value="@(item.Price*(decimal?)item.Qty)" />
                                                                    </td>
                                                                    <td class="tabledit-edit-mode">
                                                                        <input type="text" class="Notes form-control tabledit-input form-control-sm" value="@item.Notes" />
                                                                    </td>
                                                                    <td>
                                                                        <a href="javascript:void(0);" onclick="deleteElement(this)">
                                                                            <i class="fas fa-trash-alt"></i>
                                                                        </a>
                                                                    </td>
                                                                </tr>
                                                            }
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                            <!------------------------------------------------------------------------------------>

                                            <div class="form-group row">
                                                <label class=" col-sm-2 control-label" for="SalaryItemId">@MyERP.Properties.Resources.TotalDamages</label>
                                                <div class="col-sm-4">
                                                    <input id="TotalDamages" class="form-control" />
                                                </div>

                                            </div>


                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!---------------------------------------------- Saves Buttons ----------------------------------------------------------->
                <div class="row">
                    <div class="col-sm-offset-2">
                        @if (Model == null)
                        {
                            <button onclick="addEdit('new');" class="btn btn-success" id="newbtn">
                                @MyERP.Properties.Resources.SaveAndNew
                            </button>
                            <button onclick="addEdit();" class="btn btn-success" id="save">
                                @MyERP.Properties.Resources.Save
                            </button>
                            <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                        }
                        else if (Model.IsDeleted == false)
                        {
                            <button onclick="addEdit();" class="btn btn-success" id="save">
                                @MyERP.Properties.Resources.Save
                            </button>
                            <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                            <a href="javascript:void(0);" class="btn btn-danger" onclick="Delete(@Model.Id)" role="button">@MyERP.Properties.Resources.Delete</a>
                        }
                    </div>
                </div>
                <!----------------------------------------------------------------------------------------------------------------------------------------->


            </div>

            <!-------- journal entry --------->
            @if (Model != null && ViewBag.Journal != null)
            {
                <div class="card">
                    <div class="card-body">
                        <h5 class="header-title">
                            @MyERP.Properties.Resources.JournalEntry

                        </h5>
                        <div class="form-horizontal">
                            <div class="form-group row">
                                <label for="JournalDocNo" class="col-sm-2 control-label">
                                    @MyERP.Properties.Resources.JournalEntrieNo
                                </label>
                                <div class="col-sm-4">
                                    <input type="text" class="form-control" name="JournalDocNo" value="@ViewBag.Journal.DocumentNumber" id="JournalDocNo" placeholder="@MyERP.Properties.Resources.JournalEntrieNo" readonly>

                                </div>
                                <label for="JournalDate" class="col-sm-2 control-label">@MyERP.Properties.Resources.Date </label>
                                <div class="col-sm-4">
                                    <input type="datetime-local" class="form-control" name="JournalDate" value="@ViewBag.VoucherDate" id="JournalDate" placeholder="@MyERP.Properties.Resources.ReleaseDate" readonly>

                                </div>
                            </div>
                            <div class="form-group row">
                                <label for="JournalNotes" class="col-2 control-label">@MyERP.Properties.Resources.Notes</label>
                                <div class="col-sm-4">
                                    <textarea class="form-control" id="JournalNotes" value="@ViewBag.Journal.Notes" readonly name="JournalNotes" placeholder="@MyERP.Properties.Resources.Notes"></textarea>
                                </div>

                                @*<label for="JournalIsPosted" class="col-sm-2 control-label">@MyERP.Properties.Resources.CarriedOver</label>
                                    <div class="col-sm-4">
                                        <input type="checkbox" id="JournalIsPosted" name="JournalIsPosted" disabled @Html.Raw(Model.IsPosted == true ? "checked" : null)>

