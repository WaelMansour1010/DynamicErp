   function GetPropertyContractTerminationDetails() {
    var q = $('#SearchText').val().trim();

    // شرط بسيط لتقليل الضغط
    if (q.length < 2) {
        $('#ShowResultDetails').html('<tr><td colspan="6" class="text-muted">اكتب حرفين على الأقل…</td></tr>');
        return;
    }

    // الغِ أي طلب سابق لسه ما خلصش
    if (_searchXhr && _searchXhr.readyState !== 4) {
        try { _searchXhr.abort(); } catch (e) {}
    }

    // شكل تحميل مبدئي
    $('#ShowResultDetails').html('<tr><td colspan="6">...جارِ التحميل</td></tr>');

    _searchXhr = $.ajax({
        url: '/PropertyContractTermination/GetPropertyContractTerminationDetails',
        type: 'GET',
        cache: false,
        // خليك على نفس اسم البارامتر في الكنترولر (searchText)
        data: { searchText: q }
    })
    .done(function (r) {
        var rows = Array.isArray(r) ? r : [];
        if (!rows.length) {
            $('#ShowResultDetails').html('<tr><td colspan="6" class="text-muted">لا توجد نتائج</td></tr>');
            return;
        }

        $('#ShowResultDetails').empty();
        ContractDetails = rows; // لو باقي الصفحة بيعتمد عليها

        for (var i = 0; i < rows.length; i++) {
            var x = rows[i];
            var renter       = x.Renter || '';
            var mobile       = x.RenterMobile || '';
            var contractNo   = x.ContractNo || '';
            var property     = x.Property || '';
            var unitType     = x.UnitType || '';
            var unitCode     = x.UnitCode || '';

            // نفس الـ markup اللي كان موجود عندك (labels + زر الإضافة)
            var tr =
                '<tr>' +
                    '<td class="tabledit-edit-mode"><label class="PopUpRenter control-label control-label">' + renter     + '</label></td>' +
                    '<td class="tabledit-edit-mode"><label class="PopUpRenterMobile control-label control-label">' + mobile     + '</label></td>' +
                    '<td class="tabledit-edit-mode"><label class="PopUpContractNo control-label control-label">' + contractNo + '</label></td>' +
                    '<td class="tabledit-edit-mode"><label class="PopUpProperty control-label control-label">' + property   + '</label></td>' +
                    '<td class="tabledit-edit-mode"><label class="PopUpPropertyUnitType control-label control-label">' + unitType   + '</label></td>' +
                    '<td class="tabledit-edit-mode"><label class="PopUpUnitNo control-label control-label">' + unitCode   + '</label></td>' +
                    '<td class="tabledit-edit-mode"><button class="btn btn-primary" onclick="AddToDetails(' + x.ContractId + ')">@MyERP.Properties.Resources.Add</button></td>' +
                '</tr>';

            // لو حابب تظهر فقط اللي ليه UnitCode، أضف الشرط هنا:
            // if (unitCode) { $('#ShowResultDetails').append(tr); }

            $('#ShowResultDetails').append(tr);
        }
    })
    .fail(function () {
        $('#ShowResultDetails').html('<tr><td colspan="6" class="text-danger">حدث خطأ في البحث</td></tr>');
    });
}


