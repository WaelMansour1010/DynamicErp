    //delete element from PurchaseQuotationDetails table
    function deleteElement(e) {

        var tr = $(e).closest('tr');

        if ($(tr).index() > 0) {
            e.parentNode.parentNode.parentNode.removeChild(e.parentNode.parentNode);
        } else if ($(tr).index() == 0 && $(tr).closest('tbody').children('tr').length > 1) {
            e.parentNode.parentNode.parentNode.removeChild(e.parentNode.parentNode);

        } else if ($(tr).index() == 0 && $(tr).closest('tbody').children('tr').length == 1) {
            $(tr).children("input[type|='text']").each(function () {
                $(this).empty();
            });
        }

        calculateTotal();
        DiscountValueChange();

        var itemId = $(e).closest('tr').find('.item').val();
        $('#heading' + itemId).closest('.panel').remove();

        $("#selectedItems option[value|='" + itemId + "']").remove();
        }






