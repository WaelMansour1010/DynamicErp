<div class="modal fade" id="itemDetails" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" data-backdrop="false" style="background-color: rgba(0, 0, 0, 0.5);">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="myModalLabel">تفاصيل الصنف</h4>
            </div>
            <div class="modal-body" id="itemDetailsBody">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">غلق</button>
            </div>
        </div>
    </div>
</div>

<input hidden value="@OpenReportAfterAdd" id="AfterAdd" />
<input hidden value="@OpenReportAfterEdit" id="AfterEdit" />
<input hidden value="@ShowSalesPricesForScript" id="ShowSalesPrices" />
<script>
    var items;
    var ItemPriceId = JSON.parse('@Html.Raw(ViewBag.ItemPriceId)');
    if ($('#Id').val() > 0) {
        $('#PurchaseQuotationDetails tr').each(function () {
            setItemPrices(this);
            setlastPriceForEdit(this);


        });

    }
    //date
    function zeroPadded(val) {
        if (val >= 10)
            return val;
        else
            return '0' + val;
    }
    if (!$('#Id').val() > 0) {

            $('.itemcost').val(0).inputmask({
                alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
            });
            $('#DiscountValue').val(0).inputmask({
                alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
            });
            $('#SalesTaxes').val(0).inputmask({
                alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
            });
            $('#Total').val(0).inputmask({
                alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
            });
            $('#TotalAfterTaxes').val(0).inputmask({
                alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
            });
            $('#NetTotal').val(0).inputmask({
                alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
            });
            $(".price1").val(0).inputmask({
                alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
            });
            $(".price2").val(0).inputmask({
                alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
            });
            $(".price3").val(0).inputmask({
                alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
            });
            $(".lastPrice").val(0).inputmask({
                alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
            });
            $(".avg").val(0).inputmask({
                alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
            });
            $("#percentage").val(0);

    }


    $(document).ready(function () {

        $('input[type="checkbox"]').click(function () {
            if ($(this).prop("checked") == true) {
                $('.taxesLabel').each(function () {
                    $(this).removeClass('hidden');
                });
                $('.taxes').each(function () {
                    $(this).removeClass('hidden');
                });
                calcTotalAfterTaxes();
                Taxes();


            }
            else if ($(this).prop("checked") == false) {
                $('.taxesLabel').each(function () {
                    $(this).addClass('hidden');
                });

                $('.taxes').each(function () {
                    $(this).val(0).inputmask({
                        alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
                    });
                    $(this).addClass('hidden');
                });

            }
        });
        addToPurchaseQuotationDetails();
    });



     //calc total after discountValue
    function DiscountValueChange() {
        var total = $('#Total').inputmask('unmaskedvalue') * 1;
        var disc = $('#DiscountValue').inputmask('unmaskedvalue') * 1;
        //check value of DiscountValue  !>  Total
        if (disc > total) {
            $('#DiscountValue').val(total).inputmask({
                alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
            });
        }
        var discountValue = $('#DiscountValue').inputmask('unmaskedvalue');
        //total after discount
        $('#NetTotal').val(total - discountValue).inputmask({
            alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
        });
        //prec
        var calcPerc = (discountValue * 100 / total).toFixed(2);
        $("#percentage").val(calcPerc);

        if ($('input[type="checkbox"]').prop("checked") == true) {
            calcTotalAfterTaxes();
            Taxes();

        }
    }

    function calculateTotal() {
        var sum = 0;
        $('.total').each(function () {
            sum += $(this).inputmask('unmaskedvalue') * 1;
        });
        $('#Total').val(sum).inputmask({
            alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
        });


    }
    //calc Taxes issu
    function Taxes() {

        var total = $('#NetTotal').inputmask('unmaskedvalue');
        var percentage = 14;

        var calcPrice = (total * percentage / 100).toFixed(2);
        $('#SalesTaxes').val(calcPrice).inputmask({
            alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
        });
        calcTotalAfterTaxes();
    }
    //calc discount from prec
    function PrecChange() {
        if ($('#percentage').val() > 100) {

            $('#percentage').val(100);

        }
        var discountValue = $('#DiscountValue').inputmask('unmaskedvalue');
        var total = $('#Total').inputmask('unmaskedvalue');
        var percentage = $("#percentage").val();

        var calcPrice = (total * percentage / 100).toFixed(2);
        $('#DiscountValue').val(calcPrice).inputmask({
            alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
        });
        DiscountValueChange();
    }
    //calc total after taxes
    function calcTotalAfterTaxes() {
        var Taxes = $('#SalesTaxes').inputmask('unmaskedvalue');
        var totalAfterDis = $('#NetTotal').inputmask('unmaskedvalue');
        var TotalAfterTaxes = (totalAfterDis * 1) + (Taxes * 1)
        $('#TotalAfterTaxes').val(TotalAfterTaxes);

    }

