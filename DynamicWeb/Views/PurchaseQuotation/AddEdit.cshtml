    //Item Prices
    function setItemPrices(e) {
        $('#preloader, #status').fadeIn();
        var itemDDL = $(e).closest('tr').find('.item').val();
        var itemPrices = $.get('/PurchaseQuotation/GetItemPrices?itemId=' + itemDDL).done(function (r) {
            if (r.length > 0) {

                $.each(r, function (index, value) {
                    if (index == 0) {
                        $(e).closest('tr').find('.price1').val(value['Price']);
                    }
                    else if (index == 1) {
                        $(e).closest('tr').find('.price2').val(value['Price']);
                    }
                    else {
                        $(e).closest('tr').find('.price3').val(value['Price']);

                    }
                    $('#preloader, #status').fadeOut();
                })
            }

             else {
                $(e).closest('tr').find('.price1').val(0).inputmask({
                    alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
                });
                $(e).closest('tr').find('.price2').val(0).inputmask({
                    alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
                });
                $(e).closest('tr').find('.price3').val(0).inputmask({
                    alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
                });
                $('#preloader, #status').fadeOut();
            }
        });
    }
