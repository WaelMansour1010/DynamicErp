@model MyERP.Models.PurchaseRequest

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.PurchaseRequest;
}

<input type="hidden" id="PurchaseRequestId" value="@ViewBag.PurchaseRequestId" />
<input type="hidden" id="IsApproved" value="@Html.Raw(ViewBag.IsApproved)" />
<input type="hidden" id="StatusId" value="@ViewBag.StatusId" />

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
            </div>
            <h4 class="page-title">@MyERP.Properties.Resources.PurchaseRequest:</h4>
        </div>
    </div>
</div>

<div class="row">
