    function CalculateTotals() {
        var total = 0;
        $('.total').each(function () {
            total += $(this).inputmask('unmaskedvalue') * 1;
        });
        $('#Total').val(total);
        if ($('#VoucherDiscountPercentage').inputmask('unmaskedvalue') < 100) {
            $('#VoucherDiscountValue').val(($('#VoucherDiscountPercentage').inputmask('unmaskedvalue') / 100) * total);
        } else {
            $('#VoucherDiscountPercentage').val(0);
            $('#VoucherDiscountValue').val(0);
        }
        if ($('#VoucherDiscountValue').val()) {
            total -= $('#VoucherDiscountValue').inputmask('unmaskedvalue');
        }
        $('#NetTotal').val(total);
        if ($('#hasTaxes').prop('checked')) {
            $('#SalesTaxes').val(total * taxPercentage);
            if ($('#hasComercialTaxes').prop('checked')) {
                $('#CommercialRevenueTaxAmount').val(total * .01);
                total -= total * .01;
            }
            total += $('#SalesTaxes').inputmask('unmaskedvalue') * 1;
        }
        $('#TotalAfterTaxes').val(total);

        $('#InstallmentAmount').val('0');
        if ($('#PaymentType').val() == 1) {
            $('#CashAmount').val(total);
        }
        else if ($('#PaymentType').val() == 2) {
            $('#DebitAmount').val(total);
        }
        if ($('#IsInstallmentPlan').prop('checked')) {
            $('#InstallmentAdvance').trigger('change');
        }
        showInvoiceProfit();
    }
    function showInvoiceProfit() {
        $('#showInvoiceProfit').prop('checked') ? $('.showProfit').show() : $('.showProfit').hide();
        totalInvoiceProfit = 0;
        $('.item').each(function () {
            if (!isNaN($(this).val()) && $(this).val() > 0) {
                var item = (this);
                let price = $(item).closest('tr').find('.price').inputmask('unmaskedvalue') * 1;
                let cost = $(item).closest('tr').find('.avgCost').val() * 1;
                let profit = (parseFloat(price) * 1 - parseFloat(cost)) * 1;
                profit = parseFloat(profit).toFixed(2);//to digits fraction

                $(item).closest('tr').find('.avgCostProfit').val((profit - $(item).closest('tr').find('.DiscountValue').val()) * $(item).closest('tr').find('.quantity').val());
                totalInvoiceProfit += profit * $(item).closest('tr').find('.quantity').val();
            }
        });
        $('#totalProfit').val(totalInvoiceProfit - $('#VoucherDiscountValue').inputmask('unmaskedvalue') * 1);
    }

