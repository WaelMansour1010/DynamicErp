    function getItemPrice(item) {
        // console.log(items);
        let itemId = items.filter(function (i) { return i.ItemPriceId == item.val(); })[0].Id;
        $('#pleasewait').fadeIn();
        $.get('/SalesInvoice/GetItemPrice?customerId=' + $('#VendorOrCustomerId').val() + '&itemId=' + itemId + '&departmentId=' + $('#DepartmentId').val()).done(function (r) {
            if (r) {
                $(item).closest('tr').find('.price').val($('#useAvgCostPrice').prop('checked') ? r.AvgCost : r.Price);
                $(item).closest('tr').find('.avgCost').val(r.AvgCost);
            }
            else {
                $(item).closest('tr').find('.price').val(0);
                $(item).closest('tr').find('.avgCost').val(0);
            }
            $(item).closest('tr').find('.price').trigger('change');
            $('#pleasewait').fadeOut();
        }).fail(function () {
            $(item).closest('tr').find('.price').val(0);
            $(item).closest('tr').find('.total').val(0);
            $(item).closest('tr').find('.price').trigger('change');
            $('#pleasewait').fadeOut();
        });
    }
    function CalculateDiscountForOneItem(e, s) {
        let DiscountPerc = $(e).find('.DiscountPerc').val();
        let DiscountValue = $(e).find('.DiscountValue').val();
        let quantity = $(e).find('.quantity').val();
        let price = $(e).find('.price').inputmask('unmaskedvalue') * 1;
        let calculateTotalAfterDiscount;
        if (s == "Value") {
            calculateTotalAfterDiscount = (quantity * price) - (DiscountValue * quantity);
            let CalculateDiscountPercentFromValue = (DiscountValue / price) * 100;
            $(e).find('.DiscountPerc').val(CalculateDiscountPercentFromValue);
        }
        else if (s == "Percent") {
            let CalculateDiscountValueFromPercent = (price * DiscountPerc) / 100;
            $(e).find('.DiscountValue').val(CalculateDiscountValueFromPercent);
            calculateTotalAfterDiscount = (quantity * price) - (CalculateDiscountValueFromPercent * quantity);
        }
        else {
            calculateTotalAfterDiscount = quantity * price * 1;
        }
        $(e).find('.total').val(calculateTotalAfterDiscount);
        showInvoiceProfit();
        CalculateTotals();
    }
    function getItemQuantityOnSystem(item) {
        let itemId = items.filter(function (i) { return i.ItemPriceId == item.val(); })[0].Id;

        requestData('/Helper/ItemQuantityOnSystem?warehouseId=' + $('#WarehouseId').val() + '&itemId=' + itemId).done(function (r) {
            var qtyOnSystem = (r * 1 > 0 ? r * 1 : 0);
            $(item).closest('tr').find('.quantityOnSystem').val(qtyOnSystem.toFixed(2));
            $(item).closest('tr').find('.quantity').val('@ViewBag.DefaultQuantityInPos');
            $(item).closest('tr').find('.quantity').trigger('change');
            addToPurchaseRequestDetails($(item).closest('tr'));
            $('#preloader, #status').fadeOut();
        }).fail(function () {
            $(item).closest('tr').find('.quantity').val(0);
            $('#preloader, #status').fadeOut();
        });

    }

