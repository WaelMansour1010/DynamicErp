@model IEnumerable<MyERP.Models.PurchaseRequest>

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.PurchaseRequest;
}

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <a class="btn btn-info" href="@Url.Action("History")" role="button"> @MyERP.Properties.Resources.TrackingPurchaseRequestsTransactions </a>
                <a class="btn btn-info" href="@Url.Action("AddEdit")" role="button">@MyERP.Properties.Resources.AddNew</a>
            </div>
            <h4 class="page-title">@MyERP.Properties.Resources.PurchaseRequest</h4>
        </div>
    </div>
</div>
<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal" role="form">
                        <div class="form-group row">
                            <div class="col-xs-12 col-sm-6 col-lg-3">
                                <input type="text" class="form-control searchtxt" value="@Html.Raw(ViewBag.searchWord)" placeholder="@MyERP.Properties.Resources.Search">
                            </div>
                            <div class="col-xs-12 col-sm-3 col-lg-3">
                                <button type="button" class="btn btn-success btnSearch" onclick="searchWord = $('.searchtxt').val(); paging();">
                                    <i class="fa fa-search"></i>
                                </button>
                                <a class="btn btn-info" href="/PurchaseRequest/Index" role="button"><i class="fe-refresh-ccw"></i></a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-12">
                    <div class="table-responsive">
                        <table class="table table-striped table-centered mb-0">
                            <thead>
                                <tr>
                                    <th>
                                        @MyERP.Properties.Resources.RequestNo
                                    </th>
                                    <th>
                                        @MyERP.Properties.Resources.Department
                                    </th>
                                    <th>
                                        @MyERP.Properties.Resources.Approval
                                    </th>

                                    <th>
                                        @MyERP.Properties.Resources.Date
                                    </th>
                                    <th>
                                        @MyERP.Properties.Resources.ApprovalDate
                                    </th>
                                    <th>
                                        @MyERP.Properties.Resources.ItemGroups
                                    </th>
                                    <th>
                                        @MyERP.Properties.Resources.Status
                                    </th>
                                    <th>
                                        @MyERP.Properties.Resources.Edit
                                    </th>
                                    <th>
                                        @MyERP.Properties.Resources.Delete
                                    </th>
                                    <th>
                                        @MyERP.Properties.Resources.Print
                                    </th>
                                </tr>
                            </thead>
                            <tbody id="PurchaseRequestsTable">
                                @foreach (var PurchaseRequest in Model)
                                {
                                <tr>
                                    <td>
                                        @*@Html.DisplayFor(modelPurchaseRequest => PurchaseRequest.DocumentNumber)*@
                                        @Html.Raw(PurchaseRequest.DocumentNumber.ToString().Replace("-", ""))
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelPurchaseRequest => PurchaseRequest.Department.ArName)
                                    </td>
                                    <td>
                                        <input type="checkbox" data-plugin="switchery" data-color="#00b19d" data-secondary-color="#ED5565" data-size="small"
                                               @Html.Raw(PurchaseRequest.ManufacturingPurchaseRequests.Any() ? "disabled data-toggle='tooltip' data-title="+MyERP.Properties.Resources.ApprovalCannotBeCanceled+" " : "")
                                               @Html.Raw(PurchaseRequest.IsApproved == true ? "checked" : "") onchange="ActivateDeactivate(@PurchaseRequest.Id,this)" />
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelPurchaseRequest => PurchaseRequest.VoucherDate)
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelPurchaseRequest => PurchaseRequest.ApprovalDate)
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelPurchaseRequest => PurchaseRequest.ItemGroup.ArName)
                                    </td>
                                    <td class="status-name">
                                        @Html.DisplayFor(modelPurchaseRequest => PurchaseRequest.PurchaseRequestStatu.ArName)
                                    </td>
                                    <td>
                                        <a href="@Url.Action("AddEdit","PurchaseRequest",new { id=PurchaseRequest.Id })" onclick="$('#preloader, #status').fadeIn();">
                                            <i class="fa fa-edit"></i>
                                        </a>
                                    </td>
                                    <td>
                                        <a href="javascript:void(0);" class="btnDelete_@PurchaseRequest.Id" @((PurchaseRequest.IsApproved.HasValue && PurchaseRequest.IsApproved.Value) ? "style=color:gray;cursor:no-drop;" : "onclick=DeleteFunc(" + @PurchaseRequest.Id + ")")>
                                            <i class="fas fa-trash-alt"></i>
                                        </a>
                                    </td>
                                    <td>
                                        <a href="@Url.Action("PurchaseRequest","Report",new { id=PurchaseRequest.Id,print=true})" target="_blank">
                                            <i class="remixicon-printer-fill"></i>
                                        </a>
                                    </td>
                                </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div style="text-align:center;margin-bottom: 50px;">

    <div class="form-group row">
        <div class="col-sm-4">
            <select id="ShowByPage" class="form-control" style="width:70px;float:left;" onchange="paging()">
                <option value="10">10</option>
                <option value="30">30</option>
                <option value="50">50</option>
                <option value="100">100</option>
                <option value="200">200</option>
                <option value="@ViewBag.Count">@MyERP.Properties.Resources.All</option>
            </select>
            <span style="font-size:12px;float:right;"> @MyERP.Properties.Resources.NoOfResults : <span id="RowsCount">@ViewBag.Count</span></span>
        </div>
        <div class="col-sm-2">
            <lablel class="col-sm-8"> @MyERP.Properties.Resources.PageNo: </lablel>
        </div>
        <div class="col-sm-2">
            <select id="pagination" class="pagination form-control" style="width:70px;float:left;">
            </select>
        </div>
    </div>
</div>

<script>
            var pageNo = 1;
    var searchWord = '@Html.Raw(ViewBag.searchWord)';

    $('#ShowByPage').val(@ViewBag.wantedRowsNo);

    function paging() {

        var link = '/PurchaseRequest/Index?pageIndex=' + pageNo + '&wantedRowsNo=' + $('#ShowByPage').val() + '&searchWord=' + searchWord ;
        window.location.replace(link);
    }

    function setPages() {
        var count =@ViewBag.Count;
        for (var i = 0; i < Math.ceil(count / $('#ShowByPage').val()); i++)
           $('#pagination').append('<option onchange="pageNo=' + (i + 1) + '; paging();" id="pg' + (i + 1) + '">' + (i + 1) + '</option>');
    }

    setPages();
   $('#pg' +@ViewBag.PageIndex).attr('selected', 'selected')

    $('#pagination').on('change', function () {
        pageNo = $('#pagination').val();
         paging();
    })


    function DeleteFunc(id) {
        Swal.fire({
            title: '@MyERP.Properties.Resources.AreYouSureYouWantToDelete',
            text: " ",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: '@MyERP.Properties.Resources.Ok',
            cancelButtonText: '@MyERP.Properties.Resources.Cancel',
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                $('#preloader, #status').fadeIn();
                $.ajax(
                    {
                        url: '/PurchaseRequest/Delete',
                        type: 'POST',
                        data: {
                            "Id": id,
                        },
                        error: function (e) {
                            $('#preloader, #status').fadeOut();
                        },
                        success: function (r) {
                            $('#preloader, #status').fadeOut();
                            if (r == 'true') {
                                window.location.reload();
                            }
                        }
                    });
            }
            else { result.dismiss; }
        });

        @*if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToDelete')) {
            $('#preloader, #status').fadeIn();
            $.ajax(
                {
                    url: '/PurchaseRequest/Delete',
                    type: 'POST',
                    data: {
                        "Id": id,
                    },
                    error: function (e) {
                        $('#preloader, #status').fadeOut();
                    },
                    success: function (r) {
                        $('#preloader, #status').fadeOut();
                        if (r == 'true') {
                            window.location.reload();
                        }
                    }
                });
        }*@
    }

    let changeIsApproved = true;
    function ActivateDeactivate(id, chk) {
        if (changeIsApproved) {
            $('#preloader, #status').fadeIn();
            $.ajax({
                url: '/PurchaseRequest/ActivateDeactivate',
                type: 'POST',
                data: {
                    "Id": id,
                },
                error: function (e) {
                    //alert('@MyERP.Properties.Resources.ApprovalStatusDoesNotChange');
                    Swal.fire(
                        {
                            title: '@MyERP.Properties.Resources.ApprovalStatusDoesNotChange',
                            text: " ",
                            icon: 'error',
                            showCancelButton: false,
                            confirmButtonText: '@MyERP.Properties.Resources.Ok',
                            confirmButtonColor: '#3085d6'
                        });
                    changeIsApproved = false;
                    $(chk).siblings('.switchery').trigger('click');
                    $('#preloader, #status').fadeOut();
                },
                success: function (r) {
                    $('#preloader, #status').fadeOut();
                    if (r == 'approved') {
                        //alert('@MyERP.Properties.Resources.RequestApproved');
                        Swal.fire(
                            {
                                title: '@MyERP.Properties.Resources.RequestApproved',
                                text: " ",
                                icon: 'success',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                        $(chk).closest('tr').find('.status-name').html('@MyERP.Properties.Resources.IsApproved');
                        $(".btnDelete_" + id).css("color", "gray").css("cursor", "no-drop").removeAttr("onclick");
                    }
                    else if (r == 'notApproved') {
                        //  alert('@MyERP.Properties.Resources.RequestApprovedIsCanceled');
                        Swal.fire(
                            {
                                title: '@MyERP.Properties.Resources.RequestApprovedIsCanceled',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                        $(chk).closest('tr').find('.status-name').html('@MyERP.Properties.Resources.New');
                        $(".btnDelete_" + id).css("color", "#3bafda").css("cursor", "pointer").attr("onclick", "DeleteFunc(" + id + ")");
                    } else {
                        // alert('@MyERP.Properties.Resources.ApprovalRequestNotEdit');
                        Swal.fire(
                            {
                                title: '@MyERP.Properties.Resources.ApprovalRequestNotEdit',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                        changeIsApproved = false;
                        $(chk).siblings('.switchery').trigger('click');
                    }
                }
            });
        }
        changeIsApproved = true;
    }

    $(function () {
        $(".switchery").click(function (e) {
            if ($(this).prev("input").attr('disabled'))
                // alert('@MyERP.Properties.Resources.ApprovalRequestNotEdit');
                Swal.fire(
                    {
                        title: '@MyERP.Properties.Resources.ApprovalRequestNotEdit',
                        text: " ",
                        icon: 'error',
                        showCancelButton: false,
                        confirmButtonText: '@MyERP.Properties.Resources.Ok',
                        confirmButtonColor: '#3085d6'
                    });
        });
    });

</script>