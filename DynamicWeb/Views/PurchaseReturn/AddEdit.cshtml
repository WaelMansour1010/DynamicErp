    function chooseItem(item) {
        let itemId = $(item).closest('tr').find('.items-prices-quantities-id').val();
        $('#PurchaseReturnsDetails .item:last').val(itemId);
        $('#PurchaseReturnsDetails .item-name:last').val($(item).closest('tr').find('.nameOfItem').text());
        $('#PurchaseReturnsDetails .name:last').text($(item).closest('tr').find('.nameOfItem').text());
        $('#PurchaseReturnsDetails .item:last').trigger('change');
        $('.bs-example-modal-lg').modal('hide');
    }


    function deleteElement(e) {
        let tr = $(e).closest('tr');
        if ($(tr).index() == 0 && $(tr).closest('tbody').children('tr').length == 1) {
            $(tr).find("input").val('');
            $(tr).find('.Add-Button').prop('hidden', false);
            $(tr).find('.popupCell').attr('onclick', 'showSearchModal()');
        }
        else if ($(tr).index() < $(tr).closest('tbody').children('tr').length - 1)
            e.parentNode.parentNode.parentNode.removeChild(e.parentNode.parentNode);
        else if ($(tr).index() == $(tr).closest('tbody').children('tr').length - 1) {
            $(tr).find("input").val('');
            $(tr).find('input, select').removeAttr('required');
            $(tr).find('select').empty();
            $(tr).find('.Add-Button').prop('hidden', false);
            $(tr).find('.popupCell').attr('onclick', 'showSearchModal()');
        }
        CalculateTotals();
    }

    function addEdit(n) {
        var valid = true;
        if ($(".form-control:invalid").length > 0) {
            $('.form-horizontal').addClass('was-validated');
            $('html, body').animate({
                scrollTop: $(".form-control:invalid").eq(0).offset().top - 80
            }, 500);
            console.log($(".form-control:invalid"));
            valid = false;
        }
        if (valid && $('#CashAmount').inputmask('unmaskedvalue')*1 > 0) {
            if (!$('#CashBoxId').val()) {
                //alert("لابد من اختيار الصندوق الذى تم دفع المبلغ النقدى له ")
                Swal.fire({
                title: '@MyERP.Properties.Resources.YouMustChooseCashBoxToWhichTheCashAmountWasPaid',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
                valid = false;
            }
        }
        if (valid && $('#ChequeAmount').inputmask('unmaskedvalue')*1 > 0) {
            if (!$('#BankIdForCheque').val()) {
                //alert("لابد من اختيار البنك الذى يتم صرف الشيك منه ")
                Swal.fire({
                title: '@MyERP.Properties.Resources.YouMustChooseTheBankFromWhichTheChequeIsCashed',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
                valid = false;
            } else if (!$('#BankAccountIdForCheque').val()) {
                //alert("لابد من اختيار الحساب البنكى لصرف هذا الشيك  ")
                Swal.fire({
                title: '@MyERP.Properties.Resources.YouMustChooseABankAccountToCashThisCheque',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
                valid = false;
            }
        }
        if (valid && $('#VisaAmount').inputmask('unmaskedvalue')*1 > 0) {
            if (!$('#BankIdForVisa').val()) {
                //alert("لابد من اختيار البنك التابعة له هذه الفيزا ")
                Swal.fire({
                title: '@MyERP.Properties.Resources.YouMustChooseTheBankToWhichThisVisaIsAffiliated',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
                valid = false;
            } else if (!$('#BankAccountIdForVisa').val()) {
                //alert("لابد من اختيار الحساب البنكى لهذه الفيزا  ")
                Swal.fire({
                title: '@MyERP.Properties.Resources.YouMustChooseTheBankAccountForThisVisa',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
                valid = false;
            }
        }
        if (valid) {
            if ($('#hasTaxes').prop('checked') == false) {
                $('#TotalAfterTaxes').val($('#NetTotal').inputmask('unmaskedvalue'));
            }
        }
        if (valid) {
            var PurchaseReturnsDetails = [];
            $('#PurchaseReturnsDetails tr').each(function () {
                var td = $(this);
                if (td.find('.quantity').val() * 1 != 0 && td.find('.item').val() > 0) {
                    let itemId = items.filter(function (i) { return i.ItemPriceId == td.find('.item').val(); })[0].Id;
                    var purchaseReturnsDetail = {
                        ItemId: itemId,
                        ItemPriceId: td.find('.item').val(),
                        ItemUnitId: td.find('.item-unit').val(),
                        UnitEquivalent: td.find('.unit-equavalent').val(),
                        Price: td.find('.price').inputmask('unmaskedvalue'),
                        Qty: td.find('.quantity').val(),
                        IsActive: true,
                        IsDeleted: false,
                        Notes: td.find('.Notes').val(),
                        ExpireDate: td.find('.ExpiryDate').val(),
                        PatchId: td.find('.PatchId').val(),
                        CostPrice: td.find('.cost').inputmask('unmaskedvalue'),
                    };

                    PurchaseReturnsDetails.push(purchaseReturnsDetail);
                }
            });
            valid = PurchaseReturnsDetails.length > 0 ? true : false;
            !valid ?
                Swal.fire({
                title: '@MyERP.Properties.Resources.AllDetailsRequired',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            }): null;
        }
        if (valid) {
            var paymentMethods = [];
            var totalPaied = 0;
            $('#PurchaseReturnPaymentMethods tr').each(function () {
                var td = $(this);
                totalPaied += td.find('.PaymentAmount').inputmask('unmaskedvalue')*1;
                var paymentMethod = {
                    PurchaseReturnId: $('#Id').val(),
                    PaymentMethodId: td.find('.PaymentMethodId').val(),
                    CashBoxId: td.find('.CashBoxId').val(),
                    Amount: td.find('.PaymentAmount').inputmask('unmaskedvalue'),
                    BankId: td.find('.PaymentAmount').inputmask('unmaskedvalue') && td.find('.BankId').val() > 0 ? td.find('.BankId').val() : null,
                    BankAccountId: td.find('.PaymentAmount').inputmask('unmaskedvalue') && td.find('.BankAccountId').val() > 0 ? td.find('.BankAccountId').val() : null
                };
                paymentMethods.push(paymentMethod);
            });

            if ($('#TotalAfterTaxes').inputmask('unmaskedvalue') != totalPaied) {
               // alert("قيمة الإجمالى  لا تساوى قيمة مجموع المدفوع");
                Swal.fire({
                title: '@MyERP.Properties.Resources.TheTotalValueIsNotEqualToTotalAmountPaid',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
                valid = false;
            }
        }
        if (valid) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.AreYouSureYouWantToSave',
                text: " ",
                icon: 'info',
                showCancelButton: true,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                cancelButtonText: '@MyERP.Properties.Resources.Cancel',
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    $('#preloader, #status').fadeIn();
                    $('#newbtn').prop('disabled', true);
                    $('#save').prop('disabled', true);
                    $.ajax({
                        type: "POST", contentType: "application/json",
                        url: "/PurchaseReturn/AddEdit",
                        data:
                            JSON.stringify({
                                Id: $('#Id').val(),
                                DocumentNumber: $('#DocumentNumber').val(),
                                BranchId: $('#BranchId').val(),
                                WarehouseId: $('#WarehouseId').val(),
                                VoucherDate: $('#VoucherDate').val(),
                                VendorOrCustomerId: $('#VendorOrCustomerId').val(),
                                CurrencyId: $('#CurrencyId').val(),
                                CurrencyEquivalent: $('#CurrencyEquivalent').val(),
                                Total: $('#Total').inputmask('unmaskedvalue'),
                                SalesTaxes: $('#SalesTaxes').inputmask('unmaskedvalue'),
                                TotalAfterTaxes: $('#TotalAfterTaxes').inputmask('unmaskedvalue'),
                                VoucherDiscountValue: $('#DiscountValue').inputmask('unmaskedvalue'),
                                VoucherDiscountPercentage: $('#VoucherDiscountPercentage').val(),
                                NetTotal: $('#NetTotal').inputmask('unmaskedvalue'),
                                SystemPageId: $('#SystemPageId').val(),
                                DepartmentId: $('#DepartmentId').val(),
                                PurchaseReturnsDetails: PurchaseReturnsDetails,
                                IsActive: $('#IsActive').val(),
                                IsDeleted: $('#IsDeleted').val(),
                                Notes: $('#Notes').val(),
                                PurchaseReturnPaymentMethods: paymentMethods,
                                CostCenterId: $('#CostCenterId').val()
                            }),
                        success: function (r) {
                            if (r == "true") {
                                // alert("تم الحفظ");
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.Saved',
                                    text: " ",
                                    icon: 'success',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                                var itemIds = [];
                                $('#PurchaseReturnsDetails tr').each(function () {
                                    var td = $(this);
                                    if (td.find('.item').val() > 0)
                                        itemIds.push({
                                            ItemId: td.find('.item').val(),
                                        });
                                });
                                $.ajax({
                                    type: "POST", contentType: "application/json",
                                    url: "/Helper/UpdateItemQuantities",
                                    data:
                                        JSON.stringify({
                                            itemIds: itemIds,
                                            date: new Date()
                                        }),
                                    success: function (r) { }
                                });
                                $('#preloader, #status').fadeOut();
                                if (n == "new") {
                                    window.location.replace("/PurchaseReturn/AddEdit");
                                } else {
                                    window.location.replace("/PurchaseReturn");
                                }
                            }
                             else if (r == "Cannot Be Edited")
                    {
                        $('#preloader, #status').fadeOut();
                        Swal.fire({
                            title: '@MyERP.Properties.Resources.TheInvoiceHasBeenGeneratedAndCannotBeEdited',
                            text: " ",
                            icon: 'error',
                            showCancelButton: false,
                            confirmButtonText: '@MyERP.Properties.Resources.Ok',
                            confirmButtonColor: '#3085d6'
                        });

                    }
                    else {
                        $('#preloader, #status').fadeOut();
                        $('#newbtn').prop('disabled', false);
                        $('#save').prop('disabled', false);
                        //alert("@MyERP.Properties.Resources.NotSaved");
                        Swal.fire({
                            title: '@MyERP.Properties.Resources.NotSaved',
                            text: " ",
                            icon: 'error',
                            showCancelButton: false,
                            confirmButtonText: '@MyERP.Properties.Resources.Ok',
                            confirmButtonColor: '#3085d6'
                        });
                    }
                        },
                        error: function (r) {
                            $('#preloader, #status').fadeOut();
                            $('#newbtn').prop('disabled', false);
                            $('#save').prop('disabled', false);
                            console.log(r.response)
                            //alert("لم يتم الحفظ!");
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.NotSaved',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                        }
                    });
                }
                else { result.dismiss; }
            });
        }
