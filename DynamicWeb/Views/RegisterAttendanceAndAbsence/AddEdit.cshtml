    function addEdit(n) {
        let valid = true;
        if ($('.form-horizontal').first().find('.form-control:invalid').length > 0) {
            $('.form-horizontal').first().addClass('was-validated');
            $('html, body').animate({
                scrollTop: $('.form-horizontal').first().find(".form-control:invalid").eq(0).offset().top - 100
            }, 500);
            valid = false;
            console.log($(".form-control:invalid"));
        }
        let RegisterAttendanceAndAbsenceDetails = [];
        $('#RegisterAttendanceAndAbsenceDetails').find('tr').each(function () {
            var RegisterAttendanceAndAbsenceDetail = {
                Code: $(this).find('.Code').val(),
                AttendDate: $(this).find('.AttendDate').val(),
                SubjectId: $(this).find('.SubjectId').val(),
                LessonId: $(this).find('.LessonId').val(),
                StudentId: $(this).find('.StudentId').val(),
                IsAttended: $(this).find('.IsAttended').prop('checked'),
                IsDeleted: false,
                IsActive:true,
                UserId: $('#UserId').val(),
            }
                RegisterAttendanceAndAbsenceDetails.push(RegisterAttendanceAndAbsenceDetail);
        });
        var RegisterAttendanceAndAbsence = {
            Id: $('#Id').val(),
            Code: $('#Code').val(),
            Date: $('#Date').val(),
            SubjectId: $('#SubjectId').val(),
            LessonId: $('#LessonId').val(),
            UserId: $('#UserId').val(),
            IsDeleted: false,
            IsActive: true,
            Notes: $('#Notes').val(),
            Image: $('#Image').val(),
            RegisterAttendanceAndAbsenceDetails: RegisterAttendanceAndAbsenceDetails
        }
        if (valid) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.AreYouSureYouWantToSave',
                text: " ",
                icon: 'info',
                showCancelButton: true,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                cancelButtonText: '@MyERP.Properties.Resources.Cancel',
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    $('#preloader, #status').fadeIn();
                    $('#newbtn').prop('disabled', true);
                    $('#save').prop('disabled', true);
                    $.ajax({
                        type: "POST", contentType: "application/json",
                        url: "/RegisterAttendanceAndAbsence/AddEdit",
                        data: JSON.stringify(RegisterAttendanceAndAbsence),
                        success: function (r) {
                            if (r.success == true) {
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.Saved',
                                    text: " ",
                                    icon: 'success',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                }); if (n == "new") {
                                    window.location.replace("/RegisterAttendanceAndAbsence/AddEdit");
                                } else {
                                    window.location.replace("/RegisterAttendanceAndAbsence");
                                }
                            }
                            else {
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.NotSaved !',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                            }
                            $('#preloader, #status').fadeOut();
                            $('#newbtn').prop('disabled', false);
                            $('#save').prop('disabled', false);
                        },
                        error: function (r) {
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.NotSaved !',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            }); $('#preloader, #status').fadeOut();
                            $('#newbtn').prop('disabled', false);
                            $('#save').prop('disabled', false);
                        }
                    });
                }
                else { result.dismiss; }
            });
        }
    }

