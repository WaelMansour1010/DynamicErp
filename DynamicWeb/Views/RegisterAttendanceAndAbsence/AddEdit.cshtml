function AdvancedEntry() {
        let valid = true
        var Date = $('#Date').val();
        var LessonId = $('#LessonId').val();
    var SubjectId = $('#SubjectId').val();
    let Code = 1;
    if ($('#RegisterAttendanceAndAbsenceDetails tr').length == 0) {
        Code = 1;
    }
    else {
        Code = parseInt($('#RegisterAttendanceAndAbsenceDetails .Code:last').val()) + 1;
    }

         if (Date == null) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.AttendDate @MyERP.Properties.Resources.Required !',
                text: " ",
                icon: 'error',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
            valid = false;
        }
        if (!SubjectId) {
            Swal.fire({
                        title: '@MyERP.Properties.Resources.SelectCourse !',
                        text: " ",
                        icon: 'error',
                        showCancelButton: false,
                        confirmButtonText: '@MyERP.Properties.Resources.Ok',
                        confirmButtonColor: '#3085d6'
            });
            valid = false;
        }
        if (!LessonId) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.SelectLecture !',
                text: " ",
                icon: 'error',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
            valid = false;
        }
    if (valid == true) {
        let Id = $('#Id').val() > 0 ? $('#Id').val() : 0;
            window.location.replace('/RegisterAttendanceAndAbsence/AdvancedEntry?Date=' + Date + '&LessonId=' + LessonId + '&SubjectId=' + SubjectId + '&Id=' + Id + '&Code=' + Code + '&MasterCode=' + $('#Code').val());
        }
    }

    function CheckIfRegisteredBefore() {
        $.get('/RegisterAttendanceAndAbsence/CheckIfRegisteredBefore?LessonId=' + $('#LessonId').val() + '&SubjectId=' + $('#SubjectId').val()).done(function (r) {
            if (r.success == "Exist") {
                Swal.fire({
                    title: '@MyERP.Properties.Resources.RegisteredBeforeWantToRedirect ?',
                    text: " ",
                    icon: 'info',
                    showCancelButton: true,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    cancelButtonText: '@MyERP.Properties.Resources.Cancel',
                    confirmButtonColor: '#3085d6',
                    cancelButtonColor: '#d33',
                    reverseButtons: true
                }).then((result) => {
                    if (result.isConfirmed) {
                        window.location.replace("/RegisterAttendanceAndAbsence/AddEdit?id=" + r.Id);
                    }
                    else {
                        result.dismiss;
                        $('#SubjectId').prop('selectedIndex', 0).select2();
                        $('#LessonId').prop('selectedIndex', 0).select2();
                    }
                });
            }
        });
    }
