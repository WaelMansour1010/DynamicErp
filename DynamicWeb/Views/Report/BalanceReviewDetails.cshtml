
@{
    if (ViewBag.ShowReport == true)
    {
        Layout = null;
    }
    else
    {
        Layout = "~/Views/Shared/_Layout.cshtml";
    }
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = MyERP.Properties.Resources.BalanceReview;
}


<meta name="viewport" content="width=device-width" />
<title> @MyERP.Properties.Resources.BalanceReview </title>
@if (ViewBag.ShowReport == true)
{
    @Html.DevExpress().GetStyleSheets(
            new StyleSheet { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
            new StyleSheet { ExtensionSuite = ExtensionSuite.Editors },
            new StyleSheet { ExtensionSuite = ExtensionSuite.Report }
        )
    @Html.DevExpress().GetScripts(
            new Script { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
            new Script { ExtensionSuite = ExtensionSuite.Editors },
            new Script { ExtensionSuite = ExtensionSuite.Report }
        )
    
    <div>
        @Html.DevExpress().WebDocumentViewer(settings =>
        {
            settings.Name = "WebDocumentViewer";
        }).Bind(new DevExpress.XtraReports.Web.CachedReportSourceWeb(new BalanceReview2_Report( ViewBag.DepartmentId, ViewBag.From, ViewBag.To, ViewBag.ActivityId, ViewBag.CompanyId))).GetHtml()
    </div>
}
else
{
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <div class="form-horizontal needs-validation" role="form">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.BalanceReview
                                    </h5>
                                    <div class="form-group row">
                                        <label class=" col-sm-1 control-label" for="ArName">@MyERP.Properties.Resources.Department</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("DepartmentId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", required = "required" })
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label for="DateFrom" class="control-label col-sm-1">@MyERP.Properties.Resources.FromDate</label>
                                        <div class="col-sm-5">
                                            <input id="DateFrom" name="DateFrom" class="form-control" type="date" required />
                                        </div>
                                        <label for="DateTo" class="control-label col-sm-1">@MyERP.Properties.Resources.ToDate</label>
                                        <div class="col-sm-5">
                                            <input id="DateTo" name="DateTo" class="form-control" type="date" required />
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class=" col-sm-1 control-label">@MyERP.Properties.Resources.Activity</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("ActivityId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                        <label class=" col-sm-1 control-label">@MyERP.Properties.Resources.Company</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("CompanyId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-offset-2">
                        <button class="btn btn-success" onclick="DownloadReport()">
                            @MyERP.Properties.Resources.ShowReport
                        </button>
                        <button class="btn btn-success" onclick="ShowData()">
                            @MyERP.Properties.Resources.ShowData
                        </button>
                        <button class="btn btn-success" onclick="ShowReport()">
                            @MyERP.Properties.Resources.ShowDesign
                        </button>
                        <button class="btn btn-warning" onclick="ShowReportDetails()">
                          حسابات تحليلى
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!--------------------------------ShowData Table --------------------------------------->
    <div class="row" id="AllTable" style="display:none">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <div class="form-horizontal needs-validation" role="form">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.ReportData
                                    </h5>

                                    <div class="table-responsive">
                                        <table class="table table-striped table-centered mb-0">
                                            <thead>
                                                <tr>
                                                    <th>
                                                        @MyERP.Properties.Resources.Code
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Name
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.DebitOB
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.CreditOB
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.DebitTransaction
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.CreditTransaction
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.TotalDebit
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.TotalCredit
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.DebitBalance
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.CreditBalance
                                                    </th>
                                                </tr>
                                            </thead>
                                            <tbody id="ShowDataTable"></tbody>
                                        </table>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!--***********************************************************************************************-->
}
<script>
    var pageNo = 1;
        $('#ShowByPage').val('@ViewBag.wantedRowsNo');

        function JsDate(val) {
        var date = new Date(val);
        var dd = date.getDate();
        var mm = date.getMonth() + 1; //January is 0!
        var yyyy = date.getFullYear();

        if (dd < 10) {
            dd = '0' + dd;
        }

        if (mm < 10) {
            mm = '0' + mm;
        }

        return date = yyyy + '-' + mm + '-' + dd;
    }
    $(document).ready(function () {
        $.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
            var from = JsDate(r.PeriodStart);
            var to = JsDate(r.PeriodEnd);
            $('#DateFrom').prop('min', from);
            $('#DateFrom').prop('max', to);
            $('#DateFrom').val(from);
            $('#DateTo').prop('min', from);
            $('#DateTo').prop('max', to);
            $('#DateTo').val(to);
        });
    });

    
    function ShowReportDetails() {
        window.open("/Report/BalanceReviewDetails?DepartmentId=" + $('#DepartmentId').val() + "&From=" + $('#DateFrom').val() + "&To=" + $('#DateTo').val() + '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val() + '&showReport=' + true + '&print=' + false, "blank");
    }
    function ShowReport() {
        window.open("/Report/BalanceReview?DepartmentId=" + $('#DepartmentId').val() + "&From=" + $('#DateFrom').val() + "&To=" + $('#DateTo').val()+ '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val() + '&showReport=' + true+ '&print=' + false, "blank");
    }
    function DownloadReport() {
        window.open("/Report/BalanceReview?DepartmentId=" + $('#DepartmentId').val() + "&From=" + $('#DateFrom').val() + "&To=" + $('#DateTo').val()+ '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val() + '&showReport=' + false+ '&print=' + true, "blank");
    }

    function ShowData() {
        $('#ShowDataTable').empty();
        $('#preloader, #status').fadeIn();

        $.get("/Helper/GetBalanceReview?DepartmentId=" + $('#DepartmentId').val() + "&From=" + $('#DateFrom').val() + "&To=" + $('#DateTo').val()+ '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val()).done(function (r) {
            $('#AllTable').show();
            for (var i = 0; i < r.length; i++) {
                r[i].Code = r[i].Code == null ? "" : r[i].Code;
                r[i].ArName = r[i].ArName == null ? "" : r[i].ArName;
                r[i].ObDebit = r[i].ObDebit == null ? 0 : parseFloat(r[i].ObDebit).toFixed(2);
                r[i].ObCredit = r[i].ObCredit == null ? 0 : parseFloat(r[i].ObCredit).toFixed(2);
                r[i].Debit = r[i].Debit == null ? 0 : parseFloat(r[i].Debit).toFixed(2);
                r[i].Credit = r[i].Credit == null ? 0 : parseFloat(r[i].Credit).toFixed(2);
                r[i].TotalDebit = r[i].TotalDebit == null ? 0 : parseFloat(r[i].TotalDebit).toFixed(2);
                r[i].TotalCredit = r[i].TotalCredit == null ? 0 : parseFloat(r[i].TotalCredit).toFixed(2);
                r[i].BalanceDebit = r[i].BalanceDebit == null ? 0 : parseFloat(r[i].BalanceDebit).toFixed(2);
                r[i].BalanceCredit = r[i].BalanceCredit == null ? 0 : parseFloat(r[i].BalanceCredit).toFixed(2);

                let tr = '<tr><td><label class="control-label">' +
                    r[i].Code + '</label></td><td><label class="control-label">' +
                    r[i].ArName + '</label></td><td><label class="control-label">' +
                    r[i].ObDebit + '</label></td><td><label class="control-label">' +
                    r[i].ObCredit + '</label></td><td><label class="control-label">' +
                    r[i].Debit + '</label></td><td><label class="control-label">' +
                    r[i].Credit + '</label></td><td><label class="control-label">' +
                    r[i].TotalDebit + '</label></td><td><label class="control-label">' +
                    r[i].TotalCredit + '</label></td><td><label class="control-label">' +
                    r[i].BalanceDebit + '</label></td><td><label class="control-label">' +
                    r[i].BalanceCredit + '</label></td></tr>';
                $('#ShowDataTable').append(tr);
            }
            $('#preloader, #status').fadeOut();
        });
    }

    function convertToJavaScriptDate(value) {
        if (value === null)
            return null;
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        return ((dt.getMonth() + 1 + "/" + dt.getDate() + "/" + dt.getFullYear()));
    }

</script>