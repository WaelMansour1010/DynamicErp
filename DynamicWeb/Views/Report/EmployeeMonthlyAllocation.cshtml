
@{
    if (ViewBag.ShowReport == true)
    {
        Layout = null;
    }
    else
    {
        Layout = "~/Views/Shared/_Layout.cshtml";
    }
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = MyERP.Properties.Resources.EmployeeMonthlyAllocation;
}

<meta name="viewport" content="width=device-width" />
<title> @MyERP.Properties.Resources.EmployeeMonthlyAllocation </title>

@if (ViewBag.ShowReport == true)
{
    @Html.DevExpress().GetStyleSheets(
            new StyleSheet { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
            new StyleSheet { ExtensionSuite = ExtensionSuite.Editors },
            new StyleSheet { ExtensionSuite = ExtensionSuite.Report }
        )
    @Html.DevExpress().GetScripts(
            new Script { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
            new Script { ExtensionSuite = ExtensionSuite.Editors },
            new Script { ExtensionSuite = ExtensionSuite.Report }
        )

    <div>
        @Html.DevExpress().WebDocumentViewer(settings =>
   {
       settings.Name = "WebDocumentViewer";
   }).Bind(new DevExpress.XtraReports.Web.CachedReportSourceWeb(new EmployeeMonthlyAllocation_Report(ViewBag.DepartmentId, ViewBag.AllocationType, ViewBag.Year, ViewBag.Month, ViewBag.ActivityId, ViewBag.CompanyId))).GetHtml()
    </div>
}
else
{
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <div class="form-horizontal needs-validation" role="form">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.EmployeeMonthlyAllocation
                                    </h5>
                                    <div class="form-group row">
                                        <label class=" col-sm-1 control-label" for="ArName">@MyERP.Properties.Resources.Department</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("DepartmentId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", required = "required" })
                                        </div>
                                        <label class=" col-sm-1 control-label" for="Code">@MyERP.Properties.Resources.AllocationType</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("AllocationType", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", required = "required" })
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class=" col-sm-1 control-label" for="ArName">@MyERP.Properties.Resources.Year</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("Year", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", required = "required" })
                                        </div>
                                        <label class=" col-sm-1 control-label" for="Code">@MyERP.Properties.Resources.Month</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("Month", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", required = "required" })
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class=" col-sm-1 control-label">@MyERP.Properties.Resources.Activity</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("ActivityId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                        <label class=" col-sm-1 control-label">@MyERP.Properties.Resources.Company</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("CompanyId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-offset-2">
                        <button class="btn btn-success" onclick="DownloadReport()">
                            @MyERP.Properties.Resources.ShowReport
                        </button>
                        <button class="btn btn-success" onclick="ShowData()">
                            @MyERP.Properties.Resources.ShowData
                        </button>
                        <button class="btn btn-success" onclick="ShowReport()">
                            @MyERP.Properties.Resources.ShowDesign
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!--------------------------------ShowData Table --------------------------------------->
    <div class="row" id="AllTable" style="display:none">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <div class="form-horizontal needs-validation" role="form">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.ReportData
                                    </h5>

                                    <div class="table-responsive">
                                        <table class="table table-striped table-centered mb-0">
                                            <thead>
                                                <tr>
                                                    <th>
                                                        @MyERP.Properties.Resources.Employee
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Amount
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Notes
                                                    </th>
                                                </tr>
                                            </thead>
                                            <tbody id="ShowDataTable"></tbody>
                                        </table>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>

                   
                </div>
                
            </div>
        </div>
    </div>

    <!--***********************************************************************************************-->
}

<script>
    var pageNo = 1;
    $('#ShowByPage').val('@ViewBag.wantedRowsNo');

    function ShowReport() {
        if  (!$('#DepartmentId').val())
            Swal.fire({
                title: '@MyERP.Properties.Resources.Department' + ' ' + '@MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        else if (!$('#AllocationType').val()) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.AllocationType' + ' ' + '@MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        }
        else if (!$('#Year').val()) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.Year' + ' ' + '@MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        } else if (!$('#Month').val()) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.Month' + ' ' + '@MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        }
        else {
            window.open("/Report/EmployeeMonthlyAllocation?DepartmentId=" + $('#DepartmentId').val() + "&AllocationType=" + $('#AllocationType').val() + "&Year=" + $('#Year').val() + "&Month=" + $('#Month').val()+ '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val() + '&showReport=' + true+'&print='+false, "blank");
        }
    }
        function DownloadReport() {
        if  (!$('#DepartmentId').val())
            Swal.fire({
                title: '@MyERP.Properties.Resources.Department' + ' ' + '@MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        else if (!$('#AllocationType').val()) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.AllocationType' + ' ' + '@MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        }
        else if (!$('#Year').val()) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.Year' + ' ' + '@MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        } else if (!$('#Month').val()) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.Month' + ' ' + '@MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        }
        else {
            window.open("/Report/EmployeeMonthlyAllocation?DepartmentId=" + $('#DepartmentId').val() + "&AllocationType=" + $('#AllocationType').val() + "&Year=" + $('#Year').val() + "&Month=" + $('#Month').val()+ '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val() + '&showReport=' + false+'&print='+true, "blank");
        }
    }

    function ShowData() {

        if  (!$('#DepartmentId').val())
            Swal.fire({
                title: '@MyERP.Properties.Resources.Department' + ' ' + '@MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        else if (!$('#AllocationType').val()) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.AllocationType' + ' ' + '@MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        }
        else if (!$('#Year').val()) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.Year' + ' ' + '@MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        } else if (!$('#Month').val()) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.Month' + ' ' + '@MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        }
        else {
        $('#ShowDataTable').empty();
        $('#preloader, #status').fadeIn();

        $.get('/Helper/GetEmployeeMonthlyAllocation?DepartmentId=' + $('#DepartmentId').val() + "&AllocationType=" + $('#AllocationType').val() + "&Year=" + $('#Year').val() + "&Month=" + $('#Month').val()+ '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val()).done(function (r) {
            $('#AllTable').show();
            for (var i = 0; i < r.length; i++) {
                r[i].EmployeeName = r[i].EmployeeName == null ? "" : r[i].EmployeeName;
                r[i].Value = r[i].Value == null ? 0 : r[i].Value;
                r[i].Notes = r[i].Notes == null ? "" : r[i].Notes;

                let tr = '<tr><td ><label class="control-label ">' +
                    r[i].EmployeeName + '</label></td><td><label class="control-label ">' +
                    r[i].Value + '</label></td><td><label class="control-label ">' +
                    r[i].Notes + '</label></td></tr>';
                $('#ShowDataTable').append(tr);
            }

            $('#preloader, #status').fadeOut();

        });
    }
    }



    function convertToJavaScriptDate(value) {
        if (value === null)
            return null;
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        return ((dt.getMonth() + 1 + "/" + dt.getDate() + "/" + dt.getFullYear()));
    }

</script>