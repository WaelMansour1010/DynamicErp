@{
    if (ViewBag.ShowReport == true)
    {
        Layout = null;
    }
    else
    {
        Layout = "~/Views/Shared/_Layout.cshtml";
    }
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = MyERP.Properties.Resources.ExpensesInPeriod;
}


<meta name="viewport" content="width=device-width" />
<title> @MyERP.Properties.Resources.ExpensesInPeriod </title>

@if (ViewBag.ShowReport == true)
{
    @Html.DevExpress().GetStyleSheets(
            new StyleSheet { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
            new StyleSheet { ExtensionSuite = ExtensionSuite.Editors },
            new StyleSheet { ExtensionSuite = ExtensionSuite.Report }
        )
    @Html.DevExpress().GetScripts(
            new Script { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
            new Script { ExtensionSuite = ExtensionSuite.Editors },
            new Script { ExtensionSuite = ExtensionSuite.Report }
        )

    <div>

        @Html.DevExpress().WebDocumentViewer(settings =>
   {
       settings.Name = "WebDocumentViewer";
   }).Bind(new DevExpress.XtraReports.Web.CachedReportSourceWeb(new ExpensesInPeriod_Report(ViewBag.DepartmentId, ViewBag.From, ViewBag.To, ViewBag.ExpenseId, ViewBag.ActivityId, ViewBag.CompanyId))).GetHtml()


    </div>
}
else
{
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <div class="form-horizontal needs-validation" role="form">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.ExpensesInPeriod
                                    </h5>
                                    <div class="form-group row">
                                        <label class=" col-sm-1 control-label">@MyERP.Properties.Resources.Department</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("DepartmentId", null, null, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                        <label class=" col-sm-1 control-label">@MyERP.Properties.Resources.Expense</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("ExpenseId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class=" col-sm-1 control-label" for="Code">@MyERP.Properties.Resources.From</label>
                                        <div class="col-sm-5">
                                            <input id="From" class="form-control" type="date" required />
                                        </div>
                                        <label class=" col-sm-1 control-label" for="Code">@MyERP.Properties.Resources.To</label>
                                        <div class="col-sm-5">
                                            <input id="To" class="form-control" type="date" required />
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class=" col-sm-1 control-label">@MyERP.Properties.Resources.Activity</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("ActivityId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                        <label class=" col-sm-1 control-label">@MyERP.Properties.Resources.Company</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("CompanyId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-offset-2">
                        <button class="btn btn-success" onclick="DownloadReport()">
                            @MyERP.Properties.Resources.ShowReport
                        </button>
                        <button class="btn btn-success" onclick="ShowData()">
                            @MyERP.Properties.Resources.ShowData
                        </button>
                        <button class="btn btn-success" onclick="ShowReport()">
                            @MyERP.Properties.Resources.ShowDesign
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!--------------------------------ShowData Table --------------------------------------->
    <div class="row" id="AllTable" style="display:none">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <div class="form-horizontal needs-validation" role="form">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.ReportData
                                    </h5>

                                    <div class="table-responsive">
                                        <table class="table table-striped table-centered mb-0">
                                            <thead>
                                                <tr>
                                                    <th>
                                                        @MyERP.Properties.Resources.Date
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.DocNo
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.DocumentType
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.ExpenseType
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.JournalEntrieNo
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Value
                                                    </th>
                                                </tr>
                                            </thead>
                                            <tbody id="ShowDataTable"></tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class=" col-sm-1 control-label" for="Code">@MyERP.Properties.Resources.Total</label>
                                <div class="col-sm-5">
                                    <input id="Total" class="form-control" type="text" disabled />
                                </div>
                               
                            </div>

                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>



    <!--***********************************************************************************************-->

}

<script>
    function JsDate(val) {
        var date = new Date(val);
        var dd = date.getDate();
        var mm = date.getMonth() + 1; //January is 0!
        var yyyy = date.getFullYear();

        if (dd < 10) {
            dd = '0' + dd;
        }

        if (mm < 10) {
            mm = '0' + mm;
        }

        return date = yyyy + '-' + mm + '-' + dd;
    }
    $(document).ready(function () {
        $.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
            var from = JsDate(r.PeriodStart);
            var to = JsDate(r.PeriodEnd);
            $('#DateFrom').prop('min', from);
            $('#DateFrom').prop('max', to);
            $('#DateFrom').val(from);
            $('#DateTo').prop('min', from);
            $('#DateTo').prop('max', to);
            $('#DateTo').val(to);
        });
    });

    function ShowReport() {
        window.open('/Report/ExpensesInPeriod?From=' + $('#From').val() + '&To=' + $('#To').val() + '&ExpenseId=' + $('#ExpenseId').val() + '&DepartmentId=' + $('#DepartmentId').val()+ '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val() + '&showReport=' + true + '&print=' + false, "blank");
    }
    function DownloadReport() {
        window.open('/Report/ExpensesInPeriod?From=' + $('#From').val() + '&To=' + $('#To').val() + '&ExpenseId=' + $('#ExpenseId').val() + '&DepartmentId=' + $('#DepartmentId').val()+ '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val() + '&showReport=' + false + '&print=' + true, "blank");
    }

    function ShowData() {
        $('#ShowDataTable').empty();
        $('#preloader, #status').fadeIn();
        var sum = 0;
        $.get('/Helper/GetExpensesInPeriod?From=' + $('#From').val() + '&To=' + $('#To').val() + '&ExpenseId=' + $('#ExpenseId').val() + '&DepartmentId=' + $('#DepartmentId').val()+ '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val()).done(function (r) {
            $('#AllTable').show();
            for (var i = 0; i < r.length; i++) {
                r[i].Date = r[i].Date == null ? "" : convertToJavaScriptDate( r[i].Date);
                r[i].DocumentNumber = r[i].DocumentNumber == null ? "" : r[i].DocumentNumber;
                r[i].DocType = r[i].DocType == null ? "" : r[i].DocType;
                r[i].ArName = r[i].ArName == null ? "" : r[i].ArName;
                r[i].journalDocNo = r[i].journalDocNo == null ? "" : r[i].journalDocNo;
                r[i].ChequeValue = r[i].ChequeValue == null ? 0 : r[i].ChequeValue;
               
                let tr = '<tr><td><label class="control-label">' +
                    r[i].Date + '</label></td><td><label class="control-label">' +
                    r[i].DocumentNumber + '</label></td><td><label class="control-label">' +
                    r[i].DocType + '</label></td><td><label class="control-label">' +
                    r[i].ArName + '</label></td><td><label class="control-label">' +
                    r[i].journalDocNo + '</label></td><td><label class="control-label">' +
                    r[i].ChequeValue + '</label></td></tr>';
                sum += r[i].ChequeValue;
                $('#ShowDataTable').append(tr);
                $('#Total').val(sum);
            }

            $('#preloader, #status').fadeOut();
        });
    }


    function convertToJavaScriptDate(value) {
        if (value === null)
            return null;
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        return ((dt.getMonth() + 1 + "/" + dt.getDate() + "/" + dt.getFullYear()));
    }

</script>
