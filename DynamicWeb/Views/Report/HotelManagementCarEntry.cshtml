@model HotelManagementCarEntry_Report

@{
    if (ViewBag.ShowReport == true)
    {
        Layout = null;
    }
    else
    {
        Layout = "~/Views/Shared/_Layout.cshtml";
    }
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = MyERP.Properties.Resources.HotelManagementCarEntry;
}
<!DOCTYPE html>


<meta name="viewport" content="width=device-width" />
<title>@MyERP.Properties.Resources.HotelManagementCarEntry</title>

@if (ViewBag.ShowReport == true)
{
    @Html.DevExpress().GetStyleSheets(
        new StyleSheet { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
        new StyleSheet { ExtensionSuite = ExtensionSuite.Editors },
        new StyleSheet { ExtensionSuite = ExtensionSuite.Report }
        )
    @Html.DevExpress().GetScripts(
        new Script { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
        new Script { ExtensionSuite = ExtensionSuite.Editors },
        new Script { ExtensionSuite = ExtensionSuite.Report }
        )


    @Html.DevExpress().WebDocumentViewer(settings =>
    {
        settings.Name = "WebDocumentViewer1";
    }).Bind(new DevExpress.XtraReports.Web.CachedReportSourceWeb(new HotelManagementCarEntry_Report(ViewBag.DateFrom, ViewBag.DateTo))).GetHtml()

}
else
{
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <div class="form-horizontal needs-validation" role="form">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.HotelManagementCarEntry

                                    </h5>

                                    <div class="form-group row">
                                        <label for="DateFrom" class="control-label col-sm-2">@MyERP.Properties.Resources.FromDate</label>
                                        <div class="col-sm-4">
                                            <input id="DateFrom" name="DateFrom" class="form-control" type="datetime-local" required />
                                        </div>
                                        <label for="DateTo" class="control-label col-sm-2">@MyERP.Properties.Resources.ToDate</label>
                                        <div class="col-sm-4">
                                            <input id="DateTo" name="DateTo" class="form-control" type="datetime-local" required />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-offset-2">
                        <button class="btn btn-success" onclick="ShowReport()">
                            @MyERP.Properties.Resources.ShowReport
                        </button>
                        <button class="btn btn-success" onclick="ShowData()">
                            @MyERP.Properties.Resources.ShowData
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!--------------------------------ShowData Table --------------------------------------->
    <div class="row" id="AllTable" style="display:none">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <div class="form-horizontal needs-validation" role="form">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.ReportData
                                    </h5>

                                    <div class="table-responsive">
                                        <table class="table table-striped table-centered mb-0">
                                            <thead>
                                                <tr>
                                                    <th>
                                                        @MyERP.Properties.Resources.ReservationNumber
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Date
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.CarNumber
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.CarType
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Price
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Department
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.CashBox
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Customer
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Notes
                                                    </th>
                                                </tr>
                                            </thead>
                                            <tbody id="ShowDataTable">
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-12">
            <div style="text-align:center;margin-bottom: 50px;">
                <div class="form-group row">
                    <div class="col-sm-6">
                        <select id="ShowByPage" class="form-control" style="width:70px;float:left;" onchange="ShowData()">
                            <option value="100">100</option>
                            <option value="200">200</option>
                            <option value="300">300</option>
                            <option value="@ViewBag.Count">@MyERP.Properties.Resources.All</option>
                        </select>
                        <span style="font-size:12px;float:right;"> @MyERP.Properties.Resources.NoOfResults: <span id="RowsCount">@ViewBag.Count</span></span>
                    </div>
                    <div class="col-sm-6">
                        <select id="pagination" class="pagination form-control col-sm-4" style="width:70px;float:left;">
                        </select>
                        <lablel class="col-sm-2"> @MyERP.Properties.Resources.PageNo: </lablel>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <!--***********************************************************************************************-->
}
<script>
    function JsDate(val) {
        var date = new Date(val);
        var dd = date.getDate();
        var mm = date.getMonth() + 1; //January is 0!
        var yyyy = date.getFullYear();

        if (dd < 10) {
            dd = '0' + dd;
        }

        if (mm < 10) {
            mm = '0' + mm;
        }

       return date = yyyy + '-' + mm + '-' + dd;
    }
    $(document).ready(function () {
        $.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
            $("input[type|='datetime-local']").prop('min', r.PeriodStart).prop('max', r.PeriodEnd);
        });
        //$.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
        //    var from = JsDate(r.PeriodStart);
        //    var to = JsDate(r.PeriodEnd);
        //    $('#DateFrom').prop('min', from);
        //    $('#DateFrom').prop('max', to);
        //    $('#DateFrom').val(from);
        //    $('#DateTo').prop('min', from);
        //    $('#DateTo').prop('max', to);
        //    $('#DateTo').val(to);
        //});
    });

    var pageNo = 1;
        $('#ShowByPage').val('@ViewBag.wantedRowsNo');

    function ShowReport() {
        if (!$('#DateFrom').val()) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.FromDate' + ' ' + '@MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        }
        else if (!$('#DateTo').val()) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.ToDate' + ' ' + '@MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        }
        else {
            window.open('/Report/HotelManagementCarEntry?DateFrom=' + $('#DateFrom').val() + '&DateTo=' + $('#DateTo').val() + '&showReport=' + true, "blank");
        }
    }

    function ShowData() {
        if (!$('#DateFrom').val()) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.FromDate' + ' ' + '@MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        }
        else if (!$('#DateTo').val()) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.ToDate' + ' ' + '@MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        }
        else {
            $('#ShowDataTable').empty();
            $('#preloader, #status').fadeIn();
            $.get('/Helper/GetHotelManagementCarEntry?DateFrom=' + $('#DateFrom').val() + '&DateTo=' + $('#DateTo').val() + '&pageIndex=' + pageNo + '&wantedRowsNo=' + $('#ShowByPage').val()).done(function (r) {
                if (r.length > 0) {
                    $('#AllTable').show();
                    for (var i = 0; i < r.length; i++) {
                        r[i].DocumentNumber = r[i].DocumentNumber == null ? "" : r[i].DocumentNumber;
                        r[i].VoucherDate = r[i].VoucherDate == null ? "" : r[i].VoucherDate;
                        r[i].CarNumber = r[i].CarNumber == null ? "" : r[i].CarNumber;
                        r[i].CarType = r[i].CarType == null ? "" : r[i].CarType;
                        r[i].Price = r[i].Price == null ? "" : r[i].Price;

                        r[i].DepartmentArName = r[i].DepartmentArName == null ? "" : r[i].DepartmentArName;
                        r[i].CashBoxArName = r[i].CashBoxArName == null ? "" : r[i].CashBoxArName;
                        r[i].CustomerArName = r[i].CustomerArName == null ? "" : r[i].CustomerArName;
                        r[i].Notes = r[i].Notes == null ? "" : r[i].Notes;

                        let tr = '<tr><td><label class="control-label">' +
                            r[i].DocumentNumber + '</label></td><td><label class="control-label">' +
                            r[i].VoucherDate + '</label></td><td><label class="control-label">' +
                            r[i].CarNumber + '</label></td><td><label class="control-label">' +
                            r[i].CarType + '</label></td><td><label class="control-label">' +
                            r[i].Price + '</label></td><td><label class="control-label">' +
                            r[i].DepartmentArName + '</label></td><td><label class="control-label">' +
                            r[i].CashBoxArName + '</label></td><td><label class="control-label">' +
                            r[i].CustomerArName + '</label></td><td><label class="control-label">' +
                            r[i].Notes + '</label></td></tr>';
                        $('#ShowDataTable').append(tr);
                    }
                }
            });
            $('#preloader, #status').fadeOut();
        }
    }

    function setPages() {
        var count ='@ViewBag.Count';
        for (var i = 0; i < Math.ceil(count / $('#ShowByPage').val()); i++)
   $('#pagination').append('<option onchange="pageNo=' + (i + 1) + '; paging();" id="pg' + (i + 1) + '">' + (i + 1) + '</option>');
    }

    setPages();

    $('#pg' +'@ViewBag.PageIndex').attr('selected', 'selected');

    $('#pagination').on('change', function () {
        pageNo = $('#pagination').val();
        ShowData();
    });

    function convertToJavaScriptDate(value) {
        if (value === null)
            return null;
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        return ((dt.getMonth() + 1 + "/" + dt.getDate() + "/" + dt.getFullYear()));
    }

</script>