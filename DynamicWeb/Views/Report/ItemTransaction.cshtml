    function ShowReport() {
        @*if (!$('#Item').val())
            alert('@MyERP.Properties.Resources.Item' + ' ' + '@MyERP.Properties.Resources.Required');
        else {*@
        if ($('#DateFrom').val() && $('#DateTo').val()) {
            window.open('/Report/ItemTransaction?itemId=' + $('#Item').val() + '&departmentId=' + $('#DepartmentId').val() + '&DateFrom=' + $('#DateFrom').val() + '&DateTo=' + $('#DateTo').val() + '&warehouseId=' + $('#WarehouseId').val() + '&itemCategoryId=' + $('#ItemCategoryId').val() + '&itemGroupId=' + $('#ItemGroupId').val() + '&docType=' + $('#DocType').val()+ '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val() + '&showReport=' + true + '&print=' + false, "blank");
        }
        else {
            alert('@MyERP.Properties.Resources.Date' + " " + '@MyERP.Properties.Resources.Required')
        }
