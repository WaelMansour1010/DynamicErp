             ViewBag.ItemCategoryId, ViewBag.ActivityId, ViewBag.CompanyId))).GetHtml()*@

    @Html.DevExpress().WebDocumentViewer(settings =>
    {
        settings.Name = "WebDocumentViewer";
    }).Bind(new DevExpress.XtraReports.Web.CachedReportSourceWeb(new ItemTransaction_Report(
                ViewBag.ItemId,
                ViewBag.DepartmentId,
                ViewBag.DateFrom,
                ViewBag.DateTo,
                ViewBag.WarehouseId,
                ViewBag.DocType,
                ViewBag.ItemGroupId,
                ViewBag.ItemCategoryId,
                ViewBag.ActivityId,
                ViewBag.CompanyId))).GetHtml()

</div>
}
else
{

    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <div class="form-horizontal needs-validation" role="form">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.ItemTransaction
                                    </h5>
                                    <div class="form-group row">
                                        <label class=" col-sm-1 control-label" for="Code">@MyERP.Properties.Resources.Item</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("Item", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                            {
                                                @class = "form-control"@*, required = "required"*@})
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>

                                        <label class=" col-sm-1 control-label" for="ArName">@MyERP.Properties.Resources.Department</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("DepartmentId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                            {
                                                @class = "form-control"@*, required = "required"*@})
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class=" col-sm-1 control-label" for="Code">@MyERP.Properties.Resources.WareHouse</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("WarehouseId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>

                                        <label class=" col-sm-1 control-label" for="ArName">@MyERP.Properties.Resources.DocumentType</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("DocType", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class=" col-sm-1 control-label" for="ItemGroupId">@MyERP.Properties.Resources.ItemGroups</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("ItemGroupId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>

                                        <label class=" col-sm-1 control-label" for="ItemCategoryId">@MyERP.Properties.Resources.ItemCategory</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("ItemCategoryId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label for="DateFrom" class="control-label col-sm-1">@MyERP.Properties.Resources.FromDate</label>
                                        <div class="col-sm-5">
                                            <input id="DateFrom" name="DateFrom" class="form-control" type="datetime-local" required />
                                        </div>
                                        <label for="DateTo" class="control-label col-sm-1">@MyERP.Properties.Resources.ToDate</label>
                                        <div class="col-sm-5">
                                            <input id="DateTo" name="DateTo" class="form-control" type="datetime-local" required />
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class=" col-sm-1 control-label">@MyERP.Properties.Resources.Activity</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("ActivityId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                        <label class=" col-sm-1 control-label">@MyERP.Properties.Resources.Company</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("CompanyId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-offset-2">
                        <button class="btn btn-success" onclick="DownloadReport()">
                            @MyERP.Properties.Resources.ShowReport
                        </button>
                        <button class="btn btn-success" onclick="ShowData()">
                            @MyERP.Properties.Resources.ShowData
                        </button>
                        <button class="btn btn-success" onclick="ShowReport()">
                            @MyERP.Properties.Resources.ShowDesign
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!--------------------------------ShowData Table --------------------------------------->
    <div class="row" id="AllTable" style="display:none">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <div class="form-horizontal needs-validation" role="form">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.ReportData
                                    </h5>

                                    <div class="table-responsive">
                                        <table class="table table-striped table-centered mb-0">
                                            <thead>
                                                <tr>
                                                    <th>
                                                        @MyERP.Properties.Resources.Date
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.DocumentType
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.DocNo
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.MainDocNo
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Qty
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Equivalent
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Price
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Unit
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.WareHouse
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Vendor/@MyERP.Properties.Resources.Customer/@MyERP.Properties.Resources.WareHouse
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.QtyAfterTransaction
                                                    </th>

                                                </tr>
                                            </thead>
                                            <tbody id="ShowDataTable">
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div style="text-align:center;margin-bottom: 50px;">
                        <div class="form-group row">
                            <div class="col-sm-6">
                                <select id="ShowByPage" class="form-control" style="width:70px;float:left;" onchange="ShowData()">
                                    <option value="100">100</option>
                                    <option value="200">200</option>
                                    <option value="300">300</option>
                                    <option value="@ViewBag.Count">@MyERP.Properties.Resources.All</option>
                                </select>
                                <span style="font-size:12px;float:right;"> @MyERP.Properties.Resources.NoOfResults: <span id="RowsCount">@ViewBag.Count</span></span>
                            </div>
                            <div class="col-sm-6">
                                <select id="pagination" class="pagination form-control col-sm-4" style="width:70px;float:left;">
                                </select>
                                <lablel class="col-sm-2"> @MyERP.Properties.Resources.PageNo: </lablel>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!--***********************************************************************************************-->
}
@*</body>
    </html>*@

