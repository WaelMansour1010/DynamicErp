    function DownloadReport() {
        if ($('#DateFrom').val() && $('#DateTo').val()) {
            window.open('/Report/ItemTransaction?itemId=' + $('#Item').val() + '&departmentId=' + $('#DepartmentId').val() + '&DateFrom=' + $('#DateFrom').val() + '&DateTo=' + $('#DateTo').val() + '&warehouseId=' + $('#WarehouseId').val() + '&itemCategoryId=' + $('#ItemCategoryId').val() + '&itemGroupId=' + $('#ItemGroupId').val() + '&docType=' + $('#DocType').val() + '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val() + '&showReport=' + false + '&print=' + true, "blank");
        }
        else {
            alert('@MyERP.Properties.Resources.Date' + " " + '@MyERP.Properties.Resources.Required')
        }
    }



    function ShowData() {

        @*if (!$('#Item').val())
            alert('@MyERP.Properties.Resources.Item' + ' ' + '@MyERP.Properties.Resources.Required');
        else {*@
        if ($('#DateFrom').val() && $('#DateTo').val()) {
            $('#ShowDataTable').empty();
            $('#preloader, #status').fadeIn();

            $.get('/Helper/GetItemTransaction?itemId=' + $('#Item').val() + '&departmentId=' + $('#DepartmentId').val() + '&DateFrom=' + $('#DateFrom').val() + '&DateTo=' + $('#DateTo').val() + '&warehouseId=' + $('#WarehouseId').val() + '&itemCategoryId=' + $('#ItemCategoryId').val() + '&itemGroupId=' + $('#ItemGroupId').val() + '&docType=' + $('#DocType').val()+ '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val() + '&pageIndex=' + pageNo + '&wantedRowsNo=' + $('#ShowByPage').val()).done(function (r) {
                $('#AllTable').show();
                for (var i = 0; i < r.length; i++) {
                    r[i].Date = r[i].Date == null ? "" : convertToJavaScriptDate(r[i].Date);
                    r[i].DocType = r[i].DocType == null ? "" : r[i].DocType;
                    r[i].DocNum = r[i].DocNum == null ? "" : r[i].DocNum;
                    r[i].SourceVoucherDocumentNumber = r[i].SourceVoucherDocumentNumber == null ? "" : r[i].SourceVoucherDocumentNumber;
                    r[i].Qty = r[i].Qty == null ? "" : r[i].Qty;
                    r[i].UnitEquivalent = r[i].UnitEquivalent == null ? "" : r[i].UnitEquivalent;
                    r[i].Price = r[i].Price == null ? "" : r[i].Price;
                    r[i].UnitName = r[i].UnitName == null ? "" : r[i].UnitName;
                    r[i].Warehouse = r[i].Warehouse == null ? "" : r[i].Warehouse;
                    r[i].VendorOrCustomer = r[i].VendorOrCustomer == null ? "" : r[i].VendorOrCustomer;
                    r[i].QtyAfterTransaction = r[i].QtyAfterTransaction == null ? "" : r[i].QtyAfterTransaction;

                    let tr = '<tr><td ><label class="control-label Date">' +
                        r[i].Date + '</label></td><td><label class="control-label DocType">' +
                        r[i].DocType + '</label></td><td><label class="control-label DocNum">' +
                        r[i].DocNum + '</label></td><td><label class="control-label SourceVoucherDocumentNumber">' +
                        r[i].SourceVoucherDocumentNumber + '</label></td><td><label class="control-label Qty">' +
                        r[i].Qty + '</label></td><td><label class="control-label UnitEquivalent">' +
                        r[i].UnitEquivalent + '</label></td><td><label class="control-label Price">' +
                        r[i].Price + '</label></td><td><label class="control-label UnitName">' +
                        r[i].UnitName + '</label></td><td><label class="control-label Warehouse">' +
                        r[i].Warehouse + '</label></td><td><label class="control-label VendorOrCustomer">' +
                        r[i].VendorOrCustomer + '</label></td><td><label class="control-label QtyAfterTransaction">' +
                        r[i].QtyAfterTransaction + '</label></td></tr>';
                    $('#ShowDataTable').append(tr);
                }
                $('#preloader, #status').fadeOut();

            });
        }
        else {
            alert('@MyERP.Properties.Resources.Date'+" "+'@MyERP.Properties.Resources.Required')
        }
        //}
    }


    function setPages() {
        var count ='@ViewBag.Count';
        for (var i = 0; i < Math.ceil(count / $('#ShowByPage').val()); i++)
   $('#pagination').append('<option onchange="pageNo=' + (i + 1) + '; paging();" id="pg' + (i + 1) + '">' + (i + 1) + '</option>');
    }

    setPages();

    $('#pg' +'@ViewBag.PageIndex').attr('selected', 'selected');



    $('#pagination').on('change', function () {
        pageNo = $('#pagination').val();
        ShowData();
    });

    function convertToJavaScriptDate(value) {
        if (value === null)
            return null;
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        return ((dt.getMonth() + 1 + "/" + dt.getDate() + "/" + dt.getFullYear()));
    }

</script>
