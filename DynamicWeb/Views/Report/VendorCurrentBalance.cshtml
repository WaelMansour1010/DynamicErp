@model VendorCurrentBalance_Report

@{
    if (ViewBag.ShowReport == true)
    {
        Layout = null;
    }
    else
    {
        Layout = "~/Views/Shared/_Layout.cshtml";
    }
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = MyERP.Properties.Resources.VendorCurrentBalance;
}

<!DOCTYPE html>

@*<html>
    <head>*@
<meta name="viewport" content="width=device-width" />
<title> @MyERP.Properties.Resources.VendorCurrentBalance </title>
@if (ViewBag.ShowReport == true)
{
    @Html.DevExpress().GetStyleSheets(
        new StyleSheet { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
        new StyleSheet { ExtensionSuite = ExtensionSuite.Editors },
        new StyleSheet { ExtensionSuite = ExtensionSuite.Report }
    )
    @Html.DevExpress().GetScripts(
        new Script { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
        new Script { ExtensionSuite = ExtensionSuite.Editors },
        new Script { ExtensionSuite = ExtensionSuite.Report }
    )
    @*</head>
        <body>*@
    <div>

        @Html.DevExpress().WebDocumentViewer(settings =>
    {
    settings.Name = "WebDocumentViewer";
    }).Bind(new DevExpress.XtraReports.Web.CachedReportSourceWeb(new VendorCurrentBalance_Report(ViewBag.Department, ViewBag.ActivityId, ViewBag.CompanyId))).GetHtml()

    </div>
    @*</body>
        </html>*@
}
else
{

    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <div class="form-horizontal needs-validation" role="form">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.VendorCurrentBalance
                                    </h5>
                                    <div class="form-group row">
                                        <label class=" col-sm-2 control-label" for="Code">@MyERP.Properties.Resources.Department</label>
                                        <div class="col-sm-4">
                                            @Html.DropDownList("DepartmentId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                            {
                                                @class = "form-control",
                                                required = "required"
                                            })
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>
                                        <label class=" col-sm-2 control-label" for="Code">@MyERP.Properties.Resources.HideZeros</label>
                                        <div class="col-sm-4">
                                            <select id="HideZeros" class="form-control">
                                                <option value="1">@MyERP.Properties.Resources.Yes</option>
                                                <option value="2">@MyERP.Properties.Resources.No</option>
                                            </select>
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class=" col-sm-2 control-label">@MyERP.Properties.Resources.Activity</label>
                                        <div class="col-sm-4">
                                            @Html.DropDownList("ActivityId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                        <label class=" col-sm-2 control-label">@MyERP.Properties.Resources.Company</label>
                                        <div class="col-sm-4">
                                            @Html.DropDownList("CompanyId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>

                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-offset-2">
                        <button class="btn btn-success" onclick="DownloadReport()">
                            @MyERP.Properties.Resources.ShowReport
                        </button>
                        <button class="btn btn-success" onclick="ShowData()">
                            @MyERP.Properties.Resources.ShowData
                        </button>
                        <button class="btn btn-success" onclick="ShowReport()">
                            @MyERP.Properties.Resources.ShowDesign
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!--------------------------------ShowData Table --------------------------------------->
    <div class="row" id="AllTable" style="display:none">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <div class="form-horizontal needs-validation" role="form">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.ReportData
                                    </h5>

                                    <div class="table-responsive">
                                        <table class="table table-striped table-centered mb-0">
                                            <thead>
                                                <tr>
                                                    <th>
                                                        @MyERP.Properties.Resources.Vendor
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.DebitBalance
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.CreditBalance
                                                    </th>

                                                </tr>
                                            </thead>
                                            <tbody id="ShowDataTable">
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-12">
                            <div class="form-group row">
                                <label for="TotalDebitBalance" class="control-label col-sm-2">@MyERP.Properties.Resources.TotalDebit</label>
                                <div class="col-sm-4">
                                    <input id="TotalDebitBalance" name="TotalDebitBalance" class="form-control" disabled />
                                </div>
                                <label for="TotalCreditBalance" class="control-label col-sm-2">@MyERP.Properties.Resources.TotalCredit</label>
                                <div class="col-sm-4">
                                    <input id="TotalCreditBalance" name="TotalCreditBalance" class="form-control" disabled />
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div style="text-align:center;margin-bottom: 50px;">
                <div class="form-group row">
                    <div class="col-sm-3">
                        <select id="ShowByPage" class="form-control" style="width:70px;float:left;" onchange="ShowData()">
                            <option value="100">100</option>
                            <option value="200">200</option>
                            <option value="300">300</option>
                            <option value="@ViewBag.Count">@MyERP.Properties.Resources.All</option>
                        </select>
                        <span style="font-size:12px;float:right;"> @MyERP.Properties.Resources.NoOfResults: <span id="RowsCount">@ViewBag.Count</span></span>
                    </div>
                    <div class="col-sm-3">
                        <select id="pagination" class="pagination form-control col-sm-4" style="width:70px;float:left;">
                        </select>
                        <lablel class="col-sm-2"> @MyERP.Properties.Resources.PageNo: </lablel>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!--***********************************************************************************************-->
}

<script>
    //$(document).ready(function () {
    //    $.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
    //        $("input[type|='datetime-local']").prop('min', r.PeriodStart).prop('max', r.PeriodEnd);
    //    });
    //});
    var pageNo = 1;
        $('#ShowByPage').val('@ViewBag.wantedRowsNo');

    function ShowReport() {
        if (!$('#DepartmentId').val())
            Swal.fire({
                title: '@MyERP.Properties.Resources.Department' + ' ' + '@MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        else {
            window.open('/Report/VendorCurrentBalance?departmentId=' + $('#DepartmentId').val() + '&DateFrom=' + $('#DateFrom').val() + '&DateTo=' + $('#DateTo').val()+ '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val() + '&showReport=' + true+'&print='+false, "blank");
        }
    }
    function DownloadReport() {
        if (!$('#DepartmentId').val())
            Swal.fire({
                title: '@MyERP.Properties.Resources.Department' + ' ' + '@MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        else {
            window.open('/Report/VendorCurrentBalance?departmentId=' + $('#DepartmentId').val() + '&DateFrom=' + $('#DateFrom').val() + '&DateTo=' + $('#DateTo').val()+ '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val() + '&showReport=' + false+'&print='+true, "blank");
        }
    }

    function ShowData() {
        var sumDebit = 0;
        var sumCredit = 0;

        if (!$('#DepartmentId').val())
        Swal.fire({
            title: '@MyERP.Properties.Resources.Department' + ' ' + '@MyERP.Properties.Resources.Required',
            text: " ",
            icon: 'info',
            showCancelButton: false,
            confirmButtonText: '@MyERP.Properties.Resources.Ok',
            confirmButtonColor: '#3085d6'
        });
        else {
            $('#ShowDataTable').empty();
            $('#preloader, #status').fadeIn();
            $.get('/Helper/GetVendorCurrentBalance?departmentId=' + $('#DepartmentId').val()+ '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val() + '&pageIndex=' + pageNo + '&wantedRowsNo=' + $('#ShowByPage').val()).done(function (r) {
                $('#AllTable').show();
                for (var i = 0; i < r.length; i++) {
                    r[i].DebitBalance = r[i].DebitBalance == null ? 0 : r[i].DebitBalance;
                    r[i].CreditBalance = r[i].CreditBalance == null ? 0 :  r[i].CreditBalance;
                    r[i].ArName = r[i].ArName == null ? "" : r[i].ArName;
                    r[i].CreditBalance = r[i].Credit > r[i].Debit ? r[i].Credit - r[i].Debit : 0;
                    r[i].DebitBalance = r[i].Debit > r[i].Credit ? r[i].Debit - r[i].Credit : 0;
                     var diff = /*Math.Abs(*/r[i].CreditBalance - r[i].DebitBalance/*)*/;
                    let tr = '<tr><td><label class="control-label ArName">' +
                        r[i].ArName + '</label></td><td><label class="control-label DebitBalance">' +
                        r[i].DebitBalance + '</label></td><td><label class="control-label CreditBalance">' +
                        r[i].CreditBalance + '</label></td></tr>';
                    if ($('#HideZeros').val() == 1 && diff == 0) { }
                    else {
                    $('#ShowDataTable').append(tr);
                    }
                    sumDebit += r[i].DebitBalance;
                    sumCredit += r[i].CreditBalance;
                }


            $('#TotalDebitBalance').val(sumDebit);
            $('#TotalCreditBalance').val(sumCredit);
            $('#preloader, #status').fadeOut();
            });
        }
    }

    function setPages() {
        var count ='@ViewBag.Count';
        for (var i = 0; i < Math.ceil(count / $('#ShowByPage').val()); i++)
   $('#pagination').append('<option onchange="pageNo=' + (i + 1) + '; paging();" id="pg' + (i + 1) + '">' + (i + 1) + '</option>');
    }

    setPages();

    $('#pg' +'@ViewBag.PageIndex').attr('selected', 'selected');

    $('#pagination').on('change', function () {
        pageNo = $('#pagination').val();
        ShowData();
    });

    function convertToJavaScriptDate(value) {
        if (value === null)
            return null;
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        return ((dt.getMonth() + 1 + "/" + dt.getDate() + "/" + dt.getFullYear()));
    }

</script>