@model MyERP.Models.RoomType

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = MyERP.Properties.Resources.RoomTypes;
}
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                @if (Model != null)
                {
                    if (Model.IsDeleted == false)
                    {
                        if (ViewBag.Previous > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.First })" class="btn btn-info">@MyERP.Properties.Resources.First</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Previous })" class=" btn btn-info">&#8250;</a>
                        }
                        if (ViewBag.Next > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Next })" class="btn btn-info">&#8249;</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Last })" class="btn btn-info">@MyERP.Properties.Resources.Last</a>
                        }
                    }
                }
                <a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
            </div>
            <h4 class="page-title">@MyERP.Properties.Resources.RoomTypes :</h4>
        </div>
    </div>
</div>
@if (Model != null)
{
    if (Model.Id > 0)
    {
        @Html.HiddenFor(model => model.Id)
    }
    @Html.HiddenFor(model => model.IsActive)
    @Html.HiddenFor(model => model.UserId)
    @Html.HiddenFor(model => model.IsDeleted)
    @Html.HiddenFor(model => model.Image)
}

<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal needs-validation" role="form">

                        <div class="card">
                            <div class="card-body">
                                <h5 class="header-title">
                                    @MyERP.Properties.Resources.MainData
                                </h5>
                                <div class="form-group row">
                                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                    @Html.AntiForgeryToken()
                                    @if (Model != null)
                                    {

                                        @Html.HiddenFor(model => model.Id)
                                        @Html.HiddenFor(model => model.IsActive)
                                        @Html.HiddenFor(model => model.UserId)
                                        @Html.HiddenFor(model => model.Image)
                                        @Html.HiddenFor(model => model.IsDeleted)
                                    }

                                    <label for="Code" class="col-sm-2 control-label">@MyERP.Properties.Resources.Code</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.Code, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.Code, @readonly = "readonly", required = "required" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.CodeRequired
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="ArName" class="col-sm-2 control-label">@MyERP.Properties.Resources.ArName</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.ArName, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.ArName, required = "required" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.ArNameRequired
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="EnName" class="col-sm-2 control-label">@MyERP.Properties.Resources.EnName</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.EnName, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.EnName } })
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="Price" class="col-sm-2 control-label">@MyERP.Properties.Resources.Price</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.Price, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.Price, required = "required", @type = "number" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group  row">
                                    <label for="TypeId" class="control-label col-sm-2">@MyERP.Properties.Resources.Type</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("TypeId", null, htmlAttributes: new { @class = "form-control" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row" style="display:none;" id="ParentIdDiv">
                                    <label for="ParentId" class="control-label col-sm-2">@MyERP.Properties.Resources.MainChalet</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("ParentId", null, htmlAttributes: new { @class = "form-control" /*, disabled = "true" */})
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>

                                <div class="form-group row">
                                    <label class="control-label col-sm-2" for="Notes">@MyERP.Properties.Resources.Notes</label>
                                    <div class="col-sm-4">
                                        <textarea id="Notes" name="Notes" class="form-control" rows="5" cols="5">@if (Model != null) { @Model.Notes; }</textarea>
                                    </div>
                                </div>
                                @* مكان الصورة *@
                                <div class="form-group row">
                                    <div id="gallery" style="width: 100%;margin: 20px;">
                                        @{ if (Model != null && Model.RoomTypeImages != null)
                                            {
                                                foreach (MyERP.Models.RoomTypeImage img in Model.RoomTypeImages)
                                                {
                                                    <img onclick="ShowModal(this)" data-toggle="modal" data-target="#ImageModal" src="@img.Image" alt="" class="img_@img.Id" style="max-width: 200px;max-height: 200px;" />
                                                    <i class="fas fa-trash-alt img_@img.Id" style="cursor:pointer;" onclick="DeleteIMG('@img.Id');$(this).prev().remove();$(this).remove();"></i>
                                                }
                                            }
                                        }
                                    </div>
                                    <input type="file" id="BrowseImage" onchange="previewFile()" value="Browse" multiple />
                                    <div style="display:none;">
                                        @Html.ListBoxFor(i => i.RoomTypeImages, new SelectList(Model == null ? new List<MyERP.Models.RoomTypeImage>() : Model.RoomTypeImages, "Id", "Image", Model == null ? null : Model.RoomTypeImages), new { @class = "form-control1", placeholder = "Item Photos" })
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-sm-offset-2">
                    @if (Model == null)
                    {
                        <button type="submit" onclick="addEdit('new')" class="btn btn-success">@MyERP.Properties.Resources.SaveAndNew</button>
                        <button class="btn btn-success" onclick="addEdit()">@MyERP.Properties.Resources.Save</button>
                        <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                    }
                    else if (Model.IsDeleted == false)
                    {

                        <button class="btn btn-success" onclick="addEdit()">
                            @MyERP.Properties.Resources.Save
                        </button>
                        <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                        <a href="javascript:void(0);" class="btn btn-danger" onclick="Delete(@Model.Id)" role="button">@MyERP.Properties.Resources.Delete</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@* ----------------------------------  image Modal ---------------------------------------------- *@
<div class="modal fade" id="ImageModal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <img id="imagepreview" src="" style="max-width: 400px;max-height: 400px;margin-left: 2%;margin-bottom: 2%;" alt="" />
            </div>
        </div>
    </div>
</div>

<script>
//--------------- Variables Declarations -------------------//
    let ParentOptions = '';
    //*********************************************************//
    $('#TypeId').on('change', function () {
        if ($('#TypeId').val() != 1) {
            $('#ParentIdDiv').show();
            GetRoomByType().then(function () {
                $("#ParentId").empty().append(ParentOptions);
            });
        }
        else {
            $('#ParentIdDiv').hide();
            $('#ParentId').val(0);
        }
    });

    function GetRoomByType() {
        ParentOptions = '';
        $('#ParentId').empty();
        return requestData('/RoomType/GetRoomByType?TypeId=' + $('#TypeId').val())
       
        // return requestData('/RoomType/GetRoomByType')
            .done(function (r) {
                for (var i = 0; i < r.length; i++) {
                    ParentOptions += '<option value="' + r[i].Id + '">' + r[i].ArName + '</option>';
                    //$('#ParentId').append($('<option>', {
                    //    value: r[i].Id,
                    //    text: r[i].ArName
                    //}));
                }
            });
       }

    //--------------- Ready Function -------------------//
    $(document).ready(function () {
        if ($('#Id').val()) {
            if ($('#TypeId').val() != 1) {
                $('#ParentIdDiv').show();
            }
        }
        else {
            setCodeNum();
        }
        $('#img').on('change', function () {

            $('#oImg').val($('#img').val());
        });

    });

    //*********************************************************//
    $(".photo").change(function () {
        $(".imgold").addClass("hidden");
    });
    function readURL(input) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = function (e) {
                $(".imgnew").removeClass("hidden");

                $('#blah')
                    .attr('src', e.target.result)
            };

            reader.readAsDataURL(input.files[0]);
        }
    }
    //---------------------------------------------------------------- images gallery  --------------------------------------------------------------//
    function DeleteIMG(url)
    {
        $("#RoomTypeImages option[value='" + url + "']").remove();
    }
    function previewFile()
    {
        var reader = new FileReader();
        reader.addEventListener("load", function () {

            $("#gallery").append('<img style="max-width: 200px;max-height: 200px;margin-left: 2%;margin-bottom: 2%;" src="' + reader.result + '" alt="" /></a><i class="fas fa-trash-alt" style="cursor:pointer;" onclick="DeleteIMG(\'' + reader.result + '\');$(this).prev().remove();$(this).remove();"></i>');
            $("#RoomTypeImages").append("<option style='float: left;' selected=selected>" + reader.result + "</option>");
        }, false);

        for (var i = 0; i < $("#BrowseImage")[0].files.length; i++) {
            if ($("#BrowseImage")[0].files[i]) {
                reader.readAsDataURL($("#BrowseImage")[0].files[i]);
            }
        }
    }
    $("#RoomTypeImages option").attr('selected', 'selected');
    $("#RoomTypeImages").hide();
    $("#GetImage").click(function () {
        $("#GetImage").fadeOut();
        $('#UploadImage').photobooth().on("image", function (event, dataUrl) {
            $("#gallery").append('<img style="max-width: 200px;max-height: 200px;margin-left: 2%;margin-bottom: 2%;" src="' + dataUrl + '" alt="" /><i class="fa fa-trash-o" style="cursor:pointer;position: absolute;" onclick="DeleteIMG("' + dataUrl + '");;$(this).prev().remove();$(this).remove();"></i>');
            $("#RoomTypeImages").append("<option style='float: left;' selected=selected>" + dataUrl + "</option>");
        });
    });
    function ShowModal(img)
    {
        let ImageSelected = $(img);
        let ImageSrc = ImageSelected[0].currentSrc;
        $('#imagepreview').attr('src', ImageSrc);
    }
    //--------------------------------------------------------------------------------------------------------------------------------------------------------------------//

    function setCodeNum() {
        var doc = $.get('/RoomType/SetCodeNum').done(function (r) {
            $('#Code').val(r);
        });
    }

    function deleteElement(e) {
        let tr = $(e).closest('tr');
        if ($(tr).index() == 0 && $(tr).closest('tbody').children('tr').length == 1)
            $(tr).find("input").val('');
        else if ($(tr).index() < $(tr).closest('tbody').children('tr').length - 1)
            e.parentNode.parentNode.parentNode.removeChild(e.parentNode.parentNode);
        else if ($(tr).index() == $(tr).closest('tbody').children('tr').length - 1) {
            $(tr).find("input").val('');
            $(tr).find('input, select').removeAttr('required');
            $(tr).find('select').empty();
        }

    }

 
   
    function addEdit(n) {
        let valid = true;
        if ($(".form-control:invalid").length > 0) {
            $('.form-horizontal').addClass('was-validated');
            $('html, body').animate({
                scrollTop: $(".form-control:invalid").eq(0).offset().top - 80
            }, 500);
            console.log($(".form-control:invalid"));
            valid = false;
        }


        var RoomTypeImages = [];
        if (valid) {
            $('#RoomTypeImages option').each(function () {
                var option = $(this);

                var RoomTypeImage =
                {
                    MainDocId: $('#Id').val(),
                    Image: option.text()
                };
                RoomTypeImages.push(RoomTypeImage);
            });
        }

        if (valid) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.AreYouSureYouWantToSave',
                text: " ",
                icon: 'info',
                showCancelButton: true,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                cancelButtonText: '@MyERP.Properties.Resources.Cancel',
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    $('#preloader, #status').fadeIn();
                    $.ajax({
                        type: "POST", contentType: "application/json",
                        url: "/RoomType/AddEdit",
                        data:
                            JSON.stringify({
                                Id: $('#Id').val(),
                                Code: $('#Code').val(),
                                ArName: $('#ArName').val(),
                                EnName: $('#EnName').val(),
                                Notes: $('#Notes').val(),
                                UserId: $('#UserId').val(),
                                Image: $('#Image').val(),
                                ParentId: $('#TypeId').val()==1?null:$('#ParentId').val(),
                                TypeId: $('#TypeId').val(),
                                Price: $('#Price').inputmask('unmaskedvalue'),
                                IsActive: true,
                                IsDeleted: false,
                                RoomTypeImages: RoomTypeImages,
                               
                            }),
                        success: function (r) {
                            if (r.success == "true") {
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.Saved',
                                    text: " ",
                                    icon: 'success',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                                $('#preloader, #status').fadeOut();
                                if (n == "new") {
                                    window.location.replace("/RoomType/AddEdit");
                                }
                                else {
                                        window.location.replace("/RoomType");
                                }
                            }
                            else {
                                $('#preloader, #status').fadeOut();
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.NotSaved !',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                            }
                        },
                        error: function (r) {
                            $('#preloader, #status').fadeOut();
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.NotSaved !',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                        }
                    });
                }
                else { result.dismiss; }
            });
        }
    }

    function Delete(id) {
        Swal.fire({
            title: '@MyERP.Properties.Resources.AreYouSureYouWantToDelete',
            text: " ",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: '@MyERP.Properties.Resources.Ok',
            cancelButtonText: '@MyERP.Properties.Resources.Cancel',
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                $('#preloader, #status').fadeIn();
                $.ajax(
                    {
                        url: '/RoomType/Delete',
                        type: 'POST',
                        data: {
                            "Id": id,
                        },
                        error: function (e) {
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.DeleteDoesNotSucceeded',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                            $('#preloader, #status').fadeOut();
                        },
                        success: function (r) {
                            if (r == 'true') {
                                window.location.replace('/RoomType');
                            } else {
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.DeleteDoesNotSucceeded',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                                $('#preloader, #status').fadeOut();
                            }
                        }
                    });
            }
            else { result.dismiss; }
        });
    }
</script>