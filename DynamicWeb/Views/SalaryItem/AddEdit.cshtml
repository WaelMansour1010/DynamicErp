        $('#SalaryItemValueCalcMethodId').change(function () {
            var getValue = $(this).val();

            if (getValue == 1) {
                $('#ValOfAll').hide();
                $('#itemTable').hide();
            }
            else if (getValue == 2) {
                $('#ValOfAll').show();
                $('#itemTable').hide();
            }
            else {
                $('#ValOfAll').hide();
                $('#itemTable').show();
            }

        })


