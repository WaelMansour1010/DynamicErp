        function Addvalue() {
            var Value = $('#Val').val();
            if ($('#Val').val() != 0 && $('#Val').val() != null && $('#Val').val() != "") {
                //Value
                $('#EquationValue').val($('#EquationValue').val() + "_" + Value );
                //Text
                $('#EquationText').val($('#EquationText').val() + "_" + Value);
                $('#Val').val('')
            }
            else {
                //Value
                $('#EquationValue').val($('#EquationValue').val());
                //Text
                $('#EquationText').val($('#EquationText').val());
            }
        }

        function ClearEquation() {
            $('#EquationValue').val('');
            $('#EquationText').val('');
