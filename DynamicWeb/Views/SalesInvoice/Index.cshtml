@model IEnumerable<MyERP.Models.SalesInvoice>
@{
    if (System.Web.Configuration.WebConfigurationManager.AppSettings["ECommerce"] == "true")
    {
        Layout = "~/Views/Shared/_EcommerceLayout.cshtml";
    }
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.SalesInvoice;
}


<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <a class="btn btn-info" href="@Url.Action("AddEdit")" role="button" style="float:left; margin-right:4px">@MyERP.Properties.Resources.AddNew</a>
            </div>
            <h4 class="page-title"> @MyERP.Properties.Resources.SalesInvoice </h4>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal" role="form">
                        <div class="form-group row">
                            <div class="col-xs-12 col-sm-6 col-lg-3">
                                <input type="text" class="form-control searchtxt" value="@Html.Raw(ViewBag.searchWord)" placeholder="@MyERP.Properties.Resources.Search">
                            </div>
                            <div class="col-xs-12 col-sm-6 col-lg-3">
                                @Html.DropDownList("DepartmentId", null, @MyERP.Properties.Resources.Department, htmlAttributes: new { @class = "form-control searchtxt" })
                            </div>
                            <div class="col-xs-12 col-sm-3 col-lg-3">
                                <button type="button" class="btn btn-success btnSearch" onclick="searchWord = $('.searchtxt').val(); paging();">
                                    <i class="fa fa-search"></i>
                                </button>
                                <a class="btn btn-info" href="@Url.Action("Index")" role="button"><i class="fe-refresh-ccw"></i></a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-12">
                    <div class="table-responsive">
                        <table class="table table-striped table-centered mb-0">
                            <thead>
                                <tr>
                                    <th>
                                        @MyERP.Properties.Resources.DocNo
                                    </th>
                                    <th>
                                        @MyERP.Properties.Resources.CustomerName
                                    </th>

                                    <th>
                                        @MyERP.Properties.Resources.Date
                                    </th>

                                    <th>
                                        @MyERP.Properties.Resources.Department
                                    </th>
                                    <th>
                                        @MyERP.Properties.Resources.WareHouse
                                    </th>
                                    <th>
                                        @MyERP.Properties.Resources.Total
                                    </th>
                                    <th>  @MyERP.Properties.Resources.PaymentMethod </th>
                                    <th>@MyERP.Properties.Resources.LinkedToPurchaseInvoice</th>
                                    <th>
                                        @if (ViewBag.InabilityToEditSalesAndPurchaseInvoicesAndReturns == true)
                                        {
                                            @MyERP.Properties.Resources.View
                                        }
                                        else
                                        {
                                            @MyERP.Properties.Resources.Edit
                                        }
                                    </th>

                                    @if (ViewBag.ShowSerialNumbers)
                                    {
                                        <th>
                                            @MyERP.Properties.Resources.SerialNumber
                                        </th>
                                    }
                                    <th>
                                        @MyERP.Properties.Resources.Delete
                                    </th>
                                    <th>@MyERP.Properties.Resources.Print</th>
                                    <th> @MyERP.Properties.Resources.PrintJournalEntry </th>
                                    <th> @MyERP.Properties.Resources.EInvoice </th>
                                    <th> @MyERP.Properties.Resources.EInvoice </th>
                                    <th> @MyERP.Properties.Resources.Send </th>

                                </tr>
                            </thead>
                            @foreach (var item in Model)
                            {
                        <tr>
                            <td>
                                @*@Html.DisplayFor(modelItem => item.DocumentNumber)*@
                                @Html.Raw(item.DocumentNumber.ToString().Replace("-", ""))
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Customer.ArName)
                            </td>

                            <td>
                                @Html.DisplayFor(modelItem => item.VoucherDate)
                            </td>

                            <td>
                                @Html.DisplayFor(modelItem => item.Department.ArName)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Warehouse.ArName)
                            </td>

                            <td>
                                @if (item.IsInstallmentPlan == true)
                                {
                                    @Html.DisplayFor(modelItem => item.TotalAfterTotalInstallment, new { @class = "money" })
                                }
                                else
                                {
                                    @Html.DisplayFor(modelItem => item.TotalAfterTaxes, new { @class = "money" })
                                }
                            </td>
                            <td>

                                @foreach (var paymentMethod in item.SalesInvoicePaymentMethods)
                                {
                                    if (paymentMethod.Amount > 0)
                                    {
                                        <label> @paymentMethod.PaymentMethod.ArName </label>
                                    }
                                }

                            </td>
                            <td>
                                @if (item.IsLinked == true)
                                {
                                    <i class="fe-check-circle"></i>
                                }
                            </td>
                            <td>
                                @if (item.IsClosed == false)
                                {
                                <a href="@Url.Action("AddEdit", "SalesInvoice", new { id = item.Id })" onclick="$('#preloader, #status').fadeIn();">
                                    @if (ViewBag.InabilityToEditSalesAndPurchaseInvoicesAndReturns == true)
                                    {
                                        <i class="fa fa-eye"></i>
                                    }
                                    else
                                    {
                                        <i class="fa fa-edit"></i>
                                    }
                                </a>
                                }
                            </td>
                            @if (ViewBag.ShowSerialNumbers)
                            {
                                <td>
                                    <a class="btn btn-success" target="_blank" href="@Url.Action("AddEditSerialNumber", "SalesInvoice", new { id = item.Id, itemId = 0 })" role="button">@MyERP.Properties.Resources.SerialNumber</a>
                                </td>
                            }
                            <td>
                                @if (item.IsClosed == false)
                                {
                                    <a href="javascript:void(0);" @((item.IsLinked == true) ? "style=color:gray;cursor:no-drop;" : "onclick=Delete(" + @item.Id + ")")>
                                        <i class="fas fa-trash-alt"></i>
                                    </a>
                                }

                            </td>
                            @if (ViewBag.PrintReceiptInsteadOfSalesInvoice == true)
                            {
                        <td>
                            @*<a href="@Url.Action("CashierInvoice2","Report",new { id=item.Id, print = true})" target="_blank">
                                <i class="remixicon-printer-fill"></i>
                            </a>*@
                            <a role="button" href="javascript:void(0);" onclick="EncodeId(@item.Id)">
                                <i class="remixicon-printer-fill"></i>
                            </a>
                        </td>
                            }
                            else if (System.Web.Configuration.WebConfigurationManager.AppSettings["ProjectName"] == "Kimo")
                            {
                                <td>
                                    <a href="@Url.Action("KimoSalesInvoice","Report",new { id=item.Id})" target="_blank">
                                        <i class="remixicon-printer-fill"></i>
                                    </a>
                                </td>
                            }
                            else
                            {
                        <td>
                            @*<a href="@Url.Action("SalesInvoice","Report",new { id=item.Id})" target="_blank">
            <i class="remixicon-printer-fill"></i>
        </a>*@
                            <a href="@Url.Action("E_Invoice","Report",new { id=item.Id, print = true})" target="_blank">
                                <i class="remixicon-printer-fill"></i>
                            </a>
                        </td>
                            }
                            <td>
                                <a href="#" onclick="printJournal(@item.Id)">
                                    <i class="remixicon-printer-fill"></i>
                                </a>
                            </td>
                            <td>
                                <a href="@Url.Action("E_Invoice","Report",new { id=item.Id, print = true})" target="_blank">
                                    <i class="remixicon-printer-fill"></i>
                                </a>
                            </td> 
                            <td>
                                <a href="@Url.Action("E_Invoice","Report",new { id=item.Id, print = false})" target="_blank">
                                    <i class="fa fa-download"></i>
                                </a>
                            </td>
                            <td>
                                <a href="https://api.whatsapp.com/send?phone=@item.Customer.Mobile&text=@ViewBag.domainName/Report/E_Invoice/@item.Id?print=True" target="_blank">
                                    <i class="fab fa-whatsapp"></i>                    
                                </a>
                            </td>
                        </tr>
                            }

                        </table>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<div style="text-align:center;margin-bottom: 50px;">

    <div class="form-group row">
        <div class="col-sm-4">
            <select id="ShowByPage" class="form-control" style="width:70px;float:left;" onchange="paging()">
                <option value="10">10</option>
                <option value="30">30</option>
                <option value="50">50</option>
                <option value="100">100</option>
                <option value="200">200</option>
                <option value="@ViewBag.Count">@MyERP.Properties.Resources.All</option>
            </select>
            <span style="font-size:12px;float:right;"> @MyERP.Properties.Resources.NoOfResults : <span id="RowsCount">@ViewBag.Count</span></span>
        </div>
        <div class="col-sm-2">
            <lablel class="col-sm-8"> @MyERP.Properties.Resources.PageNo: </lablel>
        </div>
        <div class="col-sm-2">
            <select id="pagination" class="pagination form-control" style="width:70px;float:left;">
            </select>
        </div>
    </div>
</div>

<script>
    var pageNo = 1;
    var searchWord = '@Html.Raw(ViewBag.searchWord)';

    $('#ShowByPage').val(@ViewBag.wantedRowsNo);

    function paging() {
        var link = '/SalesInvoice/Index?' + 'pageIndex=' + pageNo + '&wantedRowsNo=' + $('#ShowByPage').val() + '&searchWord=' + searchWord + '&departmentId=' + $('#DepartmentId').val();
        window.location.replace(link);
    }

    function setPages() {
        var count =@ViewBag.Count;
        for (var i = 0; i < Math.ceil(count / $('#ShowByPage').val()); i++)
            $('#pagination').append('<option onchange="pageNo=' + (i + 1) + '; paging();" id="pg' + (i + 1) + '">' + (i + 1) + '</option>');
    }

    setPages();
   $('#pg' +@ViewBag.PageIndex).attr('selected', 'selected')

    $('#pagination').on('change', function () {
        pageNo = $('#pagination').val();
         paging();
    })

    function Delete(id) {
        Swal.fire({
            title: '@MyERP.Properties.Resources.AreYouSureYouWantToDelete',
            text: " ",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: '@MyERP.Properties.Resources.Ok',
            cancelButtonText: '@MyERP.Properties.Resources.Cancel',
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                $('#preloader, #status').fadeIn();
                $.ajax(
                    {
                        url: '/SalesInvoice/Delete',
                        type: 'POST',
                        data: {
                            "Id": id,
                        },
                        error: function (e) {
                        },
                        success: function (r) {
                            if (r == 'true') {
                                window.location.reload();
                            }
                            else if (r == 'False') {
                                $('#preloader, #status').fadeOut();
                                // alert('@MyERP.Properties.Resources.DeleteDoesNotSucceededBecauseSalesInvoiceExistInCashReceiptVoucher');
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.DeleteDoesNotSucceededBecauseSalesInvoiceExistInCashReceiptVoucher',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                            }
                            else if (r == 'IsLinkedWithOrderSalesInvoice') {
                                $('#preloader, #status').fadeOut();
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.YouCantDeleteThisDocument',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                            }
                            else if (r == 'Cannot Be Deleted') {
                                $('#preloader, #status').fadeOut();
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.TheInvoiceHasBeenGeneratedAndCannotBeDeleted',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                            }
                            else {
                                // alert("@MyERP.Properties.Resources.DeleteDoesNotSucceeded");
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.DeleteDoesNotSucceeded',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                                $('#preloader, #status').fadeOut();
                            }
                        }
                    });
            }
            else { result.dismiss; }
        });

        @*if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToDelete')) {
            $('#preloader, #status').fadeIn();
            $.ajax(
                {
                    url: '/SalesInvoice/Delete',
                    type: 'POST',
                    data: {
                        "Id": id,
                    },
                    error: function (e) {
                    },
                    success: function (r) {
                        if (r == 'true') {
                            window.location.reload();
                        }
                        else if (r == 'False') {
                            $('#preloader, #status').fadeOut();
                            // alert('@MyERP.Properties.Resources.DeleteDoesNotSucceededBecauseSalesInvoiceExistInCashReceiptVoucher');
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.DeleteDoesNotSucceededBecauseSalesInvoiceExistInCashReceiptVoucher',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                        }
                        else {
                            //  alert("@MyERP.Properties.Resources.DeleteDoesNotSucceeded");
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.DeleteDoesNotSucceeded',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                            $('#preloader, #status').fadeOut();
                        }
                    }
                });
        }*@
    }

    function printJournal(InvoiceId) {
        requestData('/Helper/GetJournalEntryBySourceId?InvoiceId=' + InvoiceId).done(function (r) {
            window.open("/Report/JournalEntryDetails/" + r);
        });
    }

    function EncodeId(id, mobile) {
        $.get('/Helper/EncodeId?id=' + id).done(function (r) {
            var report = "/Report/CashierInvoice2?id=" + r + "&print=True";
            window.open(report, "_blank");
        });
    }

</script>
