                $('#SalesOrderDetails .money').inputmask({
                    alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, 'allowMinus': false, digitsOptional: false, 'placeholder': '0'
                });
            }
            else if (Path.search('StockIssueVoucher') > -1) { //Exist
                $('#StockIssueVoucherDetails').empty().append(r.view);
                $('#StockIssueVoucherDetails select').select2({
                    matcher: matchCustom
                });
                $('#StockIssueVoucherDetails .money').inputmask({
                    alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, 'allowMinus': false, digitsOptional: false, 'placeholder': '0'
                });
            }
            else {
                $('#SalesInvoiceDetails').empty().append(r.view);
                $('#SalesInvoiceDetails select').select2({
                    matcher: matchCustom
                });
                $('#SalesInvoiceDetails .money').inputmask({
                    alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, 'allowMinus': false, digitsOptional: false, 'placeholder': '0'
                });
            }



            if (window.sessionStorage.getItem("UseItemUnit") == 'true') {
                $('.UnitClass').show();
                $('.UnitEquivClass').show();
            }
            if (AllowDiscountPerItemInSalesInvoice == 'True') {
                $('.IsDiscountTrue').show();
            }
            if (UseExpiryDateForItems == 'True') {
                $('.expiry').show();
            }
            if (ShowItemWidthAndHeightAndAreaInTransactions == 'True') {
                $('.ItemArea').show();
            }
            if ($('#hasTaxes').prop('checked') == true) {
