@model IEnumerable<MyERP.Models.PurchaseRequest>
@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
}
@foreach (var item in Model)
{
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.DocumentNumber)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.VoucherDate)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Department.ArName)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.ItemGroup.ArName)
        </td>
        <td>
            <a href="@Url.Action("AddEdit","PurchaseRequest",new { id=item.Id })" target="_blank">
                <i class="fa fa-edit"></i>
            </a>
        </td>
        <td>
            <input type="checkbox" class="purchaseRequestId" value="@item.Id" doc-num="@item.DocumentNumber" />

        </td>
    </tr>

}
<script>

    function PurchaseInvoiceDetails()
    {
        $('#preloader, #status').fadeIn();
        purchaseReqeustIds = $.map($('.purchaseRequestId:checked'), function (i) { return $(i).val(); });
        var Path = window.location.pathname;
        $.ajax({
            type: "POST", contentType: "application/json",
            url: "/SalesInvoice/PurchaseInvoiceDetails",
            data:
                JSON.stringify({ purchaseReqeustIds: purchaseReqeustIds }),
            success: function (r) {
                //$('#SalesInvoiceDetails').empty().append(r.view);
                //$('#SalesInvoiceDetails select').select2({
                //    matcher: matchCustom
                //});
                //$('#SalesInvoiceDetails .money').inputmask({
                //    alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, 'allowMinus': false, digitsOptional: false, 'placeholder': '0'
                //});


                if (Path.search('SalesOrder') > -1) { //Exist
                $('#SalesOrderDetails').empty().append(r.view);
                $('#SalesOrderDetails select').select2({
                    matcher: matchCustom
                });
                $('#SalesOrderDetails .money').inputmask({
                    alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, 'allowMinus': false, digitsOptional: false, 'placeholder': '0'
                });
            }
            else if (Path.search('StockIssueVoucher') > -1) { //Exist
                $('#StockIssueVoucherDetails').empty().append(r.view);
                $('#StockIssueVoucherDetails select').select2({
                    matcher: matchCustom
                });
                $('#StockIssueVoucherDetails .money').inputmask({
                    alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, 'allowMinus': false, digitsOptional: false, 'placeholder': '0'
                });
            }
            else {
                $('#SalesInvoiceDetails').empty().append(r.view);
                $('#SalesInvoiceDetails select').select2({
                    matcher: matchCustom
                });
                $('#SalesInvoiceDetails .money').inputmask({
                    alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, 'allowMinus': false, digitsOptional: false, 'placeholder': '0'
                });
            }

                let docNums = $.map($('.purchaseRequestId:checked'), function (i) { return $(i).attr('doc-num'); });
                $('#PurchaseRequestDocNum').text('@MyERP.Properties.Resources.PurchaseRequestNo' + ': ' + docNums);

                $('#cancelPurchaseRequest').show();
                $('#VoucherDate').val(r.VoucherDate);
                $('#Id').remove();
                SystemPageId = null;
                isLinked = true;
                $('#DepartmentId')[0].value == 28;
                $('#Total').val('');
                details = [];
                $('#selectedItems').empty();
                //$('.price').each(function () {
                //    $(this).closest('tr').find('.total').val($(this).inputmask('unmaskedvalue') * $(this).closest('tr').find('.quantity').val());
                //    AddToSerialNumberTable($(this).closest('tr'));
                //});
                if (Path.search('SalesOrder') > -1 || Path.search('StockIssueVoucher') > -1) { //Exist
                    $('.price').each(function () {
                        $(this).closest('tr').find('.total').val($(this).inputmask('unmaskedvalue') * $(this).closest('tr').find('.quantity').val());
                    });
                }
                else {
                    $('.price').each(function () {
                        $(this).closest('tr').find('.total').val($(this).inputmask('unmaskedvalue') * $(this).closest('tr').find('.quantity').val());
                        AddToSerialNumberTable($(this).closest('tr'));
                    });
                }

                CalculateTotals();
                $('#preloader, #status').fadeOut();
            },
            error: function () {
                $('#preloader, #status').fadeOut();
                Swal.fire({
                    title: '@MyERP.Properties.Resources.NotLinked' + ' !',
                    text: " ",
                    icon: 'error',
                    showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    confirmButtonColor: '#3085d6'
                });
            }
        });
    }
