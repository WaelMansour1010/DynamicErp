@model MyERP.Models.Employee
@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.SalesRepresentative;
}
<script src="~/Scripts/SaveAndNew.js"></script>
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                @*@if (Model != null)
                    {
                        if (Model.IsDeleted == false)
                        {
                            if (ViewBag.Previous > 0)
                            {
                                <a href="@Url.Action("AddEdit", new { id = ViewBag.First })" class="btn btn-info">@MyERP.Properties.Resources.First</a>
                                <a href="@Url.Action("AddEdit", new { id = ViewBag.Previous })" class=" btn btn-info">&#8250;</a>
                            }
                            if (ViewBag.Next > 0)
                            {
                                <a href="@Url.Action("AddEdit", new { id = ViewBag.Next })" class="btn btn-info">&#8249;</a>
                                <a href="@Url.Action("AddEdit", new { id = ViewBag.Last })" class="btn btn-info">@MyERP.Properties.Resources.Last</a>
                            }
                            <a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                        }
                    }
                    else
                    {*@
                <a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>

                @*}*@
            </div>
            <h4 class="page-title"> @MyERP.Properties.Resources.SalesRepresentative </h4>
        </div>
    </div>
</div>


<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="form-horizontal needs-validation" role="form">
                @*<form action="/SalesRepresentative/AddEdit" class="form-horizontal needs-validation" novalidate method="post" enctype="multipart/form-data">*@
                <div class="row">
                    @Html.AntiForgeryToken()
                    @if (Model != null)
                    {
                        @Html.HiddenFor(model => model.Id)
                        @Html.HiddenFor(model => model.IsActive)
                        @Html.HiddenFor(model => model.IsDeleted)
                        @Html.HiddenFor(model => model.UserId)
                        @Html.HiddenFor(model => model.Image)
                    }
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">
                                <h5 class="header-title">
                                    @MyERP.Properties.Resources.MainData
                                </h5>
                                <br />

                                <div class="form-group row">
                                    <label class=" col-sm-2 control-label" for="ArName">@MyERP.Properties.Resources.Representative</label>
                                    <div class="col-sm-4">
                                        @if (Model == null)
                                        {
                                            @Html.DropDownListFor(model => model.RepId, null, null, htmlAttributes: new { @class = "form-control" })
                                        }
                                        else
                                        {
                                            @Html.DropDownListFor(model => model.RepId, null, null, htmlAttributes: new { @class = "form-control",@disabled="disabled" })

                                        }
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.ArName @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="col-sm-2 control-label" for="EnName">@MyERP.Properties.Resources.Department</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownListFor(model => model.DepartmentRepId, null, null, htmlAttributes: new { @class = "form-control" })
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="col-sm-2 control-label" for="EnName">@MyERP.Properties.Resources.SalesRepresentativesGroup</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownListFor(model => model.RepresentativeGroupId, null, null, htmlAttributes: new { @class = "form-control" })
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class=" col-sm-2 control-label" for="CommissionPerc">@MyERP.Properties.Resources.DiscountPercentage</label>
                                    <div class="col-sm-3">
                                        @Html.EditorFor(model => model.DiscountPercentage, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.DiscountPercentage, required = "required" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <span class="col-sm-1"> % </span>

                                </div>


                            </div>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">
                                <input id="new" name="newBtn" hidden />
                                <div style="float:left;">
                                    @if (Model == null)
                                    {
                                        <button type="submit" id="newbtn" onclick="addEdit('new')" class="btn btn-success">
                                            @MyERP.Properties.Resources.SaveAndNew
                                        </button>
                                        <button class="btn btn-success" id="save" onclick="addEdit()">
                                            @MyERP.Properties.Resources.Save
                                        </button>
                                        <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                                    }
                                    else
                                    {
                                        if (Model.IsDeleted == false)
                                        {
                                            <button class="btn btn-success" id="save" onclick="addEdit()">
                                                @MyERP.Properties.Resources.Save
                                            </button>
                                            <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                                        }
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                @*</form>*@
            </div>
        </div>
    </div>
</div>

<script>
       function addEdit(n) {
        let valid = true;
        if ($(".form-control:invalid").length > 0) {
            $('.form-horizontal').addClass('was-validated');
            $('html, body').animate({
                scrollTop: $(".form-control:invalid").eq(0).offset().top - 80
            }, 500);
            console.log($(".form-control:invalid"));
            valid = false;
        }
        if (valid) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.AreYouSureYouWantToSave',
                text: " ",
                icon: 'info',
                showCancelButton: true,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                cancelButtonText: '@MyERP.Properties.Resources.Cancel',
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    $('#preloader, #status').fadeIn();
                    $('#newbtn').prop('disabled', true);
                    $('#save').prop('disabled', true);
                    $('#saveAndPrint').prop('disabled', true);
                    $.ajax({
                        type: "POST", contentType: "application/json",
                        url: '/SalesRepresentative/AddEdit?RepId=' + $('#RepId').val() + '&Id=' + $('#Id').val()+ '&DepartmentRepId=' + $('#DepartmentRepId').val() + '&RepresentativeGroupId=' + $('#RepresentativeGroupId').val() + '&DiscountPercentage=' + $('#DiscountPercentage').inputmask('unmaskedvalue') + '&IsSalesRepresentative=' + true,
                        //data:
                        //    JSON.stringify({
                        //        Id: $('#RepId').val(),
                        //        RepId: $('#RepId').val(),
                        //        DepartmentRepId: $('#DepartmentRepId').val(),
                        //        RepresentativeGroupId: $('#RepresentativeGroupId').val(),
                        //        IsSalesRepresentative: true,
                        //        DiscountPercentage: $('#DiscountPercentage').inputmask('unmaskedvalue'),
                        //    }),
                        success: function (r) {
                            if (r.success == "true") {
                                Swal.fire(
                                    {
                                        title: '@MyERP.Properties.Resources.Saved',
                                        text: " ",
                                        icon: 'success',
                                        showCancelButton: false,
                                        confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                        confirmButtonColor: '#3085d6'
                                    });
                                $('#preloader, #status').fadeOut();
                                if (n == "new") {
                                    window.location.replace("/SalesRepresentative/AddEdit");
                                }
                                else {
                                    window.location.replace("/SalesRepresentative");
                                }
                            }
                            else if (r.success == 'Exist Before')
                            {
                                $('#preloader, #status').fadeOut();
                                $('#newbtn').prop('disabled', false);
                                $('#save').prop('disabled', false);
                                $('#saveAndPrint').prop('disabled', false);
                                 Swal.fire({
                                    title: '@MyERP.Properties.Resources.ExistsBefore',
                                    text: " ",
                                    icon: 'info',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });

                            }
                            else {
                                $('#preloader, #status').fadeOut();
                                $('#newbtn').prop('disabled', false);
                                $('#save').prop('disabled', false);
                                $('#saveAndPrint').prop('disabled', false);
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.NotSaved',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                            }
                        },
                        error: function (r) {
                            $('#preloader, #status').fadeOut();
                            $('#newbtn').prop('disabled', false);
                            $('#save').prop('disabled', false);
                            $('#saveAndPrint').prop('disabled', false);
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.NotSaved',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                        }
                    });
                }
                else { result.dismiss; }
            });
        }
        
    }

</script>


