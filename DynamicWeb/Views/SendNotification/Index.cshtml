
@{
    ViewBag.Title = "ارسال إشعارات";
}

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <a class="btn btn-info" href="@Url.Action("","Technician")" role="button" style="float:left;">رجوع</a>
            </div>
                <div class="hed page-title"> الفنيين</div>
        </div>
    </div>
</div>
<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal needs-validation" role="form">
                        <div class="card">
                            <div class="card-body">
                                <div class="form-group row">
                                    <label for="TechnicianId" class="control-label col-sm-2">الفني</label>
                                    <div class="col-sm-5">

                                        @Html.DropDownList("TechnicianId", null, "اختر", htmlAttributes: new { @class = "form-control" })
                                    </div>
                                    <label for="allTechs" class="control-label col-sm-1">الكل</label>
                                    <div class="col-sm-4">
                                        <input type="checkbox" id="allTechs" />
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="control-label col-sm-2" for="title">عنوان الرسالة</label>
                                    <div class="col-sm-5">
                                        <input type="text" class="form-control" id="title" />
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="control-label col-sm-2" for="msg">نص الرسالة</label>
                                    <div class="col-sm-5">
                                        <textarea class="form-control" id="msg" rows="5" cols="5"></textarea>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <div class="col-sm-offset-2">
                                        <button type="submit" onclick="send()" class="btn btn-success">
                                            ارسال
                                        </button>

                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
    </div>
</div>
    </div>
</div>
</div>
<script>
    function send() {
        $('#preloader, #status').fadeIn();

        $.ajax({
            type: "POST", contentType: "application/json",
            url: "/SendNotification/Send",
            data: JSON.stringify({
                techId: $('#TechnicianId').val(),
                allTechs: $('#allTechs').prop('checked'),
                title: $('#title').val(),
                msg: $('#msg').val()
            }),
            success: function (r) {
                if (r == "true") {
                    alert('تم الارسال!');
                } else {
                    alert("لم يتم الارسال!");
                }
                $('#preloader, #status').fadeOut();
            },
            error: function (r) {
                $('#preloader, #status').fadeOut();
                console.log(r.response)
                alert("لم يتم الارسال!");
            }
        });
    
    }
</script>