@{
    ViewBag.Title = "اعدادات الخدمات";
}

<div class="panel panel-widget forms-panel">
    <div class="forms">
        <div class=" form-grids form-grids-right">
            <div class="widget-shadow " data-example-id="basic-forms">
                <div class="form-title">
                    <input type="button" class="btn btn-info btnAdd" name="AddEdit" value="رجوع" onclick="back('@ViewContext.RouteData.Values["controller"].ToString()')" style="float:left;">
                    <h4> اعدادات الخدمات</h4>
                </div>
                <div class="form-body">
                    <form class="form-horizontal">

                        <div class="form-group">
                            <label for="inputtext3" class="col-sm-2 control-label"> رسوم الخدمة</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" name="txtCompanyFees" id="txtCompanyFees" placeholder="رسوم الخدمة" required>
                                <span class="Asterisks">*</span>
                            </div>

                        </div>

                        <div class="form-group">
                            <label for="inputtext3" class="col-sm-2 control-label"> الجد الادنى للطلب</label>
                            <div class="col-sm-9">
                                <input type="number" step="any" class="form-control" name="txtMinimumCharge" id="txtMinimumCharge" placeholder="الجد الادنى للطلب">
                            </div>
                        </div>

                        <div class="col-sm-offset-2">
                            <button type="button" class="btn btn-success" onclick="save()">
                                حفظ
                            </button>
                            <button type="reset" class="btn btn-danger" onclick="back('@ViewContext.RouteData.Values["controller"].ToString()')">
                                رجوع
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>

    function save() {

        CheckInputs();

        if ($("form").valid() && $('.error:visible').length == 0) {
            $('#preloader, #status').fadeIn();
            $.ajax(
                {
                    url: MainDomain + 'api/ServiceSettings/ServiceSettingsUpdateInsert',
                    type: ( 'POST'),
                    data: {

                        "CompanyFees": $('#txtCompanyFees').val(),
                        "MinimumCharge": $('#txtMinimumCharge').val(),
                    },
                    beforeSend: function (xhr) {
                        xhr.setRequestHeader('Authorization', 'Bearer ' + $("#userToken").val());
                    },
                    error: function (e) {
                        if (e) {

                            $('#preloader, #status').fadeOut();
                        } else
                            window.location = '/logout/';
                    },
                    success: function (r) {
                        back('@ViewContext.RouteData.Values["controller"].ToString()');
                    }
                });
        } else {
            CheckSave();
            $("label.error").html('يرحى ادخال هذا الحقل');
            $('html').animate({ scrollTop: $('.error:visible').offset().top - 170 }, '500', 'swing');
        }
    }

        $.ajax(
            {
                url: MainDomain + 'api/ServiceSettings/GetSettings',
                type: 'Get',
                beforeSend: function (xhr) {
                    xhr.setRequestHeader('Authorization', 'Bearer ' + $("#userToken").val());
                },
                error: function (e) {
                    console.log(e);
                    window.location = '/logout/';
                },
                success: function (r) {

                    if (r != null) {

                        $('#txtCompanyFees').val(r['CompanyFees']);
                        $('#txtMinimumCharge').val(r['MinimumCharge']);

                        FillAutoCompelete();
                    }

                    $('#preloader, #status').fadeOut();
                }
            });


</script>



