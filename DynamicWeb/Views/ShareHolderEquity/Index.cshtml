
@{
    ViewBag.Title = "حقوق المساهمين";
}
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="hed page-title">حقوق المساهمين :</div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal" role="form">
                        <div class="form-group row">
                            <label for="DepartmentId" class=" col-sm-1 control-label">الفرع </label>
                            <div class="col-xs-12 col-sm-6 col-lg-3">
                                @Html.DropDownList("DepartmentId", null, "إختر الفرع", htmlAttributes: new { @class = "form-control" })
                            </div>
                            <button class="btn btn-success" onclick="getShareholderEquity()">بحث</button>
                        </div>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-12">
                        <div class="table-responsive">
                            <table class="table table-striped table-centered mb-0">
                                <thead>
                                    <tr>
                                        <th>الكود</th>
                                        <th>الاسم عربى</th>
                                        <th>مبلغ المساهة</th>
                                        <th>النسبة</th>
                                        <th>المدفوع</th>
                                        <th>الباقي</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody id="ShareHolderEquity"></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        <div class="card-box">
            <div class="form-group row">
                <label for="totalValue" class="col-sm-2 control-label">اجمالي الحصص:</label>
                <div class="col-sm-3">
                    <input readonly id="totalValue" class="money form-control" value="0" />
                </div>
            </div>
            <div class="form-group row">
                <label for="totalPaid" class="col-sm-2 control-label">اجمالي المدفوع:</label>
                <div class="col-sm-3">
                    <input readonly id="totalPaid" class="money form-control" value="0" />
                </div>
            </div>
            <div class="form-group row">
                <label for="totalRemaining" class="col-sm-2 control-label">اجمالي الباقي:</label>
                <div class="col-sm-3">
                    <input readonly id="totalRemaining" class="money form-control" value="0" />
                </div>
            </div>
        </div>
     </div>
</div>
            <script>
                $(document).on('change', '#DepartmentId', function () {
                    getShareholderEquity();
                });

                $(document).on('change', '.Value', function () {
                    $(this).closest('tr').find('button').removeClass('disabled').removeProp('disabled');
                });

                function getShareholderEquity() {
                    $('#preloader, #status').fadeIn();
                    $.get('/ShareHolderEquity/_ShareHolderEquity?depId=' + $('#DepartmentId').val()).done(function (r) {
                        $('#ShareHolderEquity').empty();
                        $('#ShareHolderEquity').append(r);
                        $('.money').inputmask({
                            alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
                        });
                        let totalPayment = 0;
                        $('.TotalPayment').each(function () {
                            totalPayment += $(this).text() * 1;
                        });
                        let totalValue = 0;
                        $('.Value').each(function () {
                            totalValue += $(this).inputmask('unmaskedvalue') * 1;
                        });
                        let totalRemaining = 0;
                        $('#ShareHolderEquity').find('tr').each(function () {
                            let value = $(this).find('.Value').inputmask('unmaskedvalue') * 1;
                            console.log('value ' + value + ' total ' + totalValue);
                            $(this).find('.share-percentage').text(value ? (value * 100 / totalValue) : 0);
                            $(this).find('.share-remaining').text(value - $(this).find('.TotalPayment').text());
                            totalRemaining += $(this).find('.share-remaining').text() * 1;
                        });
                        $('#totalPaid').val(totalPayment);
                        $('#totalRemaining').val(totalRemaining);
                        $('#totalValue').val(totalValue);
                        $('#preloader, #status').fadeOut();
                    });
                }

                function saveShareholderEquity(e) {
                    let tr = $(e).closest('tr');
                    $.ajax({
                        type: 'POST',
                        contentType: 'application/json',
                        url: '/ShareHolderEquity/PostShareholderEquity',
                        data: JSON.stringify({
                            ShareHolderId: $(tr).find('.ShareHolderId').val(),
                            Value: $(tr).find('.Value').inputmask('unmaskedvalue') * 1,
                            DepartmentId: $('#DepartmentId').val()
                        }),
                        success: function (r) {
                            if (r == 'true') {
                                getShareholderEquity();
                            }
                        },
                        error: function () {
                            alert('لم يتم الحفظ!');
                        }
                    });
                }
            </script>
