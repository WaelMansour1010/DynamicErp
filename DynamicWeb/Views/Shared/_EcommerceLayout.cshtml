        //});
        $('.money').inputmask({
            alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, 'allowMinus': false, digitsOptional: false, 'placeholder': '0'
        });

        $("form button[type|='submit']:not(.search)").on('click', function () {
            let form = $(this).closest('form');
            if (form.find('input:invalid, select:invalid').length == 0)
                if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToSave')) {
                    return true;
                    $('#preloader, #status').fadeIn();
                } else {
                    return false;
                }
            else
                $('html, body').animate({
                    scrollTop: form.find(".form-control:invalid").eq(0).offset().top - 100
                }, 500);
        });
        $("form").submit(function () {
            $('.money').each(function () {
                var val = $(this).inputmask('unmaskedvalue');
                $(this).inputmask('remove');
                $(this).val(val);
            });

        });

        $(document).on('focus', 'input[type=number]', function (e) {
            $(this).on('mousewheel.disableScroll', function (e) {
                e.preventDefault()
            })
        });
        $(document).on('blur', 'input[type=number]', function (e) {
            $(this).off('mousewheel.disableScroll')
        });

        //mask for input type number
        $('input[type=number]').not('#IdentityNumber').not('#InstallmentPaymentCount').not('#txtPoints').not('#servicesPrice').removeProp('oninput').prop('type', 'text').inputmask({
            alias: 'numeric', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
        });
        $('input.small-number').not('#InstallmentPaymentCount').not('#txtPoints').not('#servicesPrice').removeProp('oninput').prop('type', 'text').inputmask({
            alias: 'numeric', autoGroup: true, digits: 4, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
        });
        //observe document change to apply mask for input type number
