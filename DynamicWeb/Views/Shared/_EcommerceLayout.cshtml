        //    });
        //});
        //observer.observe(document, config);

        setInterval(function () {
            getNotifications();
        }, 5000);

        function getNotifications() {
            $.get('/OccuredNotifications/Notifications').done(function (r) {
                $('#user-notifications').empty().append(r.notifications);
                if (r.count * 1 > 0)
                    $('#user-notifications').closest('li').find('.noti-icon-badge').text(r.count).show();
                $('#user-notifications').height(68 * r.count);
            });
        }
        getNotifications();

        function notificationRead(id) {
            $.post('/OccuredNotifications/NotificationRead/' + id);
            getNotifications();
        }

