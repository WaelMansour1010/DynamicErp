    <script>
         GetLogo();
         function GetLogo()
        {
            $.get('/Helper/GetLogo').done(function (r) {
                $('#SystemLogo').attr('src', r);
            });
        }

        function searchSideMenu() {
            var name = $('#side-menu-search').val();

            $('#side-menu > li > a').each(function () {
                if ($(this).text().indexOf(name.trim()) > -1) {
                    $(this).show();

                } else {
                    $(this).hide();
                }
            });
            $('#side-menu > li > ul > li >  a').each(function () {
                if ($(this).text().indexOf(name.trim()) > -1) {
                    $(this).show();
                    $(this).closest('#find > li').find('a:first').show();
                } else {
                    $(this).hide();
                }

            });
            $('#side-menu > li > ul > li > ul > li > a').each(function () {
                if ($(this).text().indexOf(name.trim()) > -1) {
                    $(this).show();
                    $(this).closest('#side-menu > li > ul > li').find('a:first').show();
                    $(this).closest('#side-menu > li').find('a:first').show();
                } else {
                    $(this).hide();
                }
            });
        }

        function matchCustom(params, data) {
            if ($.trim(params.term) === '') {
                return data;
            }

            if (typeof data.text === 'undefined') {
                return null;
            }

            var termCount = params.term.trim().split(' ').length;
            var matchCount = 0;
            for (var i = 0; i < termCount; i++) {
                var term = params.term.trim().split(' ')[i];
                for (var j = 0; j < data.text.trim().split(' ').length; j++) {
                    if (data.text.trim().split(' ')[j].toUpperCase().indexOf(term.toUpperCase()) > -1) {
                        matchCount++;
                        if (matchCount == termCount)
                            return data;
                    }
                }
            }
            return null;
        }
        $('[data-plugin="switchery"]').each(function (t, e) { new Switchery($(this)[0], $(this).data()) });
        $("select:not(#ShowByPage):not(#pagination)").select2({
            matcher: matchCustom
        });


        $('.money').inputmask({
            alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, 'allowMinus': false, digitsOptional: false, 'placeholder': '0'
        });

        $("form button[type|='submit']:not(.search)").on('click', function () {
            let form = $(this).closest('form');
            if (form.find('input:invalid, select:invalid').length == 0)
        {
                if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToSave')) {
                    return true;
                    $('#preloader, #status').fadeIn();
                } else {
                    return false;
                }
         @*Swal.fire({
            title: '@MyERP.Properties.Resources.AreYouSureYouWantToSave',
            text: " ",
            icon: 'info',
            showCancelButton: true,
            confirmButtonText: '@MyERP.Properties.Resources.Ok',
            cancelButtonText: '@MyERP.Properties.Resources.Cancel',
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                return true;
                $('#preloader, #status').fadeIn();
        form.preventDefault();
            }
            else { 
         return false;
        result.dismiss;
        }
        });*@
        }
            else
                $('html, body').animate({
                    scrollTop: form.find(".form-control:invalid").eq(0).offset().top - 100
                }, 500);
        });
        $("form").submit(function () {
            $('.money').each(function () {
                var val = $(this).inputmask('unmaskedvalue');
                $(this).inputmask('remove');
                $(this).val(val);
            });

        });

        $(document).on('focus', 'input[type=number]', function (e) {
            $(this).on('mousewheel.disableScroll', function (e) {
                e.preventDefault()
            })
        });
        $(document).on('blur', 'input[type=number]', function (e) {
            $(this).off('mousewheel.disableScroll')
        });

        //mask for input type number
        $('input[type=number]').not('#IdentityNumber').not('#InstallmentPaymentCount').not('#txtPoints').not('#servicesPrice').removeProp('oninput').prop('type', 'text').inputmask({
            alias: 'numeric', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
        });
        $('input.small-number').not('#InstallmentPaymentCount').not('#txtPoints').not('#servicesPrice').removeProp('oninput').prop('type', 'text').inputmask({
            alias: 'numeric', autoGroup: true, digits: 4, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
        });


        setInterval(function () {
            getNotifications();
        }, 5000);

        function getNotifications() {
            $.get('/OccuredNotifications/Notifications').done(function (r) {
                $('#user-notifications').empty().append(r.notifications);
                if (r.count * 1 > 0)
                    $('#user-notifications').closest('li').find('.noti-icon-badge').text(r.count).show();
                $('#user-notifications').height(68 * r.count);
            });
        }
        getNotifications();

        function notificationRead(id) {
            $.post('/OccuredNotifications/NotificationRead/' + id);
            getNotifications();
        }

        function changeLaguage() {
            requestData('/Helper/ChangeLanguage').done(function (r) {
                window.location.reload();
            });
        }


        $('.pagination').css("display", "flex");
        $('.pagination').css("flex-wrap", "wrap");
