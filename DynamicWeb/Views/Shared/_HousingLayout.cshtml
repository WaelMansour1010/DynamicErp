@{
    if (Session["lang"] == null || Session["lang"].ToString() == "ar")
    {
        Session["lang"] = "ar";
        Culture = UICulture = "ar";
    }
    else
    {
        Culture = UICulture = "ar";
    }
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";

}
