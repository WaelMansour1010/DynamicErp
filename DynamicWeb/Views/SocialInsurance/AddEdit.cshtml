@model MyERP.Models.SocialInsurance

@{
    UICulture = Session["lang"] != null?Session["lang"].ToString():"ar";

    ViewBag.Title =MyERP.Properties.Resources.RegisterProofOfInsurance;
}

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                @if (Model != null)
                {
                    if (Model.IsDeleted == false)
                    {
                        if (ViewBag.Previous > 0)
                        {
                <a href="@Url.Action("AddEdit", new { id = ViewBag.First })" class="btn btn-info">@MyERP.Properties.Resources.First</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Previous })" class=" btn btn-info">&#8250;</a>
                        }
                        if (ViewBag.Next > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Next })" class="btn btn-info">&#8249;</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Last })" class="btn btn-info">@MyERP.Properties.Resources.Last</a>
                        }
                    }
                }
                <a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
            </div>
            <h4 class="page-title"> @MyERP.Properties.Resources.RegisterProofOfInsurance:</h4>
        </div>
    </div>
</div>

@if (Model != null)
{
    if (Model.Id > 0)
    {
        @Html.HiddenFor(model => model.Id)
    }
    @Html.HiddenFor(model => model.IsDeleted)
    @Html.HiddenFor(model => model.IsPosted)

}



<div class="row">
    <div class="col-12">
        <div class="card-box">

            <div class="row">
                <div class="col-12">
                    @* <form action="/SocialInsurance/AddEdit" class="form-horizontal needs-validation" novalidate method="post">*@

                    <div class="form-horizontal needs-validation" role="form">

                        <div class="card">
                            <div class="card-body">

                                <div class="form-group row">
                                    <label class=" col-sm-2 control-label" for="DocumentNumber">@MyERP.Properties.Resources.DocNo</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.DocumentNumber, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly", placeholder = @MyERP.Properties.Resources.DocNo, required = "required", hidden = "hidden" } })
                                        <input id="DocumentNumbers" class="form-control" placeholder=@MyERP.Properties.Resources.DocNo required readonly />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>

                                    <label for="Date" class="control-label col-sm-2">@MyERP.Properties.Resources.Date </label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(a => a.Date, new { htmlAttributes = new { @class = "form-control", required = "required", type = "datetime-local" } })
                                        @*<input id="VoucherDate" name="VoucherDate" class="form-control" type="datetime-local" value="@ViewBag.VoucherDate" required />*@
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.EnterDate
                                        </div>
                                    </div>
                                </div>

                                <div class="form-group row">
                                    <label for="Month" class="col-sm-2 control-label">@MyERP.Properties.Resources.Month</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownListFor(a => a.Month, null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", @required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>

                                    <label for="Year" class="col-sm-2 control-label">@MyERP.Properties.Resources.Year</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownListFor(a => a.Year, null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", @required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>

                                <div class="form-group row">
                                    <label for="DepartmentId" class="col-sm-2 control-label">@MyERP.Properties.Resources.BranchOfTransaction</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownListFor(a => a.DepartmentId, null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", @required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-12">
                                        <div class="card">

                                            <div class="card-body">
                                                <div class="form-group row" id="selectDept">
                                                    <label for="EmployeeDepartmentId" class="col-sm-2 control-label">@MyERP.Properties.Resources.EmployeeDepartment</label>
                                                    <div class="col-sm-4">
                                                        @Html.DropDownListFor(a => a.EmployeeDepartmentId, null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                                        {
                                                            @class = "form-control"@*, id = "SelectOneDept"*@})
                                                    </div>

                                                    @*<div style="float:right;">
            <button type="button" id="show" class="btn btn-info" onclick="ShowDetails()">
                عرض
            </button>
        </div>*@
                                                </div>
                                            </div>

                                            <div class="row">
                                                <div class="col-12">
                                                    <div class="table-responsive">
                                                        <table class="table table-striped table-centered mb-0">
                                                            <thead>
                                                                <tr>
                                                                    <th hidden></th>
                                                                    <th>
                                                                        @MyERP.Properties.Resources.Branch
                                                                    </th>

                                                                    <th>
                                                                        @MyERP.Properties.Resources.EmployeeCode
                                                                    </th>

                                                                    <th>
                                                                        @MyERP.Properties.Resources.EmployeeName
                                                                    </th>
                                                                    <th>
                                                                        @MyERP.Properties.Resources.Nationality
                                                                    </th>
                                                                    <th>
                                                                        @MyERP.Properties.Resources.WorkingFirstDate
                                                                    </th>
                                                                    <th>
                                                                        @MyERP.Properties.Resources.NoOfWorkingDays
                                                                    </th>
                                                                    <th>
                                                                        @MyERP.Properties.Resources.Citizen/@MyERP.Properties.Resources.Resident
                                                                    </th>
                                                                    <th>
                                                                        @MyERP.Properties.Resources.CompanyRatio
                                                                    </th>
                                                                    <th>
                                                                        @MyERP.Properties.Resources.EmployeePercentage
                                                                    </th>
                                                                    <th>
                                                                        @MyERP.Properties.Resources.TotalSalarySubjectToInsurance
                                                                    </th>
                                                                    <th>
                                                                        @MyERP.Properties.Resources.NetSalarySubjectToInsurance
                                                                    </th>
                                                                    <th>
                                                                        @MyERP.Properties.Resources.CompanyAmount
                                                                    </th>
                                                                    <th>
                                                                        @MyERP.Properties.Resources.EmployeeAmount
                                                                    </th>


                                                                </tr>
                                                            </thead>
                                                            <tbody id="Detail">
