@model MyERP.Models.StockIssueVoucher

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";

    if (ViewBag.Type == 1 || (Model != null && Model.TypeId == 1))
    {
        ViewBag.Title = MyERP.Properties.Resources.WarehouseExchangeVouchers;

    }
    else if (ViewBag.Type == 2 || (Model != null && Model.TypeId == 2))
    {
        ViewBag.Title = MyERP.Properties.Resources.CorruptedVouchers;
    }
    else if (ViewBag.Type == 3 || (Model != null && Model.TypeId == 3))
    {
        ViewBag.Title = MyERP.Properties.Resources.LostVouchers;
    }
}
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                @if (Model != null)
                {
                    if (Model.IsDeleted == false)
                    {
                        if (ViewBag.Previous > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.First })" class="btn btn-info">@MyERP.Properties.Resources.First</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Previous })" class=" btn btn-info">&#8250;</a>
                        }
                        if (ViewBag.Next > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Next })" class="btn btn-info">&#8249;</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Last })" class="btn btn-info">@MyERP.Properties.Resources.Last</a>
                        }
                    }
                }
                <a class="btn btn-info" href="@Url.Action("Index",new { type=Model==null?ViewBag.Type:Model.TypeId})" role="button">@MyERP.Properties.Resources.Back</a>
            </div>
            <h4 class="page-title">@ViewBag.Title:</h4>
        </div>
    </div>
</div>
@if (Model != null)
{
    @Html.HiddenFor(model => model.Id)
    @Html.HiddenFor(model => model.IsActive)
    @Html.HiddenFor(model => model.UserId)
    @Html.HiddenFor(model => model.IsLinked)
    @Html.HiddenFor(model => model.IsPosted)
    @Html.HiddenFor(model => model.IsDeleted)
    @Html.HiddenFor(model => model.IsAccepted)
    @Html.HiddenFor(model => model.IsCompleted)
    @Html.HiddenFor(model => model.Image)
    @Html.HiddenFor(model => model.AutoCreated)
    @Html.HiddenFor(model => model.TypeId)
}
else
{
    <input id="TypeId" type="hidden" value="@ViewBag.Type" />
}
<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal needs-validation" role="form">
                        <div class="card">
                            <div class="card-body">
                                <h5 class="header-title">
                                    @MyERP.Properties.Resources.MainData
                                </h5>
                                <div class="form-group row">
                                    <label class=" col-sm-1 control-label" for="DocumentNumber">@MyERP.Properties.Resources.DocNo</label>
                                    <div class="col-sm-5">
                                        @Html.EditorFor(model => model.DocumentNumber, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly", placeholder = @MyERP.Properties.Resources.DocNo, required = "required", hidden = "hidden" } })
                                        <input id="DocumentNumbers" class="form-control" placeholder=@MyERP.Properties.Resources.Code required readonly />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label for="VoucherDate" class="control-label col-sm-1">@MyERP.Properties.Resources.InvoiceDate</label>
                                    <div class="col-sm-5">
                                        <input id="VoucherDate" name="VoucherDate" class="form-control" type="datetime-local" value="@ViewBag.VoucherDate" required />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.EnterDate
                                        </div>
                                    </div>
                                </div>

                                <div class="form-group row">
                                    <label for="DepartmentId" class="col-sm-1 control-label">@MyERP.Properties.Resources.Branch</label>
                                    <div class="col-sm-5">
                                        @Html.DropDownList("DepartmentId", null, null, htmlAttributes: new { @class = "form-control", required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Select
                                        </div>
                                    </div>

                                    <label for="WarehouseId" class="col-sm-1 control-label">@MyERP.Properties.Resources.WareHouse</label>
                                    <div class="col-sm-5">
                                        @Html.DropDownList("WarehouseId", null, null, htmlAttributes: new { @class = "form-control", required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Select
                                        </div>
                                    </div>
                                </div>

                                @if (Model != null && Model.Id > 0 && Model.AutoCreated == true)
                                {
                                    <div class="form-group row">
                                        <label class="control-label col-sm-1" for="SystemPage">@MyERP.Properties.Resources.MainDoc</label>
                                        <div class="col-sm-5">
                                            <input id="SystemPage" class="form-control" type="text" readonly value="@ViewBag.SystemPage" />
                                        </div>
                                        <label class="control-label col-sm-1" for="SelectedId">@MyERP.Properties.Resources.MainDocNo</label>
                                        <div class="col-sm-5">
                                            <input id="SelectedId" class="form-control" type="text" readonly value="@Model.SelectedId" />
                                        </div>
                                    </div>
                                }
                                <div class="form-group row">
                                    <label class="control-label col-sm-1" for="Notes">@MyERP.Properties.Resources.Notes</label>
                                    <div class="col-sm-5">
                                        <textarea id="Notes" name="Notes" class="form-control" rows="5" cols="5">@if (Model != null) { @Model.Notes; }</textarea>
                                    </div>

                                    <div class="col-sm-6">
                                        <button class="btn btn-primary" data-toggle="modal" data-target="#LinkWithOtherDocModal"> @MyERP.Properties.Resources.LinkWithOtherDoc </button>
                                        <label id="SalesInvoiceDocNum">
                                            @if (Model != null && Model.SystemPageId.HasValue && Model.SelectedId.HasValue)
                                            {
                                                @Html.Raw(@MyERP.Properties.Resources.DocNo + " : " + ViewBag.SalesInoiveDocNum)
                                            }
                                        </label>
                                        <button id="cancelSalesInvoice" onclick="cancelSalesInvoice()" class="btn btn-icon waves-effect waves-light btn-danger btn-xs" style="display:none;"> <i class="fas fa-times"></i> </button>
                                        <label id="PurchaseRequestDocNum"></label>
                                        <button id="cancelPurchaseRequest" onclick="cancelPurchaseRequest()" class="btn btn-icon waves-effect waves-light btn-danger btn-xs" style="display:none;"> <i class="fas fa-times"></i> </button>

                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @Html.Partial("ItemSearch")

            <!-- Patch Modal-->
            <div id="patchModal" class="modal fade bs-example-modal-lg" tabindex="-1" role="dialog" aria-labelledby="myLargeModalLabel" data-backdrop="false" style="background-color: rgba(0, 0, 0, 0.5);">
                <div class="modal-dialog modal-lg" role="document">
                    <div class="modal-content">
                        <div class="modal-header">
                            <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                        </div>
                        <div class="modal-body">

                            <div class="row">
                                <div class="col-sm-12">
                                    <table class="table table-condensed">
                                        <thead>
                                            <tr>
                                                <th>@MyERP.Properties.Resources.PatchCode</th>
                                                <th>@MyERP.Properties.Resources.ExpirationDate</th>
                                                <th>@MyERP.Properties.Resources.Qty</th>
                                                <th>@MyERP.Properties.Resources.Add</th>
                                            </tr>
                                        </thead>
                                        <tbody id="item-patches"></tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-default" onclick=" $('.bs-example-modal-lg').modal('hide');" data-dismiss="modal">@MyERP.Properties.Resources.Close</button>
                        </div>
                    </div>

                </div>
            </div>
            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="header-title">@MyERP.Properties.Resources.Details</h5>
                            <div class="form-horizontal needs-validation" role="form">
                                <div class="table-responsive">
                                    <table class="table table-centered mb-0">
                                        <thead>
                                            <tr>
                                                <th>@MyERP.Properties.Resources.Barcode</th>
                                                <th>@MyERP.Properties.Resources.Item</th>
                                                <th class="expiry" style="display:none;"> @MyERP.Properties.Resources.ExpirationDate </th>
                                                <th>@MyERP.Properties.Resources.Qty</th>
                                                <th class="UnitClass" style="display:none;">@MyERP.Properties.Resources.Unit</th>
                                                <th class="UnitEquivClass" style="display:none;">@MyERP.Properties.Resources.Equivalent</th>
                                                @if ((bool)ViewBag.ShowCost)
                                                {
                                                    <th>@MyERP.Properties.Resources.DefaultUnitCost</th>
                                                    <th>@MyERP.Properties.Resources.Total</th>
                                                }
                                                <th>@MyERP.Properties.Resources.CurrentQtyOfDefaultUnit</th>
                                                <th>@MyERP.Properties.Resources.Details</th>
                                                <th>@MyERP.Properties.Resources.Delete</th>
                                            </tr>
                                        </thead>
                                        <tbody id="StockIssueVoucherDetails">

                                            @if (Model != null)
                                            {
                                                foreach (var item in Model.StockIssueVoucherDetails)
                                                {
                                                    <tr>
                                                        <td class="tabledit-edit-mode"><input class="barcode form-control tabledit-input form-control-sm" value="@Html.Raw(item.ItemPrice==null?"":item.ItemPrice.Barcode)" /></td>
                                                        <td class="tabledit-edit-mode">
                                                            <input type="hidden" class="item form-control tabledit-input form-control-sm" value="@item.ItemPriceId" required />
                                                            <input type="text" class="item-name form-control tabledit-input form-control-sm" value="@item.Item.ArName - @item.ItemPrice.Barcode" required hidden />
                                                            @if (Session["lang"].ToString() == "en" && item.Item.EnName != null)
                                                            {
                                                                <label style="width:200px" class="name control-label tabledit-input ">@item.Item.EnName - @item.ItemPrice.Barcode</label>
                                                            }
                                                            else
                                                            {
                                                                <label style="width:200px" class="name control-label tabledit-input ">@item.Item.ArName - @item.ItemPrice.Barcode</label>
                                                            }
                                                            @if (Session["lang"].ToString() == "en" && item.ItemUnit.EnName != null)
                                                            {
                                                                <input hidden class="itemUnitArName" value=@item.ItemUnit.EnName />
                                                            }
                                                            else
                                                            {
                                                                <input hidden class="itemUnitArName" value=@item.ItemUnit.ArName />
                                                            }
                                                        </td>
                                                        <td class="tabledit-edit-mode expiry" style="display:none;">
                                                            @if (item.ExpireDate.HasValue)
                                                            {
                                                                <input class="ExpiryDate form-control tabledit-input form-control-sm" readonly value="@item.ExpireDate.Value.ToString("MM/dd/yyyy")" />
                                                            }
                                                            else
                                                            {
                                                                <input class="ExpiryDate form-control tabledit-input form-control-sm" readonly />
                                                            }
                                                            <input class="PatchId form-control tabledit-input form-control-sm" hidden value="@item.PatchId" />
                                                            <input class="itemId form-control tabledit-input form-control-sm" hidden value="@item.ItemId" />

                                                        </td>
                                                        <td class="tabledit-edit-mode"><input class="quantity form-control tabledit-input form-control-sm" type="number" step="any" value="@item.Qty" required /></td>
                                                        <td class="tabledit-edit-mode UnitClass" style="display:none;">
                                                            <select class="item-unit form-control tabledit-input form-control-sm" required disabled>
                                                                @if (Session["lang"].ToString() == "en" && item.ItemUnit.EnName != null)
                                                                {
                                                                    <option value="@item.ItemUnitId">@item.ItemUnit.EnName</option>
                                                                }
                                                                else
                                                                {
                                                                    <option value="@item.ItemUnitId">@item.ItemUnit.ArName</option>
                                                                }
                                                            </select>
                                                        </td>
                                                        <td class="tabledit-edit-mode UnitEquivClass" style="display:none;"><input class="unit-equavalent form-control tabledit-input form-control-sm small-number" type="number" step="any" value="@item.UnitEquivalent" required /></td>
                                                        @if ((bool)ViewBag.ShowCost)
                                                        {
                                                            <td class="tabledit-edit-mode"><input type="text" class="money cost form-control tabledit-input form-control-sm" disabled="disabled" value="@item.CostPrice" required /></td>
                                                            <td class="tabledit-edit-mode"><input class="total money form-control tabledit-input form-control-sm" type="text" readonly value="0" required /></td>
                                                        }
                                                        <td class="tabledit-edit-mode"><input type="number" step="any" class="quantityOnSystem form-control tabledit-input form-control-sm" readonly /></td>
                                                        <td><button class="btn btn-info" data-toggle="modal" data-target="#itemDetails" onclick="showItemDetials(this)">@MyERP.Properties.Resources.Details</button></td>
                                                        <td>
                                                            <a href="javascript:void(0);" onclick="deleteElement(this)">
                                                                <i class="fas fa-trash-alt"></i>
                                                            </a>
                                                        </td>
                                                    </tr>
                                                }
                                            }

                                            <tr>
                                                <td class="tabledit-edit-mode"><input class="barcode form-control tabledit-input form-control-sm" /></td>
                                                <td onclick="showSearchModal()" class="tabledit-edit-mode popupCell">
                                                    <input type="hidden" class="item form-control tabledit-input form-control-sm" @Html.Raw(Model != null ? "" : "required ") />
                                                    <input type="text" class="item-name form-control tabledit-input form-control-sm" @Html.Raw(Model != null ? "" : "required ") hidden />
                                                    <span class="Add-Button" style="font-size: 25px; color: limegreen;margin-right:50%;" @*data-toggle="modal" data-target=".bs-example-modal-lg"*@><i class="fas fa-plus"></i></span>
                                                    <label style="width:200px" class="name control-label tabledit-input"></label>
                                                </td>

                                                <td class="tabledit-edit-mode expiry" style="display:none;">
                                                    <input class="ExpiryDate form-control tabledit-input form-control-sm" readonly />
                                                    <input class="PatchId form-control tabledit-input form-control-sm" hidden />
                                                    <input class="itemId form-control tabledit-input form-control-sm" hidden />

                                                </td>
                                                <td class="tabledit-edit-mode"><input class="quantity form-control tabledit-input form-control-sm" type="number" step="any" min="1" @Html.Raw(Model != null ? "" : "required ") /></td>
                                                <td class="tabledit-edit-mode UnitClass" style="display:none;"><select class="item-unit form-control tabledit-input form-control-sm" @Html.Raw(Model != null ? "" : "required ") disabled></select></td>
                                                <td class="tabledit-edit-mode UnitEquivClass" style="display:none;"><input class="unit-equavalent form-control tabledit-input form-control-sm small-number" type="number" step="any" @Html.Raw(Model != null ? "" : "required ") /></td>
                                                @if ((bool)ViewBag.ShowCost)
                                                {
                                                    <td class="tabledit-edit-mode"><input type="text" class="money cost form-control tabledit-input form-control-sm" disabled="disabled" @Html.Raw(Model != null ? "" : "required ") /></td>
                                                    <td class="tabledit-edit-mode"><input class="total money form-control tabledit-input form-control-sm" type="text" readonly value="0" @Html.Raw(Model != null ? "" : "required ") /></td>
                                                }
                                                <td class="tabledit-edit-mode"><input type="number" step="any" class="quantityOnSystem form-control tabledit-input form-control-sm" readonly /></td>
                                                <td><button class="btn btn-info" data-toggle="modal" data-target="#itemDetails" onclick="showItemDetials(this)">@MyERP.Properties.Resources.Details</button></td>
                                                <td>
                                                    <a href="javascript:void(0);" onclick="deleteElement(this)">
                                                        <i class="fas fa-trash-alt"></i>
                                                    </a>
                                                </td>
                                            </tr>

                                        </tbody>
                                    </table>
                                </div>
                                @if ((bool)ViewBag.ShowCost)
                                {
                                    <div class="form-group row">
                                        <label for="TotalCostPrice" class="control-label col-sm-1">
                                            @MyERP.Properties.Resources.TotalCost
                                        </label>
                                        <div class="col-sm-3">
                                            @Html.EditorFor(model => model.TotalCostPrice, new { htmlAttributes = new { @class = "form-control money", placeholder = @MyERP.Properties.Resources.TotalCost, @readonly = "readonly" } })
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>


            @Html.Partial("_LinkWithDocModal")


            <div class="row">
                <div class="col-sm-offset-2">
                    @if (Model == null)
                    {
                        <button type="submit" onclick="addEdit('report')" class="btn btn-success">
                            @MyERP.Properties.Resources.SaveAndPrint
                        </button>
                        <button type="submit" id="newbtn" onclick="addEdit('new')" class="btn btn-success">
                            @MyERP.Properties.Resources.SaveAndNew
                        </button>
                        <button class="btn btn-success" id="save" onclick="addEdit()">
                            @MyERP.Properties.Resources.Save
                        </button>

                        <a class="btn btn-danger" href="@Url.Action("Index",new { type=Model == null ? ViewBag.Type : Model.TypeId })" role="button">@MyERP.Properties.Resources.Back</a>
                    }
                    else
                    {
                        if (Model.IsDeleted == false)
                        {
                            <button type="submit" onclick="addEdit('report')" class="btn btn-success">
                                @MyERP.Properties.Resources.SaveAndPrint

                            </button>
                            <button class="btn btn-success" id="save" onclick="addEdit()">
                                @MyERP.Properties.Resources.Save

                            </button>
                            <a class="btn btn-success" href="@Url.Action("StockIssueVoucher","Report",new { id=Model.Id})" role="button">
                                @MyERP.Properties.Resources.Print
                            </a>
                            <a class="btn btn-danger" href="@Url.Action("Index",new { type=Model == null ? ViewBag.Type : Model.TypeId })" role="button">
                                @MyERP.Properties.Resources.Back
                            </a>

                            if (Model.AutoCreated != true)
                            {
                                <button class="btn btn-danger" onclick="Delete(@Model.Id,'StockIssueVoucher')">
                                    @MyERP.Properties.Resources.Delete
                                </button>
                            }
                        }
                    }
                </div>

            </div>
        </div>
    </div>
</div>

@if (Model != null)
{
    if (@ViewBag.JE != null)
    {
        <div class="card">
            <div class="card-body">
                <h5 class="header-title">@MyERP.Properties.Resources.JournalEntrie</h5>
                <div class="form-horizontal">
                    <div class="form-group row">
                        <label for="inputtext3" class="col-sm-1 control-label">@MyERP.Properties.Resources.JournalEntrieNo</label>
                        <div class="col-sm-5">
                            <input type="text" class="form-control" name="txtDocNo" value="@ViewBag.JE.DocumentNumber" id="txtDocNo" placeholder=@MyERP.Properties.Resources.JournalEntrieNo disabled>

                        </div>
                        <label for="inputtext3" class="col-sm-1 control-label">@MyERP.Properties.Resources.Date </label>
                        <div class="col-sm-5">
                            <input type="datetime-local" class="form-control" name="dtDate" value="@ViewBag.VoucherDate" id="dtDate" placeholder=@MyERP.Properties.Resources.ReleaseDate disabled required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="inputtext3" class="col-sm-1 control-label">@MyERP.Properties.Resources.Branch</label>
                        <div class="col-sm-5">
                            @Html.DropDownList("DepartmentId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", id = "", @required = "required", @disabled = "disabled" })
                        </div>

                    </div>
                    <div class="form-group row">
                        <label for="inputtext3" class="col-sm-1 control-label">@MyERP.Properties.Resources.Notes</label>
                        <div class="col-sm-11">
                            <textarea type="text" class="form-control validate[required]" id="txtNotes" value="@ViewBag.JE.Notes" name="txtNotes" disabled placeholder=@MyERP.Properties.Resources.Notes></textarea>
                        </div>
                        <label for="inputtext3" class="col-sm-1 control-label">@MyERP.Properties.Resources.Deported</label>
                        <div class="col-sm-5">
                            @if (Model.IsPosted == true)
                            {
                                <input type="checkbox" class="form-control" id="chkIsPosted" name="chkIsPosted" style="width:15px;" checked>
                            }
                            else
                            {
                                <input type="checkbox" class="form-control" id="chkIsPosted" disabled name="chkIsPosted" style="width:15px;">
                            }
                        </div>
                    </div>
                </div>
                <div class="card">
                    <div class="card-body">
                        <h5 class="header-title"> @MyERP.Properties.Resources.JournalEntryDetails</h5>
                        <div class="table-responsive">
                            <table class="table table-centered mb-0">
                                <thead>
                                    <tr>
                                        <th>@MyERP.Properties.Resources.Debit</th>
                                        <th>@MyERP.Properties.Resources.Credit</th>
                                        <th>@MyERP.Properties.Resources.Account</th>
                                    </tr>
                                </thead>
                                @if (Model.Id != 0)
                                {
                                    //string color = "#CCEEFF";
                                    foreach (var jED in ViewBag.JEDetails)
                                    {
                                        <tr class="f">
                                            <td>
                                                <label class="money cr">@jED.Debit</label>
                                                <input type='text' class='txtDebit' value="@jED.Debit" hidden>
                                            </td>
                                            <td>

                                                <label class="money cr">@jED.Credit</label>
                                                <input type='text' class='txtCredit' value="@jED.Credit" hidden>
                                            </td>
                                            <td>
                                                @if (jED.AccountId != null)
                                                {
                                                    if (Session["lang"].ToString() == "en" && jED.ChartOfAccount.EnName != null)
                                                    {<label>@jED.ChartOfAccount.EnName </label>
                                                }
                                                else
                                                {
                                                    <label>@jED.ChartOfAccount.ArName</label>
                                                }
                                                <input type='number' class='AccountId' value="@jED.AccountId" hidden>
                                            }
                                            </td>
                                        </tr>
                                    }
                                }
                            </table>
                        </div>
                    </div>
                </div>
                <div class="form-group ">
                    <div class="col-sm-3">
                        <label for="inputtext3" class="col-sm-6 control-label">@MyERP.Properties.Resources.TotalDebit</label>
                        <input type='text' class='TotalDebit col-sm-6' disabled>
                    </div>
                    <div class="col-sm-3">
                        <label for="inputtext3" class="col-sm-6 control-label">@MyERP.Properties.Resources.TotalCredit</label>

                        <input type='text' class='TotalCredit col-sm-6' disabled>

                    </div>
                </div>
            </div>
        </div>
    }
}
<div id="itemDetails" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" style="display: none;" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title" id="myModalLabel">@MyERP.Properties.Resources.ItemDetails</h4>
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">×</button>
            </div>
            <div class="modal-body" id="itemDetailsBody">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light waves-effect" data-dismiss="modal">@MyERP.Properties.Resources.Close</button>
            </div>
        </div><!-- /.modal-content -->
    </div><!-- /.modal-dialog -->
</div>

<script>

    let UseExpiryDateForItems = '@ViewBag.UseExpiryDateForItems';
    var selectedItemRowToEdit; // for expire date

    var isBarcodeScanned = false; // For barcode scanner
    var barcodeScannerCode = ""; // For barcode scanner


    $(document).ready(function () {
        $.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
            $("input[type|='datetime-local']").prop('min', r.PeriodStart).prop('max', r.PeriodEnd);
        });
       // getItems();
        if ($('#Id').val()) {
            var code = $('#DocumentNumber').val();
            $('#DocumentNumbers').val(code.replaceAll("-", ""))
            $("#DepartmentId").prop('disabled', true);
            $("#VoucherDate").prop('disabled', true);
