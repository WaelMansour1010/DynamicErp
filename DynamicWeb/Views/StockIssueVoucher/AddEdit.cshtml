    function addToStockIssueVoucherDetails() {
                let ShowCost = '@((bool)ViewBag.ShowCost)' == 'True';

        if ($('.item-name').last().val())
            $('#StockIssueVoucherDetails').find('.item, .item-name, .item-unit, .quantity, .unit-equavalent, .cost').prop('required', 'required')

        if ($('#StockIssueVoucherDetails .form-control:invalid').length > 0) {
            $('#StockIssueVoucherDetails').closest('.form-horizontal').addClass('was-validated');
            $('html, body').animate({
                scrollTop: $("#StockIssueVoucherDetails").find(".form-control:invalid").eq(0).offset().top - 80
            }, 500);
        } else if ($('.item-name').last().val() && $('.quantity').last().val()) {
