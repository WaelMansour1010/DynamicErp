' + '@MyERP.Properties.Resources.Details' + '</button></td><td><a href="javascript:void(0);" onclick="deleteElement(this)"><i class="fas fa-trash-alt"></i></a></td></tr>';

            $('#StockIssueVoucherDetails').append(tr);

            // Expire date
            if (UseExpiryDateForItems == 'True') {
                $('.expiry').show();
