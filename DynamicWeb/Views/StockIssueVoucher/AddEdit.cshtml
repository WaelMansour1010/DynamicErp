                                    });
                                    $.ajax({
                                        type: "POST", contentType: "application/json",
                                        url: "/Helper/UpdateItemQuantities",
                                        data:
                                            JSON.stringify({
                                                itemIds: itemIds,
                                                date: new Date()
                                            }),
                                        success: function (r) { }
                                    });
                                    console.log(r.id);
                                    $('#preloader, #status').fadeOut();
                                    if (n == "new") {
                                        window.location.replace("/StockIssueVoucher/AddEdit");
                                    } else if (n == "report") {
                                        window.open("/Report/StockIssueVoucher?print=true&showReport=true&id=" + r.id);
                                        window.location.replace("/StockIssueVoucher/Index?type=" + $('#TypeId').val());
                                    }
                                    else {
                                        window.location.replace("/StockIssueVoucher/Index?type=" + $('#TypeId').val());
                                    }
                                }
                            },
                            error: function (r) {
                                $('#preloader, #status').fadeOut();
                                $('#newbtn').prop('disabled', false);
                                $('#save').prop('disabled', false);
                               // alert("@MyERP.Properties.Resources.NotSaved" + "!");
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.NotSaved',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                            }
                        });
                    }
                    else { result.dismiss; }
                });
            }


