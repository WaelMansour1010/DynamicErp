                            }),
                            success: function (r) {
                                if (r.success == "true") {
                                   // alert("@MyERP.Properties.Resources.Saved");
                                    Swal.fire({
                                        title: '@MyERP.Properties.Resources.Saved',
                                        text: " ",
                                        icon: 'success',
                                        showCancelButton: false,
                                        confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                        confirmButtonColor: '#3085d6'
                                    });
                                    var itemIds = [];
                                    $('#StockIssueVoucherDetails tr').each(function () {
                                        var td = $(this);
                                        if (td.find('.item').val() > 0)
                                            itemIds.push({
                                                ItemId: td.find('.item').val(),
