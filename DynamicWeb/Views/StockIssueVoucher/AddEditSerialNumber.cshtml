            alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 5, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
        });
        $('.addtd').addClass('hidden');
        $('.addtd').removeClass('hidden');



    });

    async function fillDDLs() {
        if ($('#DepartmentId').val()) {
            $('#Id').val() ? null : setDocNum();
            let warehouseId = $('#WarehouseId').val();
            setWarehouseValues(warehouseId);
         //   await getItemsByDepId();
            fillDirectExpenses();
        }
