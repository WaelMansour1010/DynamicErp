            $('#serialTable').append('<tr><td ><label">' + i +'</label"></td> <td > <input type="text" onkeypress="checkEnter(event,this);" class="serialNumber form-control  form-control-sm" /></td></tr>')


            //$('#accordion1 tbody:last').append('<tr><td class="col-sm-1"><label">' + i + '</label></td><td class="col-sm-11"><input type="text" onkeypress="checkEnter(event,this);"  class="serialNumber form-control" /></td><td hidden> <input type="hidden" class="itemId" value="' + itemId + '" hidden/></td></tr>');
        }
       // console.log(rows);

        $('#itemQuantity').val(rows);
    }

        function checkEnter(e, obj) {

           // console.log(e);

            var keycode = (e.keyCode ? e.keyCode : e.which);

            if (keycode == '13') {
                let serial = $(obj).closest('tr').closest('tr').find('.serialNumber').val();
                let exists = 0;
                $('.serialNumber').each(function () {
                    if (serial == $(this).val())
                        exists = exists + 1
                });
                if (exists == 1)//existing one time only
                    $(obj).closest('tr').next('tr').find('.serialNumber').focus();
                else {
                    Swal.fire({
                            title: '@MyERP.Properties.Resources.ThisSerialHasBeenEnteredBefore',
                            text: " ",
                            icon: 'info',
                            showCancelButton: false,
                            confirmButtonText: '@MyERP.Properties.Resources.Ok',
                            confirmButtonColor: '#3085d6'
                    });

                   // alert('@MyERP.Properties.Resources.ThisSerialHasBeenEnteredBefore');
                    $(obj).closest('tr').closest('tr').find('.serialNumber').val('');
                }
            }
        }
    async function serialpanels() {
        var details = [];
        $('#StockIssueVoucherDetails tr').each(function () {
            var tr = $(this);
            var sum = 0;
            $(".item[value=" + tr.find('.item').val() + "]").each(function () {
                sum += $(this).closest('tr').find('.quantity').val() * 1;
            });
            generatedQty = sum;
            details.push({
                quantity: sum,
                itemName: tr.find('.item-name').text(),
                itemId: tr.find('.item').val()
            });
        });

        $('#selectedItems').empty();
        details.some(function (detail) {
            if (detail.itemId) {

                var serials = [];
                if ($('#heading' + detail.itemId).length) {
                    $('#heading' + detail.itemId).closest('.panel').find('tbody').children('tr').each(function () {
                        serials.push({
                            serialNumber: $(this).find('.serialNumber').val(),
                            itemId: $(this).find('.itemId').val()
                        });
                    });

                    $('#heading' + detail.itemId).closest('.panel').remove();
                    if (detail.itemId == generalItemId) {
                        addSerialNumbers(detail.quantity, detail.itemName, detail.itemId);
                        serials.some(function (serial, i) {
                            var tr = $('#heading' + detail.itemId).closest('.panel').find('tbody').children('tr').eq(i);
                            tr.find('.itemId').val(serial.itemId);
                            tr.find('.serialNumber').val(serial.serialNumber);
                        });
                    }
                } else {
                    if (detail.itemId == generalItemId) {
                        addSerialNumbers(detail.quantity, detail.itemName, detail.itemId);
                    }
                }

                $('#selectedItems').append($('<option>', {
                    value: detail.itemId,
                    text: detail.itemName
                }));
                var selectedItems = [];
                $('#selectedItems').each(function () {
                    $(this).children('option').each(function () {
                        if ($.inArray(this.value, selectedItems) > -1) {
                            $(this).remove()
                        } else {
                            selectedItems.push(this.value);
                        }
                    });
                    selectedItems = [];
                });
            }
            $('#selectedItems').val(@ViewBag.GeneralItemId);
        });
       // console.log(details);

       // $('#itemQuantity').val(details[0].quantity);
        @*$('#heading' + details[0].itemId).closest('.panel').prevAll().remove();
        $('#heading' + @ViewBag.GeneralItemId).closest('.panel').show();
        $('#heading' + details[0].itemId).closest('.panel').nextAll().hide();*@


         $('#heading' + @ViewBag.GeneralItemId).closest('.panel').prevAll().remove();
        $('#heading' + @ViewBag.GeneralItemId).closest('.panel').show();
        $('#heading' +  @ViewBag.GeneralItemId).closest('.panel').nextAll().hide();
    }

