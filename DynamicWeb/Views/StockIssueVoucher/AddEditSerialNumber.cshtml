@model MyERP.Models.StockIssueVoucher

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.StockIssueVoucherSerialNumber;
}
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">

                <a class="btn btn-info" href="/StockIssueVoucher/Index?type=1" role="button">@MyERP.Properties.Resources.Back</a>
            </div>
            <h4 class="page-title"> @MyERP.Properties.Resources.StockIssueVoucherSerialNumber </h4>
        </div>
    </div>
</div>

<div class="row">
