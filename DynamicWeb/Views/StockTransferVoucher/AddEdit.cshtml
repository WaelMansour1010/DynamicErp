@model MyERP.Models.StockTransferVoucher

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";

    ViewBag.Title = MyERP.Properties.Resources.StockTransferVoucher;
}

<script src="~/Scripts/BarcodeScan.js"></script>
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                @if (Model != null)
                {
                    if (Model.IsDeleted == false)
                    {
                        if (ViewBag.Previous > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.First })" class="btn btn-info">@MyERP.Properties.Resources.First</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Previous })" class=" btn btn-info">&#8250;</a>
                        }
                        if (ViewBag.Next > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Next })" class="btn btn-info">&#8249;</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Last })" class="btn btn-info">@MyERP.Properties.Resources.Last</a>
                        }
                    }
                }
                <a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
            </div>
            <h4 class="page-title">@MyERP.Properties.Resources.StockTransferVoucher:</h4>
        </div>
    </div>
</div>
@if (Model != null)
{
    @Html.HiddenFor(model => model.Id)
    @Html.HiddenFor(model => model.IsActive)
    @Html.HiddenFor(model => model.UserId)
    @Html.HiddenFor(model => model.IsLinked)
    @Html.HiddenFor(model => model.IsPosted)
    @Html.HiddenFor(model => model.IsDeleted)
    @Html.HiddenFor(model => model.IsAccepted)
    @Html.HiddenFor(model => model.IsCompleted)
    @Html.HiddenFor(model => model.Image)
}
<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal needs-validation" role="form">
                        <div class="card">
                            <div class="card-body">
                                <h5 class="header-title">
                                    @MyERP.Properties.Resources.MainData
                                </h5>
                                <div class="form-group row">
                                    <label class=" col-sm-1 control-label" for="DocumentNumber">@MyERP.Properties.Resources.DocNo</label>
                                    <div class="col-sm-5">
                                        @Html.EditorFor(model => model.DocumentNumber, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly", placeholder = @MyERP.Properties.Resources.DocNo, required = "required", hidden = "hidden" } })
                                        <input id="DocumentNumbers" class="form-control" placeholder=@MyERP.Properties.Resources.Code required readonly />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label for="VoucherDate" class="control-label col-sm-1">@MyERP.Properties.Resources.DocumentDate</label>
                                    <div class="col-sm-5">
                                        <input id="VoucherDate" name="VoucherDate" class="form-control" type="datetime-local" value="@ViewBag.VoucherDate" required />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.EnterDate
                                        </div>
                                    </div>
                                </div>

                                <div class="form-group row">
                                    <label for="DepartmentId" class="col-sm-1 control-label">@MyERP.Properties.Resources.Branch</label>
                                    <div class="col-sm-5">
                                        @Html.DropDownList("DepartmentId", null, null, htmlAttributes: new { @class = "form-control", required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Select
                                        </div>
                                    </div>

                                    <label for="WarehouseId" class="col-sm-1 control-label">@MyERP.Properties.Resources.WareHouse</label>
                                    <div class="col-sm-5">
                                        @Html.DropDownList("WarehouseId", null, null, htmlAttributes: new { @class = "form-control", required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Select
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="DestinationWarehouseId" class="col-sm-1 control-label">@MyERP.Properties.Resources.ToWarehouse</label>
                                    <div class="col-sm-5">
                                        @Html.DropDownList("DestinationWarehouseId", null, null, htmlAttributes: new { @class = "form-control", required = "required" })
                                        @if (Model != null)
                                        {
                                            <input hidden id="DestinationDepartmentId" value="@Model.DestinationDepartmentId" />
                                        }
                                        else
                                        {
                                            <input hidden id="DestinationDepartmentId" />
                                        }
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Select
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="control-label col-sm-1" for="Notes">@MyERP.Properties.Resources.Notes</label>
                                    <div class="col-sm-5">
                                        <textarea id="Notes" name="Notes" class="form-control" rows="5" cols="5">@if (Model != null) { @Model.Notes; }</textarea>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>


            @Html.Partial("ItemSearch")

            <!-- Patch Modal-->
            <div id="patchModal" class="modal fade bs-example-modal-lg" tabindex="-1" role="dialog" aria-labelledby="myLargeModalLabel" data-backdrop="false" style="background-color: rgba(0, 0, 0, 0.5);">
                <div class="modal-dialog modal-lg" role="document">
                    <div class="modal-content">
                        <div class="modal-header">
                            <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                        </div>
                        <div class="modal-body">

                            <div class="row">
                                <div class="col-sm-12">
                                    <table class="table table-condensed">
                                        <thead>
                                            <tr>
                                                <th>@MyERP.Properties.Resources.PatchCode</th>
                                                <th>@MyERP.Properties.Resources.ExpirationDate</th>
                                                <th>@MyERP.Properties.Resources.Qty</th>
                                                <th>@MyERP.Properties.Resources.Add</th>
                                            </tr>
                                        </thead>
                                        <tbody id="item-patches"></tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-default" onclick=" $('.bs-example-modal-lg').modal('hide');" data-dismiss="modal">@MyERP.Properties.Resources.Close</button>
                        </div>
                    </div>

                </div>
            </div>

            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="header-title">@MyERP.Properties.Resources.Details</h5>
                            <div class="form-horizontal needs-validation" role="form">
                                <div class="table-responsive">
                                    <table class="table table-centered mb-0">
                                        <thead>
                                            <tr>
                                                <th>@MyERP.Properties.Resources.Barcode</th>
                                                <th>@MyERP.Properties.Resources.Item</th>
                                                <th class="expiry" style="display:none;"> @MyERP.Properties.Resources.ExpirationDate </th>
                                                <th>@MyERP.Properties.Resources.Qty</th>
                                                <th class="UnitClass" style="display:none;">@MyERP.Properties.Resources.Unit</th>
                                                <th class="UnitEquivClass" style="display:none;">@MyERP.Properties.Resources.Equivalent</th>
                                                @if ((bool)ViewBag.ShowCost)
                                                {
                                                    <th>@MyERP.Properties.Resources.Cost</th>
                                                    <th class="Increase" style="display:none;">@MyERP.Properties.Resources.CostBeforeIncrease</th>
                                                    <th>@MyERP.Properties.Resources.Total</th>
                                                }

                                                <th>@MyERP.Properties.Resources.CurrentQtyOfDefaultUnit</th>
                                                <th>@MyERP.Properties.Resources.Details</th>
                                                <th>@MyERP.Properties.Resources.Delete</th>
                                            </tr>
                                        </thead>
                                        <tbody id="StockTransferVoucherDetails">

                                            @if (Model != null)
                                            {
                                                foreach (var item in Model.StockTransferVoucherDetails)
                                                {
                                                    <tr>
                                                        <td class="tabledit-edit-mode"><input class="barcode form-control tabledit-input form-control-sm" value="@Html.Raw(item.ItemPrice!=null?item.ItemPrice.Barcode:"")" /></td>
                                                        <td class="tabledit-edit-mode popupCell">
                                                            <input type="hidden" class="item form-control tabledit-input form-control-sm" value="@item.ItemPriceId" required />
                                                            <input hidden type="text" class="item-name form-control tabledit-input form-control-sm" value="@item.Item.Code -@item.Item.ArName" required />
                                                            <label style="width:200px" class="name control-label tabledit-input ">@item.Item.ArName - @item.ItemPrice.Barcode -</label>
                                                            <input hidden class="itemUnitArName" value=@item.ItemUnit.ArName />

                                                        </td>

                                                        <td class="tabledit-edit-mode expiry" style="display:none;">
                                                            @if (item.ExpireDate.HasValue)
                                                            {
                                                                <input class="ExpiryDate form-control tabledit-input form-control-sm" readonly value="@item.ExpireDate.Value.ToString("MM/dd/yyyy")" />
                                                            }
                                                            else
                                                            {
                                                                <input class="ExpiryDate form-control tabledit-input form-control-sm" readonly />
                                                            }
                                                            <input class="PatchId form-control tabledit-input form-control-sm" hidden value="@item.PatchId" />
                                                            <input class="itemId form-control tabledit-input form-control-sm" hidden value="@item.ItemId" />

                                                        </td>


                                                        <td class="tabledit-edit-mode"><input class="quantity form-control tabledit-input form-control-sm" type="number" step="any" value="@item.Qty" required /></td>
                                                        <td class="tabledit-edit-mode UnitClass" style="display:none;"><select class="item-unit form-control tabledit-input form-control-sm" required disabled><option value="@item.ItemUnitId">@item.ItemUnit.ArName</option></select></td>
                                                        <td class="tabledit-edit-mode UnitEquivClass" style="display:none;"><input class="unit-equavalent form-control tabledit-input form-control-sm small-number" type="number" step="any" value="@item.UnitEquivalent" required /></td>

                                                        @if ((bool)ViewBag.ShowCost == true)
                                                        {
                                                            <td class="tabledit-edit-mode"><input type="text" class="money cost form-control tabledit-input form-control-sm" value="@item.CostPrice" required /></td>
                                                            <td class="tabledit-edit-mode Increase" style="display:none;"><input type="text" class="money CostPriceBeforeIncrease form-control tabledit-input form-control-sm" value="@item.CostPriceBeforeIncrease" /></td>
                                                            <td class="tabledit-edit-mode"><input class="total money form-control tabledit-input form-control-sm" type="text" readonly value="0" required /></td>

                                                        }
                                                        else
                                                        {
                                                            <td hidden class="tabledit-edit-mode"><input type="text" class="money cost form-control tabledit-input form-control-sm" value="@item.CostPrice" required /></td>
                                                            <td hidden class="tabledit-edit-mode Increase" style="display:none;"><input type="text" class="money CostPriceBeforeIncrease form-control tabledit-input form-control-sm" value="@item.CostPriceBeforeIncrease" /></td>
                                                            <td hidden class="tabledit-edit-mode"><input class="total money form-control tabledit-input form-control-sm" type="text" readonly value="0" required /></td>
                                                        }

                                                        <td class="tabledit-edit-mode"><input type="number" step="any" class="quantityOnSystem form-control tabledit-input form-control-sm" readonly /></td>
                                                        <td><button class="btn btn-info" data-toggle="modal" data-target="#itemDetails" onclick="showItemDetials(this)">@MyERP.Properties.Resources.Details</button></td>
                                                        <td>
                                                            <a href="javascript:void(0);" onclick="deleteElement(this)">
                                                                <i class="fas fa-trash-alt"></i>
                                                            </a>
                                                        </td>

                                                    </tr>
                                                }
                                            }
                                            <tr>
                                                <td class="tabledit-edit-mode"><input class="barcode form-control tabledit-input form-control-sm" /></td>
                                                <td onclick="showSearchModal()" class="tabledit-edit-mode popupCell">
                                                    <input type="hidden" class="item form-control tabledit-input form-control-sm" @Html.Raw(Model != null ? "" : "required ") />
                                                    <input hidden type="text" class="item-name form-control tabledit-input form-control-sm" @Html.Raw(Model != null ? "" : "required ") />
                                                    <span class="Add-Button" style="font-size: 25px; color: limegreen;margin-right:50%;" @*data-toggle="modal" data-target=".bs-example-modal-lg"*@><i class="fas fa-plus"></i></span>
                                                    <label style="width:200px" class="name control-label tabledit-input"></label>
                                                </td>
                                                <td class="tabledit-edit-mode expiry" style="display:none;">
                                                    <input class="ExpiryDate form-control tabledit-input form-control-sm" readonly />
                                                    <input class="PatchId form-control tabledit-input form-control-sm" hidden />
                                                    <input class="itemId form-control tabledit-input form-control-sm" hidden />
                                                </td>
                                                <td class="tabledit-edit-mode"><input class="quantity form-control tabledit-input form-control-sm" type="number" step="any" min="1" @Html.Raw(Model != null ? "" : "required ") /></td>
                                                <td class="tabledit-edit-mode UnitClass" style="display:none;"><select class="item-unit form-control tabledit-input form-control-sm" @Html.Raw(Model != null ? "" : "required ") disabled></select></td>
                                                <td class="tabledit-edit-mode UnitEquivClass" style="display:none;"><input class="unit-equavalent form-control tabledit-input form-control-sm small-number" type="number" step="any" @Html.Raw(Model != null ? "" : "required ") /></td>
                                                @if ((bool)ViewBag.ShowCost == true)
                                                {
                                                    <td class="tabledit-edit-mode">
                                                        <input type="text" class="money cost form-control tabledit-input form-control-sm" @*@Html.Raw(Model != null ? "" : "required ")*@ />
                                                    </td>
                                                    <td class="tabledit-edit-mode Increase" style="display:none;">
                                                        <input type="text" class="money CostPriceBeforeIncrease form-control tabledit-input form-control-sm" />
                                                    </td>
                                                    <td class="tabledit-edit-mode"><input class="total money form-control tabledit-input form-control-sm" type="text" readonly value="0" @Html.Raw(Model != null ? "" : "required ") /></td>

                                                    @*<td class="tabledit-edit-mode"><input type="text" class="money cost form-control tabledit-input form-control-sm"  @Html.Raw(Model != null ? "" : "required ") />
                                                        </td>*@
                                                }
                                                else
                                                {
                                                    <td hidden class="tabledit-edit-mode"><input type="hidden" class="money cost form-control tabledit-input form-control-sm" @*@Html.Raw(Model != null ? "" : "required ")*@ /></td>
                                                    <td hidden class="tabledit-edit-mode"><input class="total money form-control tabledit-input form-control-sm" type="hidden" readonly value="0" @Html.Raw(Model != null ? "" : "required ") /></td>

                                                }
                                                @*@if ((bool)ViewBag.ShowCost == true)
                                                    {
                                                        <td class="tabledit-edit-mode"><input class="total money form-control tabledit-input form-control-sm" type="text" readonly value="0" @Html.Raw(Model != null ? "" : "required ") /></td>
                                                    }
                                                    else
                                                    {
                                                        <td hidden class="tabledit-edit-mode"><input class="total money form-control tabledit-input form-control-sm" type="hidden" readonly value="0" @Html.Raw(Model != null ? "" : "required ") /></td>
                                                    }*@
                                                <td class="tabledit-edit-mode"><input type="number" step="any" class="quantityOnSystem form-control tabledit-input form-control-sm" readonly /></td>
                                                <td><button class="btn btn-info" data-toggle="modal" data-target="#itemDetails" onclick="showItemDetials(this)">@MyERP.Properties.Resources.Details</button></td>
                                                <td>
                                                    <a href="javascript:void(0);" onclick="deleteElement(this)">
                                                        <i class="fas fa-trash-alt"></i>
                                                    </a>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>

                            </div>
                            @if ((bool)ViewBag.ShowCost)
                            {
                                <div class="form-group row">
                                    <label for="TotalCostPrice" class="control-label col-sm-2">@MyERP.Properties.Resources.TotalCost</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.TotalCostPrice, new { htmlAttributes = new { @class = "form-control money", placeholder = @MyERP.Properties.Resources.TotalCost, @readonly = "readonly", required = "required" } })
                                    </div>
                                    <label for="CostPriceIncreasePercentage" class="Increase control-label col-sm-2" style="display:none;">@MyERP.Properties.Resources.PercentageOfIncrease</label>
                                    <div class="Increase col-sm-4" style="display:none;">
                                        @Html.EditorFor(model => model.CostPriceIncreasePercentage, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.PercentageOfIncrease } })
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div hidden class="form-group row">
                                    <label for="TotalCostPrice" class="control-label col-sm-2">@MyERP.Properties.Resources.TotalCost</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.TotalCostPrice, new { htmlAttributes = new { @class = "hidden money", placeholder = @MyERP.Properties.Resources.TotalCost, @readonly = "readonly", required = "required" } })
                                    </div>
                                    <label for="CostPriceIncreasePercentage" class="Increase control-label col-sm-2" style="display:none;">@MyERP.Properties.Resources.PercentageOfIncrease</label>
                                    <div class="Increase col-sm-4" style="display:none;">
                                        @Html.EditorFor(model => model.CostPriceIncreasePercentage, new { htmlAttributes = new { @class = "hidden", placeholder = @MyERP.Properties.Resources.PercentageOfIncrease } })
                                    </div>
                                </div>
                            }

                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-sm-offset-2">
                    @if (Model == null)
                    {
                        <button type="submit" onclick="addEdit('report')" class="btn btn-success">
                            @MyERP.Properties.Resources.SaveAndPrint
                        </button>
                        <button type="submit" id="newbtn" onclick="addEdit('new')" class="btn btn-success">
                            @MyERP.Properties.Resources.SaveAndNew
                        </button>
                        <button class="btn btn-success" id="save" onclick="addEdit()">
                            @MyERP.Properties.Resources.Save
                        </button>
                        <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                    }
                    else if (Model.IsDeleted == false)
                    {
                        if (Model.IsAccepted != true)
                        {
                            <button class="btn btn-success" id="save" onclick="addEdit()">
                                @MyERP.Properties.Resources.Save
                            </button>
                            <button class="btn btn-success Accept" onclick="acceptTransferVoucher(@Model.Id)" style="display:none;">
                                @MyERP.Properties.Resources.Accept
                            </button>
                        }
                        <a class="btn btn-success" target="_blank" href="@Url.Action("StockTransferVoucher","Report",new { id=Model.Id})" role="button">@MyERP.Properties.Resources.Print</a>

                        <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                        <button class="btn btn-danger" onclick="Delete(@Model.Id,'StockTransferVoucher')" role="button">@MyERP.Properties.Resources.Delete</button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
@if (Model != null && Model.IsAccepted == true)
{
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <h5 class="header-title">
                            @MyERP.Properties.Resources.ExchangeVouchersResultingFromTheTransfer
                        </h5>
                        <div class="table-responsive">
                            <table class="table table-striped table-centered mb-0">
                                <thead>
                                    <tr>
                                        <th>
                                            @MyERP.Properties.Resources.DocNo
                                        </th>
                                        <th>
                                            @MyERP.Properties.Resources.Date
                                        </th>

                                        <th>
                                            @MyERP.Properties.Resources.TotalCost
                                        </th>
                                        <th>
                                            @MyERP.Properties.Resources.WareHouse
                                        </th>

                                        <th>@MyERP.Properties.Resources.View</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in (List<MyERP.Models.StockIssueVoucher>)ViewBag.StockIssueVouchers)
                                    {
                                        <tr>
                                            <td>
                                                @*@Html.DisplayFor(modelItem => item.DocumentNumber)*@
                                                @Html.Raw(item.DocumentNumber.ToString().Replace("-", ""))
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.VoucherDate)
                                            </td>

                                            <td>
                                                @Html.DisplayFor(modelItem => item.TotalCostPrice)
                                            </td>

                                            <td>
                                                @Html.DisplayFor(modelItem => item.Warehouse.ArName)
                                            </td>

                                            <td>
                                                <a href="@Url.Action("AddEdit","StockIssueVoucher",new { id=item.Id }) " target="_blank">
                                                    <i class="fa fa-edit"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>





    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <h5 class="header-title">
                            @MyERP.Properties.Resources.StockReceiptVoucher
                        </h5>
                        <div class="table-responsive">
                            <table class="table table-striped table-centered mb-0">
                                <thead>
                                    <tr>
                                        <th>
                                            @MyERP.Properties.Resources.DocNo
                                        </th>
                                        <th>
                                            @MyERP.Properties.Resources.Date
                                        </th>

                                        <th>
                                            @MyERP.Properties.Resources.TotalCost
                                        </th>
                                        <th>
                                            @MyERP.Properties.Resources.WareHouse
                                        </th>

                                        <th>@MyERP.Properties.Resources.View</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in (List<MyERP.Models.StockReceiptVoucher>)ViewBag.StockReceiptVouchers)
                                    {
                                        <tr>
                                            <td>
                                                @*@Html.DisplayFor(modelItem => item.DocumentNumber)*@
                                                @Html.Raw(item.DocumentNumber.ToString().Replace("-", ""))
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.VoucherDate)
                                            </td>

                                            <td>
                                                @Html.DisplayFor(modelItem => item.TotalCostPrice)
                                            </td>

                                            <td>
                                                @Html.DisplayFor(modelItem => item.Warehouse.ArName)
                                            </td>

                                            <td>
                                                <a href="@Url.Action("AddEdit","StockReceiptVoucher",new { id=item.Id }) " target="_blank">
                                                    <i class="fa fa-edit"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>




    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <h5 class="header-title">
                            @MyERP.Properties.Resources.JournalEntries
                        </h5>
                        <div class="table-responsive">
                            <table class="table table-striped table-centered mb-0">
                                <thead>
                                    <tr>
                                        <th>
                                            @MyERP.Properties.Resources.DocNo
                                        </th>
                                        <th>
                                            @MyERP.Properties.Resources.Date
                                        </th>

                                        <th>@MyERP.Properties.Resources.View</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in (List<MyERP.Models.JournalEntry>)ViewBag.JournalEntries)
                                    {
                                        <tr>
                                            <td>
                                                @*@Html.DisplayFor(modelItem => item.DocumentNumber)*@
                                                @Html.Raw(item.DocumentNumber.ToString().Replace("-", ""))
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.Date)
                                            </td>
                                            <td>
                                                <a href="@Url.Action("AddEdit","JournalEntries",new { id=item.Id }) " target="_blank">
                                                    <i class="fa fa-edit"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<div class="modal fade bs-example-modal-lg" id="item-search-modal" tabindex="-1" role="dialog" aria-labelledby="myLargeModalLabel" data-backdrop="false" style="background-color: rgba(0, 0, 0, 0.5);">
