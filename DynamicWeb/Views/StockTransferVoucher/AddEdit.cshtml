<script>
    //------------------ Variables Declaration --------------------//
    let UseExpiryDateForItems = '@ViewBag.UseExpiryDateForItems';
    var selectedItemRowToEdit; // for expire date

    var isBarcodeScanned = false; // For barcode scanner
    var barcodeScannerCode = ""; // For barcode scanner

    let items = [];
    let custIems = [];
    let warehouseOptions = '';


    function zeroPadded(val) {
        if (val >= 10)
            return val;
        else
            return '0' + val;
    }
    @*if ($('#Id').val() > 0) {
        $('#VoucherDate').val('@ViewBag.VoucherDate');
    }*@
    //else
    //{
    //    var d = new Date();
    //    $('#VoucherDate').val(d.getFullYear() + "-" + zeroPadded(d.getMonth() + 1) + "-" + zeroPadded(d.getDate()) + "T" + zeroPadded(d.getHours()) + ":" + zeroPadded(d.getMinutes()));
    //}

    $(document).ready(function () {
        if ('@ViewBag.Msg' == "NotAllow") {
            //alert('@MyERP.Properties.Resources.YouCantEditThisDocument');
            Swal.fire({
                title: '@MyERP.Properties.Resources.YouCantEditThisDocument',
                text: " ",
                icon: 'error',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
            window.location.replace("/StockTransferVoucher");
        }
        if ('@ViewBag.Accept' == "Accept") {
            $('.Accept').show();
        }
        //$.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
        //    $("input[type|='datetime-local']").prop('min', r.PeriodStart).prop('max', r.PeriodEnd);
        //});
        $.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
            $("input[type|='datetime-local']").not('.ExpiryDate').prop('min', r.PeriodStart).prop('max', r.PeriodEnd);
        });

        getItems();
        if ($('#Id').val()) {
            var code = $('#DocumentNumber').val();
            $('#DocumentNumbers').val(code.replaceAll("-", ""))
            $("#DepartmentId").prop('disabled', true);
            $("#VoucherDate").prop('disabled', true);
            // --- الجزء المسئول عن تخزين كل الاصناف الى راجعه فى حاله التعديل والكميات المتاحة من كل صنف فى الفرع الحالى ------- //
            //requestData('/Helper/ItemsByDepId?departmentId=' + $('#DepartmentId').val()).done(function (r) {
            requestData('/Helper/ItemsByDepId?departmentId=' + $('#DepartmentId').val()).done(function (r) {
                items = r;
                ItemsId = [];
                $('#StockTransferVoucherDetails tr').each(function () {

                    let tr = $(this);
                    ItemsId.push(parseInt(tr.closest('tr').find('.item').val()));
                    let item = tr.closest('tr').find('.item');

                    if (item.val() != '') {
                        let itemId = items.filter(function (i) { return i.ItemPriceId == item.val(); })[0].Id;
                        requestData('/Helper/ItemQuantityOnSystem?warehouseId=' + $('#WarehouseId').val() + '&itemId=' + itemId).done(function (r) {
                            var qtyOnSystem = (r * 1 > 0 ? r * 1 : 0);
                            var oldQuantity = tr.closest('tr').find('.quantity').val();
                            var unitEquavalent = tr.closest('tr').find('.unit-equavalent').val();
                            var newAvailabelQty = qtyOnSystem + (oldQuantity * unitEquavalent);
                            tr.closest('tr').find('.quantityOnSystem').val(newAvailabelQty);
                        });
                    }


                });


            });
            // ---------------------------------------------------------------------------------------------------------------------------- //


            $('.cost').each(function () {
                $(this).closest('tr').find('.total').val($(this).inputmask('unmaskedvalue') * $(this).closest('tr').find('.quantity').val() * $(this).closest('tr').find('.unit-equavalent').val());
            });
            if ($('#IsAccepted').val() == 'True') {
                $('input[type="checkbox"], select').attr('disabled', 'disabled');
                $('input').attr('readonly', 'readonly');
            }
            if ($('#DepartmentId').val()) {
                if ($('#DestinationDepartmentId').val() != $('#DepartmentId').val()) {
                    $('.Increase').show();
                }
                else {
                    $('.Increase').hide();
                }
            }
        }
        else {
            if ($('#DepartmentId').val()) {
                $('#DepartmentId').trigger('change');
            }
        }
        if (window.sessionStorage.getItem("UseItemUnit") == 'true') {
            $('.UnitClass').show();
            $('.UnitEquivClass').show();

            // show item unit ArName
            $('#StockTransferVoucherDetails tr').each(function () {
                var tr = $(this);

                var itemUnitArName = tr.find('.itemUnitArName');

                var itemDisplayName = tr.find('.name').text();
                if (itemDisplayName != "") {

                    itemDisplayName += " " + itemUnitArName.val();
                    tr.find('.name').text(itemDisplayName);

                }
            });
           // $('.table td, .table th').css("min-width", "10vh");

        }
        //else {
        //    $('.table td, .table th').css("min-width", "12vh");
        //}

        // Expire date
        if (UseExpiryDateForItems == 'True') {
            $('.expiry').show();
        }
    });

    function setDocNum() {
        if ($('#DepartmentId').val())
            $.get('/StockTransferVoucher/SetDocNum?id=' + $('#DepartmentId').val() + '&VoucherDate=' + $('#VoucherDate').val()).done(function (r) {
                $('#DocumentNumber').val(r);
                $('#DocumentNumbers').val(r.replaceAll("-", ""));
            });
    }
    $(document).on('change', '#VoucherDate', function () {
        setDocNum();
    });

    if (!$('#Id').val()) {
        setDocNum();
    };

    function getItems() {
        return requestData('/Helper/ItemsByDepId/?departmentId='+ $('#DepartmentId').val()).done(function (r) {
            items = r;
        });
    }

    function setWarehouseValues() {
        warehouseOptions = '';
        return requestData('/Helper/WarehousesByDepartmentId?id=' + $('#DepartmentId').val())
            .done(function (r) {
             //   warehouseOptions = '<option value>إختر</option>';
                for (var i = 0; i < r.length; i++) {
                    warehouseOptions += '<option value="' + r[i].Id + '">' + r[i].ArName + '</option>';
                }
            });
    }

    $(document).on('change', '#DepartmentId', function () {
        getItems();
        setWarehouseValues().then(function () {
            $("#WarehouseId").empty().append(warehouseOptions);
           // $("#DestinationWarehouseId").empty().append(warehouseOptions);
        });
        setDocNum();

        if ($('#StockTransferVoucherDetails tr').length > 1) {
           // alert("@MyERP.Properties.Resources.AllDataHasBeenRemoved" + "!");
            Swal.fire({
                title: '@MyERP.Properties.Resources.AllDataHasBeenRemoved' + '!',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        }
        $('#StockTransferVoucherDetails tr').not(':last').remove();
        calculateTotal();/*, .cost*/
        $('#StockTransferVoucherDetails').find('.item, .item-name, .item-unit, .quantity, .unit-equavalent').prop('required', 'required');
        if ($('#DestinationWarehouseId').val()) {
            $('#DestinationWarehouseId').trigger('change');
        }
    });
    let DestinationDepartmentId = 0;
    $('#DestinationWarehouseId').on('change', function () {

        $.get('/Helper/GetDepartmentByWareHouseId?id=' + $(this).val()).done(function (r) {
            DestinationDepartmentId = r[0].DepartmentId;
            $('#DestinationDepartmentId').val(DestinationDepartmentId);
            if (DestinationDepartmentId != $('#DepartmentId').val()) {
                $('.Increase').show();
            }
            else {
                $('.Increase').hide();
            }
        })
    })

    $('#WarehouseId').on('change', function () {
        $('.item').each(function () {
            $(this).val() > 0 ? $(this).trigger('change') : null;
        });
    });

    $(document).on('keydown', '.barcode', function (e) {
        if (e.which == 13 || e.keyCode == 13) {
            let elem = $(this);
            var barcode = elem.val().includes("-*-") ? elem.val().split("-*-")[1] : elem.val(); //For barcode scanner

            if (items.length) {
                //let itemPrice = items.filter(function (i) { return i.Barcode === $(elem).val(); })[0];
                //if (itemPrice) {
                //    $(elem).closest('tr').find('.item-name').val(itemPrice.ArName);
                //    $(elem).closest('tr').find('.item').val(itemPrice.ItemPriceId).trigger('change');
                //} else {
                //    $(elem).closest('tr').find('.item-name').val('');
                //    $(elem).closest('tr').find('.item').val('').trigger('change');
                //}

                let itemPrice = items.filter(function (i) { return i.Barcode === barcode; })[0];
                if (itemPrice) {
                    let itmId = itemPrice.Id;

                    // Item Has Expire Date
                    let ItemHasExpiry = isItemHasExpireDate(itmId);

                    // Barcode scanner
                    if (elem.val().includes("-*-")) {
                        if (ItemHasExpiry && UseExpiryDateForItems) {
                            isBarcodeScanned = true;
                            barcodeScannerCode = elem.val();
                        }
                        else if (!UseExpiryDateForItems || UseExpiryDateForItems === null || UseExpiryDateForItems === undefined) {
                            //alert("@MyERP.Properties.Resources.ExpirationDateForItemsIsDisabled");
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.ExpirationDateForItemsIsDisabled',
                                text: " ",
                                icon: 'info',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                        }
                    }
                    else {
                        isBarcodeScanned = false;
                        barcodeScannerCode = "";

                        $(elem).closest('tr').find('.ExpiryDate').val(''); //
                    }

                    $(elem).closest('tr').find('.itemId').val(itmId);

                    $(elem).closest('tr').find('.item-name').val(itemPrice.ArName);
                    $(elem).closest('tr').find('.name').text(itemPrice.ArName);
                    $(elem).closest('tr').find('.item').val(itemPrice.ItemPriceId).trigger('change');
                } else {

                    $(elem).closest('tr').find('.itemId').val(''); //
                    $(elem).closest('tr').find('.ExpiryDate').val(''); //

                    $(elem).closest('tr').find('.item-name').val('');
                    $(elem).closest('tr').find('.name').text('');
                    $(elem).closest('tr').find('.item').val('').trigger('change');
                }
            } else {
                $(elem).closest('tr').find('.item-name').val('');
                $(elem).closest('tr').find('.item').val('').trigger('change');
            }
        }
    });

    $(document).on('change', '.barcode', function () {
        let itemPrice = $(this).closest('tr').find('.item').val();
        if (items.length && itemPrice) {
            let itemPrice = $(this).closest('tr').find('.item').val();
            let barcode = items.filter(function (i) { return i.ItemPriceId == itemPrice; })[0];
            $(this).val(barcode ? barcode.Barcode : '');
        } else
            $(this).val('');
    });

    $(document).on('change', '.cost', function () {
        $(this).closest('tr').find('.total').val($(this).inputmask('unmaskedvalue') * $(this).closest('tr').find('.quantity').val() * $(this).closest('tr').find('.unit-equavalent').val());
        calculateTotal();
        addToStockTransferVoucherDetails();
    });

    $(document).on('change', '.quantity', function () {
        if ($(this).val() * 1 == 0) {
            $(this).val('');
        } else {
            let itemPrice = $(this).closest('tr').find('.item');
            let itemId = items.filter(function (i) { return i.ItemPriceId == itemPrice.val() * 1; })[0].Id;
            let sum = 0;
            items.filter(function (i) { return i.Id == itemId }).forEach(function (v, i) {
                $(".item[value=" + v.ItemPriceId + "]").not(itemPrice).each(function () {
                    sum += $(this).closest('tr').find('.quantity').val() * $(this).closest('tr').find('.unit-equavalent').val();
                });
            });
            if (sum + $(this).val() * $(this).closest('tr').find('.unit-equavalent').val() > $(this).closest('tr').find('.quantityOnSystem').val() * 1) {
              //  alert('@MyERP.Properties.Resources.RequiredQtyIsGreaterThanCurrentQty' + ' !');
                Swal.fire({
                    title: '@MyERP.Properties.Resources.RequiredQtyIsGreaterThanCurrentQty' + ' !',
                    text: " ",
                    icon: 'info',
                    showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    confirmButtonColor: '#3085d6'
                });
                $(this).val(($(this).closest('tr').find('.quantityOnSystem').val() - sum) / $(this).closest('tr').find('.unit-equavalent').val());
            }
        }
        $(this).closest('tr').find('.cost').trigger('change');
        $('#CostPriceIncreasePercentage').trigger('change');
    });

    $(document).on('change', '.unit-equavalent', function () {
        if ($(this).val() * 1 == 0) {
            $(this).val('');
        } else {
            let itemPrice = $(this).closest('tr').find('.item');
            let itemId = items.filter(function (i) { return i.ItemPriceId == itemPrice.val() * 1; })[0].Id;
            let sum = 0;
            items.filter(function (i) { return i.Id == itemId }).forEach(function (v, i) {
                $(".item[value=" + v.ItemPriceId + "]").each(function () {
                    sum += $(this).closest('tr').find('.quantity').val() * $(this).closest('tr').find('.unit-equavalent').val();

                });
            });
            if (sum > $(this).closest('tr').find('.quantityOnSystem').val() * 1) {
               // alert('@MyERP.Properties.Resources.RequiredQtyIsGreaterThanCurrentQty' + ' !');
                 Swal.fire({
                    title: '@MyERP.Properties.Resources.RequiredQtyIsGreaterThanCurrentQty' + ' !',
                    text: " ",
                    icon: 'info',
                    showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    confirmButtonColor: '#3085d6'
                });
                $(this).closest('tr').find('.quantity').val(($(this).closest('tr').find('.quantityOnSystem').val() - sum) / $(this).closest('tr').find('.unit-equavalent').val());
            }
        }
        $(this).closest('tr').find('.cost').trigger('change');
    });

    $('#CostPriceIncreasePercentage').on('change', function () {
        let Percentage = $(this).val();
        $('#StockTransferVoucherDetails tr').each(function () {
            var td = $(this);
            if (td.find('.cost').val()) {
                var CostWithPercentageIncrease = parseFloat(td.find('.CostPriceBeforeIncrease').inputmask('unmaskedvalue')) + parseFloat((td.find('.CostPriceBeforeIncrease').inputmask('unmaskedvalue') * Percentage / 100));
                td.find('.cost').val(CostWithPercentageIncrease);
                td.closest('tr').find('.cost').trigger('change');
            }
        })
    })



