yOnSystem form-control tabledit-input form-control-sm" readonly /></td><td><button class="btn btn-info" data-toggle="modal" data-target="#itemDetails" onclick="showItemDetials(this)">' + '@MyERP.Properties.Resources.Details' + '</button></td><td><a href="javascript:void(0);" onclick="deleteElement(this)"><i class="fas fa-trash-alt"></i></a></td></tr>';

            $('#StockTransferVoucherDetails').append(tr);

            // Expire date
            if (UseExpiryDateForItems == 'True') {
                $('.expiry').show();
            }

            if (window.sessionStorage.getItem("UseItemUnit") == 'true') {
                $('.UnitClass').show();
                $('.UnitEquivClass').show();
            }
            if (DestinationDepartmentId != $('#DepartmentId').val()) {
                $('.Increase').show();
            }
            else {
                $('.Increase').hide();
            }
            $('#StockTransferVoucherDetails tr:last .money').inputmask({
                alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
            });
            $('#StockTransferVoucherDetails input[type=number]').removeProp('oninput').prop('type', 'text').inputmask({
                alias: 'numeric', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
            });
            $('#StockTransferVoucherDetails tr:last input.small-number').removeProp('oninput').prop('type', 'text').inputmask({
                alias: 'numeric', autoGroup: true, digits: 4, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
            });

            $('#StockTransferVoucherDetails tr:last select').select2({
                matcher: matchCustom
