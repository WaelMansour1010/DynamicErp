    //});


    function chooseItem(item)
    {
        let itemId = $(item).closest('tr').find('.items-prices-quantities-id').val();
        let itmId = $(item).closest('tr').find('.item-id').val();
        let exist = false;
        $('#StockTransferVoucherDetails tr').each(function () {
            let tr = $(this);
            if (tr.closest('tr').find('.item').val() == itemId) {
                exist = true;
            }
        });


        if (exist == false) {
            $('#StockTransferVoucherDetails .item:last').val(itemId);
            $('#StockTransferVoucherDetails .itemId:last').val(itmId);

            $('#StockTransferVoucherDetails .item-name:last').val($(item).closest('tr').find('.nameOfItem').text());
            $('#StockTransferVoucherDetails .name:last').text($(item).closest('tr').find('.nameOfItem').text());
            $('#StockTransferVoucherDetails .item:last').trigger('change');
        }

        $('.bs-example-modal-lg').modal('hide');
    }

     // check if item has expire date
    function isItemHasExpireDate(itemId) {
        let ItemHasExpiry = items.filter(function (i) { return i.Id == itemId; })[0].ItemHasExpiry;
        return ItemHasExpiry;
    }

    // Patch modal
    function showPatchModal(itemId, isNewItem, getZeroQunatity) {
        let ItemHasExpiry = isItemHasExpireDate(itemId);
        if (UseExpiryDateForItems && ItemHasExpiry == true) {
            $('#patchModal').modal('show');
            let itemPatches = [];
            //let itemId = $(item).closest('tr').find('.item-id').val();

            $.get('/Helper/PatchesByItemId?itemId=' + itemId + '&getZeroQunatity=' + getZeroQunatity).done(function (r) {
                itemPatches = r;
                let tr = '';

                // Add
                if (isNewItem) {
                    for (var i = 0; i < itemPatches.length; i++) {
                        tr += ('<tr><td>' + (itemPatches[i].PatchCode ? itemPatches[i].PatchCode : '') + '</td><td><input hidden class="itemId" value="' + itemId + '" /><input hidden class="itemPatchId" value="' + itemPatches[i].PatchId + '" /><label class="itemPatchExpireDate">' + (itemPatches[i].ExpiryDate != null ? convertToJavaScriptDate(itemPatches[i].ExpiryDate) : '') + '</label></td ><td><input hidden class="itemPatchesQty" value="' + itemPatches[i].Qty + '"/>' + itemPatches[i].Qty + '</td><td><button class="btn btn-info js-choose-patch-item">' + '@MyERP.Properties.Resources.Add' + '</button></td></tr > ');
                    }
                }
                else {
                    for (var i = 0; i < itemPatches.length; i++) {
                        tr += ('<tr><td>' + (itemPatches[i].PatchCode ? itemPatches[i].PatchCode : '') + '</td><td><input hidden class="itemId" value="' + itemId + '" /><input hidden class="itemPatchId" value="' + itemPatches[i].PatchId + '" /><label class="itemPatchExpireDate">' + (itemPatches[i].ExpiryDate != null ? convertToJavaScriptDate(itemPatches[i].ExpiryDate) : '') + '</label></td ><td><input hidden class="itemPatchesQty" value="' + itemPatches[i].Qty + '"/>' + itemPatches[i].Qty + '</td><td><button class="btn btn-info js-edit-patch-item">' + '@MyERP.Properties.Resources.Add' + '</button></td></tr > ');
                    }
                }

                $('#item-patches').empty().append(tr);
                $('#pleasewait').fadeOut();
            });
        }

    }

    //------------------- ConvertDate-------------
    function convertToJavaScriptDate(value) {

        if (value === null)
            return null;
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        return ((dt.getMonth() + 1 + "/" + dt.getDate() + "/" + dt.getFullYear()));
        // return (dt)
    }

     // Choose patch item to add
    $("#patchModal").on('click', '.js-choose-patch-item', function () {
        var tr = $(this).closest("tr");
        var patchId = tr.find(".itemPatchId").val();
        var expireDate = tr.find(".itemPatchExpireDate").text();
        var Qty = tr.find('.itemPatchesQty').val();
        $("#patchModal").modal('hide');
        $('#StockTransferVoucherDetails tr:last').find('.PatchId').val(patchId);
        $('#StockTransferVoucherDetails tr:last').find('.ExpiryDate').val(expireDate);

         // quantity of patch
        $('#StockTransferVoucherDetails tr:last').find('.quantityOnSystem').val(Qty);

        // Default Quantity In Pos
        $('#StockTransferVoucherDetails tr:last').find('.quantity').val('@ViewBag.DefaultQuantityInPos');
        $('#StockTransferVoucherDetails tr:last').find('.quantity').trigger('change');
    });

    // Double click on expire date
    $(document).on('dblclick', ".ExpiryDate", function () {
        var expireDateInput = $(this);
        selectedItemRowToEdit= expireDateInput.closest("tr");
        var itemId = selectedItemRowToEdit.find('.itemId').val();
        if (itemId) {
            showPatchModal(itemId,false,false);
        }
    });

    // Choose patch item to edit
    $("#patchModal").on('click', '.js-edit-patch-item', function () {
        var button = $(this);
        var tr = button.closest("tr");
        var patchId = tr.find(".itemPatchId").val();
        var expireDate = tr.find(".itemPatchExpireDate").text();
        var Qty = tr.find('.itemPatchesQty').val();
        $("#patchModal").modal('hide');
        var itemRowToEdit = selectedItemRowToEdit;
        $(itemRowToEdit).find('.ExpiryDate').val(expireDate);
        $(itemRowToEdit).find('.PatchId').val(patchId);

        // quantity of patch
        $(itemRowToEdit).find('.quantityOnSystem').val(Qty);

        // Default Quantity In Pos if no qty
        if ($(itemRowToEdit).closest('tr').find('.quantity').val() === "" || $(itemRowToEdit).closest('tr').find('.quantity').val() === undefined) {
            $(itemRowToEdit).closest('tr').find('.quantity').val('@ViewBag.DefaultQuantityInPos');
        }

        $(itemRowToEdit).closest('tr').find('.quantity').trigger('change');
    });

    $(document).on('change', '.item-name', function () {
        let itemName = $(this).val();
        if (!items.filter(function (i) { return i.ArName == itemName; }).length) {
            $(this).closest('tr').find('.item-name').val('');
            $(this).closest('tr').find('.name').text('');
            $(this).closest('tr').find('.item').val('').trigger('change');
            $(this).closest('tr').find('.item-unit').empty();
        }
    });

    $(document).on('change', '.item-unit', function () {
        let itemUnitId = $(this).val();
        let itemPrice = $(this).closest('tr').find('.item');
        let itemId = items.filter(function (i) { return i.ItemPriceId == itemPrice.val(); })[0].Id;
        getItemUnits(itemId).done(function (r) {
            let equiv = r.filter(function (i) { return i.Id == itemUnitId })[0].Equivalent;
            itemPrice.closest('tr').find('.unit-equavalent').val(equiv);
        });
    });

    $(document).on('change', '.item', function () {

        let itemPrice = $(this);
        let tr = itemPrice.closest('tr');

        if (itemPrice.closest('tr').find('.Add-Button').prop('hidden') == false) {
            itemPrice.closest('tr').find('.Add-Button').prop('hidden', true);
            //itemPrice.closest('tr').find('.popupCell').attr("onclick", "");
        }


        if (itemPrice.val() && items.length) {
            getItemQuantityOnSystem($(this));
            let item = items.filter(function (i) { return i.ItemPriceId == itemPrice.val(); })[0];
            itemPrice.closest('tr').find('.barcode').val(item.Barcode);
            //itemPrice.closest('tr').find('.price').val(item.Price);
            $.get('/Helper/GetItemAvgPrice?itemId=' + item.Id + '&departmentId=' + $('#DepartmentId').val()).done(function (r) {
                if (r) {
                    $(itemPrice).closest('tr').find('.cost').val(r);
                    $(itemPrice).closest('tr').find('.CostPriceBeforeIncrease').val(r);
                }
                else {
                    $(itemPrice).closest('tr').find('.cost').val('');
                    $(itemPrice).closest('tr').find('.CostPriceBeforeIncrease').val('');
                }
                $('#preloader, #status').fadeOut();
            }).fail(function () {
                $(itemPrice).closest('tr').find('.cost').val('');
                $(itemPrice).closest('tr').find('.CostPriceBeforeIncrease').val('');
                $('#preloader, #status').fadeOut();
            });
            itemPrice.closest('tr').find('.item-unit').empty().append('<option value="' + item.ItemUnitId + '">' + item.ItemUnitArName + '</option>');
            itemPrice.closest('tr').find('.unit-equavalent').val(item.Equivalent);

            // Barcode scanner
            if (isBarcodeScanned) {
                getDataFromBarcode(barcodeScannerCode, tr, false);
            }
            else {
                showPatchModal(item.Id, true, false);
            }

        } else {
            itemPrice.closest('tr').find('input[type="text"]').val('');
            itemPrice.closest('tr').find('select').empty();
        }
        $(this).closest('tr').find('.quantity').trigger('change');
        addToStockTransferVoucherDetails();
    });

