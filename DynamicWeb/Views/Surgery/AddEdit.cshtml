<script>
    //------------------ Chart Function ----------------//
    function CheckPart(e) {
        var part = $(e).attr('part');
        var id = $(e).attr('id');
        var OrganName = $('#OrganName').val()
        var arr = id.split("");
        if (OrganName) {
            var _Prevobj = jQuery("." + OrganName + "," + arr.slice().join(""));
            _Prevobj.css({ "fill": "none" });
        }
        if (anaconfig[id] != null && anaconfig[id].enabled === true) {
            var _obj = jQuery("#" + id + "," + arr.slice().join(""));
            _obj.css({ "fill": "rgba(255, 0, 0, 0.3)" });
            $('#OrganName').val(part);
        }
        else if (frt_config[id]!=null&&frt_config[id].enabled != 0) {
            $('#' + id).css({ 'fill': frt_config[id].downColor, 'fill-opacity': frt_config[id].downOpacity, 'stroke': frt_config[id].outlineDownColor, 'stroke-opacity': frt_config[id].outlineDownOpacity })
            $('#OrganName').val(part);
        }
        else if (bck_config[id]!=null&&bck_config[id].enable ===true) {
            $('#' + id).css({ 'fill': bck_config[id].downColor, 'fill-opacity': bck_config[id].downOpacity, 'stroke': bck_config[id].outlineDownColor, 'stroke-opacity': bck_config[id].outlineDownOpacity })
            $('#OrganName').val(part);
        }

    }
    //------------------------------------------------------------------//

    //--------------- Variables Declarations -------------------//
    let Patients = [];
    let DoctorOptions = '';
    var InsuranceCompanyPercentage = 0;
    //*********************************************************//
    //--------------- Ready Function -------------------//
    $(document).ready(function () {
        //$.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
        //    $("input[type|='datetime-local']").prop('min', r.PeriodStart).prop('max', r.PeriodEnd);
        //});
         $('#BookingDate').val('@ViewBag.BookingDate');
        $('#SurgeryDate').val('@ViewBag.SurgeryDate');

       

        if ($('#Id').val()) {
            // // To get Organ Name by Class
            var part = $('#OrganName').val();
            if (part) {
                $('.' + part).each(function () {
                    if ($(this).attr("id").split('_')[0] == "bck") {
                        $('.go_bck').trigger('click')
                    }
                    $(this).css({ 'fill': "rgba(255, 0, 0, 0.3)" });
                })
            }
            //----------------------------------------------------------------------//
        }
        else {
            SetDocNum();
            GetPatients();
            GetSpecialtyDoctor().then(function () {
                $("#DoctorId").empty().append(DoctorOptions);
            });
        }
    });
    //*********************************************************//
   //--------------- Event Functions -------------------//
    $(document).on('change', '#PatientId', function () {
        let Patient = Patients.filter(function (i) { return i.Id == $('#PatientId').val() })[0];
        if (Patient) {
            $('#PatientMobile').val(Patient.Mobile);
        }
    });
    $(document).on('change', '#MedicalSpecialtyId', function () {
        GetSpecialtyDoctor().then(function () {
            $("#DoctorId").empty().append(DoctorOptions);
            $('#DoctorId').trigger('change');
        });
    });
    $(document).on('change', '#DoctorPrice', function () {
        CalculateTotalPrice();
        GetInsuranceCompanyPercentage();
    });
    $(document).on('change', '#AssistantPrice', function () {
        CalculateTotalPrice();
        GetInsuranceCompanyPercentage();
    });
    $(document).on('change', '#NursePrice', function () {
        CalculateTotalPrice();
        GetInsuranceCompanyPercentage();
    });
    $(document).on('change', '#PatientPopUpBirthDate', function () {
        var age = CalculateAge($(this).val());
        $('#PatientPopUpAge').val(age)
    });
    $(document).on('change', '#InsuranceCompanyId', function () {
        GetInsuranceCompanyPercentage();
    });
    //----------------------------------------------------------------------------------------------------------//
    //--------------- Other Functions -------------------//
    function GetInsuranceCompanyPercentage() {
        if ($('#InsuranceCompanyId').val() > 0) {
            $.get('/Surgery/GetInsuranceCompanyPercentage?InsuranceCompanyId=' + $('#InsuranceCompanyId').val()).done(function (r) {
                InsuranceCompanyPercentage = r / 100;
            }).done(function () {
                CalculateInsuranceAndPatientRatio();
            });
        }
        else {
            $('#InsuranceRatio').val(0);
            $('#PatientRatio').val(0);
        }
    }
    function CalculateInsuranceAndPatientRatio() {
        if ($('#TotalPrice').inputmask('unmaskedvalue') != "") {
            var TotalPrice = $('#TotalPrice').inputmask('unmaskedvalue') != "" ? parseFloat($('#TotalPrice').inputmask('unmaskedvalue')) : 0.0;
            var InsuranceRatio = parseFloat(TotalPrice) * InsuranceCompanyPercentage;
            var PatientRatio = TotalPrice - InsuranceRatio;

            $('#InsuranceRatio').val(InsuranceRatio);
            $('#PatientRatio').val(PatientRatio);
        }
        else {
            alert('@MyERP.Properties.Resources.TotalPriceRequired')
        }

    }
    function SetDocNum() {
        var doc = $.get('/Surgery/SetDocNum').done(function (r) {
            $('#DocumentNumber').val(r);
        });
    }
    function deleteElement(e) {
        let tr = $(e).closest('tr');
        if ($(tr).index() == 0 && $(tr).closest('tbody').children('tr').length == 1) {
            $(tr).find("input").val('');
            $(tr).find("label").text('');
            $(tr).find('input, select').removeAttr('required');
            // $(tr).find('select').empty();
            $(tr).find('select').prop('selectedIndex', 0);
            $(tr).find('select').select2();
            e.parentNode.parentNode.parentNode.removeChild(e.parentNode.parentNode);
        }
        else if ($(tr).index() < $(tr).closest('tbody').children('tr').length - 1) {
            e.parentNode.parentNode.parentNode.removeChild(e.parentNode.parentNode);
        }
        else if ($(tr).index() == $(tr).closest('tbody').children('tr').length - 1) {
            $(tr).find("input").val('');
            $(tr).find('input, select').removeAttr('required');
            // $(tr).find('select').empty();
            $(tr).find('select').prop('selectedIndex', 0);
            $(tr).find('select').select2();
            $(tr).find("label").text('');
            e.parentNode.parentNode.parentNode.removeChild(e.parentNode.parentNode);
        }
    }
    function GetSpecialtyDoctor() {
        DoctorOptions = '';
        if ($('#MedicalSpecialtyId').val() > 0) {
            return requestData('/Surgery/GetSpecialtyDoctor?MedicalSpecialtyId=' + $('#MedicalSpecialtyId').val()).done(function (r) {
                for (var i = 0; i < r.length; i++) {
                    DoctorOptions += '<option value="' + r[i].Id + '">' + r[i].ArName + '</option>';
                }
            });
        }
    }
    function AddRays() {
        let Rays = $('#Ray').val();
        let tr = '<tr><td class="tabledit-edit-mode"><input type="hidden" class="RayId form-control tabledit-input form-control-sm" /><label class="RayArName control-label tabledit-input form-control-sm">' + Rays + '</label></td><td><a href="javascript:void(0);" onclick="deleteElement(this)"><i class="fas fa-trash-alt"></i></a></td></tr>';
        $("#SurgeryRaysTable").append(tr);
        $('#Ray').val('');
    }
    function AddAnalysis() {
        let Analysis = $('#Analysis').val();
        let tr = ' <tr><td class="tabledit-edit-mode"><input type="hidden" class="AnalysisId form-control tabledit-input form-control-sm" /><label class="AnalysisArName control-label tabledit-input form-control-sm"> ' + Analysis + '</label></td><td><a href="javascript:void(0);" onclick="deleteElement(this)"><i class="fas fa-trash-alt"></i></a></td></tr>';
        $('#SurgeryAnalysisTable').append(tr);
        $('#Analysis').val('');
    }
    function AddMedicine() {
        let ItemId = $('#ItemId').val();
        let ItemName = $('#ItemId option:selected').text();
        let Description = $('#Description').val();
        let tr = ' <tr><td class="tabledit-edit-mode"><input type="hidden" class="MedicineId form-control tabledit-input form-control-sm" /><input type="hidden" class="MedicineItemId form-control tabledit-input form-control-sm" value="' + ItemId + '" /><label class="MedicineArName control-label tabledit-input form-control-sm">' + ItemName + ' </label></td><td class="tabledit-edit-mode"><label class="MedicineDescription control-label tabledit-input form-control-sm"> ' + Description + ' </label></td><td><a href="javascript:void(0);" onclick="deleteElement(this)"><i class="fas fa-trash-alt"></i></a></td></tr>';
        $('#SurgeryMedicines').append(tr);
        $('#Description').val('');
        $('#ItemId').prop('selectedIndex', 0);
        $('#ItemId').select2();
    }
    function CalculateTotalPrice() {
        var DoctorPrice = $('#DoctorPrice').inputmask('unmaskedvalue') != "" ? $('#DoctorPrice').inputmask('unmaskedvalue') : 0.00;
        var AssistantPrice = $('#AssistantPrice').inputmask('unmaskedvalue') != "" ? $('#AssistantPrice').inputmask('unmaskedvalue') : 0.00;
        var NursePrice = $('#NursePrice').inputmask('unmaskedvalue') != "" ? $('#NursePrice').inputmask('unmaskedvalue') : 0.00;

        var TotalPrice = parseFloat(DoctorPrice) + parseFloat(AssistantPrice) + parseFloat(NursePrice);
        $('#TotalPrice').val(TotalPrice);
    }
    //**************************------------------------*******************************//

    //------------ Patient Data -------------------------//
    function GetPatients(refill) {
        if (refill == true)
            requestCache['/Surgery/GetPatients'] = null;
        return requestData('/Surgery/GetPatients').done(function (r) {
            Patients = r;
        });
    }
     $(document).on('click', '#AddPatient', function () {
        $('#AddPatientModal').modal("show");
    });
    $(document).on('keydown', '#PatientMobile', function (e) {
        if (e.which == 13 || e.keyCode == 13) {
            let elem = $(this);
            let mobileNo = elem.val();
            GetPatientByMobile(mobileNo);
        }
    });
    function GetPatientByMobile(MobileNo) {
        let Patient = Patients.filter(function (i) { return i.Mobile == MobileNo })[0];
        if (Patient) {
            $("#PatientId").val(Patient.Id).trigger('change');
            ShowPatientModal(Patient, false, null);
        }
        else {
            Swal.fire({
                title: '@MyERP.Properties.Resources.ThereIsNoPatientWithThisNoDoYouWantToAdd',
                text: " ",
                icon: 'info',
                showCancelButton: true,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                cancelButtonText: '@MyERP.Properties.Resources.Cancel',
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    ShowPatientModal(null, true, MobileNo);
                }
                else { result.dismiss; }
            });
        }
    }
    function CalculateAge(birthDate)
    {
        var now = new Date().getFullYear();
        var Age = parseInt(now) - parseInt(birthDate);
        return Age;
    }
    function ShowPatientModal(patient, isNew, mobileNo) {
        if (patient != null && isNew == false) {
            $("#PatientPopUpId").val(patient.Id);
            $("#PatientPopUpCode").val(patient.Code);
            $("#PatientPopUpArName").val(patient.ArName);
            var birthdate = convertToJavaScriptDate(patient.BirthDate)
            $("#PatientPopUpBirthDate").val(birthdate);
            var Age = CalculateAge(new Date(birthdate).getFullYear());
            $("#PatientPopUpAge").val(Age);
            //$("#PatientPopUpChronicDiseaseId").val(patient.ChronicDiseaseId);
            //$("#PatientPopUpChronicDisease").val(patient.ChronicDiseaseName);
            $("#PatientPopUpChronicDiseaseId").val(patient.ChronicDiseaseId).select2();
            $("#PatientPopUpNotes").val(patient.Notes);
            $("#PatientPopUpMobile").val(patient.Mobile);
            $("#PatientPopUpAddress").val(patient.Address);
        }
        else {
            if (mobileNo != "" && mobileNo != null)
                $("#PatientPopUpMobile").val(mobileNo);
            else
                $("#PatientPopUpMobile").val("");

            $("#PatientPopUpAge").val('');
            $("#PatientPopUpChronicDiseaseId").val(0);
            $("#PatientPopUpChronicDiseaseId").select2();
            $("#PatientPopUpBirthDate").val('');
            $("#PatientPopUpChronicDisease").val('');
            $("#PatientPopUpNotes").val('');
            $("#PatientPopUpMobile").val('');
            $("#PatientPopUpAddress").val('');
        }
        $('#AddPatientModal').modal("show");
    }
    function appendPatientOptions(refill) {
        return GetPatients(refill).then(function () {
            let PatientOptions = '';

            for (var i = 0; i < Patients.length; i++) {
                PatientOptions += '<option value="' + Patients[i].Id + '">' + Patients[i].ArName + ' - ' + Patients[i].Code + '</option>';
            }
            $('#PatientId').empty().append(PatientOptions);
            $('#PatientId').trigger('change');
        });
    }
    function AddPatient() {
        let valid = true;
        if ($("#PatientPopUpArName").val() == "") {
            $("#PatientPopUpArName").prop('required', true);
        }
        if ($("#AddPatientModal").find(".form-control:invalid").length > 0) {
            $("#AddPatientModal").find('.form-horizontal').addClass('was-validated');
            $('html, body').animate({
                scrollTop: $(".form-control:invalid").eq(0).offset().top - 80
            }, 500);
        } else {
            $('#preloader, #status').fadeIn();
            $.ajax(
                {
                    url: '/Patient/AddEdit', contentType: "application/json",
                    type: 'POST',
                    data: JSON.stringify({
                        Id: $("#PatientPopUpId").val() != "" ? $("#PatientPopUpId").val() : 0,
                        Code: $('#PatientPopUpCode').val(),
                        ArName: $("#PatientPopUpArName").val(),
                        Address: $('#PatientPopUpAddress').val(),
                        Mobile: $('#PatientPopUpMobile').val(),
                        Notes: $('#PatientPopUpNotes').val(),
                        ChronicDiseaseId: $('#PatientPopUpChronicDiseaseId').val(),
                        BirthDate: $('#PatientPopUpBirthDate').val(),
                    }),
                    error: function (e) {
                        $('#preloader, #status').fadeOut();
                    },
                    success: function (r) {
                        appendPatientOptions(true).then(function () { $('#PatientId').val($('#PatientId option:last-child').val()).trigger('change'); });
                        $('#AddPatientModal').modal('hide');
                        $('#preloader, #status').fadeOut();
                    }
                });
        }
    }
    //------------------------ End of Patient Data --------------------------------//

    //---------------------------------------------------------------- Surgery images gallery  --------------------------------------------------------------//
    function DeleteSurgery(url) {
        $("#SurgeryImages option[value='" + url + "']").remove();
    }
    function SurgerypreviewFile() {
        var reader = new FileReader();
        reader.addEventListener("load", function () {

            $("#Surgerygallery").append('<img style="max-width: 200px;max-height: 200px;margin-left: 2%;margin-bottom: 2%;" src="' + reader.result + '" alt="" /></a><i class="fas fa-trash-alt" style="cursor:pointer;" onclick="DeleteSurgery(\'' + reader.result + '\');$(this).prev().remove();$(this).remove();"></i>');
            $("#SurgeryImages").append("<option style='float: left;' selected=selected>" + reader.result + "</option>");
