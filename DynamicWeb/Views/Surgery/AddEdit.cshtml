@model MyERP.Models.Surgery

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.Surgeries;
}
<script src="~/Scripts/SaveAndNew.js"></script>
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                @if (Model != null)
                {
                    if (Model.IsDeleted == false)
                    {
                        if (ViewBag.Previous > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.First })" class="btn btn-info">@MyERP.Properties.Resources.First</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Previous })" class=" btn btn-info">&#8250;</a>
                        }
                        if (ViewBag.Next > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Next })" class="btn btn-info">&#8249;</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Last })" class="btn btn-info">@MyERP.Properties.Resources.Last</a>
                        }
                        <a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                    }
                }
                else
                {
                    <a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                }
            </div>
            <h4 class="page-title"> @MyERP.Properties.Resources.Surgeries </h4>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal needs-validation" role="form">
                        <div class="card">
                            <div class="card-body">
                                @Html.AntiForgeryToken()
                                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                @if (Model != null)
                                {
                                    @Html.HiddenFor(model => model.Id)
                                    @Html.HiddenFor(model => model.UserId)
                                    @Html.HiddenFor(model => model.IsDeleted)
                                    @Html.HiddenFor(model => model.Image)
                                }


                                <!-- Panel 1 -->
                                <div class="card">
                                    <div class="card-body">
                                        <div id="accordion">
                                            <h5 class=" pb-3 header-title">
                                                <a data-toggle="collapse" data-parent="#accordion" href="#collapse1">
                                                    @MyERP.Properties.Resources.MainData
                                                </a>
                                            </h5>
                                        </div>
                                        <div id="collapse1">
                                            <div class="form-group row">
                                                <label class=" col-sm-2 control-label" for="Id">@MyERP.Properties.Resources.Code</label>
                                                <div class="col-sm-4">
                                                    @Html.EditorFor(model => model.DocumentNumber, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly", placeholder = @MyERP.Properties.Resources.Code, required = "required" } })
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group row">
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.BookingDate</label>
                                                <div class="col-sm-4">
                                                    @Html.EditorFor(model => model.BookingDate, new { htmlAttributes = new { @class = "form-control", @type = "datetime-local", @required = "required" } })
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.SurgeryDate</label>
                                                <div class="col-sm-4">
                                                    @Html.EditorFor(model => model.SurgeryDate, new { htmlAttributes = new { @class = "form-control", @type = "datetime-local", @required = "required" } })
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-sm-12" style=" padding:1px;background-color: white;">
                                                <div style="background-color:white;">
                                                    <div class="row form-group">
                                                        <label class="control-label col-sm-2 PosCustomerIdDiv">@MyERP.Properties.Resources.Patient </label>
                                                        <div class="col-sm-4 PosCustomerIdDiv">
                                                            <div class="row ">
                                                                <div class="col-sm-10">
                                                                    @Html.DropDownListFor(model => model.PatientId, null, null, htmlAttributes: new { @class = "form-control", required = "required" })
                                                                    <div class="invalid-feedback">
                                                                        @MyERP.Properties.Resources.Required
                                                                    </div>
                                                                </div>
                                                                <div class="col-sm-2 pos-customer-model-btn" style="padding: 0;margin-right: -10px;">
                                                                    <button class="btn btn-success  btn-sm" id="AddPatient" data-toggle="modal"><i class="remixicon-user-add-fill"></i></button>
                                                                </div>
                                                            </div>
                                                        </div>

                                                        <label class="PosCustomerDetailsDiv col-sm-2 control-label" for="Phone">@MyERP.Properties.Resources.PatientMobile</label>
                                                        <div class="PosCustomerDetailsDiv col-sm-4">
                                                            <input type="text" class="form-control" id="PatientMobile" />
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="form-group row">
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.MedicalSpecialty</label>
                                                <div class="col-sm-4">
                                                    @Html.DropDownListFor(model => model.MedicalSpecialtyId, null, null, htmlAttributes: new { @class = "form-control", required = "required" })
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.Doctor</label>
                                                <div class="col-sm-4">
                                                    @Html.DropDownListFor(model => model.DoctorId, null, null, htmlAttributes: new { @class = "form-control", required = "required" })
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group row">
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.AssistantDoctor</label>
                                                <div class="col-sm-4">
                                                    @Html.DropDownListFor(model => model.AssistantDoctorId, null, null, htmlAttributes: new { @class = "form-control", required = "required" })
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.AssistantNurse</label>
                                                <div class="col-sm-4">
                                                    @Html.DropDownListFor(model => model.AssistantNurseId, null, null, htmlAttributes: new { @class = "form-control", required = "required" })
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="form-group row">
                                                <label class="col-sm-2 control-label"> @MyERP.Properties.Resources.TotalPrice </label>
                                                <div class="col-sm-4">
                                                    @Html.EditorFor(model => model.TotalPrice, new { htmlAttributes = new { @class = "form-control money", type = "text", @disabled = "disabled", @readonly = "readonly" } })
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                                <label class="col-sm-2 control-label"> @MyERP.Properties.Resources.DoctorPrice </label>
                                                <div class="col-sm-4">
                                                    @Html.EditorFor(model => model.DoctorPrice, new { htmlAttributes = new { @class = "form-control money", type = "text" } })
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group row">
                                                <label class="col-sm-2 control-label"> @MyERP.Properties.Resources.AssistantPrice </label>
                                                <div class="col-sm-4">
                                                    @Html.EditorFor(model => model.AssistantPrice, new { htmlAttributes = new { @class = "form-control money", type = "text" } })
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                                <label class="col-sm-2 control-label"> @MyERP.Properties.Resources.NursePrice </label>
                                                <div class="col-sm-4">
                                                    @Html.EditorFor(model => model.NursePrice, new { htmlAttributes = new { @class = "form-control money", type = "text" } })
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group row">
                                                <label class=" col-sm-2 control-label">@MyERP.Properties.Resources.Video</label>
                                                <div class="col-sm-4">
                                                    @Html.EditorFor(model => model.Video, new
                                                    {
                                                        htmlAttributes = new
                                                        {
                                                            @class = "form-control",
                                                            placeholder = @MyERP.Properties.Resources.Video,@*required = "required",*@type = "text"
                                                        }
                                                    })
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.InsuranceCompany</label>
                                                <div class="col-sm-4">
                                                    @Html.DropDownListFor(model => model.InsuranceCompanyId, null, MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group row">
                                                <label class="col-sm-2 control-label"> @MyERP.Properties.Resources.InsuranceRatio </label>
                                                <div class="col-sm-4">
                                                    @Html.EditorFor(model => model.InsuranceRatio, new { htmlAttributes = new { @class = "form-control money", type = "text", @disabled = "disabled", @readonly = "readonly" } })
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                                <label class="col-sm-2 control-label"> @MyERP.Properties.Resources.PatientRatio </label>
                                                <div class="col-sm-4">
                                                    @Html.EditorFor(model => model.PatientRatio, new { htmlAttributes = new { @class = "form-control money", type = "text", @disabled = "disabled", @readonly = "readonly" } })
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group row">
                                                <label class="control-label col-sm-2" for="Notes">@MyERP.Properties.Resources.Notes</label>
                                                <div class="col-sm-4">
                                                    <textarea id="Notes" name="Notes" class="form-control" rows="5" cols="5">@if (Model != null) { @Model.Notes; }</textarea>
                                                </div>
                                            </div>
                                            @* مكان صور الجراحة *@
                                            <div class="form-group row">
                                                <div id="Surgerygallery" style="width: 100%;margin: 20px;">
                                                    @{ if (Model != null && Model.SurgeryImages != null)
                                                        {
                                                            foreach (MyERP.Models.SurgeryImage img in Model.SurgeryImages)
                                                            {
                                                                <img onclick="SurgeryShowModal(this)" data-toggle="modal" data-target="#ImageModal" src="@img.Image" alt="" class="img_@img.Id" style="max-width: 200px;max-height: 200px;" />
                                                                <i class="fas fa-trash-alt img_@img.Id" style="cursor:pointer;" onclick="DeleteSurgery('@img.Id');$(this).prev().remove();$(this).remove();"></i>
                                                            }
                                                        }
                                                    }
                                                </div>
                                                <input type="file" id="SurgeryBrowseImage" onchange="SurgerypreviewFile()" value="Browse" multiple />
                                                <div style="display:none;">
                                                    @Html.ListBoxFor(i => i.SurgeryImages, new SelectList(Model == null ? new List<MyERP.Models.SurgeryImage>() : Model.SurgeryImages, "Id", "Image", Model == null ? null : Model.SurgeryImages), new { @class = "form-control1", placeholder = "Surgery" })
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <!-- End Of Panel 1 -->
                                <!-- Panel 2 -->
                                <div class="card">
                                    <div class="card-body">
                                        <div id="accordion">
                                            <h5 class=" pb-3 header-title">
                                                <a data-toggle="collapse" data-parent="#accordion" href="#collapse2">
                                                    @MyERP.Properties.Resources.MedicalRadiology
                                                </a>
                                            </h5>
                                        </div>
                                        <div id="collapse2">
                                            <div class="form-group row">
                                                <label for="inputtext3" class="col-sm-2 control-label"> @MyERP.Properties.Resources.MedicalRadiology </label>
                                                <div class="col-sm-4">
                                                    <input class="form-control" type="text" id="Ray" />
                                                </div>
                                                <div class="col-sm-6">
                                                    <input type="button" value="@MyERP.Properties.Resources.Add" onclick="AddRays()" class="add-row b btn btn-success" />
                                                </div>
                                            </div>
                                            @* مكان صور الأشعة *@
                                            <div class="form-group row">
                                                <div id="SurgeryRaysgallery" style="width: 100%;margin: 20px;">
                                                    @{ if (Model != null && Model.SurgeryRayImages != null)
                                                        {
                                                            foreach (MyERP.Models.SurgeryRayImage img in Model.SurgeryRayImages)
                                                            {
                                                                <img onclick="SurgeryRaysShowModal(this)" data-toggle="modal" data-target="#ImageModal" src="@img.Image" alt="" class="img_@img.Id" style="max-width: 200px;max-height: 200px;" />
                                                                <i class="fas fa-trash-alt img_@img.Id" style="cursor:pointer;" onclick="DeleteSurgeryRays('@img.Id');$(this).prev().remove();$(this).remove();"></i>
                                                            }
                                                        }
                                                    }
                                                </div>
                                                <input type="file" id="SurgeryRaysBrowseImage" onchange="SurgeryRayspreviewFile()" value="Browse" multiple />
                                                <div style="display:none;">
                                                    @Html.ListBoxFor(i => i.SurgeryRayImages, new SelectList(Model == null ? new List<MyERP.Models.SurgeryRayImage>() : Model.SurgeryRayImages, "Id", "Image", Model == null ? null : Model.SurgeryRayImages), new { @class = "form-control1", placeholder = "Surgery Rays" })
                                                </div>
                                            </div>
                                            <div class="table-responsive">
                                                <table class="table table-centered mb-0">
                                                    <thead>
                                                        <tr>
                                                            <th>@MyERP.Properties.Resources.Name</th>
                                                            <th>@MyERP.Properties.Resources.Delete</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody id="SurgeryRaysTable">
                                                        @if (Model != null && Model.Id > 0)
                                                        {
                                                            foreach (var item in Model.SurgeryRays)
                                                            {
                                                                <tr>
                                                                    <td class="tabledit-edit-mode">
                                                                        <input type="hidden" class="RayId form-control tabledit-input form-control-sm" value="@item.Id" />
                                                                        <label class="RayArName control-label tabledit-input form-control-sm"> @item.ArName </label>
                                                                    </td>
                                                                    <td>
                                                                        <a href="javascript:void(0);" onclick="deleteElement(this)">
                                                                            <i class="fas fa-trash-alt"></i>
                                                                        </a>
                                                                    </td>
                                                                </tr>
                                                            }
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <!-- End Of Panel 2 -->
                                <!-- Panel 3 -->
                                <div class="card">
                                    <div class="card-body">
                                        <div id="accordion">
                                            <h5 class=" pb-3 header-title">
                                                <a data-toggle="collapse" data-parent="#accordion" href="#collapse3">
                                                    @MyERP.Properties.Resources.MedicalAnalysis
                                                </a>
                                            </h5>
                                        </div>
                                        <div id="collapse3">
                                            <div class="form-group row">
                                                <label for="inputtext3" class="col-sm-2 control-label"> @MyERP.Properties.Resources.MedicalAnalysis </label>
                                                <div class="col-sm-4">
                                                    <input class="form-control" type="text" id="Analysis" />
                                                </div>
                                                <div class="col-sm-6">
                                                    <input type="button" value="@MyERP.Properties.Resources.Add" onclick="AddAnalysis()" class="add-row b btn btn-success" />
                                                </div>
                                            </div>
                                            @* مكان صور التحاليل *@
                                            <div class="form-group row">
                                                <div id="SurgeryAnalysisgallery" style="width: 100%;margin: 20px;">
                                                    @{ if (Model != null && Model.SurgeryAnalysisImages != null)
                                                        {
                                                            foreach (MyERP.Models.SurgeryAnalysisImage img in Model.SurgeryAnalysisImages)
                                                            {
                                                                <img onclick="SurgeryAnalysisShowModal(this)" data-toggle="modal" data-target="#ImageModal" src="@img.Image" alt="" class="img_@img.Id" style="max-width: 200px;max-height: 200px;" />
                                                                <i class="fas fa-trash-alt img_@img.Id" style="cursor:pointer;" onclick="DeleteSurgeryAnalysis('@img.Id');$(this).prev().remove();$(this).remove();"></i>
                                                            }
                                                        }
                                                    }
                                                </div>
                                                <input type="file" id="SurgeryAnalysisBrowseImage" onchange="SurgeryAnalysispreviewFile()" value="Browse" multiple />
                                                <div style="display:none;">
                                                    @Html.ListBoxFor(i => i.SurgeryAnalysisImages, new SelectList(Model == null ? new List<MyERP.Models.SurgeryAnalysisImage>() : Model.SurgeryAnalysisImages, "Id", "Image", Model == null ? null : Model.SurgeryAnalysisImages), new { @class = "form-control1", placeholder = "Surgery Analysis" })
                                                </div>
                                            </div>
                                            <div class="table-responsive">
                                                <table class="table table-centered mb-0">
                                                    <thead>
                                                        <tr>
                                                            <th>@MyERP.Properties.Resources.Name</th>
                                                            <th>@MyERP.Properties.Resources.Delete</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody id="SurgeryAnalysisTable">
                                                        @if (Model != null && Model.Id > 0)
                                                        {
                                                            foreach (var item in Model.SurgeryAnalysis)
                                                            {
                                                                <tr>
                                                                    <td class="tabledit-edit-mode">
                                                                        <input type="hidden" class="AnalysisId form-control tabledit-input form-control-sm" value="@item.Id" />
                                                                        <label class="AnalysisArName control-label tabledit-input form-control-sm"> @item.ArName </label>
                                                                    </td>
                                                                    <td>
                                                                        <a href="javascript:void(0);" onclick="deleteElement(this)">
                                                                            <i class="fas fa-trash-alt"></i>
                                                                        </a>
                                                                    </td>
                                                                </tr>
                                                            }
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <!-- End Of Panel 3 -->
                                <!-- Panel 4 -->
                                <div class="card">
                                    <div class="card-body">
                                        <div id="accordion">
                                            <h5 class=" pb-3 header-title">
                                                <a data-toggle="collapse" data-parent="#accordion" href="#collapse4">
                                                    @MyERP.Properties.Resources.Medicines
                                                </a>
                                            </h5>
                                        </div>
                                        <div id="collapse4">
                                            <div class="form-group row">
                                                <label for="inputtext3" class="col-sm-2 control-label"> @MyERP.Properties.Resources.Medicines </label>
                                                <div class="col-sm-3">
                                                    @Html.DropDownList("ItemId", null, null, htmlAttributes: new { @class = "form-control" })
                                                </div>
                                                <label for="inputtext3" class="col-sm-2 control-label"> @MyERP.Properties.Resources.Description </label>
                                                <div class="col-sm-3">
                                                    <input class="form-control" type="text" id="Description" />
                                                </div>
                                                <div class="col-sm-2">
                                                    <input type="button" value="@MyERP.Properties.Resources.Add" onclick="AddMedicine()" class="add-row b btn btn-success" />
                                                </div>
                                            </div>

                                            <div class="table-responsive">
                                                <table class="table table-centered mb-0">
                                                    <thead>
                                                        <tr>
                                                            <th>@MyERP.Properties.Resources.Name</th>
                                                            <th>@MyERP.Properties.Resources.Description</th>
                                                            <th>@MyERP.Properties.Resources.Delete</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody id="SurgeryMedicines">
                                                        @if (Model != null && Model.Id > 0)
                                                        {
                                                            foreach (var item in Model.SurgeryMedicines)
                                                            {
                                                                <tr>
                                                                    <td class="tabledit-edit-mode">
                                                                        <input type="hidden" class="MedicineId form-control tabledit-input form-control-sm" value="@item.Id" />
                                                                        <input type="hidden" class="MedicineItemId form-control tabledit-input form-control-sm" value="@item.ItemId" />
                                                                        <label class="MedicineArName control-label tabledit-input form-control-sm"> @item.Item.ArName </label>
                                                                    </td>
                                                                    <td class="tabledit-edit-mode">
                                                                        <label class="MedicineDescription control-label tabledit-input form-control-sm"> @item.Description </label>
                                                                    </td>
                                                                    <td>
                                                                        <a href="javascript:void(0);" onclick="deleteElement(this)">
                                                                            <i class="fas fa-trash-alt"></i>
                                                                        </a>
                                                                    </td>
                                                                </tr>
                                                            }
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <!-- End Of Panel 4 -->
                                <!-- Panel 5 -->
                                <div class="card">
                                    <div class="card-body">
                                        <div id="accordion">
                                            <h5 class=" pb-3 header-title">
                                                <a data-toggle="collapse" data-parent="#accordion" href="#collapse5">
                                                    @MyERP.Properties.Resources.OrganAppliedSurgery
                                                </a>
                                            </h5>
                                        </div>
                                        <div id="collapse5">
                                            <div class="form-group row">
                                                <label for="inputtext3" class="col-sm-2 control-label"> @MyERP.Properties.Resources.OrganName </label>
                                                <div class="col-sm-3">
                                                    @Html.EditorFor(model => model.OrganName, new { htmlAttributes = new { @class = "form-control", type = "text", @disabled = "disabled", @readonly = "readonly" } })
                                                </div>
                                               
                                            </div>

                                            <div class="row">
                                                <div class="col-4">
                                                    <div class="card">
                                                        <div class="card-body">
                                                            @*<div id="accordion">
                            <h5 class="header-title">
                                <a data-toggle="collapse" data-parent="#accordion" href="#collapse3">
                                    @MyERP.Properties.Resources.OrganAppliedSurgery
                                </a>
                            </h5>
                        </div>  <br />*@
                                                            <div @*id="collapse3"*@>
                                                                <div class="form-group row">
                                                                    <div class="col-sm-3">
                                                                        @Html.Partial("_FaceChart")
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="col-8">
                                                    <div class="card">
                                                        <div class="card-body">
                                                            @*<div id="accordion">
                            <h5 class="header-title">
                                <a data-toggle="collapse" data-parent="#accordion" href="#collapse3">
                                    @MyERP.Properties.Resources.OrganAppliedSurgery
                                </a>
                            </h5>
                        </div>
                        <br />*@
                                                            <div id="collapse3">
                                                                <div class="form-group row">
                                                                    <div class="col-sm-3">
                                                                        @Html.Partial("_BodyChart")
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <!-- End Of Panel 5 -->

                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-------------------------------------------------------------------------------------------------------->
            <div class="row">
                <div class="col-sm-offset-2">
                    @if (Model == null)
                    {
                        <button onclick="addEdit('new');" class="btn btn-success" id="newbtn">
                            @MyERP.Properties.Resources.SaveAndNew
                        </button>
                        <button onclick="addEdit();" class="btn btn-success" id="save">
                            @MyERP.Properties.Resources.Save
                        </button>
                        <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                    }
                    else if (Model.IsDeleted == false)
                    {
                        <button onclick="addEdit();" class="btn btn-success" id="save">
                            @MyERP.Properties.Resources.Save
                        </button>
                        <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                        <a href="javascript:void(0);" class="btn btn-danger" onclick="Delete(@Model.Id)" role="button">@MyERP.Properties.Resources.Delete</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

