<div class="panel panel-widget forms-panel">
    <div class="forms">
        <div class=" form-grids form-grids-right">
            <div class="widget-shadow " data-example-id="basic-forms">
                <div class="form-title">
                    <input type="button" class="btn btn-info btnAdd" name="AddEdit" value="رجوع" onclick="back('@ViewContext.RouteData.Values["controller"].ToString()')" style="float:left;">
                    <h4>بيانات جهة الاتصال :</h4>
                </div>
                <div class="form-body">
                    <form class="form-horizontal">
                        <div class="form-group">
                            <label for="inputtext3" class="col-sm-3 control-label">الكود</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" name="txtCode" id="txtCode" placeholder="الكود" required>
                                <span class="Asterisks">*</span>
                            </div>

                        </div>
                        <div class="form-group">
                            <label for="inputtext3" class="col-sm-3 control-label">الاسم العربى</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" name="txtArName" id="txtArName" placeholder="الاسم العربى" required>
                                <span class="Asterisks">*</span>
                            </div>

                        </div>
                        <div class="form-group">
                            <label for="inputtext3" class="col-sm-3 control-label">الاسم الانجليزى</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="txtEnName" placeholder="الاسم الانجليزى">
                            </div>
                        </div>

  
                      
                        <div class="form-group">
                            <label for="inputtext3" class="col-sm-3 control-label">رقم الهاتف</label>
                            <div class="col-sm-9">
                                <input type="number" step="any" class="form-control" id="txtTel1" placeholder="تليفون1">
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="inputtext3" class="col-sm-3 control-label">رقم الموبيل</label>
                            <div class="col-sm-9">
                                <input type="number" step="any" class="form-control" id="txtTel2" placeholder="تليفون2">
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="inputtext3" class="col-sm-3 control-label">فاكس</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="txtFax" placeholder="فاكس">
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="inputtext3" class="col-sm-3 control-label">البريد الاليكترونى</label>
                            <div class="col-sm-9">
                                <input type="email" class="form-control" id="txtEmail" placeholder="البريد الاليكترونى">
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="inputtext3" class="col-sm-3 control-label">العنوان</label>
                            <div class="col-sm-9">
                                <input type="email" class="form-control" id="Address" placeholder="العنوان">
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="inputtext3" class="col-sm-3 control-label">المدينة</label>
                            <div class="col-sm-9">
                                <select id="ddlCityId" name="ddlCityId" class="form-control"></select>
                                
                            </div>
                        </div>
                  
                        <div class="form-group">
                            <label for="inputtext3" class="col-sm-3 control-label">ملاحظات</label>
                            <div class="col-sm-9">
                                <textarea type="text" class="form-control" id="txtNotes" placeholder="ملاحظات"></textarea>

                            </div>
                        </div>
                        <div class="col-sm-offset-2">
                            <button type="button" class="btn btn-success" onclick="save()">
                                حفظ
                            </button>
                            <button type="reset" class="btn btn-danger" onclick="back('@ViewContext.RouteData.Values["controller"].ToString()')">
                                رجوع
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<input type="hidden" id="hdnobjID" />
<input type="hidden" id="hdnUserId" />
<input type="hidden" id="hdnIsDeleted" />
<input type="hidden" id="hdnIsActive"  />
<input type="hidden" id="hdnImage"/>
<script>


    FillcityDDL();
    function save() {

        CheckInputs();

        if ($("form").valid() && $('.error:visible').length == 0) {
            $('#preloader, #status').fadeIn();
            $.ajax(
                {
                    url: MainDomain + 'api/Contacts/' + $('#hdnobjID').val(),
                    type: ((@ViewBag.ID.ToString() != '') ? 'PUT' : 'POST'),
                    data: {
                        "Id": $('#hdnobjID').val(),
                        "Code": $('#txtCode').val(),
                        "ArName": $('#txtArName').val(),
                        "EnName": $('#txtEnName').val(),
                   
                       
                        "MobileNo": $('#txtTel1').val(),
                        "PhoneNo": $('#txtTel2').val(),
                      
                        "Fax": $('#txtFax').val(),
                        "Email": $('#txtEmail').val(),
                        "CityId": $('#ddlCityId').val(),
                        "Address": $('#Address').val(),
                        "Notes": $('#txtNotes').val(),
                        "UserId": $('#hdnUserId').val(),
                        "IsDeleted": (@ViewBag.ID.ToString() != '') ? $('#hdnIsDeleted').val() : false,
                        "IsActive": (@ViewBag.ID.ToString() != '') ? $('#hdnIsActive').val() : true,
                        "Image": (@ViewBag.ID.ToString() != '') ? $('#hdnImage').val() : true,
                    },
                    beforeSend: function (xhr) {
                        xhr.setRequestHeader('Authorization', 'Bearer ' + $("#userToken").val());
                    },
                    error: function (e) {
                        if (e.responseJSON.Message == 'Duplicate Code Found') {
                            alert("الكود موجود بالفعل");
                            $('#preloader, #status').fadeOut();
                        } else
                            window.location = '/logout/';
                    },
                    success: function (r) {
                        back('@ViewContext.RouteData.Values["controller"].ToString()');
                    }
                });
        } else {
            CheckSave();
            $("label.error").html('يرحى ادخال هذا الحقل');
            $('html').animate({ scrollTop: $('.error:visible').offset().top - 170 }, '500', 'swing');
        }
    }

    if (@ViewBag.ID.ToString() != '') {

        $.ajax(
            {
                url: MainDomain + 'api/Contacts/@ViewBag.ID.ToString()',
                type: 'Get',
                beforeSend: function (xhr) {
                    xhr.setRequestHeader('Authorization', 'Bearer ' + $("#userToken").val());
                },
                error: function (e) {
                    console.log(e);
                    window.location = '/logout/';
                },
                success: function (r) {

                    if (r != null) {
                        $('#txtAddress').val(r['Address']);
                        $('#txtArName').val(r['ArName']);
                        $('#CompanyName').val(r['CompanyName']);
                     

                        $('#txtCode').val(r['Code']);
                        $('#txtEmail').val(r['Email']);
                        $('#txtEnName').val(r['EnName']);
                        $('#txtFax').val(r['Fax']);
                 
                        $('#txtSite').val(r['Site']);
                        $('#txtTel1').val(r['MobileNo']);
                        $('#txtTel2').val(r['PhoneNo']);

                        $('#hdnImage').val(r['Image']);
                        $('#hdnobjID').val(r['Id']);
                        $('#hdnUserId').val(r['UserId']);
                        $('#hdnIsDeleted').val(r['IsDeleted']);
                        $('#hdnIsActive').val(r['IsActive']);

                        FillAutoCompelete();
                    }

                    $('#preloader, #status').fadeOut();
                }
            });
    }

</script>
