                    <div class="card">
                        <div class="card-body">
                            <h5 class="header-title">@MyERP.Properties.Resources.Service</h5>
                            <div class="form-horizontal needs-validation" role="form">
                                <input hidden id="hasDetails" />
                                <div class="table-responsive">
                                    <table class="table table-centered mb-0">
                                        <thead>
                                            <tr>
                                                <th> @MyERP.Properties.Resources.Service</th>
                                                <th> @MyERP.Properties.Resources.Choose </th>

