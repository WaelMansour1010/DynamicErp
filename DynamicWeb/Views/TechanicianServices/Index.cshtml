            </div>
            <div class="row">
                <div class="col-sm-offset-2">
                    @if (Model == null)
                    {

                        <button type="button" id="newbtn" onclick="addEdit('new')" class="btn btn-success">
                            @MyERP.Properties.Resources.SaveAndNew
                        </button>
                        <button class="btn btn-success" id="save" onclick="addEdit()">
                            @MyERP.Properties.Resources.Save
                        </button>
                        <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                    }
                    else if (Model.IsDeleted == false)
                    {

                        <button class="btn btn-success" id="save" onclick="addEdit()">
                            @MyERP.Properties.Resources.Save
                        </button>
                        <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                        <button class="btn btn-danger" onclick="Delete(@Model.Id)">
                            @MyERP.Properties.Resources.Delete
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<script>

    $('#EmployeeId').on('change', function () {
        GetServiceCategory();
    });

    function GetServiceCategory() {
        if ($('#EmployeeId').val()) {
            $('#preloader, #status').fadeIn();
            $.get('/TechanicianServices/GetServiceCategory?EmployeeId=' + $('#EmployeeId').val()).done(function (r) {
                console.log("GetServiceCategory: ",r)
                $('#services').empty();
                $('#services').append('<tr><td class="col-sm-8">@MyERP.Properties.Resources.All</td><td class="col-sm-4"><input type="checkbox" id="checkAll" onclick="All()" /></td></tr>' + r);
                $('#preloader, #status').fadeOut();
            });
        }
    }



    $(document).on('change', 'input[type="checkbox"]:not("#checkAll")', function () {
        $(this).prop('checked') ? null : $('#checkAll').removeAttr('checked');
    });

    function All() {
        if ($('#checkAll').prop('checked')) {
            $('input[type="checkbox"]').prop('checked', 'checked');
        } else {
            $('input[type="checkbox"]').removeAttr('checked');
        }
    }

    function addEdit(n) {
        var valid = true;
        if ($(".form-control:invalid").length > 0) {
            $('.form-horizontal').addClass('was-validated');
            $('html, body').animate({
                scrollTop: $(".form-control:invalid").eq(0).offset().top - 80
            }, 500);
            console.log($(".form-control:invalid"));
            valid = false;
        }
        if (!$('#services tr').find('.ServiceId').val()) {
            valid = false;
            alert('برجاء اختيار الخدمة !')
        }

        if (valid) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.AreYouSureYouWantToSave',
                text: " ",
                icon: 'info',
                showCancelButton: true,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                cancelButtonText: '@MyERP.Properties.Resources.Cancel',
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    $('#preloader, #status').fadeIn();
                    $('#newbtn').prop('disabled', true);
                    $('#save').prop('disabled', true);
                    var techanicianServices = [];
                    $('#services tr').each(function () {
                        var td = $(this);
                        if (td.find('.ServiceId').val()) {
                            var service = {
                                ServiceId: td.find('.ServiceId').val(),
                               // TechanicianId: $('#TechnicianId').val(),
                                Choosen: td.find('.Choosen').prop('checked'),
                                IsDeleted: false,
                                IsActive: true,
                                EmployeeId: $('#EmployeeId').val(),
                            };
                            techanicianServices.push(service);}
                    });
                    if ($('#hasDetails').val() == 1) {
                        var data = {
                            techanicianServiceList: techanicianServices,
                           // ParentId: $('#deviceType').val()
                             EmployeeId: $('#EmployeeId').val(),
                        }
                    }
                    else if ($('#hasDetails').val() == 0) {
                        var data = {
                            techanicianServiceList: techanicianServices,
                           // ParentId: $('#mainServiceCat').val()
                             EmployeeId: $('#EmployeeId').val(),
                        }
                    }
                    if (!$('#EmployeeId').val()) {
                        valid = false;
                        alert('برجاء اختيار الفنى !')
                    }
                    $.ajax({
                        type: "POST",
                        url: "/TechanicianServices/Index",
                        data: data,
                        success: function (r) {
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.Saved',
                                text: " ",
                                icon: 'success',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                            $('#preloader, #status').fadeOut();
                            location.reload();
                        },
                        error: function (r) {
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.NotSaved',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });

                            $('#preloader, #status').fadeOut();
                        }
                    })
                }
                else { result.dismiss; }
            });
        }
    }


    $('#TechnicianId').on('change', function () {
        if ($('#TechnicianId').val() != 0) {
            $('#mainServiceCat').removeAttr('disabled');
        }
        else {

            $('#mainServiceCat').attr('disabled');
        }
    });

    $('#mainServiceCat').on('change', function () {

        $('#deviceType').empty();


        $('#deviceType').removeAttr('disabled');

        $.get('/TechanicianServices/SubServiceCategories/' + $(this).val()).done(function (r) {
            if (r.HasDetails == "false") {
                $('#deviceType').attr('disabled', 'disabled');
                if ($('#TechnicianId').val() != 0) {
                    $('#preloader, #status').fadeIn();
                    var techId = $('#TechnicianId').val();
                    var parentId = $('#mainServiceCat').val();
                    $('#hasDetails').val(0);
                    $.get('/TechanicianServices/_TechnicianServices?techId=' + techId + '&parentId=' + parentId + '&hasDetails=' + 0).done(function (r) {
                        $('#services').empty();
                        $('#services').append('<tr><td class="col-sm-8">@MyERP.Properties.Resources.All</td><td class="col-sm-4"><input type="checkbox" id="checkAll" onclick="All()" /></td></tr>' + r);
                        $('#preloader, #status').fadeOut();
                    });
                }
                else {
                    Swal.fire({
                        title: '@MyERP.Properties.Resources.SelectTechnicianFirst',
                        text: " ",
                        icon: 'info',
                        showCancelButton: false,
                        confirmButtonText: '@MyERP.Properties.Resources.Ok',
                        confirmButtonColor: '#3085d6'
                    });
                }
            } else {
                $('#hasDetails').val(1);
                $('#deviceType').append($('<option>', {
                    value: 0,
                    text: '@MyERP.Properties.Resources.Select'
                }));
                for (var i = 0; i < r.ServicesCategories.length; i++) {
                    $('#deviceType').append($('<option>', {
                        value: r.ServicesCategories[i].Id,
                        text: r.ServicesCategories[i].ArName
                    }));
                }
            }
            if ($('#hdnobjID').val() > 0 && parentCategories[0].HasDetails == true) {
                $('#deviceType').val(parentCategories[1].Id).trigger('change');
            }
        });
    });

    $(document).on('change', '#deviceType', function () {
        if ($('#TechnicianId').val() != 0) {
            $('#preloader, #status').fadeIn();
            var techId = $('#TechnicianId').val();
            var parentId = $('#deviceType').val();
            $.get('/TechanicianServices/_TechnicianServices?techId=' + techId + '&parentId=' + parentId + '&hasDetails=' + 1).done(function (r) {
                console.log("Service: ",r)
                $('#services').empty();
                $('#services').append('<tr><td class="col-sm-8">@MyERP.Properties.Resources.All</td><td class="col-sm-4"><input type="checkbox" id="checkAll" onclick="All()" /></td></tr>' + r);
                $('#preloader, #status').fadeOut();
            });
        }
        else {
            Swal.fire({
                title: '@MyERP.Properties.Resources.SelectTechnicianFirst',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
            $('#mainServiceCat').trigger('change');
        }
    });


