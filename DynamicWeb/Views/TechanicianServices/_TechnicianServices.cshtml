@model IEnumerable<MyERP.Models.GetTechnicianServices_Result>

@foreach (var item in Model)
{
    <tr>
        <td class="col-sm-8">
            <input class="ServiceId" type="hidden" value="@item.Id" />
            @Html.DisplayFor(modelItem => item.ArName)
        </td>
 
        <td class="col-sm-4">
            @if (item.Allow == "true")
            {

                <input type="checkbox" class="Choosen" checked />

            }
            else
            {

                <input type="checkbox" class="Choosen"  />
            }
        </td>

    </tr>
}

