
<div class="panel panel-widget forms-panel">
    <div class="forms">
        <div class=" form-grids form-grids-right">
            <div class="widget-shadow " data-example-id="basic-forms">
                <div class="form-title">
                    <input type="button" class="btn btn-info btnAdd" name="AddEdit" value="رجوع" onclick="back('@ViewContext.RouteData.Values["controller"].ToString()')" style="float:left;">
                    <h4>بيانات الفنى :</h4>
                </div>
                <div class="form-body">
                    <form class="form-horizontal">
                        <div class="form-group">
                            <label for="inputtext3" class="col-sm-3 control-label"> الكود</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" name="code" id="code" placeholder="الكود " required>
                                <span class="Asterisks">*</span>
                            </div>

                        </div>
                        <div class="form-group">
                            <label for="inputtext3" class="col-sm-3 control-label">  اسم الفنى عربي</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" name="txtArName" id="txtArName" placeholder="الاسم العربى" required>
                                <span class="Asterisks">*</span>
                            </div>

                        </div>
                        <div class="form-group">
                            <label for="inputtext3" class="col-sm-3 control-label">  اسم الفنى انجليزى</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" name="txtEnName" id="txtEnName" placeholder="الاسم الانجليزى" >
                                
                            </div>

                        </div>
                        <div class="form-group">
                            <label for="inputtext3" class="col-sm-3 control-label">  رقم التليفون1</label>
                            <div class="col-sm-9">
                                <input type="number" step="any" class="form-control" name="phone1" id="phone1" placeholder="رقم التليفون1">

                            </div>

                        </div>
           
                        <div class="form-group">
                            <label for="inputtext3" class="col-sm-3 control-label">  رقم التليفون2</label>
                            <div class="col-sm-9">
                                <input type="number" step="any" class="form-control" name="phone2" id="phone2" placeholder="رقم التليفون2" >

                            </div>

                        </div>

                        <div class="form-group">
                            <label for="inputtext3" class="col-sm-3 control-label">  العنوان</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" name="address" id="address" placeholder="العنوان" >

                            </div>

                        </div>

                        <div class="col-sm-offset-2">
                            <button type="button" class="btn btn-success" onclick="save()">
                                حفظ
                            </button>
                            <button type="reset" class="btn btn-danger" onclick="back('@ViewContext.RouteData.Values["controller"].ToString()')">
                                رجوع
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<input type="hidden" id="hdnobjID" />
<input type="hidden" id="hdnUserId" />
<input type="hidden" id="hdnIsDeleted" />
<input type="hidden" id="hdnIsActive" />
<input type="hidden" id="hdnImage" />
<script>


    function save() {

        CheckInputs();

        if ($("form").valid() && $('.error:visible').length == 0) {
            $('#preloader, #status').fadeIn();
            $.ajax(
                {
                    url: MainDomain + 'api/Techanicians/' + $('#hdnobjID').val(),
                    type: ((@ViewBag.ID.ToString() != '') ? 'PUT' : 'POST'),
                    data: {
                        "Id": $('#hdnobjID').val(),
                        "Code": $('#code').val(),
                        "ArName": $('#txtArName').val(),
                        "EnName": $('#txtEnName').val(),
                        "Phone1": $('#phone1').val(),
                        "Phone2": $('#phone2').val(),
                        "Address": $('#address').val(),
                        "UserId": $('#hdnUserId').val(),
                        "IsDeleted": (@ViewBag.ID.ToString() != '') ? $('#hdnIsDeleted').val() : false,
                        "IsActive": (@ViewBag.ID.ToString() != '') ? $('#hdnIsActive').val() : true,
                        "Image": (@ViewBag.ID.ToString() != '') ? $('#hdnImage').val() : true,
                    },
                    beforeSend: function (xhr) {
                        xhr.setRequestHeader('Authorization', 'Bearer ' + $("#userToken").val());
                    },
                    error: function (e) {
                        if (e) {

                            $('#preloader, #status').fadeOut();
                        } else
                            window.location = '/logout/';
                    },
                    success: function (r) {
                        back('@ViewContext.RouteData.Values["controller"].ToString()');
                    }
                });
        } else {
            CheckSave();
            $("label.error").html('يرحى ادخال هذا الحقل');
            $('html').animate({ scrollTop: $('.error:visible').offset().top - 170 }, '500', 'swing');
        }
    }

    if (@ViewBag.ID.ToString() != '') {

        $.ajax(
            {
                url: MainDomain + 'api/Techanicians/@ViewBag.ID.ToString()',
                type: 'Get',
                beforeSend: function (xhr) {
                    xhr.setRequestHeader('Authorization', 'Bearer ' + $("#userToken").val());
                },
                error: function (e) {
                    console.log(e);
                    window.location = '/logout/';
                },
                success: function (r) {

                    if (r != null) {
                        $('#code').val(r['Code']);
                        $('#txtArName').val(r['ArName']);
                        $('#txtEnName').val(r['EnName']);
                        
                        $('#phone1').val(r['Phone1']);
                        $('#phone2').val(r['Phone2']);
                        $('#address').val(r['Address']);
                        $('#hdnImage').val(r['Image']);
                        $('#hdnobjID').val(r['Id']);
                        $('#hdnUserId').val(r['UserId']);
                        $('#hdnIsDeleted').val(r['IsDeleted']);
                        $('#hdnIsActive').val(r['IsActive']);

                        FillAutoCompelete();
                    }

                    $('#preloader, #status').fadeOut();
                }
            });
    }

</script>



