                                                        <th class="col-sm-2">@MyERP.Properties.Resources.PaymentMethod</th>
                                                        <th class="col-sm-2">@MyERP.Properties.Resources.Amount</th>
                                                        <th class="col-sm-3">@MyERP.Properties.Resources.CashBox/@MyERP.Properties.Resources.Bank</th>
                                                        <th class="col-sm-3">@MyERP.Properties.Resources.BankAccount</th>
                                                    </tr>
                                                </thead>
                                                <tbody id="PaiedWay">
