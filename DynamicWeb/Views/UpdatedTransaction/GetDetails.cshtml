

@model MyERP.Models.UpdatedTransaction

@{
    UICulture = Session["lang"] != null?Session["lang"].ToString():"ar";

    ViewBag.Title = MyERP.Properties.Resources.UpdatedTransactions;
}
<script src="~/js/CalcTotalDebitAndCredit.js"></script>
@Html.AntiForgeryToken()
<div class="panel panel-widget forms-panel">
    <div class="forms">
        <div class=" form-grids form-grids-right">
            <div class="widget-shadow " data-example-id="basic-forms">
                <div class="form-title">
                    @if (Model.Id > 0)
                    {
                        if (Model.IsDeleted == false)
                        {
                    <a class="btn btn-info" href="@Url.Action("Index")" role="button" style="float:left;">@MyERP.Properties.Resources.Back</a>
                            if (ViewBag.Previous > 0)
                            {
                <a href="@Url.Action("AddEdit",new {id= ViewBag.First })" class="btn btn-info">@MyERP.Properties.Resources.First</a>
                                <a href="@Url.Action("AddEdit",new { id=ViewBag.Previous })" class=" btn btn-info" >&#8250;</a>
                            }
                            if (ViewBag.Next > 0)
                            {
                                <a href="@Url.Action("AddEdit",new { id=ViewBag.Next })" class="btn btn-info" >&#8249;</a>
                                <a href="@Url.Action("AddEdit",new {id=ViewBag.Last })" class="btn btn-info">@MyERP.Properties.Resources.Last</a>
                            }
                        }
                    }
                    else
                    {<a class="btn btn-info" href="@Url.Action("Index")" role="button" style="float:left;">@MyERP.Properties.Resources.Back</a>}
                    <h4>@Model.SystemPage.ArName</h4>
                </div>
                <div class="form-body">
                    <div class="form-horizontal">
                        <hr />
                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                        <input value="@ViewBag.SystemPageId" id="SystemPageId" hidden />
                        <input type="text" class="money" id="TotalPaymentMethods" hidden />
                        @if (Model.Id > 0)
                        {
                            @Html.HiddenFor(model => model.Id, new { id = "Id" })
                            @Html.HiddenFor(model => model.IsActive)
                            @Html.HiddenFor(model => model.UserId)
                            @Html.HiddenFor(model => model.IsLinked)
                            @Html.HiddenFor(model => model.IsPosted)
                            @Html.HiddenFor(model => model.IsDeleted)
                            @Html.HiddenFor(model => model.IsAccepted)
                            @Html.HiddenFor(model => model.IsCompleted)
                            @Html.HiddenFor(model => model.Image)
                        }
                        <div class="panel-group">
                            <div class="panel panel-default">
                                <div class="panel-heading">
                                    @MyERP.Properties.Resources.MainData
                                </div>
                                <div class="panel-body ">
                                    <div class="form-group">
                                        <label class=" col-sm-1 control-label" for="DocumentNumber">@MyERP.Properties.Resources.DocNo</label>
                                        <div class="col-sm-5">
                                            @Html.EditorFor(model => model.DocumentNumber, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly", placeholder = @MyERP.Properties.Resources.DocNo } })
                                            @Html.ValidationMessageFor(model => model.DocumentNumber, "", new { @class = "text-danger" })
                                            <span class="Asterisks">*</span>
                                        </div>
                                        <label for="DepartmentId" class="col-sm-1 control-label">@MyERP.Properties.Resources.Branch</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("DepartmentId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", @required = "required", @disabled = "disabled" })
                                            <span class="Asterisks">*</span>
                                        </div>
                                        @*<label class="col-sm-1 control-label" for="BranchId">الفرع</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("BranchId", null, "إختر الفرع", htmlAttributes: new { @class = "form-control", @required = "required", @disabled = "disabled" })
                                            @Html.ValidationMessageFor(model => model.BranchId, "", new { @class = "text-danger" })
                                            <span class="Asterisks">*</span>
                                        </div>*@
                                    </div>

                                    <div class="form-group">

                                        <label for="VoucherDate" class="control-label col-sm-1">@MyERP.Properties.Resources.InvoiceDate</label>
                                        <div class="col-sm-5">

                                            @Html.EditorFor(model => model.VoucherDate, new { htmlAttributes = new { @class = "form-control", type = "datetime-local", @required = "required", @readonly = "readonly" } })
                                            <span class="Asterisks">*</span>
                                            @Html.ValidationMessageFor(model => model.VoucherDate, "", new { @class = "text-danger" })
                                        </div>
                                        <label for="WarehouseId" class="col-sm-1 control-label">@MyERP.Properties.Resources.WareHouse</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("WarehouseId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", @required = "required", @disabled = "disabled" })
                                            @Html.ValidationMessageFor(model => model.WarehouseId, "", new { @class = "text-danger" })
                                            <span class="Asterisks">*</span>
                                        </div>
                                    </div>


                                        <div class="form-group" hidden>
                                            <label class="control-label col-sm-1" for="CurrencyId"> @MyERP.Properties.Resources.Currency</label>
