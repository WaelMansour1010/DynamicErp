                                                        {
                                                            <td><input class=" money Amount form-control" type="text" value="@method.Amount" id="Amount1" /></td>
                                                            <td>
                                                                @Html.DropDownList("CashBoxId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "CashBoxId form-control" })


                                                            </td>
                                                            <td></td>
                                                        }
                                                        else if (method.PaymentMethod.Id == 2)
                                                        {
                                                            <td><input class=" money Amount form-control" type="text" id="Amount2" value="@method.Amount" /></td>
                                                            <td></td>
                                                            <td></td>
                                                        }
                                                        else if (method.PaymentMethod.Id == 3)
                                                        {
                                                            <td><input class=" money Amount form-control" type="text" value="@method.Amount" id="Amount3" /></td>
                                                            <td>
                                                                @Html.DropDownList("BankIdForCheque", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "BankId form-control", id = "BankIdForCheque" })
                                                            </td>
                                                            <td>
                                                                @Html.DropDownList("BankAccountIdForCheque", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "BankAccountId form-control", id = "BankAccountIdForCheque" })
                                                            </td>
                                                        }
                                                        else if (method.PaymentMethod.Id == 4)
                                                        {
                                                            <td><input class=" money Amount form-control" type="text" value="@method.Amount" id="Amount4" /></td>
                                                            <td>
                                                                @Html.DropDownList("BankIdForVisa", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "BankId form-control", id = "BankIdForVisa" })
                                                            </td>
                                                            <td>
                                                                @Html.DropDownList("BankAccountIdForVisa", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "BankAccountId form-control", id = "BankAccountIdForVisa" })
                                                            </td>
                                                        }


                                                    </tr>
                                                            }
                                                        }
                                                       
                                                    </tbody>

                                            </table>
                                        </div>

                                </div>
                            </div>
                            @*<div class="panel panel-default">
                                <div class="panel-heading">
                                    <h4 class="panel-title">
                                        <a data-toggle="collapse" data-parent="#accordion" href="#collapse5">
                                            السريال
                                        </a>
                                    </h4>
                                </div>
                                <div id="collapse5" class="panel-collapse collapse">
                                    <div class="form-group">
                                        <label class="col-sm-2 control-label" for="selectedItems">الصنف</label>
                                        <select id="selectedItems" class="form-control"></select>
                                        <div class="panel-group" id="accordion1" role="tablist" aria-multiselectable="true">

                                        </div>
                                    </div>


                                </div>
                            </div>*@
                        </div>


                    </div>

                    

                </div>
               
            </div>
        </div>
    </div>
</div>

<script>
    $('.invoice').each(function () {

        if ($(this).val() > 0) {
            $(this).show();
        }
        else {
            $(this).closest('.div').hide();
        }
    });

    serialpanels();
     //calc total after discountValue
    function DiscountValueChange() {

        var discountValue = $('#DiscountValue').inputmask('unmaskedvalue');
        var total = $('#Total').inputmask('unmaskedvalue');
        //total after discount
        $('#NetTotal').val(total - discountValue);

        //prec
        var calcPerc = (discountValue * 100 / total).toFixed(2);
        $("#percentage").val(calcPerc);

    }
    function calculateTotal() {
        var sum = 0;
        $('.total').each(function () {
            sum = sum + $(this).inputmask('unmaskedvalue') * 1;
        });
        $('#Total').val(sum).inputmask({
            alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
        });
    }
    //calc Taxes issu
    function Taxes() {
        if ($('#check').prop('checked')) {
            var total = $('#Total').inputmask('unmaskedvalue');
            var percentage = 14;

            var calcPrice = (total * percentage / 100).toFixed(2);
            $('#SalesTaxes').val(calcPrice).inputmask({
                alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
            });

        }
        calcTotalAfterTaxes();
    }
    //calc discount from prec
    function PrecChange() {
        var discountValue = $('#DiscountValue').inputmask('unmaskedvalue');
        var total = $('#Total').inputmask('unmaskedvalue');
        var percentage = $("#percentage").val();

        var calcPrice = (total * percentage / 100).toFixed(2);
        $('#DiscountValue').val(calcPrice).inputmask({
            alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
        });
        DiscountValueChange();
    }
    //calc total after taxes
    function calcTotalAfterTaxes() {
        var Taxes = $('#SalesTaxes').inputmask('unmaskedvalue');
        var totalAfterDis = $('#NetTotal').inputmask('unmaskedvalue');
        var TotalAfterTaxes = (totalAfterDis * 1) + (Taxes * 1)
        $('#TotalAfterTaxes').val(TotalAfterTaxes);

        $('#Amount2').val('0');
        $('#Amount3').val('0');
        $('#Amount4').val('0');
        $('#Amount1').val($('#TotalAfterTaxes').val());
    }

    function calcTotalPaymentMethods() {
        var sum = 0;
        $('.Amount').each(function () {
            sum += $(this).inputmask('unmaskedvalue') * 1;

        });
        $('#TotalPaymentMethods').val(sum).inputmask({
            alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
        });
    }



    function addSerialNumbers(rows, itemName, itemId) {
        var div = '<div class="panel panel-default" hidden><div class="panel-heading" role="tab" id="heading' + itemId + '"><h4 class="panel-title"><a role="button" data-toggle="collapse" data-parent="#accordion1" href="#coll' + itemId + '" aria-expanded="false" aria-controls="coll' + itemId + '">' + itemName + '</a></h4></div ><div id="coll' + itemId + '" class="panel-collapse collapse in" role="tabpanel" aria-labelledby="heading' + itemId + '"><div class="panel-body"><table class="table table-hover table-condensed"><thead><tr><th class="col-sm-1">#</th><th class="col-sm-11">السريال</th><th hidden></th></tr></thead><tbody class="serialNumbers"></tbody></table></div></div></div>'

        $('#accordion1').append(div);
        for (var i = 1; i <= rows; i++) {
            $('#accordion1 tbody:last').append('<tr><td class="col-sm-1"><label">' + i + '</label></td><td class="col-sm-11"><input type="text" class="serialNumber form-control" readonly/>' + '</td><td hidden> <input type="hidden" class="itemId" value="' + itemId + '" hidden/></td></tr>');

        }
    }
    function ItemQuantityOnSystem(item) {
        var qty = $.get('/Helper/ItemQuantityOnSystem?warehouseId=' + $('#WarehouseId').val() + '&itemId=' + $(item).val()).done(function () {
            $(item).closest('tr').find('.quantityOnSystem').val(qty.responseJSON);
            $(item).closest('tr').find('.quantity').val(qty.responseJSON * 1 > 0 ? 1 : 0);
            $(item).closest('tr').find('.total').val(($(item).closest('tr').find('.quantity').val() * $(item).closest('tr').find('.cost').inputmask('unmaskedvalue')).toFixed(2));
            calculateTotal();
            DiscountValueChange();
            Taxes();
            serialpanels();
        });
    }





    function serialpanels() {

        var details = [];
        $('#SalesInvoiceDetails tr').each(function () {
            var tr = $(this);
            var sum = 0;
            $(".item option:selected[value=" + tr.find('.item').val()+"]").each(function () {
                sum += $(this).closest('tr').find('.quantity').val() * 1;
            });
            details.push({
                quantity: sum,
                itemName: tr.find('.item option:selected').text(),
                itemId: tr.find('.item').val()
            });
        });

        $('#selectedItems').empty();
        details.some(function (detail) {
            if (detail.itemId) {
                var serials = [];
                if ($('#heading' + detail.itemId).length) {
                    $('#heading' + detail.itemId).closest('.panel').find('tbody').children('tr').each(function () {
                        serials.push({
                            serialNumber: $(this).find('.serialNumber').val(),
                            itemId: $(this).find('.itemId').val()
                        });
                    });

                    $('#heading' + detail.itemId).closest('.panel').remove();
                    addSerialNumbers(detail.quantity , detail.itemName, detail.itemId);
                    serials.some(function (serial, i) {
                        var tr = $('#heading' + detail.itemId).closest('.panel').find('tbody').children('tr').eq(i);
                        tr.find('.itemId').val(serial.itemId);
                        tr.find('.serialNumber').val(serial.serialNumber);
                    });
                } else {
                    addSerialNumbers(detail.quantity, detail.itemName, detail.itemId);
                }

                $('#selectedItems').append($('<option>', {
                    value: detail.itemId,
                    text: detail.itemName
                }));
                var selectedItems = [];
                $('#selectedItems').each(function () {
                    $(this).children('option').each(function () {
                        if ($.inArray(this.value, selectedItems) > -1) {
                            $(this).remove()
                        } else {
                            selectedItems.push(this.value);
                        }
                    });
                    selectedItems = [];
                });
            }
        });

        $('#heading' + details[0].itemId).closest('.panel').prevAll().remove();
        $('#heading' + details[0].itemId).closest('.panel').show();
        $('#heading' + details[0].itemId).closest('.panel').nextAll().hide();
    }


