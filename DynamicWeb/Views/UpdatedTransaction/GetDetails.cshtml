                                                                <td class="col-sm-1">
                                                                    <input class="quantity form-control" oninput="validity.valid||(value='');" type="number" step="any" readonly value="@item.Qty" /><span class="Asterisks">*</span>
                                                                    <input type="hidden" class="quantityOnSystem" />
                                                                </td>
                                                                <td class="col-sm-1"><input type="text" class="money cost form-control" readonly value="@item.Price" /><span class="Asterisks">*</span></td>


                                                                <td class="col-sm-1"><input class="total form-control" type="text" readonly value="0" /></td>
                                                              
                                                            </tr>
                                                        }
                                                    }
                                                
                                                </tbody>
                                            </table>
                                        </div>

                                        <hr />
                                        <div class="form-group">
                                            <label for="Total" class="control-label col-sm-2">@MyERP.Properties.Resources.Total:</label>
                                            <div class="col-sm-2">
                                                @Html.EditorFor(model => model.Total, new { htmlAttributes = new { @class = "form-control money", type = "text", id = "Total", @disabled = "disabled " } })
                                                @Html.ValidationMessageFor(model => model.Total, "", new { @class = "text-danger" })
                                            </div>
                                            <label for="VoucherDiscountValue" class="control-label col-sm-2">@MyERP.Properties.Resources.DiscountValue: </label>
                                            <div class="col-sm-2">
                                                @Html.EditorFor(model => model.VoucherDiscountValue, new { htmlAttributes = new { @class = "form-control money", id = "DiscountValue", type = "text", @readonly = "readonly", onchange = "DiscountValueChange()", value = "0" } })
                                                @Html.ValidationMessageFor(model => model.VoucherDiscountValue, "", new { @class = "text-danger" })
                                            </div>
                                            <label for="VoucherDiscountPercentage" class="control-label col-sm-2">@MyERP.Properties.Resources.DiscountPercentage: </label>
                                            <div class="col-sm-2">
                                                @Html.EditorFor(model => model.VoucherDiscountPercentage, new { htmlAttributes = new { @class = "form-control", id = "percentage", type = "number", @readonly = "readonly", onchange = "PrecChange()", oninput = "validity.valid||(value='');", value = "0" } })
                                                @Html.ValidationMessageFor(model => model.VoucherDiscountPercentage, "", new { @class = "text-danger" })
                                            </div>




                                        </div>
                                        <div class="form-group">

                                            <label for="NetTotal" class="control-label col-sm-2">@MyERP.Properties.Resources.TotalAfterDiscount:</label>
                                            <div class="col-sm-2">
                                                @Html.EditorFor(model => model.NetTotal, new { htmlAttributes = new { @class = "form-control money", type = "text", @disabled = "disabled ", id = "NetTotal", value = "0" } })
                                                @Html.ValidationMessageFor(model => model.NetTotal, "", new { @class = "text-danger" })
                                            </div>
                                            @if (Model.SalesTaxes > 0)
                                            {
                                        <div class="col-sm-4">
                                            <input type="checkbox" checked id="check" />@MyERP.Properties.Resources.IncludeValueAddedTax

                                        </div>

                                            }
                                            else
                                            {
                                        <div class="col-sm-4">
                                            <input type="checkbox" id="check" />@MyERP.Properties.Resources.IncludeValueAddedTax
                                        </div>
                                            }

                                        </div>
                                        @if (Model.SalesTaxes > 0)
                                        {
                                            <div class="form-group">

                                                <label for="SalesTaxes" class="control-label  col-sm-2  taxesLabel">@MyERP.Properties.Resources.ValueAddedTax:</label>
                                                <div class="col-sm-2">
                                                    @Html.EditorFor(model => model.SalesTaxes, new { htmlAttributes = new { @class = "form-control money taxes ", @readonly = "readonly", id = "SalesTaxes", type = "text", onchange = "calcTotalAfterTaxes()", value = "0" } })
                                                    @Html.ValidationMessageFor(model => model.SalesTaxes, "", new { @class = "text-danger" })
                                                </div>
                                                <label for="Paid" class="control-label col-sm-2 taxesLabel  ">@MyERP.Properties.Resources.TotalAfterTaxes:</label>
                                                <div class="col-sm-2">
                                                    @Html.EditorFor(model => model.TotalAfterTaxes, new { htmlAttributes = new { @class = "form-control taxes money ", type = "text", id = "TotalAfterTaxes", @disabled = "disabled ", value = "0" } })
                                                    @Html.ValidationMessageFor(model => model.TotalAfterTaxes, "", new { @class = "text-danger" })
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="form-group">

                                                <label for="SalesTaxes" class="control-label  col-sm-2 hidden taxesLabel">@MyERP.Properties.Resources.ValueAddedTax:</label>
                                                <div class="col-sm-2">
                                                    @Html.EditorFor(model => model.SalesTaxes, new { htmlAttributes = new { @class = "form-control money taxes hidden", @readonly = "readonly", id = "SalesTaxes", type = "text", onchange = "calcTotalAfterTaxes()", value = "0" } })
                                                    @Html.ValidationMessageFor(model => model.SalesTaxes, "", new { @class = "text-danger" })
                                                </div>
                                                <label for="Paid" class="control-label col-sm-2 taxesLabel  hidden">@MyERP.Properties.Resources.TotalAfterTaxes:</label>
                                                <div class="col-sm-2">
                                                    @Html.EditorFor(model => model.TotalAfterTaxes, new { htmlAttributes = new { @class = "form-control taxes money hidden", type = "text", id = "TotalAfterTaxes", @disabled = "disabled ", value = "0" } })
                                                    @Html.ValidationMessageFor(model => model.TotalAfterTaxes, "", new { @class = "text-danger" })
                                                </div>
                                            </div>

                                        }

                                </div>
                            </div>
                            <div class="panel panel-default">
                                <div class="panel-heading">
                                    @MyERP.Properties.Resources.PaymentMethods
                                </div>
                                <div class="panel-body">
                                        <div class="form-group">
                                            <table class="table table-hover table-condensed">
