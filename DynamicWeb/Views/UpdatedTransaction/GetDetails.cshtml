    function fillItems() {
        if (!$('#Id').val() > 0) {
            $('.item').empty();
            $('.item').append($('<option>', {

                text: "@MyERP.Properties.Resources.Select"
            }));
            for (var i = 0; i < items.length; i++) {
                $('.item').append($('<option>', {
                    value: items[i].Id,
                    text: items[i].ArName
                }));
            }
        } else {
            var selectedItem;
            var itemBarcode;
            $('.item').each(function () {
                selectedItem = $(this).val();
                itemBarcode = $(this).closest('tr').find('.barcode').val();
                $(this).empty();
                for (var i = 0; i < items.length; i++) {
                    $(this).append($('<option>', {
                        value: items[i].Id,
                        text: items[i].ArName
                    }));
                }
                $(this).val(selectedItem);
                $(this).closest('tr').find('.barcode').val(itemBarcode);
            });
        }
    }






