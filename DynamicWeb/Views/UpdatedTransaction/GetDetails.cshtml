                                                <label for="VoucherDate" class="control-label col-sm-1">@MyERP.Properties.Resources.Customer </label>
                                                <div class="col-sm-5">
                                                    @Html.DropDownList("CustomerId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control invoice", @required = "required", @disabled = "disabled" })
                                                    @Html.ValidationMessageFor(model => model.CurrencyId, "", new { @class = "text-danger" })
                                                    <span class="Asterisks">*</span>
                                                </div>
                                            </div>
                                                <div class="div">
                                                    <label for="VoucherDate" class="control-label col-sm-1">@MyERP.Properties.Resources.Supplier </label>

                                                    <div class="col-sm-5">
                                                        @Html.DropDownList("VendorId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control invoice", @required = "required", @disabled = "disabled" })
                                                        <span class="Asterisks">*</span>
                                                    </div>
                                                </div>
                                            </div>

                                        <div class="form-group">
                                            <label class="control-label col-sm-1" for="Notes">@MyERP.Properties.Resources.Notes</label>
                                            <div class="col-sm-5">
                                                <textarea id="Notes" name="Notes" class="form-control col-sm-11" rows="5" cols="5" readonly>@Model.Notes</textarea>

                                                @Html.ValidationMessageFor(model => model.Notes, "", new { @class = "text-danger" })
                                            </div>
                                        </div>
                                    
                                </div>
                            </div>
                            <div class="panel panel-default">
                                <div class="panel-heading">
                                            @MyERP.Properties.Resources.Details
                                    
                                </div>
                                <div class="panel-body ">
                                        <div class="form-group">
                                            <table class="table table-hover table-condensed">
                                                <thead>
                                                    <tr>
                                                        <th class="col-sm-1">@MyERP.Properties.Resources.Barcode</th>
                                                        <th class="col-sm-2">@MyERP.Properties.Resources.Item</th>
                                                        <th class="col-sm-1">@MyERP.Properties.Resources.Qty</th>
                                                        @*<th class="col-sm-2">الوحدة</th>
                                                            <th class="col-sm-1">معامل التحويل</th>*@
                                                    <th class="col-sm-1">@MyERP.Properties.Resources.SellingPrice</th>

                                                    <th class="col-sm-1">@MyERP.Properties.Resources.Total</th>
                                                       
                                                    </tr>
                                                </thead>
                                                <tbody id="SalesInvoiceDetails">
                                                    @if (Model.Id > 0)
                                                    {
                                                        foreach (var item in Model.UpdatedTransactionDetails)
                                                        {
                                                            <tr>
                                                                @if (item.ItemPriceId != null)
                                                                {
                                                                    <td class="col-sm-1"><input class="barcode form-control" value="@item.ItemPrice.Barcode" readonly/></td>

                                                                }
                                                                else
                                                                {
                                                                    <td class="col-sm-1"><input class="barcode form-control" /></td>

                                                                }
