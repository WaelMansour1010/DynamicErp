@model MyERP.Models.VendorOpenningBalance

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.VendorsOB;
}
@Html.AntiForgeryToken()

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            @*<div class="page-title-right">
                    <a class="btn btn-info" href="@Url.Action("Index")" role="button" style="float:left;">@MyERP.Properties.Resources.Back</a>
                </div>*@
            <div class="hed page-title">@MyERP.Properties.Resources.VendorsOB:</div>
        </div>
    </div>
</div>
<hr />
@Html.ValidationSummary(true, "", new { @class = "text-danger" })
@if (Model != null)
{
    @Html.HiddenFor(model => model.Id)
}

<div class="card-box">
    <div class="row">
        <div class="col-12">
            <div class="form-horizontal" role="form">
                <div class="panel-group" id="accordion">
                    <div class="form-group row">
                        <label class=" col-sm-1 control-label">@MyERP.Properties.Resources.Department </label>
                        <div class="col-sm-4">
                            @Html.DropDownList("DepartmentId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })
                            @*<span class="Asterisks">*</span>*@
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <hr />
    <div class="row">
        <div class="col-12">
            <div class="table-responsive">
                <table class="table table-striped table-centered mb-0">
                    <thead>
                        <tr>
                            <th>@MyERP.Properties.Resources.Code</th>
                            <th>@MyERP.Properties.Resources.ArName</th>
                            <th>@MyERP.Properties.Resources.DebitOB</th>
                            <th>@MyERP.Properties.Resources.CreditOB</th>
                        </tr>
                    </thead>
                    <tbody id="VendorOB"></tbody>
                </table>
            </div>
            <hr />
            <div class="form-group row ">
                <div class="col-sm-3">
                    <label for="inputtext3" class="col-sm-6 control-label">@MyERP.Properties.Resources.TotalDebit</label>


                    <input type='text' class='TotalDebit col-sm-6' value="" disabled>


                </div>
                <div class="col-sm-3">
                    <label for="inputtext3" class="col-sm-6 control-label">@MyERP.Properties.Resources.TotalCredit</label>

                    <input type='text' class='TotalCredit col-sm-6' value="" disabled>

                </div>
                <div class="col-sm-3">
                    <label for="inputtext3" class="col-sm-6 control-label">@MyERP.Properties.Resources.Subtraction</label>

                    <input type='text' class='money difference col-sm-6' value="" disabled>
                </div>
            </div>
            <hr />
            <div class="col-sm-offset-2">

                <button class="btn btn-success" onclick="addEdit()">
                    @MyERP.Properties.Resources.Save
                </button>
                    <a href="javascript:void(0);" class="btn btn-danger" onclick="DeleteFunc()" role="button">@MyERP.Properties.Resources.Delete</a>
            </div>
        </div>
    </div>
</div>



<script>
    function DeleteFunc() {
        if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToDelete')) {
            $('#preloader, #status').fadeIn();
            var VendorOBList = [];
            $('#VendorOB tr').each(function () {
                var td = $(this);
                var ObVendor = {
                    VendorId: td.find('.id').val(),
                    DepartmentId: $('#DepartmentId').val(),
                    OBDebit: td.find('.OBDebit').inputmask('unmaskedvalue'),
                    OBCredit: td.find('.OBCredit').inputmask('unmaskedvalue')
                };
                VendorOBList.push(ObVendor);
            });
            var data = { VendorOBList: VendorOBList }
            $.ajax({
                type: "POST",
                url: "/VendorOB/Delete",
                data: data,
                 success: function (r) {
                    if (r == 'true') {
                        alert('@MyERP.Properties.Resources.Saved');
                    } else if (r == 'nullAccount') {
                        alert('@MyERP.Properties.Resources.AccountDoesNotExist');
                    }
                    $('#preloader, #status').fadeOut();
                },
                error: function (r) {
                    alert('@MyERP.Properties.Resources.NotSaved');
                    $('#preloader, #status').fadeOut();
                }
            })
        }
    }


    function addEdit() {
        if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToSave')) {
            $('#preloader, #status').fadeIn();
            var VendorOBList = [];
            $('#VendorOB tr').each(function () {
                var td = $(this);
                var ObVendor = {
                    VendorId: td.find('.id').val(),
                    DepartmentId: $('#DepartmentId').val(),
                    OBDebit: td.find('.OBDebit').inputmask('unmaskedvalue'),
                    OBCredit: td.find('.OBCredit').inputmask('unmaskedvalue')
                };
                VendorOBList.push(ObVendor);
            });
            var data = {VendorOBList: VendorOBList}
           // console.log(data)

            $.ajax({
                type: "POST",
                url: "/VendorOB/Save",
                data: data,
                success: function (r) {
                    if (r == 'true') {
                        alert('@MyERP.Properties.Resources.Saved');
                    } else if (r == 'nullAccount') {
                        alert('@MyERP.Properties.Resources.AccountDoesNotExist');
                    }

                    $('#preloader, #status').fadeOut();
                },
                error: function (r) {
                    alert('@MyERP.Properties.Resources.NotSaved');

                    $('#preloader, #status').fadeOut();
                }
            })
        }
    }

    $(document).on('change', '#DepartmentId', function () {
        $('#DepartmentId').val() ? $('#preloader, #status').fadeIn() : null;
        $.get('/VendorOB/_GetAllVendors/' + $('#DepartmentId').val()).done(function (r) {
            $('#VendorOB').empty();
            $('#VendorOB').append(r);
            $('#preloader, #status').fadeOut();
            $('.money').inputmask({
                alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
            });
            calculateTotalDebit();
            calculateTotalCredit();
            calculateDifference();
        });


    });
    $(document).on("change", ".OBDebit", function () {


        $(this).closest("tr")
            .find(".OBCredit").val(0).inputmask({
                alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
            });
        calculateTotalDebit();
        calculateTotalCredit();
        calculateDifference();
    });
    $(document).on("change", ".OBCredit", function () {
        $(this).closest("tr")
            .find(".OBDebit").val(0).inputmask({
                alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
            });
        calculateTotalDebit();
        calculateTotalCredit();
        calculateDifference();

    });

    function calculateTotalDebit() {
        var sum = 0;

        $("#VendorOB tr .OBDebit").each(function () {

            sum += $(this).inputmask('unmaskedvalue') * 1;

        });

        $(".TotalDebit").val(sum).inputmask({
            alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
        });


    }
    function calculateTotalCredit() {
        var sum = 0;


        $("#VendorOB tr .OBCredit").each(function () {

            sum += $(this).inputmask('unmaskedvalue') * 1;

        });

        $(".TotalCredit").val(sum).inputmask({
            alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
        });


    }
    function calculateDifference() {


        $(".difference").val($(".TotalDebit").inputmask('unmaskedvalue') - $(".TotalCredit").inputmask('unmaskedvalue')).inputmask({
            alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
        });



    }
    $(document).ready(function () {

        $('.money').inputmask({
            alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
        });
    })

</script>
