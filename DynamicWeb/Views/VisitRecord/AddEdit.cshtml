        let VacationPeriodTypeId = r[0].EmployeeContractVacationDetails[0].VacationPeriod;

        let calc = (((VacationPeriodNum * VacationPeriodTypeId) / (VacationDuePeriodNum * VacationDuePeriodTypeId)) * 30) * (TotalDutyDays / 30);
        console.log(calc, "calc");
        console.log(TotalDutyDays, "TotalDutyDays");
        TotalCarryOverBalance = (r[0].EmployeeVacation[0].VacationBalance + calc) - r[0].VacationWithSalaryRecord;
        console.log(TotalCarryOverBalance.toFixed(2), "TotalCarryOverBalance");
        $('#CarryOverBalanceDays').val(TotalCarryOverBalance.toFixed(2));
        // -----------------------------  الايام المخصومة -----------------//
        TotalDeductionDays = $('#DeductionDays').val();
        //------------------------------ صافى مدة العمل ------------------//
        let NetWorkDays = TotalWorkDays - TotalDeductionDays;
        CalcEquivalent(NetWorkDays);
        $('#NetWork_Days').val(days);
        $('#NetWork_Months').val(months);
        $('#NetWork_Years').val(years);
        //----------------------------
        let BeforeDeductionDays = calcTotalDays(new Date($('#VacationStartDate').val()), new Date($('#VacationEndDate').val()));
        console.log(BeforeDeductionDays, "BeforeDeductionDays inside ShowEmployeeVacation()")
        $('#VacationDaysBeforeDeduction').val(BeforeDeductionDays);
        //----------------------------
        $('#AbsenceDays').val(TotalAbsenceDays);
        $('#VacationWithoutSalaryDays').val(TotalDaysOFVacationWithoutSalary);
        //----------------------------
        let NetAbsenceDay = TotalAbsenceDays - TotalDaysOFVacationWithoutSalary;
        $('#NetAbsenceDay').val(NetAbsenceDay);
        VacationDays = $('#VacationDaysBeforeDeduction').val();
        //----------------------------
        let VacationDues = VacationDays - NetAbsenceDay;
        $('#VacationDues').val(VacationDues);

    }


