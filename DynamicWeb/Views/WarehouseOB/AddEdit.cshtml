    function showItemDetials(e) {
        let itemPrice = $(e).closest('tr').find('.item');
       let item = items.filter(function (i) { return i.ItemPriceId == itemPrice.val(); })[0];
       $('#itemDetailsBody').empty();
        if (item) {
             $('#itemDetailsBody').append('<div class="d-flex align-items-center"><div class="spinner-border ml-auto" role="status" aria-hidden="true"></div></div>');
            $.get('/Item/GetItemQuantityInEachWarehouse?itemId=' + item.Id + '&depId=' + $('#DepartmentId').val()).done(function (r) {
                $('#itemDetailsBody').empty().append(r);
            });
        }
    }

    function Delete(id) {
        Swal.fire({
            title: '@MyERP.Properties.Resources.AreYouSureYouWantToDelete',
            text: " "/*"You won't be able to revert this!"*/,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: '@MyERP.Properties.Resources.Ok',
            cancelButtonText: '@MyERP.Properties.Resources.Cancel',
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {

                $('#preloader, #status').fadeIn();
                $.ajax(
                    {
                        url: '/WarehouseOB/Delete',
                        type: 'POST',
                        data: {
                            "Id": id,
                        },
                        error: function (e) {
                             Swal.fire({
                                    title: "@MyERP.Properties.Resources.DeleteDoesNotSucceeded" + "!",
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                             })
                            $('#preloader, #status').fadeOut();
                        },
                        success: function (r) {
                            if (r == 'true') {
                                window.location.replace('/WarehouseOB');
                            } else
                                 Swal.fire({
                                    title: "@MyERP.Properties.Resources.DeleteDoesNotSucceeded" + "!",
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                             })
                            $('#preloader, #status').fadeOut();
                        }
                    });
            }
            else {
                result.dismiss;
            }
        });

