            }, 500);
            console.log($(".form-control:invalid"));
        }
        else if ($(".form-control:invalid").length == 0) {
            var warehouseOBDetails = [];
            $('#WarehouseOBDetails tr').each(function () {
                let td = $(this);
                if (td.find('.item').val()) {
                    let itemId = items.filter(function (i) { return i.ItemPriceId == td.find('.item').val(); })[0].Id;
                    let warehouseOBDetail = {
                        ItemPriceId: td.find('.item').val(),
                        ItemId: itemId,
                        Cost: td.find('.cost').inputmask('unmaskedvalue'),
                        Quantity: td.find('.quantity').val(),
                        ItemUnitId: td.find('.item-unit').val(),
                        UnitEquavalent: td.find('.unit-equavalent').val(),
                        IsActive: true,
                        IsDeleted: false,
                        ExpireDate: td.find('.ExpiryDate').val(),
                        PatchCode: td.find('.PatchCode').val(),
                        PatchId: td.find('.PatchId').val()
                    };
                    warehouseOBDetails.push(warehouseOBDetail);
                }
            });

            Swal.fire({
                title: '@MyERP.Properties.Resources.AreYouSureYouWantToSave',
                text: " ",
                icon: 'info',
                showCancelButton: true,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                cancelButtonText: '@MyERP.Properties.Resources.Cancel',
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    $('#preloader, #status').fadeIn();
                $('#newbtn').prop('disabled', true);
                $('#save').prop('disabled', true);
                $.ajax({
                    type: "POST", contentType: "application/json",
                    url: "/WarehouseOB/AddEdit",
                    data: JSON.stringify({
                        Id: $('#Id').val(),
                        DocumentNumber: $('#DocumentNumber').val(),
                        BranchId: $('#BranchId').val(),
                        WarehouseId: $('#WarehouseId').val(),
                        DepartmentId: $('#DepartmentId').val(),
                        Date: $('#Date').val(),
                        CurrencyId: $('#CurrencyId').val(),
                        CurrencyEquivalent: $('#CurrencyEquivalent').val(),
                        MoneyTotal: $('#MoneyTotal').inputmask('unmaskedvalue'),
                        WarehouseOBDetails: warehouseOBDetails,
                        IsActive: $('#IsActive').val(),
                        IsDeleted: $('#IsDeleted').val(),
                        Notes: $('#Notes').val(),
                    }),
                    success: function (r) {
                        if (r == "true") {
                            var itemIds = [];
                            $('#WarehouseOBDetails tr').each(function () {
                                var td = $(this);
                                if (td.find('.item').val() > 0)
                                    itemIds.push({
                                        ItemId: td.find('.item').val(),
                                    });
                            });
                            $.ajax({
                                type: "POST", contentType: "application/json",
                                url: "/Helper/UpdateItemQuantities",
                                data:
                                    JSON.stringify({
                                        itemIds: itemIds,
                                        date: new Date()
                                    }),
                                success: function (r) { }
                            });
                            $('#preloader, #status').fadeOut();

                            if (n == "new") {
                                window.location.replace("/WarehouseOB/AddEdit");
                            } else {
                                window.location.replace("/WarehouseOB");
                            }
                        } else {
                            $('#preloader, #status').fadeOut();
                            $('#newbtn').prop('disabled', false);
                            $('#save').prop('disabled', false);
                            Swal.fire({
                                    title: "@MyERP.Properties.Resources.NotSaved" + "!",
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                })
                            // alert("@MyERP.Properties.Resources.NotSaved"+"!");
                        }

                    },
                    error: function (r) {
                        $('#preloader, #status').fadeOut();
                        $('#newbtn').prop('disabled', false);
                        $('#save').prop('disabled', false);
                       Swal.fire({
                                    title: "@MyERP.Properties.Resources.NotSaved" + "!",
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                })
                        //alert("@MyERP.Properties.Resources.NotSaved"+"!");
                    }
                });
                }
                else
                 {
                    result.dismiss;
                }
            })



