            //    responsive: true,
            //    searching: true,
            //    destroy: true
            //    //columnDefs: [
            //    //    { responsivePriority: 1, targets: -1 },
            //    //    { responsivePriority: 2, targets: -2 },
            //    //    { responsivePriority: 3, targets: 1 },
            //    //    { responsivePriority: 4, targets: 0 }
            //    //]
            //});
            //$('#tbldata3').DataTable({

            //    responsive: true,
            //    searching: true,
            //    destroy: true
            //    //columnDefs: [
            //    //    { responsivePriority: 1, targets: -1 },
            //    //    { responsivePriority: 2, targets: -2 },
            //    //    { responsivePriority: 3, targets: 1 },
            //    //    { responsivePriority: 4, targets: 0 }
            //    //]
            //});

        });

        function React2(s, t, i) {
            $.ajax({
                url: '@Url.Action("React")',
                type: "get",
                data: { s: s, t: t, i: i },
                success: function (data) {
                    location.reload();
                }
            });
        }
        function React(s, t, i, l) {
            $.ajax({
                url: '@Url.Action("React")',
                type: "get",
                data: { s: s, t: t, i: i, l: l },
                success: function (data) {
                    location.reload();
                }
            });
        }
        function closetran(t, i) {

            $.ajax({
                url: '@Url.Action("Close")',
                type: "get",
                data: { t: t, i: i },
                success: function (data) {
                    location.reload();
                }
            });
        }
    </script>
}


