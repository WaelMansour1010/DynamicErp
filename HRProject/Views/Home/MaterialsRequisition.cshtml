@using Microsoft.AspNetCore.Mvc.TagHelpers
@model HRServices.Models.OrderModel
<style>
    .btnNav {
        /*  width: 64px !important;
                height: 45px !important;*/
        border-color: white;
        /*   padding: 11px;
                margin: 3px;*/
        /*color: gray;*/
    }

    #radioBtn .notActive {
        color: #3276b1;
        background-color: #fff;
    }

    .sticky {
        position: -webkit-sticky;
        position: sticky;
        top: 0;
    }

    .tblFooter {
        font-weight: bold;
        background-color: lightgray;
        font-size: 14px;
    }

    .NuInput {
        border-top-style: hidden;
        border-right-style: hidden;
        border-left-style: hidden;
        border-bottom-style: hidden;
        background-color: transparent;
        width: 65px
    }

    label {
        color: black;
        font-size: large;
        font-weight: bold
    }

    .bookcode {
        width: 80px;
    }

    .txtInput {
        border-top-style: hidden;
        border-right-style: hidden;
        border-left-style: hidden;
        border-bottom-style: hidden;
        background-color: transparent;
        width: 100%
    }

    .no-outline:focus {
        outline: none;
    }

    .customername {
        color: black;
        font-size: large;
        font-weight: bold
    }
</style>

<form asp-action="MaterialsRequisition" method="get">
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox ">
               
                <div class="ibox-content m-b-sm border-bottom">
                    <div class="row">
                        <div class="col-md">
                            <div class="form-group">
                                <label class="col-form-label" for="order_id">Order No</label>
                                <input asp-for="OrderNo" type="text" id="order_id" name="order_id" disabled="disabled" class="form-control">
                            </div>
                        </div>
                        <div class="col-md">
                            <div class="form-group">
                                <label class="col-form-label" for="status">Order status</label>
                                <input type="text" id="status" asp-for="Status" disabled="disabled" class="form-control">
                            </div>
                        </div>

                    </div>
                    <div class="row">
                        <div class="col-sm">
                            <div class="form-group">
                                <label class="col-form-label" for="date_added">Order Date</label>
                                <div class="input-group date">
                                    <span class="input-group-addon">
                                        <i class="fa fa-calendar"></i>
                                    </span><input id="date_added" type="text" disabled="disabled" class="form-control" value="@Model.OrderDate">
                                </div>
                            </div>
                        </div>



                    </div>



                    <div class="row">
                        <div class="col-md">
                            <div class="form-group">
                                <button id="btnSave" class="btn btn-lg btn-danger" type="button" onclick="save();">Save</button>

                            </div>
                        </div>
                    </div>

                    <div class="ibox-content">
                        <div class="row">
                            <button class="btn btn-primary " onclick="showItemlist();" type="button">ِAdd Item</button>
                        </div>
                        <div class="row">
                            <div class="col-sm">
                                <div class="form-group">
                                    <label class="col-form-label" for="date_added">Item Code</label>
                                    <div class="input-group">
                                        <input id="txtSearch" type="text" class="form-control">
                                    </div>
                                </div>
                            </div>



                        </div>


                        <div class="table-responsive">

                            <table id="tbl" class="   nowrap table table-striped table-bordered table-hover" style="width:100%">
                                <thead>
                                    <tr>
                                        <th>Item Code</th>
                                        <th>Item Name </th>
                                        <th>Item E Name </th>
                                        <th>Unit</th>
                                        <th>Qty</th>
                                        <th>Notes</th>
                                        <th> </th>
                                    </tr>
                                </thead>
                                <tbody>
                                </tbody>
                                <tfoot class="tblFooter">
                                </tfoot>
                            </table>

                        </div>



                    </div>


                </div>




            </div>
        </div>
    </div>
</form>
<div class="modal" id="mydiv">
</div>
<div class="modal  fade" id="mymodal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-dialog-centered modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="items"></h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                    <input type="hidden" />
                </button>
            </div>
            <div id="content" class="modal-body">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-danger" data-dismiss="modal" onclick="addSelected();">Insert</button>
                <button type="button" class="btn btn-secondary" onclick="closeModal();">Close</button>
             
            </div>
        </div>
    </div>
</div>
@section scripts
{
    <script src="~/assets/js/plugins/datapicker/bootstrap-datepicker.js"></script>
    <script src="~/assets/js/plugins/jquery-ui/jquery-ui.min.js"></script>
    <script>


        function setUpAutoCompleate() {


            var $elem = $('#txtSearch').autocomplete({
                source: function(request, response) {

                    $.ajax({
                        url: "@Url.Action("SearchAutoCompleteNew")",
                        type: "get",
                        dataType: "json",
                        minLength: 3,
                        data: { word: request.term },
                        success: function(data) {
                            response($.map(data,
                                function(item) {
                                    return {
                                        label: `${item.itemCode}-${item.itemNamee}`,
                                        value: item.itemNamee,
                                        id: item.itemId,
                                        code: item.itemCode,
                                        itemname: item.itemName,
                                        itemnamee: item.itemNamee,
                                        unitId :item.unitId,
                                        itemUnites:item.itemUnites
                                    };
                                }
                            ));
                        }
                    });
                },
                select: function(event, ui) {

                    var obj2 = {
                        rowId: genid(),
                        itemId: ui.item.id,
                        itemCode: ui.item.code,
                        itemName: ui.item.itemname,
                        itemNamee: ui.item.itemnamee,
                        unitName: ui.item.unitName,
                        unitId: ui.item.unitId,
                        itemUnites:ui.item.itemUnites,
                        qty: 1,
                        notes: ''
                    };
                    addrow(obj2);

                    return false;
                },
                close: function() {
                    $('#txtSearch').val('');
                }
            });


        }

        var rows_selected = [];
        var tblBooks;

        function showItemlist() {


            $('#content').html(`<table id="tblItemlist" class="table table-striped table-bordered table-hover no-footer" style="width:100% !important">

                                           <thead>
                                                                        <tr>
                                        <th><input type="checkbox" name="select_all" value="1" id="colselectall" class="form-check-input"></th>
                                                                            <th>Item Code</th>
                                                                            <th>Item Name</th>
                                                                            <th>Item E-Name </th>
                                                                        </tr>
                                                                    </thead>
                                                                    <tbody>
                                                                    </tbody>
                                                        </table>`);


            $('#items').text('Items List');
            //   'className': 'dt-body-center',

            tblBooks = $('#tblItemlist').DataTable({
                "proccessing": true,
                "serverSide": true,
                "ajax": {
                    url: '@Url.Action("ItemsList")',
                    type: 'POST'
                },
                responsive: true,
                searching: true,
                destroy: true,
                columns: [
                    {
                        data: null,
                        'searchable': false,
                        'orderable': false,
                        'render': function(data, type, full, meta) {
                            return '<input type="checkbox" name="id[]">';
                        }
                    },
                    { title: 'Item Code', data: 'itemCode' },
                    {
                        title: 'Item Name',
                        data: 'itemName',
                        render: function(data, type, item) {
                            return `${item.itemName}<input type='hidden' class='id' value='${item.itemId}'/>`;
                        }
                    },
                    { title: 'Item E Name', data: 'itemNamee' }
                ],
                'rowCallback': function(row, data, dataIndex) {
                    var rowId = data.itemId;
                    var name = data.itemName;
                    var oldobj = rows_selected.filter(t => t.itemId == rowId);
                    let index = -1;
                    if (oldobj.length) {
                        if (oldobj.length > 0) {
                            index = rows_selected.indexOf(oldobj[0]);
                        }
                    }
                    if (index !== -1) {
                        $(row).find('input[type="checkbox"]').prop('checked', true);
                        $(row).addClass('selected');
                    }
                }
            });
            $('#colselectall').on('click',
                function() {

                    var rows = tblBooks.rows({ 'search': 'applied' }).nodes();

                    $('input[type="checkbox"]', rows).prop('checked', this.checked);
                    $('input[type="checkbox"]', rows).change();


                });
            $('#tblItemlist tbody').on('change',
                'input[type="checkbox"]',
                function(e) {
                    var $row = $(this).closest('tr');
                    var data = tblBooks.row($row).data();

                    var itemId = data.itemId;
                    //  var name = data.itemname;
                    var obj = data;
                    var oldobj = rows_selected.filter(t => t.itemId == itemId);
                    let index = -1;
                    if (oldobj.length) {
                        if (oldobj.length > 0) {
                            index = rows_selected.indexOf(oldobj[0]);
                        }
                    }

                    // $.inArray(obj, rows_selected);
                    if (!this.checked) {
                        if (!this.checked && index !== -1) {
                            rows_selected.splice(index, 1);
                            //  console.log('removed from  selected ' + itemId);
                        }
                        var el = $('#colselectall').get(0);
                        if (el && el.checked && ('indeterminate' in el)) {
                            el.indeterminate = true;
                        }
                    }


                    if (this.checked && index === -1) {
                        rows_selected.push(obj);
                        //  console.log('Add To selected ' + itemId);
                    }

                    updateDataTableSelectAllCtrl(tblBooks);

                    // Prevent click event from propagating to parent
                    e.stopPropagation();
                });

            $('#mymodal').modal('show');
        }

        function closeModal() {
            rows_selected = [];
            $('#mymodal').modal('hide');
        }

        function updateDataTableSelectAllCtrl(table) {
            var $table = table.table().node();
            var $chkbox_all = $('tbody input[type="checkbox"]', $table);
            var $chkbox_checked = $('tbody input[type="checkbox"]:checked', $table);
            var chkbox_select_all = $('thead input[name="select_all"]', $table).get(0);


            if ($chkbox_checked.length === 0) {
                chkbox_select_all.checked = false;
                if ('indeterminate' in chkbox_select_all) {
                    chkbox_select_all.indeterminate = false;
                }


            } else if ($chkbox_checked.length === $chkbox_all.length) {
                chkbox_select_all.checked = true;
                if ('indeterminate' in chkbox_select_all) {
                    chkbox_select_all.indeterminate = false;
                }


            } else {
                chkbox_select_all.checked = true;
                if ('indeterminate' in chkbox_select_all) {
                    chkbox_select_all.indeterminate = true;
                }
            }
        }

        function addSelected() {
            let tbl = $('#tbl').DataTable();
            var allData = tbl.rows().data().toArray();


            if (rows_selected.length) {
                if (rows_selected.length > 0) {
                    for (let x in rows_selected) {

                        let obj = allData.filter(t => t.itemId == rows_selected[x].ItemId);
                       // console.log(rows_selected[x]);
                        if (obj.length == 0) {

                            var obj2 = {
                                rowId: genid(),
                                itemId: rows_selected[x].itemId,
                                itemCode: rows_selected[x].itemCode,
                                itemName: rows_selected[x].itemName,
                                itemNamee: rows_selected[x].itemNamee,
                                unitId  : rows_selected[x].unitId,
                                itemUnites: rows_selected[x].itemUnites,
                                qty: 1,
                                notes: ''
                            };
                            addrow(obj2);

                        }

                    }
                    //  tbl.draw();
                    rows_selected = [];
                }

            }

        }

        function genid() {

            return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g,
                function(c) {
                    var r = Math.random() * 16 | 0, v = c == 'x' ? r : (r & 0x3 | 0x8);
                    return v.toString(16);
                });

        }

        function addrow(obj) {

            obj['rowId'] = genid();
            var table = document.getElementById('tbl');
            for (var i = 0; i < table.rows.length; i++) {
                var row = table.rows[i];
                var anyinput = $(row.cells[0].innerHTML).attr('id');
                if (!anyinput) {
                    continue;
                }
                var rowid = anyinput.split('_')[0];
                var idinput = $(`#${rowid}_id`);
                if (idinput) {
                    var itemid = idinput.val();
                    if (itemid == obj.itemId) {
                        var qtyInput = $(`#${rowid}_qty`);
                        qtyInput.val(getNum(qtyInput.val()) + 1);
                        return;
                    }

                }
            }
            var tbl = $('#tbl').DataTable();
            tbl.row.add(obj);
            tbl.draw(false);
            rowfunction();
        }

        function getNum(n) {
            if (isNaN(n)) return 0;
            return Number(n);

        }

        function rowfunction() {
            return;

            $('.bookscode , .books').keypress(function(event) {

                var mcode = $(this).val();

                var keycode = (event.keyCode ? event.keyCode : event.which);
                if (keycode == '13') {
                    $.ajax({
                        url: `/masterfile/getbookbycode/`,
                        type: 'GET',
                        cache: false,
                        data: { code: mcode },
                        dataType: 'json',
                        success: function(data) {
                            if (data.isok) {
                                var mobj = {
                                    bookID: data.data.id,
                                    bookCode: data.data.code,
                                    bookName: data.data.name,
                                    price: data.data.price,
                                    cost: data.data.cost,
                                    multi: data.data.multi,
                                    copyes: 1,
                                    lineTotal: data.data.price,
                                    descount: 0.0,
                                    descountValue: 0.0,
                                    lineTotalAfterDes: data.data.price
                                };
                                addrow(mobj);
                                //  addrow(data.data.id, data.data.code, data.data.name, data.data.price, data.data.cost, data.data.multi);
                            } else {
                                ShowError(data);
                            }


                        }
                    });
                }
            });
            $('.booksid').keypress(function(event) {
                var keycode = (event.keyCode ? event.keyCode : event.which);
                if (keycode == '13') {
                    $.ajax({
                        url: `/masterfile/getbookbyid/`,
                        type: 'GET',
                        cache: false,
                        data: { code: $('.booksid').val() },
                        dataType: 'json',
                        success: function(data) {
                            if (data.isok) {
                                var mobj = {
                                    bookID: data.data.id,
                                    bookCode: data.data.code,
                                    bookName: data.data.name,
                                    price: data.data.price,
                                    cost: data.data.cost,
                                    multi: data.data.multi,
                                    copyes: 1,
                                    lineTotal: data.data.price,
                                    descount: 0.0,
                                    descountValue: 0.0,
                                    lineTotalAfterDes: data.data.price
                                };
                                addrow(mobj);

                                // addrow(data.data.id, data.data.code, data.data.name, data.data.price, data.data.cost, data.data.multi);
                            } else {
                                ShowError(data);
                            }


                        }
                    });
                }
            });
        }


        function additem(obj) {
            var row = $(obj).parents('tr').first();
            var tbl = $(row.parent().parent()).DataTable();

            var data = tbl.row(row).data();
            var obj2 = {
                rowId: genid(),
                itemId: data.itemId,
                itemCode: data.itemCode,
                itemName: data.itemName,
                itemNamee: data.itemNamee,
                unitId: data.unitId,
                unitName: data.unitName,
                notes: '',
                qty: 1

            };
            addrow(obj2);
            // addrow(data.id, data.code, data.name, data.price, data.cost, data.multi);
        }

        var tblinvoice;
        $(document).ready(function() {
            setUpAutoCompleate();
            $('.datepicker').datepicker({
                todayBtn: "linked",
                keyboardNavigation: false,
                forceParse: false,
                calendarWeeks: true,
                autoclose: true,
                format: 'dd/mm/yyyy'
            });


            tblinvoice = $('#tbl').DataTable({
                responsive: true,
                paging: false,
                searching: false,
                ordering: false,
                info: false,
                "rowId": "rowid",
                "createdRow": function(row, data, dataIndex) {

                },
                columns: [
                    {
                        data: null,
                        render: function(data, type, item) {
                            return `<input id='${item.rowId}_code'  class = 'txtInput' type="text"  disabled value='${item.itemCode}'
                                                      data-id='${item.itemId}'/>
                                                                       <input type='hidden' id='${item.rowId}_id'  value='${item.itemId}'> `;

                        }
                    },
                    {
                        data: null,
                        render: function(data, type, item) {
                            return `<input id='${item.rowId}_name' type='text' class='txtInput' disabled  value='${item.itemName}' />`;
                        }
                    },
                    {
                        data: null,
                        render: function(data, type, item) {
                            return `<input id='${item.rowId}_namee' class = 'txtInput' disabled type="text" value='${item.itemNamee}''/>`;

                        }
                    },
                    {
                        data: null,

                        render: function(data, type, item) {
                            /*          <option value="volvo">Volvo</option>
          <option value="saab">Saab</option>
          <option value="mercedes">Mercedes</option>
          <option value="audi">Audi</option> */
                            let options = '';
                          //  console.log(item);
                            if (item.itemUnites) {
                               
                                for (let index = 0; index < item.itemUnites.length; index++) {
                                    let selected = '';
                                    if (item.itemUnites[index].unitId == item.unitId || item.itemUnites.length ==0) {
                                        selected = 'selected="selected"';
                                    }
                                    options += `<option ${selected} value="${item.itemUnites[index].unitId}">${item.itemUnites[index].unitName}</option>`;
                                }

                            }

                            let str = `<select   id='${item.rowId}_unitId' class='txtInput'>
                                            ${options}
        </select>`;
                            return str;
                            //`<input id='${item.unitId}_unitId' class = 'txtInput'  type="text" value='${item.itemNamee}''/>`;

                        }
                    },
                    {
                        data: null,
                        render: function(data, type, item) {
                            return `<input id='${item.rowId}_qty' class = 'NuInput' type="number" min="1" value='${item.qty}'/>`;
                        }
                    },
                    {
                        data: null,
                        render: function(data, type, item) {
                            return `<input id='${item.rowId}_notes' class = 'txtInput' type="text" value='${item.notes}'  '/>`;
                        }
                    },
                    {
                        data: null,
                        render: function(data, type, item) {
                            return `<i class='fa fa-times-circle fa-sm' onclick='removerow(this);'></i>`;
                        }
                    }
                ]

            });
            //  move('ne');

        });

        function save() {
            let tbl = $('#tbl').DataTable();
            var allData = tbl.rows().data().toArray();


            if (allData.length == 0) {
                showerror('Insert items befor Save ');
            } else {
                $("#btnSave").attr("disabled", true);

                saveok();
            }
        }

        function saveok() {
            let tbl = $('#tbl').DataTable();
            var allData = tbl.rows().data().toArray();
            var items = [];
            for (let row = 0; row < allData.length; row++) {
                let qty = $(`#${allData[row].rowId}_qty`).val();
                let notes = $(`#${allData[row].rowId}_notes`).val();
                let unt = $(`#${allData[row].rowId}_unitId`).val();
              //  console.log(`#${allData[row].rowId}_unitId`);
             //  continue;
                items.push({
                    itemId: allData[row].itemId,
                    qty: qty,
                    notes: notes,
                    unitid: unt
                });
            }
           // return;
            var mdata = JSON.stringify(items);
            $.ajax({
                contentType: 'application/json; charset=utf-8',
                dataType: 'json',
                type: 'POST',
                url: '@Url.Action("SaveItemRequest")',
                data: mdata,
                success: function(res) {
                    if (res.isok) {
                        ShowSuccess(`Saved`).then(function() {
                            window.location = '@Url.Action("Index")';
                        });
                    } else {
                        showError(res);
                    }
                },
                failure: function(response) {
                    showError('error');
                }
            });


        }

        async function removerow(obj) {


            var row = $(obj).parent().parent();
            let tbl = $('#tbl').DataTable();
            tbl.row(row)
                .remove()
                .draw();


        }

        function showconfirm(m, callback) {
            Swal.fire({
                text: m,
                // type: 'question',
                showClass: {
                    icon: 'swal2-arabic-question-mark'
                },
                confirmButtonText: 'Yes',
                cancelButtonText: 'No',
                showCancelButton: true,
                showCloseButton: true
            }).then((result) => {


                if (result.value) {
                    callback();
                }
            });


        }


        function ShowSuccess(msg, m2) {
            return Swal.fire({
                icon: 'success',
                confirmButtonText: "Ok",
                text: m2,
                title: msg
            });
        }

    </script>
}



