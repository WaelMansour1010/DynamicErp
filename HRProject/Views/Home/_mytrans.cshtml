@using HRServices.Models
@model List<HRServices.Models.ManagerTransModel>
  
 
 <div class="ibox" id="ibox1">
     <div class="ibox-title">
         <h5>My Trans</h5>
     </div>
     <div class="ibox-content">
         <div class="sk-spinner sk-spinner-wave">
             <div class="sk-rect1"></div>
             <div class="sk-rect2"></div>
             <div class="sk-rect3"></div>
             <div class="sk-rect4"></div>
             <div class="sk-rect5"></div>
         </div>



     </div>
     <div class="ibox-footer">
         <table class="display nowrap" style="width:100% !important" id="tbldata">
             <thead>
             <tr>

                 <th>Order ID </th>
                 <th>Order Date</th>
                 <th>Type </th>
                 <th>Employee Code </th>
                 <th>Employee Name </th>
                 <th>Job</th>
                 <th>Project</th>
                 <th> Action</th>
                 <th>Status </th>

             </tr>
             </thead>
             <tbody>
             @foreach (var emp in Model)
             {
                 <tr>
                     <td>@emp.OrderId </td>
                     <td>@emp.Date </td>
                     <td>@emp.TransTypeName</td>
                     <td>@emp.EmployeeCode</td>
                     <td>@emp.EmployeeName</td>
                     <td>@emp.JobName</td>
                     <td>@emp.ProjectName</td>
                    

                     <td>
                         <div class="btn-group">
                             @{
                                 var rowId = Guid.NewGuid().ToString("D");
                             }
                             <input id="@rowId" type="hidden" value="@emp.Data" />
                             <input id="@(rowId)_o" type="hidden" value="@emp.OrderId" />
                             <input id="@(rowId)_d" type="hidden" value="@emp.Date" />
                             <input id="@(rowId)_t" type="hidden" value="@emp.TransTypeName" />
                             <input id="@(rowId)_name" type="hidden" value="@emp.EmployeeName" />
                             <input id="@(rowId)_pname" type="hidden" value="@emp.ProjectName" />
                             <input id="@(rowId)_jname" type="hidden" value="@emp.JobName" />
                             <input id="@(rowId)_ecode" type="hidden" value="@emp.EmployeeCode" />
                             @if (emp.Status == StatusEnum.Accepted)
                             {
                                    <button class="btn-danger btn btn-xs mx-auto" type="button" onclick="close( @((int)emp.TransType), @emp.OrderId);">Close</button>
                             }

                             <button class="btn-warning   btn btn-xs mx-auto" type="button" onclick="show('@rowId');">Preview</button>
                         </div>
                     </td>
                     @if (emp.Status == StatusEnum.Pinding)
                     {
                         <td> <span class="label label-success ">Pending</span> </td>
                     }
                     else if (emp.Status == StatusEnum.Accepted)
                     {
                         <td> <span class="label label-primary">Accepted</span> </td>
                     }
                     else if (emp.Status == StatusEnum.Rejected)
                     {
                         <td> <span class="label label-danger">Rejected</span> </td>
                     }
                     else if (emp.Status == StatusEnum.Approved)
                     {
                         <td>  <span class="label label-warning ">Approved</span> </td>
                     }
                     else if (emp.Status == StatusEnum.Closed)
                     {
                         <td>  <span class="label label-info  ">Closed</span> </td>
                     }


                 </tr>
             }





             </tbody>
             <tfoot>
             </tfoot>
         </table>
     </div>

 </div>
@section scripts{
    <script>
        function close(t, i) {
            alert('ss');
            $.ajax({
                url: '@Url.Action("Close")',
                type: "get",
                data: {  t: t, i: i },
                success: function(data) {
                    location.reload();
                }
            });
        }
    </script>
}