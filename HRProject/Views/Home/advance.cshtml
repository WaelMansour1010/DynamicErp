@using Microsoft.AspNetCore.Mvc.TagHelpers
@model HRServices.Models.AdvanceModel

<link href="assets/css/plugins/datapicker/datepicker3.css" rel="stylesheet">
<div class="ibox">
  
    <div class="ibox-content">
        <form id="frmadvnce" asp-action="advance" method="post">
            <div class="form-group">
                <label class="col-form-label" for="txtemployeecode">Employee</label>
                <input id="txtemployeecode" asp-for="EmployeeName" type="text" class="form-control" readonly="readonly">
            </div>
            <div class="hr-line-dashed"></div>
 
            <div class="form-group">
                <label class=" col-form-label" for="txtmngrcode">Manager </label>
                <input id="txtmngrcode" asp-for="MangerName" type="text" class="form-control" readonly="readonly">
            </div>

            <div class="hr-line-dashed"></div>
            <div class="form-group">
                        <label class="col-form-label" for="txtSearchemp1">Guarantee 1</label>
                        <input id="txtSearchemp1" type="text" class="form-control">
                        <input id="txtalteremp1" type="hidden" class="form-control" asp-for="Emp1">
                    </div>
            <div class="hr-line-dashed"></div>
            <label class="col-form-label" for="txtSearchemp2">Guarantee 2</label>
                        <div class="input-group">
                            <input id="txtSearchemp2" type="text" class="form-control">
                            <input id="txtalteremp2" type="hidden" class="form-control" asp-for="Emp2">
                        </div>
            <div class="hr-line-dashed"></div>
            <label class="col-form-label" for="txtSearchemp2">Amount</label>
            <div class="input-group">
                <input id="txtamount" type="text" class="form-control" asp-for="Amount">
            </div>
            <div class="hr-line-dashed"></div>
            <label class="col-form-label" for="txtnotes">Amount</label>
            <div class="input-group">
                <input id="txtnotes" type="text" class="form-control" asp-for="Notes">
            </div>
            <div class="ibox-footer">
                <button type="button" class="btn-danger  btn-lg" onclick="sendform();"> Send </button>
            </div>
        </form>
    </div>
</div>

@section scripts
{
    <script src="~/assets/js/plugins/jquery-ui/jquery-ui.min.js"></script>
    <script src="~/assets/js/plugins/datapicker/bootstrap-datepicker.js"></script>
    <script>
        function sendform() {
            if (!$('#txtalteremp1').val() || $('#txtalteremp1').val() == '0') {
                showError('fill Guarantee 1');
                return;
            }
            if (!$('#txtalteremp2').val() || $('#txtalteremp2').val() == '0') {
                showError('fill Guarantee 2');
                return;
            }
            if ($('#txtalteremp2').val() == $('#txtalteremp2').val() ) {
                showError(' Guarantee 1 must be different of Guarantee 2');
                return;
            }
           
            if (!isNumber($('#txtamount').val())) {
                showError('fill amount ');
            }
            $('#frmadvnce').submit();
        }

        $(document).ready(function () {
            setUpAutoCompleate();
            //$('.datepicker').datepicker({
            //    todayBtn: "linked",
            //    keyboardNavigation: false,
            //    forceParse: false,
            //    calendarWeeks: true,
            //    autoclose: true,
            //    format: 'dd/mm/yyyy'
            //});
        });
        function setUpAutoCompleate() {
            /*    name = t.Emp_Name,
                namee = t.Emp_Namee,
                id = t.Emp_ID,
                code = t.Emp_Code */

            var $elem = $('#txtSearchemp1').autocomplete({
                source: function (request, response) {

                    $.ajax({
                        url: "@Url.Action("SearchAutoCompleteEmployee")",
                        type: "get",
                        dataType: "json",
                        minLength: 3,
                        data: { word: request.term },
                        success: function (data) {
                            response($.map(data,
                                function (item) {
                                    return {
                                        label: `${item.code}-${item.namee}`,
                                        value: item.namee,
                                        id: item.id,
                                        code: item.code,
                                        name: item.name,
                                        namee: item.namee
                                    };
                                }
                            ));
                        }
                    });
                },
                select: function (event, ui) {

                    $('#txtSearchemp1').val(`${ui.item.code}-${ui.item.namee}`);
                    $('#txtalteremp1').val(ui.item.id);
                    return false;
                },
                close: function () {
                    //$('#txtSearchemp').val('');
                }
            });


            var $elem = $('#txtSearchemp2').autocomplete({
                source: function (request, response) {

                    $.ajax({
                        url: "@Url.Action("SearchAutoCompleteEmployee")",
                        type: "get",
                        dataType: "json",
                        minLength: 3,
                        data: { word: request.term },
                        success: function (data) {
                            response($.map(data,
                                function (item) {
                                    return {
                                        label: `${item.code}-${item.namee}`,
                                        value: item.namee,
                                        id: item.id,
                                        code: item.code,
                                        name: item.name,
                                        namee: item.namee
                                    };
                                }
                            ));
                        }
                    });
                },
                select: function (event, ui) {

                    $('#txtSearchemp2').val(`${ui.item.code}-${ui.item.namee}`);
                    $('#txtalteremp2').val(ui.item.id);
                    return false;
                },
                close: function () {
                    //$('#txtSearchemp').val('');
                }
            });


        }
    </script>
 }
