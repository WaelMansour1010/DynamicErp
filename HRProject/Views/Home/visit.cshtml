@using Microsoft.AspNetCore.Mvc.TagHelpers
@using HROnlineModel
@{
}
<style>
    .ui-autocomplete {
        z-index: 2147483647;
    }
    .swal2-container {
        z-index: 99999999999;
    }
</style>
<link href="assets/css/plugins/datapicker/datepicker3.css" rel="stylesheet">
<div class="ibox" id="ibox1">
    <div class="ibox-title">
        <div id="txtinfo"></div>
        <h5>Visits</h5>
        <button type="button" class="btn btn-lg btn-primary" onclick="shownew()">Add New</button>

    </div>
    <div class="ibox-content">
        <div class="sk-spinner sk-spinner-wave">
            <div class="sk-rect1"></div>
            <div class="sk-rect2"></div>
            <div class="sk-rect3"></div>
            <div class="sk-rect4"></div>
            <div class="sk-rect5"></div>
        </div>
        <table id="tblVistslist" class="table table-striped table-bordered table-hover no-footer" style="width:100% !important">

            <thead>
            <tr>
                <th>Edit</th>
                <th>Customer Code</th>
                <th>Customer Name</th>
                <th>Order Date</th>
                <th>Visit Name</th>
                <th>Visit Date</th>
                <th>SingIN Date</th>
                <th>SingOut Date</th>
                <th> Status </th>
                <th> type </th>
                <th> Notes </th>
                <th> </th>
            </tr>
            </thead>
            <tbody>
            </tbody>
        </table>
    </div>
    <div class="ibox-footer">
       
    </div>



</div>
<div class="modal inmodal" id="myModalCust" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content animated bounceInRight">
           
            <div class="modal-body">

                <div class="form-group">
                    <label class="control-label">Customer</label>
                    <input type="hidden" id="txtisnew" value="" />
                    <input type="hidden" id="txtviId" value=""/>
                    <input id="txtSearch" type="text" placeholder="Customer Code" class="form-control">
                    <input type="hidden" id="txtId" value=""/>
                </div>
                <div class="form-group">
                    <label class="control-label">Visit Name</label>
                    <input id="txtVisitName" type="text" placeholder="Visit Name" class="form-control">
                   
                </div>
                <div class="form-group">
                    <label class="control-label">Visit Date</label>
                    <input id="txtVisitDate" type="text" class="form-control datepicker"   autocomplete="off">
                </div>
                <div class="form-group">
                    <div class="row">
                        <div class="col">  <label for="txttime0">From time:</label>
                            <input type="time" class="form-control" id="txttime0" name="appt"></div>
                        <div class="col">  <label for="txttime1">To time:</label>
                            <input type="time" class="form-control" id="txttime1" name="appt"></div>
                    </div>
                  
                </div>

                <div class="form-group">
                    <label class="control-label">Visit Type</label>
                    <select class="form-control" id="txttype">
                      
                        @foreach (TblTypeVisit mtype in ViewBag.VType)
                        {
                            <option value="@mtype.Id">@mtype.namee</option>
                        }
                    </select>
                </div>


                <div class="form-group">
                    <div class="row">
                        <div class="col">
                            <label class ="control-label">
                                <input class="form-check" type="checkbox" id="chkvisitdone" />
                                Visit Done
                            </label>
                          
                        </div>
                        <div class="col">
                            <label class="control-label">
                                <input class="form-check" type="checkbox" id="chkcanceled" />
                                Canceled
                            </label>
                        </div>
                        <div class="col">
                            <label class="control-label">
                                <input class="form-check" type="checkbox" id="chkcontracted" />
                                Contracted
                            </label>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label class ="control-label">Notes</label>
                    <textarea id="txtnotes" class="form-control"></textarea>
                </div>
                 
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-danger" onclick="addnew();">Save</button>
            </div>
        </div>
    </div>
</div>

@section scripts
{
    <script src="~/assets/js/plugins/jquery-ui/jquery-ui.min.js"></script>
    <script src="~/assets/js/plugins/datapicker/bootstrap-datepicker.js"></script>
    <script src="~/js/loc.js?v=123"></script>

    <script>

        var tblBooks;

        function shownew() {
            setUpAutoCompleate();
            $('#txtisnew').val('1');
            $('#txtSearch').val('');
            $('#txtId').val('');
            $('#txtviId').val('');
            $('#txtVisitName').val('');
            $('#txtVisitDate').val('');
            $('#txttime0').val('');
            $('#txttime1').val('');
            $('#txtnotes').val('');
            $("#chkvisitdone").prop("checked",false);
            $("#chkcanceled").prop("checked", false);
            $("#chkcontracted").prop("checked", false);
            $("#txttype").val('');
            $('#myModalCust').modal('show');

        }
        function edit(id) {
            setUpAutoCompleate();
            $('#txtviId').val(id);
            $.ajax({
                url: '/home/getvisit',
                type: "get",
                data: { id: id},
                success: function (res) {
                    loading(false);
                    if (res.isok) {
                      
                        $('#txtSearch').val(res.data.customername);
                        $('#txtisnew').val('0');
                        $('#txtId').val(res.data.customerid);
                        $('#txtviId').val(res.data.id);
                        $('#txtVisitName').val(res.data.visitname);
                        $('#txtVisitDate').val(res.data.date);
                        $('#txttime0').val(res.data.time0);
                        $('#txttime1').val(res.data.time1);
                        $('#txtnotes').val(res.data.notes);
                        $("#chkvisitdone").prop("checked", res.data.visitdone);
                        $("#chkcanceled").prop("checked", res.data.canceled);
                        $("#chkcontracted").prop("checked", res.data.contracted);
                        $("#txttype").val(res.data.type);
                        $('#myModalCust').modal('show');
                    } else {
                        showError(data.msg);
                    }
                },
                error: () => {
                    loading(false);
                    showError('Error');
                }
            });
          

        }

        function setpiker() {
            $('.datepicker').datepicker({
                todayBtn: "linked",
                keyboardNavigation: false,
                forceParse: false,
                calendarWeeks: true,
                autoclose: true,
                format: 'dd/mm/yyyy'
            });
        }

        function setUpAutoCompleate() {


            var $elem = $('#txtSearch').autocomplete({
                source: function(request, response) {

                    $.ajax({
                        url: "@Url.Action("SearchAutoCompleteCustomer")",
                        type: "get",
                        dataType: "json",
                        minLength: 3,
                        data: { word: request.term },
                        success: function(data) {
                            response($.map(data,
                                function(item) {
                                    return {
                                        label: `${item.fullcode}-${item.namee}`,
                                        value: item.namee,
                                        id: item.id,
                                        code: item.fullcode,
                                        name: item.name,
                                        namee: item.namee
                                    };
                                }
                            ));
                        }
                    });
                },
                select: function(event, ui) {
                    $('#txtSearch').val(`${ui.item.code}-${ui.item.namee}`);
                    $('#txtId').val(ui.item.id);
                    return false;
                },
                close: function() {
                    // $('#txtSearch').val('');
                }
            });


        }


        $(document).ready(() => {
            setpiker();
            navigator.geolocation.watchPosition(function(position) {
                    $('#txtinfo').html(`<div class="alert alert-success  fade show" role="alert">
                    <strong>Location Permssion Allowed </strong>
                  
                </div>`);
                },
                function(error) {
                    let myerror = 'Error';
                    switch (error.code) {
                    case error.PERMISSION_DENIED:
                        myerror = 'PERMISSION DENIED';
                        break;
                    case error.POSITION_UNAVAILABLE:
                        myerror = 'POSITION UNAVAILABLE';
                        break;
                    case error.TIMEOUT:
                        myerror = 'Error TIMEOUT';
                        break;


                    default:
                    }

                    $('#txtinfo').html(`<div class="alert alert-danger  fade show" role="alert">
                                            <strong>Location  ${myerror}</strong>
                          
                        </div>`);

                });
            // setUpAutoCompleate();
            tblBooks = $('#tblVistslist').DataTable({
                "proccessing": true,
                "serverSide": true,
                "ajax": {
                    url: '@Url.Action("VisitList")',
                    type: 'POST'
                },
                responsive: true,
                searching: true,
                destroy: true,
                columns: [
                    {
                        title: 'Edit',
                        data: null,
                        render: function(data, type, item) {
                            return `<button type="button" class="btn  " onclick="edit('${item.id}')"><i class="fa fa-pencil-square-o" aria-hidden="true"></i></button>`;
                        }
                    },
                    { title: 'Customer Code', data: 'code' },
                    {
                        title: 'Customer Name',
                        data: 'name'
                    },
                    { title: 'Order Date', data: 'orderdate' },
                    { title: 'Visit Name', data: 'visitname' },
                    { title: 'visit Date', data: 'visitdate' },
                    { title: 'Sign IN Date', data: 'signindate' },
                    { title: 'Sign out Date', data: 'signoutdate' },
                    { title: 'Status', data: 'notes2' },
                    { title: 'Type', data: 'type' },
                    { title: 'Notes', data: 'notes' },
                    {
                        //btn btn-default btn-xs
                        title: 'Action',
                        data: null,
                        render: function(data, type, item) {
                            let ctl = '';
                            if (item.signindate) {
                                ctl += ` <a href="https://maps.google.com/?q=${item.signinlocation}" class="btn btn-lg btn-info btn-xs  m-1" target="_blank">sign in location</a>`;
                            }
                            if (!item.signindate && !item.signoutdate) {
                                ctl += `<button type="button" class="btn btn-lg btn-success btn-xs  m-1 btns" onclick="locLog('${item.id}')">Sign In</button>`;
                            }
                            if (item.signindate && !item.signoutdate) {
                                ctl += `<button type="button" class="btn btn-lg btn-danger btn-xs  m-1 btns" onclick="loclogOut('${item.id}')">Sign Out</button>`;
                            }


                            if (item.signoutdate) {
                                ctl += ` <a href="https://maps.google.com/?q=${item.signoutlocation}" class="btn btn-lg btn-info btn-xs  m-1" target="_blank">sign out location</a>`;

                            }

                            return ctl;
                        }
                    }
                ]
            });
        });
    </script>


}
