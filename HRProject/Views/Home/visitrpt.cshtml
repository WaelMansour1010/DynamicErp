@using Microsoft.AspNetCore.Mvc.TagHelpers
@using HROnlineModel
@model List<HRServices.Models.VisitDataModel>
@{
}
<style>
    .ui-autocomplete {
        z-index: 2147483647;
    }
    .swal2-container {
        z-index: 99999999999;
    }
</style>
<link href="assets/css/plugins/datapicker/datepicker3.css" rel="stylesheet">
<div class="ibox" id="ibox1">
    <div class="ibox-title">
        <div id="txtinfo"></div>
        <h5>Visits Reprot</h5>
       

    </div>
    <div class="ibox-content">
        <div class="sk-spinner sk-spinner-wave">
            <div class="sk-rect1"></div>
            <div class="sk-rect2"></div>
            <div class="sk-rect3"></div>
            <div class="sk-rect4"></div>
            <div class="sk-rect5"></div>
        </div>
        <table id="tblVistslist" class="table table-striped table-bordered table-hover no-footer" style="width:100% !important">

            <thead>
            <tr>
              
                <th>Customer Code</th>
                <th>Customer Name</th>
                <th>Order Date</th>
                <th>Visit Name</th>
                <th>Visit Date</th>
                <th>SingIN Date</th>
                <th>SingOut Date</th>
                <th>Visit Time</th>
                <th> Status </th>
                <th> type </th>
                <th> Notes </th>
            </tr>
            </thead>
            <tbody>
            @foreach (var v in Model)
            {
                <tr>
                    <td>@v.code</td>
                    <td>@v.name</td>
                    <td>@v.orderdate</td>
                    <td>@v.visitname</td>
                    <td>@v.visitdate</td>
                    <td>@v.signindate</td>
                    <td>@v.signoutdate</td>
                    <td>@v.visittime</td>
                    <td>@v.notes2</td>
                    <td>@v.type</td>
                    <td>@v.notes</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    <div class="ibox-footer">
       
    </div>



</div>
 

@section scripts
{
    <script src="~/assets/js/plugins/jquery-ui/jquery-ui.min.js"></script>
    <script src="~/assets/js/plugins/datapicker/bootstrap-datepicker.js"></script>
    <script src="~/js/loc.js?v=123"></script>

    <script>

        var tblBooks;

 

     


        $(document).ready(() => {
 
            tblBooks = $('#tblVistslist').DataTable({
                responsive: true,
                searching: true,
                paging: true
            });
        });
    </script>


}
