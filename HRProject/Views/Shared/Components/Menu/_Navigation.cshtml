
@model UserViewModel
<style>
    #imgLogo {
        vertical-align: middle;
        border-style: none;
        height: 60px;
        width: 60px;
    }
</style>
<nav class="navbar-default navbar-static-side" role="navigation">
    <div class="sidebar-collapse">
        <ul class="nav metismenu" id="side-menu">
            <li class="nav-header">
                <div class="dropdown profile-element">
                    <img id="imgLogo" alt="image" class="rounded-circle" src="/image/logo.jpeg" />
                    <a data-toggle="dropdown" class="dropdown-toggle" href="#">
                        <span class="block m-t-xs font-bold">@Model.UserName</span>
                        @*  <span class="text-muted text-xs block">@Model.BranchName <b class="caret"></b></span>*@
                    </a>
                    <ul class="dropdown-menu animated fadeInRight m-t-xs">
                       
                        <li class="dropdown-divider"></li>
                        <li>
                            <form action="@Url.Action("logout", "Account")" method="post">
                                @Html.AntiForgeryToken()
                                <button class="dropdown-item" type="submit">Logout</button>
                            </form>
                        </li>
                        <li>
                            <button class="dropdown-item" type="button" onclick="changep();">Change Password</button>
                        </li>
                    </ul>
                </div>
                <div class="logo-element">
                    EC
                </div>
            </li>
            @*   @if (@Model.IsAdmin)
            {
                <li>
                    <a href="@Url.Action("index","Home")"><i class="fa fa-th-large"></i> <span class="nav-label">System</span> <span class="fa arrow"></span></a>
                
                    <ul class="nav nav-second-level collapse">
                        <li><a href="@Url.Action("index" , "Users")">Users</a></li>
                        <li><a href="@Url.Action("index","Branches")">Branches</a></li>

                    </ul>
                </li>
            }*@
           

            <li class="active">
            <a href="#"><i class="fa fa-bar-chart-o"></i> <span class="nav-label">Report</span><span class="fa arrow"></span></a>
            <ul class="nav nav-second-level collapse in">
                <li><a href="@Url.Action("Index","Home")">All Transactions</a></li>
                <li><a href="@Url.Action("EmployeeTrans","Home")">My Requests</a></li>
                    @if (@CurrentSession.location)
                    {
                      <li><a href="@Url.Action("visitrpt","Home")">visits</a></li>
                    }
                    
            </ul>

        </ul>

    </div>
</nav>

<div class="modal inmodal" id="myModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content animated bounceInRight">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal"><span aria-hidden="true">&times;</span><span class="sr-only">Close</span></button>
                <i class="fa fa-laptop modal-icon"></i>
                <h4 class="modal-title">Change password</h4>
              
            </div>
            <div class="modal-body">

                <div class="form-group">
                    <label>current password</label>
                    <input id="txtpass" type="password" placeholder="Enter  current password" class="form-control">
                </div>
                <div class="form-group">
                    <label>New password</label>
                    <input id="txtnpass" type="password" placeholder="Enter  new password" class="form-control">
                </div>
                <div class="form-group">
                    <label>confirm password</label>
                    <input id="txtcnpass" type="password" placeholder="Enter  confirm password" class="form-control">
                </div>
            </div>
            <div class="modal-footer">
           
                <button type="button" class="btn btn-danger" onclick="dochange();">Save</button>
            </div>
        </div>
    </div>
</div>
 