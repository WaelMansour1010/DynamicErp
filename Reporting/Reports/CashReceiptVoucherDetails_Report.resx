  <data name="customSqlQuery1.Sql" xml:space="preserve">
    <value>SELECT        CashReceiptVoucher.DocumentNumber, CONVERT(nvarchar, CashReceiptVoucher.MoneyAmount) AS MoneyAmount, CashReceiptVoucher.Date, CashReceiptVoucher.CurrencyEquivalent, CashReceiptVoucher.Notes, 
                         Customer.ArName AS Customer, CashReceiptSourceType.ArName AS CashReceiptSource, Currency.ArName AS Currency, ChartOfAccount.ArName AS Account, Vendor.ArName AS Vendor, Employee.ArName AS Employee, 
                         Department.ArName AS Department, Branch.ArName AS Branch, CashBox.ArName AS CashBox, BankAccount.AccountNumber, CashReceiptVoucher.TransactionNo, CashReceiptVoucher.TransactionDate, 
                         Emp.ArName AS EmployeeName, DirectRevenue.ArName AS DirectRevenue, ShareHolder.ArName AS ShareHolder, CashIssuePaymentMethod.ArName AS PaymentMethodName, 
                         CashIssuePaymentMethod.EnName AS EnPaymentMethodName, CashReceiptVoucherPropertyContractBatch.Paid, CashReceiptVoucherPropertyContractBatch.Remain, CashReceiptVoucherPropertyContractBatch.IsDelivered, 
                         PropertyContractBatch.BatchNo, PropertyContractBatch.BatchDate, PropertyContractBatch.BatchRentValue, PropertyContractBatch.BatchRentValueTaxes, PropertyContractBatch.BatchTotal
FROM            PropertyContractBatch INNER JOIN
                         ERPUser AS [User] ON PropertyContractBatch.UserId = [User].Id RIGHT OUTER JOIN
                         CashReceiptVoucherPropertyContractBatch ON PropertyContractBatch.Id = CashReceiptVoucherPropertyContractBatch.PropertyContractBatchId 
and CashReceiptVoucherPropertyContractBatch.paid &lt;&gt; 0
RIGHT OUTER JOIN
                         CashReceiptVoucher AS CashReceiptVoucher ON CashReceiptVoucherPropertyContractBatch.CashReceiptVoucherId = CashReceiptVoucher.Id AND [User].Id = CashReceiptVoucher.UserId LEFT OUTER JOIN
                         Branch AS Branch ON Branch.Id = CashReceiptVoucher.BranchId LEFT OUTER JOIN
                         CashReceiptSourceType AS CashReceiptSourceType ON CashReceiptSourceType.Id = CashReceiptVoucher.SourceTypeId LEFT OUTER JOIN
                         Currency AS Currency ON Currency.Id = CashReceiptVoucher.CurrencyId LEFT OUTER JOIN
                         ChartOfAccount AS ChartOfAccount ON ChartOfAccount.Id = CashReceiptVoucher.AccountId LEFT OUTER JOIN
                         DirectRevenue AS DirectRevenue ON DirectRevenue.Id = CashReceiptVoucher.DirectRevenueId LEFT OUTER JOIN
                         Customer AS Customer ON Customer.Id = CashReceiptVoucher.CustomerId LEFT OUTER JOIN
                         Vendor AS Vendor ON Vendor.Id = CashReceiptVoucher.VendorId LEFT OUTER JOIN
                         Employee AS Emp ON Emp.Id = [User].EmployeeId LEFT OUTER JOIN
                         Employee AS Employee ON Employee.Id = CashReceiptVoucher.EmployeeId LEFT OUTER JOIN
                         Department AS Department ON Department.Id = CashReceiptVoucher.DepartmentId LEFT OUTER JOIN
                         CashBox AS CashBox ON CashBox.Id = CashReceiptVoucher.CashBoxId LEFT OUTER JOIN
                         BankAccount AS BankAccount ON BankAccount.Id = CashReceiptVoucher.BankAccountId LEFT OUTER JOIN
                         ShareHolder AS ShareHolder ON ShareHolder.Id = CashReceiptVoucher.ShareholderId LEFT OUTER JOIN
                         CashIssuePaymentMethod AS CashIssuePaymentMethod ON CashIssuePaymentMethod.Id = CashReceiptVoucher.CashReceiptPaymentMethodId

where
       (("CashReceiptVoucher"."DocumentNumber" = @DocumentNumber)
       and ("CashReceiptVoucher"."DepartmentId" = @DepId)
and ("CashReceiptVoucher"."IsDeleted" = 0)
and ("CashReceiptVoucher"."IsActive" = 1)
and (@Id is null or "CashReceiptVoucher"."Id" = @Id))</value>
