  <data name="customSqlQuery1.Sql" xml:space="preserve">
    <value>select 
(SELECT REPLACE(DebitAndCreditNotification.DocumentNumber, '-', ''))DocumentNumber,
       convert(nvarchar,DebitAndCreditNotification.TotalMoneyAmount)TotalMoneyAmount,
       DebitAndCreditNotification.Date,CurrencyEquivalent,DebitAndCreditNotification.Notes as Notes,
       DebitAndCreditNotification.InvoiceNo,       
       DebitAndCreditNotification.IssuedPerson,       
       DebitAndCreditNotificationSourceType.ArName as CashReceiptSource,
       Currency.ArName as Currency,
       ChartOfAccount.ArName as Account,
       Department.ArName as Department,
	   Emp.ArName as EmployeeName,
	   
	   NotificationType.ArName as NotificationType,
	  --(select  top(1) ss.CommercialRegistrationNo from SystemSetting ss) CommercialRegistrationNo,
      --(select  top(1) ss.CompanyEnName from SystemSetting ss) CompanyEnName,
      --(select  top(1) ss.StreetArName from SystemSetting ss) StreetArName,
      --(select  top(1) ss.StreetEnName from SystemSetting ss) StreetEnName,
	  (select top(1)  ss.TaxCardNumber from SystemSetting ss) TaxCardNumber,
      (select  top(1) ss.CompanyArName from SystemSetting ss) CompanyArName

from dbo.DebitAndCreditNotification
       DebitAndCreditNotification
 
  left join dbo.DebitAndCreditNotificationSourceType
       DebitAndCreditNotificationSourceType
       on (DebitAndCreditNotificationSourceType.Id = DebitAndCreditNotification.SourceTypeId)
  left join dbo.Currency Currency
       on (Currency.Id = DebitAndCreditNotification.CurrencyId)
  left join dbo.ChartOfAccount
       ChartOfAccount
       on (ChartOfAccount.Id = DebitAndCreditNotification.AccountId)
  left join dbo.ERPUser u
       on (u.Id = DebitAndCreditNotification.UserId)
  left join dbo.Employee Emp
       on (Emp.Id = u.EmployeeId)

  left join dbo.Department Department
       on (Department.Id = DebitAndCreditNotification.DepartmentId)
	    left join dbo.DebitAndCreditNotificationType NotificationType
       on (NotificationType.Id = DebitAndCreditNotification.DebitAndCreditNotificationTypeId)

where
((DebitAndCreditNotification.DocumentNumber = @DocumentNumber)
and (DebitAndCreditNotification.DepartmentId = @DepId)
and (DebitAndCreditNotification.IsDeleted = 0)
and (DebitAndCreditNotification.IsActive = 1)
and (@Id is null or DebitAndCreditNotification.Id = @Id))</value>
  </data>
