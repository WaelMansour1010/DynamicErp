  <data name="customSqlQuery1.Sql" xml:space="preserve">
    <value>SELECT
    pb.Id AS BatchId,
    pb.BatchNo,
    pb.BatchDate,
    ISNULL(pb.AddValue, 0) + ISNULL(pb.BatchTaxValue, 0) + ISNULL(pb.BatchValueBeforeDiscountAddtionAndTax, 0) - ISNULL(pb.Discount, 0) AS TotalBatchValue,
    pb.TotalPaid,
    (ISNULL(pb.AddValue, 0) + ISNULL(pb.BatchTaxValue, 0) + ISNULL(pb.BatchValueBeforeDiscountAddtionAndTax, 0) - ISNULL(pb.Discount, 0)) - ISNULL(pb.TotalPaid, 0) AS Remain,
    pb.Discount,
    pb.BatchTaxValue,
    pb.AddValue,
    pb.Notes,
    pb.UserId,
    pb.MainDocId,
    pr.ArName AS PropertyName,
    po.ArName AS OwnerName,
    t.ArName AS PropertyType,
    
    dept.ArName AS Department,
    dept.Id AS DepartmentId,
    pr.Id AS PropertyId,pr.PropertyOwnerId
,
    -- ملاحظات السداد الجزئي
    CASE 
        WHEN pb.TotalPaid &gt; 0 
             AND (ISNULL(pb.AddValue, 0) + ISNULL(pb.BatchTaxValue, 0) + ISNULL(pb.BatchValueBeforeDiscountAddtionAndTax, 0) - ISNULL(pb.Discount, 0)) &gt; pb.TotalPaid
        THEN N'سداد جزئي' ELSE N'' END AS PartialPaymentNote_Ar,
    CASE 
        WHEN pb.TotalPaid &gt; 0 
             AND (ISNULL(pb.AddValue, 0) + ISNULL(pb.BatchTaxValue, 0) + ISNULL(pb.BatchValueBeforeDiscountAddtionAndTax, 0) - ISNULL(pb.Discount, 0)) &gt; pb.TotalPaid
        THEN 'Partial Payment' ELSE '' END AS PartialPaymentNote_En
FROM
    PropertyBatch pb
    INNER JOIN Property pr ON pr.Id = pb.MainDocId
    INNER JOIN PropertyOwner po ON po.Id = pr.PropertyOwnerId
    LEFT JOIN PropertyType t ON t.Id = pr.PropertyTypeId
    LEFT JOIN Department dept ON dept.Id = pr.DepartmentId
    
WHERE
   pb.IsDeleted = 0
    AND (ISNULL(pb.AddValue, 0) + ISNULL(pb.BatchTaxValue, 0) + ISNULL(pb.BatchValueBeforeDiscountAddtionAndTax, 0) - ISNULL(pb.Discount, 0)) &gt; ISNULL(pb.TotalPaid, 0)
AND (@DateFrom IS NULL OR pb.BatchDate &gt;= @DateFrom)
   AND (@DateTo IS NULL OR pb.BatchDate &lt;= @DateTo)
   AND (@OwnerId IS NULL OR po.Id = @OwnerId)

  AND (@PropertyId IS NULL OR pr.Id = @PropertyId)
  AND (@DepartmentId IS NULL OR dept.Id = @DepartmentId)
ORDER BY
    pb.BatchDate DESC, pb.BatchNo</value>
  </data>
