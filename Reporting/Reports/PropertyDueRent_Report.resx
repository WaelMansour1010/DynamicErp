  <data name="customSqlQuery1.Sql" xml:space="preserve">
    <value>--Declare @DateFrom date ,@DateTo date ,@RenterId int ,@PropertyId int


SELECT
    DISTINCT
    c.Id,
    c.DocumentNumber AS ContractNo,
    r.ArName AS Renter,
    r.Mobile AS RenterMobile,
    cb.BatchNo,
    cb.BatchDate,
    p.ArName AS Property,
    t.ArName AS PropertyType,
    d.PropertyUnitNo,
    (ISNULL(cb.BatchTotal, 0)) AS Total,
    ISNULL(SUM(b.Paid), 0) AS Paid,  -- تجميع إجمالي المدفوعات
	
    Remain = (ISNULL(cb.BatchTotal, 0))-ISNULL(SUM(b.Paid), 0),
    dept.ArName AS Department,
	dept.Id as deptId,    
	p.Id as PropertyId
FROM PropertyContract c
INNER JOIN PropertyContractBatch cb
    ON cb.MainDocId = c.Id
LEFT JOIN CashReceiptVoucherPropertyContractBatch b
    ON b.PropertyContractBatchId = cb.Id
INNER JOIN PropertyRenter r
    ON r.Id = c.PropertyRenterId
INNER JOIN Property p
    ON p.Id = c.PropertyId
	and  p.IsActive =1
INNER JOIN PropertyType t
    ON t.Id = p.PropertyTypeId
INNER JOIN PropertyDetail d
    ON c.PropertyUnitId = d.Id
INNER JOIN Department dept
    ON dept.Id = c.DepartmentId
where 

c.IsDeleted=0
 and(@DateFrom is null or cb.BatchDate&gt;= @DateFrom) 
 and(@DateTo is null or cb.BatchDate&lt;= @DateTo) 
 and(@RenterId is null or c.PropertyRenterId= @RenterId) 
 and(@PropertyId is null or c.PropertyId= @PropertyId) 
and c.Id Not In (Select pc.PropertyContractId from PropertyContractTermination PC)
 and(@DepartmentId is null or c.DepartmentId= @DepartmentId) 


GROUP BY
    c.Id,
    c.DocumentNumber,
    r.ArName,
    r.Mobile,
    cb.BatchNo,
    cb.BatchDate,
    p.ArName,
    t.ArName,
    d.PropertyUnitNo,
    cb.BatchTotal,
    dept.ArName,
dept.Id ,    
	p.Id 
	HAVING
    (ISNULL(cb.BatchTotal, 0)) - ISNULL(SUM(b.Paid), 0) &lt;&gt; 0</value>
  </data>
