@{ 
    UICulture = Session["lang"] != null?Session["lang"].ToString():"ar";
}
<div style="text-align: left;padding-bottom: 23px;">
</div>


<div class="panel panel-widget forms-panel">
    <div class="forms">
        <div class=" form-grids form-grids-right">
            <div class="widget-shadow " data-example-id="basic-forms">
                <div class="tables">
                    <div class="form-title">
                        <input type="button" class="btn btn-info btnAdd" name="AddEdit" value=@MyERP.Properties.Resources.AddNew
                               onclick="$('#preloader, #status').fadeIn();
                                                    $.ajax(
                                                        {
                                                            url: '/AdvertisingCompaigns/AddEdit',
                                                            type: 'Get',
                                                            success: function (r) {

                                                                $('.main-page').html(r);
                                                                $('#preloader, #status').fadeOut();
                                                            }
                                                        });" style="float:left;">
                        <h4>@MyERP.Properties.Resources.AdvertisingCampaigns :</h4>
                    </div>
                    @Html.Partial("~/Views/PartialViews/_SearchView.cshtml")


                </div>
            </div>
        </div>
    </div>
</div>

<div class="panel panel-widget forms-panel">
    <div class="forms">
        <div class=" form-grids form-grids-right">
            <div class="widget-shadow " data-example-id="basic-forms">
                <div class="tables">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>@MyERP.Properties.Resources.Code</th>
                                <th>@MyERP.Properties.Resources.ArName</th>
                                <th>@MyERP.Properties.Resources.EnName</th>
                                <th>@MyERP.Properties.Resources.StartDate </th>
                                <th>@MyERP.Properties.Resources.EndDate</th>

                                <th>@MyERP.Properties.Resources.Edit</th>
                                <th>@MyERP.Properties.Resources.Active</th>
                                <th>@MyERP.Properties.Resources.Delete</th>
                            </tr>
                        </thead>
                        <tbody id="detailsBody"></tbody>
                    </table>
                </div>

            </div>
        </div>
    </div>
</div>

@Html.Partial("~/Views/PartialViews/_PagerView.cshtml")


<script>

    var pageNo = 1;

    function LoadData() {
        $('#preloader, #status').fadeIn();
        $.ajax(
            {
                url: MainDomain + 'api/AdvertisingCompaigns/'+ pageNo + '/' + $('#ShowByPage').val() + '/' + $('.searchtxt').val(),
                type: 'Get',
                beforeSend: function (xhr) {
                    xhr.setRequestHeader('Authorization', 'Bearer ' + $("#userToken").val());
                },
                error: function (e) {
                    console.log(e);

                },
                success: function (r) {

                    $('#detailsBody').html('');
                    newHTML = '';

                    lst = $.parseJSON(r.list);

                    for (var i = 0; i < lst.length; i++) {
                        newHTML += '<tr>' +
                            '<th scope="row">' + CheckNullObject(lst[i].Code) + '</th>' +
                            '<td>' + CheckNullObject(lst[i].ArName) + '</td>' +
                            '<td>' + CheckNullObject(lst[i].EnName) + '</td>' +
                            '<td>' + CheckNullObject(lst[i].StartDate) + '</td>' +
                            '<td>' + CheckNullObject(lst[i].EndDate) + '</td>' +
                            '<td><a href="javascript:void(0);" onclick="$(\'#preloader\').fadeIn();' +
                            '$.ajax(' +
                            '{' +
                            'url: \'/AdvertisingCompaigns/AddEdit/' + lst[i].Id + '\',' +
                            'type: \'Get\',' +
                            'beforeSend: function (xhr) {' +
                            'xhr.setRequestHeader(\'Authorization\', \'Bearer ' + $("#userToken").val() + '\'' +
                            ')},' +
                            'success: function (r) {' +
                            '$(\'.main-page\').html(r);' +
                            '}' +
                            '});"><i class="fa fa-edit"></i></a></td>' +
                           '<td>\
                            <label class="switch">\
                            <input class="switch-input" type="checkbox" ' + (lst[i].IsActive ? 'Checked' : '') +'  onclick="ActivateFunc(' + lst[i].Id + ',\'@ViewContext.RouteData.Values["controller"].ToString()\')"/>\
                            <span class="switch-label" data-on="'+'@MyERP.Properties.Resources.Active'+'" data-off="'+'@MyERP.Properties.Resources.InActive'+'"></span>\
                             <span class="switch-handle"></span> \
                             </label ></td>'+
                            '<td><a href="javascript:void(0);" onclick="DeleteFunc(' + lst[i].Id + ',\'@ViewContext.RouteData.Values["controller"].ToString()\')"><i class="fas fa-trash-alt"></i></a></td>' +
                            '</tr>';
                    }

                    $('.pagination').html('');

                    for (var i = 0; i < Math.ceil(r.count / $('#ShowByPage').val()); i++)
                        $('.pagination').append('<li id="pg' + (i + 1) + '"><a href="javascript:void(0);" onclick="GoToPage(' + (i + 1) + ');">' + (i + 1) + '</a></li>');

                    if (lst.length == 0)
                        $('#detailsBody').append("<div style='text-align: center;position: absolute;width:100%;'>'"+'@MyERP.Properties.Resources.NoDataFound'+"'</div > ");

                    $('#RowsCount').html(r.count);

                    $('.pagination li').removeClass("active");

                    $('#pg' + pageNo).addClass("active");

                    $('#detailsBody').append(newHTML);

                    $('#preloader, #status').fadeOut();
                },
                complete: function () {



                }
            });
    }

    LoadData();


    function DeleteFunc(id, controllerName) {
        if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToDelete')) {

            $('#preloader, #status').fadeIn();
            $.ajax(
                {

                    url: MainDomain + 'api/' + controllerName + '/' + id + '?userId=1',
                    type: 'DELETE',
                    data: {
                        "Id": id,

                    },
                    beforeSend: function (xhr) {
                        xhr.setRequestHeader('Authorization', 'Bearer ' + $("#userToken").val());
                    },
                    error: function (e) {



                    },
                    success: function (r) {

                        back('@ViewContext.RouteData.Values["controller"].ToString()');

                    }
                });
        }

    }
    function ActivateFunc(id, controllerName) {
        if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToChangeActiveState')) {

            $('#preloader, #status').fadeIn();
            $.ajax(
                {

                    url: MainDomain + 'api/' + controllerName + '/ActivateAsync/' + id,
                    type: 'PUT',
                    data: {
                        "Id": id,
                        "IsActive": false,

                    },
                    beforeSend: function (xhr) {
                        xhr.setRequestHeader('Authorization', 'Bearer ' + $("#userToken").val());
                    },
                    error: function (e) {



                    },
                    success: function (r) {

                        back('@ViewContext.RouteData.Values["controller"].ToString()');

                    }
                });
        }

}

</script>

