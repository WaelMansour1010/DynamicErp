@model MyERP.Models.BorrowRequest

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";

    ViewBag.Title = MyERP.Properties.Resources.BorrowRequest;
}
<script src="~/Scripts/SaveAndNew.js"></script>

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                @if (Model != null)
                {
                    if (Model.IsDeleted == false)
                    {
                        if (ViewBag.Previous > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.First })" class="btn btn-info">@MyERP.Properties.Resources.First</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Previous })" class=" btn btn-info">&#8250;</a>
                        }
                        if (ViewBag.Next > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Next })" class="btn btn-info">&#8249;</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Last })" class="btn btn-info">@MyERP.Properties.Resources.Last</a>
                        }
                    }
                }
                <a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
            </div>
            <div class="hed page-title">@MyERP.Properties.Resources.BorrowRequest :</div>
        </div>
    </div>
</div>
<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="form-horizontal needs-validation" role="form">

                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">
                                <div class="form-group row">
                                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                    @Html.AntiForgeryToken()
                                    @if (Model != null)
                                    {
                                        @Html.HiddenFor(model => model.Id)
                                        @Html.HiddenFor(model => model.UserId)
                                        @Html.HiddenFor(model => model.Image)
                                        @Html.HiddenFor(model => model.IsDeleted)
                                        @Html.HiddenFor(model => model.IsDelivered)
                                        @Html.HiddenFor(model => model.IsAccepted)
                                        @Html.HiddenFor(model => model.IsLinked)
                                        @Html.HiddenFor(model => model.IsCompleted)
                                        @Html.HiddenFor(model => model.IsPosted)
                                        @Html.HiddenFor(model => model.AutoCreated)
                                        @Html.HiddenFor(model => model.SystemPageId)
                                        @Html.HiddenFor(model => model.SelectedId)
                                    }

                                    <label class=" col-sm-2 control-label" for="DocumentNumber">@MyERP.Properties.Resources.DocNo</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.DocumentNumber, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly", placeholder = @MyERP.Properties.Resources.DocNo, hidden = "hidden" } })
                                        <input id="DocumentNumbers" class="form-control" placeholder=@MyERP.Properties.Resources.DocNo required readonly />
                                    </div>
                                    <label for="DepartmentId" class="control-label col-sm-2">@MyERP.Properties.Resources.Department</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownListFor(model => model.DepartmentId, null, null, htmlAttributes: new { @class = "form-control", @required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="EmployeeId" class="control-label col-sm-2">@MyERP.Properties.Resources.Employee</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownListFor(model => model.EmployeeId, null, null, htmlAttributes: new { @class = "form-control", @required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label class="col-sm-2 control-label " for="VoucherDate">@MyERP.Properties.Resources.VoucherDate</label>
                                    <div class="col-sm-4">
                                        <input type="datetime-local" name="VoucherDate" id="VoucherDate" class="form-control" value="@ViewBag.VoucherDate" required />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="col-sm-2 control-label " for="BorrowRequestDate">@MyERP.Properties.Resources.BorrowRequestDate</label>
                                    <div class="col-sm-4">
                                        <input type="date" name="BorrowRequestDate" @Html.Raw(Model != null && Model.IsIssued == true ? "disabled" : "") id="BorrowRequestDate" class="form-control" value="@ViewBag.BorrowRequestDate" required />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label class=" col-sm-2 control-label" for="BorrowValue">@MyERP.Properties.Resources.BorrowValue</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.BorrowValue, new { htmlAttributes = new { @class = "form-control", @required = "required", placeholder = @MyERP.Properties.Resources.BorrowValue, @type = "number" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class=" col-sm-2 control-label" for="InstallmentValue">@MyERP.Properties.Resources.InstallmentValue</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.InstallmentValue, new { htmlAttributes = new { @class = "form-control", @required = "required", placeholder = @MyERP.Properties.Resources.InstallmentValue, @type = "number" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label class=" col-sm-2 control-label" for="InstallmentNo">@MyERP.Properties.Resources.InstallmentNo</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.InstallmentNo, new { htmlAttributes = new { @class = "form-control", @required = "required", placeholder = @MyERP.Properties.Resources.InstallmentNo, @type = "text" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="col-sm-2 control-label " for="InstallmentFirstDate">@MyERP.Properties.Resources.InstallmentFirstDate</label>
                                    <div class="col-sm-4">
                                        <input type="date" name="InstallmentFirstDate" @Html.Raw(Model != null && Model.IsIssued == true ? "disabled" : "") id="InstallmentFirstDate" class="form-control" value="@ViewBag.InstallmentFirstDate" required />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <div class="col-sm-6">
                                        <div class="col-sm-4">
                                            <input type="checkbox" disabled name="IsIssued" @Html.Raw(Model != null && Model.IsIssued == true ? "checked" : "") id="IsIssued" />
                                            <label class="col-sm-10 control-label" for="IsIssued">
                                                @MyERP.Properties.Resources.IsIssued
                                            </label>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="BorrowStatusId" class="control-label col-sm-2">@MyERP.Properties.Resources.BorrowStatus</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownListFor(model => model.BorrowStatusId, null, null, htmlAttributes: new { @class = "form-control" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label class=" col-sm-2 control-label RefuseReason" style="display:none;" for="RefuseReason">@MyERP.Properties.Resources.RefuseReason</label>
                                    <div class="col-sm-4 RefuseReason" style="display:none;">
                                        @Html.EditorFor(model => model.RefuseReason, new { htmlAttributes = new { @class = "form-control" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="control-label col-sm-2" for="Notes">@MyERP.Properties.Resources.Notes</label>
                                    <div class="col-sm-4">
                                        <textarea id="Notes" name="Notes" class="form-control" rows="5" cols="5">@if (Model != null) { @Model.Notes; }</textarea>
                                        @Html.ValidationMessageFor(model => model.Notes, "", new { @class = "text-danger" })
                                    </div>


                                </div>

                                <!--Details Table-->
                                <div class="row">
                                    <div class="col-12">
                                        <div class="form-horizontal needs-validation" role="form">
                                            <div class="card">
                                                <div class="card-body">
                                                    <div class="header-title">
                                                        @MyERP.Properties.Resources.Details
                                                    </div>
                                                    <div class="table-responsive">
                                                        <table class="table table-centered mb-0">
                                                            <thead>
                                                                <tr>
                                                                    <td>
                                                                        @MyERP.Properties.Resources.InstallmentDate
                                                                    </td>
                                                                    <td>
                                                                        @MyERP.Properties.Resources.InstallmentValue
                                                                    </td>
                                                                    <td>
                                                                        @MyERP.Properties.Resources.InstallmentStatus
                                                                    </td>
                                                                </tr>
                                                            </thead>
                                                            <tbody id="BorrowRequestDetails">
                                                                @if (Model != null)
                                                                {
                                                                    foreach (var item in Model.BorrowRequestDetails)
                                                                    {
                                                                        <tr>
                                                                            <td class="tabledit-edit-mode">
                                                                                <input type="date" class="InstallmentDate form-control tabledit-input form-control-sm" value="@item.InstallmentDate.Value.ToString("yyyy-MM-dd")" disabled readonly />
                                                                            </td>

                                                                            <td class="tabledit-edit-mode">
                                                                                <input type="number" step="any" class="InstallmentValue form-control tabledit-input form-control-sm" value="@item.InstallmentValue" disabled readonly />
                                                                            </td>

                                                                            <td class="tabledit-edit-mode">
                                                                                <input type="checkbox" class="IsInstallmentPaid" @Html.Raw(Model != null && item.IsInstallmentPaid == true ? "checked disabled" : "") />
                                                                                <label class="control-label">@MyERP.Properties.Resources.IsPaid</label>
                                                                            </td>
                                                                        </tr>
                                                                    }
                                                                }

                                                            </tbody>
                                                        </table>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <!--End Of Details Table-->
                            </div>
                        </div>

                        <div class="row" @*style="display:none;"*@>
                            <div class="col-12">
                                <div class="form-horizontal needs-validation" role="form">
                                    <div class="card">
                                        <div class="card-body">
                                            <div class="header-title">
                                                @MyERP.Properties.Resources.FinancialData
                                            </div>
                                            <div class="form-group row">
                                                <label for="TotalVacationAllocation" class="control-label  col-sm-2">
                                                    @MyERP.Properties.Resources.TotalVacationAllocation :
                                                </label>
                                                <div class="col-sm-2">
                                                    <label class="control-label" id="TotalVacationAllocation">  </label>
                                                </div>
                                                <label for="BorrowBalance" class="control-label col-sm-2">
                                                    @MyERP.Properties.Resources.BorrowBalance :
                                                </label>
                                                <div class="col-sm-2">
                                                    <label class="control-label" id="BorrowBalance">  </label>
                                                </div>
                                                <label for="SalaryDueBalance" class="control-label col-sm-2">
                                                    @MyERP.Properties.Resources.SalaryDueBalance :
                                                </label>
                                                <div class="col-sm-2">
                                                    <label class="control-label" id="SalaryDueBalance">  </label>
                                                </div>
                                            </div>
                                            <div class="form-group row">
                                                <label for="RemainInstallmentNo" class="control-label  col-sm-2">
                                                    @MyERP.Properties.Resources.RemainInstallmentNo :
                                                </label>
                                                <div class="col-sm-2">
                                                    <label class="control-label" id="RemainInstallmentNo">  </label>
                                                </div>
                                                <label for="RemainContractPeriod" class="control-label col-sm-2">
                                                    @MyERP.Properties.Resources.RemainContractPeriod :
                                                </label>
                                                <div class="col-sm-1">
                                                    <label class="control-label" id="RemainContractPeriod">  </label>
                                                </div>
                                                <div class="col-sm-1">
                                                    <label class="control-label"> @MyERP.Properties.Resources.Month </label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>



                        <!--**********************************************************************-->

                        <div class="row">
                            <div class="col-sm-offset-2">
                                @if (Model == null)
                                {
                                    <button onclick="addEdit('new');" class="btn btn-success" id="newbtn">
                                        @MyERP.Properties.Resources.SaveAndNew
                                    </button>
                                    <button onclick="addEdit();" class="btn btn-success" id="save">
                                        @MyERP.Properties.Resources.Save
                                    </button>
                                    <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                                }
                                else if (Model.IsDeleted == false)
                                {
                                    <button onclick="addEdit();" class="btn btn-success" id="save">
                                        @MyERP.Properties.Resources.Save
                                    </button>
                                    <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                                    <a href="javascript:void(0);" class="btn btn-danger" onclick="Delete(@Model.Id)" role="button">@MyERP.Properties.Resources.Delete</a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<script>
    //---------------------- Variable Declaration -----------------------//
    //********************************************************************//

    //----------------------  Ready Finction -----------------------//
    $(document).ready(function () {
        $.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
            $("input[type|='datetime-local']")/*.not('#TransactionDate')*/.prop('min', r.PeriodStart).prop('max', r.PeriodEnd);
            // $('#VoucherDate').val('@ViewBag.VoucherDate');
            $('#BorrowRequestDate').val('@ViewBag.BorrowRequestDate');
            $('#InstallmentFirstDate').val('@ViewBag.InstallmentFirstDate');
        });
        if (!$('#Id').val()) {
            setDocNum();
        }
        else {
            var code = $('#DocumentNumber').val();
            $('#DocumentNumbers').val(code.replaceAll("-", ""))
            $("#DepartmentId").prop('disabled', true);
            $("#VoucherDate").prop('disabled', true);

            if ($('#InstallmentFirstDate').val()) {
                $('#InstallmentFirstDate').attr('disabled', true);
            }
            if ($('#InstallmentValue').val()) {
                $('#InstallmentValue').attr('disabled', true);
            }
            if ($('#BorrowValue').val()) {
                $('#BorrowValue').attr('disabled', true);
            }
            if ($('#InstallmentNo').val()) {
                $('#InstallmentNo').attr('disabled', true);
            }
            $('#BorrowStatusId').trigger('change');
            //if ($('#IsIssued').prop('checked') == true) {
            //    $('#DepartmentId').attr('disabled', true);
            //    $('#EmployeeId').attr('disabled', true);
                $('#BorrowStatusId').attr('disabled', true);
            //    $('#BorrowRequestDate').attr('disabled', true);
            //}
        }
        $('#EmployeeId').trigger('change');
    });
    //********************************************************************//

    //----------------------  Event Functions -----------------------//
    $(document).on('change', '#DepartmentId', function () {
        if ($('#DepartmentId').val()) {
            setDocNum();
        }
    });
    $(document).on('change', '#VoucherDate', function () {
        if ($('#DepartmentId').val()) {
            setDocNum();
        }
    });
    var _installmentFirstDate;
    $(document).on('change', '#InstallmentFirstDate', function () {
         _installmentFirstDate = new Date($('#InstallmentFirstDate').val());
        //if ($('#InstallmentNo').val() > 0 && $('#BorrowValue').inputmask('unmaskedvalue') > 0) {
        //    $('#InstallmentValue').val(0)
        //    CalculateInstallment();
        //}
        //else {
        //    $('#BorrowRequestDetails').empty();
        //}
        if (($('#InstallmentValue').inputmask('unmaskedvalue') > 0 || $('#InstallmentNo').val() > 0) && $('#BorrowValue').inputmask('unmaskedvalue') > 0) {
            CalculateInstallment();
        }
        else {
            Swal.fire({
                title: '@MyERP.Properties.Resources.BorrowValue' + " , " + '@MyERP.Properties.Resources.InstallmentValue' + " / " + '@MyERP.Properties.Resources.InstallmentNo' + "  " + '@MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
            $(this).val(0);
            $('#BorrowRequestDetails').empty();
        }
    });
    $(document).on('change', '#InstallmentValue , #BorrowValue', function () {
        $('#InstallmentNo').val(0);
        _installmentFirstDate = new Date($('#InstallmentFirstDate').val());

        if (($('#InstallmentValue').inputmask('unmaskedvalue') > 0 || $('#InstallmentNo').val() > 0) && $('#BorrowValue').inputmask('unmaskedvalue') > 0 && $('#InstallmentFirstDate').val()) {
            CalculateInstallment();
        }
        else {
            $('#BorrowRequestDetails').empty();
        }
    });
    $(document).on('change', '#InstallmentNo', function () {
        $('#InstallmentValue').val(0);
        _installmentFirstDate = new Date($('#InstallmentFirstDate').val());
        if ($('#InstallmentNo').val() > 0 && $('#BorrowValue').inputmask('unmaskedvalue') > 0 && $('#InstallmentFirstDate').val()) {
            CalculateInstallment();
        }
        else {
            $('#BorrowRequestDetails').empty();
        }
    });

    $(document).on('change', '#BorrowStatusId', function () {
        if ($(this).val() == 3) {
            $('.RefuseReason').show();
        }
        else {
            $('.RefuseReason').hide();
        }
    });
    $(document).on('change', '#EmployeeId', function () {
        GetEmployeeFinancialData();
    });

    //********************************************************************//

     //----------------------  Other Functions -----------------------//
    function setDocNum() {
        $.get('/BorrowRequest/SetDocNum?id=' + $('#DepartmentId').val() + '&VoucherDate=' + $('#VoucherDate').val()).done(function (r) {
            $('#DocumentNumber').val(r);
            $('#DocumentNumbers').val(r.replaceAll("-", ""));
        });
    }
    function convertToJavaScriptDate(value) {
        if (value === null)
            return null;
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        return ((dt.getMonth() + 1 + "/" + dt.getDate() + "/" + dt.getFullYear()));
    }
    function zeroPadded(val) {
        if (val >= 10)
            return val;
        else
            return '0' + val;
    }
    function SetInstallmentFirstDate(days, i) {
        //    var _voucherDate = new Date($('#VoucherDate').val());
        //    _voucherDate.setDate(_voucherDate.getDate() + days);
        //    $('#InstallmentFirstDate').val(_voucherDate.getFullYear() + "-" + zeroPadded(_voucherDate.getMonth() + 1) + "-" + zeroPadded(_voucherDate.getDate()));
        //var _installmentFirstDate = new Date($('#InstallmentFirstDate').val());
        _installmentFirstDate.setDate(_installmentFirstDate.getDate() /*+ days*/);
        var result;
        if (zeroPadded(_installmentFirstDate.getMonth() + 1 /*+ i*/) < 12) {
            result = _installmentFirstDate.getFullYear() + "-" + zeroPadded(parseInt(_installmentFirstDate.getMonth()) + 1) + "-" + zeroPadded(_installmentFirstDate.getDate());
            _installmentFirstDate = new Date(parseInt((_installmentFirstDate.getFullYear())), zeroPadded(parseInt(_installmentFirstDate.getMonth()) + 1 ), zeroPadded(_installmentFirstDate.getDate()));
        }
        else if (zeroPadded(_installmentFirstDate.getMonth() + 1 /*+ i*/) == 12) {
            result = parseInt((_installmentFirstDate.getFullYear())) + "-" + zeroPadded(12) + "-" + zeroPadded(_installmentFirstDate.getDate());
            _installmentFirstDate = new Date(parseInt((_installmentFirstDate.getFullYear()) + 1), 0, zeroPadded(_installmentFirstDate.getDate()));
        }
       
        return result
    }
    function CalculateInstallment() {
        $('#BorrowRequestDetails').empty();
        // var InstallmentFirstDate= $('#InstallmentFirstDate').val();
        var InstallmentDate;
        var InstallmentValue = 0;
        let borrowVal = $('#BorrowValue').inputmask('unmaskedvalue') * 1;
        let _installmentVal;
        let installmentNo;

        // لو حاطط قيمة القسط بحسب عدد الاقساط
        if ($('#BorrowValue').val() && $('#InstallmentValue').val()) {
            _installmentVal = $('#InstallmentValue').inputmask('unmaskedvalue') * 1;
            installmentNo = (borrowVal / _installmentVal);//Math.round(borrowVal / _installmentVal);
            $('#InstallmentNo').val(installmentNo);
        }
                //   لو حاطط  عدد الاقساط بحسب قيمة القسط

        if ($('#BorrowValue').val() && $('#InstallmentNo').val()) {
            installmentNo = $('#InstallmentNo').val();
            _installmentVal = (borrowVal / installmentNo); //Math.round(borrowVal / installmentNo);
            $('#InstallmentValue').val(_installmentVal);
        }
        for (var i = 0; i < installmentNo; i++) {
            if (_installmentVal > 0 && _installmentVal < borrowVal) {
                borrowVal -= _installmentVal
                InstallmentValue = _installmentVal;
            }
            else if (borrowVal < _installmentVal) {
                InstallmentValue = borrowVal;
            }
            if (i == 0) {
                if (installmentNo == 1) {
                    InstallmentValue = borrowVal;
                }
                else 
                {
                    // بجيب كسور الاقساط و اجمعها و اضيفها ع اول قسط
                        InstallmentValue = Math.round(InstallmentValue + (InstallmentValue - (Math.round(InstallmentValue))) * parseInt(installmentNo));
                    }
            }
            else {
                InstallmentValue = Math.round(InstallmentValue);
            }
            InstallmentDate = SetInstallmentFirstDate(30 * i,i);
            let tr = '<tr><td class="tabledit-edit-mode"><input type="date"  value="' + InstallmentDate + '" class="InstallmentDate form-control tabledit-input form-control-sm"  disabled readonly /></td><td class="tabledit-edit-mode"><input type="number" step="any" value="' + InstallmentValue + '" class="InstallmentValue form-control tabledit-input form-control-sm"  disabled readonly /></td><td class="tabledit-edit-mode"><input type="checkbox" class="IsInstallmentPaid" /><label class="control-label">@MyERP.Properties.Resources.IsPaid</label></td></tr>';
            $('#BorrowRequestDetails').append(tr);
        }
    }
    function GetEmployeeFinancialData() {
        $.get('/BorrowRequest/GetEmployeeFinancialData?EmployeeId=' + $('#EmployeeId').val()).done(function (r) {
            $('#BorrowBalance').text(r.BorrowBalance);
            $('#RemainContractPeriod').text(r.RemainContractPeriod);
            $('#RemainInstallmentNo').text(r.RemainInstallmentNo);
            $('#TotalVacationAllocation').text(r.TotalVacationAllocation);
            $('#SalaryDueBalance').text(r.SalaryDueBalance);


        });
    }
   //------------------------------------------------------------------------------------------//
    function Delete(id) {
        Swal.fire({
            title: '@MyERP.Properties.Resources.AreYouSureYouWantToDelete',
            text: " ",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: '@MyERP.Properties.Resources.Ok',
            cancelButtonText: '@MyERP.Properties.Resources.Cancel',
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                $('#preloader, #status').fadeIn();
                $.ajax({
                    url: '/BorrowRequest/Delete',
                    type: 'POST',
                    data: {
                        "Id": id,
                    },
                    error: function (e) {
                        $('#preloader, #status').fadeOut();
                        Swal.fire({
                            title: '@MyERP.Properties.Resources.DeleteDoesNotSucceeded',
                            text: " ",
                            icon: 'error',
                            showCancelButton: false,
                            confirmButtonText: '@MyERP.Properties.Resources.Ok',
                            confirmButtonColor: '#3085d6'
                        });
                    },
                    success: function (r) {
                        if (r == 'true') {
                            window.location.replace('/BorrowRequest');
                        } else {
                            $('#preloader, #status').fadeOut();
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.DeleteDoesNotSucceeded',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                        }
                    }
                });
            }
            else { result.dismiss; }
        });
    }

    function addEdit(n) {
        let valid = true;
        if ($(".form-control:invalid").length > 0) {
            $('.form-horizontal').addClass('was-validated');
            $('html, body').animate({
                scrollTop: $(".form-control:invalid").eq(0).offset().top - 80
            }, 500);
            console.log($(".form-control:invalid"));
            valid = false;
        }
        var borrowRequestDetails = [];
        if (valid) {
            $('#BorrowRequestDetails tr').each(function () {
                var td = $(this);
                var borrowRequestDetail = {
                    MainDocId: $('#Id').val(),
                    InstallmentDate: td.find('.InstallmentDate').val(),
                    InstallmentValue: td.find('.InstallmentValue').inputmask('unmaskedvalue'),
                    IsInstallmentPaid: td.find('.IsInstallmentPaid').prop('checked'),
                    IsDeleted: false,
                    SystemPageId: td.find('.SystemPageId').val(),
                    SelectedId: td.find('.SelectedId').val(),
                };
                borrowRequestDetails.push(borrowRequestDetail);
            });
        }
        if ($('#BorrowStatusId').val() != 3) {
            $('#RefuseReason').val('')
        }
        if ($('#Id').val() > 0 && $('#IsIssued').prop('checked') == true) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.CantEditBecauseIsIssued',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
            valid = false;
        }
        if (valid) {
            var borrowRequest = {
                Id: $('#Id').val(),
                DocumentNumber: $('#DocumentNumber').val(),
                VoucherDate: $('#VoucherDate').val(),
                DepartmentId: $('#DepartmentId').val(),
                EmployeeId: $('#EmployeeId').val(),
                BorrowRequestDate: $('#BorrowRequestDate').val(),
                BorrowValue: $('#BorrowValue').inputmask('unmaskedvalue'),
                InstallmentFirstDate: $('#InstallmentFirstDate').val(),
                InstallmentValue: $('#InstallmentValue').inputmask('unmaskedvalue'),
                IsDeleted: false,
                Notes: $('#Notes').val(),
                Image: $('#Image').val(),
                UserId: $('#UserId').val(),
                SystemPageId: $('#SystemPageId').val(),
                SelectedId: $('#SelectedId').val(),
                IsDelivered: $('#IsDelivered').val(),
                IsAccepted: $('#IsAccepted').val(),
                IsLinked: $('#IsLinked').val(),
                IsCompleted: $('#IsCompleted').val(),
                IsPosted: $('#IsPosted').val(),
                AutoCreated: $('#AutoCreated').val(),
                InstallmentNo: $('#InstallmentNo').val(),
                BorrowStatusId: $('#BorrowStatusId').val(),
                RefuseReason: $('#RefuseReason').val(),
                IsIssued: $('#IsIssued').prop('checked'),
                BorrowRequestDetails: borrowRequestDetails
            }
        }

        if ($('#BorrowRequestDetails tr').length == 0) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.AllDetailsRequired',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
            valid = false;
        }
        if (valid == true) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.AreYouSureYouWantToSave',
                text: " ",
                icon: 'info',
                showCancelButton: true,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                cancelButtonText: '@MyERP.Properties.Resources.Cancel',
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    $('#preloader, #status').fadeIn();
                    $('#SaveAndNew').prop('disabled', true);
                    $('#Save').prop('disabled', true);
                    $.ajax({
                        type: "POST", contentType: "application/json",
                        url: "/BorrowRequest/AddEdit",
                        data:
                            JSON.stringify({ borrowRequest }),
                        success: function (r) {
                            if (r.success == "true") {
                                if (n == 'new') {
                                    window.location.replace("/BorrowRequest/AddEdit");
                                }
                                else {
                                    window.location.replace("/BorrowRequest");
                                }
                            } else {
                                $('#preloader, #status').fadeOut();
                                $('#SaveAndNew').prop('disabled', false);
                                $('#Save').prop('disabled', false);
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.NotSaved !',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                            }
                        },
                        error: function (r) {
                            $('#preloader, #status').fadeOut();
                            $('#SaveAndNew').prop('disabled', false);
                            $('#Save').prop('disabled', false);
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.NotSaved !',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                        }
                    });
                }
                else { result.dismiss; }
            });
        }
    }
</script>