    function getCustomerSalesInvoices() {
        var vid = 0;
        if (checkId()) {
            vid = $('#Id').val();
        }
        $('#pleasewait').fadeIn();
        $.get('/Helper/GetCustomerSalesInvoices?id=' + $('#CustomerId').val() + '&cashReceiptVoucherId=' + vid + '&DepartmentId=' + $('#DepartmentId').val()).done(function (r) {
            $('.invoice').remove();
            var DueDate;
            let tr;
            var Remain;
            for (var i = 0; i < r.length; i++) {
                if (r[i].Paid == null) {
                    r[i].Paid = 0;
                }
                if (r[i].PaidAmount == null) {
                    r[i].PaidAmount = 0;
                }
                if (r[i].RemainAmount == null && r[i].PaidInTransaction == 0 && (r[i].PaidAmount == 0 || r[i].PaidAmount == null)) {
                    r[i].RemainAmount = r[i].TotalAfterTaxes;
                }
                if (r[i].DueDate == null) {
                    DueDate = "";
                }
                else {
                    DueDate = convertToJavaScriptDate(r[i].DueDate);
                }
                if (checkId() ) {
                    Remain = (parseFloat(r[i].PaidInTransaction) + parseFloat(r[i].RemainAmount)).toFixed(2);
                    var TotalRequiredAmount = (parseFloat(Remain) - parseFloat(r[i].PaidAmount)).toFixed(2);
                    tr = '<tr class="invoice"><td><input hidden class="SalesInvoiceId" value="' +
                        r[i].Id + '"/><label class="ActualPaymentDocNo control-label">' +
