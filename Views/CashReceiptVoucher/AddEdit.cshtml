@using MyERP.Models
@using MyERP.Models.MyModels
@model MyERP.Models.CashReceiptVoucher

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";

    ViewBag.Title = MyERP.Properties.Resources.CashReceiptVoucher;
}
<script src="~/Scripts/SaveAndNew.js"></script>

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                @if (Model != null)
                {
                    if (Model.IsDeleted == false)
                    {

                        if (ViewBag.Previous > 0)
                        {
                            <a href="@Url.Action("AddEdit",new {id= ViewBag.First })" class="btn btn-info">@MyERP.Properties.Resources.First</a>
                            <a href="@Url.Action("AddEdit",new { id=ViewBag.Previous })" class=" btn btn-info">&#8250;</a>
                        }
                        if (ViewBag.Next > 0)
                        {
                            <a href="@Url.Action("AddEdit",new { id=ViewBag.Next })" class="btn btn-info">&#8249;</a>
                            <a href="@Url.Action("AddEdit",new {id=ViewBag.Last })" class="btn btn-info">@MyERP.Properties.Resources.Last</a>
                        }
                    }
                }
                <a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
            </div>
            <div class="hed page-title">@MyERP.Properties.Resources.CashReceiptVoucher :</div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="form-horizontal needs-validation" role="form">
                @*<form action="/CashReceiptVoucher/AddEdit" class="form-horizontal needs-validation" novalidate method="post">*@
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">
                                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                @Html.AntiForgeryToken()
                                @if (Model != null && Model?.Id != 0)
                                {
                                    @Html.HiddenFor(model => model.Id)
                                    @Html.HiddenFor(model => model.IsActive)
                                    @Html.HiddenFor(model => model.IsLinked)
                                    @Html.HiddenFor(model => model.IsPosted)
                                    @Html.HiddenFor(model => model.UserId)
                                    @Html.HiddenFor(model => model.Image)
                                    @Html.HiddenFor(model => model.IsDeleted)
                                }
                                else
                                {
                                    <input type="hidden" name="Id" id="Id" value="0" />
                                }
                                <div class="form-group row">
                                    <label class=" col-sm-2 control-label" for="DocumentNumber">@MyERP.Properties.Resources.DocNo</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.DocumentNumber, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly", placeholder = @MyERP.Properties.Resources.VoucherNo, hidden = "hidden" } })
                                        <input id="DocumentNumbers" class="form-control" placeholder=@MyERP.Properties.Resources.Code required readonly />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>

                                    </div>

                                    <label for="DepartmentId" class="control-label col-sm-2">@MyERP.Properties.Resources.Branch</label>
                                    <div class="col-sm-4">

                                        @Html.DropDownList("DepartmentId", null, null, htmlAttributes: new { @class = "form-control", @required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>

                                <div class="form-group row">
                                    <label class="col-sm-2 control-label " for="MoneyAmount">@MyERP.Properties.Resources.Amount</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.MoneyAmount, new { htmlAttributes = new { @class = "form-control money", placeholder = @MyERP.Properties.Resources.Amount, @required = "required" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label class="col-sm-2 control-label " for="Date">@MyERP.Properties.Resources.Date</label>
                                    <div class="col-sm-4">
                                        <input id="Date" name="Date" class="form-control" type="datetime-local" required value="@ViewBag.Date" />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>

                                    </div>
                                </div>

                                <div class="form-group row">
                                    <label class="col-sm-2 control-label " for="SourceTypeId">@MyERP.Properties.Resources.Source</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("SourceTypeId", null, htmlAttributes: new { @class = "form-control", @required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label for="CustomerId" class="CustomerId control-label col-sm-2">@MyERP.Properties.Resources.Customer</label>
                                    <div class="CustomerId col-sm-4">
                                        @Html.DropDownList("CustomerId", null, htmlAttributes: new { @class = "CustomerId form-control" })
                                    </div>

                                    <label class="col-sm-2 control-label AccountId" for="AccountId">@MyERP.Properties.Resources.Account</label>
                                    <div class="col-sm-4 AccountId">
                                        @Html.DropDownList("AccountId", null, htmlAttributes: new { @class = " AccountId form-control" })
                                    </div>

                                    <label for="VendorId" class="VendorId control-label col-sm-2">@MyERP.Properties.Resources.Supplier</label>
                                    <div class="VendorId col-sm-4">
                                        @Html.DropDownList("VendorId", null, htmlAttributes: new { @class = "VendorId form-control" })
                                    </div>

                                    <label for="ShareholderId" class="ShareholderId control-label col-sm-2">@MyERP.Properties.Resources.Contributor</label>
                                    <div class="ShareholderId col-sm-4">
                                        @Html.DropDownList("ShareholderId", null, htmlAttributes: new { @class = "ShareholderId form-control" })

                                    </div>

                                    <label for="EmployeeId" class="EmployeeId control-label col-sm-2">@MyERP.Properties.Resources.Employee</label>
                                    <div class="EmployeeId col-sm-4">
                                        @Html.DropDownList("EmployeeId", null, htmlAttributes: new { @class = "EmployeeId form-control" })
                                    </div>
                                    <label for="PropertyContractId" class="PropertyContractId control-label col-sm-2">@MyERP.Properties.Resources.Contracts</label>
                                    <div class="PropertyContractId col-sm-4">

                                        @Html.DropDownList("PropertyContractId", null, htmlAttributes: new { @class = "PropertyContractId form-control" })
                                    </div>


                                    <label for="TechId" class="TechId control-label col-sm-2">@MyERP.Properties.Resources.Technician</label>
                                    <div class="TechId col-sm-4">
                                        @Html.DropDownList("TechnicianId", null, htmlAttributes: new { @class = "TechId form-control" })
                                    </div>

                                    <label for="DirectRevenueId" class="DirectRevenueId control-label col-sm-2">@MyERP.Properties.Resources.DirectRevenue</label>
                                    <div class="DirectRevenueId col-sm-4">
                                        @Html.DropDownList("DirectRevenueId", null, htmlAttributes: new { @class = "DirectRevenueId form-control" })
                                    </div>

                                    <label for="ChildrenId" class="ChildrenId control-label col-sm-2">@MyERP.Properties.Resources.Students</label>
                                    <div class="ChildrenId col-sm-4">
                                        @Html.DropDownList("ChildrenId", null, htmlAttributes: new { @class = "ChildrenId form-control" })
                                    </div>

                                    <label for="ElderId" class="ElderId control-label col-sm-2">@MyERP.Properties.Resources.Elder</label>
                                    <div class="ElderId col-sm-4">
                                        @Html.DropDownList("ElderId", null, htmlAttributes: new { @class = "ElderId form-control" })
                                    </div>
                                    <label for="RenterId" class="RenterId control-label col-sm-2">@MyERP.Properties.Resources.Renter</label>
                                    <div class="RenterId col-sm-4">
                                        @Html.DropDownList("RenterId", null, htmlAttributes: new { @class = "RenterId form-control" })
                                    </div>
                                </div>

                                <div class="form-group row" id="Month_Year" style="display:none;">
                                    <label for="Month" class="control-label col-sm-2">@MyERP.Properties.Resources.Month</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("Month", null, htmlAttributes: new { @class = "form-control" })
                                    </div>
                                    <label for="Year" class="control-label col-sm-2">@MyERP.Properties.Resources.Year</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("Year", null, htmlAttributes: new { @class = "form-control" })
                                    </div>
                                </div>



                                <div class="form-group row">
                                    <label for="CashReceiptPaymentMethodId" class="CashReceiptPaymentMethodId control-label col-sm-2">@MyERP.Properties.Resources.PaymentMethod</label>
                                    <div class="CashReceiptPaymentMethodId col-sm-4">
                                        @Html.DropDownList("CashReceiptPaymentMethodId", null, htmlAttributes: new { @class = "CashBoxId form-control" })
                                    </div>

                                    <label for="CashBoxId" style="display:none;" class="CashBoxId CashBoxDiv control-label col-sm-2">@MyERP.Properties.Resources.CashBox</label>
                                    <div class="CashBoxId CashBoxDiv col-sm-4" style="display:none;">
                                        @Html.DropDownList("CashBoxId", null, htmlAttributes: new { @class = "CashBoxId form-control" })
                                    </div>
                                    <label for="ChartOfAccountId" style="display:none;" class="ChartOfAccountId ChartOfAccountDiv control-label col-sm-2">@MyERP.Properties.Resources.Account</label>
                                    <div class="ChartOfAccountId ChartOfAccountDiv col-sm-4" style="display:none;">
                                        @Html.DropDownList("ChartOfAccountId", null, htmlAttributes: new { @class = "ChartOfAccountId form-control" })
                                    </div>
                                    <label for="BankAccountId" style="display:none;" class="BankAccountId BankAccountDiv control-label col-sm-2">@MyERP.Properties.Resources.BankAccount</label>
                                    <div style="display:none;" class="BankAccountId BankAccountDiv col-sm-4">
                                        @Html.DropDownList("BankAccountId", null, htmlAttributes: new { @class = "BankAccountId form-control" })
                                    </div>
                                </div>

                                <div class="form-group row" id="TransactionDiv" style="display:none;">
                                    <label class="col-sm-2 control-label " id="TransactionNoLabel" for="TransactionNo">@MyERP.Properties.Resources.TransactionNumber</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.TransactionNo, new { htmlAttributes = new { @class = "form-control" } })
                                    </div>
                                    <label class="col-sm-2 control-label" id="TransactionDateLabel" for="TransactionDate">@MyERP.Properties.Resources.TransactionDate </label>
                                    <div class="col-sm-4">
                                        @if (Model != null && Model?.Id != 0)
                                        {
                                            <input type="datetime-local" name="TransactionDate" id="TransactionDate" class="form-control" value="@ViewBag.TransactionDate" />
                                        }
                                        else
                                        {
                                            <input type="datetime-local" name="TransactionDate" id="TransactionDate" class="form-control" />
                                        }
                                    </div>
                                </div>

                                <div class="form-group row">
                                    <label class="control-label col-sm-2" for="Notes">@MyERP.Properties.Resources.Notes</label>
                                    <div class="col-sm-4">
                                        <textarea id="Notes" name="Notes" class="form-control" rows="5" cols="5">@if (Model != null && Model?.Id != 0) { @Model.Notes; }</textarea>

                                    </div>

                                    @if (ViewBag.UseCostCenter == true)
                                    {
                                        <label for="CostCenterId" class="control-label col-sm-2">@MyERP.Properties.Resources.CostCenter </label>

                                        <div class="col-sm-4">
                                            @Html.DropDownList("CostCenterId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })
                                        </div>
                                    }
                                </div>

                                <div class="form-group row">
                                    <label class="control-label col-sm-2" for="Notes">@MyERP.Properties.Resources.InvoiceSelected</label>
                                    <div class="col-sm-4">
                                        <input type="checkbox" id="IsInvoiceSelected" @Html.Raw(Model != null && Model.IsInvoiceSelected == true ? "checked" : "") style="width:15px;">
                                    </div>
                                    <label class=" col-sm-2 control-label" for="VendorInvoiceNumber">@MyERP.Properties.Resources.VendorReceiptNumber</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.VendorReceiptNumber, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.VendorReceiptNumber } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row" id="SalesInvoiceActualPayment" style="display:none;">
                            <div class="col-12">
                                <div class="card-box">
                                    <div class=" table-responsive">
                                        <table class="table table-striped table-centered mb-0">
                                            <thead>
                                                <tr>
                                                    <th>
                                                        @MyERP.Properties.Resources.InvoiceNo
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.VoucherDate
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.DueDate
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Department
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Total
                                                        @*إجمالى الفاتورة*@
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Paid
                                                        @*مسدد سابقا*@
                                                    </th>
                                                    <th>
                                                        @*متبقى*@
                                                        @MyERP.Properties.Resources.Remain
                                                    </th>
                                                    <th>
                                                        <i class="fe-check-circle"></i>
                                                    </th>
                                                    <th>
                                                        @*مسدد الحركة*@
                                                        @MyERP.Properties.Resources.PaidAmount
                                                    </th>
                                                    <th>@MyERP.Properties.Resources.NetRequired</th>
                                                    @*الصافى المستحق*@
                                                </tr>
                                            </thead>

                                            <tbody id="SalesInvoiceActualPaymentTable">
                                            </tbody>
                                        </table>
                                    </div>

                                </div>
                            </div>
                        </div>
                        <!--------------------------------  CashReceiptVoucherPropertyContractBatches  --------------------------------------------->
                        <div class="row" id="CashReceiptVoucherPropertyContractBatchesTable" style="display:none;">
                            <div class="col-12">
                                <div class="card-box">
                                    <div class=" table-responsive">
                                        <table class="table table-striped table-centered mb-0">
                                            <thead>
                                                <tr>
                                                    <th>
                                                        @MyERP.Properties.Resources.Batch
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Date
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Rent
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.VAT
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Electricity
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.VAT
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Water
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.VAT
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Gas
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.VAT
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Services
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.VAT
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Commission
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.VAT
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Insurance
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.VAT
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Total
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Property
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Unit
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.IsDelivered
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.PaidBefor
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Paid
                                                    </th>

                                                    <th>
                                                        @MyERP.Properties.Resources.Remain
                                                    </th>
                                                </tr>
                                            </thead>
                                            <tbody id="CashReceiptVoucherPropertyContractBatches" style="overflow-x:scroll;">
                                                @{
                                                    var Batchlst = (ViewBag.BathcesPaid as List<BatchPaidModel>) ?? new List<BatchPaidModel>();
                                                    var unitdetails = (ViewBag.PropertyUnits as List<UniteModel>) ?? new List<UniteModel>();
                                                }
                                                @if (Model != null && Model.CashReceiptVoucherPropertyContractBatches.Count() > 0)
                                                {
                                                    foreach (var item in Model.CashReceiptVoucherPropertyContractBatches)
                                                    {
                                                        <tr>
                                                            <td>
                                                                <input hidden class="PropertyContractBatchId" value="@item.PropertyContractBatchId" />
                                                                <label class="control-label">
                                                                    @item.PropertyContractBatch.BatchNo
                                                                </label>
                                                            </td>
                                                            <td>
                                                                <label class="control-label Gregorian">
                                                                    @item.PropertyContractBatch.BatchDate.Value.ToString("yyyy/MM/dd")
                                                                </label>
                                                            </td>

                                                            <td class="tabledit-edit-mode">
                                                                <input type="number" step="any" class="BatchRentValue form-control tabledit-input form-control-sm" value="@item.PropertyContractBatch.BatchRentValue" disabled readonly />
                                                            </td>
                                                            <td class="tabledit-edit-mode">
                                                                <input type="number" step="any" class="BatchRentValueTaxes form-control tabledit-input form-control-sm" value="@item.PropertyContractBatch.BatchRentValueTaxes" disabled readonly />
                                                            </td>
                                                            <td class="tabledit-edit-mode">
                                                                <input type="number" step="any" class="BatchElectricityValue form-control tabledit-input form-control-sm" value="@item.PropertyContractBatch.BatchElectricityValue" disabled readonly />
                                                            </td>
                                                            <td class="tabledit-edit-mode">
                                                                <input type="number" step="any" class="BatchElectricityValueTaxes form-control tabledit-input form-control-sm" value="@item.PropertyContractBatch.BatchElectricityValueTaxes" disabled readonly />
                                                            </td>
                                                            <td class="tabledit-edit-mode">
                                                                <input type="number" step="any" class="BatchWaterValue form-control tabledit-input form-control-sm" value="@item.PropertyContractBatch.BatchWaterValue" disabled readonly />
                                                            </td>
                                                            <td class="tabledit-edit-mode">
                                                                <input type="number" step="any" class="BatchWaterValueTaxes form-control tabledit-input form-control-sm" value="@item.PropertyContractBatch.BatchWaterValueTaxes" disabled readonly />
                                                            </td>
                                                            <td class="tabledit-edit-mode">
                                                                <input type="number" step="any" class="BatchGasValue form-control tabledit-input form-control-sm" value="@item.PropertyContractBatch.BatchGasValue" disabled readonly />
                                                            </td>
                                                            <td class="tabledit-edit-mode">
                                                                <input type="number" step="any" class="BatchGasValueTaxes form-control tabledit-input form-control-sm" value="@item.PropertyContractBatch.BatchGasValueTaxes" disabled readonly />
                                                            </td>
                                                            <td class="tabledit-edit-mode">
                                                                <input type="number" step="any" class="BatchServicesValue form-control tabledit-input form-control-sm" value="@item.PropertyContractBatch.BatchServicesValue" disabled readonly />
                                                            </td>
                                                            <td class="tabledit-edit-mode">
                                                                <input type="number" step="any" class="BatchServicesValueTaxes form-control tabledit-input form-control-sm" value="@item.PropertyContractBatch.BatchServicesValueTaxes" disabled readonly />
                                                            </td>
                                                            <td class="tabledit-edit-mode">
                                                                <input type="number" step="any" class="BatchCommissionValue form-control tabledit-input form-control-sm" value="@item.PropertyContractBatch.BatchCommissionValue" disabled readonly />
                                                            </td>
                                                            <td class="tabledit-edit-mode">
                                                                <input type="number" step="any" class="BatchCommissionValueTaxes form-control tabledit-input form-control-sm" value="@item.PropertyContractBatch.BatchCommissionValueTaxes" disabled readonly />
                                                            </td>
                                                            <td class="tabledit-edit-mode">
                                                                <input type="number" step="any" class="BatchInsuranceValue form-control tabledit-input form-control-sm" value="@item.PropertyContractBatch.BatchInsuranceValue" disabled readonly />
                                                            </td>
                                                            <td class="tabledit-edit-mode">
                                                                <input type="number" step="any" class="BatchInsuranceValueTaxes form-control tabledit-input form-control-sm" value="@item.PropertyContractBatch.BatchInsuranceValueTaxes" disabled readonly />
                                                            </td>
                                                            <td>
                                                                <input class="form-control BatchTotal" disabled value="@(item.PropertyContractBatch.BatchTotal.Value.ToString("0.00"))" />
                                                            </td>
                                                            <td>
                                                                <input class="form-control property" disabled value="@item.PropertyContractBatch.PropertyContract.Property.ArName">
                                                            </td>
                                                            <td>
                                                                @{
                                                                    var unitNo = unitdetails.FirstOrDefault(t => t.Id == item.PropertyContractBatch.PropertyContract.PropertyUnitId)?.PropertyUnitNo;
                                                                }
                                                                <input class="form-control unit" disabled value="@unitNo">
                                                            </td>
                                                            <td>
                                                                <input type="checkbox" class="IsDelivered" @Html.Raw(Model != null && item.IsDelivered == true ? "checked disabled" : "") />
                                                            </td>
                                                            <td class="tabledit-edit-mode">
                                                                @{
                                                                    var totalPaid = (Batchlst.FirstOrDefault(t => t.Id != item.PropertyContractBatchId)?.Paid ?? 0m) - item.Paid;
                                                                }
                                                                <input type="number" step="any" class="TotalPaid form-control tabledit-input form-control-sm" value="@totalPaid" readonly disabled />
                                                            </td>
                                                            <td class="tabledit-edit-mode">
                                                                <input type="number" step="any"  class="Paid form-control tabledit-input form-control-sm" value="@item.Paid" @Html.Raw(Model != null && item.IsDelivered == true ? "readonly disabled" : "") />
                                                            </td>
                                                            <td class="tabledit-edit-mode">
                                                                <input type="number" step="any" class="Remain form-control tabledit-input form-control-sm" value="@item.Remain" readonly disabled />
                                                            </td>
                                                        </tr>
                                                    }
                                                }
                                            </tbody>

                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-------------------------------------------------------------------------------------------------------------->
                        <div class="row" id="PropertyBillRegisteration" style="display:none;">
                            <div class="col-12">
                                <div class="card-box">
                                    <h5 class="header-title"> @MyERP.Properties.Resources.BillRegisteration</h5>
                                    <div class="form-group row">
                                        <label class="col-sm-2 control-label ElectricityBillValue" for="ElectricityBillValue">@MyERP.Properties.Resources.Electricity</label>
                                        <div class="col-sm-4">
                                            <input id="ElectricityBillValue" name="ElectricityBillValue" class="form-control" type="number" step="0.01" disabled placeholder=@MyERP.Properties.Resources.Electricity value="@((Model == null)? "":Model.ElectricityBillValue.ToString())" />
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class="col-sm-2 control-label GasBillValue" for="GasBillValue">@MyERP.Properties.Resources.Gas</label>
                                        <div class="col-sm-4">
                                            <input id="GasBillValue" name="GasBillValue" class="form-control" type="number" step="0.01" disabled placeholder=@MyERP.Properties.Resources.Gas value="@((Model == null)? "": Model.GasBillValue.ToString())" />
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>
                                    </div>
                                    <div class="form-group row">
