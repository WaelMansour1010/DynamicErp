                        convertToJavaScriptDate(r[i].VoucherDate) + '</label></td><td><label class="control-label ActualPaymentDate"> ' +
                        DueDate + '</label></td><td><input hidden class="ActualPaymentDepartmentId" value="' +
                        r[i].DepartmentId + '" /><lable class="control-label ActualPaymentDepartmentArName">' +
