<script>
    // --- Variable Declaration ---//
    var EditAmount = 0;

    //---------- Ready Function --------------------//
    $(document).ready(function () {



        $('#RenterId').change(function () {
            console.log('RenterId');
            $('#PropertyContractId').empty( );
            $.getJSON('@Url.Action("ContractList","CashReceiptVoucher")/' + $('#RenterId').val(), function (data) {
                console.log(data);
                var items = "";
                $.each(data, function (i, state)
                {
                    items += "<option value='" + state.Value + "'>" + state.Text + "</option>";
                });
                $('#PropertyContractId').html(items);

                GetContractBatches();
            });
        });

        $.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
            $("input[type|='datetime-local']").not('#TransactionDate').prop('min', r.PeriodStart).prop('max', r.PeriodEnd);
        });

        if (!checkId()) {
            console.log('id empty');
            if ($('#DepartmentId').val()) {
                setDocNum();
                cashBoxByDepartment();
            }
        } else {
            console.log('id not ');
            var code = $('#DocumentNumber').val();
            $('#DocumentNumbers').val(code.replaceAll("-", ""))
            $("#DepartmentId").prop('disabled', true);
            $("#Date").prop('disabled', true);
        }

        if ($('#IsInvoiceSelected').prop("checked") == true && $('#SourceTypeId').val() == 1) {
            $('#IsInvoiceSelected').prop('disabled', false);
            $('#IsInvoiceSelected').prop('readonly', false);
            $('#SalesInvoiceActualPayment').show();
        }
        else {
            $('#SalesInvoiceActualPayment').hide();
        }

        sourceTypeChange();
        getCustomerSalesInvoices();
        $('#CashReceiptPaymentMethodId').trigger('change');
        if (checkId() && ($('#SourceTypeId').val() != 12)) {
            CalculateBatchesTotalMoney();
        }



    });
    //*********************************************************************************************//

    //---------------------------------- Event Functions -------------------------------------//
    $('#SourceTypeId').on('change', function () {
        sourceTypeChange();
    });
    $(document).on('change', '#DepartmentId', function () {
        if ($('#DepartmentId').val()) {
            if (!checkId())  {
                setDocNum();
            }
            cashBoxByDepartment();
            getCustomerSalesInvoices()
        }
    });
    $('#CustomerId').on('change', function () {
        getCustomerBalanceInEachDept();
        getCustomerSalesInvoices();
    });
    $('#VendorId').on('change', function () {
        getVendorBalanceInEachDept();
    });
    $(document).on('focusout', '.ActualPaymentPaidAmount', function () {
        if ($(this).val() > 0) {
            EditAmount = 0;
            ReCalculateMoneyAmount();
            var remain = $(this).closest('tr').find('.ActualPaymentRemain').text();
            var paidAmount = $(this).val();
            var NetRequired = parseFloat(remain) - parseFloat(paidAmount);
            $(this).closest('tr').find('.ActualPaymentNetRequired').text(NetRequired.toFixed(2));
          }

    });
    $(document).on('click', '#IsInvoiceSelected', function () {
        if ($('#IsInvoiceSelected').prop("checked") == true && $('#SourceTypeId').val() == 1) {
            getCustomerSalesInvoices();
            if ($('#MoneyAmount').val() > 0) {
                $('#MoneyAmount').val(0)
            }
            $('#SalesInvoiceActualPayment').show();
            $('#MoneyAmount').prop('disabled', true).prop('readonly', true).attr('placeholder', '0.00');
        }
        else {
            $('#SalesInvoiceActualPayment').hide();
            $('#MoneyAmount').prop('disabled', false).prop('readonly', false).attr('placeholder','@MyERP.Properties.Resources.Amount');
        }
    });
    $('#MoneyAmount').on('focusout', function () {
        var money = $(this).val();
        $('#SalesInvoiceActualPaymentTable tr').each(function () {
            var td = $(this);
            var NetRequired;// td.find('.ActualPaymentNetRequired').text();
            var Amount = td.find('.ActualPaymentPaidAmount').val();
            var TotalRemain = parseFloat(td.find('.ActualPaymentRemain').text());
            if (money > 0) {
                if (money > TotalRemain) {
                    money -= TotalRemain;
                    money = money.toFixed(2);
                    td.find('.ActualPaymentPaidAmount').val(TotalRemain);
                    Amount = td.find('.ActualPaymentPaidAmount').val();
                    NetRequired = (Amount - TotalRemain).toFixed(2);
                    td.find('.ActualPaymentNetRequired').text(NetRequired);
                }
                else if (money <= TotalRemain) {
                    td.find('.ActualPaymentPaidAmount').val(money);
                    NetRequired = Math.abs(TotalRemain - money).toFixed(2);
                    td.find('.ActualPaymentNetRequired').text(NetRequired);
                    money -= TotalRemain;
                    money = money.toFixed(2);
                }
            }

        })

    });
    $(document).on('change', '#CashReceiptPaymentMethodId', function () {
        if ($('#CashReceiptPaymentMethodId').val() == 1) { //نقدى
            $('.CashBoxDiv').show();
            $('.ChartOfAccountDiv').hide();
            $('.BankAccountDiv').hide();
            $('#TransactionDiv').hide();
            $('#TransactionNo').attr('required', false);
            $('#TransactionDate').attr('required', false);
        }
        else if ($('#CashReceiptPaymentMethodId').val() == 2) { //حوالة بنكية
            $('.CashBoxDiv').hide();
            $('.ChartOfAccountDiv').hide();
            $('.BankAccountDiv').show();
            $('#TransactionDiv').show();
            $('#TransactionNoLabel').text('@MyERP.Properties.Resources.TransactionNumber');
            $('#TransactionDateLabel').text('@MyERP.Properties.Resources.TransactionDate');
            if (!$('#TransactionNo').val()) {
                $('#TransactionNo').attr('required', true);
                $('#TransactionDate').attr('required', true);
            }
        }
        else if ($('#CashReceiptPaymentMethodId').val() == 3) { // شيك مصدق
            $('.CashBoxDiv').hide();
            $('.ChartOfAccountDiv').hide();
            $('.BankAccountDiv').show();
            $('#TransactionDiv').show();
            $('#TransactionNoLabel').text('@MyERP.Properties.Resources.ChequeNo');
            $('#TransactionDateLabel').text('@MyERP.Properties.Resources.ChequeDate');
            if (!$('#TransactionNo').val()) {
                $('#TransactionNo').attr('required', true);
                $('#TransactionDate').attr('required', true);
            }
        }
        else if ($('#CashReceiptPaymentMethodId').val() == 4) { //الحساب
            $('.CashBoxDiv').hide();
            $('.ChartOfAccountDiv').show();
            $('.BankAccountDiv').hide();
            $('#TransactionDiv').hide();
            $('#TransactionNo').attr('required', false);
            $('#TransactionDate').attr('required', false);
        }

    });
    $(document).on('change', '#Date', function () {
        if (!checkId()) {
            setDocNum();
        }
    });

        //$('form').submit(function () {
    //    if ($('.form-horizontal').first().find('.form-control:invalid').length > 0) {
    //        $('.form-horizontal').first().addClass('was-validated');
    //        $('html, body').animate({
    //            scrollTop: $('.form-horizontal').first().find(".form-control:invalid").eq(0).offset().top - 100
    //        }, 500);
    //    } else {
    //        $(this).find("button[id='newbtn']").prop('disabled', true);
    //        $(this).find("button[id='save']").prop('disabled', true);
    //    }
    //});


    //*********************************************************************************************//

    //---------------- Other Functions ----------------------//


    function setDocNum() {
        $.get('/CashReceiptVoucher/SetDocNum?id=' + $('#DepartmentId').val() +'&VoucherDate=' + $('#Date').val()).done(function (r) {
            $('#DocumentNumbers').val(r.replaceAll("-", ""));
            $('#DocumentNumber').val(r);
        });
    }
    function sourceTypeChange() {
        $('.AccountId').hide();
        $('.VendorId').hide();
        $('.CustomerId').hide();

        $('.EmployeeId').hide();
        $('.RenterId').hide();
        $('.TechId').hide();

        $('.DirectRevenueId').hide();
        $('.ShareholderId').hide();
        $('#balanceTable').hide();
        $('#IsInvoiceSelected').prop('disabled', true);
        $('#IsInvoiceSelected').prop('readonly', true);
        $('#IsInvoiceSelected').prop("checked", false);
        $('#SalesInvoiceActualPayment').hide();
        $('#Month_Year').hide();
        $('.ElderId').hide();
        $('.ChildrenId').hide();
        $('.PropertyContractId').hide();
        $('#PropertyBillRegisteration').hide();
        $('#CashReceiptVoucherPropertyContractBatchesTable').hide();
        if ($('#SourceTypeId').val() == 6) {
            $('.AccountId').show();
            $('.balance-details-btn').text('@MyERP.Properties.Resources.Balance');
        }
        else if ($('#SourceTypeId').val() == 4) {
            $('.DirectRevenueId').show();
            $('.balance-details-btn').text('@MyERP.Properties.Resources.Balance');
        }
        else if ($('#SourceTypeId').val() == 3) {
            $('.EmployeeId').show();
            $('.RenterId').show();
            $('.RenterId').prop('disabled', false);
            $('.balance-details-btn').text('@MyERP.Properties.Resources.Balance');
        }
        else if ($('#SourceTypeId').val() == 5) {
            $('.TechId').show();
            $('.balance-details-btn').text('@MyERP.Properties.Resources.Balance');
        }
        else if ($('#SourceTypeId').val() == 2) {
            $('.VendorId').show();
            $('#balanceTable').show();
            getVendorBalanceInEachDept();
            $('.balance-details-btn').text('@MyERP.Properties.Resources.VendorBalance');
        }
        else if ($('#SourceTypeId').val() == 1) {
            $('.CustomerId').show();
            $('#balanceTable').show();
            getCustomerBalanceInEachDept();
            $('.balance-details-btn').text('@MyERP.Properties.Resources.CustomerBalance');
            $('#IsInvoiceSelected').prop('disabled', false);
            $('#IsInvoiceSelected').prop('readonly', false);
            if ($('#IsInvoiceSelected').prop("checked") == true) {
                $('#SalesInvoiceActualPayment').show();
            }
        }
        else if ($('#SourceTypeId').val() == 8) {
            $('.ShareholderId').show();
            $('.balance-details-btn').text('@MyERP.Properties.Resources.Balance');
        }
        else if ($('#SourceTypeId').val() == 9) {  //Elder
            $('#Month_Year').show();
            $('.ElderId').show();
            GetMonthlySubscription();
            $('.balance-details-btn').text('@MyERP.Properties.Resources.Balance')
        }
        else if ( $('#SourceTypeId').val() == 10) { //child
            $('#Month_Year').show();
            $('.ChildrenId').show();
            GetMonthlySubscription();
            $('.balance-details-btn').text('@MyERP.Properties.Resources.Balance');
        }
        else if ($('#SourceTypeId').val() == 11) { //Property Contract
            $('.PropertyContractId').show();
            $('.PropertyContractId').prop('disabled', false);
            $('.RenterId').show();
            $('.RenterId').prop('disabled', false);
            $('#CashReceiptVoucherPropertyContractBatchesTable').show();
            if (!checkId()) {
                $('#PropertyContractId').trigger('change');
            }

            $('.balance-details-btn').text('@MyERP.Properties.Resources.Balance');
        }
        else if ($('#SourceTypeId').val() == 12) { //Property Bill registeration تسجيل مصاريف
            
            $('.PropertyContractId').show();
            $('.PropertyContractId').prop('disabled', true);
            $('.RenterId').show();
            $('.RenterId').prop('disabled', true);
            $('#PropertyBillRegisteration').show();

            $('.balance-details-btn').text('@MyERP.Properties.Resources.Balance');
        }

    }

    $('#ElderId').on('change', function () {
        GetMonthlySubscription()
    });
    $('#ChildrenId').on('change', function () {
        GetMonthlySubscription()
    });
    $('#Month').on('change', function () {
        GetMonthlySubscription()
    });
    $('#Year').on('change', function () {
        GetMonthlySubscription()
    });
    $('#PropertyContractId').on('change', function () {
        console.log('PropertyContractId');
        GetContractBatches();
    });
    $(document).on('change', '.IsDelivered', function (e) {
        if ($(this).prop('checked') == true) {
            $(this).closest('tr').find('.Paid').val($(this).closest('tr').find('.BatchTotal').inputmask('unmaskedvalue'));
            $(this).closest('tr').find('.Remain').val(0);
        }
        else {
            $(this).closest('tr').find('.Paid').val(0);
            $(this).closest('tr').find('.Remain').val(0);
        }

        CalculateBatchesTotalMoney();
    });
    $(document).on('change', '.Paid', function (e) {
    //    var diff = parseFloat($(this).closest('tr').find('.BatchTotal').inputmask('unmaskedvalue')) - parseFloat($(this).inputmask('unmaskedvalue'));
        var diff = parseFloat($(this).closest('tr').find('.BatchTotal').val()) - parseFloat($(this).val());
    console.log(diff.toFixed(2));
    //$(this).closest('tr').find('.Paid').val($(this).closest('tr').find('.BatchTotal').inputmask('unmaskedvalue'))
        if (diff >= 0) {
            $(this).closest('tr').find('.Remain').val(diff.toFixed(2));
            $(this).closest('tr').find('.Remain').prop('required', false);
        }
        else {
            $(this).closest('tr').find('.Remain').empty();
            $(this).closest('tr').find('.Remain').prop('required', true);
        }
        CalculateBatchesTotalMoney();
    });

    function GetMonthlySubscription() {
        var type = "";
        var id = 0;
        if ($('#SourceTypeId').val() == 9) {
            type = "Elder";
            id = $('#ElderId').val();
        }
        else {
            type = "Children";
            id = $('#ChildrenId').val();
