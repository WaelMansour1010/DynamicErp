    function CalculateBatchesTotalMoney(fromload) {
        var sum = 0;
        $('.BatchTotal').each(function () {

            //if ($(this).closest('tr').find('.IsDelivered').prop('checked') == true) {
            //    var isDisabled = $(this).closest('tr').find('.IsDelivered').prop('disabled');
            //    if (!isDisabled) {
            //        sum += parseFloat($(this).val());
            //    }

            //}
              {
                if ($(this).closest('tr').find('.Paid').val() > 0) {
                    sum += parseFloat($(this).closest('tr').find('.Paid').val());
                }

                let paid = parseFloat($(this).closest('tr').find('.Paid').val());
                let totalPaid = parseFloat($(this).closest('tr').find('.TotalPaid').val());
                let total = parseFloat($(this).val());

                $(this).closest('tr').find('.Remain').val((total - (paid + totalPaid)).toFixed(2));
                console.log(total - (paid + totalPaid));


            }

        });
        if (!fromload) {
            $('#MoneyAmount').val(sum.toFixed(2));
        }

    }
