                        Remain + '</label></label></td><td><input type="checkbox" onclick="PaidAllAmount(this)" class="IsAllPaid form-control" style="width:15px;" /></td><td><input type="text" class="ActualPaymentPaidAmount form-control money" value="' +
                        r[i].PaidAmount + '" /></td><td><label class="control-label ActualPaymentNetRequired">' +
                        TotalRequiredAmount + '</label></td></tr>';
                }
                else {
                     Remain = (parseFloat(r[i].TotalAfterTaxes) - parseFloat(r[i].Paid)).toFixed(2);
                    tr = '<tr class="invoice"><td><input hidden class="SalesInvoiceId" value="' +
                        r[i].Id + '"/><label class="ActualPaymentDocNo control-label">' +
