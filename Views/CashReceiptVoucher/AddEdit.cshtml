    function PaidAllAmount(e) {
        var TotalAmount = $(e).closest('tr').find('.ActualPaymentRemain').text();
        if ($(e).prop('checked') == true) {

            $(e).closest('tr').find('.ActualPaymentPaidAmount').val(TotalAmount);
            $(e).closest('tr').find('.ActualPaymentPaidAmount').prop('disabled', true);
            $(e).closest('tr').find('.ActualPaymentNetRequired').text('0');
        }
        else {
            $(e).closest('tr').find('.ActualPaymentPaidAmount').val(0);
            $(e).closest('tr').find('.ActualPaymentPaidAmount').prop('disabled', false);
            $(e).closest('tr').find('.ActualPaymentNetRequired').text(TotalAmount);
        }
        EditAmount = 0;
        ReCalculateMoneyAmount();
    }
    function ReCalculateMoneyAmount() {
        if ($('#SourceTypeId').val() == 1) {
            $('#SalesInvoiceActualPaymentTable tr').each(function () {
                let td = $(this);
                if (td.find('.ActualPaymentPaidAmount').val() > 0) {
                    EditAmount += parseFloat(td.find('.ActualPaymentPaidAmount').val());
                }
            });
            $('#MoneyAmount').val(EditAmount.toFixed(2));
        }
    }
