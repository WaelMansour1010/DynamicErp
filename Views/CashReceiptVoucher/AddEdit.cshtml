                            $('#SaveAndPrint').prop('disabled', false);
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.NotSaved !',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                        }
                    });
                }
                else { result.dismiss; }
            });
        }
    }

    function checkId() {
        var value = $('#Id').val(); // Get the value of the hidden input
        if (value === null || value.trim() === "" || value === "0" || value===0) {
            return false;
        }
        return true;
    }
</script>
