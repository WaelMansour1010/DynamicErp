                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="tab-pane" id="5">
                                <label for="ArName" class="col-sm-2 control-label">@MyERP.Properties.Resources.Image</label>
                                <input hidden id="EditPopUpMemberImage" />

                                <div id="EditMembergallery" style="width: 100%;margin: 20px;">

                                </div>

                                <input type="file" id="EditMemberBrowseImage" onchange="EditMemberpreviewImage()" value="Browse" />
                            </div>
                        </div>

                    </div>
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group">
                                <label for="Address" class="control-label">@MyERP.Properties.Resources.Address</label>
                                <input type="text" class="form-control" id="EditFamilyMemberAddress" placeholder=@MyERP.Properties.Resources.Address>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group no-margin">
                                <label for="Notes" class="control-label">@MyERP.Properties.Resources.Notes</label>
                                <textarea class="form-control" id="EditFamilyMemberNotes" placeholder=@MyERP.Properties.Resources.Notes></textarea>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary waves-effect" data-dismiss="modal">@MyERP.Properties.Resources.Close</button>
                <button type="button" class="btn btn-info waves-effect waves-light" onclick="EditFamilyMember();">@MyERP.Properties.Resources.Edit</button>
            </div>
        </div>
    </div>
</div>
<!-- End Of Modal Section -->

<script>

    //--------------- Variables Declarations -------------------//
    let FamilyMembers = [];
    let AllMembers = [];
    //*********************************************************//

    //--------------- Ready Function -------------------//
    $(document).ready(function () {
        $('#Date').val('@ViewBag.Date');
        GetMembers();
        if ($('#Id').val() > 0) {
            let ChurchMembershipId = $('#ChurchMembershipId').val();
            appendFamilyMemberOptions(true).then(function () { $('#ChurchMembershipId').val(ChurchMembershipId).trigger('change') });
        }
        else {
            setCodeNum();
            appendFamilyMemberOptions(true);
        }
    });
    //*********************************************************//
    function SearchByMobileNo() {

        $.get('/ChurchMembership/SearchFamilyMemberByMobileNo?Mobile=' + $('#Mobile').val()).done(function (r) {
                r = r[0];
                if (r) {
                    r.BirthDate = r.BirthDate != null ? convertToJavaScriptDate2(r.BirthDate) : null;
                  //  $('#Mobile').val(r.Mobile);
                    $('#FamilyMemberIdInput').val(r.Id);
                    $('#FamilyMemberCodeInput').val(r.Code);
                    $('#FamilyMemberAddress').val(r.Address);
                    $('#FamilyMemberMobile').val(r.Mobile);
                    $("#FamilyMemberPhone").val(r.Phone);
                    $("#FamilyMemberEmail").val(r.Email);
                    $("#FamilyMemberBirthDate").val(r.BirthDate);
                    $("#AreaId").val(r.AreaId);
                    $("#AreaId").select2();
                    $("#ChurchMembershipId").val(r.Id);
                    $("#ChurchMembershipId").select2();
                    $("#FamilyMemberArName").val(r.ArName);
                    $("#FamilyMemberNotes").val(r.Notes);
                    $("#FamilyMemberIsAlive").prop("checked", r.IsAlive);
                    $("#IsUseApplication").prop("checked", r.IsUseApplication);
                    $("#TopicsForDiscussion").val(r.TopicsForDiscussion);
                    r.Image = r.Image != null ? "<img src ='" +
                        r.Image + "' alt='' class='MemberImage' style='width:200px;height:200px;' />" : "<img src ='/assets/images/users/Avatar_User.png' alt='' class='MemberImage' style='width:200px;height:200px;' />";
                    $("#MemberImage").html(r.Image);
                    GetPreviousChurchMeeting();
                }
                else {
                    $("#MemberImage").empty();
                    if (confirm('@MyERP.Properties.Resources.ThereIsNoMemberWithThisNoDoYouWantToAdd')) {
                        $('#FamilyMemberModal').modal("show");
                        $('#FamilyMemberMobile').val($('#Mobile').val());
                    }
                    else {
                        //$('#ChurchMembershipId').val(0);
                        //$('#ChurchMembershipId').select2();
                        $('#ChurchMembershipId').prop('selectedIndex', 0).select2();

                    }
                }
            });

    }
    //--------------- Event Functions -------------------//
    //$(document).on('keydown', '#Mobile', function (e) {
    //    if (e.which == 13 || e.keyCode == 13) {
    //        SearchByMobileNo();
    //    }
    //});
    $(document).on('change', '#ChurchMembershipId', function (e) {
        $("#MemberImage").empty();
        $.get('/ChurchMeeting/GetFamilyMemberById?ChurchMembershipId=' + $(this).val()).done(function (r) {
            let member = r;
            if (member) {
                //member.BirthDate = member.BirthDate != null ? convertToJavaScriptDate(member.BirthDate) : null;
                //$('#FamilyMemberIdInput').val(member.Id);
                //$('#FamilyMemberCodeInput').val(member.Code);
                //$('#FamilyMemberAddress').val(member.Address);
                //$('#FamilyMemberMobile').val(member.Mobile);
                //$("#FamilyMemberPhone").val(member.Phone);
                //$("#FamilyMemberBirthDate").val(member.BirthDate);
                //$("#AreaId").val(member.AreaId);
                //$("#AreaId").select2();
                //$("#FamilyMemberArName").val(member.ArName);
                //$("#FamilyMemberNotes").val(member.Notes);
                //$("#FamilyMemberIsAlive").prop("checked", member.IsAlive);
                $('#Mobile').val(member.Mobile);
                $("#IsUseApplication").prop("checked", member.IsUseApplication);
                $("#TopicsForDiscussion").val(member.TopicsForDiscussion);
                member.Image = member.Image != null ? "<img src ='" +
                    member.Image + "' alt='' class='MemberImage' style='width:200px; height:200px;'/>" : "<img src ='/assets/images/users/Avatar_User.png' alt='' class='MemberImage' style='width:200px;height:200px;' />";
                $("#MemberImage").html(member.Image);

                //$("#Membergallery").html(member.Image)
                //$('#PopUpMemberImage').val(member.Image);
            }
        });
        GetPreviousChurchMeeting();
    });
    $(document).on('click', '#FamilyMemberAddBtn', function () {
        $('#FamilyMemberModal').modal("show");
        $("#FamilyMemberArName").val('')
    });
    $(document).on('click', '#FamilyMemberEditBtn', function () {
        if ($('#ChurchMembershipId').val()) {
            $("#MemberImage").empty();
            $.get('/ChurchMeeting/GetFamilyMemberById?ChurchMembershipId=' + $('#ChurchMembershipId').val()).done(function (r) {
                let member = r;
                if (member) {
                    member.BirthDate = member.BirthDate != null ? convertToJavaScriptDate2(member.BirthDate) : null;
                    $('#EditFamilyMemberIdInput').val(member.Id);
                    $('#EditFamilyMemberCodeInput').val(member.Code);
                    $('#EditFamilyMemberAddress').val(member.Address);
                    $('#EditFamilyMemberMobile').val(member.Mobile);
                    $("#EditFamilyMemberPhone").val(member.Phone);
                    $("#EditFamilyMemberBirthDate").val(member.BirthDate);
                    $("#EditFamilyMemberArName").val(member.ArName);
                    $("#EditFamilyMemberNotes").val(member.Notes);
                    $('#EditMobile').val(member.Mobile);
                    $('#EditFamilyMemberRelative').val(member.Relative);
                    $('#EditFamilyMemberParentId').val(member.ParentId);
                    $('#EditPopUpMemberImage').val(member.Image);

                    member.Image = member.Image != null ? "<img src ='" +member.Image + "' alt='' class='MemberImage' style='width:200px; height:200px;'/>" : "<img src ='/assets/images/users/Avatar_User.png' alt='' class='MemberImage' style='width:200px;height:200px;' />";

                    $("#MemberImage").html(member.Image);

                    $("#EditMembergallery").html(member.Image)

                }
            });


            $('#FamilyMemberEditModal').modal("show");
        }
        else {
            alert('@MyERP.Properties.Resources.Member @MyERP.Properties.Resources.Required')
        }
        $("#FamilyMemberArName").val('')
    });
    //*********************************************************//

    //--------------- Other Functions -------------------//
    function GetMembers() {
        return requestData('/ChurchMeeting/GetMembers').done(function (r) {
            AllMembers = r;
