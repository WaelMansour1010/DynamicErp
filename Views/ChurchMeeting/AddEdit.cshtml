@model MyERP.Models.ChurchMeeting

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.Confessions;
}
<script src="~/Scripts/SaveAndNew.js"></script>
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                @if (Model != null)
                {
                    if (Model.IsDeleted == false)
                    {
                        if (ViewBag.Previous > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.First })" class="btn btn-info">@MyERP.Properties.Resources.First</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Previous })" class=" btn btn-info">&#8250;</a>
                        }
                        if (ViewBag.Next > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Next })" class="btn btn-info">&#8249;</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Last })" class="btn btn-info">@MyERP.Properties.Resources.Last</a>
                        }
                        <a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                    }
                }
                else
                {<a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>}
            </div>
            <h4 class="page-title"> @MyERP.Properties.Resources.Confessions </h4>
        </div>
    </div>
</div>


<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal needs-validation" role="form">
                        <div class="card">
                            <div class="card-body">
                                @Html.AntiForgeryToken()
                                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                @if (Model != null)
                                {
                                    @Html.HiddenFor(model => model.Id)
                                    @Html.HiddenFor(model => model.UserId)
                                    @Html.HiddenFor(model => model.IsActive)
                                    @Html.HiddenFor(model => model.IsDeleted)
                                    @Html.HiddenFor(model => model.Image)
                                }
                                <h5 class="header-title">
                                    @MyERP.Properties.Resources.MainData
                                </h5>
                                <div class="form-group row">
                                    <label class=" col-sm-2 control-label" for="Id">@MyERP.Properties.Resources.Code</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.Code, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.Code, @readonly = "readonly", required = "required" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="control-label col-sm-2 ">@MyERP.Properties.Resources.MemberName </label>
                                    <div class="col-sm-4 ">
                                        <div class="row ">
                                            <div class="col-sm-10">
                                                <select class="form-control" id="ChurchMembershipId" required>
                                                    @if (Model != null)
                                                    {
                                                        <option value="@Model.ChurchMembershipId"></option>
                                                    }
                                                </select>

                                                <div class="invalid-feedback">
                                                    @MyERP.Properties.Resources.Required
                                                </div>
                                            </div>

                                            <div class="col-sm-1" style="padding: 0;margin-right: -10px;">
                                                <button class="btn btn-success  btn-sm" id="FamilyMemberAddBtn" data-toggle="modal"><i class="remixicon-user-add-fill"></i></button>
                                            </div>
                                            <div class="col-sm-1" style="padding: 0;margin-right:2px;">
                                                <button class="btn btn-success  btn-sm" id="FamilyMemberEditBtn" data-toggle="modal"><i class="fa fa-edit"></i></i></button>
                                            </div>
                                        </div>
                                    </div>

                                    @*<label class="control-label col-sm-2">@MyERP.Properties.Resources.MemberName</label>
        <div class="col-sm-4">
            @Html.DropDownListFor(model => model.ChurchMembershipId, null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })
            <div class="invalid-feedback">
                @MyERP.Properties.Resources.Required
            </div>
        </div>*@
                                    <label for="MobileNumber" class="control-label col-sm-2"> @MyERP.Properties.Resources.Mobile</label>
                                    <div class="col-sm-3">
                                        @Html.EditorFor(model => model.Mobile, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.Mobile } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <div class="col-sm-1" style="padding: 0;">
                                        <button class="btn btn-success  btn-sm" onclick="SearchByMobileNo()"><i class="fa fa-search"></i></i></button>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.Date</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.Date, new { htmlAttributes = new { @class = "form-control", @type = "datetime-local" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label for="ConfessionFather" class="control-label col-sm-2">@MyERP.Properties.Resources.Father </label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("ChurchFatherId",null,MyERP.Properties.Resources.Select, new { htmlAttributes = new { @class = "form-control"} })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
    @*<label for="ConfessionFather" class="control-label col-sm-2">@MyERP.Properties.Resources._Interviewer </label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.ConfessionFather, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources._Interviewer } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>*@
                                </div>
                                <div class="form-group row">
                                    <label class="control-label col-sm-2" for="TopicsForDiscussion">@MyERP.Properties.Resources.TopicsForDiscussion</label>
                                    <div class="col-sm-4">
                                        <textarea id="TopicsForDiscussion" name="TopicsForDiscussion" class="form-control" rows="5" cols="5">@*@if (Model != null) { @Model.TopicsForDiscussion; }*@ </textarea>
                                    </div>
                                    <label class="control-label col-sm-2" for="Notes">@MyERP.Properties.Resources.Notes</label>
                                    <div class="col-sm-4">
                                        <textarea id="Notes" name="Notes" class="form-control" rows="5" cols="5">@if (Model != null) { @Model.Notes; }</textarea>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <div class="col-sm-6">
                                        <input type="checkbox" name="IsUseApplication" id="IsUseApplication" disabled />
                                        <label class="col-sm-10 control-label" for="IsUseApplication">
                                            @MyERP.Properties.Resources.IsUseApplication
                                        </label>
                                    </div>
                                    <div class="col-sm-6">
                                        <div class="tab-pane" id="5">
                                            <label class="col-sm-4 control-label">@MyERP.Properties.Resources.Image</label>
                                            <div id="MemberImage" style="width: 100%;margin: 20px;">

                                            </div>

                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-body">
                           
                            <h5 class="header-title">
                                @MyERP.Properties.Resources.PreviousMeetings
                            </h5>
                            <div class="table-responsive">
                                <table class="table table-striped table-centered mb-0">
                                    <thead>
                                        <tr>
                                            <th>
                                                @MyERP.Properties.Resources.Date
                                            </th>
                                            <th>
                                                @MyERP.Properties.Resources._Interviewer
                                            </th>
                                            <th>
                                                @MyERP.Properties.Resources.Notes
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody id="MeetingData">
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                      </div>
                    </div>

                    <!-------------------------------------------------------------------------------------------------------->

                    <div class="row">
                        <div class="col-sm-offset-2">
                            @if (Model == null)
                            {
                                <button onclick="addEdit('new');" class="btn btn-success" id="newbtn">
                                    @MyERP.Properties.Resources.SaveAndNew
                                </button>
                                <button onclick="addEdit();" class="btn btn-success" id="save">
                                    @MyERP.Properties.Resources.Save
                                </button>
                                <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                            }
                            else if (Model.IsDeleted == false)
                            {
                                <button onclick="addEdit();" class="btn btn-success" id="save">
                                    @MyERP.Properties.Resources.Save
                                </button>
                                <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                                <a href="javascript:void(0);" class="btn btn-danger" onclick="Delete(@Model.Id)" role="button">@MyERP.Properties.Resources.Delete</a>
                            }
                        </div>
                    </div>

                </div>
    </div>
</div>

<!-- Modal Section -->
<div id="FamilyMemberModal" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true" style="display: none;">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">@MyERP.Properties.Resources.FamilyMember</h4>
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">×</button>
            </div>
            <div class="modal-body p-4">
                <div class="form-horizontal needs-validation" role="form">
                    <input hidden id="FamilyMemberIdInput" name="FamilyMemberIdInput" />
                    <input hidden id="FamilyMemberCodeInput" name="FamilyMemberCodeInput" />
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="ArName" class="control-label">@MyERP.Properties.Resources.ArName</label>
                                <input type="text" class="form-control" id="FamilyMemberArName" placeholder=@MyERP.Properties.Resources.ArName>
                            </div>
                            <div class="invalid-feedback">
                                @MyERP.Properties.Resources.Required
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="EnName" class="control-label">@MyERP.Properties.Resources.BirthDate</label>
                                <input type="datetime-local" class="form-control" id="FamilyMemberBirthDate" value="@ViewBag.Date">
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="EnName" class="control-label">@MyERP.Properties.Resources.Phone</label>
                                <input type="text" class="form-control" id="FamilyMemberPhone" placeholder=@MyERP.Properties.Resources.Phone>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="Mobile1" class="control-label">@MyERP.Properties.Resources.Mobile </label>
                                <input type="text" class="form-control" id="FamilyMemberMobile" placeholder="@MyERP.Properties.Resources.Mobile">
                            </div>
                        </div>

                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="GroupId" class="control-label">@MyERP.Properties.Resources.Area</label>
                                @Html.DropDownList("AreaId", null, null, htmlAttributes: new { @class = "form-control", required = "required" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <input type="checkbox" id="FamilyMemberIsAlive" checked>
                                <label for="IsBlocked" class="control-label col-sm-8">@MyERP.Properties.Resources.IsAlive</label>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="Email" class="control-label">@MyERP.Properties.Resources.Email </label>
                                <input class="form-control" id="MemberEmailPopUp" placeholder=@MyERP.Properties.Resources.Email />
                            </div>
                            <div class="invalid-feedback">
                                @MyERP.Properties.Resources.Required
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="tab-pane" id="5">
                                <label for="ArName" class="col-sm-2 control-label">@MyERP.Properties.Resources.Image</label>
                                <input hidden id="PopUpMemberImage" />

                                <div id="Membergallery" style="width: 100%;margin: 20px;">

                                </div>

                                <input type="file" id="MemberBrowseImage" onchange="MemberpreviewImage()" value="Browse" />
                            </div>
                        </div>

                    </div>
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group">
                                <label for="Address" class="control-label">@MyERP.Properties.Resources.Address</label>
                                <input type="text" class="form-control" id="FamilyMemberAddress" placeholder=@MyERP.Properties.Resources.Address>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group no-margin">
                                <label for="Notes" class="control-label">@MyERP.Properties.Resources.Notes</label>
                                <textarea class="form-control" id="FamilyMemberNotes" placeholder=@MyERP.Properties.Resources.Notes></textarea>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary waves-effect" data-dismiss="modal">@MyERP.Properties.Resources.Close</button>
                <button type="button" class="btn btn-info waves-effect waves-light" onclick="addFamilyMember();">@MyERP.Properties.Resources.Save</button>
            </div>
        </div>
    </div>
</div>

