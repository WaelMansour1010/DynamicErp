    function addFamilyMember() {
        let valid = true;
        if ($("#FamilyMemberArName").val() == "") {
            $("#FamilyMemberArName").prop('required', true);
        }
        var member = AllMembers.filter(function (i) { return i.Mobile == $('#FamilyMemberMobile').val(); })[0];

        if (member && parseInt($("#FamilyMemberIdInput").val()) !== member.Id) {
            alert('@MyERP.Properties.Resources.ThisMobileNoExistsBefore');
            $('#FamilyMemberMobile').val('');
            valid = false;
        }
        if ($("#FamilyMemberModal").find(".form-control:invalid").length > 0) {
            $("#FamilyMemberModal").find('.form-horizontal').addClass('was-validated');
            $('html, body').animate({
                scrollTop: $(".form-control:invalid").eq(0).offset().top - 80
            }, 500);
            valid = false;
        } else {
            $('#preloader, #status').fadeIn();
            if (valid == true) {
                $.ajax(
                    {
                        url: '/ChurchMembership/AddEdit', contentType: "application/json",
                        type: 'POST',
                        data: JSON.stringify({
                            Id: $("#FamilyMemberIdInput").val() != "" ? $("#FamilyMemberIdInput").val() : 0,
                            Code: $("#FamilyMemberCodeInput").val(),
                            ArName: $("#FamilyMemberArName").val(),
                            BirthDate: $('#FamilyMemberBirthDate').val(),
                            Address: $('#FamilyMemberAddress').val(),
                            Email: $('#MemberEmailPopUp').val(),
                            Image: $('#PopUpMemberImage').val(),
                            Mobile: $('#FamilyMemberMobile').val(),
                            Phone: $('#FamilyMemberPhone').val(),
                            Notes: $('#FamilyMemberNotes').val(),
                            AreaId: $('#AreaId').val(),
                            IsAlive: $('#FamilyMemberIsAlive').prop('checked'),
                            ParentId: null,
                            Relative: null,
                            IsActive: true,
                            IsDeleted: false
                        }),
                        error: function (e) {
                            $('#preloader, #status').fadeOut();
                        },
                        success: function (r) {
                            appendFamilyMemberOptions(true).then(function () { $('#ChurchMembershipId').val(r.Id).trigger('change'); });
                            $('#FamilyMemberModal').modal('hide');
                            $('#preloader, #status').fadeOut();
                        }
                    });
            }
            $('#preloader, #status').fadeOut();
        }
    }
    function appendFamilyMemberOptions(refill) {
        return getFamilyMembers(refill).then(function () {
            let FamilyMemberOptions = '';
            FamilyMemberOptions = '<option value="">' + "@MyERP.Properties.Resources.Select" + '</option>';

            for (var i = 0; i < FamilyMembers.length; i++) {
                FamilyMemberOptions += '<option value="' + FamilyMembers[i].Id + '">' + FamilyMembers[i].ArName + ' - ' + FamilyMembers[i].Code + '</option>';
            }
            $('#ChurchMembershipId').empty().append(FamilyMemberOptions);
            $('#ChurchMembershipId').trigger('change');
        });
    }
    function getFamilyMembers(refill) {
        if (refill == true)
            requestCache['/ChurchMeeting/GetMembers'] = null;
        return requestData('/ChurchMeeting/GetMembers').done(function (r) {
            FamilyMembers = r;
        });
    }

