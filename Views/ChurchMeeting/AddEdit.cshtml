                                <input type="text" class="form-control" id="EditFamilyMemberPhone" placeholder=@MyERP.Properties.Resources.Phone>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="Mobile1" class="control-label">@MyERP.Properties.Resources.Mobile </label>
                                <input type="text" class="form-control" id="EditFamilyMemberMobile" placeholder="@MyERP.Properties.Resources.Mobile">
                            </div>
                        </div>

                    </div>
                    
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
