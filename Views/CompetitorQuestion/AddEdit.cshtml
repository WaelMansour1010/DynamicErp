@model MyERP.Models.CompetitorQuestion

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.Questions;
    Layout = "~/Views/Shared/_ActivityLayout.cshtml";
    int i = 1;
}
<script src="~/Scripts/SaveAndNew.js"></script>

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
                <div class="text-center w-75 m-auto" style="padding-top: 2%;">
                    <span>
                        <img src="@ViewBag.logo" alt="" height="200" width="200" />
                    </span>
                </div>
            <div class="hed page-title">@MyERP.Properties.Resources.Questions :</div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="form-horizontal needs-validation" role="form">
                @*<form action="/CompetitorQuestion/AddEdit" class="form-horizontal needs-validation" novalidate method="post" enctype="multipart/form-data" id="FormId">*@
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">
                                <h4 style="color:red;"> @ViewBag.ThereIsAnswersForThoseQuestions </h4>
                                <div class="form-group row">
                                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                    @Html.AntiForgeryToken()
                                    @if (Model != null)
                                    {
                                        @Html.HiddenFor(model => model.Id)
                                    }
                                    <label for="inputtext3" class="col-sm-2 control-label">@MyERP.Properties.Resources.Code</label>
                                    <div class="col-sm-4">
                                        @if (Model != null)
                                        {
                                            @Html.EditorFor(model => model.Code, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.Code, @readonly = "readonly", required = "required" } })
                                        }
                                        else
                                        {
                                            @Html.EditorFor(model => model.Code, new { htmlAttributes = new { @class = "form-control", @Value = ViewBag.Code, placeholder = @MyERP.Properties.Resources.Code, @readonly = "readonly", required = "required" } })
                                        }
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="inputtext3" class="col-sm-2 control-label"> @MyERP.Properties.Resources.Date</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.Date, new { htmlAttributes = new { @class = "form-control", @type = "datetime-local", required = "required" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                @if (Model != null && Model.CompetitorQuestionDetails.Count > 0)
                                {
                                    foreach (var item in Model.CompetitorQuestionDetails)
                                    {
                                        <div class="form-group row">
                                            <label for="inputtext3" class="col-sm-2 control-label"> @MyERP.Properties.Resources.Question @i </label>
                                            <div class="col-sm-4">
                                                <textarea class="form-control Question"> @item.Question </textarea>
                                            </div>
                                        </div>
                                        i++;
                                    }
                                }
                                else
                                {
                                    <div class="form-group row">
                                        <label for="inputtext3" class="col-sm-2 control-label"> @MyERP.Properties.Resources.Question 1</label>
                                        <div class="col-sm-4">
                                            <textarea class="form-control Question"></textarea>
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label for="inputtext3" class="col-sm-2 control-label"> @MyERP.Properties.Resources.Question 2</label>
                                        <div class="col-sm-4">
                                            <textarea class="form-control Question"></textarea>
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label for="inputtext3" class="col-sm-2 control-label"> @MyERP.Properties.Resources.Question 3</label>
                                        <div class="col-sm-4">
                                            <textarea class="form-control Question"></textarea>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                </div>
                @*</form>*@

                <!---------------------------------------------- Saves Buttons ----------------------------------------------------------->
                <div class="row">
                    <div class="col-sm-offset-2">
                        @if (Model == null)
                        {
                            <button onclick="addEdit('new');" class="btn btn-success" id="newbtn">
                                @MyERP.Properties.Resources.SaveAndNew
                            </button>
                            <button onclick="addEdit();" class="btn btn-success" id="save">
                                @MyERP.Properties.Resources.Save
                            </button>
                            <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                        }
                        else if (Model.IsDeleted == false)
                        {
                            <button onclick="addEdit();" class="btn btn-success" id="save">
                                @MyERP.Properties.Resources.Save
                            </button>
                            <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                            @*<a href="javascript:void(0);" class="btn btn-danger" onclick="Delete(@Model.Id)" role="button">@MyERP.Properties.Resources.Delete</a>*@
                        }
                    </div>
                </div>
                <!----------------------------------------------------------------------------------------------------------------------------------------->

            </div>
            
        </div>
    </div>
</div>



<script>
    //--------------- Variables Declarations -------------------//
    //*********************************************************//
    //--------------- Ready Function -------------------//
    $(document).ready(function () {
            $('#Date').val('@ViewBag.Date');
        if ($('#Id').val() == 0) {
            setCodeNum();
        }
    });

    //*********************************************************//
    //--------------- Event Functions -------------------//
    //*********************************************************//
     //--------------- Other Functions -------------------//
    function setCodeNum() {
        $.get('/CompetitorQuestion/SetCodeNum').done(function (r) {
            $('#Code').val(r);
        });
    }
     //*********************************************************//
        function addEdit(n) {
        let valid = true;
        if ($('.form-horizontal').first().find('.form-control:invalid').length > 0) {
            $('.form-horizontal').first().addClass('was-validated');
            $('html, body').animate({
                scrollTop: $('.form-horizontal').first().find(".form-control:invalid").eq(0).offset().top - 100
            }, 500);
            valid = false;
            console.log($(".form-control:invalid"));
        }
            var CompetitorQuestionDetails = [];
            if (valid) {
                $('.Question').each(function () {
                    var td = $(this);
                    var CompetitorQuestionDetail = {
                        CompetitorQuestionId: $('#Id').val(),
                        Question: $(this).val(),
                        IsDeleted: false,
                        Notes: td.find('.Notes').val(),
                    };
                  //  if ( $(this).val().length > 0 || $(this).val()!="") {
                        CompetitorQuestionDetails.push(CompetitorQuestionDetail);
                   // }
                });
            }
            var Check = CompetitorQuestionDetails.filter(function (i) { return i.Question.length > 0 });
            if (Check.length == 0) {
                Swal.fire({
                    title: '@MyERP.Properties.Resources.InsertAQuestionAtLeast',
                    text: " ",
                    icon: 'info',
                    showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    confirmButtonColor: '#3085d6'
                });
                valid = false;
            }
            var CompetitorQuestion = {
                Id: $('#Id').val(),
                Code: $('#Code').val(),
                Date: $('#Date').val(),
                IsActive: true,
                IsDeleted: false,
                Notes: $('#Notes').val(),
                Image: $('#Image').val(),
                CompetitorQuestionDetails: CompetitorQuestionDetails
            }
        if (valid) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.AreYouSureYouWantToSave',
                text: " ",
                icon: 'info',
                showCancelButton: true,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                cancelButtonText: '@MyERP.Properties.Resources.Cancel',
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    $('#preloader, #status').fadeIn();
                    $('#newbtn').prop('disabled', true);
                    $('#save').prop('disabled', true);
                    $.ajax({
                        type: "POST", contentType: "application/json",
                        url: "/CompetitorQuestion/AddEdit",
                        data: JSON.stringify(CompetitorQuestion),
                        success: function (r) {
                            if (r.success == true) {
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.Saved',
                                    text: " ",
                                    icon: 'success',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                                if (n == "new") {
                                    window.location.replace("/CompetitorQuestion/AddEdit");
                                } else {
                                    window.location.replace("/CompetitorQuestion");
                                }
                            }
                            else if (r.success == "Exist Before") {
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.ThisDateIsRelatedWithAnotherQuestionsAlready',
                                    text: " ",
                                    icon: 'info',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                            }
                            else {
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.NotSaved !',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                            }
                            $('#preloader, #status').fadeOut();
                            $('#newbtn').prop('disabled', false);
                            $('#save').prop('disabled', false);
                        },
                        error: function (r) {
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.NotSaved !',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                            $('#preloader, #status').fadeOut();
                            $('#newbtn').prop('disabled', false);
                            $('#save').prop('disabled', false);
                        }
                    });
                }
                else { result.dismiss; }
            });
        }
    }
        function Delete(id) {
        if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToDelete')) {
            $('#preloader, #status').fadeIn();
            $.ajax(
                {
                    url: '/CompetitorQuestion/Delete',
                    type: 'POST',
                    data: {
                        "Id": id,
                    },
                    error: function (e) {

                    },
                    success: function (r) {
                        if (r == 'true') {
                            window.location.replace('/CompetitorQuestion');
                        } else
                        alert('@MyERP.Properties.Resources.DeleteDoesNotSucceeded');
                        $('#preloader, #status').fadeOut();
                    }
                });
        }
    }

    //*********************************************************//



</script>

