
@model IEnumerable<MyERP.Models.GetUserGroupReports_Result>

@foreach (var item in Model)
{
    <tr>
        <td class="col-sm-8">
            <input class="ReportId" type="hidden" value="@item.Id" />
            @Html.DisplayFor(modelItem => item.ArName)
        </td>
        <td class="col-sm-4">
         @if (item.Allow == "true")
         {

            <input type="checkbox" class="Privileged" checked />

         }
         else
         {

            <input type="checkbox" class="Privileged" />
         }
        </td>

    </tr>
}
