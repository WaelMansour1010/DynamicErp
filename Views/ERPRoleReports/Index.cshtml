
@model MyERP.Models.ERPRoleReport

@{
    UICulture = Session["lang"] != null?Session["lang"].ToString():"ar";
    ViewBag.Title = @MyERP.Properties.Resources.ERPRoleReport;
    }
<script src="~/js/DeleteFunctionForAddEditView.js"></script>
<script src="~/Scripts/SaveAndNew.js"></script>

@Html.AntiForgeryToken()
@Html.ValidationSummary(true, "", new { @class = "text-danger" })
@if (Model != null)
{
    @Html.HiddenFor(model => model.Id)
}
<div class="panel panel-widget forms-panel">
    <div class="row">
        <div class="col-12">
            <div class="page-title-box">
                <div class="page-title-right">
                    <a class="btn btn-info" href="@Url.Action("Index")" role="button" style="float:left;">@MyERP.Properties.Resources.Back</a>
                </div>
                <div class="hed page-title">@MyERP.Properties.Resources.ERPRoleReport:</div>
            </div>
        </div>
    </div>
</div>
<div class="row">
    <div class="col-12">
        <div class="card-box">
         
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">
                                <div class="panel-group" id="accordion">
                                    <div>
                                        <div class="form-group row">
                                            <label class=" col-sm-1 control-label">@MyERP.Properties.Resources.Group </label>
                                            <div class="col-sm-4">
                                                @Html.DropDownList("UserRoleId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", required = "required" })
                                                <div class="invalid-feedback">
                                                    @MyERP.Properties.Resources.Required
                                                </div>
                                                @*<span class="Asterisks">*</span>*@
                                            </div>


                                        </div>
                                        <hr />
                                        <div class="form-group">
                                            <table class="table table-hover table-condensed">
                                                <thead>
                                                    <tr>
                                                        <th class="col-sm-8">@MyERP.Properties.Resources.Reports  </th>
                                                        <th class="col-sm-4">@MyERP.Properties.Resources.Privilege</th>
                                                    </tr>
                                                </thead>
                                                <tbody id="Privileges"></tbody>
                                            </table>
                                        </div>

                                        <div style="float:left">

                                            <button class="btn btn-success" onclick="addEdit()">
                                                @MyERP.Properties.Resources.Save
                                            </button>

                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
        
        </div>
    </div>
</div>

<script>
    $(document).on('change', '#UserRoleId', function () {
        $('#UserId').val() ? $('#preloader, #status').fadeIn() : null;
        $.get('/ERPRoleReports/GetERPRoleReports?roleId=' + $('#UserRoleId').val()).done(function (r) {
            $('#Privileges').empty();
            $('#Privileges').append('<tr><td class="col-sm-8">'+'@MyERP.Properties.Resources.All'+'</td><td class="col-sm-4"><input type="checkbox" id="checkAll" onclick="All()" /></td></tr>' + r);
            $('#preloader, #status').fadeOut();
        });
    });
    $(document).on('change', 'input[type="checkbox"]:not("#checkAll")', function () {
        $(this).prop('checked') ? null : $('#checkAll').removeAttr('checked');
    });

    function All() {
        if ($('#checkAll').prop('checked')) {
            $('input[type="checkbox"]').prop('checked', 'checked');
        } else {
            $('input[type="checkbox"]').removeAttr('checked');
        }
    }

    function addEdit() {
        $('#preloader, #status').fadeIn();
        var Privileges = [];
        $('#Privileges tr').each(function () {
            var td = $(this);
            var erpRoleReport = {
                ReportId: td.find('.ReportId').val(),
                UserRoleId: $('#UserRoleId').val(),
                Privileged: td.find('.Privileged').prop('checked')
            };
            Privileges.push(erpRoleReport);
        });
        var data = {
            Id: $('#UserRoleId').val(),
            ERPRoleReports: Privileges

        }
        console.log(data)

        $.ajax({
            type: "POST",
            url: "/ERPRoleReports/Index",
            data:
                data
            ,

            success: function (r) {

                alert('@MyERP.Properties.Resources.Saved');

                $('#preloader, #status').fadeOut();
            },
            error: function (r) {
                alert('@MyERP.Properties.Resources.NotSaved');

                $('#preloader, #status').fadeOut();
            }
        })
    }
</script>
