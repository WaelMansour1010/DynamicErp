<script>
    function zeroPadded(val) {
        if (val >= 10)
            return val;
        else
            return '0' + val;
    }

    if ($('#Id').val() > 0) {
        $('#ContractStartTime').val('@ViewBag.ContractStartTime');
        $('#ContractEndTime').val('@ViewBag.ContractEndTime');
        $('#HireDate').val('@ViewBag.HireDate');

    }
    else
    {
        var d = new Date();
        $('#HireDate').val(d.getFullYear() + "-" + zeroPadded(d.getMonth() + 1) + "-" + zeroPadded(d.getDate()) + "T" + zeroPadded(d.getHours()) + ":" + zeroPadded(d.getMinutes()));
        $('#ContractStartTime').val(d.getFullYear() + "-" + zeroPadded(d.getMonth() + 1) + "-" + zeroPadded(d.getDate()) + "T" + zeroPadded(d.getHours()) + ":" + zeroPadded(d.getMinutes()));
        $('#ContractEndTime').val(d.getFullYear() + "-" + zeroPadded(d.getMonth() + 1) + "-" + zeroPadded(d.getDate()) + "T" + zeroPadded(d.getHours()) + ":" + zeroPadded(d.getMinutes()));

    }


    if (!$('#Id').val() > 0)
    {
        function setCodeNum() {
            var doc = $.get('/EmployeeContract/SetCodeNum').done(function (r) {
                $('#Code').val(r);
            });

        }

        setCodeNum();
    }

    // show the equvalent hijry date of selected date
    $('.Gregorian').on('change', function () {

        var Hijry = new Intl.DateTimeFormat('ar-sa').format(new Date($(this).val())).toString();
        $('#Hijry' + $(this).attr('id') + '').val(Hijry);

    });


    // show the code of the selected employee
    $('#EmployeeId').change(function () {
        GetEmployeeContract($(this).val());
        var choise = $('#EmployeeId option:selected').text();
        var code = choise.split("-")[0]
        $('#EmployeeCode').val(code);
    });

     // // show the employee total salary
    //$('.ItemValue').on('change', function ()
    //{
    //    CalculateSalaryItems();

    //    //$('#EmployeeTotalSalary').val(0);
    //    //$('#EmployeeContractSalaryItems tr').each(function () {
    //    //    var tr = $(this);
    //    //    $('#EmployeeTotalSalary').val(parseInt($('#EmployeeTotalSalary').val()) + parseInt(tr.find('.ItemValue').val()))
    //    //  //  alert($('#EmployeeTotalSalary').val()+" EmployeeTotalSalary");
    //    //});
    //});

    // vacation radio button function
    $('.Vacation').on('click', function () {
        let Fixed = "Fixed";
        let Variable = "Variable";
        if ($(this).attr("id") == Fixed) {
            // console.log($(this).attr("id"));
            $('#VacationEquivalentWorkPeriodNum').val('');
            $('#VacationEquivalentWorkPeriodId').attr('disabled', true);
            $('#VacationEquivalentWorkPeriodId').val('');
            $('#VacationsSalaryItemId').attr('disabled', true);
            $('#VacationEquivalentWorkPeriodNum').attr("disabled", true);
            $('#VacationSalaryIncreaseValue').attr("disabled", false);

            $("#VacationTable button").each(function () {
                $(this).attr('disabled', true);
            });
        }
        else if ($(this).attr("id") == Variable)
        {
            $('#VacationSalaryIncreaseValue').val('');
            $('#VacationSalaryIncreaseValue').attr("disabled", true);
            $('#VacationEquivalentWorkPeriodNum').attr("disabled", false);
            $('#VacationEquivalentWorkPeriodId').attr('disabled', false);
            $('#VacationEquivalentWorkPeriodId').val('');
            $('#VacationsSalaryItemId').attr('disabled', false);
            $("#VacationTable button").each(function () {
                $(this).attr('disabled', false);
            });
        }
    });

    // annual increase radio button function
    $('.AnnualIncrease').on('click', function () {
        let Fixed = "Fixed";
        let Ratio = "Ratio";
        if ($(this).attr("id") == Fixed) {
            // console.log($(this).attr("id"));
            $('#SalaryIncreaseRatio').val('');
            $('#SalaryIncreaseRatio').attr("disabled", true);
            $('#SalaryFixedIncreaseValue').attr("disabled", false);
            $('#AnnualIncreasesSalaryItemId').attr('disabled', true);
            $("#AnnualIncreaseTable button").each(function () {
                $(this).attr('disabled', true);
            });
        }
        else if ($(this).attr("id") == Ratio) {
            $('#SalaryFixedIncreaseValue').val('');
            $('#SalaryFixedIncreaseValue').attr("disabled", true);
            $('#SalaryIncreaseRatio').attr("disabled", false);
            $('#AnnualIncreasesSalaryItemId').attr('disabled', false);
            $("#AnnualIncreaseTable button").each(function () {
                $(this).attr('disabled', false);
            });
        }
    });


    // add item in any salary item table Vacation , Annual increase or End of service
    $('.AddItem').on('click', function () {
        let id = $(this).attr('id');
        // console.log(id);
        // console.log('#'+ id +'SalaryItemId');
        if (!$('#' + id + 'SalaryItemId').val()) {
            alert('@MyERP.Properties.Resources.SelectSalaryItem')
        }
        else {
            let valid = true;
            $('#EmployeeContract'+ id +' tr').each(function () {
                var td = $(this);
                //// console.log($('#'+ id +'SalaryItemId').val());
                // console.log(td.find('.SalaryItemId').val());
                if ($('#'+ id +'SalaryItemId').val() == td.find('.SalaryItemId').val())
                    valid = false;
            });

            if (valid == false)
                alert('@MyERP.Properties.Resources.ExistsBefore')
            else {
                $('#EmployeeContract' + id + '').append('<tr><td hidden><input class="SalaryItemId" value=' + $('#' + id +'SalaryItemId').val() + '></td ><td><label >' + $('#' + id + 'SalaryItemId option:selected').text() + '</label ></td><td><button type="button" class="btn btn-danger" onclick="deleteElement(this)">حذف</button></td></tr>');
            }
        }

    });



    // add item in Employee salary item table
    $('.AddSalaryItem').on('click', function () {
        $('#EmployeeTotalSalary').val(0);
        // console.log($('#EmployeeSalaryItemId').val());
        if (!$('#EmployeeSalaryItemId').val()) {
            alert('@MyERP.Properties.Resources.SelectSalaryItem')
        }
        else {
            let valid = true;
            $('#EmployeeContractSalaryItems tr').each(function () {
                var td = $(this);
                //// console.log($('#'+ id +'SalaryItemId').val());
                // console.log(td.find('.SalaryItemId').val());
                if ($('#EmployeeSalaryItemId').val() == td.find('.SalaryItemId').val())
                    valid = false;
            });

            if (valid == false)
                alert('@MyERP.Properties.Resources.ExistsBefore')
            else
            {
                let id = $('#EmployeeSalaryItemId').val()
                $.ajax({
                    type: "GET",
                    //contentType: "application/json",
                    url: "/SalaryItem/GetSalaryItem/"+id,
                    //data: { id : id },
                    success: function (r) {
                        // console.log(r, "salaryitem");
                        if (r.ItemFixedValueForAllEmployees == null) {
                            r.ItemFixedValueForAllEmployees = 0;
                        }
                        if (r.EquationMaximumValue == null) {
                            r.EquationMaximumValue = 0;
                        }
                        if (r.EquationMinimumValue == null) {
                            r.EquationMinimumValue = 0;
                        }
                        if (r.SalaryItemValueCalcMethodId == 2) {
                            $('#EmployeeContractSalaryItems').append('<tr><td hidden><label class="SalaryItemValueCalcMethodId">2</label></td><td hidden><input class="SalaryItemId form-control" value=' + $('#EmployeeSalaryItemId').val() + '></td ><td><label >' + $('#EmployeeSalaryItemId option:selected').text() + '</label ></td><td><input readonly  type="number" step="any" value="' + r.ItemFixedValueForAllEmployees + '" class="ItemValue form-control "/></label></td><td><select class=" SalaryItemTypeId form-control"><option value="0" > ' + '@MyERP.Properties.Resources.GeneralSalaryItem' + '</option ><option value="1"> ' + '@MyERP.Properties.Resources.DueSalaryItem' + '</option></select ></td><td hidden><label class"Equation">' + r.EquationValue + '</label></td><td><label class="EquationValue">' + '@MyERP.Properties.Resources.NoValue' + '</label></td><td><label class="ItemFixedValue">' + r.ItemFixedValueForAllEmployees + '</label></td><td><label class="MinimumValue">0</label></td><td><label class="MaximumValue">0</label></td><td><button type="button" class="btn btn-danger" onclick="deleteElement(this)">' + '@MyERP.Properties.Resources.Delete' + '</button></td></tr>');
                        }
                        else {
                            if (r.SalaryItemValueCalcMethodId == 1 || r.EquationValue==null) {
