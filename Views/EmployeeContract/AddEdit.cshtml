    function CalculateEquation()
    {
        $('#EmployeeContractSalaryItems tr').each(function () {
            var tr = $(this);
            var calculatedEquation = parseInt(tr.find('.SalaryItemValueCalcMethodId').text());
            // console.log(calculatedEquation,"calc");
            if (calculatedEquation == 3) {
                let e = tr.find('.Equation').text();
                //// console.log(e, "e");
                let arr = e.split('_');
                let arr2 = [];
                //// console.log(arr,"arr");
                for (var i = 0; i < arr.length; i++) {
                    if (arr[i].includes("Id")) {

                        arr[i] = arr[i].slice(2)
                        var exist = false;
                        $('#EmployeeContractSalaryItems tr').each(function () {
                            var td = $(this);
                            if (arr[i] == td.find('.SalaryItemId').val()) {
                                exist = true;
                                arr2.push(td.find('.ItemValue').val());
                            }

                        });
                        if (exist == false) {
                            arr2.push(0);
                        }
                    }
                    else {
                        arr2.push(arr[i]);
                    }
                }
                // console.log(arr2, "arr2");

                let finalEquation = "";
                for (var i = 0; i < arr2.length; i++) {
                    finalEquation += arr2[i];
                }
                // console.log(finalEquation,"FnalEqn");
                // console.log(finalEquation,"eval(finalEquation)");
                let finalEquationValue = parseInt(eval(finalEquation));
                // console.log(finalEquationValue,"finalEquationValue");
                if (finalEquationValue < parseInt(tr.find('.MinimumValue').text()) && parseInt(tr.find('.MinimumValue').text())>0) {
                    finalEquationValue = parseInt(tr.find('.MinimumValue').text());
                   // console.log("finalEquationValue : ", finalEquationValue);
                }
                else {
                    if (finalEquationValue > parseInt(tr.find('.MaximumValue').text()) && parseInt(tr.find('.MaximumValue').text())>0) {
                        finalEquationValue = parseInt(tr.find('.MaximumValue').text());
                       //console.log("finalEquationValue Max : ",finalEquationValue);
                    }
                }
                tr.find('.ItemValue').val(finalEquationValue);
            }

        });
        CalculateSalaryItems()
    }



