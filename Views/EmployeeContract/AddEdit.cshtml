@model MyERP.Models.EmployeeContract

@{
    UICulture = Session["lang"] != null?Session["lang"].ToString():"ar";
    ViewBag.Title = @MyERP.Properties.Resources.EmployeeContracts;
}
<script src="~/js/DeleteFunctionForAddEditView.js"></script>
<script src="~/Scripts/SaveAndNew.js"></script>




@Html.AntiForgeryToken()
@Html.ValidationSummary(true, "", new { @class = "text-danger" })
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <a class="btn btn-info" href="@Url.Action("Index")" role="button" style="float:left;">@MyERP.Properties.Resources.Back</a>
            </div>
            <div class="hed page-title">  @MyERP.Properties.Resources.EmployeeContracts :</div>
        </div>
    </div>
</div>
<div class="row">
    <div class="col-12">
        <div class="card-box">

            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal needs-validation" role="form">
                        @* panal 1 *@
                        <div class="card">
                            <div class="card-body">
                                <div id="accordion">
                                    <h5 class=" pb-3 header-title">
                                        <a data-toggle="collapse" data-parent="#accordion" href="#collapse1">
                                            @MyERP.Properties.Resources.ContractData
                                        </a>
                                    </h5>
                                </div>
                                <div id="collapse1">

                                    <div class="form-group row">
                                        @if (Model != null)
                                        {
                                            @Html.HiddenFor(model => model.Id)
                                            @Html.HiddenFor(model => model.IsActive)
                                            @Html.HiddenFor(model => model.UserId)
                                            @Html.HiddenFor(model => model.Image)
                                        }
                                        <label class=" col-sm-2 control-label" for="Id">@MyERP.Properties.Resources.ContractNo</label>
                                        <div class="col-sm-4">
                                            @Html.EditorFor(model => model.Code, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.ContractNo, @readonly = "readonly", required = "required" } })
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>

                                        </div>

                                        <label class=" col-sm-2 control-label" for="Sequence">@MyERP.Properties.Resources.Sequence</label>
                                        <div class="col-sm-4">
                                            @Html.EditorFor(model => model.Sequence, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.Sequence, required = "required" } })
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>

                                        </div>
                                    </div>

                                    <div class="form-group row">
                                        <label for="ContractStartTime" class="control-label col-sm-2">@MyERP.Properties.Resources.ContractStartDate</label>
                                        <div class="col-sm-4">
                                            @Html.EditorFor(model => model.ContractStartTime, new { htmlAttributes = new { @class = "form-control Gregorian", @type = "datetime-local", @required = "required" } })
                                            @Html.ValidationMessageFor(model => model.ContractStartTime, "", new { @class = "text-danger" })
                                        </div>
                                        <label class="control-label col-sm-2"> @MyERP.Properties.Resources.HijriContractStartDate</label>
                                        <div class="col-sm-4">
                                            <input readonly type="text" id="HijryContractStartTime" class="form-control" />
                                        </div>
                                    </div>

                                    <div class="form-group row">
                                        <label for="ContractEndTime" class="control-label col-sm-2">@MyERP.Properties.Resources.ContractEndDate</label>
                                        <div class="col-sm-4">
                                            @Html.EditorFor(model => model.ContractEndTime, new { htmlAttributes = new { @class = "form-control Gregorian", @type = "datetime-local", @required = "required" } })
                                            @Html.ValidationMessageFor(model => model.ContractStartTime, "", new { @class = "text-danger" })
                                        </div>
                                        <label class="control-label col-sm-2"> @MyERP.Properties.Resources.HijriContractEndDate</label>
                                        <div class="col-sm-4">
                                            <input readonly type="text" id="HijryContractEndTime" class="form-control" />
                                        </div>
                                    </div>

                                    <div class="form-group row">
                                        <label class="control-label col-sm-2">@MyERP.Properties.Resources.EmployeeName</label>
                                        <div class="col-sm-4">
                                            @Html.DropDownList("EmployeeId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", required = "required" })
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>
                                        <label class="control-label col-sm-2">@MyERP.Properties.Resources.EmployeeCode</label>
                                        <div class="col-sm-4">
                                            @if (Model != null)
                                            {
                                                <input type="text" readonly class="form-control" id="EmployeeCode" value="@Model.Employee.Code" />
                                            }
                                            else
                                            {
                                                <input type="text" readonly class="form-control" id="EmployeeCode" />
                                            }
                                        </div>

                                    </div>

                                    <div class="form-group row">
                                        <label for="ContractPeriodNum" class="control-label col-sm-2">@MyERP.Properties.Resources.ContractPeriod</label>
                                        <div class="col-sm-2">
                                            @Html.EditorFor(model => model.ContractPeriodNum, new { htmlAttributes = new { @class = "form-control", @required = "required", @type = "number" } })
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>
                                        <div class="col-sm-2">
                                            @Html.DropDownList("ContractPeriodTypeId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", required = "required" })
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>

                                        </div>
                                        <label class="control-label col-sm-2">@MyERP.Properties.Resources.TestPeriodNum</label>
                                        <div class="col-sm-2">
                                            @Html.EditorFor(model => model.TestPeriodNum, new { htmlAttributes = new { @class = "form-control", @type = "number" } })
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>
                                        <div class="col-sm-2">
                                            @Html.DropDownList("TestPeriodTypeId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", required = "required" })
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>

                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label for="ContractJobId" class="control-label col-sm-2">@MyERP.Properties.Resources.Job</label>
                                        <div class="col-sm-4">
                                            @Html.DropDownList("ContractJobId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", required = "required" })
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>

                                        </div>
                                        <label for="ContractsTypeId" class="control-label col-sm-2">@MyERP.Properties.Resources.ContractsType</label>
                                        <div class="col-sm-4">
                                            @Html.DropDownList("ContractsTypeId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", required = "required" })
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>

                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label for="ContractsStatusId" class="control-label col-sm-2">@MyERP.Properties.Resources.ContractsStatus </label>
                                        <div class="col-sm-4">
                                            @Html.DropDownList("ContractsStatusId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", required = "required" })
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>
                                        <label for="ContractTypeId" class="control-label col-sm-2"> @MyERP.Properties.Resources.ContractType</label>
                                        <div class="col-sm-4">
                                            @Html.DropDownList("ContractTypeId", null, @MyERP.Properties.Resources.ContractType, htmlAttributes: new { @class = "form-control", required = "required" })
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>
                                    </div>

                                    <div class="form-group row">
                                        <label for="AdministrativeDepartmentId" class="control-label col-sm-2">@MyERP.Properties.Resources.AdministrativeDepartment</label>
                                        <div class="col-sm-4">
                                            @Html.DropDownList("AdministrativeDepartmentId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", required = "required" })
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label for="HireDate" class="control-label col-sm-2">@MyERP.Properties.Resources.HireDate</label>
                                        <div class="col-sm-4">
                                            @Html.EditorFor(model => model.HireDate, new { htmlAttributes = new { @class = "form-control Gregorian", @type = "datetime-local", @required = "required" } })
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>
                                        <label class="control-label col-sm-2"> @MyERP.Properties.Resources.HijriHireDate</label>
                                        <div class="col-sm-4">
                                            <input readonly type="text" id="HijryHireDate" class="form-control" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>


                        @* panal 7 *@
                        <div class="card">
                            <div class="card-body">
                                <div id="accordion">
                                    <h5 class=" pb-3 header-title">
                                        <a data-toggle="collapse" data-parent="#accordion" href="#collapse7">
                                            @MyERP.Properties.Resources.EmployeeSalaryItems
                                        </a>
                                    </h5>
                                </div>
                                <div id="collapse7">
                                    <div class="form-group row">
                                        <label class=" col-sm-2 control-label" for="SalaryItemId">@MyERP.Properties.Resources.SalaryItem</label>
                                        <div class="col-sm-4">
                                            @Html.DropDownList("EmployeeSalaryItemId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })
                                            @*<div class="invalid-feedback">
                                                    اختر مفردات الراتب
                                                </div>*@
                                        </div>
                                        <div class="col-sm-offset-2">
                                            <button id="EndOfServices" class="btn btn-success AddSalaryItem">
                                                @MyERP.Properties.Resources.Add
                                            </button>
                                        </div>
                                    </div>
                                    <div class="table-responsive">
                                        <table class="table table-striped table-centered mb-0">
                                            <thead>
                                                <tr>
                                                    <th>
                                                        @MyERP.Properties.Resources.SalaryItemName
                                                    </th>

                                                    <th>
                                                        @MyERP.Properties.Resources.SalaryItemValue

                                                    </th>

                                                    <th>
                                                        @MyERP.Properties.Resources.SalaryItemType
                                                    </th>

                                                    <th>
                                                        @MyERP.Properties.Resources.SalaryItemCalcMethod
                                                    </th>

                                                    <th>
                                                        @MyERP.Properties.Resources.SalaryItemFixedValue
                                                    </th>

                                                    <th>
                                                        @MyERP.Properties.Resources.SalaryItemMinValue
                                                    </th>

                                                    <th>
                                                        @MyERP.Properties.Resources.SalaryItemMaxValue
                                                    </th>

                                                    <th>
                                                        @MyERP.Properties.Resources.Delete
                                                    </th>

                                                </tr>
                                            </thead>
                                            <tbody id="EmployeeContractSalaryItems">
                                                @if (Model != null)
                                                {
                                                    foreach (var item in Model.EmployeeContractSalaryItems)
                                                    {
                                                <tr>
                                                    <td hidden><input class="SalaryItemId" value="@item.SalaryItemId" /></td>
                                                    <td>
                                                        <label>@item.SalaryItem.ArName</label>
                                                    </td>
                                                    @if (item.SalaryItem.SalaryItemValueCalcMethodId == 1 || item.EquationValue == "لا يوجد قيمة")
                                                    {
                                                        <td hidden><label class="SalaryItemValueCalcMethodId">1</label></td>
                                                        <td>
                                                            <input onchange="CalculateEquation()" type="number" step="any" class="ItemValue variable form-control" value="@item.ItemValue" />
                                                        </td>

                                                        <td>
                                                            <select class="SalaryItemTypeId form-control">
                                                                @if (item.SalaryItemTypeId == 0)
                                                                {
                                                                    <option selected value="0">
                                                                        @MyERP.Properties.Resources.GeneralSalaryItem
                                                                    </option>
                                                                    <option value="1">
                                                                        @MyERP.Properties.Resources.DueSalaryItem
                                                                    </option>
                                                                }
                                                                else
                                                                {
                                                                    <option value="0">
                                                                        @MyERP.Properties.Resources.GeneralSalaryItem
                                                                    </option>
                                                                    <option selected value="1">
                                                                        @MyERP.Properties.Resources.DueSalaryItem
                                                                    </option>
                                                                }
                                                            </select>
                                                        </td>

                                                        <td hidden>
                                                            <label class="Equation">@item.EquationValue</label>
                                                        </td>

                                                        <td>
                                                            <label class="EquationValue">
                                                                @MyERP.Properties.Resources.NoValue
                                                            </label>
                                                        </td>

                                                        <td>
                                                            <label class="ItemFixedValue">@item.ItemFixedValueForAllEmployees</label>
                                                        </td>

                                                        <td>
                                                            <label class="MinimumValue">0</label>
                                                        </td>

                                                        <td>
                                                            <label class="MaximumValue">0</label>
                                                        </td>
                                                    }
                                                    else if (item.SalaryItem.SalaryItemValueCalcMethodId == 2)
                                                    {
                                                        <td hidden><label class="SalaryItemValueCalcMethodId">2</label></td>
                                                        <td>
                                                            <input type="number" step="any" readonly class="ItemValue form-control" value="@item.ItemValue" />
                                                        </td>

                                                        <td>
                                                            <select class="SalaryItemTypeId form-control">
                                                                @if (item.SalaryItemTypeId == 0)
                                                                {
                                                                    <option selected value="0">
                                                                        @MyERP.Properties.Resources.GeneralSalaryItem
                                                                    </option>
                                                                    <option value="1">
                                                                        @MyERP.Properties.Resources.DueSalaryItem
                                                                    </option>
                                                                }
                                                                else
                                                                {
                                                                    <option value="0">
                                                                        @MyERP.Properties.Resources.GeneralSalaryItem
                                                                    </option>
                                                                    <option selected value="1">
                                                                        @MyERP.Properties.Resources.DueSalaryItem
                                                                    </option>
                                                                }
                                                            </select>
                                                        </td>
                                                        <td hidden>
                                                            <label class="Equation">@item.SalaryItem.EquationValue</label>
                                                        </td>
                                                        <td>
                                                            <label class="EquationValue">
                                                                @MyERP.Properties.Resources.NoValue
                                                            </label>
                                                        </td>

                                                        <td>
                                                            <label class="ItemFixedValue">@item.ItemFixedValueForAllEmployees</label>
                                                        </td>

                                                        <td>
                                                            <label class="MinimumValue">0</label>
                                                        </td>

                                                        <td>
                                                            <label class="MaximumValue">0</label>
                                                        </td>
                                                    }
                                                    else if (item.SalaryItem.SalaryItemValueCalcMethodId == 3)
                                                    {
                                                        <td hidden><label class="SalaryItemValueCalcMethodId">3</label></td>
                                                        <td>
                                                            <input type="number" step="any" readonly class="ItemValue form-control" value="@item.ItemValue" />
                                                        </td>

                                                        <td>
                                                            <select class="SalaryItemTypeId form-control">
                                                                @if (item.SalaryItemTypeId == 0)
                                                                {
                                                                    <option selected value="0">
                                                                        @MyERP.Properties.Resources.GeneralSalaryItem
                                                                    </option>
                                                                    <option value="1">
                                                                        @MyERP.Properties.Resources.DueSalaryItem
                                                                    </option>
                                                                }
                                                                else
                                                                {
                                                                    <option value="0">
                                                                        @MyERP.Properties.Resources.GeneralSalaryItem
                                                                    </option>
                                                                    <option selected value="1">
                                                                        @MyERP.Properties.Resources.DueSalaryItem
                                                                    </option>
                                                                }
                                                            </select>
                                                        </td>
                                                        <td hidden>
                                                            @*<label class="Equation">@item.EquationValue</label>*@
                                                            <label class="Equation">@item.SalaryItem.EquationValue</label>
                                                        </td>
                                                        <td>
                                                            <label class="EquationValue">@item.SalaryItem.EquationText</label>
                                                        </td>

                                                        <td>
                                                            <label class="ItemFixedValue">@item.ItemFixedValueForAllEmployees</label>
                                                        </td>

                                                        <td>
                                                            <label class="MinimumValue">@item.SalaryItem.EquationMinimumValue</label>
                                                        </td>

                                                        <td>
                                                            <label class="MaximumValue">@item.SalaryItem.EquationMaximumValue</label>
                                                        </td>
                                                    }
                                                    else if(item.EquationValue.Trim() == "لا يوجد قيمة")
                                                    {
                                                    <td hidden><label class="SalaryItemValueCalcMethodId">@item.SalaryItemId</label></td>
                                                    <td>
                                                        @*CalculateSalaryItems*@
                                                        <input onchange="CalculateEquation()" type="number" step="any" class="ItemValue variable form-control" value="@item.ItemValue" />
                                                    </td>

                                                    <td>
                                                        <select class="SalaryItemTypeId form-control">
                                                            @if (item.SalaryItemTypeId == 0)
                                                            {
                                                                <option selected value="0">
                                                                    @MyERP.Properties.Resources.GeneralSalaryItem
                                                                </option>
                                                                <option value="1">
                                                                    @MyERP.Properties.Resources.DueSalaryItem
                                                                </option>
                                                            }
                                                            else
                                                            {
                                                                <option value="0">
                                                                    @MyERP.Properties.Resources.GeneralSalaryItem
                                                                </option>
                                                                <option selected value="1">
                                                                    @MyERP.Properties.Resources.DueSalaryItem
                                                                </option>
                                                            }
                                                        </select>
                                                    </td>

                                                    <td hidden>
                                                        <label class="Equation">@item.EquationValue</label>
                                                    </td>

                                                    <td>
                                                        <label class="EquationValue">
                                                            @MyERP.Properties.Resources.NoValue
                                                        </label>
                                                    </td>

                                                    <td>
                                                        <label class="ItemFixedValue">@item.ItemFixedValueForAllEmployees</label>
                                                    </td>

                                                    <td>
                                                        <label class="MinimumValue">0.00</label>
                                                    </td>

                                                    <td>
                                                        <label class="MaximumValue">0.00</label>
                                                    </td>
                                                    }
                                                    <td>
                                                        <button type="button" class="btn btn-danger" onclick="deleteElement(this)">
                                                            @MyERP.Properties.Resources.Delete
                                                        </button>
                                                    </td>

                                                </tr>
                                                    }
                                                }


                                            </tbody>
                                        </table>
                                    </div>
                                    <div class="form-group row py-3">
                                        <label class=" col-sm-3" for="SalaryItemId">  @MyERP.Properties.Resources.TotalSalaryItem</label>
                                        <div class="col-sm-3">
                                            @Html.EditorFor(model => model.EmployeeTotalSalary, new { htmlAttributes = new { @class = "form-control", @readonly = "true" } })
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @* Panal 2 *@
                        <div class="card">
                            <div class="card-body">
                                <div id="accordion">
                                    <h5 class=" pb-3 header-title">
                                        <a data-toggle="collapse" data-parent="#accordion" href="#collapse2">
                                            @MyERP.Properties.Resources.AnnualTravelTickets
                                        </a>
                                    </h5>
                                </div>
                                <div id="collapse2">
                                    <div class="form-group row">
                                        <label for="EmployeeHasTicket" class="control-label col-sm-2">
                                            @MyERP.Properties.Resources.EmployeeTicket
                                        </label>
                                        <div class="col-sm-2">
                                            @if (Model != null && Model.EmployeeHasTicket == true)
                                            {
                                                @Html.CheckBox("EmployeeHasTicket", true, new { htmlAttributes = new { @class = "form-control", @valeu = Model.EmployeeHasTicket } })
                                            }
                                            else
                                            {
                                                @Html.CheckBox("EmployeeHasTicket", false, new { htmlAttributes = new { @class = "form-control" } })
                                            }
                                        </div>
                                        <label for="WifeHasTicket" class="control-label col-sm-2">
                                            @MyERP.Properties.Resources.WifeTicket
                                        </label>
                                        <div class="col-sm-2">
                                            @if (Model != null && Model.WifeHasTicket == true)
                                            {
                                                @Html.CheckBox("WifeHasTicket", true, new { htmlAttributes = new { @class = "form-control", @valeu = Model.WifeHasTicket } })
                                            }
                                            else
                                            {
                                                @Html.CheckBox("WifeHasTicket", false, new { htmlAttributes = new { @class = "form-control" } })
                                            }
                                        </div>
                                        <label for="RelativesHasTicket" class="control-label col-sm-2">
                                            @MyERP.Properties.Resources.RelativesTicket
                                        </label>
                                        <div class="col-sm-2">
                                            @if (Model != null && Model.RelativesHasTicket == true)
                                            {
                                                @Html.CheckBox("RelativesHasTicket", true, new { htmlAttributes = new { @class = "form-control", @valeu = Model.RelativesHasTicket } })
                                            }
                                            else
                                            {
                                                @Html.CheckBox("RelativesHasTicket", false, new { htmlAttributes = new { @class = "form-control" } })
                                            }
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label for="TicketsNum" class="control-label col-sm-2">
                                            @MyERP.Properties.Resources.TicketsNo
                                        </label>
                                        <div class="col-sm-4">
                                            @Html.EditorFor(model => model.TicketsNum, new
                                            {
                                                htmlAttributes = new
                                                {
                                                    @class = "form-control",
                                                    @type = "number",@*@required = "required"*@}
})
                                            @*<div class="invalid-feedback">
                                                    عدد التذاكر مطلوب
                                                </div>*@

                                        </div>
                                        <label for="TicketsTotalValue" class="control-label col-sm-2">
                                            @MyERP.Properties.Resources.TicketsTotalValue
                                        </label>
                                        <div class="col-sm-4">
                                            @Html.EditorFor(model => model.TicketsTotalValue, new
                                            {
                                                htmlAttributes = new
                                                {
                                                    @class = "form-control",@*@required = "required",*@@type = "number"
}
})
                                            @*<div class="invalid-feedback">
                                                    إجمالى قيمة التذاكر مطلوب
                                                </div>*@
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @* panal 3 *@
                        <div class="card">
                            <div class="card-body">
                                <div id="accordion">
                                    <h5 class=" pb-3 header-title">
                                        <a data-toggle="collapse" data-parent="#accordion" href="#collapse3">
                                            @MyERP.Properties.Resources.MedicalInsurance
                                        </a>
                                    </h5>
                                </div>
                                <div id="collapse3">
                                    <div class="form-group row">
                                        <label class=" col-sm-2 control-label" for="InsuranceNum">
                                            @MyERP.Properties.Resources.MedicalInsuranceNo
                                        </label>
                                        <div class="col-sm-4">
                                            @Html.EditorFor(model => model.InsuranceNum, new
                                       {
                                           htmlAttributes = new
                                           {
                                               @class = "form-control",
                                               placeholder = @MyERP.Properties.Resources.MedicalInsuranceNo
,@*required = "required"*@}
})
                                            @*<div class="invalid-feedback">
                                                    الرقم التأمينى مطلوب
                                                </div>*@
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class=" col-sm-2 control-label" for="EmployeeHasInsurance">
@MyERP.Properties.Resources.HasMedicalInsurance
                                        </label>
                                        <div class="col-sm-4">
                                            @if (Model != null && Model.EmployeeHasInsurance == true)
                                            {
                                                @Html.CheckBox("EmployeeHasInsurance", true, new { htmlAttributes = new { @class = "form-control", @valeu = Model.EmployeeHasInsurance } })
                                            }
