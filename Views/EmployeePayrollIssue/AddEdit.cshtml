@model MyERP.Models.EmployeePayrollIssue

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.EmployeePayrollIssue;
}
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                @if (Model != null)
                {
                    if (Model.IsDeleted == false)
                    {
                        if (ViewBag.Previous > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.First })" class="btn btn-info">@MyERP.Properties.Resources.First</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Previous })" class=" btn btn-info">&#8250;</a>
                        }
                        if (ViewBag.Next > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Next })" class="btn btn-info">&#8249;</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Last })" class="btn btn-info">@MyERP.Properties.Resources.Last</a>
                        }
                    }
                }
                <a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
            </div>
            <h4 class="page-title">@MyERP.Properties.Resources.EmployeePayrollIssue:</h4>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div role="form" class="form-horizontal needs-validation" method="post">
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">
                                @Html.AntiForgeryToken()
                                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                @if (Model != null)
                                {
                                    @Html.HiddenFor(model => model.Id)
                                }
                                <h5 class="header-title">
                                    @MyERP.Properties.Resources.MainData
                                </h5>

                                <div class="form-group row">
                                    <label class=" col-sm-1 control-label" for="DocumentNumber">@MyERP.Properties.Resources.DocNo </label>
                                    <div class="col-sm-5">
                                        @*<input type="text" class="form-control" name="DocumentNumber" readonly id="DocumentNumber" value="@ViewBag.DocumentNumber" />*@
                                        @Html.EditorFor(model => model.DocumentNumber, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly", placeholder = @MyERP.Properties.Resources.DocNo, hidden = "hidden" } })
                                        <input id="DocumentNumbers" class="form-control" placeholder=@MyERP.Properties.Resources.DocNo required readonly />
                                    </div>

                                </div>

                                <div class="form-group row">
                                    <label class=" col-sm-1 control-label" for="DepartmentId">@MyERP.Properties.Resources.Department</label>
                                    <div class="col-sm-5">
                                        @Html.DropDownList("DepartmentId", null, MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control",@required="Required" })
                                    </div>
                                    <label for="VoucherDate" class="control-label col-sm-1">@MyERP.Properties.Resources.DocumentDate </label>
                                    <div class="col-sm-5">
                                        <input id="VoucherDate" name="VoucherDate" class="form-control" type="datetime-local" value="@ViewBag.VoucherDate" required />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class=" col-sm-1 control-label" for="HrDepartmentId">@MyERP.Properties.Resources.HrDepartment</label>
                                    <div class="col-sm-5">
                                        @Html.DropDownList("HrDepartmentId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })
                                    </div>
                                    <label class=" col-sm-1 control-label" for="AdministrativeDepartmentId">@MyERP.Properties.Resources.AdministrativeDepartment</label>
                                    <div class="col-sm-5">
                                        @Html.DropDownList("AdministrativeDepartmentId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })
                                    </div>
                                </div>

                                <div class="form-group row">
                                    <label class=" col-sm-1 control-label" for="Year">@MyERP.Properties.Resources.Year</label>
                                    <div class="col-sm-5">
                                        @Html.DropDownList("Year", null, htmlAttributes: new { @class = "form-control", required = "required" })
                                    </div>
                                    <label class=" col-sm-1 control-label" for="Month">@MyERP.Properties.Resources.Month</label>
                                    <div class="col-sm-5">
                                        @Html.DropDownList("Month", null, htmlAttributes: new { @class = "form-control", required = "required" })
                                    </div>
                                </div>

                                <div class="form-group row">
                                    <label class=" col-sm-2 control-label" for="">@MyERP.Properties.Resources.SpecifiedEmployee</label>
                                    <div class="col-sm-4">
                                        <input type="checkbox" class="form-control" id="SelectEmp" name="SelectEmp" style="width:15px;" onclick="showEmps(this)">
                                    </div>
                                    <label style="display:none;" class="col-sm-1 control-label IsEmpSelected" for="EmployeeId">@MyERP.Properties.Resources.Employee</label>
                                    <div class="col-sm-5 IsEmpSelected" style="display:none;">
                                        @Html.DropDownList("EmployeeId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })
                                    </div>

                                </div>





                            </div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-sm-offset-2">
                        @if (Model == null)
                        {
                            <input id="new" name="newBtn" hidden />
                            <button onclick="addEdit('new');" class="btn btn-success" id="newbtn">
                                @MyERP.Properties.Resources.SaveAndNew
                            </button>
                            <button onclick="addEdit();" class="btn btn-success" id="save">
                                @MyERP.Properties.Resources.Save
                            </button>
                            <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                        }
                        else if (Model.IsDeleted == false)
                        {
                            <button onclick="addEdit();" class="btn btn-success" id="save">
                                @MyERP.Properties.Resources.Save
                            </button>
                            <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                            <a href="javascript:void(0);" class="btn btn-danger" onclick="Delete(@Model.Id)" role="button">@MyERP.Properties.Resources.Delete</a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

