    function Delete(id) {
        Swal.fire({
            title: '@MyERP.Properties.Resources.AreYouSureYouWantToDelete',
            text: " ",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: '@MyERP.Properties.Resources.Ok',
            cancelButtonText: '@MyERP.Properties.Resources.Cancel',
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                $('#preloader, #status').fadeIn();
                $.ajax(
                    {
                        url: '/EmployeePayrollIssue/Delete',
                        type: 'POST',
                        data: {
                            "Id": id,
                        },
                        error: function (e) {
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.DeleteDoesNotSucceeded',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                            $('#preloader, #status').fadeOut();
                        },
                        success: function (r) {
                            if (r == 'true') {
                                window.location.replace('/EmployeePayrollIssue');
                            } else {
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.DeleteDoesNotSucceeded',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                                $('#preloader, #status').fadeOut();
                            }
                        }
                    });
            }
            else { result.dismiss; }
        });
    }

    function addEdit(n) {
        let valid = true;
        if ($('.form-horizontal').first().find('.form-control:invalid').length > 0) {
            $('.form-horizontal').first().addClass('was-validated');
            $('html, body').animate({
                scrollTop: $('.form-horizontal').first().find(".form-control:invalid").eq(0).offset().top - 100
            }, 500);
            valid = false;
        }
        else {
            if ($('#EmployeePayrollIssueDetails').find('.IsIssued').prop('checked') == true) {
                valid = false;
                Swal.fire({
                    title: '@MyERP.Properties.Resources.CantEditBecauseIsIssued',
                    text: " ",
                    icon: 'info',
                    showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    confirmButtonColor: '#3085d6'
                });
            }
            if ($('#EmployeePayrollIssueDetails tr').length > 0) {
                var employeePayrollIssueDetails = [];
                $('#EmployeePayrollIssueDetails tr').each(function () {
                    let td = $(this);
                    let employeePayrollIssueDetail = {
                        EmployeeId: td.find('.EmployeeId').val(),
                        JobId: td.find('.JobId').val(),
                        HrDepartmentId: td.find('.HrDepartmentId').val(),
                        NationalityId: td.find('.NationalityId').val(),
                        TotalPenalty: td.find('.TotalPenalty').text(),
                        TotalDeductionItems: td.find('.TotalDeductionItems').text(),
                        TotalReward: td.find('.TotalReward').text(),
                        TotalOvertime: td.find('.TotalOvertime').text(),
                        TotalDueItems: td.find('.TotalDueItems').text(),
                        NetSalary: td.find('.NetSalary').text(),
                        AbsenceDays: td.find('.AbsenceDays').text(),
                        AdvancedExpenses: td.find('.AdvancedExpenses').text(),
                        FirstWorkDate: td.find('.FirstWorkDate').text(),
                        LastWorkDate: /*td.find('.LastWorkDate').text()*/ '1/1/2021',
                        NoOfWorkingDays: td.find('.NoOfWorkingDays').text(),
                        SalaryItem1: td.find('.SalaryItem1').text(),
                        SalaryItem2: td.find('.SalaryItem2').text(),
                        SalaryItem3: td.find('.SalaryItem3').text(),
                        SalaryItem4: td.find('.SalaryItem4').text(),
                        SalaryItem5: td.find('.SalaryItem5').text(),
                        SalaryItem6: td.find('.SalaryItem6').text(),
                        SalaryItem7: td.find('.SalaryItem7').text(),
                        SalaryItem8: td.find('.SalaryItem8').text(),
                        SalaryItem9: td.find('.SalaryItem9').text(),
                        SalaryItem10: td.find('.SalaryItem10').text(),
                        SalaryItem11: td.find('.SalaryItem11').text(),
                        SalaryItem12: td.find('.SalaryItem12').text(),
                        SalaryItem13: td.find('.SalaryItem13').text(),
                        SalaryItem14: td.find('.SalaryItem14').text(),
                        SalaryItem15: td.find('.SalaryItem15').text(),
                        SalaryItem16: td.find('.SalaryItem16').text(),
                        SalaryItem17: td.find('.SalaryItem17').text(),
                        SalaryItem18: td.find('.SalaryItem18').text(),
                        SalaryItem19: td.find('.SalaryItem19').text(),
                        SalaryItem20: td.find('.SalaryItem20').text(),
                        SalaryItem21: td.find('.SalaryItem21').text(),
                        SalaryItem22: td.find('.SalaryItem22').text(),
                        SalaryItem23: td.find('.SalaryItem23').text(),
                        SalaryItem24: td.find('.SalaryItem24').text(),
                        SalaryItem25: td.find('.SalaryItem25').text(),
                        SalaryItem26: td.find('.SalaryItem26').text(),
                        SalaryItem27: td.find('.SalaryItem27').text(),
                        SalaryItem28: td.find('.SalaryItem28').text(),
                        SalaryItem29: td.find('.SalaryItem29').text(),
                        SalaryItem30: td.find('.SalaryItem30').text(),
                        SalaryItem31: td.find('.SalaryItem31').text(),
                        SalaryItem32: td.find('.SalaryItem32').text(),
                        SalaryItem33: td.find('.SalaryItem33').text(),
                        BorrowValue: td.find('.BorrowValue').text(),
                        IsActive: true,
                        IsDeleted: false,
                        IsPaid: false,
                        IsIssued: td.find('.IsIssued').prop('checked'),
                        RemainingDays: td.find('.RemainingDays').text()
                    };
                    employeePayrollIssueDetails.push(employeePayrollIssueDetail)
                });
            }
            else {
                valid = false;
                Swal.fire({
                    title: '@MyERP.Properties.Resources.AllDetailsRequired',
                    text: " ",
                    icon: 'info',
                    showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    confirmButtonColor: '#3085d6'
                });
            }

            if (valid == true) {
                Swal.fire({
                    title: '@MyERP.Properties.Resources.AreYouSureYouWantToSave',
                    text: " ",
                    icon: 'info',
                    showCancelButton: true,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    cancelButtonText: '@MyERP.Properties.Resources.Cancel',
                    confirmButtonColor: '#3085d6',
                    cancelButtonColor: '#d33',
                    reverseButtons: true
                }).then((result) => {
                    if (result.isConfirmed) {
                        $('#preloader, #status').fadeIn();
                        $('#newbtn').prop('disabled', true);
                        $('#save').prop('disabled', true);
                        $.ajax({
                            type: "POST", contentType: "application/json",
                            url: "/EmployeePayrollIssue/AddEdit",
                            data: JSON.stringify({
                                Id: $('#Id').val(),
                                DocumentNumber: $('#DocumentNumber').val(),
                                VoucherDate: $('#VoucherDate').val(),
                                DepartmentId: $('#DepartmentId').val(),
                                Month: $('#Month').val(),
                                Year: $('#Year').val(),
                                Status: $('#Status').prop('checked'),
                                EmployeeId: $('#EmployeeId').val(),
                                HrDepartmentId: $('#HrDepartmentId').val(),
                                AdministrativeDepartmentId: $('#AdministrativeDepartmentId').val(),
                                EmployeePayrollIssueDetails: employeePayrollIssueDetails
                            }),
                            success: function (r) {
                                if (r.success == true) {
                                    if (n == "new") {
                                        window.location.replace("/EmployeePayrollIssue/AddEdit");
                                    } else {
                                        window.location.replace("/EmployeePayrollIssue");
                                    }
                                    Swal.fire({
                                        title: '@MyERP.Properties.Resources.Saved',
                                        text: " ",
                                        icon: 'success',
                                        showCancelButton: false,
                                        confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                        confirmButtonColor: '#3085d6'
                                    });
                                } else
                                    Swal.fire({
                                        title: '@MyERP.Properties.Resources.NotSaved !',
                                        text: " ",
                                        icon: 'error',
                                        showCancelButton: false,
                                        confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                        confirmButtonColor: '#3085d6'
                                    }); $('#preloader, #status').fadeOut();
                                $('#newbtn').prop('disabled', false);
                                $('#save').prop('disabled', false);
                            },
                            error: function (r) {
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.NotSaved !',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                }); $('#preloader, #status').fadeOut();
                                $('#newbtn').prop('disabled', false);
                                $('#save').prop('disabled', false);
                            }
                        });
                    }
                    else { result.dismiss; }
                });
            }
        }
    }


