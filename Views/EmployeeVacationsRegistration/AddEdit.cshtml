@model MyERP.Models.EmployeeVacationsRegistration

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.VacationsRegistration;
}
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                @if (Model != null)
                {
                    if (Model.IsDeleted == false)
                    {
                        if (ViewBag.Previous > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.First })" class="btn btn-info">@MyERP.Properties.Resources.First</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Previous })" class=" btn btn-info">&#8250;</a>
                        }
                        if (ViewBag.Next > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Next })" class="btn btn-info">&#8249;</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Last })" class="btn btn-info">@MyERP.Properties.Resources.Last</a>
                        }
                    }
                }
                <a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
            </div>
            <h4 class="page-title"> @MyERP.Properties.Resources.VacationsRegistration:</h4>
        </div>
    </div>
</div>


@if (Model != null)
{
    @Html.HiddenFor(model => model.Id)
    @Html.HiddenFor(model => model.IsActive)
    @Html.HiddenFor(model => model.IsDeleted)
    @Html.HiddenFor(model => model.UserId)
    @Html.HiddenFor(model => model.Image)

}
<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal needs-validation" role="form">
                        <div class="card">
                            <div class="card-body">

                                <div class="form-group row">
                                    <label class=" col-sm-2 control-label" for="DocumentNumber"> @MyERP.Properties.Resources.TransactionNo </label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.DocumentNumber, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly", placeholder = @MyERP.Properties.Resources.TransactionNo, required = "required", hidden = "hidden" } })
                                        <input id="DocumentNumbers" class="form-control" placeholder=@MyERP.Properties.Resources.DocNo required readonly />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label for="Date" class="control-label col-sm-2">@MyERP.Properties.Resources.Date </label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.Date, new { htmlAttributes = new { @class = "form-control", required = "required", type = "datetime-local" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="DepartmentId" class="col-sm-2 control-label"> @MyERP.Properties.Resources.Department </label>
                                    <div class="col-sm-4">
                                        @Html.DropDownListFor(a => a.DepartmentId, null, null, htmlAttributes: new { @class = "form-control", @required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label for="EmployeeId" class="col-sm-2 control-label"> @MyERP.Properties.Resources.Employee </label>
                                    <div class="col-sm-4">
                                        @Html.DropDownListFor(a => a.EmployeeId, null, null, htmlAttributes: new { @class = "form-control", @required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="Date" class="control-label col-sm-2">@MyERP.Properties.Resources.VacationStartDate </label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.VacationFrom, new { htmlAttributes = new { @class = "form-control", required = "required", type = "datetime-local" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label for="Date" class="control-label col-sm-2">@MyERP.Properties.Resources.VacationEndDate </label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.VacationTo, new { htmlAttributes = new { @class = "form-control", required = "required", type = "datetime-local" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="NoOfDays" class="control-label col-sm-2">@MyERP.Properties.Resources.NoOfDays </label>
                                    <div class="col-sm-3">
                                        <label class="control-label" id="NoOfDays">@Html.Raw(Model != null && Model.NoOfDays != null ? Model.NoOfDays : null) </label>
                                    </div>
                                    <div class="col-sm-1">
                                        <span>
                                            @MyERP.Properties.Resources.Day
                                        </span>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <div class="row">
                <div class="col-sm-offset-2">
                    @if (Model == null)
                    {
                        <button type="submit" id="newbtn" onclick="addEdit('new')" class="btn btn-success">
                            @MyERP.Properties.Resources.SaveAndNew
                        </button>
                        <button class="btn btn-success" id="save" onclick="addEdit()">
                            @MyERP.Properties.Resources.Save
                        </button>
                                               <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                    }
                    else if (Model.IsDeleted == false)
                    {
                        
                        <button class="btn btn-success" id="save" onclick="addEdit()">
                            @MyERP.Properties.Resources.Save
                        </button>
                         <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                        <button class="btn btn-danger" onclick="Delete(@Model.Id)">
                            @MyERP.Properties.Resources.Delete
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
<script>
//----------- variable Declaration -----------

//----------------------- On Ready -------------
    $(document).ready(function () {
        $.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
            $("input[type|='datetime-local']").not('#VacationFrom').not('#VacationTo').prop('min', r.PeriodStart).prop('max', r.PeriodEnd);
        });

         $('#Date').val('@ViewBag.Date');
         $('#VacationFrom').val('@ViewBag.VacationFrom');
         $('#VacationTo').val('@ViewBag.VacationTo');
        if ($('#Id').val() > 0) {
            var code = $('#DocumentNumber').val();
            $('#DocumentNumbers').val(code.replaceAll("-", ""))
            $("#DepartmentId").prop('disabled', true);
            $("#Date").prop('disabled', true);
        }
        else {
            setDocNum();
            var val = datediff(new Date($('#VacationFrom').val()), new Date($('#VacationTo').val()));
            $('#NoOfDays').text(val);
        }
    });

//------------------------- On Change -------------------------------//

//-------------------------- DocNum---------------------------------//
    function setDocNum() {
        if ($('#DepartmentId').val())
            $.get('/EmployeeVacationsRegistration/SetDocNum?id=' + $('#DepartmentId').val() + '&VoucherDate=' + $('#Date').val()).done(function (r) {
                $('#DocumentNumber').val(r);
                $('#DocumentNumbers').val(r.replaceAll("-", ""));
            });
    }

    $(document).on('change', '#DepartmentId', function () {
        if ($('#DepartmentId').val()) {
            setDocNum();
        }
    });
    $(document).on('change', '#Date', function () {
            setDocNum();
    });
    $(document).on('change', '#VacationFrom', function () {
        var val = datediff(new Date($('#VacationFrom').val()).getTime(), new Date($('#VacationTo').val()).getTime());
        $('#NoOfDays').text(val);
    });
    $(document).on('change', '#VacationTo', function () {
        var val = datediff(new Date($('#VacationFrom').val()).getTime(), new Date($('#VacationTo').val()).getTime());
        $('#NoOfDays').text(val);
    });
    function datediff(first, second) {
        var x = Math.round((second - first) / (1000 * 60 * 60 * 24));
        return x
    }
//------------------------------- ShowDate------------------------------//
    function zeroPadded(val) {
        if (val >= 10)
            return val;
        else
            return '0' + val;
    }

//------------------- ConvertDate -------------//
    function convertToJavaScriptDate(value) {
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        return (dt)
    }

    //--------------------------------------- ADD EDIT---------------------------//
    function addEdit(n) {
        if ($(".form-control:invalid").length > 0) {
            console.log($(".form-control:invalid"));
            $('.form-horizontal').addClass('was-validated');
            $('html, body').animate({
                scrollTop: $(".form-control:invalid").eq(0).offset().top - 100
            }, 500);
            valid = false;
        }
        else {

            var EmployeeVacationsRegistration =
            {
                Id: $('#Id').val(),
                DocumentNumber: $('#DocumentNumber').val(),
                DepartmentId: $('#DepartmentId').val(),
                EmployeeId: $('#EmployeeId').val(),
                Date: $('#Date').val(),
                VacationFrom: $('#VacationFrom').val(),
                VacationTo: $('#VacationTo').val(),
                NoOfDays: $('#NoOfDays').text(),
                IsActive: true,
                IsDeleted: false,
            };

            Swal.fire({
                title: '@MyERP.Properties.Resources.AreYouSureYouWantToSave',
                text: " ",
                icon: 'info',
                showCancelButton: true,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                cancelButtonText: '@MyERP.Properties.Resources.Cancel',
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {

                    $('#newbtn').prop('disabled', true);
                    $('#save').prop('disabled', true);
                    $('#preloader, #status').fadeIn();
                    $.ajax({
                        type: "POST",
                        url: "/EmployeeVacationsRegistration/AddEdit",
                        data: EmployeeVacationsRegistration,
                        success: function (r) {
                            if (r.success == "true") {
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.Saved',
                                    text: " ",
                                    icon: 'success',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                                if (n == "new") {
                                    window.location.replace("/EmployeeVacationsRegistration/AddEdit");
                                } else {
                                    window.location.replace("/EmployeeVacationsRegistration");
                                }
                            }
                            else
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.NotSaved !',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                }); $('#preloader, #status').fadeOut();
                            $('#newbtn').prop('disabled', false);
                            $('#save').prop('disabled', false);
                        },
                        error: function (r) {
                            $('#preloader, #status').fadeOut();
                            $('#newbtn').prop('disabled', false);
                            $('#save').prop('disabled', false);
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.NotSaved !',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                        }
                    });
                }
                else { result.dismiss; }
            });
        }
    }

        function Delete(id) {
        Swal.fire({
            title: '@MyERP.Properties.Resources.AreYouSureYouWantToDelete',
            text: " ",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: '@MyERP.Properties.Resources.Ok',
            cancelButtonText: '@MyERP.Properties.Resources.Cancel',
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
   $('#preloader, #status').fadeIn();
            $.ajax(
                {

                    url: '/EmployeeVacationsRegistration/Delete',
                    type: 'POST',
                    data: {
                        "Id": id,
                    },
                    error: function (e) {
                        Swal.fire({
                            title: '@MyERP.Properties.Resources.DeleteDoesNotSucceeded',
                            text: " ",
                            icon: 'error',
                            showCancelButton: false,
                            confirmButtonText: '@MyERP.Properties.Resources.Ok',
                            confirmButtonColor: '#3085d6'
                        });
                        $('#preloader, #status').fadeOut();
                    },
                    success: function (r) {
                        if (r == 'true') {
                            window.location.replace("/EmployeeVacationsRegistration");
                        }
                        else {
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.DeleteDoesNotSucceeded',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                            $('#preloader, #status').fadeOut();
                        }
                    }
                });
            }
            else { result.dismiss; }
        });
    }

</script>
