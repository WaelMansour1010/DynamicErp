<div id="ShowTransactions" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" style="display: none;" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title" id="myModalLabel">@MyERP.Properties.Resources.ShowClosedTransactions</h4>
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">×</button>
            </div>
            <div class="modal-body" id="ShowTransactionsBody">
                @foreach (var Transaction in ViewBag.ClosedTransactions)
                {
                    <label class="control-label col-sm-6">@Transaction </label>
                }

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light waves-effect" data-dismiss="modal">Close</button>
            </div>
        </div><!-- /.modal-content -->
    </div><!-- /.modal-dialog -->
</div>





<div style="text-align:center;margin-bottom: 50px;">

    <div class="form-group row">
        <div class="col-sm-4">
            <select id="ShowByPage" class="form-control" style="width:70px;float:left;" onchange="paging()">
                <option value="10">10</option>
                <option value="30">30</option>
                <option value="50">50</option>
                <option value="100">100</option>
                <option value="200">200</option>
                <option value="@ViewBag.Count">@MyERP.Properties.Resources.All</option>
            </select>
            <span style="font-size:12px;float:right;"> @MyERP.Properties.Resources.NoOfResults : <span id="RowsCount">@ViewBag.Count</span></span>
        </div>
        <div class="col-sm-2">
            <lablel class="col-sm-8"> @MyERP.Properties.Resources.PageNo: </lablel>
        </div>
        <div class="col-sm-2">
            <select id="pagination" class="pagination form-control" style="width:70px;float:left;">
            </select>
        </div>
    </div>
</div>

<script>
    var pageNo = 1;

    $('#ShowByPage').val(@ViewBag.wantedRowsNo);
    $('#pg' +@ViewBag.PageIndex).attr('selected', 'selected');

    function paging() {
        var link = '/FinancialPeriods/Index?' + 'pageIndex=' + pageNo + '&wantedRowsNo=' + $('#ShowByPage').val() /*+ '&searchWord=' + $('.searchtxt').val()*/ + '&date=' + $('#Date').val();
        window.location.replace(link);
    }

    function setPages() {
        var count =@ViewBag.Count;
        for (var i = 0; i < Math.ceil(count / $('#ShowByPage').val()); i++)
            $('#pagination').append('<option onchange="pageNo=' + (i + 1) + '; paging();" id="pg' + (i + 1) + '">' + (i + 1) + '</option>');
    }

    setPages();

    $('#pagination').on('change', function () {
        pageNo = $('#pagination').val();
        paging();
    });


    function ClosePeriod(id) {
        if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToClosePeriod')) {
            $('.closeed').closest("tr").find('.opend').prop("disabled", true);
            $('#preloader, #status').fadeIn();
            $.ajax(
                {
                    url: '/FinancialPeriods/ClosePeriod',
                    type: 'POST',
                    data: {
                        "id": id,
                    },
                    error: function (e) {

                    },
                    success: function (r) {
                        if (r == 'True') {
                            window.location.reload();
                            $('#preloader, #status').fadeOut();

                        }
                        else {
                            alert("@MyERP.Properties.Resources.YouShouldClosePreviousPeriodFirst");
                            $('#preloader, #status').fadeOut();
                        }
                    }
                });
        }
    }
    function Cancel(id) {

        if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToCanclePeriodClosing')) {

            $('#preloader, #status').fadeIn();
            $.ajax(
                {
                    url: '/FinancialPeriods/ReOpen',
                    type: 'POST',
                    data: {
                        "id": id,
                    },
                    error: function (e) {

                    },
                    success: function (r) {
                        console.log(r)
                        if (r == 'True') {
                            window.location.reload();
                            $('#preloader, #status').fadeOut();

                        }
                        else {
                            alert("@MyERP.Properties.Resources.YouShouldCancelPeriodClosingNextPeriodFirst");
                            $('#preloader, #status').fadeOut();
                        }
                    }
                });
        }





    };
    function OpenPeriod(id){

        if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToOpenPeriod')) {

            $('#preloader, #status').fadeIn();
            $.ajax(
                {
                    url: '/FinancialPeriods/OpenPeriod',
                    type: 'POST',
                    data: {
                        "id": id,
                    },
                    error: function (e) {

                    },
                    success: function (r) {
                        console.log(r)
                        if (r == 'True') {
                            window.location.reload();
                            $('#preloader, #status').fadeOut();

                        }
                        else {
                            alert("@MyERP.Properties.Resources.YouShouldOpenPreviousPeriodFirst");
                            $('#preloader, #status').fadeOut();
                        }
                    }
                });
        }





    };










</script>
