                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-12">
            <div class="table-responsive">
                <table class="table table-striped table-centered mb-0">
                    <thead>
                        <tr style="background-color:white">

                            <th>
                                @MyERP.Properties.Resources.ArName
                            </th>
                            <th>
                                @MyERP.Properties.Resources.EnName
                            </th>
                            <th>
                                @MyERP.Properties.Resources.PeriodStart
                            </th>
                            <th>
                                @MyERP.Properties.Resources.PeriodEnd
                            </th>
                            <th>
                                @MyERP.Properties.Resources.Edit
                            </th>
                        </tr>

                        @foreach (var item in Model)
                        {

                            <tr>
                                <td @*style="background-color:#8fe2fc96"*@>
                                    @Html.DisplayFor(modelItem => item.ArName)
                                </td>
                                <td @*style="background-color:#8fe2fc96"*@>
                                    @Html.DisplayFor(modelItem => item.EnName)
                                </td>
                                <td @*style="background-color:#8fe2fc96"*@>
                                    @Html.DisplayFor(modelItem => item.PeriodStart)
                                </td>
                                <td @*style="background-color:#8fe2fc96"*@>
                                    @Html.DisplayFor(modelItem => item.PeriodEnd)
                                </td>
                                <td>
                                    <a href="@Url.Action("AddEdit", "FinancialPeriods", new { id = item.Id })" onclick="$('#preloader, #status').fadeIn();">
                                        <i class="fa fa-edit"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                        
                </table>
            </div>
        </div>
    </div>

