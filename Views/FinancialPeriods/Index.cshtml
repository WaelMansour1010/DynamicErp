@model IEnumerable<MyERP.Models.FinancialPeriodMaster>

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.FinancialPeriods;
}
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <a class="btn btn-info" href="@Url.Action("AddEdit")" role="button" style="float:left;"> @MyERP.Properties.Resources.AddNew </a>
            </div>
            <div class="hed page-title"> @MyERP.Properties.Resources.FinancialPeriods </div>
        </div>
    </div>
</div>
<div class="card-box">
