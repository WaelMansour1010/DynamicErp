                        <div class="hed page-title">@MyERP.Properties.Resources.FinancialPeriods</div>
                    </div>
                </div>
                <div class="form-group row">
                    <div class="col-md-2">
                        <input id="Date" name="Date" class="form-control" type="date" value="@ViewBag.Date" />
                    </div>
                    <div class="col-md-2">
                        <button type="button" class="btn btn-success btnSearch" onclick="searchWord = $('.searchtxt').val(); paging();">
                            <i class="fa fa-search"></i>
                        </button>
                        <a class="btn btn-info" href="@Url.Action("Index")" role="button"><i class="fe-refresh-ccw"></i></a>

                    </div>
