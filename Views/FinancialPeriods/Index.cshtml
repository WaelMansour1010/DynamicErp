                            <div class="col-md-6" style="background-color:red;width:20px;height:20px"></div>
                            <label class="col-md-8">@MyERP.Properties.Resources.Closed</label>
                        </div>
                        <div class="col-md-2">
                            <div class="col-md-3" style="background-color:white ;width:20px;height:20px"></div>
                            <label class="col-md-9">@MyERP.Properties.Resources.InActivated</label>
                        </div>
                        <div class="col-md-2">
                            <div class="col-md-6" style="background-color:#8fe2fc96;width:20px;height:20px"></div>
                            <label class="col-md-8">@MyERP.Properties.Resources.Activated</label>
                        </div>*@
