@model MyERP.Models.Housing

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.Housing;
    Layout = "~/Views/Shared/_HousingLayout.cshtml";
}
<script src="~/Scripts/SaveAndNew.js"></script>

<div class="row" style="padding-left:25px;padding-right:25px;">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                @if (Model != null)
                {
                    if (Model.IsDeleted == false) 
                    {
                        if (ViewBag.Previous > 0)
                        {
                            <a href="@Url.Action("AddEdit",new {id= ViewBag.First })" class="btn btn-info">@MyERP.Properties.Resources.First</a>
                            <a href="@Url.Action("AddEdit",new { id=ViewBag.Previous })" class=" btn btn-info">&#8250;</a>
                        }
                        if (ViewBag.Next > 0)
                        {
                            <a href="@Url.Action("AddEdit",new { id=ViewBag.Next })" class="btn btn-info">&#8249;</a>
                            <a href="@Url.Action("AddEdit",new {id=ViewBag.Last })" class="btn btn-info">@MyERP.Properties.Resources.Last</a>
                        }
                    }
                }
            </div>
            <div class="hed page-title">@MyERP.Properties.Resources.Housing :</div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card-box">
            <form action="/Housing/AddEdit2" class="form-horizontal needs-validation" novalidate method="post" enctype="multipart/form-data" id="FormId">
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">
                                <div class="form-group row">
                                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                    @Html.AntiForgeryToken()
                                    @if (Model != null)
                                    {

                                        @Html.HiddenFor(model => model.Id)
                                        @Html.HiddenFor(model => model.IsActive)
                                        @Html.HiddenFor(model => model.UserId)
                                        @Html.HiddenFor(model => model.Image)
                                        @Html.HiddenFor(model => model.IsDeleted)
                                        @Html.HiddenFor(model => model.IsConfirmed)
                                        @Html.HiddenFor(model => model.Code)
                                        @Html.HiddenFor(model => model.ArName)
                                        @Html.HiddenFor(model => model.EnName)
                                        @Html.HiddenFor(model => model.RoomNo)
                                        @Html.HiddenFor(model => model.RoomContent)
                                    }

                                    <label for="DepartmentId" class="col-sm-2 control-label">@MyERP.Properties.Resources.Name</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("Id", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", @required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                   
                                </div>

                                <div class="form-group row">
                                    <label for="inputtext3" class="col-sm-2 control-label"> @MyERP.Properties.Resources.IdentityNumber</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.NationalNo, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.IdentityNumber, required = "required" } })
                                    </div>
                                    <label for="inputtext3" class="col-sm-2 control-label"> @MyERP.Properties.Resources.Mobile</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.Mobile, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.Mobile, required = "required" } })
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>

                    <div class="row" style="float:left;">
                        <input id="new" name="newBtn" hidden />
                        <div>
                            @if (Model == null)
                            {
                                <input id="new" name="newBtn" hidden />
                               
                                <button type="submit" class="btn btn-success" style="margin-right:25px;">
                                    @MyERP.Properties.Resources.Save
                                </button>
                            }
                            else
                            {
                                if (Model.IsDeleted == false)
                                {
                                    <button type="submit" class="btn btn-success" style="margin-right:25px;">
                                        @MyERP.Properties.Resources.Save
                                    </button>
                                }
                            }
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    
    $(document).on('change','#Id',function(){
     GetHousingDetails();
    });

    function GetHousingDetails(){
     $.get('/Housing/GetHousingDetails?Id='+$('#Id').val()).done(function(r){
    $('#Mobile').val(r.Mobile);
    $('#NationalNo').val(r.NationalNo);
    });
    }
</script>

