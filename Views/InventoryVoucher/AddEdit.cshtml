    function SetItemPrice() {
        $('#preloader, #status').fadeIn();
        var sum = 0.00;
        $('#InventoryVoucherDetails tr').each(function () {
            let td = $(this);
            if (td.find('.item').val()) {
                if ($("input[name='InventoryTypeId']:checked").val() == 1) {
                    $.get('/Helper/GetItemAvgPrice?itemId=' + td.find('.itemId').val() + '&departmentId=' + $('#DepartmentId').val()).done(function (r) {
                        td.find('.Price').val(r);
                        sum += r * td.find('.quantity').val();
                        $('#Total').val(sum);
                    });
                }
                else {
                    let itemPrice = items.filter(function (i) { return i.ItemPriceId == td.find('.item').val(); })[0].Price;
                    td.find('.Price').val(itemPrice);
                    sum += itemPrice * td.find('.quantity').val();
                    $('#Total').val(sum);
                }
                //SetItemStatus(td.find('.quantity'));
            }
            $('#preloader, #status').fadeOut();
        });
        SetTotalPrice();
    }

    function SetItemStatus(e) {
        if ($(e).val() != null) { // Came From Quantity Change
            let elem = $(e).closest('tr');
            if (elem.find('.item').val()) {
                var qtyOnSystem = elem.find('.quantityOnSystem').val();
                var qty = $(e).val();
                if (qtyOnSystem === qty) {
                    elem.find('.Status').val(1);
                    elem.find('.StatusName').text('@MyERP.Properties.Resources.Equal');
                }
                else if (qtyOnSystem < 0 && qty < 0) {
                    if (qtyOnSystem > qty) {
                        elem.find('.Status').val(2);
                        elem.find('.StatusName').text('@MyERP.Properties.Resources.Extra');
                    }
                    else {
                        elem.find('.Status').val(3);
                        elem.find('.StatusName').text('@MyERP.Properties.Resources.Deficiency');
                    }
                }
                else {
                    if (qtyOnSystem < qty) {
                        elem.find('.Status').val(2);
                        elem.find('.StatusName').text('@MyERP.Properties.Resources.Extra');
                    }
                    else {
                        elem.find('.Status').val(3);
                        elem.find('.StatusName').text('@MyERP.Properties.Resources.Deficiency');
                    }
                }

            }
        }
        else {
            $('#InventoryVoucherDetails tr').each(function () {
            let td = $(this);
            if (td.find('.item').val()) {
                var qtyOnSystem = td.find('.quantityOnSystem').val();
                var qty = td.find('.quantity').val();
                if (qtyOnSystem === qty) {
                    td.find('.Status').val(1);
                    td.find('.StatusName').text('@MyERP.Properties.Resources.Equal');
                }
                else if (qtyOnSystem < qty) {
                     td.find('.Status').val(2);
                    td.find('.StatusName').text('@MyERP.Properties.Resources.Extra');
                }
                else {
                     td.find('.Status').val(3);
                    td.find('.StatusName').text('@MyERP.Properties.Resources.Deficiency');
                }
            }
        });

        }
        SetItemPrice();
    }

    $(document).on('change', '.quantity', function () {
        SetItemStatus($(this));
    });
    function SetTotalPrice() {
        var sum = 0.00;
         $('#InventoryVoucherDetails tr').each(function () {
            let td = $(this);
             if (td.find('.item').val()) {
                 var Price = td.find('.Price').val();
                 var qty = td.find('.quantity').val();
                 sum += Price * qty;
                 $('#Total').val(sum);
             }
             else {
                 sum += 0.00;
                 $('#Total').val(sum);
             }
         });
    }

