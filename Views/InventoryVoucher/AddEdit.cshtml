@model MyERP.Models.InventoryVoucher

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";

    ViewBag.Title = MyERP.Properties.Resources.InventoryVoucher;
}
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                @if (Model != null)
                {
                    if (Model.IsDeleted == false)
                    {
                        if (ViewBag.Previous > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.First })" class="btn btn-info">@MyERP.Properties.Resources.First</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Previous })" class=" btn btn-info">&#8250;</a>
                        }
                        if (ViewBag.Next > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Next })" class="btn btn-info">&#8249;</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Last })" class="btn btn-info">@MyERP.Properties.Resources.Last</a>
                        }
                    }
                }
                <a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
            </div>
            <h4 class="page-title">@MyERP.Properties.Resources.InventoryVoucher:</h4>
        </div>
    </div>
</div>
@if (Model != null)
{
    @Html.HiddenFor(model => model.Id)
    @Html.HiddenFor(model => model.IsActive)
    @Html.HiddenFor(model => model.UserId)
    @Html.HiddenFor(model => model.IsLinked)
    @Html.HiddenFor(model => model.IsPosted)
    @Html.HiddenFor(model => model.IsDeleted)
    @Html.HiddenFor(model => model.IsAccepted)
    @Html.HiddenFor(model => model.IsCompleted)
    @Html.HiddenFor(model => model.Image)
    @Html.HiddenFor(model => model.AutoCreated)
}
<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal needs-validation" role="form">
                        <div class="card">
                            <div class="card-body">
                                <h5 class="header-title">
                                    @MyERP.Properties.Resources.MainData
                                </h5>
                                <div class="form-group row">
                                    <label class=" col-sm-2 control-label" for="DocumentNumber">@MyERP.Properties.Resources.DocNo</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.DocumentNumber, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly", placeholder = @MyERP.Properties.Resources.DocNo, required = "required", hidden = "hidden" } })
                                        <input id="DocumentNumbers" class="form-control" placeholder=@MyERP.Properties.Resources.Code required readonly />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label for="VoucherDate" class="control-label col-sm-2">@MyERP.Properties.Resources.InvoiceDate</label>
                                    <div class="col-sm-4">
                                        <input id="VoucherDate" name="VoucherDate" class="form-control" type="datetime-local" value="@ViewBag.VoucherDate" required />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.EnterDate
                                        </div>
                                    </div>
                                </div>

                                <div class="form-group row">
                                    <label for="DepartmentId" class="col-sm-2 control-label">@MyERP.Properties.Resources.Branch</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("DepartmentId", null, null, htmlAttributes: new { @class = "form-control", required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Select
                                        </div>
                                    </div>

                                    <label for="WarehouseId" class="col-sm-2 control-label">@MyERP.Properties.Resources.WareHouse</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("WarehouseId", null, null, htmlAttributes: new { @class = "form-control", required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Select
                                        </div>
                                    </div>
                                </div>

                                <div class="form-group row">
                                    <div class="col-sm-4">
                                        <input type="checkbox" name="AdjustmentonEmployeeReceivable" @Html.Raw(Model != null && Model.AdjustmentonEmployeeReceivable == true ? "checked" : "") id="AdjustmentonEmployeeReceivable" />
                                        <label for="AdjustmentonEmployeeReceivable" class="col-sm-8 control-label">@MyERP.Properties.Resources.AdjustmentonEmployeeReceivable</label>
                                    </div>

                                    <div class="col-sm-8">
                                        <label for="InventoryTypeId" class="col-sm-2 control-label">@MyERP.Properties.Resources.InventoryType</label>
                                        <input type="radio" id="CostPriceInventory" name="InventoryTypeId" value="1" class="col-sm-2" checked="checked" />@MyERP.Properties.Resources.CostPriceInventory
                                        <input type="radio" id="SalePriceInventory" name="InventoryTypeId" value="2" class="col-sm-2" />@MyERP.Properties.Resources.SalePriceInventory
                                        @if (Model != null && Model.InventoryTypeId > 0)
                                        {
                                            <input id="InventoryType" hidden value="@Model.InventoryTypeId" />
                                        }

                                    </div>
                                </div>


                                <div class="form-group row">
                                    <label class="control-label col-sm-2" for="Notes">@MyERP.Properties.Resources.Notes</label>
                                    <div class="col-sm-4">
                                        <textarea id="Notes" name="Notes" class="form-control" rows="5" cols="5">@if (Model != null) { @Model.Notes; }</textarea>
                                    </div>
                                    @if (ViewBag.ShowItemsInsteadOfItemGroupsInInventoryVoucher != true && ViewBag.ShowDepartmentItemsInInventoryVoucher != true)
                                    {
                                        <label for="ItemGroupId" class="col-sm-2 control-label">@MyERP.Properties.Resources.Group</label>
                                        <div class="col-sm-4">
                                            @Html.DropDownList("ItemGroupId", null, htmlAttributes: new { @class = "form-control", required = "required" })
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Select
                                            </div>
                                        </div>
                                    }

                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            @if (ViewBag.ShowItemsInsteadOfItemGroupsInInventoryVoucher == true)
            {
                @Html.Partial("ItemSearch")
            }
            @*@Html.Partial("ItemSearch")*@

            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="header-title">@MyERP.Properties.Resources.Details</h5>
                            <div class="form-horizontal needs-validation" role="form">
                                <div class="table-responsive">
                                    <table class="table table-centered mb-0">
                                        <thead>
                                            <tr>
                                                <th>@MyERP.Properties.Resources.Barcode</th>
                                                <th>@MyERP.Properties.Resources.Item</th>
                                                <th class="expiry" style="display:none;"> @MyERP.Properties.Resources.ExpirationDate </th>
                                                <th>@MyERP.Properties.Resources.BookQuantity</th>
                                                <th>@MyERP.Properties.Resources.ActualQuantity</th>
                                                <th class="UnitEquivClass" style="display:none;">@MyERP.Properties.Resources.Unit</th>
                                                <th class="UnitEquivClass" style="display:none;">@MyERP.Properties.Resources.Equivalent</th>
                                                <th>@MyERP.Properties.Resources.Price</th>
                                                <th>@MyERP.Properties.Resources.Status</th>

                                                @if (ViewBag.ShowItemsInsteadOfItemGroupsInInventoryVoucher == true)
                                                {
                                                    <th> @MyERP.Properties.Resources.Delete </th>
                                                }
                                            </tr>
                                        </thead>
                                        <tbody id="InventoryVoucherDetails">

                                            @if (Model != null)
                                            {
                                                foreach (var item in Model.InventoryVoucherDetails)
                                                {
                                                    <tr>
                                                        <td class="tabledit-edit-mode"><input class="barcode form-control tabledit-input form-control-sm" value="@Html.Raw(item.ItemPrice==null?"":item.ItemPrice.Barcode)" disabled /></td>
                                                        <td class="tabledit-edit-mode">
                                                            <input type="hidden" class="item form-control tabledit-input form-control-sm" value="@item.ItemPriceId" required />
                                                            <input type="text" hidden class="item-name form-control tabledit-input form-control-sm" value=" @item.ItemPrice.Barcode -@item.Item.ArName - @item.ItemUnit.ArName" required disabled />
                                                            <label class="name"> @item.ItemPrice.Barcode -@item.Item.ArName - </label>
                                                            <input hidden class="itemUnitArName" value=@item.ItemUnit.ArName />

                                                        </td>
                                                        <td class="tabledit-edit-mode expiry" style="display:none;">
                                                            @if (item.ExpireDate.HasValue)
                                                            {
                                                                <input class="ExpiryDate form-control tabledit-input form-control-sm" readonly value="@item.ExpireDate.Value.ToString("MM/dd/yyyy")" />
                                                            }
                                                            else
                                                            {
                                                                <input class="ExpiryDate form-control tabledit-input form-control-sm" readonly />
                                                            }
                                                            <input class="PatchId form-control tabledit-input form-control-sm" hidden value="@item.PatchId" />
                                                            <input class="itemId form-control tabledit-input form-control-sm" hidden value="@item.ItemId" />

                                                        </td>
                                                        <td class="tabledit-edit-mode"><input type="text" class="quantityOnSystem form-control tabledit-input form-control-sm" value="@item.QtyOnSystem" disabled /></td>
                                                        <td class="tabledit-edit-mode">
                                                            <input class="quantity form-control tabledit-input form-control-sm" type="text" value="@item.Qty" />
                                                        </td>
                                                        <td class="tabledit-edit-mode UnitClass" style="display:none;"><select class="item-unit form-control tabledit-input form-control-sm" required disabled><option value="@item.ItemUnitId">@item.ItemUnit.ArName</option></select></td>
                                                        <td class="tabledit-edit-mode UnitEquivClass" style="display:none;"><input class="unit-equavalent form-control tabledit-input form-control-sm" type="number" step="any" value="@item.UnitEquivalent" disabled /></td>
                                                        <td class="tabledit-edit-mode"><input class="Price form-control tabledit-input form-control-sm " type="text" value="@item.CostPrice.Value.ToString("0.00")" disabled /></td>
                                                        <td class="tabledit-edit-mode">
                                                            @if (item.Status !=null)
                                                            {
                                                                <input class="Status form-control tabledit-input form-control-sm" value="@item.Status" hidden />
                                                                if (item.Status == 1)
                                                                {
                                                                    <label class="StatusName control-label"> @MyERP.Properties.Resources.Equal </label>
                                                                }
                                                                else if (item.Status == 2)
                                                                {
                                                                    <label class="StatusName control-label"> @MyERP.Properties.Resources.Extra </label>
                                                                }
                                                                else if (item.Status == 3)
                                                                {
                                                                    <label class="StatusName control-label"> @MyERP.Properties.Resources.Deficiency </label>
                                                                }
                                                                else
                                                                {
                                                                    <label class="StatusName control-label">  </label>
                                                                }
                                                            }
                                                            else
                                                            {
                                                                <input class="Status form-control tabledit-input form-control-sm"  hidden />
                                                                <label class="StatusName control-label">  </label>
                                                            }
                                                        </td>
                                                    </tr>

                                                }
                                            }
                                            else
                                            {
                                                if (ViewBag.ShowItemsInsteadOfItemGroupsInInventoryVoucher == true)
                                                {

                                                    <tr>
                                                        <td class="tabledit-edit-mode">
                                                            <input class="barcode form-control tabledit-input form-control-sm" />
                                                        </td>
                                                        <td onclick="showSearchModal()" class="tabledit-edit-mode popupCell">
                                                            <input type="hidden" class="item form-control tabledit-input form-control-sm" @Html.Raw(Model != null ? "" : "required ") />
                                                            <input type="text" hidden class="item-name form-control tabledit-input form-control-sm" @Html.Raw(Model != null ? "" : "required ") />
                                                            <span class="Add-Button" style="font-size: 25px; color: limegreen;margin-right:50%;"><i class="fas fa-plus"></i></span>
                                                            <label style="width:200px" class="name control-label tabledit-input"></label>
                                                            <input hidden class="itemUnitArName" />
                                                        </td>

                                                        <td class="tabledit-edit-mode expiry" style="display:none;">

                                                            <input class="ExpiryDate form-control tabledit-input form-control-sm" readonly />

                                                            <input class="PatchId form-control tabledit-input form-control-sm" hidden />
                                                            <input class="itemId form-control tabledit-input form-control-sm" hidden />

                                                        </td>
                                                        <td class="tabledit-edit-mode"><input type="text" class="quantityOnSystem form-control tabledit-input form-control-sm" disabled /></td>
                                                        <td class="tabledit-edit-mode">
                                                            <input class="quantity form-control tabledit-input form-control-sm" type="text" />
                                                        </td>
                                                        <td class="tabledit-edit-mode UnitClass" style="display:none;"><select class="item-unit form-control tabledit-input form-control-sm" required disabled><option></option></select></td>
                                                        <td class="tabledit-edit-mode UnitEquivClass" style="display:none;"><input class="unit-equavalent form-control tabledit-input form-control-sm" type="number" step="any" disabled /></td>
                                                        <td>
                                                            <a href="javascript:void(0);" onclick="deleteElement(this)">
                                                                <i class="fas fa-trash-alt"></i>
                                                            </a>
                                                        </td>
                                                    </tr>

                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>


                    <div class="card">
                        <div class="card-body">
                            <div class="form-group row">

                                <label for="Total" class="col-sm-2 control-label">@MyERP.Properties.Resources.Total</label>
                                <div class="col-sm-4">
                                    @Html.EditorFor(model => model.Total, new { htmlAttributes = new { @class = "form-control", @type = "number", @readonly = "readonly", placeholder = @MyERP.Properties.Resources.Total } })

                                    @*<input type="text" id="Total" class="form-control" disabled />*@
                                </div>


                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Patch Modal-->
            <div id="patchModal" class="modal fade bs-example-modal-lg" tabindex="-1" role="dialog" aria-labelledby="myLargeModalLabel" data-backdrop="false" style="background-color: rgba(0, 0, 0, 0.5);">
                <div class="modal-dialog modal-lg" role="document">
                    <div class="modal-content">
                        <div class="modal-header">
                            <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                        </div>
                        <div class="modal-body">

                            <div class="row">
                                <div class="col-sm-12">
                                    <table class="table table-condensed">
                                        <thead>
                                            <tr>
                                                <th>@MyERP.Properties.Resources.PatchCode</th>
                                                <th>@MyERP.Properties.Resources.ExpirationDate</th>
                                                <th>@MyERP.Properties.Resources.Qty</th>
                                                <th>@MyERP.Properties.Resources.Add</th>
                                            </tr>
                                        </thead>
                                        <tbody id="item-patches"></tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-default" onclick=" $('.bs-example-modal-lg').modal('hide');" data-dismiss="modal">@MyERP.Properties.Resources.Close</button>
                        </div>
                    </div>

                </div>
            </div>
            <div class="row">
                <div class="col-sm-offset-2">
                    @if (Model == null)
                    {
                        <button type="button" onclick="addEdit('report')" class="btn btn-success">
                            @MyERP.Properties.Resources.SaveAndPrint
                        </button>
                        <button type="submit" id="newbtn" onclick="addEdit('new')" class="btn btn-success">
                            @MyERP.Properties.Resources.SaveAndNew
                        </button>
                        <button class="btn btn-success" id="save" onclick="addEdit()">
                            @MyERP.Properties.Resources.Save
                        </button>
                        <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                    }
                    else if (Model.IsDeleted == false)
                    {
                        <button type="button" onclick="addEdit('report')" class="btn btn-success">
                            @MyERP.Properties.Resources.SaveAndPrint
                        </button>
                        <button class="btn btn-success" id="save" onclick="addEdit()">
                            @MyERP.Properties.Resources.Save
                        </button>
                        <button class="btn btn-success" onclick="adjustment(@Model.Id)">
                            @MyERP.Properties.Resources.Adjustment
                        </button>

                        <a class="btn btn-success" target="_blank" href="@Url.Action("InventoryVoucher","Report",new { id=Model.Id})" role="button"> @MyERP.Properties.Resources.Print</a>

                        <a class="btn btn-danger" href="@Url.Action("Index")" role="button"> @MyERP.Properties.Resources.Back</a>
                        <button class="btn btn-danger" onclick="Delete(@Model.Id)" role="button"> @MyERP.Properties.Resources.Delete</button>
                    }
                </div>

            </div>

            <!-- JournalEntry -->
            @if (Model != null && Model.IsCompleted == true)
            {
                <div class="row">
                    <div class="col-12">
                        <div class="card-box">
                            <div class="row">
                                <div class="col-12">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.StockIssueVouchers
                                    </h5>
                                    <div class="table-responsive">
                                        <table class="table table-striped table-centered mb-0">
                                            <thead>
                                                <tr>
                                                    <th>
                                                        @MyERP.Properties.Resources.DocNo
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Date
                                                    </th>

                                                    <th>
                                                        @MyERP.Properties.Resources.TotalCost
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.WareHouse
                                                    </th>

                                                    <th>@MyERP.Properties.Resources.View</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var item in (List<MyERP.Models.StockIssueVoucher>)ViewBag.StockIssueVouchers)
                                                {
                                                    <tr>
                                                        <td>
                                                            @*@Html.DisplayFor(modelItem => item.DocumentNumber)*@
                                                            @Html.Raw(item.DocumentNumber.ToString().Replace("-", ""))
                                                        </td>
                                                        <td>
                                                            @Html.DisplayFor(modelItem => item.VoucherDate)
                                                        </td>

                                                        <td>
                                                            @Html.DisplayFor(modelItem => item.TotalCostPrice)
                                                        </td>

                                                        <td>
                                                            @Html.DisplayFor(modelItem => item.Warehouse.ArName)
                                                        </td>

                                                        <td>
                                                            <a href="@Url.Action("AddEdit","StockIssueVoucher",new { id=item.Id }) " target="_blank">
                                                                <i class="fa fa-edit"></i>
                                                            </a>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-12">
                        <div class="card-box">
                            <div class="row">
                                <div class="col-12">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.StockReceiptVoucher
                                    </h5>
                                    <div class="table-responsive">
                                        <table class="table table-striped table-centered mb-0">
                                            <thead>
                                                <tr>
                                                    <th>
                                                        @MyERP.Properties.Resources.DocNo
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Date
                                                    </th>

                                                    <th>
                                                        @MyERP.Properties.Resources.TotalCost
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.WareHouse
                                                    </th>

                                                    <th>@MyERP.Properties.Resources.View</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var item in (List<MyERP.Models.StockReceiptVoucher>)ViewBag.StockReceiptVouchers)
                                                {
                                                    <tr>
                                                        <td>
                                                            @*@Html.DisplayFor(modelItem => item.DocumentNumber)*@
                                                            @Html.Raw(item.DocumentNumber.ToString().Replace("-", ""))
                                                        </td>
                                                        <td>
                                                            @Html.DisplayFor(modelItem => item.VoucherDate)
                                                        </td>

                                                        <td>
                                                            @Html.DisplayFor(modelItem => item.TotalCostPrice)
                                                        </td>

                                                        <td>
                                                            @Html.DisplayFor(modelItem => item.Warehouse.ArName)
                                                        </td>

                                                        <td>
                                                            <a href="@Url.Action("AddEdit","StockReceiptVoucher",new { id=item.Id }) " target="_blank">
                                                                <i class="fa fa-edit"></i>
                                                            </a>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-12">
                        <div class="card-box">
                            <div class="row">
                                <div class="col-12">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.JournalEntries
                                    </h5>
                                    <div class="table-responsive">
                                        <table class="table table-striped table-centered mb-0">
                                            <thead>
                                                <tr>
                                                    <th>
                                                        @MyERP.Properties.Resources.DocNo
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.MainDoc
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Date
                                                    </th>

                                                    <th>@MyERP.Properties.Resources.View</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var item in (List<MyERP.Models.JournalEntry>)ViewBag.JournalEntries)
                                                {
                                                    <tr>
                                                        <td>
                                                            @*@Html.DisplayFor(modelItem => item.DocumentNumber)*@
                                                            @Html.Raw(item.DocumentNumber.ToString().Replace("-", ""))
                                                        </td>
                                                        <td>
                                                            @Html.DisplayFor(modelItem => item.SystemPage.ArName)
                                                        </td>
                                                        <td>
                                                            @Html.DisplayFor(modelItem => item.Date)
                                                        </td>
                                                        <td>
                                                            <a href="@Url.Action("AddEdit","JournalEntries",new { id=item.Id }) " target="_blank">
                                                                <i class="fa fa-edit"></i>
                                                            </a>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <!-------------------------------------------------------------->

        </div>
    </div>
</div>

<script src="~/Scripts/BarcodeScan.js"></script>
<script>
    //-------------- Variable Declarations ----------------//
    let UseExpiryDateForItems = '@ViewBag.UseExpiryDateForItems';
    var selectedItemRowToEdit; // for expire date
    let ShowItemsInsteadOfItemGroupsInInventoryVoucher = '@ViewBag.ShowItemsInsteadOfItemGroupsInInventoryVoucher';
    let ShowDepartmentItemsInInventoryVoucher = '@ViewBag.ShowDepartmentItemsInInventoryVoucher';
    let items = [];
    let custIems = [];
    let warehouseOptions = '';
    var isBarcodeScanned = false; // For barcode scanner
    var barcodeScannerCode = ""; // For barcode scanner
    var currentItemTr;
    //-------------------- conditions and Checks ----------------------//
    if ($('#IsCompleted').val() == 'True') {
        $('button.btn.btn-success').addClass('disabled').attr('disabled', 'disabled');
    }

    //---------------------- Ready ----------------------//
    $(document).ready(function () {
        $.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
            $("#VoucherDate").prop('min', r.PeriodStart).prop('max', r.PeriodEnd);
        });
        if ($('#Id').val() > 0) {
            var code = $('#DocumentNumber').val();
            $('#DocumentNumbers').val(code.replaceAll("-", ""))
            $('#ItemGroupId').prop('disabled', true);
            $('#DepartmentId').prop('disabled', true);
            $('#ItemGroupId').prop('disabled', true);
            $('#WarehouseId').prop('disabled', true);
            $('#VoucherDate').prop('disabled', true);
            $('.cost').each(function () {
                $(this).closest('tr').find('.total').val($(this).inputmask('unmaskedvalue') * $(this).closest('tr').find('.quantity').val());
            });
            // getItems();
