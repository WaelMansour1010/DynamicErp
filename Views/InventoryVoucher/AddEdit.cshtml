    var qtyOnSystem = 0;
    function getItemQuantityOnSystem(item) {
        let itemId = items.filter(function (i) { return i.ItemPriceId == item.val(); })[0].Id;
        //  let itemName = items.filter(function (i) { return i.ItemPriceId == item.val(); })[0].ArName;
        if ($('#WarehouseId').val())
            requestData('/Helper/ItemQuantityOnSystem?warehouseId=' + $('#WarehouseId').val() + '&itemId=' + itemId).done(function (r) {
                qtyOnSystem = r;// (r * 1 > 0 ? r * 1 : 0) ;
                $(item).closest('tr').find('.quantityOnSystem').val(qtyOnSystem);
                $(item).closest('tr').find('.quantity').val(qtyOnSystem);
                $('#preloader, #status').fadeOut();
            }).fail(function () {
                $(item).closest('tr').find('.quantityOnSystem').val('');
                $(item).closest('tr').find('.quantity').val('');
                $('#preloader, #status').fadeOut();
            });
        setTimeout(SetItemStatus, 1000);
    }

    // check if item has expire date
    function isItemHasExpireDate(itemId) {
        let ItemHasExpiry = items.filter(function (i) { return i.Id == itemId; })[0].ItemHasExpiry;
        return ItemHasExpiry;
    }

    // Patch modal
    function showPatchModal(itemId, isNewItem, getZeroQunatity) {
        let ItemHasExpiry = isItemHasExpireDate(itemId);
        if (UseExpiryDateForItems && ItemHasExpiry == true) {
            $('#patchModal').modal('show');
            let itemPatches = [];
            //let itemId = $(item).closest('tr').find('.item-id').val();
            $.get('/Helper/PatchesByItemId?itemId=' + itemId + '&getZeroQunatity=' + getZeroQunatity).done(function (r) {
                itemPatches = r;
                let tr = '';
                // Add
                if (isNewItem) {
                    for (var i = 0; i < itemPatches.length; i++) {
                        tr += ('<tr><td>' + (itemPatches[i].PatchCode ? itemPatches[i].PatchCode : '') + '</td><td><input hidden class="itemId" value="' + itemId + '" /><input hidden class="itemPatchId" value="' + itemPatches[i].PatchId + '" /><label class="itemPatchExpireDate">' + (itemPatches[i].ExpiryDate != null ? convertToJavaScriptDate(itemPatches[i].ExpiryDate) : '') + '</label></td ><td><input hidden class="itemPatchesQty" value="' + itemPatches[i].Qty + '"/>' + itemPatches[i].Qty + '</td><td><button class="btn btn-info js-choose-patch-item">' + ' @MyERP.Properties.Resources.Add' + '</button></td></tr > ');
                    }
                }
                else {
                    for (var i = 0; i < itemPatches.length; i++) {
                        tr += ('<tr><td>' + (itemPatches[i].PatchCode ? itemPatches[i].PatchCode : '') + '</td><td><input hidden class="itemId" value="' + itemId + '" /><input hidden class="itemPatchId" value="' + itemPatches[i].PatchId + '" /><label class="itemPatchExpireDate">' + (itemPatches[i].ExpiryDate != null ? convertToJavaScriptDate(itemPatches[i].ExpiryDate) : '') + '</label></td ><td><input hidden class="itemPatchesQty" value="' + itemPatches[i].Qty + '"/>' + itemPatches[i].Qty + '</td><td><button class="btn btn-info js-edit-patch-item">اضف</button></td></tr > ');
                    }
                }
                $('#item-patches').empty().append(tr);
                $('#pleasewait').fadeOut();
            });
        }
    }

    //------------------- ConvertDate-------------
    function convertToJavaScriptDate(value) {

                                        if (value === null)
                                            return null;
                                        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        return ((dt.getMonth() + 1 + "/" + dt.getDate() + "/" + dt.getFullYear()));
        // return (dt)
    }

