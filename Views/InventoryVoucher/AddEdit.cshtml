                                title: '@MyERP.Properties.Resources.ExpirationDateForItemsIsDisabled' + ' !',
                                text: " ",
                                icon: 'info',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                        }
                    }
                    else {
                        isBarcodeScanned = false;
                        barcodeScannerCode = "";

                        $(elem).closest('tr').find('.ExpiryDate').val(''); //
                    }

                    $(elem).closest('tr').find('.itemId').val(itmId);
                    $(elem).closest('tr').find('.name').text(itemPrice.ArName);

                    $(elem).closest('tr').find('.item-name').val(itemPrice.ArName);
                    $(elem).closest('tr').find('.item').val(itemPrice.ItemPriceId).trigger('change');
                } else {

                    $(elem).closest('tr').find('.itemId').val(''); //
                    $(elem).closest('tr').find('.ExpiryDate').val(''); //

                    $(elem).closest('tr').find('.item-name').val('');
                    $(elem).closest('tr').find('.name').text('');

                    $(elem).closest('tr').find('.item').val('').trigger('change');
                }
            } else {
                $(elem).closest('tr').find('.item-name').val('');
                $(elem).closest('tr').find('.name').text('');

                $(elem).closest('tr').find('.item').val('').trigger('change');
            }
        }
    });

