
@{
    UICulture = Session["lang"] != null?Session["lang"].ToString():"ar";

    ViewBag.Title = MyERP.Properties.Resources.AdjustingPricesOfGroupOfItems;
}

<div style="text-align: left;padding-bottom: 23px;">
</div>

<div class="panel panel-widget forms-panel">
    <div class="forms">
        <div class=" form-grids form-grids-right">
            <div class="widget-shadow " data-example-id="basic-forms">
                <div class="tables">
                    <div class="form-title">
                        <a class="btn btn-info" href="@Url.Action("Index")" role="button" style="float:left;">@MyERP.Properties.Resources.Back</a>
                        <div class="hed"> @MyERP.Properties.Resources.Items</div>
                    </div>
                    <div class="form-body">
                        <div class="form-horizontal">
                            <div class="form-group">
                                <label for="ItemGroupId" class="control-label col-sm-1">@MyERP.Properties.Resources.ItemsGroup</label>
                                <div class="col-sm-5">
                                    @Html.DropDownList("ItemGroupId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })
                                </div>
                            </div>
                            <div class="form-group">
                                <div class="col-sm-1">
                                    <input type="radio" name="adjustPriceMethod" value="value" checked="checked" />
                                    <label for="adjustValue">@MyERP.Properties.Resources.Value</label>
                                </div>
                                <div class="col-sm-5">
                                    <input type="text" id="adjustValue" />
                                </div>
                            </div>
                            <div class="form-group">
                                <div class="col-sm-1">
                                    <input type="radio" name="adjustPriceMethod" value="perc" />
                                    <label for="adjustPerc">@MyERP.Properties.Resources.Percentage</label>
                                </div>
                                <div class="col-sm-5">
                                    <input type="text" id="adjustPerc" readonly/>%
                                </div>
                            </div>
                            <div class="form-group">
                                <div class="col-sm-offset-2">
                                    <button type="submit" onclick="post()" class="btn btn-success">
                                        @MyERP.Properties.Resources.Edit
                                    </button>
                                   
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    $('#adjustValue, #adjustPerc').inputmask({
        alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'placeholder': '0'
    });
    $('#adjustValue').on('change', function () {
        $('#adjustPerc').val(0);
    });

    $('#adjustPerc').on('change', function () {
        $('#adjustValue').val(0);
    });

    $("input[name='adjustPriceMethod']").on('change', function () {
        if ($(this).val() == 'perc') {
            $('#adjustValue').attr('readonly', 'readonly');
            $('#adjustValue').val('0');
            $('#adjustPerc').removeAttr('readonly');
        } else if ($(this).val() == 'value') {
            $('#adjustPerc').attr('readonly', 'readonly');
            $('#adjustPerc').val('0');
            $('#adjustValue').removeAttr('readonly');
        }
    });

    function post() {
        if ($('#ItemGroupId').val()) {
            $('#preloader, #status').fadeIn();
            $.post('/Item/AdjustPrice?id=' + $('#ItemGroupId').val() + '&value=' + $('#adjustValue').inputmask('unmaskedvalue') + '&perc=' + $('#adjustPerc').inputmask('unmaskedvalue')).done(function (r) {
                if (r == 'true') {
                    alert('@MyERP.Properties.Resources.Modified'+'!');
                } else {
                    alert('@MyERP.Properties.Resources.NotModified'+'!');
                }
                $('#preloader, #status').fadeOut();
            }).fail(function () {
                alert('@MyERP.Properties.Resources.NotModified'+'!');
                $('#preloader, #status').fadeOut();
            });
        }
    }
</script>

