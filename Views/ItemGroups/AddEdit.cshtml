<script src="~/Scripts/SaveAndNew.js"></script>
@model MyERP.Models.ItemGroup
@{
    if (System.Web.Configuration.WebConfigurationManager.AppSettings["ECommerce"] == "true")
    {
        Layout = "~/Views/Shared/_EcommerceLayout.cshtml";
    }
}
@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";

    ViewBag.Title = MyERP.Properties.Resources.ItemGroups;
    bool isECommerce = System.Web.Configuration.WebConfigurationManager.AppSettings["ECommerce"] == "true" ? true : false;
    string AmazonS3Server = string.IsNullOrEmpty(System.Web.Configuration.WebConfigurationManager.AppSettings["AmazonS3Server"]) ? "" : System.Web.Configuration.WebConfigurationManager.AppSettings["AmazonS3Server"];
}

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                @if (Model != null)
                {
                    if (Model.IsDeleted == false)
                    {
                        if (ViewBag.Previous > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.First })" class="btn btn-info">@MyERP.Properties.Resources.First</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Previous })" class=" btn btn-info">&#8250;</a>
                        }
                        if (ViewBag.Next > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Next })" class="btn btn-info">&#8249;</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Last })" class="btn btn-info">@MyERP.Properties.Resources.Last</a>
                        }
                    }
                }
                <a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
            </div>
            <h4 class="page-title">@MyERP.Properties.Resources.ItemGroups :</h4>
        </div>
    </div>
</div>



<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="form-horizontal needs-validation" role="form">

                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">
                                <div class="form-group row">
                                    @if (Model != null)
                                    {


                                        @Html.HiddenFor(model => model.Id)
                                        @Html.HiddenFor(model => model.Image)

                                        @Html.HiddenFor(model => model.IsActive)
                                        @Html.HiddenFor(model => model.UserId)
                                        @Html.HiddenFor(model => model.IsDeleted)
                                    }
                                    <label for="Code" class="col-sm-2 control-label">@MyERP.Properties.Resources.Code</label>
                                    <div class="col-sm-2">
                                        @Html.EditorFor(model => model.Code, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.Code, @readonly = "readonly", required = "required" } })
                                        @Html.ValidationMessageFor(model => model.Code, "", new { @class = "text-danger" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div> <div class="col-sm-2">
                                        @Html.DropDownList("FieldsCodingId", null, null, htmlAttributes: new { @class = "form-control" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="ArName" class="col-sm-2 control-label">@MyERP.Properties.Resources.ArName</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.ArName, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.ArName, required = "required" } })

                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="EnName" class="col-sm-2 control-label">@MyERP.Properties.Resources.EnName</label>
                                    <div class="col-sm-4">
                                        @if (isECommerce)
                                        {
                                            @Html.EditorFor(model => model.EnName, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.EnName, required = "required" } })

                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        }
                                        else
                                        {
                                            @Html.EditorFor(model => model.EnName, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.EnName, } })
                                        }
                                    </div>
                                </div>

                                @if (isECommerce)
                                {
                                    <div class="form-group row">
                                        <label for="EnName" class="col-sm-2 control-label">@MyERP.Properties.Resources.KurdishName</label>
                                        <div class="col-sm-4">
                                            @Html.EditorFor(model => model.KrName, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.KurdishName, required = "required" } })

                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>
                                    </div>
                                }

                                <div class="form-group  row">
                                    <label for="TypeId" class="control-label col-sm-2">@MyERP.Properties.Resources.Type</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("TypeId", null, htmlAttributes: new { @class = "form-control" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row" style="display:none;" id="ParentIdDiv">
                                    <label for="ParentId" class="control-label col-sm-2">@MyERP.Properties.Resources.MainGroup</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("ParentItemGroupId", null, htmlAttributes: new { @class = "form-control" /*, disabled = "true" */})
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>

                                @*<div class="form-group row">
            <label for="ParentItemGroupId" class="col-sm-2 control-label">@MyERP.Properties.Resources.MainGroup</label>

            <div class="col-sm-4">
                @Html.DropDownListFor(model => model.ParentItemGroupId, null, @MyERP.Properties.Resources.Select, new { @class = "form-control", id = "ParentItemGroupId" })
            </div>
        </div>*@


                                <div class="form-group row">
                                    <label for="ArName" class="col-sm-2 control-label">@MyERP.Properties.Resources.PrinterName</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.PrinterName, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.PrinterName, required = "required"} })

                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>


                                @if (!isECommerce)
                                {
                                    <div class="form-group row">
                                        <div class="col-sm-2">
                                            <input type="checkbox" id="IsInPos" @Html.Raw(Model != null && Model.IsInPos == true ? "checked" : "") />
                                        </div>
                                        <label for="IsInPos" class="col-sm-4 control-label">@MyERP.Properties.Resources.ShowInPOS</label>
                                    </div>


                                    <div class="form-group row">
                                        <div class="col-sm-2">
                                            <input type="checkbox" id="IsInAllDepartments" @Html.Raw(Model != null && Model.IsInAllDepartments == true ? "checked" : "") />
                                        </div>
                                        <label for="IsInAllDepartments" class="col-sm-4 control-label">@MyERP.Properties.Resources.ShowInAllBranches</label>
                                    </div>
                                }
                                @if (isECommerce)
                                {
                                    <div class="form-group row">
                                        <div class="col-sm-2">
                                            <input type="checkbox" id="ShowInMenu" name="ShowInMenu" @Html.Raw(Model != null && Model.ShowInMenu == true ? "checked" : "") />
                                        </div>
                                        <label for="ShowInMenu" class="col-sm-4 control-label">@MyERP.Properties.Resources.ShowInMenu</label>
                                    </div>

                                    <div class="form-group row">
                                        <div class="col-sm-2">
                                            <input type="checkbox" id="ShowInMainPage" name="ShowInMainPage" @Html.Raw(Model != null && Model.ShowInMainPage == true ? "checked" : "") />
                                        </div>
                                        <label for="ShowInMainPage" class="col-sm-4 control-label">@MyERP.Properties.Resources.ShowInMainPage</label>
                                    </div>
                                }
                                @if (!isECommerce)
                                {
                                    <div class="form-group row">
                                        <div class="col-sm-4">
                                            @Html.DropDownList("DepartmentId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", id = "DepartmentId" })
                                        </div>
                                        <div class="col-sm-2">
                                            <button type="button" class="btn btn-success" onclick=" AddDepartment()" id="btn">@MyERP.Properties.Resources.Add</button>
                                        </div>
                                    </div>
                                }
                                <div class="tab-pane" id="5">
                                    <label for="ArName" class="col-sm-2 control-label">@MyERP.Properties.Resources.Image</label>

                                    <div id="gallery" style="width: 100%;margin: 20px;">

                                        @if (Model != null && Model.Image != null)
                                        {
                                            if (isECommerce == false)
                                            {
                                                <img src="@Model.Image" alt="" class="img_@Model.Id" style="max-width: 200px;max-height: 200px;" />
                                            }
                                            else
                                            {
                                                <img src="@AmazonS3Server/Groups/@Model.Image" alt="" class="img_@Model.Id" style="max-width: 200px;max-height: 200px;" />
                                            }

                                            <i class="fas fa-trash-alt img_@Model.Id" style="cursor:pointer;" onclick="DeleteIMG('@Model.Id');$(this).prev().remove();$(this).remove();"></i>
                                        }

                                    </div>

                                    <input type="file" id="BrowseImage" onchange="previewFile()" value="Browse" @*multiple*@ />

                                    @*<input type="button" id="GetImage" value="GetImage" />*@


                                    @*<div id="UploadImage" style="height:600px;width:600px;">

            </div>*@
                                </div>

                                <!-----------------------Table---------------------->
                                @if (!isECommerce)
                                {
                                    <div class="table-responsive" style="overflow:unset">
                                        <table class="table table-striped table-centered mb-0">
                                            <thead>
                                                <tr>
                                                    <th>
                                                        @MyERP.Properties.Resources.Branch
                                                    </th>

                                                    <th>
                                                        @MyERP.Properties.Resources.Delete
                                                    </th>

                                                </tr>
                                            </thead>
                                            <tbody id="DepartmentsTable">
                                                @if (Model != null)
                                                {
                                                    foreach (var item in Model.ItemGroupDepartments)
                                                    {
                                                        <tr>
                                                            <td hidden><input class="DeptId" value="@item.DepartmentId" /></td>
                                                            <td>
                                                                <label>@item.Department.ArName</label>
                                                            </td>
                                                            <td>
                                                                <button type="button" class="btn btn-danger" onclick="deleteElement(this)">@MyERP.Properties.Resources.Delete</button>
                                                            </td>
                                                        </tr>
                                                    }
                                                }


                                            </tbody>
                                        </table>
                                    </div>
                                }

                                <!-------------------------------------------------->

                                <div class="row">
                                    <div class="col-sm-offset-2">
                                        @if (Model == null)
                                        {
                                            <button type="submit" onclick="addEdit('new')" class="btn btn-success">
                                                @MyERP.Properties.Resources.SaveAndNew
                                            </button>
                                            <button class="btn btn-success" onclick="addEdit()">
                                                @MyERP.Properties.Resources.Save
                                            </button>
                                            <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                                        }
                                        else if (Model.IsDeleted == false)
                                        {
                                            <button class="btn btn-success" onclick="addEdit()">
                                                @MyERP.Properties.Resources.Save
                                            </button>
                                            <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                                        }

                                    </div>
                                </div>


                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>

    function DeleteIMG(url)
    {

        //$("#ItemURLImages option[value='" + url + "']").remove();
        $("#BrowseImage").val('')
        //$("img[src='" + url + "']").remove();
    }

    var data = "";
    function previewFile() {

        var reader = new FileReader();

        reader.addEventListener("load", function () {

            $("#gallery").html('<img style="max-width: 200px;max-height: 200px;margin-left: 2%;margin-bottom: 2%;" src="' + reader.result + '" alt="" /><i class="fas fa-trash-alt" style="cursor:pointer;" onclick="DeleteIMG(\'' + reader.result + '\');$(this).prev().remove();$(this).remove();"></i>');
            $("#Image").val(reader.result);
            data = reader.result;
            console.log(reader.result); // القيمة تمام
            console.log($("#Image").val()); // القيمة undefine
            console.log(data);
        }, false);

        for (var i = 0; i < $("#BrowseImage")[0].files.length; i++) {
            if ($("#BrowseImage")[0].files[i]) {
                reader.readAsDataURL($("#BrowseImage")[0].files[i]);
            }
        }
    }

    //$("#ItemURLImages option").attr('selected', 'selected');
    //$("#ItemURLImages").hide();
    $("#GetImage").click(function () {
        $("#GetImage").fadeOut();
        $('#UploadImage').photobooth().on("image", function (event, dataUrl) {
            $("#gallery").append('<img style="max-width: 200px;max-height: 200px;margin-left: 2%;margin-bottom: 2%;" src="' + dataUrl + '" alt="" /><i class="fa fa-trash-o" style="cursor:pointer;position: absolute;" onclick="DeleteIMG("' + dataUrl + '");;$(this).prev().remove();$(this).remove();"></i>');
            //$("#ItemURLImages").append("<option style='float: left;' selected=selected>" + dataUrl + "</option>");
        });
    });



    function DeleteFunc(id) {
        if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToDelete')) {
            $('#preloader, #status').fadeIn();
            $.ajax(
                {
                    url: '/Slider/Delete',
                    type: 'POST',
                    data: {
                        "Id": id,
                    },
                    error: function (e) {
                        $('#preloader, #status').fadeOut();
                        alert('@MyERP.Properties.Resources.DeleteDoesNotSucceeded'+'!');
                    },
                    success: function (r) {
                        if (r == 'true') {
                            window.location.replace('/Slider');
                        } else
                            alert('@MyERP.Properties.Resources.DeleteDoesNotSucceeded'+'!');
                    }
                });
        }
    }
</script>
<script>
    //--------------- Variables Declarations -------------------//
    let ParentOptions = '';
    //*********************************************************//

    $('#TypeId').on('change', function () {
        if ($('#TypeId').val() != 1) {
            $('#ParentIdDiv').show();
            GetItemByType().then(function () {
                $("#ParentItemGroupId").empty().append(ParentOptions);
            });
        }
        else {
            $('#ParentIdDiv').hide();
            $('#ParentItemGroupId').val(0);
        }
    });

    function GetItemByType() {
        ParentOptions = '';
        $('#ParentId').empty();
        return requestData('/ItemGroups/GetItemByType?TypeId=' + $('#TypeId').val())

            // return requestData('/RoomType/GetRoomByType')
            .done(function (r) {
                for (var i = 0; i < r.length; i++) {
                    ParentOptions += '<option value="' + r[i].Id + '">' + r[i].ArName + '</option>';
                    //$('#ParentId').append($('<option>', {
                    //    value: r[i].Id,
                    //    text: r[i].ArName
                    //}));
                }
            });
    }

    $(document).ready(function () {
        if (!$('#Id').val()) { //add
            $('#IsInAllDepartments').prop("checked", true);
            $('#DepartmentId').attr("disabled", true);
            $('#btn').prop('disabled', true);
        }
        else { //edit
            if ($('#TypeId').val() != 1) {
                $('#ParentIdDiv').show();
            }
            $('#FieldsCodingId').prop('disabled', true);

            if ($('#IsInAllDepartments').prop("checked") == true) {
                $('#DepartmentId').attr("disabled", true);
                $('#btn').prop('disabled', true);
            }
            else if ($('#IsInAllDepartments').prop("checked") == false) {
                $('#DepartmentId').attr("disabled", false);
                $('#btn').prop('disabled', false)
            }
        }
    });

    function addEdit(n) {
        if ($(".form-control:invalid").length > 0) {
            console.log($(".form-control:invalid"));
            $('.form-horizontal').addClass('was-validated');
            $('html, body').animate({
                scrollTop: $(".form-control:invalid").eq(0).offset().top - 100
            }, 500);
        }
        else {
            console.log(data);
            var ItemGroupDepartments = [];
            $('#DepartmentsTable tr').each(function () {
                var td = $(this);
                //   console.log(td);
                var ItemGroupDepartment = {
                    ItemGroupId: $('#Id').val(),
                    DepartmentId: td.find('.DeptId').val()
                };
                ItemGroupDepartments.push(ItemGroupDepartment);
            });

            var ItemGroup =
            {
                Id: $('#Id').val(),
                Code: $('#Code').val(),
                ArName: $('#ArName').val(),
                EnName: $('#EnName').val(),
                KrName: $('#KrName').val(),
                PrinterName: $('#PrinterName').val(),
                IsInAllDepartments: $('#IsInAllDepartments').prop('checked'),
                IsInPos: $('#IsInPos').prop('checked'),
                IsActive: true,
                IsDeleted: false,
                ItemGroupDepartments: ItemGroupDepartments,
                //ParentItemGroupId: $("#ParentItemGroupId").val(),
                Image: data,
                ShowInMenu: $('#ShowInMenu').prop('checked'),
                ShowInMainPage: $('#ShowInMainPage').prop('checked'),
                FieldsCodingId: $('#FieldsCodingId').val(),
                ParentItemGroupId: $('#TypeId').val() == 1 ? null : $('#ParentItemGroupId').val(),
                TypeId: $('#TypeId').val(),
            }

            //if (($('#IsInAllDepartments').prop("checked") == false) && !$('#DepartmentId').val() )
            //{ alert(" اختر الفرع اولا") }
            //else {
            if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToSave'))
                $.ajax({
                    type: "POST",
                    url: "/ItemGroups/AddEdit",
                    data: ItemGroup,
                    success: function (r) {
                        if (r.success == "true") {
                            if (n == "new") {
                                window.location.replace("/ItemGroups/AddEdit");
                            } else {
                                window.location.replace("/ItemGroups");
                            }
                        }
                        else
                            alert('@MyERP.Properties.Resources.NotSaved');
                        $('#preloader, #status').fadeOut();
                    },
                    error: function (r) {
                        $('#preloader, #status').fadeOut();
                        alert('@MyERP.Properties.Resources.NotSaved');
                    }
                });
            // }
        }
    }

    $('#IsInAllDepartments').click(function () {
        if ($(this).prop("checked") == true) {
            $('#DepartmentId').attr("disabled", true);
            $('#btn').prop('disabled', true);
            $('#DepartmentsTable').empty();

        }
        else if ($(this).prop("checked") == false) {
            $('#DepartmentId').attr("disabled", false);
            $('#btn').prop('disabled', false)
        }
    });

    function AddDepartment() {

        if (!$('#DepartmentId').val()) {
            alert('@MyERP.Properties.Resources.SelectTheBranch')
        }
        else {
            let valid = true;
            $('#DepartmentsTable tr').each(function () {
                var td = $(this);
                if ($('#DepartmentId').val() == td.find('.DeptId').val())
                    valid = false;
            });

            if (valid == false)
                alert('@MyERP.Properties.Resources.ThisBranchWasPreviouslyAdded')
            else {
                var deptID = $('#DepartmentId option:selected').val();
                var deptName = $('#DepartmentId option:selected').text();
                $('#DepartmentsTable').append('<tr><td hidden><input class="DeptId" value="' + deptID + '" /></td><td><label>' + deptName + '</label></td><td><button type="button" class="btn btn-danger" onclick="deleteElement(this)">'+'@MyERP.Properties.Resources.Delete'+'</button></td></tr>')

            }
        }
    }

    function deleteElement(e) {
        var tr = $(e).closest('tr');
        e.parentNode.parentNode.parentNode.removeChild(e.parentNode.parentNode);
    }

    $('#FieldsCodingId').on('change', function () {
        if (!$('#Id').val()) {
            setCodeNum();
        }
    });

    function setCodeNum() {
        $.get('/ItemGroups/SetCodeNum?FieldsCodingId=' + $('#FieldsCodingId').val()).done(function (r) {
            $('#Code').val(r);
        });
    }

    if (!$('#Id').val()) {
        setCodeNum();
    }

    function Delete(id) {
        if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToDelete')) {
            $('#preloader, #status').fadeIn();
            $.ajax(
                {
                    url: '/ItemGroups/Delete',
                    type: 'POST',
                    data: {
                        "Id": id,
                    },
                    error: function (e) {

                    },
                    success: function (r) {
                        if (r == 'true') {
                            window.location.replace('/ItemGroups');
                        } else
                            alert('@MyERP.Properties.Resources.DeleteDoesNotSucceeded!');
                        $('#preloader, #status').fadeOut();
                    }
                });
        }
    }

</script>
