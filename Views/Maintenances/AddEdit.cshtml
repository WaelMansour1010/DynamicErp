                                    {
                                        htmlAttributes = new {@class = "form-control" @*, @readonly = "readonly", required = "required"*@}
                                })

                                    @Html.ValidationMessageFor(model => model.PurchaseInvoiceId, "", new { @class = "text-danger" })
                                </div>
                            </div>


                            <div class="form-group">
                                <label class=" col-sm-1 control-label" for="PurchaseDate">تاريخ فاتورة المورد</label>
                                <div class="col-sm-5">
                                    @Html.EditorFor(model => model.PurchaseDate, new { htmlAttributes = new { @class = "form-control", @type = "datetime-local", @required = "required" } })
                                    @Html.ValidationMessageFor(model => model.PurchaseDate, "", new { @class = "text-danger" })
                                </div>
                                <label class=" col-sm-1 control-label" for="InvoiceNumberOfVendor">مسلسل فاتورة المورد</label>
                                <div class="col-sm-5">
                                    @Html.EditorFor(model => model.InvoiceNumberOfVendor, new
                                    {
                                        htmlAttributes = new {@class = "form-control" @*, @readonly = "readonly", required = "required"*@}
                                })

                                    @Html.ValidationMessageFor(model => model.InvoiceNumberOfVendor, "", new { @class = "text-danger" })
                                </div>
                            </div>

                            <div class="form-group">

                                <label class="control-label col-sm-1" for="Notes">ملاحظات</label>
                                <div class="col-sm-5">
                                    <textarea id="Notes" name="Notes" class="form-control" rows="5" cols="5">@if (Model != null)
                                                                                     {
                                                                                         @Model.Notes
                                                                                         ;
                                                                                     }</textarea>

                                    @Html.ValidationMessageFor(model => model.Notes, "", new { @class = "text-danger" })
                                </div>
                            </div>
                            <br />
                            <div class="form-group">


                                <input value="@Model.AttachedFiles" class="col-sm-11" name="AttachedFiles" hidden />


                                <label class="control-label col-sm-3" for="file">إختر مرفق جديد</label>
                                <div class="col-sm-9">
                                    <input type="file" name="upload" class="col-sm-11" />
                                    @Html.ValidationMessageFor(model => model.AttachedFiles, "", new { @class = "text-danger" })
                                </div>
                                @*<div class="col-sm-11">
                                    <input id="AttachedFiles" name="attachment" class="col-sm-11" />*@


                                @*@Html.ValidationMessageFor(model => model.AttachedFiles, "", new { @class = "text-danger" })
                                    </div>*@
                            </div>



                            <input id="new" name="newBtn" hidden />
                            <div class="col-sm-offset-2">
                                @*<div class="col-sm-offset-2">*@
                                @if (Model.Id == 0)
                                {
                                    <button type="submit" id="newbtn" class="btn btn-success">
                                        حفظ و جديد
                                    </button>
                                    <button type="submit" id="save" class="btn btn-success">
                                        حفظ
                                    </button>
                                    <a class="btn btn-danger" href="@Url.Action("Index")" role="button">رجوع</a>
                                }
                                else
                                {
                                    if (Model.IsDeleted == false)
                                    {
                                        <button type="submit" class="btn btn-success">
                                            حفظ
                                        </button>
                                        <a class="btn btn-danger" href="@Url.Action("Index")" role="button">رجوع</a>
                                        <a class="btn btn-danger" onclick="Delete(@Model.Id, 'Maintenances')" role="button">حذف</a>

                                    }
                                }

                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

}

<script>
    function zeroPadded(val) {
        if (val >= 10)
            return val;
        else
            return '0' + val;
    }




    if ($('#hdnobjID').val() > 0) {
        $('#Date').val('@ViewBag.Date');
        $('#SalesInvoiceDate').val('@ViewBag.SalesInvoiceDate');
        $('#PurchaseDate').val('@ViewBag.PurchaseDate');

    } else {
        var d = new Date();
        $('#Date').val(d.getFullYear() + "-" + zeroPadded(d.getMonth() + 1) + "-" + zeroPadded(d.getDate()) + "T" + zeroPadded(d.getHours()) + ":" + zeroPadded(d.getMinutes()));
        $('#SalesInvoiceDate').val(d.getFullYear() + "-" + zeroPadded(d.getMonth() + 1) + "-" + zeroPadded(d.getDate()) + "T" + zeroPadded(d.getHours()) + ":" + zeroPadded(d.getMinutes()));
        $('#PurchaseDate').val(d.getFullYear() + "-" + zeroPadded(d.getMonth() + 1) + "-" + zeroPadded(d.getDate()) + "T" + zeroPadded(d.getHours()) + ":" + zeroPadded(d.getMinutes()));

    }

        $(document).on('change', '#SerialNumber', function () {
            $('#preloader, #status').fadeIn();
            $.get("/Maintenances/Serial?Num=" + $('#SerialNumber').val()).done(function (r) {
                if (r == "error") {
                    alert("هذا الرقم التسلسلى غير موجود");
                }
                $('#CustomerId').val(r.Customer).trigger('change'), $('#VendorId').val(r.Vendor).trigger('change'),
                    $('#SalesInvoiceId').val(r.DocumentNumberSal), $('#PurchaseInvoiceId').val(r.DocumentNumberPur);
                        //$('#SalesPrice').val(r.Price);
                    $('#preloader, #status').fadeOut();





        });

        });


    $(document).on('change', '#DamagedItemsId', function () {
        $('#preloader, #status').fadeIn();
        $.get("/Maintenances/item?Num=" + $('#DamagedItemsId').val()).done(function (r) {
            if (r == "error") {

            }


            $('#SalesPrice').val(r.Price), $('#Barcode').val(r.Barcode);
            $('#preloader, #status').fadeOut();





        });

    });
