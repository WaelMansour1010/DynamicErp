                                    <input type="text" class="money form-control" name="SalesPrice" id="txtSalesPrice" value="@Model.SalesInvoice" />
                                    @Html.ValidationMessageFor(model => model.SalesPrice, "", new { @class = "text-danger" })
                                </div>
                            </div>
                            <div class="form-group">

                                <label for="VendorId" class="control-label col-sm-1">المورد</label>
