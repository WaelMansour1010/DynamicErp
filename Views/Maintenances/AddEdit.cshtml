                                })

                                    @Html.ValidationMessageFor(model => model.Barcode, "", new { @class = "text-danger" })
                                </div>
                            </div>

                            <div class="form-group">
                                <label class=" col-sm-1 control-label" for="SalesPrice">سعر البيع</label>
