@model MyERP.Models.Maintenance

@{
    ViewBag.Title = " الصيانات";
}
@{
    List<SelectListItem> MaintenanceTypeId = new List<SelectListItem>();
    MaintenanceTypeId.Add(new SelectListItem
    {
        Text = "صيانة ضمان",
        Value = "1"
    });
    MaintenanceTypeId.Add(new SelectListItem
    {
        Text = "صيانة",
        Value = "2"

    });
}
<script src="~/Scripts/SaveAndNew.js"></script>
<script src="~/js/DeleteFunctionForAddEditView.js"></script>
@using (Html.BeginForm("AddEdit", "Maintenances", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()
    <div class="panel panel-widget forms-panel">
        <div class="forms">
            <div class=" form-grids form-grids-right">
                <div class="widget-shadow " data-example-id="basic-forms">
                    <div class="form-title">
                        @if (Model.Id > 0)
                        {
                            if (Model.IsDeleted == false)
                            {
                                <a class="btn btn-info" href="@Url.Action("Index")" role="button" style="float: left;">رجوع</a>
                                if (ViewBag.Previous > 0)
                                {
                                    <a href="@Url.Action("AddEdit", new {id = ViewBag.First})" class="btn btn-info" style="height: 33px; float: left; margin-left: 1%">الأول</a>
                                    <a href="@Url.Action("AddEdit", new {id = ViewBag.Previous})" class=" btn btn-info" style="height: 33px; float: left; margin-left: 1%">&#8250;</a>
                                }
                                if (ViewBag.Next > 0)
                                {
                                    <a href="@Url.Action("AddEdit", new {id = ViewBag.Next})" class="btn btn-info" style="height: 33px; float: left; margin-left: 1%">&#8249;</a>
                                    <a href="@Url.Action("AddEdit", new {id = ViewBag.Last})" class="btn btn-info" style="height: 33px; float: left; margin-left: 1%">الأخير</a>
                                }
                            }
                        }
                        else
                        {
                            <a class="btn btn-info" href="@Url.Action("Index")" role="button" style="float: left;">رجوع</a>
                        }
                        <div class="hed">بيانات استلام الصيانات :</div>
                    </div>

                    <div class="form-body">
                        <div class="form-horizontal">
                            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                            <input type="hidden" id="hdnobjID" value="@Model.Id" />

                            @Html.HiddenFor(model => model.IsActive)
                            @*@Html.HiddenFor(model => model.UserId)
                                @Html.HiddenFor(model => model.Image)*@
                            <hr />




                            <div class="form-group">
                                <label for="MaintenanceTypeID" class="control-label col-sm-1">نوع الصيانة</label>
                                <div class="col-sm-5">
                                    @Html.DropDownListFor(model => model.MaintenanceTypeID, MaintenanceTypeId, "-- اختر  النوع --", new { @class = "form-control", id = "type1", @required = "required" })
                                    @Html.ValidationMessageFor(model => model.MaintenanceTypeID, "", new { @class = "text-danger" })


                                    <span class="Asterisks">*</span>
                                </div>
                                <label class=" col-sm-1 control-label" for="SerialNumber">  السريال</label>
                                <div class="col-sm-5">
                                    @Html.EditorFor(model => model.SerialNumber, new
                                    {
                                        htmlAttributes = new {@class = "form-control", placeholder = "السريال" , required = "required"}
                                    })
                                    <span class="Asterisks">*</span>
                                    @Html.ValidationMessageFor(model => model.SerialNumber, "", new { @class = "text-danger" })
                                </div>

                            </div>

                            <div class="form-group">
                                <label class=" col-sm-1 control-label" for="ServicelNumber">امر شغل</label>
                                <div class="col-sm-5">
                                    @Html.EditorFor(model => model.ServicelNumber, new
                                    {
                                        htmlAttributes = new {@class = "form-control", placeholder = "امر شغل" @*, @readonly = "readonly", required = "required"*@}
                                })

                                    @Html.ValidationMessageFor(model => model.ServicelNumber, "", new { @class = "text-danger" })
                                </div>
                                <label for="CustomerId" class="control-label col-sm-1">العميل</label>

                                <div class="col-sm-5">

                                    @Html.DropDownList("CustomerId", null, "اختر العميل", htmlAttributes: new { @class = "form-control", required = "required" })

                                    <span class="Asterisks">*</span>
                                    @Html.ValidationMessageFor(model => model.VendorId, "", new { @class = "text-danger" })
                                </div>
                            </div>


                            <div class="form-group">
                                <br />
                                <label for="Date" class="control-label col-sm-1"> التاريخ</label>
                                <div class="col-sm-5">

                                    @Html.EditorFor(model => model.Date, new { htmlAttributes = new { @class = "form-control", @type = "datetime-local", @required = "required" } })
                                    @Html.ValidationMessageFor(model => model.Date, "", new { @class = "text-danger" })
                                </div>

                            </div>
                            <br />
                            <hr />
                            <div class="panel-widget forms-panel "> <h4>الضمانات</h4></div>
                            <hr />

                            <br />
                            <div class="form-group">
                                <label class=" col-sm-1 control-label" for="ClientProblem">شكوى العميل</label>
                                @* <div class="col-sm-5">
                                    @Html.EditorFor(model => model.ClientProblem, new {htmlAttributes = new {@class = "form-control", @readonly = "readonly", required = "required"}
                                                                    })*@
                                <div class="col-sm-5">
                                    <textarea id="ClientProblem" name="ClientProblem" class="form-control" rows="2" cols="2">@if (Model != null)
                                                                                                     {
                                                                                                         @Model.ClientProblem
                                                                                                         ;
                                                                                                     }</textarea>

                                    @Html.ValidationMessageFor(model => model.ClientProblem, "", new { @class = "text-danger" })
                                </div>

                                <label class=" col-sm-1 control-label" for="Appearance">الفحص الظاهرى</label>
                                <div class="col-sm-5">
                                    @Html.EditorFor(model => model.Appearance, new
                                    {
                                        htmlAttributes = new {@class = "form-control" @*, @readonly = "readonly", required = "required"*@}
                                })

                                    @Html.ValidationMessageFor(model => model.Appearance, "", new { @class = "text-danger" })
                                </div>
                            </div>

                            <div class="form-group">
                                <label for="DamagedItemsId" class="control-label col-sm-1">الصنف التالف</label>

                                <div class="col-sm-5">

                                    @Html.DropDownList("DamagedItemsId", null, "اختر الصنف التالف", htmlAttributes: new { @class = "form-control" })
                                    @Html.ValidationMessageFor(model => model.DamagedItemsId, "", new { @class = "text-danger" })

                                </div>

                                <label for="SalesInvoiceId" class=" col-sm-1 control-label">رقم فاتورة المبيعات</label>
                                <div class="col-sm-5">
                                    @Html.EditorFor(model => model.SalesInvoiceId, new
                                    {
                                        htmlAttributes = new {@class = "form-control" @*, @readonly = "readonly", required = "required"*@}
                                })

                                    @Html.ValidationMessageFor(model => model.Appearance, "", new { @class = "text-danger" })
