<input hidden id="ShiftId" value="@ViewBag.ShiftId" />
<input hidden id="SystemPageId" value="@ViewBag.SystemPageId" />


<script>

    //--------------- Variables Declarations -------------------//
    var taxPercentage = 0.15;
    let items = [];
    let DisplayFactoryPrice = '@ViewBag.DisplayFactoryPrice';
    let customers = [];
    let posCustomers = [];
    let warehouseOptions = '';
    let getDocNum = true;
    let isLinked = false;
    //let SystemPageId=;
    let UniqueSerial = 0;   // unique part added to item id to make it easy to add additional item to it  when this item added many times //
    let newHeight = 315;
    let salesOrderIds = [];
    let custIems = [];

    //*********************************************************//
    //--------------- Ready Function -------------------//
    $(document).ready(function () {
        $('body.enlarged').css('min-height', '0px'); // to prevent Page Scroll
        if (window.location.href.includes('selectedTableId') || window.location.href.includes('selectedTableName') || window.location.href.includes('depId') || window.location.href.includes('selectedcustomerType')) {
            $('#invoiceTypeModal').modal("hide");
            checkCustomerType();
            const urlParams = new URLSearchParams(window.location.search);
            const selectedTableName = urlParams.get('selectedTableName');
            const selectedTableId = urlParams.get('selectedTableId');
            selectTable(selectedTableName, selectedTableId);
        }
        else {
            if ('@ViewBag.showPaymentMethods' == 'True')
                $('#paymentMethodsModal').modal("show");
            else
                $('#paymentMethodsModal').hide();

            if ('@ViewBag.EnableAdditionalItemsOnPos' == 'True')
                $('.EnableAdditionalItemsOnPos').show();
            else
                $('.EnableAdditionalItemsOnPos').hide();

            if ('@ViewBag.NewInvoice' == 'True') {
                if ($('#DepartmentId').val() == 28 && '@ViewBag.ProjectName' == "Genoise") {
                    $('#ShowDepartmentBtn').show();
                }
            }
            // In case of invoice edit
            if ('@ViewBag.SelectedCustomerType' != "") {
                $("#CustomerType").val('@ViewBag.SelectedCustomerType').trigger('change');
            }
            if ('@ViewBag.DepId') {
                $("#DepartmentId").val('@ViewBag.DepId').trigger('change');
            }
            checkCustomerType();
        }
        GetCurrentTaxPercentage();
        getItems();
        $('#cashBoxBalance').inputmask({
            alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, 'allowMinus': true, digitsOptional: false, 'placeholder': '0'
        });

        if (!$('#Id').val()) {
            $('#hasTaxes').trigger('change');
            setDocNum();
            cashBoxByDepartment();
            if ($('#DepartmentId').val() == 28 && '@ViewBag.ProjectName' == "Genoise") {
                //مخزن الجاهز فى جنواز لان البيع بيكون من المخزن ده فقط لو الفاتورة من فرع المصنع
                $('#DepartmentId').trigger('change');
            }
            else {
                getItemGroups();
            }
            appendCustomerOptions(true);
            appendPosCustomerOptions(true);
        }
        else {
            getItemGroups();
            let customerId = $('#VendorOrCustomerId').val();
            appendCustomerOptions(true).then(function () { $('#VendorOrCustomerId').val(customerId).trigger('change') });
            let posCustomerId = $('#PosCustomerId').val();
            appendPosCustomerOptions(true).then(function () { $('#PosCustomerId').val(posCustomerId).trigger('change') });
            $('#Paid').trigger('change')
            //let totalPaied = 0;
            //$('#SalesInvoicePaymentMethods tr').each(function () {
            //    var td = $(this);
            //    totalPaied += td.find('.PaymentAmount').inputmask('unmaskedvalue') * 1;
            //});
            //$('#Paid').val(totalPaied);
            //$('#Remaining').val(($('#Paid').inputmask('unmaskedvalue') * 1 - $('#TotalAfterTaxes').inputmask('unmaskedvalue') * 1).toFixed(2));
        }
        $('#CashBoxId').trigger('change');
        $('#CustomerType').trigger('change');
        if (window.sessionStorage.getItem("UseItemUnit") == 'true') {
            $('.UnitClass').show();
        }
        getGovernorates();
        getCities();
        getAreas();
        $('#SearchText').focus();
        showTime();
        
    });

    //*********************************************************//
    //--------------- Event Functions -------------------//
    // Old code
    $(document).on('change', '#CustomerType', function () {
        if ($("#CustomerType").val() == 2 || $("#CustomerType").val() == 3) {
            $("#PayMethod2").val($("#TotalAfterTaxes").val());
            $("#PayMethod1").val('');
        }
        else if ($("#CustomerType").val() == 1) {
            $("#PayMethod1").val($("#TotalAfterTaxes").val());
            $("#PayMethod2").val('');
        }
        if ($("#CustomerType").val() == 3) {
            // Enable delivery cost input
            $("#DeliveryCost").prop("disabled", false);
            $(".deliveryData").prop("hidden", false);
            //if (WorkWithCommercialPOS == "True") {
            //    $(".drivers").prop("hidden", false);
            //    $(".deliveryInvoicesBtn").prop("hidden", false);
            //    // $("#invoiceTypeBtn").prop("hidden", false);
            //    $("#getSalesOrdersBtn").prop("hidden", false);
            //}
        }
        else {
            $("#DeliveryCost").prop("disabled", true);
            $(".deliveryData").prop("hidden", true);
        }


        appendCustomerOptions(false).then(function () { $('#VendorOrCustomerId').trigger('change') });
        checkCustomerType();
        //$("#TotalAfterTaxes").trigger('change');
    });
    $(document).on('change', '#CashBoxId', function () {
        cashBoxBalance();
    });
    $(document).on('change', '#DepartmentId', function () {
        $("#DepartmentHallsId").empty();
        getItems();

        if ($(this)[0].value == 28 && '@ViewBag.ProjectName' == "Genoise") {
          getItemGroups();
            $('#getSalesOrdersBtn').hide();
            $('#getPurchaseRequestsBtn').show();
            $('#CustomerType').val(4).trigger('change').attr('disabled', 'disabled');
        } else if ('@ViewBag.ProjectName' == "Genoise") {
            getItemGroups();
            $('#getSalesOrdersBtn').show();
            $('#getPurchaseRequestsBtn').hide();
            $('#CustomerType').val() == 4 ? $('#CustomerType').val(1).trigger('change').attr('disabled', 'disabled') : $('#CustomerType').val($('#CustomerType').val()).trigger('change').attr('disabled', 'disabled');
        }
        else {
            $('#getSalesOrdersBtn').hide();
            $('#getPurchaseRequestsBtn').hide();
            $('#CustomerType').val(1).trigger('change').attr('disabled', 'disabled');
        }

        checkCustomerType();

        if ($('#DepartmentId').val()) {
            setWarehouseValues().then(function () {
                $("#WarehouseId").empty().append(warehouseOptions);
                if ($('#DepartmentId').val() == 28 && '@ViewBag.ProjectName' == "Genoise") {
                       //مخزن الجاهز فى جنواز لان البيع بيكون من المخزن ده فقط لو الفاتورة من فرع المصنع
                    $("#WarehouseId").val(9);
                }
            });
            setDocNum();
            cashBoxByDepartment();
        } else {
            $('#DocumentNumber').val('');
            $("#WarehouseId").empty();//.append('<option value>إختر المخزن</option>');;
        }
        if ($(this)[0].value == 28 && DisplayFactoryPrice != 'True' && '@ViewBag.ProjectName' == "Genoise") {
            $('.price, .total').closest('td').hide();
            $('.price-th').hide();
            $('.totals').hide();

        }
        else {
            $('.price, .total').closest('td').show();
            $('.totals').show();
            $('.price-th').show();

        }
        $('.item-unit').trigger('change');


        $('#PointOfSaleDetails tr').each(function () {
            var td = $(this);
            var quantity0;
            if ('@System.Web.Configuration.WebConfigurationManager.AppSettings["ProjectName"]' == "Genoise" && $('#DepartmentId').val() == 28) {
                quantity0 = 0.00;
                }
            else {
               quantity0 = '@ViewBag.DefaultQuantityInPos';
            }
            td.find('.quantity').val(quantity0);
        });
    });
    $(document).on('change', '.item-unit', function () {
        let itemUnitId = $(this).val();
        let item = $(this).closest('tr').find('.item');
        let isFactoryChosen = false;
        if ($('#DepartmentId')[0].value == 28 && '@ViewBag.ProjectName' == "Genoise")
            isFactoryChosen = true;
        getItemUnits(item.val()).done(function (r) {
            let itemUnit = r.filter(function (i) { return i.Id == itemUnitId })[0];
            item.closest('tr').find('.unit-equavalent').val(itemUnit.Equivalent);

            if (item.closest('tr').find('.extra').val() == null) {

                    item.closest('tr').find('.accessoryPrice').val(itemUnit.AccessoryPrice);
                item.closest('tr').find('.price').val(isFactoryChosen ? itemUnit.FactoryPrice : itemUnit.Price);
            }
            item.closest('tr').find('.barcode').val(itemUnit.Barcode);
            item.closest('tr').find('.item-price-id').val(itemUnit.ItemPriceId);
            CalculateTotals();
            $('#Paid').trigger('change');
            $("#TotalAfterTaxes").trigger('change');
        });
    });
    $(document).on('change', '.quantity', function () {
        CalculateTotals();
    });
    $(document).on('keydown', '#pos-customer-mobile', function (e) {
        if (e.which == 13 || e.keyCode == 13) {
            let elem = $(this);
            let mobileNo = elem.val();
            searchPosCustomers(mobileNo);
        }
    });
    $(document).on('change', '.PaymentAmount', function () {
        let totalPaied = 0;
        $('#SalesInvoicePaymentMethods tr').each(function () {
            var td = $(this);
            totalPaied += td.find('.PaymentAmount').inputmask('unmaskedvalue') * 1;
        });
        $('#Paid').val(totalPaied);
        $('#Remaining').val(($('#Paid').inputmask('unmaskedvalue') - $('#TotalAfterTaxes').inputmask('unmaskedvalue')).toFixed(2))
    });
    $(document).on('click', '#posCustomerAddBtn',function () {
        getGovernorates();
        $('#pos-customer-modal').modal("show");
    });
    $(document).on('keyup', '#SearchText', function () {
        let itemNameInput = $(this);
        if (!custIems.length)
            custIems = $.map(items, function (n) {
                return { label: n.ArName, value: n.ItemPriceId };
            });
        $(this).autocomplete({
            source: custIems,
            select: function (event, ui) {
                event.preventDefault();
                $(itemNameInput).val(ui.item.label);
                $(itemNameInput).closest('td').find('.item').val(ui.item.value).trigger('change');
                if (items.length) {
                    let itemPrice = items.filter(function (i) { return i.ItemPriceId === ui.item.value; })[0];
                    let itemid = $(itemPrice).siblings('.item-id').val();
                    let RowId = itemid + UniqueSerial.toString();   // unique part added to item id to make it easy to add additional item to it when this item added many times //
                    if ('@System.Web.Configuration.WebConfigurationManager.AppSettings["ProjectName"]' == "Genoise" && $('#DepartmentId').val() == 28) {
                        itemPrice.Quantity = 0.00;
                }
                else {
                        itemPrice.Quantity = '@ViewBag.DefaultQuantityInPos';
                }
                    let tr ='<tr><td hidden class="RowId">' + RowId + '</td><td hidden class="Main">Main</td>< td hidden class="MainItemId" > ' + itemid + '</td><td style="width:40%" class="tabledit-edit-mode" colspan="1"><input type="hidden" class="item" required value="' + itemPrice.Id + '" /><input type="text" class="item-name form-control tabledit-input form-control-sm" required readonly value="' + itemPrice.ArName + '" /><input type="hidden" class="barcode" required value="' +
                        itemPrice.Barcode + '" /><input type="hidden" class="item-price-id" required value="' + itemPrice.ItemPriceId + '" /></td><td class="tabledit-edit-mode" colspan="1"><input class="money quantity form-control tabledit-input form-control-sm" type="text" min="0" required value="' + itemPrice.Quantity + '" /></td><td class="tabledit-edit-mode UnitClass" style="display:none;" colspan="1"><select class="item-unit form-control tabledit-input form-control-sm" required><option value="' +
                        itemPrice.ItemUnitId + '">' + itemPrice.ItemUnitArName + '</option></select><input class="unit-equavalent" type="hidden" required value="' + itemPrice.Equivalent + '" /></td><td class="tabledit-edit-mode" colspan="1"><input type="text" class="money price form-control tabledit-input form-control-sm" required readonly value="' + itemPrice.Price + '" /><input hidden type="text" class="money accessoryPrice form-control tabledit-input form-control-sm" readonly value="" /></td><td class="tabledit-edit-mode" colspan="1"><input type="text" class="money total form-control tabledit-input form-control-sm" required readonly value="' +itemPrice.Price * itemPrice.Quantity + '" /><input hidden class="itemTotalAccessoryPrice" readonly value="" /></td><td><a href="javascript:void(0);" onclick="deleteElement(this)"><i class="fas fa-trash-alt"></i></a></td><td class="EnableAdditionalItemsOnPos text-center"><a href="javascript:void(0);" onclick="ShowExtra(this)"><i class="fa fa-plus" aria-hidden="true"></i></a></td></tr>'

                    $('#PointOfSaleDetails').append(tr);
                    if (window.sessionStorage.getItem("UseItemUnit") == 'true') {
                        $('.UnitClass').show();
                    }
                }
                $('#SearchText').val('');
                $('#SearchText').focus();
                CalculateTotals();

            },
            minLength: 0,
            focus: function (event, ui) {
                event.preventDefault();
            }
        })
     });
    $(document).on('keydown', '#SearchText', function (e) {
        if (e.which == 13 || e.keyCode == 13) {
            let elem = $(this);
            var barcode = elem.val().includes("-*-") ? elem.val().split("-*-")[1] : elem.val(); //For barcode scanner
            if (items.length) {
                let itemPrice = items.filter(function (i) { return i.Barcode === barcode; })[0];
                let itemid = $(itemPrice).siblings('.item-id').val();
                let RowId = itemid + UniqueSerial.toString();   // unique part added to item id to make it easy to add additional item to it when this item added many times //
                let tr = '<tr><td hidden class="RowId">' + RowId + '</td><td hidden class="Main">Main</td>< td hidden class="MainItemId" > ' + itemid + '</td><td style="width:40%" class="tabledit-edit-mode" colspan="1"><input type="hidden" class="item" required value="' + itemPrice.Id + '" /><input type="text" class="item-name form-control tabledit-input form-control-sm" required readonly value="' + itemPrice.ArName + '" /><input type="hidden" class="barcode" required value="' +
                    itemPrice.Barcode + '" /><input type="hidden" class="item-price-id" required value="' + itemPrice.ItemPriceId + '" /></td><td class="tabledit-edit-mode" colspan="1"><input class="money quantity form-control tabledit-input form-control-sm" type="text" min="0" required value="' + itemPrice.Quantity + '" /></td><td class="tabledit-edit-mode UnitClass" style="display:none;" colspan="1"><select class="item-unit form-control tabledit-input form-control-sm" required><option value="' +
                    itemPrice.ItemUnitId + '">' + itemPrice.ItemUnitArName + '</option></select><input class="unit-equavalent" type="hidden" required value="' + itemPrice.Equivalent + '" /></td><td class="tabledit-edit-mode" colspan="1"><input type="text" class="money price form-control tabledit-input form-control-sm" required readonly value="' + itemPrice.Price + '" /><input hidden type="text" class="money accessoryPrice form-control tabledit-input form-control-sm" readonly value="" /></td><td class="tabledit-edit-mode" colspan="1"><input type="text" class="money total form-control tabledit-input form-control-sm" required readonly value="' + itemPrice.Price * itemPrice.Quantity + '" /><input hidden class="itemTotalAccessoryPrice" readonly value="" /></td><td><a href="javascript:void(0);" onclick="deleteElement(this)"><i class="fas fa-trash-alt"></i></a></td><td class="EnableAdditionalItemsOnPos text-center"><a href="javascript:void(0);" onclick="ShowExtra(this)"><i class="fa fa-plus" aria-hidden="true"></i></a></td></tr>'
                $('#PointOfSaleDetails').append(tr);
                if (window.sessionStorage.getItem("UseItemUnit") == 'true') {
                    $('.UnitClass').show();
                }
                $('#SearchText').val('');
                $('#SearchText').focus();
                CalculateTotals();
            }
        }
    });
    $(document).on('click', '.invoiceInfoBtn', function () {
        $('#invoiceInfoModal').modal("show");
    });
    $(document).on('change', "#TotalAfterTaxes", function () {
        if ($("#CustomerType").val() == 2 || $("#CustomerType").val() == 3) {
            $("#PayMethod2").val($("#TotalAfterTaxes").val());
            $("#PayMethod1").val('');
            $(".PaymentAmount").trigger('change');

        }
        else if ($("#CustomerType").val() == 1) {
            $("#PayMethod1").val($("#TotalAfterTaxes").val());
            $("#PayMethod2").val('');

            $(".PaymentAmount").trigger('change');
        }
    });
    $('#Paid').on('change', function () {
        $('#Remaining').val(($('#Paid').inputmask('unmaskedvalue') - $('#TotalAfterTaxes').inputmask('unmaskedvalue')).toFixed(2));
    });
    $('#VoucherDate').on('change', function () {
        GetCurrentTaxPercentage();
    });
    $('#VendorOrCustomerId').on('change', function () {

        CalculateTotals($('#NetTotal').inputmask('unmaskedvalue') * 1);

        let customer = customers.filter(function (i) { return i.Id == $('#VendorOrCustomerId').val() })[0];
        if (customer) {
            $('#customer-address').val(customer.Address);
            $('#customer-mobile').val(customer.Mobile);
        }
    });
    $('#PosCustomerId').on('change', function () {

        CalculateTotals($('#NetTotal').inputmask('unmaskedvalue') * 1);

        let customer = posCustomers.filter(function (i) { return i.Id == $('#PosCustomerId').val() })[0];
        if (customer) {
            $('#pos-customer-address').text(customer.Address);
            $('#pos-customer-mobile').val(customer.Mobile1);
        }
    });
    $('#customer-modal').on('show.bs.modal', function () {
        $("#ArName, #Address, #Mobile").attr('required', 'required');
    });
    $('#customer-modal').on('hide.bs.modal', function () {
        $("#ArName, #Address, #Mobile").removeAttr('required');
        $("#customer-modal").find(".form-control").val('');
    });

    //*********************************************************//
     //--------------- Other Functions -------------------//
    function getItems() {
        return requestData('/Helper/ItemsByDepId/?departmentId=' + $('#DepartmentId').val()).done(function (r) {
            items = r;
        });
    }
    function PayByVisa() {
        $('#PaymentMethodId').val(4);
    }
    function PayByCash() {
        $('#PaymentMethodId').val(1);
    }
    function getItemGroups() {
        $('#item-groups').empty();
        $.get('/Helper/ItemGroups?pageIndex=1&departmentId=' + $('#DepartmentId').val()).done(function (r) {
            $('#item-groups').append(r);
            $('.nav-link.mb-2').first().trigger('click');
        });
    }
    function getCustomers(refill) {
        if (refill == true)
            requestCache['/Helper/GetCustomers'] = null;
        return requestData('/Helper/GetCustomers').done(function (r) {
            customers = r;
        });
    }
    function getPosCustomers(refill) {
        if (refill == true)
            requestCache['/Helper/GetPosCustomers'] = null;
        return requestData('/Helper/GetPosCustomers').done(function (r) {
            posCustomers = r;
        });
    }
    function GetCurrentTaxPercentage() {
        $.get('/TaxesPercentages/GetCurrentTaxPercentage?date=' + $('#VoucherDate').val()).done(function (r) {
            taxPercentage = r / 100;
            CalculateTotals();
        });

    }
    function appendCustomerOptions(refill) {
        return getCustomers(refill).then(function () {
            let custumerType = $('#CustomerType').val();
            let customerOptions = '';
            let customersfiltered = customers.filter(function (i) {
                if (custumerType == 1 || custumerType == 3)
                    return i.IsBranch != true && i.IncludeFees != true
                else if (custumerType == 2)
                    return i.IncludeFees == true;
                else if (custumerType == 4)
                    return i.IsBranch == true;
            });
            for (var i = 0; i < customersfiltered.length; i++) {
                if (custumerType == 1 || custumerType == 3)
                    customerOptions += '<option value="' + customersfiltered[i].Id + '">' + customersfiltered[i].ArName + ' - ' + customersfiltered[i].Mobile + '</option>';
                else
                    customerOptions += '<option value="' + customersfiltered[i].Id + '">' + customersfiltered[i].ArName + ' - ' + customersfiltered[i].Code + '</option>';
            }
            $('#VendorOrCustomerId').empty().append(customerOptions);
            $('#VendorOrCustomerId').trigger('change');
        });
    }
    function appendPosCustomerOptions(refill) {
        return getPosCustomers(refill).then(function () {
            // let custumerType = $('#CustomerType').val();
            let posCustomerOptions = '';

            for (var i = 0; i < posCustomers.length; i++) {
                posCustomerOptions += '<option value="' + posCustomers[i].Id + '">' + posCustomers[i].ArName + ' - ' + posCustomers[i].Code + '</option>';
            }
            $('#PosCustomerId').empty().append(posCustomerOptions);
            $('#PosCustomerId').trigger('change');
        });
    }
    function setDocNum() {
        if ($('#DepartmentId').val() && getDocNum)
            $.get('/SalesInvoice/SetDocNum?id=' + $('#DepartmentId').val()).done(function (r) {
                $('#DocumentNumber').val(r);
            });
        getDocNum = true;
    }
    function addCustomer() {
        if ($("#customer-modal").find(".form-control:invalid").length > 0) {
