<div class="account-pages mt-5 mb-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6 col-xl-5">
                <div class="card">

                    <div class="card-body p-4">
                        
                        @if (System.Web.Configuration.WebConfigurationManager.AppSettings["ProjectName"] == "Genoise")
                        {<div class="text-center w-75 m-auto">
                                <span>
                                    <img src="~/assets\images\logo-dark.png" alt="" height="80" />
                                </span>
                            </div>
                        }
                        else
                        {
                            <div class="form-group">
                                <img id="Logo" src="@ViewBag.Logo" alt="Logo" style="width: 50%;background-color: #2494be;margin-right: 25%;/*border-radius: 50%;*/">
                            </div>
                        }


                    <form action="/Pos/AddEdit" class="form-horizontal needs-validation" novalidate method="post">
                        <div class="row">
                            <div class="col-12" style="align-content:center">
                                <div class="card" style="margin: auto;">
                                    <div class="card-body">
                                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                                        <h5 class="header-title">
                                            @MyERP.Properties.Resources.OpenPointOfSale
                                        </h5>
                                        <div class="form-group row">
                                            <label class=" col-sm-4 control-label" for="EnName">@MyERP.Properties.Resources.UserName </label>
                                            <div class="col-sm-8">
                                                <input type="text" class="form-control" id="UserName" />
                                            </div>
                                        </div>
                                        <div class="form-group row">
                                            <label class=" col-sm-4 control-label" for="EnName">@MyERP.Properties.Resources.PassWord </label>
                                            <div class="col-sm-8">
                                                <input type="password" class="form-control" id="Password" />
                                            </div>
                                        </div>
                                        <div class="form-group row">
                                            <label for="PosManagerId" class="control-label col-sm-4">@MyERP.Properties.Resources.Shifts</label>
                                            <div class="col-sm-8">
                                                @Html.DropDownList("ShiftId", null, @MyERP.Properties.Resources.Shifts, htmlAttributes: new { @class = "form-control", required = "required" })
                                                <div class="invalid-feedback">
                                                    @MyERP.Properties.Resources.Select
                                                </div>
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-sm-offset-4">
                                                <button type="button" onclick="login()" class="btn btn-success">
                                                    @MyERP.Properties.Resources.OpenPointOfSale
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>

                    </div> <!-- end card-body -->
                </div>
                <!-- end card -->
                <!-- end row -->

            </div> <!-- end col -->
        </div>
        <!-- end row -->
    </div>
    <!-- end container -->
</div>



