<script>

    function login() {
        if (!$('#Password').val()) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.PassWord @MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        }
        else if (!$('#UserName').val()) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.UserName @MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        }
        else if (!$('#ShiftId').val()) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.SelectShift',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        }
        else {
            $('#preloader, #status').fadeIn();
            $.ajax({
                url: '/MiniPointOfSale/MiniPosLogin', contentType: "application/json",
                type: 'POST',
                data: JSON.stringify({
                    Password: $('#Password').val(),
                    UserName: $('#UserName').val(),
                    ShiftId: $('#ShiftId').val()
                }),
                error: function (e) {
                    $('#preloader, #status').fadeOut();
                },
                success: function (r) {
                    if (r == 'PasswordIncorrect') {
                        Swal.fire({
                            title: '@MyERP.Properties.Resources.ThePOSManagerPasswordIsIncorrect',
                            text: " ",
                            icon: 'error',
                            showCancelButton: false,
                            confirmButtonText: '@MyERP.Properties.Resources.Ok',
                            confirmButtonColor: '#3085d6'
                        });
                    }
                    else if (r == 'UserIsNull') {
                        Swal.fire({
                            title: '@MyERP.Properties.Resources.PosManagerHasNoUserName',
                            text: " ",
                            icon: 'error',
                            showCancelButton: false,
                            confirmButtonText: '@MyERP.Properties.Resources.Ok',
                            confirmButtonColor: '#3085d6'
                        });
                    }
                    else {
                        window.location.replace("/MiniPointOfSale/AddEdit?ShiftId=" + r.ShiftId);
                    }
                    $('#preloader, #status').fadeOut();
                }
            });
        }
    }
</script>