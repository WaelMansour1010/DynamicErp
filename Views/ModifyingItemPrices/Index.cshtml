@model IEnumerable<MyERP.Models.GetModifyingItemPrices_Result>

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.ModifyingItemPrices;
}

<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal needs-validation" role="form">
                        <div class="card">
                            <div class="card-body">
                                <h5 class="header-title">
                                    @MyERP.Properties.Resources.ModifyingItemPrices
                                </h5>
                                <div class="form-group row">
                                    <label class=" col-sm-1 control-label" for="Code">@MyERP.Properties.Resources.Group</label>
                                    <div class="col-sm-5">
                                        @Html.DropDownList("ItemGroupId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                        {
                                            @class = "form-control",
                                            required = "required"
                                        })
                                    </div>
                                    <label class=" col-sm-1 control-label" for="Code">@MyERP.Properties.Resources.Category</label>
                                    <div class="col-sm-5">
                                        @Html.DropDownList("ItemCategoryId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                        {
                                            @class = "form-control",
                                            required = "required"
                                        })
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class=" col-sm-1 control-label" for="Code">@MyERP.Properties.Resources.Type</label>
                                    <div class="col-sm-5">
                                        @Html.DropDownList("ItemTypeId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                        {
                                            @class = "form-control",
                                            required = "required"
                                        })
                                    </div>
                                    <label class=" col-sm-1 control-label" for="Code">@MyERP.Properties.Resources.Department</label>
                                    <div class="col-sm-5">
                                        @Html.DropDownList("DepartmentId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                        {
                                            @class = "form-control",
                                            required = "required"
                                        })
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.ModificationMethod </label>
                                    <div class="col-sm-4">
                                        <input type="radio" id="PercentageRadio" name="ModificationMethod" value="1" class="col-sm-2" checked="checked" />@MyERP.Properties.Resources.Percentage
                                        <input type="radio" id="ValueRadio" name="ModificationMethod" value="2" class="col-sm-2" />@MyERP.Properties.Resources.Value
                                    </div>
                                    <div class="col-sm-6 row" id="PercentageDiv">
                                        <label class="control-label col-sm-2">@MyERP.Properties.Resources.Percentage </label>
                                        <div class="col-sm-9">
                                            <input type="text" id="Percentage" class="form-control" />
                                        </div>
                                        <span> % </span>
                                    </div>
                                    <div class="col-sm-6 row" id="ValueDiv" style="display:none;">
                                        <label class="control-label col-sm-2">@MyERP.Properties.Resources.Value </label>
                                        <div class="col-sm-10">
                                            <input type="text" id="Value" class="form-control" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-sm-offset-2">
                    <button class="btn btn-success" onclick="Edit()">
                        @MyERP.Properties.Resources.Edit
                    </button>
                </div>
            </div>
        </div>

    </div>
</div>

<!--------------------------------ShowData Table --------------------------------------->
<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal needs-validation" role="form">
                        <div class="card">
                            <div class="card-body">
                                <h5 class="header-title">
                                    @MyERP.Properties.Resources.ModifyingItemPrices
                                </h5>

                                <div class="table-responsive">
                                    <table class="table table-striped table-centered mb-0">
                                        <thead>
                                            <tr>

                                                <th>
                                                    @MyERP.Properties.Resources.Item
                                                </th>
                                                <th>
                                                    @MyERP.Properties.Resources.Price
                                                </th>

                                            </tr>
                                        </thead>
                                        <tbody id="Items">
                                            @if (Model != null)
                                            {
                                                foreach (var item in Model)
                                                {
                                                    <tr>
                                                        <td>
                                                            <input hidden class="ItemPriceId" value="@item.ItemPriceId" />
                                                            <input hidden class="ItemId" value="@item.ItemId" />
                                                            <label class="ItemName"> @item.ItemName </label>
                                                        </td>
                                                        <td>
                                                            <label class="Price"> @item.Price.Value.ToString("0.00")</label>
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!--***********************************************************************************************-->
<div class="row">
    <div class="col-sm-offset-2">
        <button class="btn btn-success" onclick="Save()">
            @MyERP.Properties.Resources.Save
        </button>
    </div>
</div>
<script>

    function Edit() {
        var link = '/ModifyingItemPrices/Index?DepartmentId=' + $('#DepartmentId').val() + '&ItemTypeId=' + $('#ItemTypeId').val() + '&ItemGroupId=' + $('#ItemGroupId').val() + '&ItemCategoryId=' + $('#ItemCategoryId').val() + '&IsSearch=' + true;
        window.location.replace(link);
    }

    function Save(n) {
        let valid = true;
        if ($("input[name='ModificationMethod']:checked").val() == 2) {
            if (!$('#Value').val()) {
                valid = false;
                Swal.fire({
                    title: '@MyERP.Properties.Resources.Value @MyERP.Properties.Resources.Required',
                    text: " ",
                    icon: 'error',
                    showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    confirmButtonColor: '#3085d6'
                });
            }
        }
        else {
            if (!$('#Percentage').val()) {
                valid = false;
                Swal.fire({
                    title: '@MyERP.Properties.Resources.Percentage @MyERP.Properties.Resources.Required',
                    text: " ",
                    icon: 'error',
                    showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    confirmButtonColor: '#3085d6'
                });
            }
        }

        if (valid == true) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.AreYouSureYouWantToSave',
                text: " ",
                icon: 'info',
                showCancelButton: true,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                cancelButtonText: '@MyERP.Properties.Resources.Cancel',
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    $('#preloader, #status').fadeIn();
                    if ($("input[name='ModificationMethod']:checked").val() == 2) { // value
                        $.get('/ModifyingItemPrices/SaveModifyingItemPrices?DepartmentId = ' + $('#DepartmentId').val() + '&ItemTypeId=' + $('#ItemTypeId').val() + '&ItemGroupId=' + $('#ItemGroupId').val() + '&ItemCategoryId=' + $('#ItemCategoryId').val() + '&IsValue=' + true + '&ValueOrPercentage=' + $('#Value').val()).done(function (r) {
                            if (r.success == true) {
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.Saved',
                                    text: " ",
                                    icon: 'success',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                                window.location.replace("/ModifyingItemPrices");
                                $('#preloader, #status').fadeOut();
                            }
                            else {
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.NotSaved',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                                $('#preloader, #status').fadeOut();
                            }
                        });
                    }
                    else { // percentage
                        $.get('/ModifyingItemPrices/SaveModifyingItemPrices?DepartmentId = ' + $('#DepartmentId').val() + '&ItemTypeId=' + $('#ItemTypeId').val() + '&ItemGroupId=' + $('#ItemGroupId').val() + '&ItemCategoryId=' + $('#ItemCategoryId').val() + '&IsValue=' + false + '&ValueOrPercentage=' + $('#Percentage').val()).done(function (r) {
                            if (r.success == true) {
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.Saved',
                                    text: " ",
                                    icon: 'success',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                                window.location.replace("/ModifyingItemPrices");
                                $('#preloader, #status').fadeOut();
                            }
                            else {
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.NotSaved',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                                $('#preloader, #status').fadeOut();
                            }
                        });
                    }
                }
                else { result.dismiss; }
            });
        }
    }


    $("input[name='ModificationMethod']").on('change', function () {
        if ($("input[name='ModificationMethod']:checked").val() == 1) {
            $("#PercentageDiv").show();
            $("#ValueDiv").hide();
        }
        else {
            $("#ValueDiv").show();
            $("#PercentageDiv").hide();
        }
    });
    $("#Percentage").on('change', function () {
        ChangeByPercentage();
    });

    $("#Value").on('change', function () {
        ChangeByValue();
    });

    function ChangeByPercentage() {
        $('#preloader, #status').fadeIn();
        var Perc = parseFloat($("#Percentage").val())/100;
        $('.Price').each(function () {
            var NewPrice = parseFloat($(this).text()) + (parseFloat($(this).text()) * Perc);
            $(this).text(NewPrice);
        });
        $('#preloader, #status').fadeOut();
        $("#Value").val('');
    }

    function ChangeByValue() {
        $('#preloader, #status').fadeIn();
        var Val = parseFloat($("#Value").val());
        $('.Price').each(function () {
            var NewPrice = parseFloat($(this).text()) + Val;
            $(this).text(NewPrice);
        });
        $('#preloader, #status').fadeOut();
        $("#Percentage").val('');
    }

</script>