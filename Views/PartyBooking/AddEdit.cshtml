@model MyERP.Models.PartyBooking

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.PartyBooking;
}
<script src="~/Scripts/SaveAndNew.js"></script>
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                @if (Model != null)
                {
                    if (Model.IsDeleted == false)
                    {
                        if (ViewBag.Previous > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.First })" class="btn btn-info">@MyERP.Properties.Resources.First</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Previous })" class=" btn btn-info">&#8250;</a>
                        }
                        if (ViewBag.Next > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Next })" class="btn btn-info">&#8249;</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Last })" class="btn btn-info">@MyERP.Properties.Resources.Last</a>
                        }
                        <a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                    }
                }
                else
                {<a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>}
            </div>
            <h4 class="page-title"> @MyERP.Properties.Resources.PartyBooking </h4>
        </div>
    </div>
</div>


<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal needs-validation" role="form">
                        <div class="card">
                            <div class="card-body">
                                @Html.AntiForgeryToken()
                                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                @if (Model != null)
                                {
                                    @Html.HiddenFor(model => model.Id)
                                    @Html.HiddenFor(model => model.UserId)
                                    @Html.HiddenFor(model => model.IsDeleted)
                                    @Html.HiddenFor(model => model.Image)
                                    @Html.HiddenFor(model => model.PaymentMethodId)
                                    @Html.HiddenFor(model => model.OnlinePaymentNo)
                                }
                                <h5 class="header-title">
                                    @MyERP.Properties.Resources.MainData
                                </h5>
                                <div class="form-group row">
                                    <label class=" col-sm-2 control-label" for="Id">@MyERP.Properties.Resources.DocNo</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.DocumentNumber, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly", placeholder = @MyERP.Properties.Resources.DocNo, required = "required" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.BookingDate</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.BookingDate, new { htmlAttributes = new { @class = "form-control", @type = "datetime-local", @required = "required" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.Customers</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownListFor(model => model.CustomerId, null, null, htmlAttributes: new { @class = "form-control", required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.Party</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownListFor(model => model.PartyId, null, null, htmlAttributes: new { @class = "form-control", required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>

                                    <label for="Date" class="col-sm-2 control-label">@MyERP.Properties.Resources.Singer</label>
                                    <div class="col-sm-4">
                                        <input id="Singer" class="form-control" disabled readonly />
                                    </div>
                                </div>

                                <div class="form-group row">
                                    <label for="Date" class="col-sm-2 control-label">@MyERP.Properties.Resources.RemainingChairs</label>
                                    <div class="col-sm-4">
                                        <input id="RemainingChairs" class="form-control" disabled readonly />
                                    </div>

                                    <label for="Date" class="col-sm-2 control-label">@MyERP.Properties.Resources.Date</label>
                                    <div class="col-sm-4">
                                        <input id="Date" class="form-control" type="date" disabled readonly />
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="col-sm-2 control-label" for="From"> @MyERP.Properties.Resources.FromTime </label>
                                    <div class="col-sm-4">
                                        <input id="FromTime" class="form-control" type="time" disabled readonly />
                                    </div>
                                    <label class="col-sm-2 control-label" for="To"> @MyERP.Properties.Resources.ToTime </label>
                                    <div class="col-sm-4">
                                        <input id="ToTime" class="form-control" type="time" disabled readonly />
                                    </div>
                                </div>

                                @*<div class="form-group row">
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.ChairsNo</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.ChairsNo, new { htmlAttributes = new { @class = "form-control", @type = "text", @required = "required" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label for="RoomPrice" class="control-label col-sm-2">@MyERP.Properties.Resources.Price:</label>
                                    <div class="col-sm-4">
                                        <input class="form-control money" type="number" step="any" id="Price" readonly disabled />
                                    </div>
                                </div>*@

                                <div class="form-group row">
                                    <label for="Total" class="control-label col-sm-2">@MyERP.Properties.Resources.Total:</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.Total, new { htmlAttributes = new { @class = "form-control money", type = "text", @readonly = "readonly" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label for="Total" class="control-label col-sm-2">@MyERP.Properties.Resources.Tax:</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.Taxes, new { htmlAttributes = new { @class = "form-control money", type = "text"} })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="Discount" class="control-label col-sm-2">@MyERP.Properties.Resources.TotalAfterTaxes: </label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.TotalAfterTaxes, new { htmlAttributes = new { @class = "form-control money", type = "text"} })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label class="control-label col-sm-2" for="Notes">@MyERP.Properties.Resources.Notes</label>
                                    <div class="col-sm-4">
                                        <textarea id="Notes" name="Notes" class="form-control" rows="5" cols="5">@if (Model != null) { @Model.Notes; }</textarea>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!--------------------- Chairs Reservation --------------------->
            <div class="row">
                <div class="col-12">

                    <div class="card" id="ChairsCard" style="overflow-y:scroll;padding-right:5%;height:50vh;max-height:100vh;">
                        <div class="card-body">
                            <div id="ChairsCardTitle"> </div>
                            <h3 class="header-title">
                                @MyERP.Properties.Resources.Chairs
                            </h3>

                            <div id="ChairsDiv" class="form-group row ">

                            </div>
                        </div>
                    </div>

                </div>

            </div>
        </div>
        <!--------------------- End Of Chairs Reservation --------------------->
        <div class="row">
            <div class="col-sm-offset-2">
                @if (Model == null)
                {
                    <button onclick="addEdit('new');" class="btn btn-success" id="newbtn">
                        @MyERP.Properties.Resources.SaveAndNew
                    </button>
                    <button onclick="addEdit();" class="btn btn-success" id="save">
                        @MyERP.Properties.Resources.Save
                    </button>
                    <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                }
                else if (Model.IsDeleted == false)
                {
                    <button onclick="addEdit();" class="btn btn-success" id="save">
                        @MyERP.Properties.Resources.Save
                    </button>
                    <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                    <a href="javascript:void(0);" class="btn btn-danger" onclick="Delete(@Model.Id)" role="button">@MyERP.Properties.Resources.Delete</a>
                }
            </div>
        </div>
        <!-------------------------------------------------------------------------------------------------------->
    </div>
</div>

<!-------------------------------------------------------------------------------------->
<!-- Modal Section -->
<!------------------------------------------------------------------------------------------------------->

<script>
  
    //--------------- Variables Declarations -------------------//
    var ProjectName = '@Html.Raw(System.Web.Configuration.WebConfigurationManager.AppSettings["ProjectName"])';
    var taxPercentage = 0.14;

    //*********************************************************//
    //--------------- Ready Function -------------------//
    $(document).ready(function () {
        $('#BookingDate').val('@ViewBag.BookingDate');
        $.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
            $("input[type|='datetime-local']").prop('min', r.PeriodStart).prop('max', r.PeriodEnd);
        });
        GetPartyDetails();
        if ($('#Id').val()) {

        }
        else {
            SetDocNum();
        }

    });
    //*********************************************************//
    //--------------- Event Functions -------------------//

    $(document).on('change', "#PartyId", function () {
       GetPartyDetails();
    });

    $("#ChairsDiv").on('change', '.IsChairChecked', function () {
        var Chair = $(this);
        if (Chair.prop('checked') == true) {
            Chair.closest('.reserve').find('.ChairStatusImg').attr('src', '/images/PartyManagement/Party_Seat/Theatre-seat-80_80_Red.png');
            Chair.closest('.reserve').find(".ChairIsReserved").val(true);
        }
        else {
            Chair.closest('.reserve').find('.ChairStatusImg').attr('src', '/images/PartyManagement/Party_Seat/Theatre-seat-80_80_Blue.png');
            Chair.closest('.reserve').find(".ChairIsReserved").val(null);
        }
        CalculateTotalPrice();
    });


    //*********************************************************//
     //--------------- Other Functions -------------------//

    function GetCurrentTaxPercentage() {
        $.get('/TaxesPercentages/GetCurrentTaxPercentage?date=' + $('#RegistrationDate').val()).done(function (r) {
            taxPercentage = r / 100;

        });
    }


    function CalculateTotalPrice() {
        var Price = 0;
        $("#ChairsDiv .reserve").each(function () {
            var _Chair = $(this);
            if (_Chair.find('.IsChairChecked').prop('checked') == true) {
                Price += parseFloat(_Chair.find(".ChairPrice").inputmask('unmaskedvalue'));
            }
            var Total = parseFloat(Price);
            var Taxes = Total * taxPercentage;
            var TotalAfterTaxes = Total + (Total * taxPercentage);
            $('#Total').val(Total.toFixed(2));
            $('#Taxes').val(Taxes.toFixed(2));
            $('#TotalAfterTaxes').val(TotalAfterTaxes.toFixed(2));
        });
    }

    function GetPartyDetails() {
        $.get('/PartyBooking/GetPartyDetails?PartyId=' + $('#PartyId').val() +'&PartyBookingId='+$('#Id').val()).done(function (r) {
            $('#ChairsDiv').empty();
            var Details = r.Details;
            var Chairs = r.Chairs;
            if (Details != null) {
                Details.Date = Details.Date != null ? convertToJavaScriptDate(Details.Date) : null;
                Details.FromTime = Details.FromTime != null ? convertToTime(Details.FromTime) : null;
                Details.ToTime = Details.ToTime != null ? convertToTime(Details.ToTime) : null;

                $('#Date').val(Details.Date);
                $('#FromTime').val(Details.FromTime);
                $('#ToTime').val(Details.ToTime);
                $('#Singer').val(Details.SingerName);
                $('#Price').val(Details.Price);
                $('#RemainingChairs').val(Details.RemainingChairs);
            }

            if (Chairs != null) {
                for (var ii = 0; ii < Chairs.length; ii++) {
                    var imgPath = Chairs[ii].IsReserved == true ? "/images/PartyManagement/Party_Seat/Theatre-seat-80_80_Red.png" : "/images/PartyManagement/Party_Seat/Theatre-seat-80_80_Blue.png";
                    var checked = Chairs[ii].IsReserved == true ? "checked" : "";
                    Chairs[ii].Price = Chairs[ii].Price == null ? 0 : Chairs[ii].Price
                    let div = '<div class="col-sm-2" style="text-align:center;max-width: 10vh;"><div class="form-group reserve" style="text-align:center"><input hidden class="ChairId" value = "' +
                    Chairs[ii].Id + '" /> <input hidden class="ChairIsReserved" value="' +
                    Chairs[ii].IsReserved + '" /><input hidden class="ChairPartyId" value="' +
                    Chairs[ii].PartyId + '" /><input hidden class="ChairPartyBookingId" value="' +
                    Chairs[ii].PartyBookingId + '" /><input hidden class="ChairNo" value = "' +
                    Chairs[ii].ChairNo + '" /><input hidden class="ChairPrice" value="' +
                    Chairs[ii].Price + '" /><input hidden class="ChairNotes" value="' +
                    Chairs[ii].Notes + '" /><img id="ChairStatusImg" class="m-2 img-responsive ChairStatusImg" style="width:5vh;" src="' +
                    imgPath + '" /><div style="text-align:center; font-size:large;">@MyERP.Properties.Resources._Number :' +
                    Chairs[ii].ChairNo + ' </div><div style="text-align:center;"> @MyERP.Properties.Resources.Price : ' +
                        Chairs[ii].Price + ' </div><div style="text-align:center;"><input type = "checkbox" class="IsChairChecked"' + checked+' /></div ></div></div></div>';
                    $('#ChairsDiv').append(div);
                }
            }
        });
    }

    function convertToJavaScriptDate(value) {
        if (value === null)
            return null;
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        var month = (dt.getMonth() + 1) < 10 ? '0' + (dt.getMonth() + 1) : (dt.getMonth() + 1);
        var day = dt.getDate() < 10 ? '0' + dt.getDate() : dt.getDate();
        var hours = dt.getHours();
        var minutes = dt.getMinutes();
        var seconds = dt.getSeconds();
        var ampm = hours >= 12 ? 'PM' : 'AM';
        hours = hours % 12;
        hours = hours ? hours : 12; // the hour '0' should be '12'
        hours = hours < 10 ? '0' + hours : hours;
        minutes = minutes < 10 ? '0' + minutes : minutes;
        seconds = seconds < 10 ? '0' + seconds : seconds;
        var strTime = hours + ':' + minutes /*+ ":" + seconds + ' ' + ampm*/;
        return ((dt.getFullYear() + "-" + month + "-" + day) /*+ "T" + strTime*/);

        //2022 - 01 - 18T20: 23
    }
    function convertToTime(time) {
        if (time === null)
            return null;
        var hours = time.Hours;
        var minutes = time.Minutes;
        var seconds = time.Seconds;
        var ampm = hours >= 12 ? 'PM' : 'AM';
        //hours = hours % 12;
        //hours = hours ? hours : 12; // the hour '0' should be '12'
        hours = hours < 10 ? '0' + hours : hours;
        minutes = minutes < 10 ? '0' + minutes : minutes;
        seconds = seconds < 10 ? '0' + seconds : seconds;
        var strTime = hours + ':' + minutes /*+ ":" + seconds  + ' ' + ampm*/;
        return strTime

        //2022 - 01 - 18T20: 23
    }
    function SetDocNum() {
        var doc = $.get('/PartyBooking/SetDocNum').done(function (r) {
            $('#DocumentNumber').val(r);

        });
    }

    function zeroPadded(val) {
        if (val >= 10)
            return val;
        else
            return '0' + val;
    }
    function deleteElement(e) {
        let tr = $(e).closest('tr');
        if ($(tr).index() == 0 && $(tr).closest('tbody').children('tr').length == 1) {
            $(tr).find("input").val('');
            $(tr).find("label").text('');
            $(tr).find('input, select').removeAttr('required');
            // $(tr).find('select').empty();
            $(tr).find('select').prop('selectedIndex', 0);
            $(tr).find('select').select2();
        }
        else if ($(tr).index() < $(tr).closest('tbody').children('tr').length - 1)
            e.parentNode.parentNode.parentNode.removeChild(e.parentNode.parentNode);
        else if ($(tr).index() == $(tr).closest('tbody').children('tr').length - 1) {
            $(tr).find("input").val('');
            $(tr).find('input, select').removeAttr('required');
           // $(tr).find('select').empty();
            $(tr).find('select').prop('selectedIndex', 0);
            $(tr).find('select').select2();
            $(tr).find("label").text('');
        }
    }


    //*********************************************************//
    function addEdit(n) {
        let valid = true;
        if ($('.form-horizontal').first().find('.form-control:invalid').length > 0) {
            $('.form-horizontal').first().addClass('was-validated');
            $('html, body').animate({
                scrollTop: $('.form-horizontal').first().find(".form-control:invalid").eq(0).offset().top - 100
            }, 500);
            valid = false;
            console.log($(".form-control:invalid"));
        }
        if ($('#RemainingChairs').val() == 0) {
            valid = false;
            Swal.fire({
                title: '@MyERP.Properties.Resources.AllChairsAreReserved !',
                text: " ",
                icon: 'error',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        }
        var Chairs = [];
        $("#ChairsDiv .reserve").each(function () {
            var _Chair = $(this);
            var Chair = {
                Id: _Chair.find(".ChairId").val(),
                IsReserved: _Chair.find(".IsChairChecked").prop('checked'),
                PartyId: _Chair.find(".ChairPartyId").val(),
               // PartyBookingId: _Chair.find('.IsChairChecked').prop('checked') == true ? $("#Id").val(): _Chair.find(".ChairPartyBookingId").val(),
                PartyBookingId: $("#Id").val(),
                Price: _Chair.find(".ChairPrice").val(),
                Notes: _Chair.find(".ChairNotes").val(),
            }
           // if (_Chair.find('.IsChairChecked').prop('checked') == true) {
                Chairs.push(Chair);
            //}
        });

        var PartyBooking = {
            Id: $('#Id').val(),
            DocumentNumber: $('#DocumentNumber').val(),
            BookingDate: $('#BookingDate').val(),
            PartyId: $('#PartyId').val(),
            Total: $('#Total').inputmask('unmaskedvalue'),
            Taxes: $('#Taxes').inputmask('unmaskedvalue'),
            TotalAfterTaxes: $('#TotalAfterTaxes').inputmask('unmaskedvalue'),
            ChairsNo: $('#ChairsNo').val(),
            UserId: $('#UserId').val(),
            IsDeleted: $('#IsDeleted').val(),
            Notes: $('#Notes').val(),
            Image: $('#Image').val(),
            CustomerId: $('#CustomerId').val(),
            PaymentMethodId: $('#PaymentMethodId').val(),
            OnlinePaymentNo: $('#OnlinePaymentNo').val(),
            ChairPrice: $('#ChairPrice').val(),
            Chairs: Chairs,
        }

        if (valid) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.AreYouSureYouWantToSave',
                text: " ",
                icon: 'info',
                showCancelButton: true,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                cancelButtonText: '@MyERP.Properties.Resources.Cancel',
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    $('#preloader, #status').fadeIn();
                    $('#newbtn').prop('disabled', true);
                    $('#save').prop('disabled', true);
                    $.ajax({
                        type: "POST", contentType: "application/json",
                        url: "/PartyBooking/AddEdit",
                        data: JSON.stringify(PartyBooking),
                        success: function (r) {
                            if (r.success == true) {
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.Saved',
                                    text: " ",
                                    icon: 'success',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                }); if (n == "new") {
                                    window.location.replace("/PartyBooking/AddEdit");
                                } else {
                                    window.location.replace("/PartyBooking");
                                }
                            }
                            else {
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.NotSaved !',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                            }
                            $('#preloader, #status').fadeOut();
                            $('#newbtn').prop('disabled', false);
                            $('#save').prop('disabled', false);
                        },
                        error: function (r) {
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.NotSaved !',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                            $('#preloader, #status').fadeOut();
                            $('#newbtn').prop('disabled', false);
                            $('#save').prop('disabled', false);
                        }
                    });
                }
                else { result.dismiss; }
            });
        }
    }

    function Delete(id) {
        Swal.fire({
            title: '@MyERP.Properties.Resources.AreYouSureYouWantToDelete',
            text: " ",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: '@MyERP.Properties.Resources.Ok',
            cancelButtonText: '@MyERP.Properties.Resources.Cancel',
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                $('#preloader, #status').fadeIn();
                $.ajax(
                    {
                        url: '/PartyBooking/Delete',
                        type: 'POST',
                        data: {
                            "Id": id,
                        },
                        error: function (e) {
                            $('#preloader, #status').fadeOut();
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.DeleteDoesNotSucceeded',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                        },
                        success: function (r) {
                            if (r == 'true') {
                                window.location.replace('/PartyBooking');
                            } else
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.DeleteDoesNotSucceeded',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                        }
                    });
            }
            else { result.dismiss; }
        });
    }

</script>
