@model MyERP.Models.PosReceiptVoucher

@{
    UICulture = Session["lang"] != null?Session["lang"].ToString():"ar";

    ViewBag.Title = MyERP.Properties.Resources.PosReceiptVoucher;

}
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                @if (Model != null)
                {
                    if (Model.IsDeleted == false)
                    {
                        if (ViewBag.Previous > 0)
                        {
                <a href="@Url.Action("AddEdit", new { id = ViewBag.First })" class="btn btn-info">@MyERP.Properties.Resources.First</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Previous })" class=" btn btn-info">&#8250;</a>
                        }
                        if (ViewBag.Next > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Next })" class="btn btn-info">&#8249;</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Last })" class="btn btn-info">@MyERP.Properties.Resources.Last</a>
                        }
                    }
                }
            <a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
            </div>
            <h4 class="page-title">@MyERP.Properties.Resources.PosReceiptVoucher :</h4>
        </div>
    </div>
</div>
@if (Model != null)
{
    if (Model.Id > 0)
    {
        @Html.HiddenFor(model => model.Id)
    }
    @Html.HiddenFor(model => model.IsActive)
    @Html.HiddenFor(model => model.UserId)
    @Html.HiddenFor(model => model.IsLinked)
    @Html.HiddenFor(model => model.IsPosted)
    @Html.HiddenFor(model => model.IsDeleted)


}

<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal needs-validation" role="form">

                        <div class="card">
                            <div class="card-body">
                                <h5 class="header-title">
                                    @MyERP.Properties.Resources.MainData
                                </h5>
                                <div class="form-group row">
                                    <label class=" col-sm-1 control-label" for="DocumentNumber">@MyERP.Properties.Resources.DocNo</label>
                                    <div class="col-sm-5">
                                        @Html.EditorFor(model => model.DocumentNumber, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly", placeholder = @MyERP.Properties.Resources.DocNo, required = "required", hidden = "hidden" } })
                                        <input id="DocumentNumbers" class="form-control" placeholder=@MyERP.Properties.Resources.DocNo required readonly />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>

                                    <label for="Date" class="control-label col-sm-1">@MyERP.Properties.Resources.DocumentDate</label>
                                    <div class="col-sm-5">
                                        <input id="Date" name="Date" class="form-control" type="datetime-local" value="@ViewBag.Date" required />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.EnterDate
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="DepartmentId" class="col-sm-1 control-label">@MyERP.Properties.Resources.Branch</label>
                                    <div class="col-sm-5">
                                        @Html.DropDownList("DepartmentId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", @required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Select
                                        </div>
                                    </div>
                                    <label for="CashierUserId" class="control-label col-sm-1">@MyERP.Properties.Resources.Cashier</label>
                                    <div class="col-sm-5">
                                        @Html.DropDownList("CashierUserId", null, @MyERP.Properties.Resources.All, htmlAttributes: new { @class = "form-control", required = "required" })

                                    </div>

                                </div>
                                <div class="form-group row">
                                    <label for="AccountantCashBoxId" class="control-label col-sm-1">@MyERP.Properties.Resources.AccountantCashBox</label>
                                    <div class="col-sm-5">
                                        @Html.DropDownList("AccountantCashBoxId", null, @MyERP.Properties.Resources.AccountantCashBox, htmlAttributes: new { @class = "form-control", required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Select
                                        </div>
                                    </div>
                                    <label for="ShiftId" class="control-label col-sm-1">@MyERP.Properties.Resources.Shift </label>
                                    <div class="col-sm-5">
                                        @Html.DropDownList("ShiftId", null, @MyERP.Properties.Resources.All, htmlAttributes: new { @class = "form-control", required = "required" })

                                    </div>

                                </div>
                                <div class="form-group row">

                                    <label for="Date" class="control-label col-sm-1">@MyERP.Properties.Resources.FromDate </label>
                                    <div class="col-sm-5">
                                        <input id="DateFrom" name="DateFrom" class="form-control" type="datetime-local" value="@ViewBag.DateFrom" required />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.EnterDate
                                        </div>
                                    </div>

                                    <label for="Date" class="control-label col-sm-1">@MyERP.Properties.Resources.ToDate </label>
                                    <div class="col-sm-5">
                                        <input id="DateTo" name="DateTo" class="form-control" type="datetime-local" value="@ViewBag.DateTo" required />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.EnterDate
                                        </div>
                                    </div>


                                </div>

                                <div class="form-group row">

                                    <label class="control-label col-sm-1" for="Notes">@MyERP.Properties.Resources.Notes</label>
                                    <div class="col-sm-5">
                                        <textarea id="Notes" name="Notes" class="form-control" rows="5" cols="5">@if (Model != null) { @Model.Notes; }</textarea>

                                    </div>
                                </div>
                                @*<div class="form-group row">
                                <button class="btn btn-success" onclick="getDetails()" @Html.Raw(Model != null? "disabled" : "")>
                                    عرض
                                </button>
                            </div>*@

                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="header-title">@MyERP.Properties.Resources.Details</h5>
                            <div class="form-horizontal needs-validation" role="form">
                                <div class="table-responsive">
                                    <table class="table table-centered mb-0">
                                        <thead>
                                            <tr>

                                                <th>@MyERP.Properties.Resources.PaymentMethod</th>
                                                <th>@MyERP.Properties.Resources.Sales </th>
                                                <th>@MyERP.Properties.Resources.Returns</th>
                                                <th>@MyERP.Properties.Resources.Expenses</th>
                                                <th>@MyERP.Properties.Resources.NetSales</th>
                                                <th>@MyERP.Properties.Resources.CurrentReservations</th>
                                                <th>@MyERP.Properties.Resources.CommissionRate</th>
                                                <th>@MyERP.Properties.Resources.CommissionValue</th>
                                                <th>@MyERP.Properties.Resources.Net</th>
                                                <th>@MyERP.Properties.Resources.Cashier</th>
                                                <th>@MyERP.Properties.Resources.AmountCollected</th>


                                            </tr>
                                        </thead>
                                        <tbody id="PosReceiptVoucherDetails">
                                            @if (Model != null)
                                            {
                                                foreach (var item in Model.PosReceiptVoucherDetails)
                                                {
                                                    <tr>

                                                        <td class="tabledit-edit-mode">
                                                            <input type="hidden" class="PaymentMethodId form-control tabledit-input form-control-sm" value="@item.PaymentMethodId" required />
                                                            @item.PaymentMethod.ArName
                                                        </td>
                                                        <td class="TotalSales ">
                                                            @string.Format("{0:0.00}", item.SalesAmount)

                                                        </td>
                                                        <td class="TotalReturn ">
                                                            @String.Format("{0:0.00}", item.ReturnAmount)
                                                        </td>
                                                        <td class="CashIssue">
                                                            @String.Format("{0:0.00}", item.CashIssueVoucherAmount)
                                                        </td>
                                                        <td class="Net ">
                                                            @String.Format("{0:0.00}", item.SalesAmount - item.ReturnAmount - item.CashIssueVoucherAmount)
                                                        </td>
                                                        <td class="ReservationsAmount ">
                                                            @String.Format("{0:0.00}", item.ReservationsAmount)
                                                        </td>
                                                        <td class="CommissionPercentage">
                                                            @item.CommissionPercentage
                                                        </td>
                                                        <td class="CommissionAmount ">
                                                            @String.Format("{0:0.00}", item.CommissionAmount)
                                                        </td>
                                                        <td class="NetSales ">
                                                            @String.Format("{0:0.00}", item.NetSales)
                                                        </td>
                                                        <td class="tabledit-edit-mode">
                                                            @if (Model != null && item.CashierUserId != null)
                                                            {
                                                                <input type="hidden" class="CashierUserId form-control tabledit-input form-control-sm" value="@item.CashierUserId" required />
                                                               @item.ERPUser.UserName
                                                            }
                                                        </td>
                                                        <td class="tabledit-edit-mode">
                                                            <input class="CollectedAmount form-control tabledit-input form-control-sm" type="number" step="any" value="@item.CollectedAmount" @Html.Raw(item.PaymentMethodId == 1 ? "required" : "readonly") />
                                                        </td>
                                                    </tr>
                                                }
                                            }

                                        </tbody>
                                    </table>
                                </div>


                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="header-title">@MyERP.Properties.Resources.CustomerType </h5>
                            <div class="form-horizontal needs-validation" role="form">
                                <div class="table-responsive">
                                    <table class="table table-centered mb-0">
                                        <thead>
                                            <tr>

                                                <th>@MyERP.Properties.Resources.CustomerType</th>
                                                <th>@MyERP.Properties.Resources.Total </th>
                                            </tr>
                                        </thead>
                                        <tbody id="PosReceiptVoucherCustomerTypes">
                                            @if (Model != null)
                                            {
                                                foreach (var item in Model.PosReceiptVoucherCustomerTypes)
                                                {
                                                    <tr>
                                                        <td class="tabledit-edit-mode">
                                                            <input type="hidden" class="CustomerTypeId" value="@item.CustomerTypeId" required />
                                                            <label class="control-label CustomerTypeName">@item.CustomerType.ArName</label>
                                                        </td>
                                                        <td>
                                                            <input type="number" step="any" class="Amount form-control col-sm-2" value="@item.Amount" required readonly disabled/>
                                                        </td>
                                                    </tr>
                                                }
                                            }

                                        </tbody>
                                    </table>
                                </div>


                            </div>
                        </div>
                    </div>
                </div>
            </div>



            <div class="row">
                <div class="col-sm-offset-2">
                    @if (Model == null)
                    {


                        @*<button type="submit" onclick="addEdit('new')" class="btn btn-success">
                        حفظ و جديد
                    </button>*@
                        <button class="btn btn-success" onclick="addEdit()" id="save">
                            @MyERP.Properties.Resources.Save
                        </button>
                        @*<a class="btn btn-danger" href="@Url.Action("Index")" role="button">رجوع</a>*@
                    }
                    else if (Model.IsDeleted == false || Model.IsPosted == true)
                    {
                        <button class="btn btn-success" onclick="addEdit()" id="save">
                            @MyERP.Properties.Resources.Save
                        </button>
                        <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
@if (Model != null && ViewBag.Journal != null)
{
    <div class="card">
        <div class="card-body">
            <h5 class="header-title">@MyERP.Properties.Resources.JournalEntrie</h5>
            <div class="form-horizontal">
                <div class="form-group row">
                    <label for="JournalDocNo" class="col-sm-1 control-label">@MyERP.Properties.Resources.JournalEntrieNo</label>
                    <div class="col-sm-5">
                        <input type="text" class="form-control" name="JournalDocNo" value="@ViewBag.Journal.DocumentNumber" id="JournalDocNo" placeholder=@MyERP.Properties.Resources.JournalEntrieNo readonly>

                    </div>
                    <label for="JournalDate" class="col-sm-1 control-label">@MyERP.Properties.Resources.Date </label>
                    <div class="col-sm-5">
                        <input type="datetime-local" class="form-control" name="JournalDate" value="@ViewBag.Date" id="JournalDate" placeholder=@MyERP.Properties.Resources.ReleaseDate readonly>

                    </div>
                </div>
                <div class="form-group row">
                    <label for="JournalNotes" class="col-sm-1 control-label">@MyERP.Properties.Resources.Notes</label>
                    <div class="col-sm-5">
                        <textarea class="form-control" id="JournalNotes" value="@ViewBag.Journal.Notes" readonly name="JournalNotes" placeholder=@MyERP.Properties.Resources.Notes></textarea>
                    </div>

                    <label for="JournalIsPosted" class="col-sm-1 control-label">@MyERP.Properties.Resources.Deported</label>
                    <div class="col-sm-5">
                        <input type="checkbox" id="JournalIsPosted" name="JournalIsPosted" disabled @Html.Raw(Model.IsPosted == true ? "checked" : null)>

                    </div>
                </div>
                <div class="card">
                    <div class="card-body">
                        <h5 class="header-title"> @MyERP.Properties.Resources.JournalEntryDetails</h5>
                        <div class="table-responsive">
                            <table class="table table-centered mb-0">
                                <thead>
                                    <tr>
                                        <th>@MyERP.Properties.Resources.Debit</th>
                                        <th>@MyERP.Properties.Resources.Credit</th>
                                        <th>@MyERP.Properties.Resources.Account</th>
                                        <th>@MyERP.Properties.Resources.Explanation</th>
                                        <th>@MyERP.Properties.Resources.CostCenter</th>
                                    </tr>
                                </thead>
                                <tbody id="JournalEntryDetails-tbody">
                                    @foreach (var item in ViewBag.Journal.JournalEntryDetails)
                                    {
                                        if (item.Debit > 0 || item.Credit > 0)
                                        {
                                            <tr>
                                                <td> @String.Format("{0:0.00}", item.Debit) @*@item.Debit*@</td>
                                                <td> @String.Format("{0:0.00}", item.Credit) @*@item.Credit*@</td>
                                                <td>
                                                    @Html.Raw(item.ChartOfAccount != null ? item.ChartOfAccount.ArName : null)
                                                    <input type="hidden" class="JournalAccountId" value="@item.AccountId" />
                                                </td>
                                                <td>@item.Notes</td>
                                                <td>
                                                    @Html.Raw(item.CostCenter != null ? item.CostCenter.ArName : null)
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@if (Model != null && ViewBag.CashTransferJournal != null)
{
    <div class="card">
        <div class="card-body">
            <h5 class="header-title">@MyERP.Properties.Resources.CashTransferEntry</h5>
            <div class="form-horizontal">
                
                <div class="card">
                    <div class="card-body">
                       
                        <div class="table-responsive">
                            <table class="table table-centered mb-0">
                                <thead>
                                    <tr>
                                        <th>@MyERP.Properties.Resources.Debit</th>
                                        <th>@MyERP.Properties.Resources.Credit</th>
                                        <th>@MyERP.Properties.Resources.Account</th>
                                        <th>@MyERP.Properties.Resources.Explanation</th>
                                        <th>@MyERP.Properties.Resources.CostCenter</th>
                                    </tr>
                                </thead>
                                <tbody id="CashTransferJournal-tbody">
                                    @foreach (var item in ViewBag.CashTransferJournal)
                                    {
                                        if (item.Debit > 0 || item.Credit > 0)
                                        {
                                            <tr>
                                                <td>@item.Debit</td>
                                                <td>@item.Credit</td>
                                                <td>
                                                    @Html.Raw(item.ChartOfAccount != null ? item.ChartOfAccount.ArName : null)
                                                    <input type="hidden" class="JournalAccountId" value="@item.AccountId" />
                                                </td>
                                                <td>@item.Notes</td>
                                                <td>
                                                    @Html.Raw(item.CostCenter != null ? item.CostCenter.ArName : null)
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}


<script>
    //--------------- Variables Declarations -------------------//
    var taxPercentage = 0.14;
    let warehouseOptions = '';
    let items = [];
    let custIems = [];
    let itemsOptionString = '';
    let includeFees = false;
    //*********************************************************//
    //--------------- Ready Function -------------------//
    $(document).ready(function () {
        $.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
            $("input[type|='datetime-local']").prop('min', r.PeriodStart).prop('max', r.PeriodEnd);
        });
        if ($('#Id').val()) {
            var code = $('#DocumentNumber').val();
            $('#DocumentNumbers').val(code.replaceAll("-", ""))
            $("#Date").prop('disabled', true);

            $('#DepartmentId').prop('disabled', 'disabled');
            $('#CashierUserId').prop('disabled', 'disabled');
            $('#ShiftId').prop('disabled', 'disabled');
            $('#DateFrom').prop('disabled', 'disabled');
            $('#DateTo').prop('disabled', 'disabled');
           // GetTotalsForEachInvoiceType();
        } else {
            setDocNum();
            $('#NetCashAmount').val(document.getElementById("PosReceiptVoucherDetails").rows[0].cells[3].innerHTML);

        }
    });
    //*********************************************************//
    //--------------- Event Functions -------------------//
    $(document).on('change', '#DepartmentId', function () {
        if ($('#DepartmentId').val()) {
            setDocNum();
            cashBoxByDepartment();
            getDetails();
            GetTotalsForEachInvoiceType();
        }
    });
    $(document).on('change', '#ShiftId', function () {
        getDetails();
        GetTotalsForEachInvoiceType();
    });
    $(document).on('change', '#CashierUserId', function () {
        getDetails();
        GetTotalsForEachInvoiceType();
    });
    $(document).on('change', '#DateFrom', function () {
        getDetails();
        GetTotalsForEachInvoiceType();
    });
    $(document).on('change', '#DateTo', function () {
        getDetails();
        GetTotalsForEachInvoiceType();
    });
    $(document).on('change', '#Date', function () {
        setDocNum();
    });
    //*********************************************************//
     //--------------- Other Functions -------------------//
    function cashBoxByDepartment() {
        $.get('/Helper/CashBoxByDepartment/' + $('#DepartmentId').val()).done(function (r) {
            $('#AccountantCashBoxId').empty();
            for (var i = 0; i < r.length; i++) {
                $('#AccountantCashBoxId').append($('<option>', {
                    value: r[i].Id,
                    text: r[i].ArName
                }));
            }
        });
    }
    function setDocNum() {
        if ($('#DepartmentId').val())
            $.get('/PosReceiptVoucher/SetDocNum?id=' + $('#DepartmentId').val() + '&VoucherDate=' + $('#Date').val()).done(function (r) {
                $('#DocumentNumber').val(r);
                $('#DocumentNumbers').val(r.replaceAll("-", ""));
            });
    }
    function ToJavaScriptDate(value) {
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        return dt.getFullYear() + "-" + zeroPadded((dt.getMonth() + 1)) + "-" + zeroPadded(dt.getDate());
    }
    function GetTotalsForEachInvoiceType() {
        $('#preloader, #status').fadeIn();
        $.get('/Helper/GetTotalsForEachInvoiceType?DepartmentId=' + $('#DepartmentId').val() + '&DateFrom=' + $('#DateFrom').val() + '&DateTo=' + $('#DateTo').val() + '&ShiftId=' + $('#ShiftId').val() + '&CashierUserId=' + $('#CashierUserId').val()).done(function (r) {
            console.log("Result : ", r);
            $('#PosReceiptVoucherCustomerTypes').empty();
            for (var i = 0; i < r.length; i++) {
                let tr = '<tr><td class="tabledit-edit-mode"><input type="hidden" class="CustomerTypeId" value="' +
                    r[i].CustomerTypeId + '" required /><label class="control-label CustomerTypeName">' +
                    r[i].CustomerTypeName + '</label></td><td><input type="number" step="any" class="Amount form-control col-sm-2" value="' +
                    r[i].TotalAfterTaxes + '" required readonly disabled/></td></tr> ';
                $('#PosReceiptVoucherCustomerTypes').append(tr);
            }
        });
        $('#preloader, #status').fadeOut();

    }

    function getDetails() {
        $('#preloader, #status').fadeIn();
        var details = $.get("/PosReceiptVoucher/GetDetails?DateFrom=" + $('#DateFrom').val() + "&DateTo=" + $('#DateTo').val() + "&cashierUserId=" + $('#CashierUserId').val() + '&DepartmentId=' + $('#DepartmentId').val() + '&ShiftId=' + $('#ShiftId').val())
            .done(function () {
                $('#PosReceiptVoucherDetails').html('');
                newHTML = '';
                details = details.responseJSON;
                for (var i = 0; i < details.length; i++) {
                    newHTML += '<tr>' +
                        '<td hidden ><input hidden class="PaymentMethodId" value="' + (details[i].Id) + '"/></td>' +
                        '<td>' + (details[i].ArName) + '</td>' +
                        '<td class="TotalSales ">' + (details[i].TotalSales) + '</td>' +
                        '<td class="TotalReturn ">' + (details[i].TotalReturn) + '</td>' +
                        '<td class="CashIssue">' + (details[i].TotalCashIssueVoucher) + '</td>' +
                        '<td class="Net ">' + (details[i].TotalSales - details[i].TotalReturn - details[i].TotalCashIssueVoucher) + '</td>' +
                        '<td class="ReservationsAmount ">' + (details[i].TotalReservations) + '</td>' +
                        '<td class="CommissionPercentage">' + (details[i].Commission / 100) + '</td>' +
                        '<td class="CommissionAmount ">' + ((details[i].TotalSales - details[i].TotalReturn + details[i].TotalReservations) * (details[i].Commission / 100)) + '</td>' +
                        '<td class="NetSales ">' + ((details[i].TotalSales - details[i].TotalReturn + details[i].TotalReservations) - (details[i].TotalCashIssueVoucher) - ((details[i].TotalSales - details[i].TotalReturn + details[i].TotalReservations) * (details[i].Commission / 100))) + '</td>' +
                        '<td>' + (details[i].Cashier) + '</td>' +
                        '<td hidden ><input hidden class="CashierUserId" value="' + (details[i].CashierUserId) + '"/></td>' +
                        '<td ><input type="number" step="any" class="CollectedAmount money form-control tabledit-input form-control-sm"  /></td>' +
                        '</tr>';
                }
                $('#PosReceiptVoucherDetails').append(newHTML);
                $('#PosReceiptVoucherDetails tr').each(function () {
                    var td = $(this);

                    if (td.find('.PaymentMethodId').val() > 1) {
                        td.find('.CollectedAmount').val(td.find('.NetSales').text());
                        td.find('.CollectedAmount').attr('readonly', 'readonly');
                    }

                });
              //  $('.table td, .table th').css("min-width", "0vh");
                $('#preloader, #status').fadeOut();
            }).fail(function () {
                $('#preloader, #status').fadeOut();
            });
    }
    function addEdit(n) {
        let valid = true;
        if (!$('#DepartmentId').val()) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.SelectTheBranch',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
            valid = false;
        }
        else if (!$('#AccountantCashBoxId').val()) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.SelectAccountantCashBox',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
            valid = false;
        }
        //else if (!$('#CashierUserId').val()) {
        //    alert('قم بإختيار الكاشير');
        //    valid = false;
        //}

        if (valid) {
            var PosReceiptVoucherDetails = [];
            $('#PosReceiptVoucherDetails tr').each(function () {
                var td = $(this);
                var PosReceiptVoucherDetail = {
                    MainDocId: $('#Id').val(),
                    PaymentMethodId: td.find('.PaymentMethodId').val(),
                    SalesAmount: td.find('.TotalSales').text(),
                    CashIssueVoucherAmount: td.find('.CashIssue').text(),
                    ReturnAmount: td.find('.TotalReturn').text(),
                    CommissionPercentage: td.find('.CommissionPercentage').text(),
                    CommissionAmount: td.find('.CommissionAmount').text(),
                    NetSales: td.find('.NetSales').text(),
                    ReservationsAmount: td.find('.ReservationsAmount').text(),
                    CollectedAmount: td.find('.CollectedAmount').inputmask('unmaskedvalue'),
                    CashierUserId: td.find('.CashierUserId').val(),
                };
                PosReceiptVoucherDetails.push(PosReceiptVoucherDetail);
            });
            var PosReceiptVoucherCustomerTypes = [];
            $('#PosReceiptVoucherCustomerTypes tr').each(function () {
                var td = $(this);
                var PosReceiptVoucherCustomerType = {
                    PosReceiptVoucherId: $('#Id').val(),
                    CustomerTypeId: td.find('.CustomerTypeId').val(),
                    Amount: td.find('.Amount').inputmask('unmaskedvalue')
                };
                PosReceiptVoucherCustomerTypes.push(PosReceiptVoucherCustomerType);
            });
        }
        if (PosReceiptVoucherDetails.length == 0) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.NoDataFound',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
            valid = false;
        }

        if (valid) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.AreYouSureYouWantToSave',
                text: " ",
                icon: 'info',
                showCancelButton: true,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                cancelButtonText: '@MyERP.Properties.Resources.Cancel',
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {

                    $('#preloader, #status').fadeIn();
                    // $('#newbtn').prop('disabled', true);
                    $('#save').prop('disabled', true);
                    $.ajax({
                        type: "POST", contentType: "application/json",
                        url: "/PosReceiptVoucher/AddEdit",
                        data:
                            JSON.stringify({
                                Id: $('#Id').val(),
                                DocumentNumber: $('#DocumentNumber').val(),
                                BranchId: $('#BranchId').val(),
                                DepartmentId: $('#DepartmentId').val(),
                                Date: $('#Date').val(),
                                DateFrom: $('#DateFrom').val(),
                                DateTo: $('#DateTo').val(),
                                ShiftId: $('#ShiftId').val(),
                                CashierUserId: $('#CashierUserId').val(),
                                AccountantCashBoxId: $('#AccountantCashBoxId').val(),
                                IsActive: $('#IsActive').val(),
                                IsDeleted: $('#IsDeleted').val(),
                                Notes: $('#Notes').val(),
                                PosReceiptVoucherDetails: PosReceiptVoucherDetails,
                                PosReceiptVoucherCustomerTypes: PosReceiptVoucherCustomerTypes
                            }),
                        success: function (r) {
                            if (r.success == "true") {
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.Saved',
                                    text: " ",
                                    icon: 'success',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                }); $('#preloader, #status').fadeOut();
                                window.location.replace("/PosReceiptVoucher/Index");
                            }
                            else {
                                $('#preloader, #status').fadeOut();
                                $('#save').prop('disabled', false);
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.NotSaved !',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                            }
                        },
                        error: function (r) {
                            $('#preloader, #status').fadeOut();
                            $('#save').prop('disabled', false);
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.NotSaved !',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                        }
                    });
                }
                else { result.dismiss; }
            });

        }
    }
    //*********************************************************//

</script>
