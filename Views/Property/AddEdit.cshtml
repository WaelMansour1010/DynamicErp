<script>
    //--------------- Variables Declarations -------------------//
    var CitiesOptions = '';
    var taxPercentage = 0.14;
    //*********************************************************//
    //--------------- Ready Function -------------------//
    $(document).ready(function () {
        $('#ContractStartDate').val('@ViewBag.ContractStartDate');
        $('#ContractEndDate').val('@ViewBag.ContractEndDate');
        $('#ContractDate').val('@ViewBag.ContractDate');
        $('#FirstBatchDate').val('@ViewBag.FirstBatchDate');

        $('.Gregorian').each(function () {
            var Hijry = new Intl.DateTimeFormat('ar-sa').format(new Date($(this).val())).toString();
            $('#Hijry' + $(this).attr('id') + '').val(Hijry);
        });

        if ($('#Id').val() > 0) {

        }
        else {
            setCodeNum();
            $('#CountryId').trigger('change');
            GetCurrentTaxPercentage();
        }
    });
    //*********************************************************//
    //--------------- Event Functions -------------------//
    $('.Gregorian').on('change', function () {
            var Hijry = new Intl.DateTimeFormat('ar-sa').format(new Date($(this).val())).toString();
            $('#Hijry' + $(this).attr('id') + '').val(Hijry);
        });
    $('#CountryId').on('change', function () {
        getCities($(this).val()).then(function () {
            $("#CityId").empty().append(CitiesOptions);
        });
    });
    $('#IsCommission').on('change', function () {
        if ($(this).prop('checked') == true) {
            $('#PropertyBatches').empty();
            $('#NumberOfBatches').val(0);
            $('#NumberOfBatches').prop('disabled',true);
            $('#PeriodBetweenBatchesNum').val(0);
            $('#PeriodBetweenBatchesNum').prop('disabled', true);
            $('#PeriodBetweenBatchesTypeId').val(0);
            $('#PeriodBetweenBatchesTypeId').prop('selectedIndex', 0).select2();
            $('#PeriodBetweenBatchesTypeId').prop('disabled', true);
            $('#FirstBatchDate').val(0);
            $('#FirstBatchDate').prop('disabled', true);
            $('#Calculate').prop('disabled', true);

        } else {
            $('#NumberOfBatches').prop('disabled', false);
            $('#PeriodBetweenBatchesNum').prop('disabled', false);
            $('#PeriodBetweenBatchesTypeId').prop('selectedIndex', 0).select2();
            $('#PeriodBetweenBatchesTypeId').prop('disabled', false);
            $('#FirstBatchDate').val(@ViewBag.FirstBatchDate);
            $('#FirstBatchDate').prop('disabled', false);
            $('#Calculate').prop('disabled', false);
        }
    });
    $('#ContractDate').on('change', function () {
        GetCurrentTaxPercentage();
    });
    $('#TaxPercentage').on('change', function () {
       if (!$('#ContractValueWithoutTax').val()) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.ContractValueWithoutTax @MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        }
       else {
           var taxValue = parseFloat($('#ContractValueWithoutTax').val() * 1) * parseFloat(taxPercentage);
           $('#TaxValue').val(taxValue);
       }
    });
    $('#TaxValue').on('change', function () {
       if (!$('#ContractValueWithoutTax').val()) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.ContractValueWithoutTax @MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        }
       else {
           if (parseFloat($(this).val() * 1) > 0) {
               var taxPercentage = parseFloat($('#ContractValueWithoutTax').val() * 1) / parseFloat($(this).val() * 1) / 100;
               $('#TaxPercentage').val(taxPercentage);
           }
           else {
               $('#TaxPercentage').val(0);
           }
       }
    });
    $('#ContractValueWithoutTax').on('change', function () {
        $('#TaxPercentage').trigger('change');
    });
    $(document).on('change', '.Discount', function () {
        var BatchValueBeforeDiscount = parseFloat($(this).closest('tr').find('.BatchValueBeforeDiscount').val() * 1);
        var Discount = parseFloat($(this).val() * 1);
        var BatchValueAfterDiscount =BatchValueBeforeDiscount-Discount
        $(this).closest('tr').find('.BatchValueAfterDiscount').val(BatchValueAfterDiscount)
    });
    //$('#IsApplyTax').on('change', function () {
    //    AppendIntoPropertyDetails();
    //});
    //$('#IsFurnishing').on('change', function () {
    //    AppendIntoPropertyDetails();
    //});
    $('#PropertyUnitNo').on('change', function () {
        let value = $('#PropertyUnitNo').val(); // Get the value
        let alphabeticPart = (value.match(/^[a-zA-Z]+/) ?? [''])[0]; // Match alphabetic characters at the start
        
        let numericPropertyUnitNo = value.replace(/^[a-zA-Z]+/, ''); // Remove alphabetic characters at the start
        
        console.log(alphabeticPart);
        console.log(numericPropertyUnitNo);

        if ($('#Number').val()) {
            var numericUnitSequenceTo = parseInt(numericPropertyUnitNo) + parseInt($('#Number').val())
            $('#UnitSequenceTo').val(alphabeticPart + numericUnitSequenceTo);
        }
        $('#UnitSequenceFrom').val($(this).val());

    });
    $('#Number').on('change', function () {
        if ($('#PropertyUnitNo').val()) {
            var PropertyUnitNo = $('#PropertyUnitNo').val();

            let PropertyUnitNumeric = parseInt(PropertyUnitNo.replace(/^[a-zA-Z]+/, ''));
            let alphabeticPart = (PropertyUnitNo.match(/^[a-zA-Z]+/) ?? [''])[0]; // Match alphabetic characters at the start
          
            var UnitSequenceTo = parseInt($(this).val()) + PropertyUnitNumeric
            $('#UnitSequenceTo').val(alphabeticPart + UnitSequenceTo);
            $('#UnitSequenceFrom').val($('#PropertyUnitNo').val());
        }
