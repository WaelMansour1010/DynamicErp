}
function Delete(id) {
    if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToDelete')) {
        $('#preloader, #status').fadeIn();
        $.ajax(
            {
                url: '/Property/Delete',
                type: 'POST',
                data: {
                    "Id": id,
                },
                error: function (e) {
                    $('#preloader, #status').fadeOut();
                },
                success: function (r) {
                    if (r == 'true') {
                        window.location.replace('/Property');
                    }
                }
            });
    }
}

// Date utility functions
function addDays(date, days) {
    var result = new Date(date);
    result.setDate(result.getDate() + days);
    return result;
}

function addWeeks(date, weeks) {
    return addDays(date, weeks * 7);
}

function addMonths(date, months) {
    var result = new Date(date);
    result.setMonth(result.getMonth() + months);
    return result;
}

function addYears(date, years) {
    var result = new Date(date);
    result.setFullYear(result.getFullYear() + years);
    return result;
}

// Fix for requestData function if not available
function requestData(url) {
    return $.get(url);
}

// Function to show alerts (if not available)
function showAlert(message, type) {
    Swal.fire({
        title: message,
        text: " ",
        icon: type,
        showCancelButton: false,
        confirmButtonText: '@MyERP.Properties.Resources.Ok',
        confirmButtonColor: '#3085d6'
    });
}
