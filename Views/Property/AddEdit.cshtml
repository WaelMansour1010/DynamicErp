    function SetBatchDate(i) {
        var PeriodBetweenBatchesTypeId = $('#PeriodBetweenBatchesTypeId').val();
        var PeriodBetweenBatchesNum = parseInput($('#PeriodBetweenBatchesNum').val());
        if (PeriodBetweenBatchesNum == 0) {
            PeriodBetweenBatchesNum = 1;
            $('#PeriodBetweenBatchesNum').val(1);
        }

        var result;
        var _FirstBatchDate = new Date($('#FirstBatchDate').val());
        if (!lastdate) {
            lastdate = new Date($('#FirstBatchDate').val());
            result = (lastdate.getFullYear()) + "-" + zeroPadded(lastdate.getMonth() + 1) + "-" + zeroPadded(lastdate.getDate());
            return result;

        }


        var x = new Date($('#PropertyContractBatches tr:last').find('.BatchDate').val());
        //console.log({
        //    lastdate: lastdate,
        //    PeriodBetweenBatchesNum: PeriodBetweenBatchesNum,
        //    PeriodBetweenBatchesTypeId: PeriodBetweenBatchesTypeId

        //});

        if (PeriodBetweenBatchesTypeId == 1) // يوم
        {
            //  _FirstBatchDate.setDate(_FirstBatchDate.getDate() + (i * PeriodBetweenBatchesNum));
            lastdate = addDays(lastdate,  PeriodBetweenBatchesNum);

            //  result = (_FirstBatchDate.getFullYear()) + "-" + zeroPadded(_FirstBatchDate.getMonth() + 1) + "-" + zeroPadded(_FirstBatchDate.getDate());
        }
        else if (PeriodBetweenBatchesTypeId == 2) // اسبوع
        {
            /// _FirstBatchDate.setDate(_FirstBatchDate.getDate() + (i * 7 * PeriodBetweenBatchesNum));
            //  result = (_FirstBatchDate.getFullYear()) + "-" + zeroPadded(_FirstBatchDate.getMonth() + 1) + "-" + zeroPadded(_FirstBatchDate.getDate());
            lastdate = addWeeks(lastdate,  PeriodBetweenBatchesNum);
        }
        else if (PeriodBetweenBatchesTypeId == 3) // شهر
        {
            //_FirstBatchDate.setDate(_FirstBatchDate.getDate());
            //if (_FirstBatchDate.getMonth() + 1 + (i * PeriodBetweenBatchesNum) <= 12) {
            //    result = _FirstBatchDate.getFullYear() + "-" + zeroPadded(_FirstBatchDate.getMonth() + 1 + (i * PeriodBetweenBatchesNum)) + "-" + zeroPadded(_FirstBatchDate.getDate());
            //}
            //else {
            //    if (zeroPadded(x.getMonth() + 1) == 1) {
            //        result = x.getFullYear() + "-" + zeroPadded(x.getMonth() + 1 + parseInt(PeriodBetweenBatchesNum)) + "-" + zeroPadded(x.getDate());
            //    }
            //    else {
            //        result = x.getFullYear() + 1 + "-" + zeroPadded(1) + "-" + zeroPadded(x.getDate());
            //    }
            //}
            lastdate = addMonths(lastdate, PeriodBetweenBatchesNum);
        }

        else if (PeriodBetweenBatchesTypeId == 4) // سنة
        {
            //_FirstBatchDate.setDate(_FirstBatchDate.getDate());
            //result = (_FirstBatchDate.getFullYear() + (i * PeriodBetweenBatchesNum)) + "-" + zeroPadded(_FirstBatchDate.getMonth() + 1) + "-" + zeroPadded(_FirstBatchDate.getDate());
            lastdate = addYears(lastdate,  PeriodBetweenBatchesNum);
        }

        result = (lastdate.getFullYear()) + "-" + zeroPadded(lastdate.getMonth() + 1) + "-" + zeroPadded(lastdate.getDate());
        return result;
    }
