var lastdate;
function SetBatchDate(i) {
    var PeriodBetweenBatchesTypeId = $('#PeriodBetweenBatchesTypeId').val();
    var PeriodBetweenBatchesNum = parseInput($('#PeriodBetweenBatchesNum').val());
    if (PeriodBetweenBatchesNum == 0) {
        PeriodBetweenBatchesNum = 1;
        $('#PeriodBetweenBatchesNum').val(1);
    }

    var result;
    var _FirstBatchDate = new Date($('#FirstBatchDate').val());
    if (!lastdate) {
        lastdate = new Date($('#FirstBatchDate').val());
        result = (lastdate.getFullYear()) + "-" + zeroPadded(lastdate.getMonth() + 1) + "-" + zeroPadded(lastdate.getDate());
        return result;

    }

    var x = new Date($('#PropertyBatches tr:last').find('.BatchDate').val());

    if (PeriodBetweenBatchesTypeId == 1) // يوم
    {
        lastdate = addDays(lastdate, PeriodBetweenBatchesNum);
    }
    else if (PeriodBetweenBatchesTypeId == 2) // اسبوع
    {
        lastdate = addWeeks(lastdate, PeriodBetweenBatchesNum);
    }
    else if (PeriodBetweenBatchesTypeId == 3) // شهر
    {
        lastdate = addMonths(lastdate, PeriodBetweenBatchesNum);
    }
    else if (PeriodBetweenBatchesTypeId == 4) // سنة
    {
        lastdate = addYears(lastdate, PeriodBetweenBatchesNum);
    }

    result = (lastdate.getFullYear()) + "-" + zeroPadded(lastdate.getMonth() + 1) + "-" + zeroPadded(lastdate.getDate());
    return result;
}

function CalculateBatches() {
    let valid = true;
    if (!$('#NumberOfBatches').val()) {
        Swal.fire({
            title: '@MyERP.Properties.Resources.NumberOfBatches @MyERP.Properties.Resources.Required',
            text: " ",
            icon: 'info',
            showCancelButton: false,
            confirmButtonText: '@MyERP.Properties.Resources.Ok',
            confirmButtonColor: '#3085d6'
        });
        valid = false;
    }
    if (!$('#ContractValueWithoutTax').val()) {
        Swal.fire({
            title: '@MyERP.Properties.Resources.ContractValueWithoutTax @MyERP.Properties.Resources.Required',
            text: " ",
            icon: 'info',
            showCancelButton: false,
            confirmButtonText: '@MyERP.Properties.Resources.Ok',
            confirmButtonColor: '#3085d6'
        });
        valid = false;
    }
    if (!$('#PeriodBetweenBatchesNum').val() || !$('#PeriodBetweenBatchesTypeId').val()) {
        Swal.fire({
            title: '@MyERP.Properties.Resources.PeriodBetweenBatches @MyERP.Properties.Resources.Required',
            text: " ",
            icon: 'info',
            showCancelButton: false,
            confirmButtonText: '@MyERP.Properties.Resources.Ok',
            confirmButtonColor: '#3085d6'
        });
        valid = false;
    }
    if (valid == true) {
        $('#PropertyBatches').empty();
        var NumberOfBatches = $('#NumberOfBatches').val() * 1;
        var ContractValueWithoutTax = parseFloat($('#ContractValueWithoutTax').val() * 1);
        var BatchValueBeforeTax = ContractValueWithoutTax / NumberOfBatches;
        var TaxPercentage = $('#TaxPercentage').val() * 1;
        var TaxValue = TaxPercentage * BatchValueBeforeTax;
        lastdate = null;

        for (var i = 0; i < NumberOfBatches; i++) {
            BatchDate = SetBatchDate(i);

            // حساب التاريخ الهجري بشكل صحيح
            var HijryBatchDate = '';
            try {
                HijryBatchDate = new Intl.DateTimeFormat('ar-sa', {
                    calendar: 'islamic',
                    year: 'numeric',
                    month: '2-digit',
                    day: '2-digit'
                }).format(new Date(BatchDate));
            } catch (e) {
                // في حالة فشل حساب التاريخ الهجري، استخدم طريقة بديلة
                var batchDateObj = new Date(BatchDate);
                HijryBatchDate = batchDateObj.getFullYear() + '/' +
                                (batchDateObj.getMonth() + 1) + '/' +
                                batchDateObj.getDate() + ' هـ';
            }

            let tr = '<tr>' +
                '<td class="tabledit-edit-mode">' +
                    '<input type="text" class="BatchNo form-control tabledit-input form-control-sm" value="' + (i + 1) + '" disabled readonly />' +
                    '<input type="text" hidden class="BatchId" value="0" disabled readonly />' +
                '</td>' +
                '<td class="tabledit-edit-mode">' +
                    '<input type="date" class="BatchDate Gregorian form-control tabledit-input form-control-sm" value="' + BatchDate + '" disabled readonly />' +
                '</td>' +
                '<td class="tabledit-edit-mode">' +
                    '<label class="HijryBatchDate control-label">' + HijryBatchDate + '</label>' +
                '</td>' +
                '<td class="tabledit-edit-mode">' +
                    '<input type="number" step="any" class="BatchValueBeforeDiscount form-control tabledit-input form-control-sm" value="' + BatchValueBeforeTax.toFixed(2) + '" />' +
                '</td>' +
                '<td class="tabledit-edit-mode">' +
                    '<input type="number" step="any" class="BatchValueBeforeTax form-control tabledit-input form-control-sm" value="' + BatchValueBeforeTax.toFixed(2) + '" disabled readonly />' +
                '</td>' +
                '<td class="tabledit-edit-mode">' +
                    '<input type="number" step="any" class="Discount form-control tabledit-input form-control-sm" value="0" />' +
                '</td>' +
                '<td class="tabledit-edit-mode">' +
                    '<input type="number" step="any" class="BatchValueAfterDiscount form-control tabledit-input form-control-sm" value="' + BatchValueBeforeTax.toFixed(2) + '"/>' +
                '</td>' +
                '<td class="tabledit-edit-mode">' +
                    '<input type="number" step="any" class="BatchTaxPercentage form-control tabledit-input form-control-sm" value="' + (TaxPercentage * 100).toFixed(2) + '" disabled readonly />' +
                '</td>' +
                '<td class="tabledit-edit-mode">' +
                    '<input type="number" step="any" class="BatchTaxValue form-control tabledit-input form-control-sm" value="' + TaxValue.toFixed(2) + '" disabled readonly />' +
                '</td>' +
                '<td class="tabledit-edit-mode">' +
                    '<input type="checkbox" class="IsDelivered" />' +
                '</td>' +
                '<td class="tabledit-edit-mode">' +
                    '<input type="number" step="any" class="TotalPaid form-control tabledit-input form-control-sm" value="0.00" readonly disabled />' +
                '</td>' +
                '<td class="tabledit-edit-mode">' +
                    '<input type="number" step="any" class="Paid form-control tabledit-input form-control-sm" value="0.00" />' +
                '</td>' +
                '<td class="tabledit-edit-mode">' +
                    '<input type="number" step="any" class="Remain form-control tabledit-input form-control-sm" value="' + (BatchValueBeforeTax + TaxValue).toFixed(2) + '" readonly disabled />' +
                '</td>' +
            '</tr>';

            $('#PropertyBatches').append(tr);
        }

        // تحديث حسابات السداد بعد إنشاء الدفعات
        updateTotalPaidForAllRows();
    }
}
