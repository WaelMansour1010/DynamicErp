    function CalculateBatches() {
        let valid = true;
        if (!$('#NumberOfBatches').val()) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.NumberOfBatches @MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
            valid = false;
        }
        if (!$('#ContractValueWithoutTax').val()) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.ContractValueWithoutTax @MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
            valid = false;
        }
        if (!$('#NumberOfBatches').val()) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.NumberOfBatches @MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
            valid = false;
        }
        if (!$('#PeriodBetweenBatchesNum').val() || !$('#PeriodBetweenBatchesTypeId').val()) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.PeriodBetweenBatches @MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
            valid = false;
        }
        if (valid == true) {

            $('#PropertyBatches').empty();
            var NumberOfBatches = $('#NumberOfBatches').val() * 1;
            var ContractValueWithoutTax = parseFloat($('#ContractValueWithoutTax').val() * 1);
            var BatchValueBeforeTax = ContractValueWithoutTax/NumberOfBatches;
            var TaxPercentage = $('#TaxPercentage').val() * 1;
            var TaxValue = TaxPercentage * BatchValueBeforeTax;
            lastdate = null;
            for (var i = 0; i < NumberOfBatches; i++) {
                BatchDate = SetBatchDate(i);

                var HijryBatchDate = new Intl.DateTimeFormat('ar-sa').format(new Date(BatchDate)).toString();
                let tr = '<tr><td class="tabledit-edit-mode"><input type="text" class="BatchNo form-control tabledit-input form-control-sm" value="' +
                    (i + 1) + '" disabled readonly />' +
                    '<input type="text" hidden class="BatchId" value="0" disabled readonly />'+
                    '</td><td class="tabledit-edit-mode"><input type = "date" class="BatchDate Gregorian form-control tabledit-input form-control-sm" value = "' +
                    BatchDate + '" disabled readonly /></td><td class="tabledit-edit-mode"><label class="HijryBatchDate control-label control-label">' +
                    HijryBatchDate + '</label></td><td class="tabledit-edit-mode"><input type="number" step="any" class="BatchValueBeforeDiscount form-control tabledit-input form-control-sm" value="' +
                    BatchValueBeforeTax + '" /></td><td class="tabledit-edit-mode"><input type="number" step="any" class="BatchValueBeforeTax form-control tabledit-input form-control-sm" value="' +
                    BatchValueBeforeTax + '" disabled readonly /></td><td class="tabledit-edit-mode"><input type="number" step="any" class="Discount form-control tabledit-input form-control-sm" value="' +
                    0 + '" /></td><td class="tabledit-edit-mode"><input type="number" step="any" class="BatchValueAfterDiscount form-control tabledit-input form-control-sm" value="' +
                    0 + '"/></td><td class="tabledit-edit-mode"><input type="number" step="any" class="BatchTaxPercentage form-control tabledit-input form-control-sm" value="' +
                    TaxPercentage + '" disabled readonly /></td><td class="tabledit-edit-mode"><input type="number" step="any" class="BatchTaxValue form-control tabledit-input form-control-sm" value="' +
                    TaxValue + '" disabled readonly /></td></tr>';
                $('#PropertyBatches').append(tr);
            }
        }
    }
