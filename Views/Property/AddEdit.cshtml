// وظيفة حساب الضريبة والمتبقي لصف معين
function calculateBatchTaxAndRemain(row) {
    var batchValueAfterDiscount = parseFloat(row.find('.BatchValueAfterDiscount').val() * 1) || 0;
    var taxPercentage = parseFloat(row.find('.BatchTaxPercentage').val() * 1) || 0;

    // حساب قيمة الضريبة
    var taxValue = batchValueAfterDiscount * (taxPercentage / 100);
    row.find('.BatchTaxValue').val(taxValue.toFixed(2));

    // حساب المتبقي
    calculateBatchRemain(row);
}

// وظيفة حساب المتبقي لصف معين
function calculateBatchRemain(row) {
    var batchValueAfterDiscount = parseFloat(row.find('.BatchValueAfterDiscount').val() * 1) || 0;
    var taxValue = parseFloat(row.find('.BatchTaxValue').val() * 1) || 0;
    var paid = parseFloat(row.find('.Paid').val() * 1) || 0;

    // إجمالي قيمة الدفعة
    var totalBatchValue = batchValueAfterDiscount + taxValue;

    // التحقق من أن المسدد لا يزيد عن إجمالي القيمة
    if (paid > totalBatchValue) {
        paid = totalBatchValue;
        row.find('.Paid').val(paid.toFixed(2));

        showAlert('المبلغ المسدد لا يمكن أن يزيد عن إجمالي قيمة الدفعة', 'warning');
    }

    // حساب المتبقي
    var remain = totalBatchValue - paid;
    row.find('.Remain').val(remain.toFixed(2));

    // تحديث حالة الصف حسب السداد
    updateRowPaymentStatus(row, paid, totalBatchValue);
}

// وظيفة تحديث حالة السداد للصف
function updateRowPaymentStatus(row, paid, totalValue) {
    var paidInput = row.find('.Paid');
    var remainInput = row.find('.Remain');

    if (paid >= totalValue) {
        // مسدد بالكامل
        row.addClass('fully-paid');
        row.removeClass('partially-paid');
        paidInput.attr('readonly', true);
    } else if (paid > 0) {
        // مسدد جزئياً
        row.addClass('partially-paid');
        row.removeClass('fully-paid');
        paidInput.attr('readonly', false);
    } else {
        // غير مسدد
        row.removeClass('fully-paid partially-paid');
        paidInput.attr('readonly', false);
    }
}

// وظيفة تحديث إجمالي المسدد السابق لكل الصفوف
    function updateTotalPaidForAllRows() {
        var totalPaid = 0;

        // نحصل على جميع الصفوف
        var rows = $('#PropertyBatches tr');

        for (var i = 0; i < rows.length; i++) {
            var row = $(rows[i]);

            // نحسب المدفوع قبل هذا الصف فقط
            row.find('.TotalPaid').val(totalPaid.toFixed(2));

            var paid = parseFloat(row.find('.Paid').val()) || 0;
            totalPaid += paid;
        }

        updatePaymentSummary();
    }


// وظيفة عرض ملخص السداد
function updatePaymentSummary() {
    var totalContractValue = 0;
    var totalPaid = 0;
    var totalRemain = 0;

    $('#PropertyBatches tr').each(function() {
        var row = $(this);
        var batchValue = parseFloat(row.find('.BatchValueAfterDiscount').val() * 1) || 0;
        var taxValue = parseFloat(row.find('.BatchTaxValue').val() * 1) || 0;
        var paid = parseFloat(row.find('.Paid').val() * 1) || 0;
        var remain = parseFloat(row.find('.Remain').val() * 1) || 0;

        totalContractValue += (batchValue + taxValue);
        totalPaid += paid;
        totalRemain += remain;
    });

    // عرض الملخص (يمكنك إضافة عناصر HTML لعرض هذه القيم)
    console.log('إجمالي قيمة العقد:', totalContractValue.toFixed(2));
    console.log('إجمالي المسدد:', totalPaid.toFixed(2));
    console.log('إجمالي المتبقي:', totalRemain.toFixed(2));
    console.log('نسبة السداد:', ((totalPaid / totalContractValue) * 100).toFixed(2) + '%');
}

// وظيفة التحقق من صحة السداد
function validatePayments() {
    var isValid = true;
    var errorMessages = [];

    $('#PropertyBatches tr').each(function(index) {
        var row = $(this);
        var batchNo = row.find('.BatchNo').val();
        var batchValue = parseFloat(row.find('.BatchValueAfterDiscount').val() * 1) || 0;
        var taxValue = parseFloat(row.find('.BatchTaxValue').val() * 1) || 0;
        var paid = parseFloat(row.find('.Paid').val() * 1) || 0;
        var totalValue = batchValue + taxValue;

        // التحقق من أن المسدد لا يكون سالب
        if (paid < 0) {
            isValid = false;
            errorMessages.push(`الدفعة ${batchNo}: المبلغ المسدد لا يمكن أن يكون سالباً`);
        }

        // التحقق من أن المسدد لا يزيد عن إجمالي القيمة
        if (paid > totalValue) {
            isValid = false;
            errorMessages.push(`الدفعة ${batchNo}: المبلغ المسدد يزيد عن قيمة الدفعة`);
        }
    });

    if (!isValid) {
        showAlert(errorMessages.join('\n'), 'error');
    }

    return isValid;
}
