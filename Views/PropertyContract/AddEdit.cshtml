    function SetContractStartDate(day, month) {
        var ContractStartDate = new Date($('#ContractStartDate').val());
        if (day != null && day > 0) {
            ContractStartDate.setDate(ContractStartDate.getDate() + parseInt(day));
        }
        else if (month != null && month > 0) {
            ContractStartDate.setMonth(ContractStartDate.getMonth() + parseInt(month));
        }
        var month = (ContractStartDate.getMonth() + 1) < 10 ? '0' + (ContractStartDate.getMonth() + 1) : (ContractStartDate.getMonth() + 1);
        var day = ContractStartDate.getDate() < 10 ? '0' + ContractStartDate.getDate() : ContractStartDate.getDate();
        var hours = ContractStartDate.getHours();
        var minutes = ContractStartDate.getMinutes();
        var seconds = ContractStartDate.getSeconds();
        var ampm = hours >= 12 ? 'PM' : 'AM';
        hours = hours % 12;
        hours = hours ? hours : 12; // the hour '0' should be '12'
        hours = hours < 10 ? '0' + hours : hours;
        minutes = minutes < 10 ? '0' + minutes : minutes;
        seconds = seconds < 10 ? '0' + seconds : seconds;
        var strTime = hours + ':' + minutes /*+ ":" + seconds + ' ' + ampm*/;
        var value = (ContractStartDate.getFullYear() + "-" + month + "-" + day) + "T" + strTime;
        $('#ContractStartDate').val(value);
    }

