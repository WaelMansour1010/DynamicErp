function parseInput(input) {
    return input === "" ? 0 : Number(input);
    }

var lastdate;
    function SetBatchDate(i) {
        var PeriodBetweenBatchesTypeId = $('#PeriodBetweenBatchesTypeId').val();
        var PeriodBetweenBatchesNum = parseInput($('#PeriodBetweenBatchesNum').val());
        if (PeriodBetweenBatchesNum == 0) {
            PeriodBetweenBatchesNum = 1;
            $('#PeriodBetweenBatchesNum').val(1);
        }

        var result;
        var _FirstBatchDate = new Date($('#FirstBatchDate').val());
        if (!lastdate) {
            lastdate = new Date($('#FirstBatchDate').val());
            result = (lastdate.getFullYear()) + "-" + zeroPadded(lastdate.getMonth() + 1) + "-" + zeroPadded(lastdate.getDate());
            return result;

        }


        var x = new Date($('#PropertyContractBatches tr:last').find('.BatchDate').val());
        //console.log({
        //    lastdate: lastdate,
        //    PeriodBetweenBatchesNum: PeriodBetweenBatchesNum,
        //    PeriodBetweenBatchesTypeId: PeriodBetweenBatchesTypeId

        //});

        if (PeriodBetweenBatchesTypeId == 1) // يوم
        {
          //  _FirstBatchDate.setDate(_FirstBatchDate.getDate() + (i * PeriodBetweenBatchesNum));
          lastdate = addDays(lastdate,  PeriodBetweenBatchesNum);

          //  result = (_FirstBatchDate.getFullYear()) + "-" + zeroPadded(_FirstBatchDate.getMonth() + 1) + "-" + zeroPadded(_FirstBatchDate.getDate());
        }
        else if (PeriodBetweenBatchesTypeId == 2) // اسبوع
        {
           /// _FirstBatchDate.setDate(_FirstBatchDate.getDate() + (i * 7 * PeriodBetweenBatchesNum));
          //  result = (_FirstBatchDate.getFullYear()) + "-" + zeroPadded(_FirstBatchDate.getMonth() + 1) + "-" + zeroPadded(_FirstBatchDate.getDate());
            lastdate = addWeeks(lastdate,  PeriodBetweenBatchesNum);
        }
        else if (PeriodBetweenBatchesTypeId == 3) // شهر
        {
            //_FirstBatchDate.setDate(_FirstBatchDate.getDate());
            //if (_FirstBatchDate.getMonth() + 1 + (i * PeriodBetweenBatchesNum) <= 12) {
            //    result = _FirstBatchDate.getFullYear() + "-" + zeroPadded(_FirstBatchDate.getMonth() + 1 + (i * PeriodBetweenBatchesNum)) + "-" + zeroPadded(_FirstBatchDate.getDate());
            //}
            //else {
            //    if (zeroPadded(x.getMonth() + 1) == 1) {
            //        result = x.getFullYear() + "-" + zeroPadded(x.getMonth() + 1 + parseInt(PeriodBetweenBatchesNum)) + "-" + zeroPadded(x.getDate());
            //    }
            //    else {
            //        result = x.getFullYear() + 1 + "-" + zeroPadded(1) + "-" + zeroPadded(x.getDate());
            //    }
            //}
            
            lastdate = addMonths(lastdate,  PeriodBetweenBatchesNum);
        }

        else if (PeriodBetweenBatchesTypeId == 4) // سنة
        {
            //_FirstBatchDate.setDate(_FirstBatchDate.getDate());
            //result = (_FirstBatchDate.getFullYear() + (i * PeriodBetweenBatchesNum)) + "-" + zeroPadded(_FirstBatchDate.getMonth() + 1) + "-" + zeroPadded(_FirstBatchDate.getDate());
            lastdate = addYears(lastdate,  PeriodBetweenBatchesNum);
        }

        result = (lastdate.getFullYear()) + "-" + zeroPadded(lastdate.getMonth() + 1) + "-" + zeroPadded(lastdate.getDate());
        return result;
    }


    function CalculateBatches() {
        $('#PropertyContractBatches').empty();
        var NumberOfBatches = $('#NumberOfBatches').val() * 1;
        var RentValue = $('#RentValue').inputmask('unmaskedvalue') * 1;
        var WaterValue = $('#WaterValue').inputmask('unmaskedvalue') * 1;
        var ElectricityValue = $('#ElectricityValue').inputmask('unmaskedvalue') * 1;
        var CommissionValue = $('#CommissionValue').inputmask('unmaskedvalue') * 1;
        var GasValue = $('#GasValue').inputmask('unmaskedvalue') * 1;
        var ServicesValue = $('#ServicesValue').inputmask('unmaskedvalue') * 1;
        var InsuranceValue = $('#InsuranceValue').inputmask('unmaskedvalue') * 1;

        var IncludeRentValueInVAT = $('#IncludeRentValueInVAT').prop('checked');
        var IncludeWaterValueInVAT = $('#IncludeWaterValueInVAT').prop('checked');
        var IncludeElectricityValueInVAT = $('#IncludeElectricityValueInVAT').prop('checked');
        var IncludeGasValueInVAT = $('#IncludeGasValueInVAT').prop('checked');
        var IncludeServicesValueInVAT = $('#IncludeServicesValueInVAT').prop('checked');
        var IncludeInsuranceValueInVAT = $('#IncludeInsuranceValueInVAT').prop('checked');
        var IncludeCommissionValueInVAT = $('#IncludeCommissionValueInVAT').prop('checked');

        var BatchRentValue = parseFloat(RentValue / NumberOfBatches).toFixed(2);
        var BatchRentValueTaxes = 0;
        if (IncludeRentValueInVAT == true) {
            BatchRentValueTaxes = parseFloat(BatchRentValue * taxPercentage).toFixed(2);
        }
        var BatchWaterValue = parseFloat(WaterValue / NumberOfBatches).toFixed(2);
 
        var BatchWaterValueTaxes = 0;
        if (IncludeWaterValueInVAT == true) {
            BatchWaterValueTaxes = parseFloat(BatchWaterValue * taxPercentage).toFixed(2);
        }
        var BatchElectricityValue = parseFloat(ElectricityValue / NumberOfBatches).toFixed(2);
        var BatchElectricityValueTaxes = 0;
        if (IncludeElectricityValueInVAT == true) {
            BatchElectricityValueTaxes = parseFloat(BatchElectricityValue * taxPercentage).toFixed(2);
        }
        var BatchGasValue = parseFloat(GasValue / NumberOfBatches).toFixed(2);
        var BatchGasValueTaxes = 0;
        if (IncludeGasValueInVAT == true) {
            BatchGasValueTaxes = parseFloat(BatchGasValue * taxPercentage).toFixed(2);
        }
        var BatchServicesValue = parseFloat(ServicesValue / NumberOfBatches).toFixed(2);
        var BatchServicesValueTaxes = 0;
        if (IncludeServicesValueInVAT == true) {
            BatchServicesValueTaxes = parseFloat(BatchServicesValue * taxPercentage).toFixed(2);
        }
        var BatchInsuranceValue = parseFloat(InsuranceValue / NumberOfBatches).toFixed(2);
        var BatchInsuranceValueTaxes = 0;
        if (IncludeInsuranceValueInVAT == true) {
            BatchInsuranceValueTaxes = parseFloat(BatchInsuranceValue * taxPercentage).toFixed(2);
        }
        var BatchCommissionValue = parseFloat(CommissionValue / NumberOfBatches).toFixed(2);
        var BatchCommissionValueTaxes = 0;
        if (IncludeCommissionValueInVAT == true) {
            BatchCommissionValueTaxes = parseFloat(BatchCommissionValue * taxPercentage).toFixed(2);
        }
        var BatchTotal = parseFloat(BatchRentValue) + parseFloat(BatchRentValueTaxes)
            + parseFloat(BatchWaterValue) + parseFloat(BatchWaterValueTaxes)
            + parseFloat(BatchElectricityValue) + parseFloat(BatchElectricityValueTaxes)
            + parseFloat(BatchGasValue) + parseFloat(BatchGasValueTaxes)
            + parseFloat(BatchServicesValue) + parseFloat(BatchServicesValueTaxes)
            + parseFloat(BatchInsuranceValue) + parseFloat(BatchInsuranceValueTaxes)
            + parseFloat(BatchCommissionValue) + parseFloat(BatchCommissionValueTaxes);
        lastdate = null;
        for (var i = 0; i < NumberOfBatches; i++) {
            BatchDate = SetBatchDate(i);
            var HijryBatchDate = new Intl.DateTimeFormat('ar-sa').format(new Date(BatchDate)).toString();
            let tr = '<tr><td class="tabledit-edit-mode"><input type="text" class="BatchNo form-control tabledit-input form-control-sm" value="' +
                (1 + i) + '" disabled readonly /></td><td class="tabledit-edit-mode"><input type="date" class="BatchDate Gregorian form-control tabledit-input form-control-sm" value="' +
