@using MyERP.Models.MyModels
@model MyERP.Models.PropertyContract
@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.Contracts;
}


@Html.AntiForgeryToken()
@Html.ValidationSummary(true, "", new { @class = "text-danger" })
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <a class="btn btn-info" href="@Url.Action("Index")" role="button" style="float:left;">@MyERP.Properties.Resources.Back</a>
            </div>
            <div class="hed page-title">@MyERP.Properties.Resources.Contracts :</div>
        </div>
    </div>
</div>
<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal needs-validation" role="form">
                        <div class="card">
                            <div class="card-body">
                                @Html.AntiForgeryToken()
                                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                @if (Model != null)
                                {
                                    @Html.HiddenFor(model => model.Id)
                                    @Html.HiddenFor(model => model.UserId)
                                    @Html.HiddenFor(model => model.IsDeleted)
                                    @Html.HiddenFor(model => model.Image)
                                    @Html.HiddenFor(model => model.JournalEntryId)
                                }
                                else
                                {
                                    <input type="hidden" value="0"  id="Id"/>
                                }
                                @*<h5 class="header-title">
                                        @MyERP.Properties.Resources.MainData
                                    </h5>*@

                                @* Panel 1 *@
                                <div class="card">
                                    <div class="card-body">
                                        <div id="accordion">
                                            <h5 class=" pb-3 header-title">
                                                <a data-toggle="collapse" data-parent="#accordion" href="#collapse1">
                                                    @MyERP.Properties.Resources.MainData
                                                </a>
                                            </h5>
                                        </div>
                                        <div id="collapse1">
                                            <div class="form-group row">
                                                <label class=" col-sm-2 control-label" for="Id">@MyERP.Properties.Resources.DocNo</label>
                                                <div class="col-sm-4">
                                                    @Html.EditorFor(model => model.DocumentNumber, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly", placeholder = @MyERP.Properties.Resources.DocNo, required = "required", hidden = "hidden" } })
                                                    <input id="DocumentNumbers" class="form-control" placeholder=@MyERP.Properties.Resources.Code required readonly />
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.UnifiedContractNumber/@MyERP.Properties.Resources.ElectronicContract</label>
                                                <div class="col-sm-4">
                                                    @Html.EditorFor(model => model.UnifiedContractNumber, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.UnifiedContractNumber } })
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group row">
                                                <label class=" col-sm-2 control-label" for="Id">@MyERP.Properties.Resources.VAT</label>
                                                <div class="col-sm-4">
                                                    <input type="radio" id="Applied" name="IsAddedValue" value="true" class="col-sm-2" checked="checked" />@MyERP.Properties.Resources.Applied
                                                    <input type="radio" id="NotApplied" name="IsAddedValue" value="false" class="col-sm-2" />@MyERP.Properties.Resources.NotApplied
                                                    @if (Model != null && Model.IsAddedValue != null)
                                                    {
                                                        <input id="IsAddedValue" hidden @Html.Raw(Model != null && Model.IsAddedValue == true ? "checked" : "") />
                                                    }
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.ContractType</label>
                                                <div class="col-sm-4">
                                                    @Html.DropDownListFor(model => model.ContractTypeId, null, null, htmlAttributes: new { @class = "form-control", required = "required" })
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group row">
                                                <label class="control-label col-sm-2"> </label>
                                                <div class="col-sm-4">
                                                    <input type="radio" id="GovernmentalContract" name="GovernmentalOrPrivateContract" value="1" class="col-sm-2" checked="checked" />@MyERP.Properties.Resources.GovernmentalContract
                                                    <input type="radio" id="PrivateContract" name="GovernmentalOrPrivateContract" value="2" class="col-sm-2" />@MyERP.Properties.Resources.PrivateContract
                                                    @if (Model != null && Model.GovernmentalOrPrivateContract != null)
                                                    {
                                                        <input id="GovernmentalOrPrivateContract" hidden type="text" value="@Model.GovernmentalOrPrivateContract" />
                                                    }
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.Department</label>
                                                <div class="col-sm-4">
                                                    @Html.DropDownListFor(model => model.DepartmentId, null, null, htmlAttributes: new { @class = "form-control", required = "required" })
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group row">
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.ContractDate</label>
                                                <div class="col-sm-4">
                                                    @Html.EditorFor(model => model.VoucherDate, new { htmlAttributes = new { @class = "form-control Gregorian", @type = "datetime-local", @required = "required" } })
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.HijryContractDate  </label>
                                                <div class="col-sm-4">
                                                    <input readonly type="text" id="HijryVoucherDate" class="form-control" />
                                                </div>
                                            </div>
                                            <div class="form-group row">
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.Renter</label>
                                                <div class="col-sm-4">
                                                    @Html.DropDownListFor(model => model.PropertyRenterId, null, null, htmlAttributes: new { @class = "form-control", required = "required" })
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.Representative</label>
                                                <div class="col-sm-4">
                                                    @Html.DropDownListFor(model => model.RepId, null, null, htmlAttributes: new
                                                    {
                                                        @class = "form-control"@*, required = "required"*@})
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                            </div>
                                            @* مكان الصورة *@
                                            <div class="form-group row">
                                                <div id="gallery" style="width: 100%;margin: 20px;">
                                                    @{ if (Model != null && Model.PropertyContractImages != null)
                                                        {
                                                            foreach (MyERP.Models.PropertyContractImage img in Model.PropertyContractImages)
                                                            {
                                                                <img onclick="ShowModal(this)" data-toggle="modal" data-target="#ImageModal" src="@img.Image" alt="" class="img_@img.Id" style="max-width: 200px;max-height: 200px;" />
                                                                <i class="fas fa-trash-alt img_@img.Id" style="cursor:pointer;" onclick="DeleteIMG('@img.Id');$(this).prev().remove();$(this).remove();"></i>
                                                            }
                                                        }
                                                    }
                                                </div>
                                                <input type="file" id="BrowseImage" onchange="previewFile()" value="Browse" multiple />
                                                <div style="display:none;">
                                                    @Html.ListBoxFor(i => i.PropertyContractImages, new SelectList(Model == null ? new List<MyERP.Models.PropertyContractImage>() : Model.PropertyContractImages, "Id", "Image", Model == null ? null : Model.PropertyContractImages), new { @class = "form-control1", placeholder = "Photos" })
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                @* Panel 2 *@
                                <div class="card">
                                    <div class="card-body">
                                        <div id="accordion">
                                            <h5 class=" pb-3 header-title">
                                                <a data-toggle="collapse" data-parent="#accordion" href="#collapse2">
                                                    @MyERP.Properties.Resources.PropertyData
                                                </a>
                                            </h5>
                                        </div>
                                        <div id="collapse2">


                                            <div class="form-group row ">
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.Property</label>
                                                <div class="col-sm-4">
                                                    @{
                                                        if ((Model?.Id ?? 0) > 0)
                                                        {
                                                            @Html.DropDownListFor(model => model.PropertyId, null, null, htmlAttributes: new { disabled = "disabled", @class = "form-control", required = "required" })
                                                        }
                                                        else
                                                        {
                                                            @Html.DropDownListFor(model => model.PropertyId, null, null, htmlAttributes: new {   @class = "form-control", required = "required" })
                                                        }
                                                    }

                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.Owner</label>
                                                <div class="col-sm-4">
                                                    @{
                                                        if ((Model?.Id ?? 0) > 0)
                                                        {
                                                            @Html.DropDownListFor(model => model.PropertyOwnerId, null, null, htmlAttributes: new { disabled = "disabled",@class = "form-control", required = "required" })
                                                        }
                                                        else
                                                        {
                                                            @Html.DropDownListFor(model => model.PropertyOwnerId, null, null, htmlAttributes: new {  @class = "form-control", required = "required" })
                                                        }
                                                    }

                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group row">
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.PropertyUnitType </label>
                                                <div class="col-sm-4">
                                                    @{
                                                        if ((Model?.Id ?? 0) > 0)
                                                        {
                                                            @Html.DropDownListFor(model => model.PropertyUnitTypeId, null, null, htmlAttributes: new { disabled = "disabled",@class = "form-control", required = "required" })
                                                        }
                                                        else
                                                        {
                                                            @Html.DropDownListFor(model => model.PropertyUnitTypeId, null, null, htmlAttributes: new {  @class = "form-control", required = "required" })

                                                        }
                                                    }

                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.Unit</label>
                                                <div class="col-sm-4">
                                                    @{
                                                        if ((Model?.Id ?? 0) > 0)
                                                        {
                                                            @Html.DropDownListFor(model => model.PropertyUnitId, null, null, htmlAttributes: new { disabled = "disabled", @class = "form-control", required = "required" })
                                                        }
                                                        else
                                                        {
                                                            @Html.DropDownListFor(model => model.PropertyUnitId, null, null, htmlAttributes: new {  @class = "form-control", required = "required" })
                                                        }
                                                    }
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="form-group row">
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.MergeUnits </label>
                                                <div class="col-sm-4">
                                                    <input type="checkbox" id="MergeUnits" @*@Html.Raw(Model != null && Model.MergeUnits == true ? "checked" : ""*@) />
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                                
                                                <label class="control-label col-sm-2 MergedUnitsDiv">@MyERP.Properties.Resources.MergedUnits</label>
                                                <div class="col-sm-4 MergedUnitsDiv">
                                                    @{
                                                        if ((Model?.Id ?? 0) > 0)
                                                        {
                                                            @*@Html.ListBox("MergedUnitsIds", null, new { @class = "form-control", size = 6, style = "width: 200px;" })*@


                                                        }
                                                        else
                                                        {
                                                            @Html.ListBox("MergedUnitsIds", null, new { @class = "form-control", size = 6, style = "width: 200px;" })

                                                            <!--@Html.ListBoxFor(model => model.PropertyUnitId,null, new { size = 6, style = "width: 200px;" })-->

                                                        }
                                                    }
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                @* Panel 3 *@
                                <div class="card">
                                    <div class="card-body">
                                        <div id="accordion">
                                            <h5 class=" pb-3 header-title">
                                                <a data-toggle="collapse" data-parent="#accordion" href="#collapse3">
                                                    @MyERP.Properties.Resources.ContractData
                                                </a>
                                            </h5>
                                        </div>
                                        <div id="collapse3">
                                            <div class="form-group row">
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.RentValue </label>
                                                <div class="col-sm-4">
                                                    @Html.EditorFor(model => model.RentValue, new { htmlAttributes = new { @class = "form-control money", placeholder = @MyERP.Properties.Resources.RentValue } })
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.IncludeInVAT</label>
                                                <div class="col-sm-4">
                                                    <input type="checkbox" id="IncludeRentValueInVAT" @Html.Raw(Model != null && Model.IncludeRentValueInVAT == true ? "checked" : "") />
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group row">
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.Water </label>
                                                <div class="col-sm-4">
                                                    @Html.EditorFor(model => model.WaterValue, new { htmlAttributes = new { @class = "form-control money", placeholder = @MyERP.Properties.Resources.Water } })
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.IncludeInVAT</label>
                                                <div class="col-sm-4">
                                                    <input type="checkbox" id="IncludeWaterValueInVAT" @Html.Raw(Model != null && Model.IncludeWaterValueInVAT == true ? "checked" : "") />
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group row">
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.Electricity </label>
                                                <div class="col-sm-4">
                                                    @Html.EditorFor(model => model.ElectricityValue, new { htmlAttributes = new { @class = "form-control money", placeholder = @MyERP.Properties.Resources.Electricity } })
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.IncludeInVAT</label>
                                                <div class="col-sm-4">
                                                    <input type="checkbox" id="IncludeElectricityValueInVAT" @Html.Raw(Model != null && Model.IncludeElectricityValueInVAT == true ? "checked" : "") />
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group row">
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.Gas </label>
                                                <div class="col-sm-4">
                                                    @Html.EditorFor(model => model.GasValue, new { htmlAttributes = new { @class = "form-control money", placeholder = @MyERP.Properties.Resources.Gas } })
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.IncludeInVAT</label>
                                                <div class="col-sm-4">
                                                    <input type="checkbox" id="IncludeGasValueInVAT" @Html.Raw(Model != null && Model.IncludeGasValueInVAT == true ? "checked" : "") />
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group row">
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.Services </label>
                                                <div class="col-sm-4">
                                                    @Html.EditorFor(model => model.ServicesValue, new { htmlAttributes = new { @class = "form-control money", placeholder = @MyERP.Properties.Resources.Services } })
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.IncludeInVAT</label>
                                                <div class="col-sm-4">
                                                    <input type="checkbox" id="IncludeServicesValueInVAT" @Html.Raw(Model != null && Model.IncludeServicesValueInVAT == true ? "checked" : "") />
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group row">
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.PropertyCommission </label>
                                                <div class="col-sm-4">
                                                    @Html.EditorFor(model => model.CommissionValue, new { htmlAttributes = new { @class = "form-control money", placeholder = @MyERP.Properties.Resources.PropertyCommission } })
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.IncludeInVAT</label>
                                                <div class="col-sm-4">
                                                    <input type="checkbox" id="IncludeCommissionValueInVAT" @Html.Raw(Model != null && Model.IncludeCommissionValueInVAT == true ? "checked" : "") />
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group row">
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.Insurance </label>
                                                <div class="col-sm-4">
                                                    @Html.EditorFor(model => model.InsuranceValue, new { htmlAttributes = new { @class = "form-control money", placeholder = @MyERP.Properties.Resources.Insurance } })
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                                <label class="control-label col-sm-2">@MyERP.Properties.Resources.IncludeInVAT</label>
                                                <div class="col-sm-4">
                                                    <input type="checkbox" id="IncludeInsuranceValueInVAT" @Html.Raw(Model != null && Model.IncludeInsuranceValueInVAT == true ? "checked" : "") />
                                                    <div class="invalid-feedback">
                                                        @MyERP.Properties.Resources.Required
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="form-group row">
                                        <div class="form-group col-sm-3">
                                            <label class="control-label  col-sm-12">@MyERP.Properties.Resources.Net:</label>
                                            <div class="col-sm-12">
                                                @Html.EditorFor(model => model.NetTotal, new { htmlAttributes = new { @class = "form-control money", type = "text", value = "0" } })
                                                <div class="invalid-feedback">
                                                    @MyERP.Properties.Resources.Required
                                                </div>
                                            </div>
                                        </div>
                                        <div class="form-group col-sm-3">
                                            <label class="control-label col-sm-12">@MyERP.Properties.Resources.VATPercentage % :</label>
                                            <div class="col-sm-12">
                                                @Html.EditorFor(model => model.VATPercentage, new { htmlAttributes = new { @class = "form-control", type = "text", @readonly = "readonly ", value = "0" } })
                                                <div class="invalid-feedback">
                                                    @MyERP.Properties.Resources.Required
                                                </div>
                                            </div>
                                        </div>
                                        <div class="form-group col-sm-3">
                                            <label class="control-label col-sm-12">@MyERP.Properties.Resources.VATValue:</label>
                                            <div class="col-sm-12">
                                                @Html.EditorFor(model => model.VATValue, new { htmlAttributes = new { @class = "form-control money", type = "text", @readonly = "readonly ", value = "0" } })
                                                <div class="invalid-feedback">
                                                    @MyERP.Properties.Resources.Required
                                                </div>
                                            </div>
                                        </div>
                                        <div class="form-group col-sm-3">
                                            <label class="control-label  col-sm-12">@MyERP.Properties.Resources.TotalAfterTaxes:</label>
                                            <div class="col-sm-12">
                                                @Html.EditorFor(model => model.TotalAfterTaxes, new { htmlAttributes = new { @class = "form-control money", type = "text", value = "0" } })
                                                <div class="invalid-feedback">
                                                    @MyERP.Properties.Resources.Required
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class="control-label col-sm-2">@MyERP.Properties.Resources.ContractStartDate</label>
                                        <div class="col-sm-4">
                                            @Html.EditorFor(model => model.ContractStartDate, new { htmlAttributes = new { @class = "form-control Gregorian", @type = "datetime-local", @required = "required" } })
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>
                                        <label class="control-label col-sm-2">@MyERP.Properties.Resources.HijryContractStartDate  </label>
                                        <div class="col-sm-4">
                                            <input readonly type="text" id="HijryContractStartDate" class="form-control" />
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class="control-label col-sm-2">@MyERP.Properties.Resources.ContractEndDate</label>
                                        <div class="col-sm-4">
                                            @Html.EditorFor(model => model.ContractEndDate, new { htmlAttributes = new { @class = "form-control Gregorian", @type = "datetime-local", @required = "required" } })
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>
                                        <label class="control-label col-sm-2">@MyERP.Properties.Resources.HijryContractEndDate  </label>
                                        <div class="col-sm-4">
                                            <input readonly type="text" id="HijryContractEndDate" class="form-control" />
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label for="ContractPeriodNum" class="control-label col-sm-2">@MyERP.Properties.Resources.ContractPeriod</label>
                                        <div class="col-sm-1">
                                            @Html.EditorFor(model => model.ContractPeriodNum, new { htmlAttributes = new { @class = "form-control", @required = "required", @type = "text" } })
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>
                                        <div class="col-sm-3">
                                            @Html.DropDownListFor(model => model.ContractPeriodTypeId, null, null, htmlAttributes: new { @class = "form-control", required = "required" })
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>
                                        <label class="control-label col-sm-2">@MyERP.Properties.Resources.GracePeriod</label>
                                        <div class="col-sm-1">
                                            @Html.EditorFor(model => model.GracePeriodDay, new { htmlAttributes = new { @class = "form-control", @type = "text" } })
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>
                                        <span class="font-20 col-sm-1">  @MyERP.Properties.Resources.Day  </span>

                                        <div class="col-sm-1">
