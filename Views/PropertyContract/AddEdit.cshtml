                HijryBatchDate + '</label ></td><td class="tabledit-edit-mode"><input type="number" step="any" class="BatchRentValue form-control tabledit-input form-control-sm" value="' +
                BatchRentValue + '" disabled readonly /></td><td class="tabledit-edit-mode"><input type="number" step="any" class="BatchRentValueTaxes form-control tabledit-input form-control-sm" value="' +
                BatchRentValueTaxes + '" disabled readonly /></td><td class="tabledit-edit-mode"><input type = "number" class="BatchWaterValue form-control tabledit-input form-control-sm" value = "' +
                BatchWaterValue + '" disabled readonly /></td><td class="tabledit-edit-mode"><input type="number" step="any" class="BatchWaterValueTaxes form-control tabledit-input form-control-sm" value="' +
                BatchWaterValueTaxes + '" disabled readonly /></td><td class="tabledit-edit-mode"><input type="number" step="any" class="BatchElectricityValue form-control tabledit-input form-control-sm" value="' +
                BatchElectricityValue + '" disabled readonly /></td><td class="tabledit-edit-mode"><input type="number" step="any" class="BatchElectricityValueTaxes form-control tabledit-input form-control-sm" value="' +
