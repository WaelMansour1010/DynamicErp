    function CalculateDeficiencyAndExtraDaysTotals() {


        // 0) إجمالى المتبقى والتأمين من الصفوف الظاهرة فقط
        // =========================================
        var totalRemain = 0;
        var totalInsurance = 0;

        // نجمع فقط من الصفوف الظاهرة (مش المخفية)
        $('#PropertyContractTerminationDetails tr:visible').each(function () {
            var tr = $(this);

            // جمع إجمالى المتبقى
            var remainText = tr.find('label.Remain').text().trim();
            var remain = parseFloat(remainText || 0);
            if (!isNaN(remain)) totalRemain += remain;

            // جمع التأمين
            var insuranceText = tr.find('label.BatchInsuranceValue').text().trim();
            var insurance = parseFloat(insuranceText || 0);
            if (!isNaN(insurance)) totalInsurance += insurance;
        });

        $('#TotalUnpaidAmount').val(totalRemain.toFixed(2));
        $('#InsuranceAmount').val(totalInsurance.toFixed(2));
        $('#RenterBalance').val(renterBalance.toFixed(2)); // لو عندك منطق للرصد
        $('#CalculationMethod').val(calculationMethod);

        // =========================================
        // 1) لو مفيش تاريخ تصفية → صفّر الأيام وارجع
        // =========================================
        var termStr = $('#TerminationDate').val();
        if (!termStr) {
            $('#IncreaseDaysNo').val(0);
            $('#IncreaseDaysTotalValue').val(0);
            $('#DeficientDaysNo').val(0);
            $('#DeficientDaysTotalValue').val(0);
            return;
        }

        var terminationDate = new Date(termStr);
        var ONE_DAY = 1000 * 60 * 60 * 24;

        // نجمع بيانات الدفعات من الجريد الظاهر
        var details = [];
        $('#PropertyContractTerminationDetails tr').each(function () {
            var tr = $(this);
            var batchDate = tr.find('.BatchDate').val();

            if (batchDate) {
                details.push({
                    BatchDate: batchDate,
                    Remain: parseFloat(tr.find('.Remain').text() || 0)
                });
            }
        });

        // نرتب الدفعات حسب التاريخ
        details.sort(function (a, b) {
            return new Date(a.BatchDate) - new Date(b.BatchDate);
        });

        // ==============================
        // 2) حساب أيام الزيادة (Extra)
        // ==============================
        var totalExtraDays = 0;

        // نجيب أول دفعة غير مسددة قبل/عند تاريخ التصفية
        var startIndexExtra = -1;
        for (var i = 0; i < details.length; i++) {
            var remain = details[i].Remain;
            var bd = new Date(details[i].BatchDate);

            if (remain > 0 && bd <= terminationDate) {
                startIndexExtra = i;
                break;
            }
        }

        if (startIndexExtra !== -1) {
            for (var i = startIndexExtra; i < details.length; i++) {
                var currentDate = new Date(details[i].BatchDate);
                var nextDate = (i + 1 < details.length)
                    ? new Date(details[i + 1].BatchDate)
                    : null;

                if (nextDate && terminationDate >= nextDate) {
                    var fullPeriodDays = Math.round((nextDate - currentDate) / ONE_DAY);
                    if (fullPeriodDays > 0) totalExtraDays += fullPeriodDays;
                } else {
                    if (terminationDate > currentDate) {
                        var partialDays = Math.round((terminationDate - currentDate) / ONE_DAY);
                        if (partialDays > 0) totalExtraDays += partialDays;
                    }
                    break;
                }
            }
        }

        $('#IncreaseDaysNo').val(totalExtraDays);
        var incDayValue = parseFloat($('#IncreaseDayValue').val() || 0);
        var totalIncreaseValue = totalExtraDays * incDayValue;
        $('#IncreaseDaysTotalValue').val(totalIncreaseValue.toFixed(2));

        // ==============================
        // 3) حساب أيام النقص (Deficiency)
        // ==============================
        var contractEndStr = $('#ContractEndDate').val() || $('#ContractEndDateStr').val();
        var contractEndDate = contractEndStr ? new Date(contractEndStr) : null;

        var totalDeficiencyDays = 0;

        if (!contractEndDate || terminationDate >= contractEndDate) {
            $('#DeficientDaysNo').val(0);
            $('#DeficientDaysTotalValue').val(0);
            return;
        }

        var futureUnpaid = details.filter(function (d) {
            var remain = d.Remain;
            var bd = new Date(d.BatchDate);
            return remain > 0 && bd > terminationDate && bd < contractEndDate;
        });

        if (!futureUnpaid.length) {
            var defDaysSimple = Math.round((contractEndDate - terminationDate) / ONE_DAY);
            if (defDaysSimple < 0) defDaysSimple = 0;

            $('#DeficientDaysNo').val(defDaysSimple);
            var defDayValueSimple = parseFloat($('#DeficientDayValue').val() || 0);
            $('#DeficientDaysTotalValue').val((defDaysSimple * defDayValueSimple).toFixed(2));
            return;
        }

        futureUnpaid.sort(function (a, b) {
            return new Date(a.BatchDate) - new Date(b.BatchDate);
        });

        for (var j = 0; j < futureUnpaid.length; j++) {
            var start = (j === 0)
                ? terminationDate
                : new Date(futureUnpaid[j].BatchDate);

            var end;
            if (j + 1 < futureUnpaid.length) {
                end = new Date(futureUnpaid[j + 1].BatchDate);
            } else {
                end = contractEndDate;
            }

            if (end > start) {
                var days = Math.round((end - start) / ONE_DAY);
                if (days > 0) totalDeficiencyDays += days;
            }
        }

        $('#DeficientDaysNo').val(totalDeficiencyDays);
        var defDayValue = parseFloat($('#DeficientDayValue').val() || 0);
        var totalDefValue = totalDeficiencyDays * defDayValue;
        $('#DeficientDaysTotalValue').val(totalDefValue.toFixed(2));
    }


    function CalculateDeficiencyAndExtraDaysTotalsOld() {
        var TerminationDate = new Date( $('#TerminationDate').val());
        var ContractEndDate = new Date($('#ContractEndDate').val());
        var ContractStartDate = new Date($('#ContractStartDate').val());
        var diff = 0;
        var sum = 0;
        $('#PropertyContractTerminationDetails tr').each(function () {
            sum += parseFloat($(this).find('.Remain').text());
        });
        if (TerminationDate <= ContractEndDate) { // Deficiency Days
            $('#DecreaseDaysTotalValue').val(sum.toFixed(2));
            if ($('#ContractEndDate').val() != null) {
                if (TerminationDate.getFullYear() == ContractEndDate.getFullYear() && TerminationDate.getMonth() + 1 <= ContractEndDate.getMonth() + 1) {
                    diff = Math.round((TerminationDate - ContractEndDate) / (1000 * 60 * 60 * 24))
                }
                else if (TerminationDate.getFullYear() < ContractEndDate.getFullYear()) {
                    diff = Math.round((ContractEndDate - TerminationDate) / (1000 * 60 * 60 * 24))
                }
                $('#DecreaseDaysNo').val(diff.toFixed(2));
                var DayValue = (sum.toFixed(2) / diff)
                $('#DecreaseDayValue').val(DayValue.toFixed(2));
            }
            $('#IncreaseDaysNo').val('');
            $('#IncreaseDayValue').val('');
            $('#IncreaseDaysTotalValue').val('');
        }
        else if (ContractEndDate <= TerminationDate) { //Extra Days
            $('#IncreaseDaysTotalValue').val(sum.toFixed(2));
            if ($('#ContractEndDate').val() != null) {
                diff = Math.round((ContractEndDate - ContractStartDate) / (1000 * 60 * 60 * 24))
                $('#IncreaseDaysNo').val(diff.toFixed(2));
                var DayValue = (sum.toFixed(2) / diff)
                $('#IncreaseDayValue').val(DayValue.toFixed(2));
            }
            $('#DecreaseDaysNo').val('');
            $('#DecreaseDayValue').val('');
            $('#DecreaseDaysTotalValue').val('');
        }
    }

