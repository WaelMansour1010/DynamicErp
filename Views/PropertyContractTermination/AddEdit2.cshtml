    function SearchPropertyContract() {
        var searchText = $('#searchText').val();

        // الحصول على تاريخ التصفية وطريقة الحساب
        var terminationDate = $('#TerminationDate').val();
        var calculationMethod = $('#CalculationMethod').val();
        var useContractEndDate = (calculationMethod === 'ContractEndDate');

        if (!searchText || searchText.trim().length < 2) {
            Swal.fire({
                icon: 'warning',
                title: 'تنبيه',
                text: 'من فضلك أدخل على الأقل حرفين للبحث'
            });
            return;
        }

        $.ajax({
            url: '/PropertyContractTermination/GetPropertyContractTerminationDetails',
            type: 'GET',
            data: {
                searchText: searchText,
                terminationDate: terminationDate,
                useContractEndDate: useContractEndDate
            },
            success: function (data) {
                if (data && data.length > 0) {
                    $('.SearchResult').show();

                    var result = data[0]; // أول نتيجة

                    // ملء البيانات الأساسية
                    $('#ContractNo').val(result.ContractNo);
                    $('#ContractId').val(result.ContractId);
                    $('#UnifiedContractNumber').val(result.UnifiedContractNumber);
                    $('#Renter').val(result.Renter);
                    $('#RenterId').val(result.RenterId);
                    $('#Property').val(result.Property);
                    $('#PropertyId').val(result.PropertyId);
                    $('#UnitType').val(result.UnitType);
                    $('#UnitTypeId').val(result.UnitTypeId);
                    $('#UnitCode').val(result.UnitCode);
                    $('#UnitId').val(result.UnitId);

                    // عرض معلومات الأيام الزيادة والنقص
                    $('#IncreaseDaysNo').val(result.IncreaseDays);
                    $('#IncreaseDayValue').val(result.DailyRate.toFixed(2));
                    $('#IncreaseDaysTotalValue').val(result.IncreaseAmount.toFixed(2));

                    $('#DecreaseDaysNo').val(result.DecreaseDays);
                    $('#DecreaseDayValue').val(result.DailyRate.toFixed(2));
                    $('#DecreaseDaysTotalValue').val(result.DecreaseAmount.toFixed(2));

                    // ملء جدول الدفعات
                    $('#PropertyContractTerminationDetails').empty();

                    if (result.Details && result.Details.length > 0) {
                        result.Details.forEach(function (batch, index) {
                            var row = '<tr>' +
                                '<td class="tabledit-edit-mode">' +
                                '<input type="hidden" class="PropertyContractBatchId" value="' + batch.PropertyContractBatchId + '" />' +
                                '<input type="hidden" class="PropertyContractId" value="' + batch.PropertyContractId + '" />' +
                                '<label class="DetailSequenceNo control-label">' + (index + 1) + '</label>' +
                                '</td>' +
                                '<td class="tabledit-edit-mode">' +
                                '<input type="date" class="BatchDate Gregorian form-control form-control-sm" value="' + formatDate(batch.BatchDate) + '" disabled readonly />' +
                                '</td>' +
                                '<td class="tabledit-edit-mode">' +
                                '<label class="HijryBatchDate control-label"></label>' +
                                '</td>' +
                                '<td class="tabledit-edit-mode">' +
                                '<label class="BatchRentValue control-label">' + batch.BatchRentValue.toFixed(2) + '</label>' +
                                '</td>' +
                                '<td class="tabledit-edit-mode">' +
                                '<label class="BatchWaterValue control-label">' + batch.BatchWaterValue.toFixed(2) + '</label>' +
                                '</td>' +
                                '<td class="tabledit-edit-mode">' +
                                '<label class="BatchElectricityValue control-label">' + batch.BatchElectricityValue.toFixed(2) + '</label>' +
                                '</td>' +
                                '<td class="tabledit-edit-mode">' +
                                '<label class="BatchCommissionValue control-label">' + batch.BatchCommissionValue.toFixed(2) + '</label>' +
                                '</td>' +
                                '<td class="tabledit-edit-mode">' +
                                '<label class="BatchServicesValue control-label">' + batch.BatchServicesValue.toFixed(2) + '</label>' +
                                '</td>' +
                                '<td class="tabledit-edit-mode">' +
                                '<label class="BatchInsuranceValue control-label">' + batch.BatchInsuranceValue.toFixed(2) + '</label>' +
                                '</td>' +
                                '<td class="tabledit-edit-mode">' +
                                '<label class="Remain control-label">' + batch.Remain.toFixed(2) + '</label>' +
                                '</td>' +
                                '<td class="tabledit-edit-mode">' +
                                '<label class="TotalRemain control-label">' + batch.Remain.toFixed(2) + '</label>' +
                                '</td>' +
                                '</tr>'
                            if (result.IncreaseDays > 0 || result.DecreaseDays > 0) {
                                var adjustmentType = result.IncreaseDays > 0 ? 'أيام زيادة' : 'أيام نقص';
                                var adjustmentDays = result.IncreaseDays > 0 ? result.IncreaseDays : result.DecreaseDays;
                                var adjustmentAmount = result.IncreaseDays > 0 ? result.IncreaseAmount : (-1 * result.DecreaseAmount);

                                var adjustmentRow = '<tr style="background-color: #fff3cd;">' +
                                    '<td class="tabledit-edit-mode">' +
                                    // ⭐ PropertyContractBatchId = 0 للسطر المحسوب
                                    '<input type="hidden" class="PropertyContractBatchId" value="0" />' +
                                    '<input type="hidden" class="PropertyContractId" value="' + result.ContractId + '" />' +
                                    '<label class="DetailSequenceNo control-label">' + (result.Details.length + 1) + '</label>' +
                                    '</td>' +
                                    '<td class="tabledit-edit-mode">' +
                                    '<input type="date" class="BatchDate Gregorian form-control form-control-sm" value="' + formatDate(result.CalculationEndDate) + '" disabled readonly />' +
                                    '</td>' +
                                    '<td class="tabledit-edit-mode">' +
                                    '<label class="HijryBatchDate control-label"></label>' +
                                    '</td>' +
                                    '<td class="tabledit-edit-mode" colspan="6">' +
                                    '<label class="control-label text-center" style="width:100%; font-weight:bold;">' +
                                    adjustmentType + ' (' + adjustmentDays + ' يوم × ' + result.DailyRate.toFixed(2) + ')' +
                                    '</label>' +
                                    '</td>' +
                                    '<td class="tabledit-edit-mode">' +
                                    // ⭐ labels مخفية للقيم الصفرية
                                    '<label class="BatchRentValue control-label" style="display:none;">0</label>' +
                                    '<label class="BatchWaterValue control-label" style="display:none;">0</label>' +
                                    '<label class="BatchElectricityValue control-label" style="display:none;">0</label>' +
                                    '<label class="BatchCommissionValue control-label" style="display:none;">0</label>' +
                                    '<label class="BatchServicesValue control-label" style="display:none;">0</label>' +
                                    '<label class="BatchInsuranceValue control-label" style="display:none;">0</label>' +
                                    '<label class="Remain control-label">' + adjustmentAmount.toFixed(2) + '</label>' +
                                    '</td>' +
                                    '<td class="tabledit-edit-mode">' +
                                    '<label class="TotalRemain control-label">' + adjustmentAmount.toFixed(2) + '</label>' +
                                    '</td>' +
                                    '</tr>';

                                $('#PropertyContractTerminationDetails').append(adjustmentRow);
                            }
                        
                                //;


                            $('#PropertyContractTerminationDetails').append(row);
                        });
                    }

                    // حساب الإجماليات
                    calculateTotals();

                    Swal.fire({
                        icon: 'success',
                        title: 'تم العثور على العقد',
                        text: 'تم تحميل بيانات العقد بنجاح',
                        timer: 2000
                    });
                } else {
                    Swal.fire({
                        icon: 'info',
                        title: 'لا توجد نتائج',
                        text: 'لم يتم العثور على أي عقد يطابق البحث'
                    });
                }
            },
            error: function (xhr, status, error) {
                Swal.fire({
                    icon: 'error',
                    title: 'خطأ',
                    text: 'حدث خطأ أثناء البحث: ' + error
                });
            }
        });
    }

    // دالة مساعدة لتنسيق التاريخ
    function formatDate(dateString) {
        if (!dateString) return '';
        var date = new Date(dateString);
        var day = ('0' + date.getDate()).slice(-2);
        var month = ('0' + (date.getMonth() + 1)).slice(-2);
        var year = date.getFullYear();
        return year + '-' + month + '-' + day;
    }

    // دالة لحساب الإجماليات
    function calculateTotals() {
        var totalRent = 0;
        var totalWater = 0;
        var totalElectricity = 0;
        var totalServices = 0;
        var totalCommission = 0;
        var totalInsurance = 0;
        var grandTotal = 0;

        $('#PropertyContractTerminationDetails tr').each(function () {
            var rent = parseFloat($(this).find('.BatchRentValue').text()) || 0;
            var water = parseFloat($(this).find('.BatchWaterValue').text()) || 0;
            var electricity = parseFloat($(this).find('.BatchElectricityValue').text()) || 0;
            var commission = parseFloat($(this).find('.BatchCommissionValue').text()) || 0;
            var services = parseFloat($(this).find('.BatchServicesValue').text()) || 0;
            var insurance = parseFloat($(this).find('.BatchInsuranceValue').text()) || 0;
            var remain = parseFloat($(this).find('.Remain').text()) || 0;

            totalRent += rent;
            totalWater += water;
            totalElectricity += electricity;
            totalServices += services;
            totalCommission += commission;
            totalInsurance += insurance;

            var rowTotal = remain;
            $(this).find('.TotalRemain').text(rowTotal.toFixed(2));
            grandTotal += rowTotal;
        });

        // تحديث الإجماليات في الفوتر
        $('#TotalRent').text(totalRent.toFixed(2));
        $('#TotalWater').text(totalWater.toFixed(2));
        $('#TotalElectricity').text(totalElectricity.toFixed(2));
        $('#TotalServices').text(totalServices.toFixed(2));
        $('#TotalCommission').text(totalCommission.toFixed(2));
        $('#TotalInsurance').text(totalInsurance.toFixed(2));
        $('#GrandTotal').text(grandTotal.toFixed(2));
    }





    $('#CalculationMethod').on('change', function () {
        var method = $(this).val();

        var text = method === '2'
            ? 'سيتم الحساب بناءً على نهاية العقد'
            : 'سيتم الحساب بناءً على تاريخ التصفية';
        $('#CalculationMethodInfo').text(text);

        if (method === '2') {
            var contractEndDate = $('#ContractEndDate').val();
            if (contractEndDate) {
                $('#TerminationDate').val(contractEndDate);
                if (selectedContractId) {
                    RefreshContractData()
                        .then(function () {
                            setTimeout(function () {
                                CalculateDeficiencyAndExtraDaysTotals();
                            }, 150);
                        })
                        .catch(function (error) {
                            console.error('خطأ في تحديث البيانات:', error);
                            Swal.fire({
                                icon: 'error',
                                title: 'خطأ',
                                text: 'لقد حدث خطأ أثناء تحديث البيانات. الرجاء المحاولة مرة أخرى.',
                                timer: 3000
                            });
                        });
                }
            }
        } else {
            if (selectedContractId) {
                RefreshContractData()
                    .then(function () {
                        setTimeout(function () {
                            CalculateDeficiencyAndExtraDaysTotals();
                        }, 150);
                    })
                    .catch(function (error) {
                        console.error('خطأ في تحديث البيانات:', error);
                        Swal.fire({
                            icon: 'error',
                            title: 'خطأ',
                            text: 'لقد حدث خطأ أثناء تحديث البيانات. الرجاء المحاولة مرة أخرى.',
                            timer: 3000
                        });
                    });
            }
        }
    });
</script>