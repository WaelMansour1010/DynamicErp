    function RefreshContractData() {
        // تأكد من وجود عقد مختار
        if (!selectedContractId) {
            return Promise.reject('لا يوجد عقد مختار');
        }

        var searchText = $('#searchText').val() || '';
        var terminationDate = $('#TerminationDate').val();
        var calculationMethod = $('#CalculationMethod').val();
        var useContractEndDate = (calculationMethod === '2');

        // تحديث الـ loader
        $('#preloader, #status').fadeIn();

        return $.ajax({
            url: '/PropertyContractTermination/GetPropertyContractTerminationDetails',
            type: 'GET',
            data: {
                searchText: searchText,
                terminationDate: terminationDate,
                useContractEndDate: useContractEndDate
            },
            error: function (xhr, status, error) {
                console.error('خطأ في AJAX:', error);
                Swal.fire({
                    icon: 'error',
                    title: 'خطأ',
                    text: 'حدث خطأ أثناء تحديث البيانات: ' + error,
                    timer: 2000
                });
                return Promise.reject(error);
            }
        }).then(function (data) {
            if (data && data.length > 0) {
                ContractDetails = data;
                AddToDetails(selectedContractId);
                console.log('تم تحديث بيانات العقد بنجاح');
                return data;
            } else {
                Swal.fire({
                    icon: 'warning',
                    title: 'تحذير',
                    text: 'لم يتم العثور على بيانات محدثة',
                    timer: 2000
                });
                return Promise.reject('No data found');
            }
        }).always(function () {
            $('#preloader, #status').fadeOut();
        });
    }


    // ========== 6. إضافة دالتي OnCalculationMethodChange و OnTerminationDateChange ===========
    // أضف هاتين الدالتين:


    function OnCalculationMethodChange() {
        var method = $('#CalculationMethod').val();

        // تحديث النص التوضيحي
        if (method == '1') {
            $('#CalculationMethodInfo').text('سيتم الحساب بناءً على تاريخ التصفية');
        } else if (method == '2') {
            $('#CalculationMethodInfo').text('سيتم الحساب بناءً على نهاية العقد');
        }

        // إعادة تحميل البيانات إذا كان هناك عقد مختار
        if (selectedContractId) {
            RefreshContractData().then(function () {
                setTimeout(function () {
                    CalculateDeficiencyAndExtraDaysTotals();
                }, 150);
            });
        }
    }

    function OnTerminationDateChange() {
