    function AddToDetails(contractId) {
        $('#preloader, #status').fadeIn();
        $('#PropertyContractTerminationDetails').empty();

        selectedContractId = contractId;
        $('#SelectedContractId').val(contractId);

        var contract = ContractDetails.filter(function (i) { return i.ContractId == contractId })[0];
        if (contract != null) {
            console.log(contract);
            $('#SearchModal').modal('hide');
            $('.SearchResult').show();

            // ملء البيانات الأساسية
            $('#ContractId').val(contract.ContractId);
            contract.ContractEndDate = contract.ContractEndDate != null ? convertToJavaScriptDate(contract.ContractEndDate) : '';
            contract.ContractStartDate = contract.ContractStartDate != null ? convertToJavaScriptDate(contract.ContractStartDate) : '';
            $('#ContractEndDate').val(contract.ContractEndDate);
            $('#ContractStartDate').val(contract.ContractStartDate);
            $('#ContractNo').val(contract.ContractNo);
            $('#UnifiedContractNumber').val(contract.UnifiedContractNumber);
            $('#PropertyId').val(contract.PropertyId);
            $('#Property').val(contract.Property);
            $('#RenterId').val(contract.RenterId);
            $('#Renter').val(contract.Renter);
            $('#UnitId').val(contract.UnitId);
            $('#UnitCode').val(contract.UnitCode);
            $('#UnitTypeId').val(contract.UnitTypeId);
            $('#UnitType').val(contract.UnitType);

            // ✅ ملء خانات أيام الزيادة/النقص (بدلاً من إضافة دفعة)
            $('#IncreaseDaysNo').val(contract.IncreaseDays || 0);
            $('#IncreaseDayValue').val((contract.IncreaseDayValue || contract.DailyRate || 0).toFixed(2));
            $('#IncreaseDaysTotalValue').val((contract.IncreaseDaysTotalValue || contract.IncreaseAmount || 0).toFixed(2));

            $('#DecreaseDaysNo').val(contract.DecreaseDays || 0);
            $('#DecreaseDayValue').val((contract.DecreaseDayValue || contract.DailyRate || 0).toFixed(2));
            $('#DecreaseDaysTotalValue').val((contract.DecreaseDaysTotalValue || contract.DecreaseAmount || 0).toFixed(2));

            // ✅ ملء الحقول الجديدة
            $('#TotalUnpaidAmount').val((contract.TotalUnpaidAmount || 0).toFixed(2));
            $('#InsuranceAmount').val((contract.InsuranceAmount || 0).toFixed(2));
            $('#RenterBalance').val((contract.RenterBalance || 0).toFixed(2));

            // تاريخ آخر دفعة
            if (contract.LastBatchDueDate) {
                var lastBatchDate = convertToJavaScriptDate(contract.LastBatchDueDate);
                $('#LastBatchDate').val(lastBatchDate);
            }

            // ملء الوحدات المدمجة
            var mergedUnitsSelect = $('#selectedMergedUnits');
            mergedUnitsSelect.empty();
            if (contract.MergedUnits && contract.MergedUnits.length > 0) {
                contract.MergedUnits.forEach(function (item) {
                    mergedUnitsSelect.append(
                        $('<option>', {
                            value: item.PropertyUnitNo,
                            text: item.PropertyUnitNo,
                            selected: true
                        })
                    );
                });
            }
            mergedUnitsSelect.prop('disabled', true).trigger('change.select2');

            // ✅ ملء جدول الدفعات (بدون الدفعة الإضافية)
            if (contract.Details && contract.Details.length > 0) {
                for (var i = 0; i < contract.Details.length; i++) {
                    var detail = contract.Details[i];

                    // ⚠️ نتجاهل الدفعات الجزئية (IsPartialBatch)
                    // لأن أيام الزيادة/النقص هتكون في الهيدر
                    if (detail.IsPartialBatch === true) {
                        console.log('تم تجاهل الدفعة الجزئية رقم: ' + detail.BatchNo);
                        continue; // نتخطى هذه الدفعة
                    }

                    detail.BatchDate = detail.BatchDate != null ? convertToJavaScriptDate(detail.BatchDate) : "";
                    var HijryBatchDate = new Intl.DateTimeFormat('ar-sa').format(new Date(detail.BatchDate)).toString();
                    detail.UnitNo = detail.UnitNo != null ? detail.UnitNo : "";

                    let tr = '<tr>' +
                        '<td class="tabledit-edit-mode">' +
                        '<input hidden class="PropertyContractBatchId" value="' + (detail.PropertyContractBatchId || 0) + '"/>' +
                        '<input hidden class="PropertyContractId" value="' + (detail.PropertyContractId || 0) + '"/>' +
                        '<label class="DetailSequenceNo control-label">' + (detail.BatchNo || '') + '</label>' +
                        '</td>' +
                        '<td class="tabledit-edit-mode">' +
                        '<input type="date" class="BatchDate Gregorian form-control tabledit-input form-control-sm" ' +
                        'value="' + detail.BatchDate + '" disabled readonly />' +
                        '</td>' +
                        '<td class="tabledit-edit-mode">' +
                        '<label class="HijryBatchDate control-label">' + HijryBatchDate + '</label>' +
                        '</td>' +
                        '<td class="tabledit-edit-mode">' +
                        '<label class="BatchRentValue control-label">' + (detail.BatchRentValue || 0).toFixed(2) + '</label>' +
                        '</td>' +
                        '<td class="tabledit-edit-mode">' +
                        '<label class="BatchWaterValue control-label">' + (detail.BatchWaterValue || 0).toFixed(2) + '</label>' +
                        '</td>' +
                        '<td class="tabledit-edit-mode">' +
                        '<label class="BatchElectricityValue control-label">' + (detail.BatchElectricityValue || 0).toFixed(2) + '</label>' +
                        '</td>' +
                        '<td class="tabledit-edit-mode">' +
                        '<label class="BatchCommissionValue control-label">' + (detail.BatchCommissionValue || 0).toFixed(2) + '</label>' +
                        '</td>' +
                        '<td class="tabledit-edit-mode">' +
                        '<label class="BatchServicesValue control-label">' + (detail.BatchServicesValue || 0).toFixed(2) + '</label>' +
                        '</td>' +
                        '<td class="tabledit-edit-mode">' +
                        '<label class="BatchInsuranceValue control-label">' + (detail.BatchInsuranceValue || 0).toFixed(2) + '</label>' +
                        '</td>' +
                        '<td class="tabledit-edit-mode">' +
                        '<label class="Remain control-label">' + (detail.Remain || 0).toFixed(2) + '</label>' +
                        '</td>' +
                        '<td class="tabledit-edit-mode">' +
                        '<label class="TotalRemain control-label">' + (detail.Remain || 0).toFixed(2) + '</label>' +
