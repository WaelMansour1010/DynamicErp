@model MyERP.Models.PropertyRenter
<script src="~/Scripts/SaveAndNew.js"></script>
<script src="~/js/DeleteFunctionForAddEditView.js"></script>

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.title = MyERP.Properties.Resources.Renters;
}

@Html.AntiForgeryToken()

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                @if (Model != null)
                {
                    if (Model.IsDeleted == false)
                    {
                        if (ViewBag.Previous > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.First })" class="btn btn-info">@MyERP.Properties.Resources.First</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Previous })" class=" btn btn-info">&#8250;</a>
                        }
                        if (ViewBag.Next > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Next })" class="btn btn-info">&#8249;</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Last })" class="btn btn-info">@MyERP.Properties.Resources.Last</a>
                        }
                        <a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                    }
                }
                else
                {<a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>}
            </div>
            <h4 class="page-title">@MyERP.Properties.Resources.Renters</h4>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="form-horizontal needs-validation" role="form">
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">
                                <div class="form-group row">
                                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                    @Html.AntiForgeryToken()
                                    @if (Model != null)
                                    {

                                        @Html.HiddenFor(model => model.Id)
                                        @Html.HiddenFor(model => model.IsActive)
                                        @Html.HiddenFor(model => model.UserId)
                                        @Html.HiddenFor(model => model.Image)
                                        @Html.HiddenFor(model => model.IsDeleted)
                                    }

                                    <label for="Code" class="col-sm-2 control-label">@MyERP.Properties.Resources.Code</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.Code, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.Code, @readonly = "readonly", required = "required" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label for="DepartmentId" class="col-sm-2 control-label"> @MyERP.Properties.Resources.Department </label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("DepartmentId", null, null, htmlAttributes: new { @class = "form-control", @required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="DepartmentId" class="col-sm-2 control-label"> @MyERP.Properties.Resources.RenterType </label>
                                    <div class="col-sm-4">
                                        @Html.DropDownListFor(model => model.RenterTypeId, null, null, htmlAttributes: new { @class = "form-control" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.RegistrationDate</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.RegistrationDate, new { htmlAttributes = new { @class = "form-control", @type = "datetime-local", @required = "required" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="ArName" class="col-sm-2 control-label">@MyERP.Properties.Resources.ArName</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.ArName, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.ArName, required = "required" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label for="EnName" class="col-sm-2 control-label">@MyERP.Properties.Resources.EnName</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.EnName, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.EnName } })
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="EnName" class="col-sm-2 control-label">@MyERP.Properties.Resources.NationalID</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.NationalNo, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.NationalID } })
                                    </div>
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.NationalExpiryDate</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.NationalExpiryDate, new { htmlAttributes = new { @class = "form-control", @type = "datetime-local" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="control-label col-sm-2">@MyERP.Properties.Resources.BirthDate</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.Birthdate, new { htmlAttributes = new { @class = "form-control", @type = "datetime-local" } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label for="EnName" class="col-sm-2 control-label">@MyERP.Properties.Resources.ContactPersonName</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.ContactPerson, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.ContactPersonName } })
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="EnName" class="col-sm-2 control-label">@MyERP.Properties.Resources.Mobile</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.Mobile, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.Mobile } })
                                    </div>
                                    <label for="EnName" class="col-sm-2 control-label">@MyERP.Properties.Resources.Tel</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.Phone, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.Tel } })
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="EnName" class="col-sm-2 control-label">@MyERP.Properties.Resources.Email</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.Email, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.Email } })
                                    </div>
                                    <label for="EnName" class="col-sm-2 control-label">@MyERP.Properties.Resources.Fax</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.Fax, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.Fax } })
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="AccountId" class="col-sm-2 control-label"> @MyERP.Properties.Resources.Customer </label>
                                    <div class="col-sm-4">
                                        @Html.DropDownListFor(model => model.CustomerId, null, null, htmlAttributes: new { @class = "form-control" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label for="AccountId" class="col-sm-2 control-label"> @MyERP.Properties.Resources.Representative </label>
                                    <div class="col-sm-4">
                                        @Html.DropDownListFor(model => model.CustomerRepId, null, null, htmlAttributes: new { @class = "form-control" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="EnName" class="col-sm-2 control-label">@MyERP.Properties.Resources.CommercialRegistrationNo</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.RegistrationNo, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.CommercialRegistrationNo } })
                                    </div>
                                    <label for="EnName" class="col-sm-2 control-label">@MyERP.Properties.Resources.VATRegisterationNo</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.VATNo, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.VATRegisterationNo } })
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="control-label col-sm-2" for="Notes">@MyERP.Properties.Resources.Address</label>
                                    <div class="col-sm-4">
                                        <textarea id="Address" name="Address" class="form-control" rows="5" cols="5">@if (Model != null) { @Model.Address; }</textarea>
                                    </div>
                                    <label class="control-label col-sm-2" for="Notes">@MyERP.Properties.Resources.Notes</label>
                                    <div class="col-sm-4">
                                        <textarea id="Notes" name="Notes" class="form-control" rows="5" cols="5">@if (Model != null) { @Model.Notes; }</textarea>
                                    </div>
                                </div>
                                @* مكان الصورة *@
                                <div class="form-group row">
                                    <div id="gallery" style="width: 100%;margin: 20px;">
                                        @{if (Model != null && Model.PropertyRenterImages != null)
                                            {
                                                foreach (MyERP.Models.PropertyRenterImage img in Model.PropertyRenterImages)
                                                {
                                                    <img onclick="ShowModal(this)" data-toggle="modal" data-target="#ImageModal" src="@img.Image" alt="" class="img_@img.Id" style="max-width: 200px;max-height: 200px;" />
                                                    <i class="fas fa-trash-alt img_@img.Id" style="cursor:pointer;" onclick="DeleteIMG('@img.Id');$(this).prev().remove();$(this).remove();"></i>
                                                }
                                            }
                                        }
                                    </div>
                                    <input type="file" id="BrowseImage" onchange="previewFile()" value="Browse" multiple />
                                    <div style="display:none;">
                                        @Html.ListBoxFor(i => i.PropertyRenterImages, new SelectList(Model == null ? new List<MyERP.Models.PropertyRenterImage>() : Model.PropertyRenterImages, "Id", "Image", Model == null ? null : Model.PropertyRenterImages), new { @class = "form-control1", placeholder = "Photos" })
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!---------------------------------------------- Saves Buttons ----------------------------------------------------------->
                    <div class="row">
                        <div class="col-sm-offset-2">
                            @if (Model == null)
                            {
                                <button onclick="addEdit('new');" class="btn btn-success" id="newbtn">
                                    @MyERP.Properties.Resources.SaveAndNew
                                </button>
                                <button onclick="addEdit();" class="btn btn-success" id="save">
                                    @MyERP.Properties.Resources.Save
                                </button>
                                <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                            }
                            else if (Model.IsDeleted == false)
                            {
                                <button onclick="addEdit();" class="btn btn-success" id="save">
                                    @MyERP.Properties.Resources.Save
                                </button>
                                <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                                <a href="javascript:void(0);" class="btn btn-danger" onclick="Delete(@Model.Id)" role="button">@MyERP.Properties.Resources.Delete</a>
                            }
                        </div>
                    </div>
                    <!----------------------------------------------------------------------------------------------------------------------------------------->
                </div>
            </div>
        </div>
    </div>
</div>


<script>

    //---------------------------------------------------------------- images gallery  --------------------------------------------------------------//
    function DeleteIMG(url) {
        $("#PropertyRenterImages option[value='" + url + "']").remove();
    }
    function previewFile() {
        var reader = new FileReader();
        reader.addEventListener("load", function () {

            $("#gallery").append('<img style="max-width: 200px;max-height: 200px;margin-left: 2%;margin-bottom: 2%;" src="' + reader.result + '" alt="" /></a><i class="fas fa-trash-alt" style="cursor:pointer;" onclick="DeleteIMG(\'' + reader.result + '\');$(this).prev().remove();$(this).remove();"></i>');
            $("#PropertyRenterImages").append("<option style='float: left;' selected=selected>" + reader.result + "</option>");
        }, false);

        for (var i = 0; i < $("#BrowseImage")[0].files.length; i++) {
            if ($("#BrowseImage")[0].files[i]) {
                reader.readAsDataURL($("#BrowseImage")[0].files[i]);
            }
        }
    }
    $("#PropertyRenterImages option").attr('selected', 'selected');
    $("#PropertyRenterImages").hide();
    $("#GetImage").click(function () {
        $("#GetImage").fadeOut();
        $('#UploadImage').photobooth().on("image", function (event, dataUrl) {
            $("#gallery").append('<img style="max-width: 200px;max-height: 200px;margin-left: 2%;margin-bottom: 2%;" src="' + dataUrl + '" alt="" /><i class="fa fa-trash-o" style="cursor:pointer;position: absolute;" onclick="DeleteIMG("' + dataUrl + '");;$(this).prev().remove();$(this).remove();"></i>');
            $("#PropertyRenterImages").append("<option style='float: left;' selected=selected>" + dataUrl + "</option>");
        });
    });
    function ShowModal(img) {
        let ImageSelected = $(img);
        let ImageSrc = ImageSelected[0].currentSrc;
        $('#imagepreview').attr('src', ImageSrc);
    }
    //--------------------------------------------------------------------------------------------------------------------------------------------------------------------//


    $(document).ready(function () {
         $('#RegistrationDate').val('@ViewBag.RegistrationDate');
        $('#NationalExpiryDate').val('@ViewBag.NationalExpiryDate');
        $('#Birthdate').val('@ViewBag.Birthdate');

        $.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
            $("input[type|='datetime-local']").not('#Birthdate').prop('min', r.PeriodStart).prop('max', r.PeriodEnd);
        });

        if (!$('#Id').val()) {
            setCodeNum();
        }
        else {

        }
    });

    function setCodeNum() {
        var doc = $.get('/PropertyRenter/SetCodeNum?id='+$('#DepartmentId').val()).done(function (r) {
            $('#Code').val(r);
        });
    }

    $(document).on('change', '#DepartmentId', function () {
        setCodeNum();
    });

        function addEdit(n) {
        let valid = true;
        if ($('.form-horizontal').first().find('.form-control:invalid').length > 0) {
            $('.form-horizontal').first().addClass('was-validated');
            $('html, body').animate({
                scrollTop: $('.form-horizontal').first().find(".form-control:invalid").eq(0).offset().top - 100
            }, 500);
            valid = false;
            console.log($(".form-control:invalid"));
        }
        var PropertyRenterImages = [];
            if (valid) {
                $('#PropertyRenterImages option').each(function () {
                    var option = $(this);

                    var PropertyRenterImage =
                    {
                        MainDocId: $('#Id').val(),
                        Image: option.text()
                    };
                    PropertyRenterImages.push(PropertyRenterImage);
                });

            }
            var PropertyRenter = {
                Id: $('#Id').val(),
                Code: $('#Code').val(),

                ContractTypeId: $('#ContractTypeId').val(),
                PropertyId: $('#PropertyId').val(),
                RentTypeId: $('#RentTypeId').val(),
                PropertyOwnerId: $('#PropertyOwnerId').val(),
                PropertyRenterId: $('#PropertyRenterId').val(),
                DepartmentId: $('#DepartmentId').val(),
                RepId: $('#RepId').val(),
                RentValue: $('#RentValue').inputmask('unmaskedvalue'),
                ArName: $('#ArName').val(),
                EnName: $('#EnName').val(),
                DepartmentId: $('#DepartmentId').val(),
                RenterTypeId: $('#RenterTypeId').val(),
                RegistrationDate: $('#RegistrationDate').val(),
                NationalNo: $('#NationalNo').val(),
                NationalExpiryDate: $('#NationalExpiryDate').val(),
                ContactPerson: $('#ContactPerson').val(),
                CustomerId: $('#CustomerId').val(),
                CustomerRepId: $('#CustomerRepId').val(),
                JobId: $('#JobId').val(),
                RegistrationNo: $('#RegistrationNo').val(),
                VATNo: $('#VATNo').val(),
                Birthdate: $('#Birthdate').val(),
                Phone: $('#Phone').val(),
                Mobile: $('#Mobile').val(),
                Fax: $('#Fax').val(),
                Email: $('#Email').val(),
                Address: $('#Address').val(),
                IsDeleted: $('#IsDeleted').val(),
                IsActive: $('#IsActive').val(),
                UserId: $('#UserId').val(),
                Notes: $('#Notes').val(),
                Image: $('#Image').val(),
                PropertyRenterImages: PropertyRenterImages,
            }
        if (valid) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.AreYouSureYouWantToSave',
                text: " ",
                icon: 'info',
                showCancelButton: true,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                cancelButtonText: '@MyERP.Properties.Resources.Cancel',
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    $('#preloader, #status').fadeIn();
                    $('#newbtn').prop('disabled', true);
                    $('#save').prop('disabled', true);
                    $.ajax({
                        type: "POST", contentType: "application/json",
                        url: "/PropertyRenter/AddEdit",
                        data: JSON.stringify(PropertyRenter),
                        success: function (r) {
                            if (r.success == true) {
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.Saved',
                                    text: " ",
                                    icon: 'success',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                }); if (n == "new") {
                                    window.location.replace("/PropertyRenter/AddEdit");
                                } else {
                                    window.location.replace("/PropertyRenter");
                                }
                            }
                            else {
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.NotSaved !',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                            }
                            $('#preloader, #status').fadeOut();
                            $('#newbtn').prop('disabled', false);
                            $('#save').prop('disabled', false);
                        },
                        error: function (r) {
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.NotSaved !',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                            $('#preloader, #status').fadeOut();
                            $('#newbtn').prop('disabled', false);
                            $('#save').prop('disabled', false);
                        }
                    });
                }
                else { result.dismiss; }
            });
        }
    }

    function Delete(id) {
        Swal.fire({
            title: '@MyERP.Properties.Resources.AreYouSureYouWantToDelete',
            text: " ",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: '@MyERP.Properties.Resources.Ok',
            cancelButtonText: '@MyERP.Properties.Resources.Cancel',
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                $('#preloader, #status').fadeIn();
                $.ajax(
                    {
                        url: '/PropertyRenter/Delete',
                        type: 'POST',
                        data: {
                            "Id": id,
                        },
                        error: function (e) {
                            $('#preloader, #status').fadeOut();
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.DeleteDoesNotSucceeded',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                        },
                        success: function (r) {
                            if (r == 'true') {
                                window.location.replace('/PropertyRenter');
                            } else
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.DeleteDoesNotSucceeded',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                        }
                    });
            }
            else { result.dismiss; }
        });
    }

</script>