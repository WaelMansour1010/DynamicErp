    function deleteExpense(e) {
        let tr = $(e).closest('tr');
        // to set TotalItemDirectExpenses Value
        var eachAmount = parseFloat(tr.find('.TotalAmounts').text());
        total -= eachAmount;
        $('#TotalItemDirectExpenses').val(total);


        if ($(tr).index() == 0 && $(tr).closest('tbody').children('tr').length == 0) {
            $(tr).find("input").val('');

         // to set TotalItemDirectExpenses Value
            $('#TotalItemDirectExpenses').val(0);
        }
        else if ($(tr).index() < $(tr).closest('tbody').children('tr').length) {
            e.parentNode.parentNode.parentNode.removeChild(e.parentNode.parentNode);

        }
        else if ($(tr).index() == $(tr).closest('tbody').children('tr').length) {
            $(tr).find("input").val('');
            $(tr).find('input, select').removeAttr('required');
            $(tr).find('select').empty();
        }
        ReSetDetailsValues();

    }

    function CalculatetotalExp() {
        $('#PurchaseInvoiceDirectExpenses tr').each(function () {
            var td = $(this);
            var eachAmount = parseFloat(td.find('.TotalAmounts').text());
            total += eachAmount;
            $('#TotalItemDirectExpenses').val(total);
        })
    }

    function ReSetDetailsValues() {
        $('#PurchaseInvoiceDetails tr').each(function () {
            var td = $(this);
            if (td.find('.item').val() > 0) {
                if ($('#TotalItemDirectExpenses').val() > 0 && $('#Total').val() > 0) {
                    var TotalDirectExpense = $('#TotalItemDirectExpenses').val();
                    var Total = $('#Total').val();
                    var Quantity = td.find('.quantity').val();
                    var PurchasingPrice = td.find('.price ').val();
                    var CurrencyEquivalent = $(this).closest('tr').find('.CurrencyEquivalent').val();

                    // equation --->> ((TotalDirectExpense /Total ))*PurchasingPrice
                    var Equation = ((parseFloat(TotalDirectExpense) / parseFloat(Total))) * parseFloat(PurchasingPrice);
                    td.find('.ItemDirectExpenses').val(Equation);
                    td.find('.CostPrice').val(parseFloat(td.find('.ItemDirectExpenses').val()) + parseFloat(PurchasingPrice));
                    //totalPrice=purchasePrice*Quantity;
                    var totalPrice ;
                    if (UseDifferentCurrencies == 'True') {
                        totalPrice = parseFloat(PurchasingPrice) * parseFloat(Quantity) * parseFloat(CurrencyEquivalent);
                    }
                    else {
                         totalPrice = parseFloat(PurchasingPrice) * parseFloat(Quantity);
                    }
                    td.find('.total ').val(totalPrice);
                }
                else {
                    td.find('.ItemDirectExpenses').val(0);
                    td.find('.CostPrice').val(td.find('.price ').val())
                }
            }

        });
    }

