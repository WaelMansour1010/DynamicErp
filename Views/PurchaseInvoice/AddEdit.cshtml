    function getSalesInvoiceDetails(id, docNum) {
        $('#salesInvoicesModal').modal('hide');
        $('#preloader, #status').fadeIn();
        $.get('/PurchaseInvoice/SalesInvoiceDetails?id=' + id).done(function (r) {
            $('#PurchaseInvoiceDetails').empty().append(r);
            $('#PurchaseInvoiceDetails .money').inputmask({
                alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
            });
             $('#PurchaseInvoiceDetails input[type=number]').removeProp('oninput').prop('type', 'text').inputmask({
                alias: 'numeric', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
             });
            $('#PurchaseInvoiceDetails input.small-number').removeProp('oninput').prop('type', 'text').inputmask({
                alias: 'numeric', autoGroup: true, digits: 4, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
            });
            $('#PurchaseInvoiceDetails select').select2({
                matcher: matchCustom
            });
            $('.price').each(function () {
                if (UseDifferentCurrencies == 'True') {
                    $(this).closest('tr').find('.total').val($(this).inputmask('unmaskedvalue') * $(this).closest('tr').find('.quantity').inputmask('unmaskedvalue') * $(this).closest('tr').find('.CurrencyEquivalent').inputmask('unmaskedvalue'));
                }
                else {
                    $(this).closest('tr').find('.total').val($(this).inputmask('unmaskedvalue') * $(this).closest('tr').find('.quantity').inputmask('unmaskedvalue'));
                }
            });
            hideShowPrices();
            CalculateTotals();
            canAppendPurchaseInvoiceDetails = false;
            $('#SelectedId').val(id);
            $('#SystemPageId').val(58);
            $('#SalesInvoiceDocNum').text('@MyERP.Properties.Resources.SalesInvoiceNo'+" : " + docNum);
            $('#cancelSalesInvoice').show();
            $('#preloader, #status').fadeOut();
        });
    }

    function cancelSalesInvoice() {
        $('#SalesInvoiceDocNum').text('');
        $('#SelectedId').val('');
        $('#SystemPageId').val('');
        $('#cancelSalesInvoice').hide();
        canAppendPurchaseInvoiceDetails = true;
        $('#PurchaseInvoiceDetails').find('tr').not(':last').remove();
        $('#PurchaseInvoiceDetails').find('tr').find("input").val('');
        $('#PurchaseInvoiceDetails').find('tr').find('input').not('.lastPrice, .total').removeAttr('readonly');
        $('#PurchaseInvoiceDetails').find('tr').find('select').empty();
    }


