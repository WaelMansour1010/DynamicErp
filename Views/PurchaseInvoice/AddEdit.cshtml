    var ShowSerialNumbers = '@Html.Raw(ViewBag.ShowSerialNumbers)';
    var ShowSalesPrices = '@Html.Raw(ViewBag.ShowSalesPrices)';
    var PayViaCheque = '@Html.Raw(ViewBag.PayViaCheque)';
    var PayViaCarryOver = '@Html.Raw(ViewBag.PayViaCarryOver)';
    var PayViaCash = '@Html.Raw(ViewBag.PayViaCash )';
    var PayViaVisa = '@Html.Raw(ViewBag.PayViaVisa )';
    let DisplayPrice = '@ViewBag.DisplayPrice';
    var taxPercentage = 0.15;
     let warehouseOptions = '';
    let items = [];
    let custIems = [];
    let itemsOptionString = '';
    let carTypes = [];
    let carModels = [];
    let carColors = [];
    let canAppendPurchaseInvoiceDetails = true;

    let Employees = [];
    let Vendors = [];
    let DirectExpenses = [];
    let PaymentMethods = [];
    carTypes = @Html.Raw(ViewBag.CarTypesJson ?? "[]");
    carModels = @Html.Raw(ViewBag.CarModelsJson ?? "[]");
    carColors = @Html.Raw(ViewBag.CarColorsJson ?? "[]");
    let CashBoxes = [];
    var total = 0;
    let UseExpiryDateForItems = '@ViewBag.UseExpiryDateForItems';
    let UseDifferentCurrencies = '@ViewBag.UseDifferentCurrencies';
    var CustomerOrVendorCreditLimitPeriod;

   function hideShowPrices() {
        if (DisplayPrice != 'True') {
            $('.price, .lastPrice, .total, .item-details-btn').closest('td').hide();
            $('.price-th, .details-th, .totals').hide();
            $('#payment-methods').hide();
        } else {
            $('.price, .lastPrice, .total, .item-details-btn').closest('td').show();
            $('.price-th, .details-th, .totals').show();
            $('#payment-methods').show();
        }
        //$('#hasTaxes').trigger('click');
    }
    hideShowPrices();

    $(document).ready(function () {

        if ($('#Id').val() > 0 && '@ViewBag.check' > 0) {
            //alert('@MyERP.Properties.Resources.EditDoesNotSucceededBecausePurchaseInvoiceExistInCashIssueVoucher');
            Swal.fire({
                title: '@MyERP.Properties.Resources.EditDoesNotSucceededBecausePurchaseInvoiceExistInCashIssueVoucher',
                text: " ",
                icon: 'error',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
            window.location.replace('/PurchaseInvoice');
        }
        $('#VoucherDiscountPercentage').inputmask({
            alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 5, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
        });
        $.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
            $("input[type|='datetime-local']").not('.ExpiryDate , #DueDate').prop('min', r.PeriodStart).prop('max', r.PeriodEnd);
        });
        getItems();
        if ($('#Id').val()) {
            GetVendorCurrency();
            var code = $('#DocumentNumber').val();
            $('#DocumentNumbers').val(code.replaceAll("-", ""))
            $("#DepartmentId").prop('disabled', true);
            $("#VoucherDate").prop('disabled', true);

            $('.price').each(function () {
                if (UseDifferentCurrencies == 'True') {
                    $(this).closest('tr').find('.total').val($(this).inputmask('unmaskedvalue') * $(this).closest('tr').find('.quantity').val() * $(this).closest('tr').find('.CurrencyEquivalent').val());
                }
                else {
                    $(this).closest('tr').find('.total').val($(this).inputmask('unmaskedvalue') * $(this).closest('tr').find('.quantity').val());
                }
            });
            if ($('#hasTaxes').prop('checked')) {
                $('.taxes').show();
                if ($('#hasComercialTaxes').prop('checked')) {
                    $('.comercialTaxes').show();
                    hideShowComercialTax(true);
                }
            }
            if ($('#SelectedId').val() && $('#SystemPageId').val() == 58) {
                canAppendPurchaseInvoiceDetails = false;
                $('#PurchaseInvoiceDetails').find('tr').last().remove();
                $('#PurchaseInvoiceDetails').find('input').not('.price').attr('readonly', 'readonly');
                $('#SalesInvoiceDocNum').siblings('button.btn.btn-primary').addClass('disabled').attr('disabled', 'disabled').removeAttr('data-target');
            }
            if ($('#SalesTaxes').val() * 1 > 0)
                taxPercentage = $('#SalesTaxes').val() * 1 / (($('#CommercialRevenueTaxAmount').val() * 1 + $('#TotalAfterTaxes').val() * 1) - $('#SalesTaxes').val() * 1);
        } else {
            if ($('#DepartmentId').val()) {
                setWarehouseValues().then(function () {
                    $("#WarehouseId").empty().append(warehouseOptions);
                });
                cashBoxByDepartment();
            }
            setDocNum();
            GetCurrentTaxPercentage();
        }
        PayViaCarryOver == 'False' ? $('#InstallmentAmount').closest('tr').remove() : null;
        PayViaCheque == 'False' ? $('#ChequeAmount').closest('tr').remove() : null;
        PayViaVisa == 'False' ? $('#VisaAmount').closest('tr').remove() : null;
        PayViaCash == 'False' ? $('#CashAmount').closest('tr').remove() : null;

        $.get('/Helper/Vendors/').done(function (v) {
            Vendors = v;
        });
        $.get('/Helper/GetAllEmployees/').done(function (g) {
            Employees = g;
        });
        $.get('/Helper/GetAllDirectExpenses/').done(function (d) {
            DirectExpenses = d;
        });

        CalculatetotalExp();
        if (window.sessionStorage.getItem("UseItemUnit") == 'true') {
            $('.UnitClass').show();//.css("display", "none");
            $('.UnitEquivClass').show();//.css("display", "none");

            // show item unit ArName
            $('#PurchaseInvoiceDetails tr').each(function () {
                var tr = $(this);

                var itemUnitArName = tr.find('.itemUnitArName');

                var itemDisplayName = tr.find('.name').text();
                if (itemDisplayName != "") {
                    if (itemDisplayName.split('-')[1] !== " ")
                        itemDisplayName += "- " + itemUnitArName.val();
                    else
                        itemDisplayName += itemUnitArName.val();

                    tr.find('.name').text(itemDisplayName);

                }
            });
        }
        if (UseExpiryDateForItems == 'True') {
            $('.expiry').show();
        }
        if (UseDifferentCurrencies == 'True') {
            $('.Currency-th').show();
        }
        if ($('#VendorOrCustomerId').val() > 0) {
            GetCustomerOrVendorCreditLimitPeriod()
        }
    });
    function zeroPadded(val) {
        if (val >= 10)
            return val;
        else
            return '0' + val;
    }
    function SetDueDate(days) {
        var _voucherDate = new Date($('#VoucherDate').val());
        _voucherDate.setDate(_voucherDate.getDate() + days);
        $('#DueDate').val(_voucherDate.getFullYear() + "-" + zeroPadded(_voucherDate.getMonth() + 1) + "-" + zeroPadded(_voucherDate.getDate()) + "T" + zeroPadded(_voucherDate.getHours()) + ":" + zeroPadded(_voucherDate.getMinutes()));
    }
    function GetCustomerOrVendorCreditLimitPeriod() {
        $.get('/Helper/GetCustomerOrVendorCreditLimitPeriod?VendorId=' + $('#VendorOrCustomerId').val()).done(function (r) {
            CustomerOrVendorCreditLimitPeriod = r;
            SetDueDate(CustomerOrVendorCreditLimitPeriod);
        });
    }
    $(document).on('change', '#VendorOrCustomerId', function () {
        GetCustomerOrVendorCreditLimitPeriod();
        //if (UseDifferentCurrencies == 'True') {
            GetVendorCurrency();
       // }
    });

    function GetVendorCurrency() {
        $.get('/Helper/GetVendorCurrency?VendorId=' + $('#VendorOrCustomerId').val()).done(function (r) {
            if (UseDifferentCurrencies == 'True') {
                $('#PurchaseInvoiceDetails tr').each(function () {
                    var tr = $(this);
                    //tr.find('.CurrencyId').val(0);
                    //tr.find('.CurrencyName').text('');
                    //tr.find('.CurrencyEquivalent').val(1);
                    r.CurrencyId = r.CurrencyId != null ? r.CurrencyId : null;
                    r.CurrencyName = r.CurrencyName != null ? r.CurrencyName : "";
                    r.CurrencyEquivalent = r.CurrencyEquivalent != null ? parseFloat(r.CurrencyEquivalent) : 1;
                    if (tr.find('.item').val() > 0) {
                        tr.find('.CurrencyId').val(r.CurrencyId);
                        tr.find('.CurrencyName').text(r.CurrencyName);
                        tr.find('.CurrencyEquivalent').val(r.CurrencyEquivalent);
                        tr.find('.total').val(tr.find('.price').inputmask('unmaskedvalue') * tr.find('.quantity').inputmask('unmaskedvalue') * tr.find('.CurrencyEquivalent').inputmask('unmaskedvalue'))
                        CalculateTotals();
                    }
                });
            }
            else {
                $('#PurchaseInvoiceDetails tr').each(function () {
                    var tr = $(this);
                    if (tr.find('.item').val() > 0) {
                        tr.find('.total').val(tr.find('.price').inputmask('unmaskedvalue') * tr.find('.quantity').inputmask('unmaskedvalue'))
                        CalculateTotals();
                    }
                });
            }
        });
        //$('.price').each(function () {
        //    if ($(this).closest('tr').find('.item').val() > 0) {
        //        $(this).closest('tr').find('.total').val($(this).inputmask('unmaskedvalue') * $(this).closest('tr').find('.quantity').val() * $(this).closest('tr').find('.CurrencyEquivalent').inputmask('unmaskedvalue'));
        //    }
        //});
        //CalculateTotals();
    }

    function setWarehouseValues() {
        warehouseOptions = '';
        return requestData('/Helper/WarehousesByDepartmentId?id=' + $('#DepartmentId').val())
            .done(function (r) {
                //  warehouseOptions = '<option value>إختر المخزن</option>';
                for (var i = 0; i < r.length; i++) {
                    warehouseOptions += '<option value="' + r[i].Id + '">' + r[i].ArName + '</option>';
                }
            });
    }

    function getItems() {
        return requestData('/PurchaseInvoice/ItemsByDepId/?departmentId=' + $('#DepartmentId').val()).done(function (r) {
            items = r;
        });
    }

    function cashBoxByDepartment() {
        $.get('/Helper/CashBoxByDepartment/' + $('#DepartmentId').val()).done(function (r) {
            $('.CashBoxId').empty();
            //$('.CashBoxId').append('<option value>اختر الصندوق</option>');
            for (var i = 0; i < r.length; i++) {
                $('.CashBoxId').append($('<option>', {
                    value: r[i].Id,
                    text: r[i].ArName
                }));
            }
        });
    }

    $(document).on('change', '#DepartmentId', function () {
        getItems();
        setWarehouseValues().then(function () {
            $("#WarehouseId").empty().append(warehouseOptions);
        });
        setDocNum();
        cashBoxByDepartment();
        if (canAppendPurchaseInvoiceDetails) {
            if ($('#PurchaseInvoiceDetails tr').length > 1) {
                //alert("@MyERP.Properties.Resources.AllDataOfPreviousDepartmentCleared");
                Swal.fire({
                    title: '@MyERP.Properties.Resources.AllDataOfPreviousDepartmentCleared',
                    text: " ",
                    icon: 'info',
                    showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    confirmButtonColor: '#3085d6'
                });
            }
            $('#PurchaseInvoiceDetails tr').not(':last').remove();
            $('#PurchaseInvoiceDetails').find('.item, .item-name, .item-unit, .quantity, .unit-equavalent, .price').prop('required', 'required');
            CalculateTotals();
        }
    });
    $('#VoucherDate').on('change', function () {
        setDocNum();
        GetCurrentTaxPercentage();
        if ($('#VendorOrCustomerId').val() > 0) {
            GetCustomerOrVendorCreditLimitPeriod();
        }
        else {
            //alert("@MyERP.Properties.Resources.SelectCustomerFirst")
            Swal.fire({
                title: '@MyERP.Properties.Resources.SelectCustomerFirst',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        }
    });
    function setDocNum() {
        if ($('#DepartmentId').val())
            $.get('/PurchaseInvoice/SetDocNum?id=' + $('#DepartmentId').val() + '&VoucherDate=' + $('#VoucherDate').val()).done(function (r) {
                $('#DocumentNumber').val(r);
                $('#DocumentNumbers').val(r.replaceAll("-", ""));
            });
    }
    function GetCurrentTaxPercentage() {
        $.get('/TaxesPercentages/GetCurrentTaxPercentage?date=' + $('#VoucherDate').val()).done(function (r) {
            taxPercentage = r / 100;
            CalculateTotals();
        });
    }
    $(document).on('change', '.price', function () {
        GetVendorCurrency();
        if (UseDifferentCurrencies == 'True') {
            $(this).closest('tr').find('.total').val($(this).inputmask('unmaskedvalue') * $(this).closest('tr').find('.quantity').inputmask('unmaskedvalue') * $(this).closest('tr').find('.CurrencyEquivalent').inputmask('unmaskedvalue'));
        }
        else {
            $(this).closest('tr').find('.total').val($(this).inputmask('unmaskedvalue') * $(this).closest('tr').find('.quantity').inputmask('unmaskedvalue'));
        }
        CalculateTotals();
        addToPurchaseInvoiceDetails();


        //costPrice
        var thisPrice = $(this).val();
        var thisDirectExpense = $(this).closest('tr').find('.ItemDirectExpenses').val() ? $(this).closest('tr').find('.ItemDirectExpenses').val():0;
        var totalCost = parseFloat(thisPrice) + parseFloat(thisDirectExpense);
        $(this).closest('tr').find('.CostPrice').val(totalCost);

       // CalculateDirectExpenceForEachItem(this);
        ReSetDetailsValues();
    });

    $(document).on('change', '.quantity', function () {
        $(this).closest('tr').find('.price').trigger('change');       // $(this).closest('tr').find('.price').trigger('change');
    });

