    function bindVehicleLookups() {
        $('#vehicleCarTypeId').empty().append('<option value="">@MyERP.Properties.Resources.Select</option>');
        carTypes.forEach(function (t) { $('#vehicleCarTypeId').append('<option value="' + t.Id + '">' + t.ArName + '</option>'); });
        $('#vehicleCarColorId').empty().append('<option value="">@MyERP.Properties.Resources.Select</option>');
        carColors.forEach(function (c) { $('#vehicleCarColorId').append('<option value="' + c.Id + '">' + c.ArName + '</option>'); });
    }
    function fillVehicleModels(typeId, selectedModelId) {
        $('#vehicleCarModelId').empty().append('<option value="">@MyERP.Properties.Resources.Select</option>');
        carModels.filter(function (m) { return m.CarTypeId == typeId; }).forEach(function (m) {
            $('#vehicleCarModelId').append('<option value="' + m.Id + '">' + m.ArName + '</option>');
        });
        if (selectedModelId) { $('#vehicleCarModelId').val(selectedModelId); }
    }
    function showVehicleDetails(e) {
        bindVehicleLookups();
        let tr = $(e).closest('tr');
        $('#vehicleCurrentRowIndex').val(tr.index());
        $('#vehicleCarTypeId').val(tr.find('.car-type-id').val());
        fillVehicleModels($('#vehicleCarTypeId').val(), tr.find('.car-model-id').val());
        $('#vehicleCarColorId').val(tr.find('.car-color-id').val());
        $('#vehicleChassisNo').val(tr.find('.chassis-no').val());
        $('#vehicleEngineNo').val(tr.find('.engine-no').val());
        $('#vehicleManufacturingYear').val(tr.find('.manufacturing-year').val());
        $('#vehiclePlateNo').val(tr.find('.plate-no').val());
        $('#vehicleNotes').val(tr.find('.vehicle-notes').val());
    }
    $('#vehicleCarTypeId').on('change', function () { fillVehicleModels($(this).val(), null); });
    function saveVehicleDetails() {
        let tr = $('#PurchaseInvoiceDetails tr').eq($('#vehicleCurrentRowIndex').val());
        tr.find('.car-type-id').val($('#vehicleCarTypeId').val());
        tr.find('.car-model-id').val($('#vehicleCarModelId').val());
        tr.find('.car-color-id').val($('#vehicleCarColorId').val());
        tr.find('.chassis-no').val($('#vehicleChassisNo').val());
        tr.find('.engine-no').val($('#vehicleEngineNo').val());
        tr.find('.manufacturing-year').val($('#vehicleManufacturingYear').val());
        tr.find('.plate-no').val($('#vehiclePlateNo').val());
        tr.find('.vehicle-notes').val($('#vehicleNotes').val());
        $('#vehicleDetailsModal').modal('hide');
    }
    function validateChassisNumbersForPurchase() {
        let map = {};
        let valid = true;
        $('#PurchaseInvoiceDetails tr').each(function () {
            let chassisNo = ($(this).find('.chassis-no').val() || '').trim().toLowerCase();
            if (chassisNo) {
                if (map[chassisNo]) { valid = false; return false; }
                map[chassisNo] = true;
            }
        });
        if (!valid) {
            Swal.fire({ title: 'رقم الشاسيه مكرر داخل نفس الفاتورة', text: ' ', icon: 'info', confirmButtonText: '@MyERP.Properties.Resources.Ok', confirmButtonColor: '#3085d6' });
        }
        return valid;
    }
    function showItemDetials(e) {
