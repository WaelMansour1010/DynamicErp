    function DirectExpensesCashBoxesByDepartment() {
        $('#CashBoxExpensesId').empty();
        $.get('/Helper/CashBoxByDepartment/' + $('#DepartmentId').val()).done(function (r) {
            CashBoxes = r;
            //$('.CashBoxExpensesId').append('<option value>اختر الصندوق</option>');
            for (var i = 0; i < CashBoxes.length; i++) {
                $('#CashBoxExpensesId').append($('<option>', {
                    value: CashBoxes[i].Id,
                    text: CashBoxes[i].ArName
                }));
            }
        });
    }

    $('#Amount').on('change', function () {
        if ($('#Id').val() > 0 && $('#PurchaseInvoiceDirectExpenses tr').length > 0) {
            taxPercentage = (parseFloat($('#PurchaseInvoiceDirectExpenses .TotalAmounts:last').text()) - parseFloat($('#PurchaseInvoiceDirectExpenses .Amounts:last').text())) / parseFloat($('#PurchaseInvoiceDirectExpenses .Amounts:last').text());
            $('#TaxesAmount').val(taxPercentage * $(this).val());
            var TotalAmount = parseFloat($('#Amount').val()) + parseFloat($('#TaxesAmount').val());

        }
        else {
            //   var Amount = $(this).val();
            $('#TaxesAmount').val((taxPercentage * $(this).val()).toFixed(2));
            var TotalAmount = parseFloat($('#Amount').val()) + parseFloat($('#TaxesAmount').val());
        }

        $('#TotalAmount').val(TotalAmount);
    })

    $('#ExpensesPaymentMethod').on('change', function () {
        DirectExpensesCashBoxesByDepartment();
        if ($(this).val() == 1) //نقدى
        {
            $('#CashId').show();
            $('#VendId').hide();
            $('#EmpId').hide();
        }
        else if ($(this).val() == 2) // آجل
        {
            $('#VendId').show();
            $('#CashId').hide();
            $('#EmpId').hide();
        }
        else if ($(this).val() == 3) // عهدة
        {
            $('#EmpId').show();
            $('#CashId').hide();
            $('#VendId').hide();
        }

    })

