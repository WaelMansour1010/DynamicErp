    function chooseItem(item)
    {
        let itemId = $(item).closest('tr').find('.items-prices-quantities-id').val();

        //let exist = false;
        //$('#PurchaseInvoiceDetails tr').each(function () {

        //    let tr = $(this);
        //    if (tr.closest('tr').find('.item').val() == itemId) {
        //        exist = true;
        //    }

        //});


      //  if (exist == false)
        //{
            $('#PurchaseInvoiceDetails .item:last').val(itemId);
            $('#PurchaseInvoiceDetails .item-name:last').val($(item).closest('tr').find('.nameOfItem').text());
            $('#PurchaseInvoiceDetails .name:last').text($(item).closest('tr').find('.nameOfItem').text());
            $('#PurchaseInvoiceDetails .item:last').trigger('change');
        //}

        $('.bs-example-modal-lg').modal('hide');
    }


     $(document).on('change', '.item-name', function () {
        let itemName = $(this).val();
        if (!items.filter(function (i) { return i.ArName == itemName; }).length) {
            $(this).closest('tr').find('.item-name').val('');
            $(this).closest('tr').find('.name').text('');
            $(this).closest('tr').find('.item').val('').trigger('change');
            $(this).closest('tr').find('.item-unit').empty();
        }
    });

    $(document).on('change', '.item', function () {
        let itemPrice = $(this);
        if (itemPrice.closest('tr').find('.Add-Button').prop('hidden') == false)
        {
            itemPrice.closest('tr').find('.Add-Button').prop('hidden', true);
            //itemPrice.closest('tr').find('.popupCell').attr("onclick", "");
        }
        if (itemPrice.val() && items.length)
        {
           let item = items.filter(function (i) { return i.ItemPriceId == itemPrice.val(); })[0];
           getItemPrice(item.Id, $(this));

           itemPrice.closest('tr').find('.barcode').val(item.Barcode);
           //itemPrice.closest('tr').find('.price').val(item.Price);
           itemPrice.closest('tr').find('.item-unit').empty().append('<option value="' + item.ItemUnitId + '">' + item.ItemUnitArName + '</option>');
           itemPrice.closest('tr').find('.unit-equavalent').val(item.Equivalent);
        }
        else
        {
           itemPrice.closest('tr').find('input[type="text"]').val('');
           itemPrice.closest('tr').find('select').empty();
        }
        $(this).closest('tr').find('.price').trigger('change');
        addToPurchaseInvoiceDetails();
        GetVendorCurrency();

    });

    $(document).on('keydown', '.barcode', function (e) {
        if (e.which == 13 || e.keyCode == 13) {
            let elem = $(this);
            if (items.length) {
                let itemPrice = items.filter(function (i) { return i.Barcode === $(elem).val(); })[0];
                if (itemPrice) {
                    $(elem).closest('tr').find('.item-name').val(itemPrice.ArName);
                    $(elem).closest('tr').find('.name').text(itemPrice.ArName);
                    $(elem).closest('tr').find('.item').val(itemPrice.ItemPriceId).trigger('change');
                } else {
                    $(elem).closest('tr').find('.item-name').val('');
                    $(elem).closest('tr').find('.item').val('').trigger('change');
                }
            } else {
                $(elem).closest('tr').find('.item-name').val('');
                $(elem).closest('tr').find('.item').val('').trigger('change');
            }
        }
    });

    $(document).on('change', '.barcode', function () {
        let itemPrice = $(this).closest('tr').find('.item').val();
        if (items.length && itemPrice) {
            let itemPrice = $(this).closest('tr').find('.item').val();
            let barcode = items.filter(function (i) { return i.ItemPriceId == itemPrice; })[0];
            $(this).val(barcode ? barcode.Barcode : '');
        } else
            $(this).val('');
    });

    function getItemPrice(id, item) {
        requestData('/PurchaseInvoice/GetItemPrices?itemId=' + id).done(function (r) {
            $(item).closest('tr').find('.lastPrice').val(r.LastPrice );
            }).fail(function () {
                $(item).closest('tr').find('.lastPrice').val(0);
            });
    }

    function addToPurchaseInvoiceDetails()
    {
        if ($('.item-name').last().val() && canAppendPurchaseInvoiceDetails)
            $('#PurchaseInvoiceDetails').find('.item, .item-unit, .quantity, .unit-equavalent, .price ').prop('required', 'required');
           // $('#PurchaseInvoiceDetails').find('.item, .item-unit, .quantity, .unit-equavalent, .price ,.ExpiryDate').prop('required', 'required');
        if ($('#PurchaseInvoiceDetails .form-control:invalid').length > 0)
        {
            $('#PurchaseInvoiceDetails').closest('.form-horizontal').addClass('was-validated');
            $('html, body').animate({
                scrollTop: $("#PurchaseInvoiceDetails").find(".form-control:invalid").eq(0).offset().top - 80
            }, 500);
        }
        else if ($('#PurchaseInvoiceDetails .quantity:last').val() != 0 && $('#PurchaseInvoiceDetails .item-name:last').val() && canAppendPurchaseInvoiceDetails)
        {
            let tr;
            var Show_Hide = ShowDirectExpense != 'True' ? "hidden" : "";
            tr = '<tr><td class="tabledit-edit-mode"><input class="barcode form-control tabledit-input form-control-sm" /></td><td onclick="showSearchModal()" class="tabledit-edit-mode popupCell"><input type="hidden" class="item form-control tabledit-input form-control-sm" /><input hidden type="text" class="item-name form-control tabledit-input form-control-sm" /><span  class="Add-Button" style="font-size: 25px; color: limegreen;margin-right:50%;" data-toggle="modal" data-target=".bs-example-modal-lg"><i class="fas fa-plus"></i></span><label style="width:200px" class="name control-label tabledit-input"></label></td> <td class="tabledit-edit-mode expiry" style="display:none;"><input class="PatchCode form-control tabledit-input form-control-sm" type="text" /></td><td class="tabledit-edit-mode expiry" style="display:none;"><input class="ExpiryDate form-control tabledit-input form-control-sm" type = "date" /><input class="PatchId form-control tabledit-input form-control-sm" hidden /></td><td class="tabledit-edit-mode"><input class="quantity form-control tabledit-input form-control-sm" type="number" step="any" /><input type="hidden" class="quantityOnSystem form-control tabledit-input form-control-sm" /></td><td class="tabledit-edit-mode UnitClass" style="display:none;"><select class="item-unit form-control tabledit-input form-control-sm" disabled></select></td><td class="tabledit-edit-mode UnitEquivClass" style="display:none;"><input class="unit-equavalent form-control tabledit-input form-control-sm small-number" type="number" step="any" /></td><td class="tabledit-edit-mode"><input type="text" class="money price form-control tabledit-input form-control-sm" /></td><td class="tabledit-edit-mode"' + Show_Hide + '><input type="text" class="money ItemDirectExpenses form-control tabledit-input form-control-sm" /></td ><td class="tabledit-edit-mode"' + Show_Hide + ' ><input type="text" class="money CostPrice form-control tabledit-input form-control-sm"/></td><td class="tabledit-edit-mode"><input class="total money form-control tabledit-input form-control-sm" type="text" readonly /></td><td class="tabledit-edit-mode Currency-th" style="display:none;"><input class="CurrencyId form-control tabledit-input form-control-sm" type = "text" readonly hidden /><label class="CurrencyName control-label tabledit-input"></label></td ><td class="tabledit-edit-mode Currency-th" style="display:none;"><input style="padding: 0.2rem;" class="CurrencyEquivalent money form-control tabledit-input form-control-sm" type="text" readonly /></td><td class="tabledit-edit-mode"><button class="btn btn-info item-details-btn" data-toggle="modal" data-target="#itemDetails" onclick="showItemDetials(this)">'+'@MyERP.Properties.Resources.Details'+'</button></td><td class="tabledit-edit-mode"> <button class="btn btn-info item-details-btn" data-toggle="modal" data-target="#itemSellPrices" onclick="showItemSellPrices(this)">'+'@MyERP.Properties.Resources.SalePrice'+'</button></td><td class="tabledit-edit-mode"><input type="hidden" class="car-type-id" /><input type="hidden" class="car-model-id" /><input type="hidden" class="car-color-id" /><input type="hidden" class="chassis-no" /><input type="hidden" class="engine-no" /><input type="hidden" class="manufacturing-year" /><input type="hidden" class="plate-no" /><input type="hidden" class="vehicle-notes" /><button class="btn btn-secondary vehicle-details-btn" data-toggle="modal" data-target="#vehicleDetailsModal" onclick="showVehicleDetails(this)">بيانات السيارة</button></td><td><a href="javascript:void(0);" onclick="deleteElement(this)"><i class="fas fa-trash-alt"></i></a></td></tr>';
            $('#PurchaseInvoiceDetails').append(tr);

            if (window.sessionStorage.getItem("UseItemUnit") == 'true') {
                $('.UnitClass').show();//.css("display", "none");
                $('.UnitEquivClass').show();//.css("display", "none");
            }
            if (UseExpiryDateForItems == 'True') {
                $('.expiry').show();
            }
            if (UseDifferentCurrencies == 'True') {
                $('.Currency-th').show();
            }
            $('#PurchaseInvoiceDetails .money').inputmask({
                alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
            });
            $('#PurchaseInvoiceDetails input[type=number]').removeProp('oninput').prop('type', 'text').inputmask({
                alias: 'numeric', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
            });
            $('#PurchaseInvoiceDetails input.small-number').removeProp('oninput').prop('type', 'text').inputmask({
                alias: 'numeric', autoGroup: true, digits: 4, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
            });
            $('#PurchaseInvoiceDetails tr:last select').select2({
                matcher: matchCustom
            });
            hideShowPrices();
        }
    }

   $(document).on('change', '#DiscountValue', function () {
        var total = 0;
        $('.total').each(function () {
            total += $(this).inputmask('unmaskedvalue') * 1;
        });
        if (($(this).inputmask('unmaskedvalue') / total) >= 1) {
            $(this).val(0);
        }
        $('#VoucherDiscountPercentage').val(($(this).inputmask('unmaskedvalue') * 100 / total));
        CalculateTotals();
    });

    $(document).on('change', '#VoucherDiscountPercentage', function () {
            CalculateTotals();
    });

    $(document).on('change', '#SalesTaxes', function () {
        CalculateTotals();
    });

    $('#hasTaxes').on('click', function () {
        if ($('#hasTaxes').prop('checked')) {
            $('.taxes').show();
        }
        else {
            $('.taxes').hide();
            $('.comercialTaxes').hide();
            $('#hasComercialTaxes').removeAttr('checked');
            hideShowComercialTax(false);
            $('#SalesTaxes').val(0);
            $('#TotalAfterTaxes').val(0);
        }
        CalculateTotals();
    });

    $('#hasComercialTaxes').on('click', function () {
        hideShowComercialTax($('#hasComercialTaxes').prop('checked'));
        CalculateTotals();
    });

    function hideShowComercialTax(show) {
        var totalAfterTaxesLabel = $('label[for="TotalAfterTaxes"]');
        var colsm2 = $('#TotalAfterTaxes').closest('.col-sm-2');
        if (show) {
            $('label[for="TotalAfterTaxes"]').remove();
            $('#TotalAfterTaxes').closest('.col-sm-2').remove();
            $('#CommercialRevenueTaxAmount').closest('.form-group').append($(totalAfterTaxesLabel));
            $('#CommercialRevenueTaxAmount').closest('.form-group').append($(colsm2));
            $('.comercialTaxes').show();
        }
        else {
            $('label[for="TotalAfterTaxes"]').remove();
            $('#TotalAfterTaxes').closest('.col-sm-2').remove();
            $(totalAfterTaxesLabel).insertAfter($('#SalesTaxes').closest('.col-sm-2'));
            $(colsm2).insertBefore($('#hasComercialTaxes').closest('.col-sm-2'));
            $('.comercialTaxes').hide();
            $('#CommercialRevenueTaxAmount').val(0);
            $('#TotalAfterTaxes').val(0);
        }
        $('#TotalAfterTaxes').inputmask({
            alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
        });
    }

    function CalculateTotals() {
      var total=0;
        $('.total').each(function () {
            total += $(this).inputmask('unmaskedvalue') * 1;
        });
        $('#Total').val(total);
        if ($('#VoucherDiscountPercentage').inputmask('unmaskedvalue') < 100) {
            $('#DiscountValue').val(($('#VoucherDiscountPercentage').inputmask('unmaskedvalue') / 100) * total);
        } else {
            $('#VoucherDiscountPercentage').val(0);
            $('#DiscountValue').val(0);
        }
        if ($('#DiscountValue').val()) {
            total -= $('#DiscountValue').inputmask('unmaskedvalue');
        }
        $('#NetTotal').val(total);
        if ($('#hasTaxes').prop('checked')) {
            $('#SalesTaxes').val(total * taxPercentage);
            if ($('#hasComercialTaxes').prop('checked')) {
                $('#CommercialRevenueTaxAmount').val(total * .01);
                total -= total * .01;
            }
            total += $('#SalesTaxes').inputmask('unmaskedvalue')*1;
        }
        $('#TotalAfterTaxes').val(total);
         $('#InstallmentAmount').val('0');
        $('#CashAmount').val(total);
    }

    function deleteElement(e)
    {
        let tr = $(e).closest('tr');
        if ($(tr).index() == 0 && $(tr).closest('tbody').children('tr').length == 1)
        {
            $(tr).find("input").val('');
            $(tr).find("label").text('');
            $(tr).find('input, select').removeAttr('required');
            $(tr).find('select').empty();
            $(tr).find('.Add-Button').prop('hidden', false);
            $(tr).find('.popupCell').attr('onclick', 'showSearchModal()');
        }
        else if ($(tr).index() < $(tr).closest('tbody').children('tr').length - 1)
            e.parentNode.parentNode.parentNode.removeChild(e.parentNode.parentNode);
        else if ($(tr).index() == $(tr).closest('tbody').children('tr').length - 1)
        {
            $(tr).find("input").val('');
            $(tr).find('input, select').removeAttr('required');
            $(tr).find('select').empty();
            $(tr).find("label").text('');
            $(tr).find('.Add-Button').prop('hidden', false);
            $(tr).find('.popupCell').attr('onclick', 'showSearchModal()');
        }

        CalculateTotals();
    }

