@model MyERP.Models.PurchaseInvoice

@{
    if (System.Web.Configuration.WebConfigurationManager.AppSettings["ECommerce"] == "true")
    {
        Layout = "~/Views/Shared/_EcommerceLayout.cshtml";
    }
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = MyERP.Properties.Resources.PurchaseInvoices;
}


<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                @if (Model != null)
                {
                    if (Model.IsDeleted == false)
                    {
                        if (ViewBag.Previous > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.First })" class="btn btn-info"> @MyERP.Properties.Resources.First </a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Previous })" class=" btn btn-info">&#8250;</a>
                        }
                        if (ViewBag.Next > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Next })" class="btn btn-info">&#8249;</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Last })" class="btn btn-info">@MyERP.Properties.Resources.Last</a>
                        }
                    }
                }
                <a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
            </div>
            <h4 class="page-title"> @MyERP.Properties.Resources.PurchaseInvoices </h4>
        </div>
    </div>
</div>
@if (Model != null)
{
    @Html.HiddenFor(model => model.Id)
    @Html.HiddenFor(model => model.IsActive)
    @Html.HiddenFor(model => model.UserId)
    @Html.HiddenFor(model => model.IsLinked)
    @Html.HiddenFor(model => model.IsPosted)
    @Html.HiddenFor(model => model.IsDeleted)
    @Html.HiddenFor(model => model.IsAccepted)
    @Html.HiddenFor(model => model.IsCompleted)
    @Html.HiddenFor(model => model.SelectedId)
    @Html.HiddenFor(model => model.SystemPageId)
    @Html.HiddenFor(model => model.Image)
}
else
{
    <input type="hidden" id="SystemPageId" />
    <input type="hidden" id="SelectedId" />
}
<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal needs-validation" role="form">
                        <div class="card">
                            <div class="card-body">
                                <h5 class="header-title">
                                    @MyERP.Properties.Resources.MainData
                                </h5>
                                <div class="form-group row">
                                    <label class=" col-sm-2 control-label" for="DocumentNumber">@MyERP.Properties.Resources.DocNo</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.DocumentNumber, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly", placeholder = @MyERP.Properties.Resources.DocNo, hidden = "hidden" } })
                                        <input id="DocumentNumbers" class="form-control" placeholder=@MyERP.Properties.Resources.DocNo required readonly />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>

                                    <label for="VoucherDate" class="control-label col-sm-2"> @MyERP.Properties.Resources.VoucherDate </label>
                                    <div class="col-sm-4">
                                        <input id="VoucherDate" name="VoucherDate" class="form-control" type="datetime-local" value="@ViewBag.VoucherDate" required />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="DepartmentId" class="col-sm-2 control-label"> @MyERP.Properties.Resources.Department </label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("DepartmentId", null, null, htmlAttributes: new { @class = "form-control", @required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>

                                    <label for="WarehouseId" class="col-sm-2 control-label"> @MyERP.Properties.Resources.WareHouse </label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("WarehouseId", null, null, htmlAttributes: new { @class = "form -control", @required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="VendorOrCustomerId" class="control-label col-sm-2"> @MyERP.Properties.Resources.Vendor </label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("VendorOrCustomerId", null, null, htmlAttributes: new { @class = "form-control", @required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>

                                    <label for="DueDate" class="control-label col-sm-2"> @MyERP.Properties.Resources.DueDate </label>
                                    <div class="col-sm-4">
                                        <input id="DueDate" name="DueDate" class="form-control" type="datetime-local" value="@ViewBag.VoucherDate" required />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>

                                    @*<label class="control-label col-sm-2" for="Notes">ملاحظات</label>
                                        <div class="col-sm-4">
                                            <textarea id="Notes" name="Notes" class="form-control" rows="5" cols="5">@if (Model != null) { @Model.Notes; }</textarea>
                                        </div>*@
                                </div>
                                <div class="form-group row">
                                    <label class=" col-sm-2 control-label" for="VendorInvoiceNumber">@MyERP.Properties.Resources.VendorInvoiceNumber</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.VendorInvoiceNumber, new { htmlAttributes = new { @class = "form-control", placeholder = @MyERP.Properties.Resources.VendorInvoiceNumber } })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="control-label col-sm-2" for="Notes">@MyERP.Properties.Resources.Notes</label>
                                    <div class="col-sm-4">
                                        <textarea id="Notes" name="Notes" class="form-control" rows="5" cols="5">@if (Model != null) { @Model.Notes; }</textarea>
                                    </div>
                                    @*<label for="DueDate" class="control-label col-sm-2">تاريخ الاستحقاق</label>
                                        <div class="col-sm-4">
                                            <input id="DueDate" name="DueDate" class="form-control" type="datetime-local" value="@ViewBag.VoucherDate" required />
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>*@
                                    <div class="col-sm-6">
                                        <button class="btn btn-primary" data-toggle="modal" data-target="#LinkWithOtherDocModal"> @MyERP.Properties.Resources.LinkWithOtherDoc </button>
                                        <label id="SalesInvoiceDocNum">
                                            @if (Model != null && Model.SystemPageId.HasValue && Model.SelectedId.HasValue)
                                            {
                                                @Html.Raw(@MyERP.Properties.Resources.DocNo + " : " + ViewBag.SalesInoiveDocNum)
                                            }
                                        </label>
                                        <button id="cancelSalesInvoice" onclick="cancelSalesInvoice()" class="btn btn-icon waves-effect waves-light btn-danger btn-xs" style="display:none;"> <i class="fas fa-times"></i> </button>
                                    </div>
                                </div>
                                @if (ViewBag.UseCostCenter == true)
                                {
                                    <div class="form-group row">
                                        <label for="CostCenterId" class="control-label col-sm-2">@MyERP.Properties.Resources.CostCenter </label>

                                        <div class="col-sm-4">
                                            @Html.DropDownList("CostCenterId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })
                                        </div>
                                    </div>
                                }
                                @if (ViewBag.WarehouseItemsDistribution == true)
                                {
                                    <div class="form-group row">
                                        <label class="control-label col-sm-2"> @MyERP.Properties.Resources.WarehouseItemsDistribution </label>
                                        <div class="col-sm-4">
                                            <input type="checkbox" id="DistributeItemsOnWarehouses" @Html.Raw(Model != null ? (Model.WarehouseItemDistribution == true ? "checked" : "") : "checked") />
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>


            @Html.Partial("ItemSearch")


            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="header-title">@MyERP.Properties.Resources.Details</h5>
                            <div class="form-horizontal needs-validation" role="form">
                                <div class="table-responsive">
                                    <table class="table table-centered mb-0">
                                        <thead>
                                            <tr>
                                                <th>@MyERP.Properties.Resources.Barcode</th>
                                                <th>@MyERP.Properties.Resources.Item </th>
                                                <th class="expiry" style="display:none;"> @MyERP.Properties.Resources.PatchCode </th>
                                                <th class="expiry" style="display:none;"> @MyERP.Properties.Resources.ExpiryDate </th>
                                                <th>@MyERP.Properties.Resources.Qty</th>
                                                <th class="UnitClass" style="display:none;">@MyERP.Properties.Resources.Unit</th>
                                                <th class="UnitEquivClass" style="display:none;">@MyERP.Properties.Resources.Equivalent</th>
                                                <th class="price-th">@MyERP.Properties.Resources.PurchasePrice</th>
                                                <th class="ItemDirectExpenses-th" @Html.Raw(ViewBag.ShowDirectExpense == true ? "" : "hidden")> @MyERP.Properties.Resources.DirectExpenses </th>
                                                <th class="CostPrice-th" @Html.Raw(ViewBag.ShowDirectExpense == true ? "" : "hidden")> @MyERP.Properties.Resources.Cost</th>
                                                @*<th class="price-th">اخر سعر شراء</th>*@
                                                <th class="price-th">@MyERP.Properties.Resources.Total</th>
                                                <th class="Currency-th" style="display:none;">@MyERP.Properties.Resources.Currency</th>
                                                <th class="Currency-th" style="display:none;">@MyERP.Properties.Resources.CurrencyEquivalent</th>
                                                <th class="details-th">@MyERP.Properties.Resources.Details</th>
                                                <th class="details-th">@MyERP.Properties.Resources.SalePrice</th>
                                                <th>بيانات السيارة</th>
                                                <th>@MyERP.Properties.Resources.Delete</th>
                                            </tr>
                                        </thead>
                                        <tbody id="PurchaseInvoiceDetails">
                                            @if (Model != null && Model.Id > 0)
                                            {
                                                foreach (var item in Model.PurchaseInvoiceDetails)
                                                {
                                                    <tr>
                                                        <td class="tabledit-edit-mode"><input class="barcode form-control tabledit-input form-control-sm" value="@Html.Raw(item.ItemPrice!=null?item.ItemPrice.Barcode:"")" /></td>
                                                        <td class="tabledit-edit-mode">
                                                            <input type="hidden" class="item form-control tabledit-input form-control-sm" value="@item.ItemPriceId" @*required*@ />
                                                            <input hidden type="text" class="item-name form-control tabledit-input form-control-sm" value="@item.Item.ArName - @item.ItemPrice.Barcode" required />
                                                            @if(Session["lang"]!=null&&Session["lang"].ToString() == "en" && item.Item.EnName != null)
                                                            {
                                                                <label style="width:200px" class="name control-label tabledit-input ">@item.Item.EnName - @item.ItemPrice.Barcode</label>
                                                            }
                                                            else
                                                            {
                                                                <label style="width:200px" class="name control-label tabledit-input ">@item.Item.ArName - @item.ItemPrice.Barcode</label>
                                                            }
                                                            <input hidden class="itemUnitArName" value=@item.ItemUnit.ArName />

                                                        </td>
                                                        <td class="tabledit-edit-mode expiry" style="display:none;">
                                                            @if (item.PatchCode!=null)
                                                            {

                                                                <input class="PatchCode form-control tabledit-input form-control-sm" type="text" value="@item.PatchCode" />
                                                            }
                                                            else
                                                            {
                                                                <input class="PatchCode form-control tabledit-input form-control-sm" type="text" />
                                                            }
                                                        </td>
                                                        <td class="tabledit-edit-mode expiry" style="display:none;">
                                                            @if (item.ExpireDate.HasValue)
                                                            {

                                                                <input class="ExpiryDate form-control tabledit-input form-control-sm" type="date" value="@item.ExpireDate.Value.ToString("yyyy-MM-dd")" />
                                                            }
                                                            else
                                                            {
                                                                <input class="ExpiryDate form-control tabledit-input form-control-sm" type="date" />
                                                            }
                                                            <input class="PatchId form-control tabledit-input form-control-sm" hidden value="@item.PatchId" />
                                                        </td>

                                                        <td class="tabledit-edit-mode">
                                                            <input class="quantity form-control tabledit-input form-control-sm" type="number" step="any" value="@item.Qty" required />
                                                        </td>
                                                        <td class="tabledit-edit-mode UnitClass" style="display:none;"><select class="item-unit form-control tabledit-input form-control-sm" required disabled><option value="@item.ItemUnitId">@item.ItemUnit.ArName</option></select></td>
                                                        <td class="tabledit-edit-mode UnitEquivClass" style="display:none;"><input class="unit-equavalent form-control tabledit-input form-control-sm small-number" type="number" step="any" value="@item.UnitEquivalent" required /></td>
                                                        <td class="tabledit-edit-mode"><input type="text" class="money price form-control tabledit-input form-control-sm" value="@item.Price" required /></td>
                                                        <td class="tabledit-edit-mode" @Html.Raw(ViewBag.ShowDirectExpense == true ? "" : "hidden")><input type="text" class="money ItemDirectExpenses form-control tabledit-input form-control-sm" value="@item.ItemDirectExpenses" /></td>
                                                        <td class="tabledit-edit-mode" @Html.Raw(ViewBag.ShowDirectExpense == true ? "" : "hidden")><input type="text" class="money CostPrice form-control tabledit-input form-control-sm" value="@item.CostPrice" /></td>
                                                        @*<td class="tabledit-edit-mode"><input type="text" class="money lastPrice form-control tabledit-input form-control-sm" readonly /></td>*@
                                                        <td class="tabledit-edit-mode"><input class="total money form-control tabledit-input form-control-sm" type="text" readonly value="0" /></td>
                                                        @if (item.Currency != null)
                                                        {
                                                            <td class="tabledit-edit-mode Currency-th" style="display:none;">
                                                                <input class="CurrencyId form-control tabledit-input form-control-sm" type="text" readonly hidden value="@item.CurrencyId" />
                                                                <label class="CurrencyName control-label tabledit-input">@item.Currency.ArName</label>
                                                            </td>
                                                            <td class="tabledit-edit-mode Currency-th" style="display:none;"><input style="padding: 0.2rem;" class="CurrencyEquivalent money form-control tabledit-input form-control-sm" type="text" readonly value="@item.Currency.Equivalent" /></td>

                                                        }
                                                        else
                                                        {
                                                            <td class="tabledit-edit-mode Currency-th" style="display:none;">
                                                                <input class="CurrencyId form-control tabledit-input form-control-sm" type="text" readonly hidden />
                                                                <label class="CurrencyName control-label tabledit-input"></label>
                                                            </td>
                                                            <td class="tabledit-edit-mode Currency-th" style="display:none;"><input class="CurrencyEquivalent money form-control tabledit-input form-control-sm" type="text" readonly /></td>
                                                        }
                                                        <td><button class="btn btn-info item-details-btn" data-toggle="modal" data-target="#itemDetails" onclick="showItemDetials(this)">@MyERP.Properties.Resources.Details</button></td>
                                                        <td class="tabledit-edit-mode">
                                                            <button class="btn btn-info item-details-btn" data-toggle="modal" data-target="#itemSellPrices" onclick="showItemSellPrices(this)"> @MyERP.Properties.Resources.SalePrice </button>
                                                        </td>
                                                        <td class="tabledit-edit-mode">
                                                            <input type="hidden" class="car-type-id" value="@item.CarTypeId" />
                                                            <input type="hidden" class="car-model-id" value="@item.CarModelId" />
                                                            <input type="hidden" class="car-color-id" value="@item.CarColorId" />
                                                            <input type="hidden" class="chassis-no" value="@item.ChassisNo" />
                                                            <input type="hidden" class="engine-no" value="@item.EngineNo" />
                                                            <input type="hidden" class="manufacturing-year" value="@item.ManufacturingYear" />
                                                            <input type="hidden" class="plate-no" value="@item.PlateNo" />
                                                            <input type="hidden" class="vehicle-notes" value="@item.VehicleNotes" />
                                                            <button class="btn btn-secondary vehicle-details-btn" data-toggle="modal" data-target="#vehicleDetailsModal" onclick="showVehicleDetails(this)">بيانات السيارة</button>
                                                        </td>
                                                        <td>
                                                            <a href="javascript:void(0);" onclick="deleteElement(this)">
                                                                <i class="fas fa-trash-alt"></i>
                                                            </a>
                                                        </td>
                                                    </tr>
                                                }

                                            }

                                            <tr>
                                                <td class="tabledit-edit-mode"><input class="barcode form-control tabledit-input form-control-sm" /></td>
                                                <td onclick="showSearchModal()" class="tabledit-edit-mode popupCell">
                                                    <input type="hidden" class="item form-control tabledit-input form-control-sm" @Html.Raw(Model != null ? "" : "required ") />
                                                    <input hidden type="text" class="item-name form-control tabledit-input form-control-sm" @Html.Raw(Model != null ? "" : "required ") />
                                                    <span class="Add-Button" style="font-size: 25px; color: limegreen;margin-right:50%;" @*data-toggle="modal" data-target=".bs-example-modal-lg"*@><i class="fas fa-plus"></i></span>
                                                    <label style="width:200px" class="name control-label tabledit-input"></label>
                                                </td>
                                                <td class="tabledit-edit-mode expiry" style="display:none;">
                                                    <input class="PatchCode form-control tabledit-input form-control-sm" type="text" />
                                                </td> 
                                                <td class="tabledit-edit-mode expiry" style="display:none;">
                                                    <input class="ExpiryDate form-control tabledit-input form-control-sm" type="date" />
                                                    <input class="PatchId form-control tabledit-input form-control-sm" hidden />
                                                </td>
                                                <td class="tabledit-edit-mode">
                                                    <input class="quantity form-control tabledit-input form-control-sm" type="number" step="any" @Html.Raw(Model != null ? "" : "required ") />
                                                    <input type="hidden" class="quantityOnSystem form-control tabledit-input form-control-sm" />
                                                </td>
                                                <td class="tabledit-edit-mode UnitClass" style="display:none;"><select class="item-unit form-control tabledit-input form-control-sm" @Html.Raw(Model != null ? "" : "required ") disabled></select></td>
                                                <td class="tabledit-edit-mode UnitEquivClass" style="display:none;"><input class="unit-equavalent form-control tabledit-input form-control-sm small-number" type="number" step="any" @Html.Raw(Model != null ? "" : "required ") /></td>
                                                <td class="tabledit-edit-mode"><input type="text" class="money price form-control tabledit-input form-control-sm" @Html.Raw(Model != null ? "" : "required ") /></td>
                                                <td class="tabledit-edit-mode" @Html.Raw(ViewBag.ShowDirectExpense == true ? "" : "hidden")><input type="text" class="money ItemDirectExpenses form-control tabledit-input form-control-sm" /></td>
                                                <td class="tabledit-edit-mode" @Html.Raw(ViewBag.ShowDirectExpense == true ? "" : "hidden")><input type="text" class="money CostPrice form-control tabledit-input form-control-sm" /></td>
                                                @*<td class="tabledit-edit-mode"><input type="text" class="money lastPrice form-control tabledit-input form-control-sm" readonly /></td>*@
                                                <td class="tabledit-edit-mode"><input class="total money form-control tabledit-input form-control-sm" type="text" readonly /></td>

                                                <td class="tabledit-edit-mode Currency-th" style="display:none;">
                                                    <input class="CurrencyId form-control tabledit-input form-control-sm" type="text" readonly hidden />
                                                    <label class="CurrencyName control-label tabledit-input"></label>
                                                </td>
                                                <td class="tabledit-edit-mode Currency-th" style="display:none;"><input style="padding: 0.2rem;" class="CurrencyEquivalent money form-control tabledit-input form-control-sm" type="text" readonly /></td>

                                                <td class="tabledit-edit-mode">
                                                    <button class="btn btn-info item-details-btn" data-toggle="modal" data-target="#itemDetails" onclick="showItemDetials(this)">@MyERP.Properties.Resources.Details</button>
                                                </td>

                                                <td class="tabledit-edit-mode">
                                                    <button class="btn btn-info item-details-btn" data-toggle="modal" data-target="#itemSellPrices" onclick="showItemSellPrices(this)">@MyERP.Properties.Resources.SalePrice</button>
                                                </td>
                                                <td class="tabledit-edit-mode">
                                                    <input type="hidden" class="car-type-id" />
                                                    <input type="hidden" class="car-model-id" />
                                                    <input type="hidden" class="car-color-id" />
                                                    <input type="hidden" class="chassis-no" />
                                                    <input type="hidden" class="engine-no" />
                                                    <input type="hidden" class="manufacturing-year" />
                                                    <input type="hidden" class="plate-no" />
                                                    <input type="hidden" class="vehicle-notes" />
                                                    <button class="btn btn-secondary vehicle-details-btn" data-toggle="modal" data-target="#vehicleDetailsModal" onclick="showVehicleDetails(this)">بيانات السيارة</button>
                                                </td>

                                                <td>
                                                    <a href="javascript:void(0);" onclick="deleteElement(this)">
                                                        <i class="fas fa-trash-alt"></i>
                                                    </a>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>

                                <hr />
                                <div class="form-group row totals">
                                    <label for="Total" class="control-label col-sm-2">@MyERP.Properties.Resources.Total:</label>
                                    <div class="col-sm-2">
                                        @Html.EditorFor(model => model.Total, new { htmlAttributes = new { @class = "form-control money", type = "text", id = "Total", @readonly = "readonly" } })
                                        @Html.ValidationMessageFor(model => model.Total, "", new { @class = "text-danger" })
                                    </div>
                                    <label for="VoucherDiscountValue" class="control-label col-sm-1">@MyERP.Properties.Resources.DiscountValue : </label>
                                    <div class="col-sm-2">
                                        @Html.EditorFor(model => model.VoucherDiscountValue, new { htmlAttributes = new { @class = "form-control money", id = "DiscountValue", type = "text", value = "0" } })
                                        @Html.ValidationMessageFor(model => model.VoucherDiscountValue, "", new { @class = "text-danger" })
                                    </div>
                                    <label for="VoucherDiscountPercentage" class="control-label col-sm-1">@MyERP.Properties.Resources.DiscountPercentage : </label>
                                    <div class="col-sm-2">
                                        @Html.EditorFor(model => model.VoucherDiscountPercentage, new { htmlAttributes = new { @class = "form-control", value = "0" } })
                                        @Html.ValidationMessageFor(model => model.VoucherDiscountPercentage, "", new { @class = "text-danger" })
                                    </div>
                                </div>

                                <div class="form-group row totals">

                                    <label for="NetTotal" class="control-label col-sm-2">@MyERP.Properties.Resources.TotalAfterDiscount:</label>
                                    <div class="col-sm-2">
                                        @Html.EditorFor(model => model.NetTotal, new { htmlAttributes = new { @class = "form-control money", type = "text", @readonly = "readonly", id = "NetTotal", value = "0" } })
                                        @Html.ValidationMessageFor(model => model.NetTotal, "", new { @class = "text-danger" })
                                    </div>

                                    <div class="col-sm-4">
                                        <input type="checkbox" id="hasTaxes" @Html.Raw(Model != null && Model.SalesTaxes > 0 ? "checked" : "") />
                                        @MyERP.Properties.Resources.ApplySalesTaxesValue
                                    </div>
                                </div>

                                <div class="form-group row totals">

                                    <label for="SalesTaxes" class="control-label  col-sm-2  taxes" style="display:none;">@MyERP.Properties.Resources.PurchaseTaxes :</label>
                                    <div class="col-sm-2 taxes" style="display:none;">
                                        @Html.EditorFor(model => model.SalesTaxes, new { htmlAttributes = new { @class = "form-control money taxes", id = "SalesTaxes", type = "text", value = "0" } })
                                        @Html.ValidationMessageFor(model => model.SalesTaxes, "", new { @class = "text-danger" })
                                    </div>
