                            text: " ",
                            icon: 'success',
                            showCancelButton: false,
                            confirmButtonText: '@MyERP.Properties.Resources.Ok',
                            confirmButtonColor: '#3085d6'
                        });
                        console.log(r.id);
                        $('#pleasewait').fadeOut();
                        if (n == "report") {
                            window.open("/Report/PurchaseInvoice?print=true&id=" + r.id);
                            window.location.replace("/PurchaseInvoice");
                        }
                        else {
                            window.location.replace("/PurchaseInvoice/AddEditSerialNumber/" + $('#Id').val() + '?itemId=' + generalItemId);
                        }
                    } else {
                        $('#pleasewait').fadeOut();
