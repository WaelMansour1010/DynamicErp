    function addSerialNumbers(rows, itemName, itemId) {
        //var div = '<div class="panel panel-default" hidden><div class="panel-heading" role="tab" id="heading' + itemId + '"><h4 class="panel-title"><a role="button" data-parent="#accordion1" href="#coll' + itemId + '" aria-expanded="false" aria-controls="coll' + itemId + '"> الكمية :' + rows + '</a></h4></div ><div id="coll' + itemId + '" class="panel-collapse collapse in" role="tabpanel" aria-labelledby="heading' + itemId + '"><div class="panel-body"><table class="table table-hover table-condensed"><thead><tr><th class="col-sm-1">#</th><th class="col-sm-11">السريال</th><th hidden></th></tr></thead><tbody class="serialNumbers"></tbody></table></div></div></div>'
        //$('#accordion1').append(div);
        for (var i = 1; i <= rows; i++) {
            $('#serialTable').append('<tr><td ><label">' + i +'</label"></td> <td > <input type="text" onkeypress="checkEnter(event,this);" class="serialNumber form-control  form-control-sm" /></td></tr>')
            //$('#accordion1 tbody:last').append('<tr><td class="col-sm-1"><label">' + i + '</label></td><td class="col-sm-11"><input type="text" onkeypress="checkEnter(event,this);"  class="serialNumber form-control" /></td><td hidden> <input type="hidden" class="itemId" value="' + itemId + '" hidden/></td></tr>');
        }
        $('#itemQuantity').val(rows);
