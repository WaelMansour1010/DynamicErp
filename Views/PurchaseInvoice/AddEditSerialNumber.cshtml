    function deleteElement(e) {
        var tr = $(e).closest('tr');

        if ($(tr).index() > 0) {
            e.parentNode.parentNode.parentNode.removeChild(e.parentNode.parentNode);
        } else if ($(tr).index() == 0 && $(tr).closest('tbody').children('tr').length > 1) {
            e.parentNode.parentNode.parentNode.removeChild(e.parentNode.parentNode);

        } else if ($(tr).index() == 0 && $(tr).closest('tbody').children('tr').length == 1) {
            $(tr).find(".money").val(0);
            $(tr).find('input[type = "number"]').val(0);
        }
        CalculateTotals().then();
        serialpanels().then();
        addToPurchaseInvoiceDetails().then();
    }

        function generateSerial() {
        if ($('#itemQuantity').val() == $('#generatedSerialCount').val())
            //alert('@MyERP.Properties.Resources.SorryAllSerialsHaveBeenEntered');
             Swal.fire({
                            title: '@MyERP.Properties.Resources.SorryAllSerialsHaveBeenEntered',
                            text: " ",
                            icon: 'info',
                            showCancelButton: false,
                            confirmButtonText: '@MyERP.Properties.Resources.Ok',
                            confirmButtonColor: '#3085d6'
                        });
        else if ($('#serialStart').val() == null || $('#serialStart').val() ==0)
           // alert('@MyERP.Properties.Resources.PleaseEnterTheBeginningOfSerial');
             Swal.fire({
                            title: '@MyERP.Properties.Resources.PleaseEnterTheBeginningOfSerial',
                            text: " ",
                            icon: 'info',
                            showCancelButton: false,
                            confirmButtonText: '@MyERP.Properties.Resources.Ok',
                            confirmButtonColor: '#3085d6'
                        });
        else if ($('#serialCount').val() == null || $('#serialCount').val()==0)
           // alert('@MyERP.Properties.Resources.PleaseEnterTheNumberOfSerials');
            Swal.fire({
                title: '@MyERP.Properties.Resources.PleaseEnterTheNumberOfSerials',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        else {
            var start = parseInt( $('#serialStart').val());
            var count = parseInt( $('#serialCount').val());
            for (var j = 0; j < count; j++) {
                if (j < count) {

                    if ($('#itemQuantity').val() > ItemSerialsNumbers.length) {
                        ItemSerialsNumbers.push({
                            ItemId: generalItemId,
                            SerialNumber: start
                        });
                        start = start + 1;
                        //count = count - 1;
                    }
                }
            }



         //   serialpanels();
            let i = 0;
          //  let itemId = 0;
            for (var j = 0; j < ItemSerialsNumbers.length; j++) {

                $('#serialTable').children('tr').eq(j).find('.serialNumber').val(ItemSerialsNumbers[j].SerialNumber);
            }
            $('#generatedSerialCount').val(ItemSerialsNumbers.length);
        }
    }

    function addEdit(n) {
        var serialNumbers = [];
        var valid = true;
        if (valid && ShowSerialNumbers == 'True') {
            $('#serialTable tr').each(function () {
                var td = $(this);
                console.log(td);
                var serialNumber = '';
             //   if (td.find('.itemId').val() == generalItemId) {//get serial of selected item only
                serialNumber = {
                    ItemId: generalItemId,
                        SerialNumber: td.find('.serialNumber').val()
                    };
               // }
                serialNumber.SerialNumber ? serialNumbers.push(serialNumber) : null;
            });

            serialNumbers.some(function (serialNumber) {
                if (serialNumber.ItemId) {
                    valid = true;
                } else {
                    valid = false;
                    //alert("@MyERP.Properties.Resources.MakeSureAllSerialDataCompleted");
                    Swal.fire({
                        title: '@MyERP.Properties.Resources.MakeSureAllSerialDataCompleted',
                        text: " ",
                        icon: 'info',
                        showCancelButton: false,
                        confirmButtonText: '@MyERP.Properties.Resources.Ok',
                        confirmButtonColor: '#3085d6'
                    });
                    return true;
                }
            });
        }

        if (valid) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.AreYouSureYouWantToSave',
                text: " ",
                icon: 'info',
                showCancelButton: true,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                cancelButtonText: '@MyERP.Properties.Resources.Cancel',
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    $('#pleasewait').fadeIn();
                    $.ajax({
                        type: "POST", contentType: "application/json",
                        url: "/PurchaseInvoice/AddEditSerialNumber",
                        data:
                            JSON.stringify({
                                purchaseInvoiceId: $('#Id').val(),
                                itemId: generalItemId,
                                serialNumbers: serialNumbers,
                            }),
                        success: function (r) {
                            if (r.success == "true") {
                                // alert("@MyERP.Properties.Resources.Saved");
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.Saved',
                                    text: " ",
                                    icon: 'success',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                                console.log(r.id);
                                $('#pleasewait').fadeOut();
                                if (n == "report") {
                                    window.open("/Report/PurchaseInvoice?print=true&id=" + r.id);
                                    window.location.replace("/PurchaseInvoice");
                                }
                                else {
                                    window.location.replace("/PurchaseInvoice/AddEditSerialNumber/" + $('#Id').val() + '?itemId=' + generalItemId);
                                }
                            } else {
                                $('#pleasewait').fadeOut();
                                // alert("@MyERP.Properties.Resources.NotSaved");
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.NotSaved',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                            }
                        },
                        error: function (r) {
                            $('#pleasewait').fadeOut();
                            console.log(r.response)
                            // alert("@MyERP.Properties.Resources.NotSaved");
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.NotSaved',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                        }
                    });
                }
                else { result.dismiss; }
            });
        }
        @*if (valid && confirm('@MyERP.Properties.Resources.AreYouSureYouWantToSave')) {
            $('#pleasewait').fadeIn();
            $.ajax({
                type: "POST", contentType: "application/json",
                url: "/PurchaseInvoice/AddEditSerialNumber",
                data:
                    JSON.stringify({
                        purchaseInvoiceId: $('#Id').val(),
                        itemId: generalItemId,
                        serialNumbers: serialNumbers,
                    }),
                success: function (r) {
                    if (r.success == "true") {
                        // alert("@MyERP.Properties.Resources.Saved");
                        Swal.fire({
