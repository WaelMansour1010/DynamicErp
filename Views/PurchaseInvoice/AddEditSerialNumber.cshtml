@model MyERP.Models.PurchaseInvoice

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = MyERP.Properties.Resources.PurchaseInvoiceSerialNumber;
}
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">

                <a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
            </div>
            <h4 class="page-title">@MyERP.Properties.Resources.PurchaseInvoiceSerialNumber </h4>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class=" card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal needs-validation" role="form">
                        <div class="card">
                            <div class="card-body">
                                <div class="form-horizontal">
                                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                    @if (Model != null && Model.Id > 0)
                                    {
                                        @Html.HiddenFor(model => model.Id)
                                    }
                                    <div class="panel-group" id="accordion">
                                        <div class="panel panel-default">
                                            <div class="panel-body">
                                                <div class="form-group row">
                                                    <label class=" col-sm-2 control-label" for="DocumentNumber"> @MyERP.Properties.Resources.DocNo </label>
                                                    <div class="col-sm-4">
                                                        @Html.EditorFor(model => model.DocumentNumber, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly", placeholder = @MyERP.Properties.Resources.DocNo, @disabled = "disabled" } })
                                                        <div class="invalid-feedback">
                                                            @MyERP.Properties.Resources.Required
                                                        </div>
                                                    </div>

                                                    <label for="VoucherDate" class="control-label col-sm-2">@MyERP.Properties.Resources.VoucherDate</label>
                                                    <div class="col-sm-4">
                                                        @Html.EditorFor(model => model.VoucherDate, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly", @disabled = "disabled" } })

                                                        <div class="invalid-feedback">
                                                            @MyERP.Properties.Resources.Required
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="form-group row">
                                                    <label for="DepartmentId" class="col-sm-2 control-label">@MyERP.Properties.Resources.Department</label>
                                                    <div class="col-sm-4">
                                                        @Html.DropDownList("DepartmentId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", @required = "required", @disabled = "disabled" })
                                                        <div class="invalid-feedback">
                                                            @MyERP.Properties.Resources.Required
                                                        </div>
                                                    </div>

                                                    <label for="WarehouseId" class="col-sm-2 control-label">@MyERP.Properties.Resources.WareHouse</label>
                                                    <div class="col-sm-4">
                                                        @Html.DropDownList("WarehouseId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", @required = "required", @disabled = "disabled" })
                                                        <div class="invalid-feedback">
                                                            @MyERP.Properties.Resources.Required
                                                        </div>
                                                    </div>
                                                </div>
                                                <hr />
                                                <div class="form-group row">
                                                    <label class="col-sm-2 control-label" for="selectedItems">@MyERP.Properties.Resources.Item</label>
                                                    <div class="col-sm-4">
                                                        <select id="selectedItems" class=" form-control"></select>
                                                    </div>
                                                    <label class="col-sm-2 control-label">@MyERP.Properties.Resources.Qty</label>
                                                    <div class="col-sm-4">
                                                        <input type="text" id="itemQuantity" class="form-control" readonly="readonly" />
                                                    </div>
                                                    <hr />
                                                </div>
                                                <hr />
                                                <div class="form-group row">

                                                    <label class="col-sm-1 control-label">@MyERP.Properties.Resources.Start</label>
                                                    <div class="col-sm-2">
                                                        <input type="text" id="serialStart" class="form-control" />
                                                    </div>

                                                    <label class="col-sm-1 control-label">@MyERP.Properties.Resources.Count</label>
                                                    <div class="col-sm-2">
                                                        <input type="text" id="serialCount" class="form-control" />
                                                    </div>
                                                    <label class="col-sm-2 control-label"> @MyERP.Properties.Resources.NoOfCurrentSerials </label>
                                                    <div class="col-sm-2">
                                                        <input type="text" id="generatedSerialCount" class="form-control" readonly="readonly" />
                                                    </div>
                                                    <div class="col-sm-2">
                                                        <button class="btn btn-success" onclick="generateSerial()">
                                                            @MyERP.Properties.Resources.GenerateSerial
                                                        </button>
                                                    </div>

                                                </div>
                                                <div style="display:none" class="panel panel-default">
                                                    <div class="panel-body">
                                                        <div class="scr">
                                                            <table class="table table-hover table-condensed">

                                                                <tbody id="PurchaseInvoiceDetails">
                                                                    @if (Model != null && Model.Id > 0)
                                                                    {
                                                                        foreach (var item in Model.PurchaseInvoiceDetails)
                                                                        {
                                                                            <tr class="scr">
                                                                                <td class="col-sm-3">
                                                                                    <input type="hidden" class="item form-control" value="@item.ItemId" />
                                                                                    @if (Session["lang"].ToString() == "en" && item.Item.EnName != null)
                                                                                    {
                                                                                        <label class="item-name">@item.Item.EnName</label>
                                                                                    }
                                                                                    else
                                                                                    {
                                                                                        <label class="item-name">@item.Item.ArName</label>
                                                                                    }
                                                                                </td>

                                                                                <td class="width">
                                                                                    <input class="quantity b" oninput="validity.valid||(value='');" type="number" step="any" value="@item.Qty" />
                                                                                    <input type="hidden" class="quantityOnSystem" />
                                                                                </td>

                                                                            </tr>
                                                                        }

                                                                    }
                                                                </tbody>

                                                            </table>
                                                        </div>
                                                    </div>
                                                </div>


                                                <div class="col-sm-offset-2">
                                                    <button class="btn btn-success" onclick="addEdit()">
                                                        @MyERP.Properties.Resources.Save
                                                    </button>
                                                    <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>

                                                </div>

                                            </div>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="form-horizontal needs-validation" role="form">
                            <div class="table-responsive">


                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card-box">

            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-body">

                            <div class="form-horizontal needs-validation" role="form">
                                <div class="table-responsive">

                                    <table id="serialTable" class="table table-centered mb-0">
                                        <thead>
                                            <tr>
                                                <th>#</th>
                                                <th>@MyERP.Properties.Resources.SerialNo </th>

                                        </thead>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

