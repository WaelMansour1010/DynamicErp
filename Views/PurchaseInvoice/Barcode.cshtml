
@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Barcode</title>
    <script src="~/Scripts/JsBarcode.all.min.js"></script>
</head>
<body>
    <div style="width:135px;max-height:80px">
        <p style="width:auto;text-align:center;margin-bottom:3px;margin-top:3px;padding:0px;font-size:10px;font-weight:bold; max-height:20px"></p>
        <svg id="barcode" style="width:135px;max-height:60px;"></svg>
    </div>
    <script>
        JsBarcode("#barcode", "@ViewBag.Barcode");
        window.print();
    </script>
</body>
</html>
