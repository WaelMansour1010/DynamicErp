@{
    if (ViewBag.ShowReport == true)
    {
        Layout = null;
    }
    else
    {
        Layout = "~/Views/Shared/_Layout.cshtml";
    }
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = MyERP.Properties.Resources.ChartsOfAccounts;
}


<meta name="viewport" content="width=device-width" />
<title> @MyERP.Properties.Resources.ChartsOfAccounts </title>

@if (ViewBag.ShowReport == true)
{
    @Html.DevExpress().GetStyleSheets(
            new StyleSheet { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
            new StyleSheet { ExtensionSuite = ExtensionSuite.Editors },
            new StyleSheet { ExtensionSuite = ExtensionSuite.Report }
        )
    @Html.DevExpress().GetScripts(
            new Script { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
            new Script { ExtensionSuite = ExtensionSuite.Editors },
            new Script { ExtensionSuite = ExtensionSuite.Report }
        )

    <div>

        @Html.DevExpress().WebDocumentViewer(settings =>
   {
       settings.Name = "WebDocumentViewer";
   }).Bind(new DevExpress.XtraReports.Web.CachedReportSourceWeb(new ChartOfAccounts_Report(ViewBag.TypeId, ViewBag.ClassificationId, ViewBag.CategoryId, ViewBag.AccountId))).GetHtml()

    </div>
}
else
{
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <div class="form-horizontal needs-validation" role="form">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.ChartsOfAccounts
                                    </h5>
                                    <div class="form-group row">
                                        <label class=" col-sm-1 control-label" for="Code">@MyERP.Properties.Resources.Type</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("TypeId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                        <label class=" col-sm-1 control-label" for="Code">@MyERP.Properties.Resources.Classification</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("ClassificationId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class=" col-sm-1 control-label" for="Code">@MyERP.Properties.Resources.Class</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("CategoryId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                        <label class=" col-sm-1 control-label" for="Code">@MyERP.Properties.Resources.MainAccount</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("AccountId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-offset-2">
                        <button class="btn btn-success" onclick="DownloadReport()">
                            @MyERP.Properties.Resources.ShowReport
                        </button>
                        <button class="btn btn-success" onclick="ShowData()">
                            @MyERP.Properties.Resources.ShowData
                        </button>
                        <button class="btn btn-success" onclick="ShowReport()">
                            @MyERP.Properties.Resources.ShowDesign
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!--------------------------------ShowData Table --------------------------------------->
    <div class="row" id="AllTable" style="display:none">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <div class="form-horizontal needs-validation" role="form">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.ReportData
                                    </h5>

                                    <div class="table-responsive">
                                        <table class="table table-striped table-centered mb-0">
                                            <thead>
                                                <tr>
                                                    <th>
                                                        @MyERP.Properties.Resources.Code
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.ArName
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.EnName
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.MainAccount
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Type
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Classification
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Class
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.DebitOB
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.CreditOB
                                                    </th>
                                                </tr>
                                            </thead>
                                            <tbody id="ShowDataTable"></tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
    


    <!--***********************************************************************************************-->

}

<script>

    function ShowReport() {
        window.open('/Report/ChartofAccounts?TypeId=' + $('#TypeId').val() + '&ClassificationId=' + $('#ClassificationId').val() + '&CategoryId=' + $('#CategoryId').val() + '&AccountId=' + $('#AccountId').val() + '&showReport=' + true + '&print=' + false, "blank");
    }
    
    function DownloadReport() {
        window.open('/Report/ChartofAccounts?TypeId=' + $('#TypeId').val() + '&ClassificationId=' + $('#ClassificationId').val() + '&CategoryId=' + $('#CategoryId').val() + '&AccountId=' + $('#AccountId').val() + '&showReport=' + false+'&print='+true, "blank");
    }

    function ShowData() {
        $('#ShowDataTable').empty();
        $('#preloader, #status').fadeIn();

        $.get('/Helper/GetChartOfAccount?TypeId=' + $('#TypeId').val() + '&ClassificationId=' + $('#ClassificationId').val() + '&CategoryId=' + $('#CategoryId').val() + '&AccountId=' + $('#AccountId').val()).done(function (r) {
            $('#AllTable').show();
            for (var i = 0; i < r.length; i++) {
                r[i].Code = r[i].Code == null ? "" : r[i].Code;
                r[i].ArName = r[i].ArName == null ? "" : r[i].ArName;
                r[i].EnName = r[i].EnName == null ? "" : r[i].EnName;
                r[i].ParentAccount = r[i].ParentAccount == null ? "" : r[i].ParentAccount;
                r[i].Type = r[i].Type == null ? "" : r[i].Type;
                r[i].Classification = r[i].Classification == null ? "" : r[i].Classification;
                r[i].Category = r[i].Category == null ? "" : r[i].Category;
                r[i].ObDebit = r[i].ObDebit == null ? 0 : r[i].ObDebit;
                r[i].ObCredit = r[i].ObCredit == null ? 0 : r[i].ObCredit;

                let tr = '<tr><td><label class="control-label">' +
                    r[i].Code + '</label></td><td><label class="control-label">' +
                    r[i].ArName + '</label></td><td><label class="control-label">' +
                    r[i].EnName + '</label></td><td><label class="control-label">' +
                    r[i].ParentAccount + '</label></td><td><label class="control-label">' +
                    r[i].Type + '</label></td><td><label class="control-label">' +
                    r[i].Classification + '</label></td><td><label class="control-label">' +
                    r[i].Category + '</label></td><td><label class="control-label">' +
                    r[i].ObDebit + '</label></td><td><label class="control-label">' +
                    r[i].ObCredit + '</label></td></tr>';
                $('#ShowDataTable').append(tr);
            }

            $('#preloader, #status').fadeOut();
        });
    }


    function convertToJavaScriptDate(value) {
        if (value === null)
            return null;
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        return ((dt.getMonth() + 1 + "/" + dt.getDate() + "/" + dt.getFullYear()));
    }

</script>