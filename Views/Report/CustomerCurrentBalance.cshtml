
@{
    if (ViewBag.ShowReport == true)
    {
        Layout = null;
    }
    else
    {
        Layout = "~/Views/Shared/_Layout.cshtml";
    }
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = MyERP.Properties.Resources.CustomerCurrentBalance;
}

<meta name="viewport" content="width=device-width" />
<title> @MyERP.Properties.Resources.CustomerCurrentBalance </title>

@if (ViewBag.ShowReport == true)
{

    @Html.DevExpress().GetStyleSheets(
        new StyleSheet { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
        new StyleSheet { ExtensionSuite = ExtensionSuite.Editors },
        new StyleSheet { ExtensionSuite = ExtensionSuite.Report }
    )
    @Html.DevExpress().GetScripts(
        new Script { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
        new Script { ExtensionSuite = ExtensionSuite.Editors },
        new Script { ExtensionSuite = ExtensionSuite.Report }
    )

    <div>
        @Html.DevExpress().WebDocumentViewer(settings =>
   {
       settings.Name = "WebDocumentViewer";
   }).Bind(new DevExpress.XtraReports.Web.CachedReportSourceWeb(new CustomerCurrentBalance_Report(ViewBag.DepartmentId,ViewBag.ShowDepartmentCustomer, ViewBag.ActivityId, ViewBag.CompanyId))).GetHtml()
    </div>
}
else
{

    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <div class="form-horizontal needs-validation" role="form">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.CustomerCurrentBalance
                                    </h5>
                                    <div class="form-group row">
                                        <label class=" col-sm-1 control-label" for="Code">@MyERP.Properties.Resources.Department</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("DepartmentId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control",
                                           required = "required"
                                       })
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>
                                        <div class="col-sm-6">
                                            <input type="checkbox" id="ShowDepartmentCustomer" style="width:15px;">
                                            <label class="col-sm-8 control-label " for="ShowDepartmentCustomer">@MyERP.Properties.Resources.ShowDepartmentCustomer</label>
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class=" col-sm-1 control-label">@MyERP.Properties.Resources.Activity</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("ActivityId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                        <label class=" col-sm-1 control-label">@MyERP.Properties.Resources.Company</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("CompanyId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>

                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-offset-2">
                        <button class="btn btn-success" onclick="DownloadReport()">
                            @MyERP.Properties.Resources.ShowReport
                        </button>
                        <button class="btn btn-success" onclick="ShowData()">
                            @MyERP.Properties.Resources.ShowData
                        </button>
                        <button class="btn btn-success" onclick="ShowReport()">
                            @MyERP.Properties.Resources.ShowDesign
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!--------------------------------ShowData Table --------------------------------------->
    <div class="row" id="AllTable" style="display:none">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <div class="form-horizontal needs-validation" role="form">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.ReportData
                                    </h5>

                                    <div class="table-responsive">
                                        <table class="table table-striped table-centered mb-0">
                                            <thead>
                                                <tr>
                                                    <th>
                                                        @MyERP.Properties.Resources.Customer
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.LastDocumentType
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.DocNo
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.LastDocumentDate
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.JournalEntrieNo
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.LastPaymentValue
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.DebitBalance
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.CreditBalance
                                                    </th>
                                                </tr>
                                            </thead>
                                            <tbody id="ShowDataTable"></tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-12">
            <div style="text-align:center;margin-bottom: 50px;">
                <div class="form-group row">
                    <div class="col-sm-6">
                        <select id="ShowByPage" class="form-control" style="width:70px;float:left;" onchange="ShowData()">
                            <option value="100">100</option>
                            <option value="200">200</option>
                            <option value="300">300</option>
                            <option value="@ViewBag.Count">@MyERP.Properties.Resources.All</option>
                        </select>
                        <span style="font-size:12px;float:right;"> @MyERP.Properties.Resources.NoOfResults: <span id="RowsCount">@ViewBag.Count</span></span>
                    </div>
                    <div class="col-sm-6">
                        <select id="pagination" class="pagination form-control col-sm-4" style="width:70px;float:left;"></select>
                        <lablel class="col-sm-2"> @MyERP.Properties.Resources.PageNo: </lablel>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <!--***********************************************************************************************-->

}

<script>
    var pageNo = 1;
    $('#ShowByPage').val('@ViewBag.wantedRowsNo');

    function ShowReport() {
        if ($('#ShowDepartmentCustomer').prop('checked')&&!$('#DepartmentId').val())
            Swal.fire({
                title: '@MyERP.Properties.Resources.Department' + ' ' + '@MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        else {
            window.open('/Report/CustomerCurrentBalance?DepartmentId=' + $('#DepartmentId').val() + '&ShowDepartmentCustomer=' + $('#ShowDepartmentCustomer').prop('checked')+ '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val() + '&showReport=' + true+'&print='+false, "blank");
        }
    }
    function DownloadReport() {
        if ($('#ShowDepartmentCustomer').prop('checked')&&!$('#DepartmentId').val())
            Swal.fire({
                title: '@MyERP.Properties.Resources.Department' + ' ' + '@MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        else {
            window.open('/Report/CustomerCurrentBalance?DepartmentId=' + $('#DepartmentId').val() + '&ShowDepartmentCustomer=' + $('#ShowDepartmentCustomer').prop('checked')+ '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val() + '&showReport=' + false + '&print=' +true, "blank");
        }
    }

    function ShowData() {
       
        if ($('#ShowDepartmentCustomer').prop('checked') &&!$('#DepartmentId').val())
            Swal.fire({
                title: '@MyERP.Properties.Resources.Department' + ' ' + '@MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        else {
            $('#ShowDataTable').empty();
            $('#preloader, #status').fadeIn();

            $.get('/Helper/GetCustomerCurrentBalance?DepartmentId=' + $('#DepartmentId').val() + '&ShowDepartmentCustomer=' + $('#ShowDepartmentCustomer').prop('checked')+ '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val() + '&pageIndex=' + pageNo + '&wantedRowsNo=' + $('#ShowByPage').val()).done(function (r) {
                $('#AllTable').show();
            for (var i = 0; i < r.length; i++) {
               r[i].Date= r[i].Date == null ? "" : convertToJavaScriptDate(r[i].Date);
               r[i].Customer = r[i].Customer == null ? "" : r[i].Customer;
               r[i].ArName = r[i].ArName == null ? "" : r[i].ArName;
               r[i].CreditBalance = r[i].Credit > r[i].Debit ? r[i].Credit - r[i].Debit : 0;
               r[i].DebitBalance = r[i].Debit > r[i].Credit ? r[i].Debit - r[i].Credit : 0;
                r[i].JournalDocNum = r[i].JournalDocNum == null ? "" : r[i].JournalDocNum;
                r[i].DocumentNumber = r[i].DocumentNumber == null ? "" : r[i].DocumentNumber;
                r[i].Amount = r[i].Amount == null ? 0 : r[i].Amount;

                let tr = '<tr><td><label class="control-label Customer">' +
                    r[i].Customer + '</label></td><td><label class="control-label ArName">' +
                    r[i].ArName + '</label></td><td><label class="control-label DocumentNumber">' +
                    r[i].DocumentNumber + '</label></td><td><label class="control-label Date">' +
                    r[i].Date + '</label></td><td><label class="control-label JournalDocNum">' +
                    r[i].JournalDocNum + '</label></td><td><label class="control-label Amount">' +
                    r[i].Amount + '</label></td><td><label class="control-label DebitBalance">' +
                    r[i].DebitBalance + '</label></td><td><label class="control-label CreditBalance">' +
                    r[i].CreditBalance + '</label></td></tr>';
                $('#ShowDataTable').append(tr);
            }
            
            $('#preloader, #status').fadeOut();
            });
        }
    }

    function setPages() {
        var count ='@ViewBag.Count';
        for (var i = 0; i < Math.ceil(count / $('#ShowByPage').val()); i++)
   $('#pagination').append('<option onchange="pageNo=' + (i + 1) + '; paging();" id="pg' + (i + 1) + '">' + (i + 1) + '</option>');
    }

    setPages();

    $('#pg' +'@ViewBag.PageIndex').attr('selected', 'selected');

    $('#pagination').on('change', function () {
        pageNo = $('#pagination').val();
        ShowData();
    });

    function convertToJavaScriptDate(value) {
        if (value === null)
            return null;
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        return ((dt.getMonth() + 1 + "/" + dt.getDate() + "/" + dt.getFullYear()));
    }

</script>