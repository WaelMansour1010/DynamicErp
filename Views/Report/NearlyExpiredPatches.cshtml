    function ShowReport() {
        @*if (!$('#CashBoxId').val())
            Swal.fire({
                title: '@MyERP.Properties.Resources.CashBox' + ' ' + '@MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        else {*@
        window.open('/Report/NearlyExpiredPatches?DaysNo=' + $('#DaysNo').val() + '&WarehouseId=' + $('#WarehouseId').val() + '&DepartmentId=' + $('#DepartmentId').val() + '&From=' + $('#DateFrom').val() + '&To=' + $('#DateTo').val()+ '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val() + '&showReport=' + true+'&print='+false, "blank");
        //}
    }
    function DownloadReport() {
        @*if (!$('#CashBoxId').val())
            Swal.fire({
                title: '@MyERP.Properties.Resources.CashBox' + ' ' + '@MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        else {*@
        window.open('/Report/NearlyExpiredPatches?DaysNo=' + $('#DaysNo').val() + '&WarehouseId=' + $('#WarehouseId').val() + '&DepartmentId=' + $('#DepartmentId').val() + '&From=' + $('#DateFrom').val() + '&To=' + $('#DateTo').val()+ '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val() + '&showReport=' + false+'&print='+true, "blank");
        //}
    }

    function ShowData() {
      
        @*if (!$('#CashBoxId').val())
            Swal.fire({
                title: '@MyERP.Properties.Resources.CashBox' + ' ' + '@MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        else {*@
            $('#ShowDataTable').empty();
            $('#preloader, #status').fadeIn();

        $.get('/Helper/GetNearlyExpiredPatches?DaysNo=' + $('#DaysNo').val() + '&WarehouseId=' + $('#WarehouseId').val() + '&DepartmentId=' + $('#DepartmentId').val() + '&From=' + $('#DateFrom').val() + '&To=' + $('#DateTo').val()+ '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val()).done(function (r) {
            $('#AllTable').show();
            for (var i = 0; i < r.length; i++) {
                r[i].ExpiryDate = r[i].ExpiryDate == null ? "" : convertToJavaScriptDate(r[i].ExpiryDate);
                r[i].Qty = r[i].Qty == null ? 0 : r[i].Qty;
                r[i].ArName = r[i].ArName == null ? "" : r[i].ArName;
                r[i].ItemCode = r[i].ItemCode == null ? "" : r[i].ItemCode;

                    let tr = '<tr><td><label class="control-label">' +
                        r[i].ItemCode + '</label></td><td><label class="control-label">' +
                        r[i].ArName + '</label></td><td><label class="control-label">' +
                        r[i].ExpiryDate + '</label></td><td><label class="control-label">' +
                        r[i].Qty + '</label></td></tr>';

                $('#ShowDataTable').append(tr);
               
            }
           
            $('#preloader, #status').fadeOut();
            });
        //}
    }

    function convertToJavaScriptDate(value) {
        if (value === null)
            return null;
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        return ((dt.getMonth() + 1 + "/" + dt.getDate() + "/" + dt.getFullYear()));
    }

</script>
