@model RoomLeavePermissionInDate_Report

@{
    if (ViewBag.ShowReport == true)
    {
        Layout = null;
    }
    else
    {
        Layout = "~/Views/Shared/_Layout.cshtml";
    }
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = MyERP.Properties.Resources.RoomLeaveInDate;
}

<!DOCTYPE html>


<meta name="viewport" content="width=device-width" />
<title>@MyERP.Properties.Resources.RoomLeaveInDate</title>
@if (ViewBag.ShowReport == true)
{
    @Html.DevExpress().GetStyleSheets(
            new StyleSheet { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
            new StyleSheet { ExtensionSuite = ExtensionSuite.Editors },
            new StyleSheet { ExtensionSuite = ExtensionSuite.Report }
            )
    @Html.DevExpress().GetScripts(
            new Script { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
            new Script { ExtensionSuite = ExtensionSuite.Editors },
            new Script { ExtensionSuite = ExtensionSuite.Report }
            )

    @Html.DevExpress().WebDocumentViewer(settings =>
{
    settings.Name = "WebDocumentViewer";
}).Bind(new DevExpress.XtraReports.Web.CachedReportSourceWeb(new RoomLeavePermissionInDate_Report(ViewBag.Date))).GetHtml()

}
else
{
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <div class="form-horizontal needs-validation" role="form">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.RoomLeaveInDate

                                    </h5>
                                    
                                    <div class="form-group row">
                                        <label for="Date" class="control-label col-sm-2">@MyERP.Properties.Resources.Date</label>
                                        <div class="col-sm-4">
                                            <input id="Date" name="Date" class="form-control" type="date" required />
                                            <div class="invalid-feedback">
                                                @MyERP.Properties.Resources.Required
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-offset-2">
                        <button class="btn btn-success" onclick="ShowReport()">
                            @MyERP.Properties.Resources.ShowReport
                        </button>
                        <button class="btn btn-success" onclick="ShowData()">
                            @MyERP.Properties.Resources.ShowData
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!--------------------------------ShowData Table --------------------------------------->
    <div class="row" id="AllTable" style="display:none">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <div class="form-horizontal needs-validation" role="form">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.ReportData
                                    </h5>

                                    <div class="table-responsive">
                                        <table class="table table-striped table-centered mb-0">
                                            <thead>
                                                <tr>
                                                    <th>
                                                        @MyERP.Properties.Resources.RoomLeavePermissionNumber
                                                    </th> 
                                                    <th>
                                                        @MyERP.Properties.Resources.RoomLeavePermissionDate
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Building
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Room
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Customer
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.CustomerTel
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Department
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.ReservationNumber
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.BookingStartDate
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.BookingEndDate
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.ResponsibleEmployee
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Insurance
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.InsuranceDeduction
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Remain
                                                    </th>

                                                </tr>
                                            </thead>
                                            <tbody id="ShowDataTable">
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    @*<div class="row">
        <div class="col-12">
            <div style="text-align:center;margin-bottom: 50px;">
                <div class="form-group row">
                    <div class="col-sm-6">
                        <select id="ShowByPage" class="form-control" style="width:70px;float:left;" onchange="ShowData()">
                            <option value="100">100</option>
                            <option value="200">200</option>
                            <option value="300">300</option>
                            <option value="@ViewBag.Count">@MyERP.Properties.Resources.All</option>
                        </select>
                        <span style="font-size:12px;float:right;"> @MyERP.Properties.Resources.NoOfResults: <span id="RowsCount">@ViewBag.Count</span></span>
                    </div>
                    <div class="col-sm-6">
                        <select id="pagination" class="pagination form-control col-sm-4" style="width:70px;float:left;">
                        </select>
                        <lablel class="col-sm-2"> @MyERP.Properties.Resources.PageNo: </lablel>
                    </div>
                </div>
            </div>
        </div>
    </div>*@


    <!--***********************************************************************************************-->
}

<script>
    function JsDate(val) {
        var date = new Date(val);
        var dd = date.getDate();
        var mm = date.getMonth() + 1; //January is 0!
        var yyyy = date.getFullYear();

        if (dd < 10) {
            dd = '0' + dd;
        }

        if (mm < 10) {
            mm = '0' + mm;
        }

       return date = yyyy + '-' + mm + '-' + dd;
    }
    $(document).ready(function () {

    });

    var pageNo = 1;
        $('#ShowByPage').val('@ViewBag.wantedRowsNo');

    function ShowReport() {
        if (!$('#Date').val()) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.Date' + ' ' + '@MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        }
        else {
            window.open('/Report/RoomLeavePermissionInDate?Date=' + $('#Date').val() + '&showReport=' + true, "blank");
        }
    }

    function ShowData() {
        if (!$('#Date').val()) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.Date' + ' ' + '@MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        }
        else {
            $('#ShowDataTable').empty();

            $('#preloader, #status').fadeIn();
            $.get('/Helper/GetRoomLeavePermissionInDate?Date=' + $('#Date').val()/* + '&pageIndex=' + pageNo + '&wantedRowsNo=' + $('#ShowByPage').val()*/).done(function (r) {
                if (r.length > 0) {
                    $('#AllTable').show();
                    for (var i = 0; i < r.length; i++) {
                        r[i].BookingStartDate = r[i].BookingStartDate == null ? "" : convertToJavaScriptDate(r[i].BookingStartDate);
                        r[i].BookingEndDate = r[i].BookingEndDate == null ? "" : convertToJavaScriptDate(r[i].BookingEndDate);
                        r[i].VoucherDate = r[i].VoucherDate == null ? "" : convertToJavaScriptDate(r[i].VoucherDate);
                        r[i].RegistrationDate = r[i].RegistrationDate == null ? "" : convertToJavaScriptDate(r[i].RegistrationDate);
                        r[i].RoomCode = r[i].RoomCode == null ? "" : r[i].RoomCode;
                        r[i].BuildingArName = r[i].BuildingArName == null ? "" : r[i].BuildingArName;
                        r[i].CustomerArName = r[i].CustomerArName == null ? "" : r[i].CustomerArName;
                        r[i].EmployeeArName = r[i].EmployeeArName == null ? "" : r[i].EmployeeArName;
                        r[i].RoomLeaveDocumentNumber = r[i].RoomLeaveDocumentNumber == null ? "" : r[i].RoomLeaveDocumentNumber.toString().replaceAll('-', '');
                        r[i].BookingDocumentNumber = r[i].BookingDocumentNumber == null ? "" : r[i].BookingDocumentNumber.toString().replaceAll('-', '');
                        r[i].CustomerMobile = r[i].CustomerMobile == null ? "" : r[i].CustomerMobile;
                        r[i].Insurance = r[i].Insurance == null ? 0 : r[i].Insurance;
                        r[i].InsuranceDeduction = r[i].InsuranceDeduction == null ? 0 : r[i].InsuranceDeduction;
                        r[i].Remain = r[i].Remain == null ? 0 : r[i].Remain;
                        let tr = '<tr><td><label class="control-label">' +
                            r[i].RoomLeaveDocumentNumber + '</label></td><td><label class="control-label">' +
                            r[i].VoucherDate + '</label></td><td><label class="control-label">' +
                            r[i].BuildingArName + '</label></td><td><label class="control-label">' +
                            r[i].RoomCode + '</label></td><td><label class="control-label">' +
                            r[i].CustomerArName + '</label></td><td><label class="control-label">' +
                            r[i].CustomerMobile + '</label></td><td><label class="control-label">' +
                            r[i].DepartmentArName + '</label></td><td><label class="control-label">' +
                            r[i].BookingDocumentNumber + '</label></td><td><label class="control-label">' +
                            r[i].BookingStartDate + '</label></td><td><label class="control-label">' +
                            r[i].BookingEndDate + '</label></td><td><label class="control-label">' +
                            r[i].EmployeeArName + '</label></td><td><label class="control-label">' +
                            r[i].Insurance + '</label></td><td><label class="control-label">' +
                            r[i].InsuranceDeduction + '</label></td><td><label class="control-label">' +
                            r[i].Remain + '</label></td></tr>';
                        $('#ShowDataTable').append(tr);

                    }

                }
            });
            $('#preloader, #status').fadeOut();
        }
    }

    function setPages() {
        var count ='@ViewBag.Count';
        for (var i = 0; i < Math.ceil(count / $('#ShowByPage').val()); i++)
   $('#pagination').append('<option onchange="pageNo=' + (i + 1) + '; paging();" id="pg' + (i + 1) + '">' + (i + 1) + '</option>');
    }

    setPages();

    $('#pg' +'@ViewBag.PageIndex').attr('selected', 'selected');

    $('#pagination').on('change', function () {
        pageNo = $('#pagination').val();
        ShowData();
    });

    function convertToJavaScriptDate(value) {
        if (value === null)
            return null;
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        return ((dt.getMonth() + 1 + "/" + dt.getDate() + "/" + dt.getFullYear()));
    }

</script>



