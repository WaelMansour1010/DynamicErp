@model  SalariesStatement_Report
@{
    if (ViewBag.ShowReport == true)
    {
        Layout = null;
    }
    else
    {
        Layout = "~/Views/Shared/_Layout.cshtml";
    }
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.SalariesStatement;
}


<meta name="viewport" content="width=device-width" />
<title>@MyERP.Properties.Resources.SalariesStatement</title>
@if (ViewBag.ShowReport == true)
{
    @Html.DevExpress().GetStyleSheets(
            new StyleSheet { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
            new StyleSheet { ExtensionSuite = ExtensionSuite.Editors },
            new StyleSheet { ExtensionSuite = ExtensionSuite.Report }
        )
    @Html.DevExpress().GetScripts(
            new Script { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
            new Script { ExtensionSuite = ExtensionSuite.Editors },
            new Script { ExtensionSuite = ExtensionSuite.Report }
        )
    <div>

        @Html.DevExpress().WebDocumentViewer(settings =>
   {
       settings.Name = "WebDocumentViewer1";
   }).Bind(new DevExpress.XtraReports.Web.CachedReportSourceWeb(new SalariesStatement_Report(ViewBag.DepartmentId, ViewBag.HrDepartmentId, ViewBag.Month, ViewBag.Year, ViewBag.ActivityId, ViewBag.CompanyId))).GetHtml()

    </div>
}
else
{
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <div class="form-horizontal needs-validation" role="form">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.SalariesStatement
                                    </h5>
                                    <div class="form-group row">
                                        <label class=" col-sm-1 control-label">@MyERP.Properties.Resources.Department</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("DepartmentId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                        <label class=" col-sm-1 control-label">@MyERP.Properties.Resources.HrDepartment</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("HrDepartmentId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                    </div>

                                    <div class="form-group row">
                                        <label class=" col-sm-1 control-label">@MyERP.Properties.Resources.Month</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("Month", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                        <label class=" col-sm-1 control-label">@MyERP.Properties.Resources.Year</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("Year", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class=" col-sm-1 control-label">@MyERP.Properties.Resources.Activity</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("ActivityId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                        <label class=" col-sm-1 control-label">@MyERP.Properties.Resources.Company</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("CompanyId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-offset-2">
                        <button class="btn btn-success" onclick="DownloadReport()">
                            @MyERP.Properties.Resources.ShowReport
                        </button>
                        <button class="btn btn-success" onclick="ShowData()">
                            @MyERP.Properties.Resources.ShowData
                        </button>
                        <button class="btn btn-success" onclick="ShowReport()">
                            @MyERP.Properties.Resources.ShowDesign
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!--------------------------------ShowData Table --------------------------------------->
    <div class="row" id="AllTable" style="display:none">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <div class="form-horizontal needs-validation" role="form">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.ReportData
                                    </h5>

                                    <div class="table-responsive">
                                        <table class="table table-striped table-centered mb-0">
                                            <thead>
                                                <tr>
                                                    <th>
                                                        @MyERP.Properties.Resources.Employee
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Department
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.HrDepartment
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.NoOfWorkingDays
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.AbsenceDays
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.RemainingDays
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.AdvancedExpences
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.OverTime
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Rewards
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Penalties
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.BorrowValue
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.TotalDues
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.TotalDeduction
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.NetSalary
                                                    </th>
                                                </tr>
                                            </thead>
                                            <tbody id="ShowDataTable"></tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!--***********************************************************************************************-->

}

<script>
    function JsDate(val) {
        var date = new Date(val);
        var dd = date.getDate();
        var mm = date.getMonth() + 1; //January is 0!
        var yyyy = date.getFullYear();

        if (dd < 10) {
            dd = '0' + dd;
        }

        if (mm < 10) {
            mm = '0' + mm;
        }

        return date = yyyy + '-' + mm + '-' + dd;
    }
    $(document).ready(function () {
        $.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
            var from = JsDate(r.PeriodStart);
            var to = JsDate(r.PeriodEnd);
            $('#DateFrom').prop('min', from);
            $('#DateFrom').prop('max', to);
            $('#DateFrom').val(from);
            $('#DateTo').prop('min', from);
            $('#DateTo').prop('max', to);
            $('#DateTo').val(to);
        });
    });

    function ShowReport() {
        let valid = true;
        if (!$('#Month').val()) {
            valid = false;
            alert('@MyERP.Properties.Resources.Month @MyERP.Properties.Resources.Required')
        }
         if (!$('#Year').val()) {
            valid = false;
            alert('@MyERP.Properties.Resources.Year @MyERP.Properties.Resources.Required')
        }
        if (valid) {
            window.open('/Report/SalariesStatement?DepartmentId=' + $('#DepartmentId').val() + '&HrDepartmentId=' + $('#HrDepartmentId').val()
                + '&Month=' + $('#Month').val() + '&Year=' + $('#Year').val()
                + '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val()
                + '&showReport=' + true + '&print=' + false, "blank");
        }
    }
    function DownloadReport() {
         let valid = true;
        if (!$('#Month').val()) {
            valid = false;
            alert('@MyERP.Properties.Resources.Month @MyERP.Properties.Resources.Required')
        }
         if (!$('#Year').val()) {
            valid = false;
            alert('@MyERP.Properties.Resources.Year @MyERP.Properties.Resources.Required')
        }
        if (valid) {
            window.open('/Report/SalariesStatement?DepartmentId=' + $('#DepartmentId').val() + '&HrDepartmentId=' + $('#HrDepartmentId').val()
                + '&Month=' + $('#Month').val() + '&Year=' + $('#Year').val()
                + '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val()
                + '&showReport=' + false + '&print=' + true, "blank");
        }
    }

    function ShowData() {
        $('#ShowDataTable').empty();
         let valid = true;
        if (!$('#Month').val()) {
            valid = false;
            alert('@MyERP.Properties.Resources.Month @MyERP.Properties.Resources.Required')
        }
         if (!$('#Year').val()) {
            valid = false;
            alert('@MyERP.Properties.Resources.Year @MyERP.Properties.Resources.Required')
        }
        if (valid) {
            $('#preloader, #status').fadeIn();
            $.get('/Helper/GetSalariesStatement?DepartmentId=' + $('#DepartmentId').val() + '&HrDepartmentId=' + $('#HrDepartmentId').val()
                + '&Month=' + $('#Month').val() + '&Year=' + $('#Year').val()
                + '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val()
            ).done(function (r) {
                $('#AllTable').show();
                for (var i = 0; i < r.length; i++) {
                    r[i].Employee = r[i].Employee == null ? "" : r[i].Employee;
                    r[i].Department = r[i].Department == null ? "" : r[i].Department;
                    r[i].HrDepartment = r[i].HrDepartment == null ? "" : r[i].HrDepartment;
                    r[i].NoOfWorkingDays = r[i].NoOfWorkingDays == null ? 0 : r[i].NoOfWorkingDays;
                    r[i].AbsenceDays = r[i].AbsenceDays == null ? 0 : r[i].AbsenceDays;
                    r[i].RemainingDays = r[i].RemainingDays == null ? 0 : r[i].RemainingDays;
                    r[i].AdvancedExpenses = r[i].AdvancedExpenses == null ? 0 : r[i].AdvancedExpenses;
                    r[i].TotalOvertime = r[i].TotalOvertime == null ? 0 : r[i].TotalOvertime;
                    r[i].TotalReward = r[i].TotalReward == null ? 0 : r[i].TotalReward;
                    r[i].TotalPenalty = r[i].TotalPenalty == null ? 0 : r[i].TotalPenalty;
                    r[i].BorrowValue = r[i].BorrowValue == null ? 0 : r[i].BorrowValue;
                    r[i].TotalDueItems = r[i].TotalDueItems == null ? 0 : r[i].TotalDueItems;
                    r[i].TotalDeductionItems = r[i].TotalDeductionItems == null ? 0 : r[i].TotalDeductionItems;
                    r[i].NetSalary = r[i].NetSalary == null ? 0 : r[i].NetSalary;

                    
                    let tr = '<tr><td><label class="control-label">' +
                        r[i].Employee + '</label></td><td><label class="control-label">' +
                        r[i].Department + '</label></td></td><td><label class="control-label">' +
                        r[i].HrDepartment + '</label></td><td><label class="control-label">' +
                        r[i].NoOfWorkingDays + '</label></td><td><label class="control-label">' +
                        r[i].AbsenceDays + '</label></td><td><label class="control-label">' +
                        r[i].RemainingDays + '</label></td><td><label class="control-label">' +
                        r[i].AdvancedExpenses + '</label></td><td><label class="control-label">' +
                        r[i].TotalOvertime + '</label></td><td><label class="control-label">' +
                        r[i].TotalReward + '</label></td><td><label class="control-label">' +
                        r[i].TotalPenalty + '</label></td><td><label class="control-label">' +
                        r[i].BorrowValue + '</label></td><td><label class="control-label">' +
                        r[i].TotalDueItems + '</label></td><td><label class="control-label">' +
                        r[i].TotalDeductionItems + '</label></td><td><label class="control-label">' +
                        r[i].NetSalary + '</label></td></tr>';
                    $('#ShowDataTable').append(tr);
                }
                $('#preloader, #status').fadeOut();
            });
            $('#preloader, #status').fadeOut();

        }
    }


    function convertToJavaScriptDate(value) {
        if (value === null)
            return null;
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        return ((dt.getMonth() + 1 + "/" + dt.getDate() + "/" + dt.getFullYear()));
    }

</script>
