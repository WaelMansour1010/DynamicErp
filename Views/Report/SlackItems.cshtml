
@{
    if (ViewBag.ShowReport == true)
    {
        Layout = null;
    }
    else
    {
        Layout = "~/Views/Shared/_Layout.cshtml";
    }
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = MyERP.Properties.Resources.SlackItems;
}


<meta name="viewport" content="width=device-width" />
<title>@MyERP.Properties.Resources.SlackItems</title>
@if (ViewBag.ShowReport == true)
{
    @Html.DevExpress().GetStyleSheets(
            new StyleSheet { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
            new StyleSheet { ExtensionSuite = ExtensionSuite.Editors },
            new StyleSheet { ExtensionSuite = ExtensionSuite.Report }
        )
    @Html.DevExpress().GetScripts(
            new Script { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
            new Script { ExtensionSuite = ExtensionSuite.Editors },
            new Script { ExtensionSuite = ExtensionSuite.Report }
        )

    <div>
        @Html.DevExpress().WebDocumentViewer(settings =>
   {
       settings.Name = "WebDocumentViewer";
   }).Bind(new DevExpress.XtraReports.Web.CachedReportSourceWeb(new SlackItems_Report(ViewBag.DepartmentId, ViewBag.From, ViewBag.To, ViewBag.GroupId, ViewBag.CategoryId, ViewBag.ActivityId, ViewBag.CompanyId))).GetHtml()
    </div>
}
else
{
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <div class="form-horizontal needs-validation" role="form">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.SlackItems
                                    </h5>
                                    <div class="form-group row">
                                        <label class=" col-sm-1 control-label" for="ArName">@MyERP.Properties.Resources.Department</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("DepartmentId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", required = "required" })
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class=" col-sm-1 control-label" for="Code">@MyERP.Properties.Resources.Group</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("GroupId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                            {
                                                @class = "form-control",
                                                required = "required"
                                            })
                                        </div>
                                        <label class=" col-sm-1 control-label" for="Code">@MyERP.Properties.Resources.Category</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("CategoryId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                            {
                                                @class = "form-control",
                                                required = "required"
                                            })
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label for="DateFrom" class="control-label col-sm-1">@MyERP.Properties.Resources.FromDate</label>
                                        <div class="col-sm-5">
                                            <input id="DateFrom" name="DateFrom" class="form-control" type="date" required />
                                        </div>
                                        <label for="DateTo" class="control-label col-sm-1">@MyERP.Properties.Resources.ToDate</label>
                                        <div class="col-sm-5">
                                            <input id="DateTo" name="DateTo" class="form-control" type="date" required />
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class=" col-sm-1 control-label">@MyERP.Properties.Resources.Activity</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("ActivityId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                        <label class=" col-sm-1 control-label">@MyERP.Properties.Resources.Company</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("CompanyId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-offset-2">
                        <button class="btn btn-success" onclick="DownloadReport()">
                            @MyERP.Properties.Resources.ShowReport
                        </button>
                        <button class="btn btn-success" onclick="ShowData()">
                            @MyERP.Properties.Resources.ShowData
                        </button>
                        <button class="btn btn-success" onclick="ShowReport()">
                            @MyERP.Properties.Resources.ShowDesign
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!--------------------------------ShowData Table --------------------------------------->
    <div class="row" id="AllTable" style="display:none">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <div class="form-horizontal needs-validation" role="form">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.ReportData
                                    </h5>

                                    <div class="table-responsive">
                                        <table class="table table-striped table-centered mb-0">
                                            <thead>
                                                <tr>
                                                    <th>
                                                        @MyERP.Properties.Resources.Code
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.ItemName
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Qty
                                                    </th>
                                                    <th>
                                                        @MyERP.Properties.Resources.Unit
                                                    </th>
                                                </tr>
                                            </thead>
                                            <tbody id="ShowDataTable"></tbody>
                                        </table>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!--***********************************************************************************************-->
}
<script>
    var pageNo = 1;
        $('#ShowByPage').val('@ViewBag.wantedRowsNo');

        function JsDate(val) {
        var date = new Date(val);
        var dd = date.getDate();
        var mm = date.getMonth() + 1; //January is 0!
        var yyyy = date.getFullYear();

        if (dd < 10) {
            dd = '0' + dd;
        }

        if (mm < 10) {
            mm = '0' + mm;
        }

        return date = yyyy + '-' + mm + '-' + dd;
    }
    $(document).ready(function () {
        $.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
            var from = JsDate(r.PeriodStart);
            var to = JsDate(r.PeriodEnd);
            $('#DateFrom').prop('min', from);
            $('#DateFrom').prop('max', to);
            $('#DateFrom').val(from);
            $('#DateTo').prop('min', from);
            $('#DateTo').prop('max', to);
            $('#DateTo').val(to);
        });
    });

    function ShowReport() {
        window.open('/Report/SlackItems?DepartmentId=' + $('#DepartmentId').val() + '&GroupId=' + $('#GroupId').val() + '&CategoryId=' + $('#CategoryId').val() + "&From=" + $('#DateFrom').val() + "&To=" + $('#DateTo').val()+ '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val() + '&showReport=' + true + '&print=' + false, "blank");
    }
    function DownloadReport() {
        window.open('/Report/SlackItems?DepartmentId=' + $('#DepartmentId').val() + '&GroupId=' + $('#GroupId').val() + '&CategoryId=' + $('#CategoryId').val() + "&From=" + $('#DateFrom').val() + "&To=" + $('#DateTo').val()+ '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val() + '&showReport=' + false + '&print=' + true, "blank");
    }

    function ShowData() {
        $('#ShowDataTable').empty();
        $('#preloader, #status').fadeIn();

        $.get('/Helper/GetSlackItems?DepartmentId=' + $('#DepartmentId').val() + '&GroupId=' + $('#GroupId').val() + '&CategoryId=' + $('#CategoryId').val() + "&From=" + $('#DateFrom').val() + "&To=" + $('#DateTo').val()+ '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val()).done(function (r) {
            $('#AllTable').show();
            for (var i = 0; i < r.length; i++) {

                r[i].Code = r[i].Code == null ? "" : r[i].Code;
                r[i].ArName = r[i].ArName == null ? "" : r[i].ArName;
                r[i].Quantity = r[i].Quantity == null ? "" : r[i].Quantity;
                r[i].UnitName = r[i].UnitName == null ? "" : r[i].UnitName;

                let tr = '<tr><td><label class="control-label Debit">' +
                    r[i].Code + '</label></td><td><label class="control-label ArName">' +
                    r[i].ArName + '</label></td><td><label class="control-label CreditBalance">' +
                    r[i].Quantity + '</label></td><td><label class="control-label DebitBalance">' +
                    r[i].UnitName + '</label></td></tr>';

                $('#ShowDataTable').append(tr);
            }
            $('#preloader, #status').fadeOut();
        });
    }
</script>