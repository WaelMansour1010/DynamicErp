    $(document).on('keydown', '#SearchItem', function (e) {
        if (e.which == 13 || e.keyCode == 13) {
            $('#ResultItems').empty();
            let searchTxt = $(this).val().trim().toUpperCase().split(' ');
            let filteredItems = items.filter(function (e) {
                let arName = e.ArName.toUpperCase();
                let termCount = searchTxt.length;
                let matchCount = 0;
                for (var i = 0; i < termCount; i++) {
                    let term = searchTxt[i];
                    for (var j = 0; j < arName.split(' ').length; j++) {
                        if (arName.split(' ')[j].indexOf(term) > -1) {
                            matchCount++;
                            if (matchCount == termCount)
                                return true;
                        }
                    }
                }
                return false;
            });

            $('#ResultItemModal').modal('show');
        for (var i = 0; i < filteredItems.length; i++) {
            let tr = ('<tr><td>' + (filteredItems[i].Barcode ? filteredItems[i].Barcode : '') + '</td><td><input hidden class="item-id" value="' + filteredItems[i].Id + '" /><input hidden class="items-prices-quantities-id" value="' + filteredItems[i].ItemPriceId + '" /><label class="nameOfItem">' + filteredItems[i].ArName + '</label></td><td>' + filteredItems[i].Price + '</td><td class="item-current-qty">' + filteredItems[i].Quantity + '</td><td><button class="btn btn-info" onclick="AddToItemSearch(' + filteredItems[i].ItemPriceId + ')" >'+'@MyERP.Properties.Resources.Add'+'</button></td></tr>');
             $('#ResultItems').append(tr);
        }
        $('#pleasewait').fadeOut();




        }
    });
