    $('#selectedItems').on('change', function () {
        $('#serialTable tr').each(function () {
            var ItemId = $(this).find('.itemId').val();
            if (ItemId) {
                if (ItemId == $('#selectedItems').val()) {
                    $(this).show();
                }
                else {
                    $(this).hide();
                }
            }
        });
    });
    $('#hasTaxes').on('click', function () {
        if ($('#hasTaxes').prop('checked')) {
            $('.taxes').show();
            $('.ItemTax').show();
        }
        else {
            $('.taxes').hide();
            $('.comercialTaxes').hide();
            $('#hasComercialTaxes').removeAttr('checked');
            hideShowComercialTax(false);
            $('#SalesTaxes').val(0);
            $('#TotalAfterTaxes').val(0);
            $('.ItemTax').hide();
        }
        CalculateTotals();
    });
    $('#hasComercialTaxes').on('click', function () {
        hideShowComercialTax($('#hasComercialTaxes').prop('checked'));
        CalculateTotals();
    });
    $('#InstallmentAdvance, #InstallmentProfitAmount').on('change', function () {
        let total = $('#TotalAfterTaxes').inputmask('unmaskedvalue');
        let InstallmentAdvance = $('#InstallmentAdvance').inputmask('unmaskedvalue') * 1;
        let TotalInstallmentBeforeProfit = total * 1 - InstallmentAdvance * 1;
        $('#TotalInstallmentBeforeProfit').val(TotalInstallmentBeforeProfit);
        let InstallmentProfitAmount = $('#InstallmentProfitAmount').inputmask('unmaskedvalue') * 1;
        let TotalInstallmentAfterProfit = InstallmentProfitAmount ? TotalInstallmentBeforeProfit + InstallmentProfitAmount : 0;
        $('#TotalInstallmentAfterProfit').val(TotalInstallmentAfterProfit);
        $('#InsallmentProfitPercentage').val(InstallmentProfitAmount * 100 / TotalInstallmentBeforeProfit);
        let InstallmentPaymentCount = $('#InstallmentPaymentCount').val();
        $('#InstallmentPaymentAmount').val(InstallmentPaymentCount ? TotalInstallmentAfterProfit / InstallmentPaymentCount : 0);
        $('#TotalAfterTotalInstallment').val(TotalInstallmentAfterProfit + InstallmentAdvance * 1);
        $('#CashAmount').val('0');
        $('#InstallmentAmount').val(TotalInstallmentAfterProfit + InstallmentAdvance * 1);
    });
    $('#InsallmentProfitPercentage').on('change', function () {
        let total = $('#TotalAfterTaxes').inputmask('unmaskedvalue');
        let InstallmentAdvance = $('#InstallmentAdvance').inputmask('unmaskedvalue') * 1;
        let TotalInstallmentBeforeProfit = total * 1 - InstallmentAdvance * 1;
        $('#TotalInstallmentBeforeProfit').val(TotalInstallmentBeforeProfit);
        let InsallmentProfitPercentage = $('#InsallmentProfitPercentage').inputmask('unmaskedvalue') / 100;
        let InstallmentProfitAmount = TotalInstallmentBeforeProfit * InsallmentProfitPercentage;
        let TotalInstallmentAfterProfit = TotalInstallmentBeforeProfit + InstallmentProfitAmount;
        $('#InstallmentProfitAmount').val(InstallmentProfitAmount);
        $('#TotalInstallmentAfteVViewBagBagewBagewBagrofit').val(TotalInstallmentAfterProfit);
        let InstallmentPaymentCount = $('#InstallmentPaymentCount').val();
        $('#InstallmentPaymentAmount').val(InstallmentPaymentCount ? TotalInstallmentAfterProfit / InstallmentPaymentCount : 0);
        $('#TotalAfterTotalInstallment').val(TotalInstallmentAfterProfit + InstallmentAdvance * 1);
        $('#CashAmount').val('0');
        $('#InstallmentAmount').val(TotalInstallmentAfterProfit + InstallmentAdvance * 1);
    });
