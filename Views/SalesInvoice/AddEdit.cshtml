    function showInvoiceProfit() {

        $('#showInvoiceProfit').prop('checked') ? $('.showProfit').show() : $('.showProfit').hide();
        totalInvoiceProfit = 0;
        $('.item').each(function () {
            if (!isNaN($(this).val()) && $(this).val() > 0) {
                //$('#pleasewait').fadeIn();
                var item = (this);
                //$.get('/SalesInvoice/GetItemPrice?customerId=' + $('#VendorOrCustomerId').val() + '&itemId=' + $(this).val()).done(function (r) {
                //    if (r) {

                //        $(item).closest('tr').find('.avgCost').val(r.AvgCost);
                //    }
                //    else {
                //        $(item).closest('tr').find('.avgCost').val(0);
                //    }
                let price = $(item).closest('tr').find('.price').inputmask('unmaskedvalue') * 1;
                let cost = $(item).closest('tr').find('.avgCost').val() * 1;
                let profit = (parseFloat(price) * 1 - parseFloat(cost)) * 1;
                profit = parseFloat(profit).toFixed(2);//to digits fraction

                $(item).closest('tr').find('.avgCostProfit').val((profit - $(item).closest('tr').find('.DiscountValue').val()) * $(item).closest('tr').find('.quantity').val());
                totalInvoiceProfit += profit * $(item).closest('tr').find('.quantity').val();

                // $('#pleasewait').fadeOut();
                //}).fail(function () {
                //    $('#pleasewait').fadeOut();
                //});
            }

        });
        $('#totalProfit').val(totalInvoiceProfit - $('#VoucherDiscountValue').inputmask('unmaskedvalue') * 1);
    }
    function hideShowComercialTax(show) {
        var totalAfterTaxesLabel = $('label[for="TotalAfterTaxes"]');
        var colsm2 = $('#TotalAfterTaxes').closest('.col-sm-2');
        if (show) {
            $('label[for="TotalAfterTaxes"]').remove();
            $('#TotalAfterTaxes').closest('.col-sm-2').remove();
            $('#CommercialRevenueTaxAmount').closest('.form-group').append($(totalAfterTaxesLabel));
            $('#CommercialRevenueTaxAmount').closest('.form-group').append($(colsm2));
            $('.comercialTaxes').show();
        }
        else {
            $('label[for="TotalAfterTaxes"]').remove();
            $('#TotalAfterTaxes').closest('.col-sm-2').remove();
            $(totalAfterTaxesLabel).insertAfter($('#SalesTaxes').closest('.col-sm-2'));
            $(colsm2).insertBefore($('#hasComercialTaxes').closest('.col-sm-2'));
            $('.comercialTaxes').hide();
            $('#CommercialRevenueTaxAmount').val(0);
            $('#TotalAfterTaxes').val(0);
        }
        $('#TotalAfterTaxes').inputmask({
            alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
        });
    }
    function CalculateTotals() {
        var total = 0;
        //var ItemTaxValue = 0;
        $('.total').each(function () {
            total += $(this).inputmask('unmaskedvalue') * 1;
        });

        $('#Total').val(total);
        if ($('#VoucherDiscountPercentage').inputmask('unmaskedvalue') < 100) {
            $('#VoucherDiscountValue').val(($('#VoucherDiscountPercentage').inputmask('unmaskedvalue') / 100) * total);
        } else {
            $('#VoucherDiscountPercentage').val(0);
            $('#VoucherDiscountValue').val(0);
        }
        if ($('#VoucherDiscountValue').val()) {
            total -= $('#VoucherDiscountValue').inputmask('unmaskedvalue');
        }
        $('#NetTotal').val(total);
        //if (includeFees) {
        //    let ServiceFees = $('#ServiceFeesPercentage').val() * total;
        //    $('#ServiceFees').val(ServiceFees);
        //    total += ServiceFees;
        //}

        //----------- Item Tax Calculations ---------------//
        $('.ItemTaxValue').each(function () {
            var _Total = $(this).closest('tr').find('.total').inputmask('unmaskedvalue');
            var _taxPerc = $(this).closest('tr').find('.ItemTaxPercentage ').val()*1/100;
            var _taxVal = (_Total * _taxPerc);
            $(this).val(_taxVal)
             //---- old code -----//
          //  ItemTaxValue += $(this).inputmask('unmaskedvalue') * 1;
        });
        //--------------------------------------------------------------------//
        if ($('#hasTaxes').prop('checked')) {
            var _SalesTax = $('#NetTotal').inputmask('unmaskedvalue') * taxPercentage;
            $('#SalesTaxes').val(_SalesTax)
            //---- old code -----//
     // $('#SalesTaxes').val(total * taxPercentage);
    //if(ItemTaxValue>0)
    //{
    //$('#SalesTaxes').val(ItemTaxValue);
    //}
            if ($('#hasComercialTaxes').prop('checked')) {
                $('#CommercialRevenueTaxAmount').val(total * .01);
                total -= total * .01;
            }
            total += $('#SalesTaxes').inputmask('unmaskedvalue') * 1;
        }
        $('#TotalAfterTaxes').val(total);

        $('#InstallmentAmount').val('0');
        if ($('#PaymentType').val() == 1) {
            $('#CashAmount').val(total);
        }
        else if ($('#PaymentType').val() == 2) {
            $('#DebitAmount').val(total);
        }
        if ($('#IsInstallmentPlan').prop('checked')) {
            $('#InstallmentAdvance').trigger('change');
        }
        showInvoiceProfit();
    }
    function setBankAccounts(bankAccount, id) {
        $(bankAccount).empty();
        return requestData('/SalesInvoice/SetBankAccounts?bankId=' + $(bankAccount).closest('tr').find('.BankId').val())
             .done(function (r) {
                 let BankAccounts = r;
                $(bankAccount).append('<option value>'+'@MyERP.Properties.Resources.Select'+'</option>');
                for (var i = 0; i < BankAccounts.length; i++) {
                    $(bankAccount).append($('<option>', {
                        value: BankAccounts[i].Id,
                        text: BankAccounts[i].AccountNumber
                    }));
                }
                id ? $(bankAccount).val(id).trigger('change') : null;
            });
    }
    function deleteElement(e) {
        let tr = $(e).closest('tr');
        if ($(tr).index() == 0 && $(tr).closest('tbody').children('tr').length == 1) {
            $(tr).find("input").val('');
            $(tr).find("label").text('');
            $(tr).find('input, select').removeAttr('required');
            $(tr).find('select').empty();
            $(tr).find('.Add-Button').prop('hidden', false);
            $(tr).find('.popupCell').attr('onclick', 'showSearchModal()');
        }
        else if ($(tr).index() < $(tr).closest('tbody').children('tr').length - 1)
            e.parentNode.parentNode.parentNode.removeChild(e.parentNode.parentNode);
        else if ($(tr).index() == $(tr).closest('tbody').children('tr').length - 1) {
            $(tr).find("input").val('');
            $(tr).find('input, select').removeAttr('required');
            $(tr).find('select').empty();
            $(tr).find("label").text('');
            $(tr).find('.Add-Button').prop('hidden', false);
            $(tr).find('.popupCell').attr('onclick', 'showSearchModal()');
        }
        //----------- Serial Number ---------------- //
        AddToSerialNumberTable(tr);
        AppendToSelectedItems($(tr).find(".quantity").val(), $(tr).find(".item").val(), $(tr).find(".name").text(), "delete")
        //-----------------------------------------------//
        CalculateTotals();

        let ItemPriceId = tr.find('.item').val();
        $('#container tr').each(function () {
            let row = $(this);
            if (ItemPriceId == row.closest('tr').find('.ItemId').val()) {
                row.remove();
            }
        });
    }
    function CalculateDiscountForOneItem(e, s) {
        let DiscountPerc = $(e).find('.DiscountPerc').val();
        let DiscountValue = $(e).find('.DiscountValue').val();
        let quantity = $(e).find('.quantity').val();
        let price = $(e).find('.price').inputmask('unmaskedvalue') * 1;
        let calculateTotalAfterDiscount;
        if (s == "Value") {
            calculateTotalAfterDiscount = (quantity * price) - (DiscountValue * quantity);
            let CalculateDiscountPercentFromValue = (DiscountValue / price) * 100;
            $(e).find('.DiscountPerc').val(CalculateDiscountPercentFromValue);
        }
        else if (s == "Percent") {
            let CalculateDiscountValueFromPercent = (price * DiscountPerc) / 100;
            $(e).find('.DiscountValue').val(CalculateDiscountValueFromPercent);
            calculateTotalAfterDiscount = (quantity * price) - (CalculateDiscountValueFromPercent * quantity);
        }
        else {
            calculateTotalAfterDiscount = quantity * price * 1;
        }
        $(e).find('.total').val(calculateTotalAfterDiscount);
        showInvoiceProfit();
        CalculateTotals();
    }
    function postInstallmentActualPayment() {
        let valid = true;
        if (!$('#InstallmentActualPaymentAmount').val()) {
            valid = false;
            Swal.fire({
                title: '@MyERP.Properties.Resources.Amount @MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        }
        if (valid && !$('#InstallmentActualPaymentCashBoxId').val()) {
            valid = false;
            Swal.fire({
                title: '@MyERP.Properties.Resources.CashBox @MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        }
        if (valid && !$('#InstallmentActualPaymentDate').val()) {
            valid = false;
            Swal.fire({
                title: '@MyERP.Properties.Resources.Date @MyERP.Properties.Resources.Required',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        }
        let totalInstallmentPaid = 0;
        $('.InstallmentPaid').each(function () {
            totalInstallmentPaid += $(this).text() * 1;
        });
        totalInstallmentPaid += $('#InstallmentActualPaymentAmount').inputmask('unmaskedvalue') * 1;
        if (totalInstallmentPaid >= $('#TotalAfterTotalInstallment').inputmask('unmaskedvalue')*1) {
            valid = false;
            Swal.fire({
                title: '@MyERP.Properties.Resources.TotalPaidIsGreaterThanTotalAfterProfit',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        }
        if (valid) {
            $('#preloader, #status').fadeIn();
            $.ajax({
                type: "POST", contentType: "application/json",
                url: "/SalesInvoice/InsertInstallmentActualPayment",
                data:
                    JSON.stringify({
                        SalesInvoiceId: $('#Id').val(),
                        Amount: $('#InstallmentActualPaymentAmount').inputmask('unmaskedvalue'),
                        CashboxId: $('#InstallmentActualPaymentCashBoxId').val(),
                        Date: $('#InstallmentActualPaymentDate').val()
                    }),
                success: function (r) {
                    $('#InstallmentActualPaymentAmount').val(0);
                    $('#InstallmentActualPaymentCashBoxId')[0].selectedIndex = 0;
                    $('#InstallmentActualPaymentCashBoxId').trigger('change');
                    $('#InstallmentActualPaymentDate').val('');
                    AppendInstallmentPlanTbody(r);
                    $('#SalesInvoiceInstallmentActualPaymentModal').modal('hide');
                    $('#preloader, #status').fadeOut();
                },
                error: function (r) {
                    $('#preloader, #status').fadeOut();
                    Swal.fire({
                        title: '@MyERP.Properties.Resources.InstallmentNotAdded',
                        text: " ",
                        icon: 'error',
                        showCancelButton: false,
                        confirmButtonText: '@MyERP.Properties.Resources.Ok',
                        confirmButtonColor: '#3085d6'
                    });
                }
            });
        }
    }
