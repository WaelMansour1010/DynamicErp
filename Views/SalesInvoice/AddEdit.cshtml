        var itemRowToEdit = selectedItemRowToEdit;
        $(itemRowToEdit).find('.ExpiryDate').val(expireDate);
        $(itemRowToEdit).find('.PatchId').val(patchId);
        $(itemRowToEdit).find('.PatchCode').val(PatchCode);

        // quantity of patch
        $(itemRowToEdit).find('.quantityOnSystem').val(Qty);

        // Default Quantity In Pos if no qty
        if ($(itemRowToEdit).closest('tr').find('.quantity').val() === "" || $(itemRowToEdit).closest('tr').find('.quantity').val() === undefined) {
            $(itemRowToEdit).closest('tr').find('.quantity').val('@ViewBag.DefaultQuantityInPos');
        }

        $(itemRowToEdit).closest('tr').find('.quantity').trigger('change');
