            if (($('#DebitAmount').inputmask('unmaskedvalue') * 1 + CustomerDebitBalance * 1) > CreditLimitAmount * 1) {
                valid = false;
                Swal.fire({
                    title: '@MyERP.Properties.Resources.CustomerDebitBalanceAlert',
                    text: CustomerDebitBalance,
                    icon: 'info',
                    showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    confirmButtonColor: '#3085d6'
                });
