    //------------------------------ Serial Number ------------------------//
    function AddToSerialNumberTable(e) {
        let SumOfValue = 0;
        let ItemID = $(e).find('.itemId').val();
        var ItemName = $(e).find('.name').text();
        SumOfValue = 0;
        let item;
        $('#SalesInvoiceDetails tr').each(function () {
            if ($(this).find('.quantity').val() && ItemID == $(this).find('.itemId').val()) {
                SumOfValue += parseInt($(this).find('.quantity').inputmask('unmaskedvalue'));
            }
        });

        $('#serialTable tr').each(function () {
            item = $(this).find('.itemId').val();
            if (item == ItemID) {
                $(this).remove();
            }
        });
        AppendToSelectedItems(SumOfValue, ItemID, ItemName, "");
        addSerialNumbers(SumOfValue, null, ItemID);

        // Show/Hide Serials According to Ids
        if ($('#selectedItems').val() != ItemID) {
            $(".SerialRow[value=" + ItemID + "]").hide();
        }
    }
    function AppendToSelectedItems(SumOfValue, ItemID, ItemName, str) {
        $('#SalesInvoiceDetails tr').each(function () {
            if (str == "delete") {
                if (!$('#SalesInvoiceDetails .item:first').val()) {
                    AppendToSelectedItems($('#SalesInvoiceDetails .quantity:first').val(), $('#SalesInvoiceDetails .itemId:first').val(), $('#SalesInvoiceDetails .name:first').text(), "");
                    details = [];
                    $('#selectedItems').empty();
                }
                else {
                    details.some(function (detail) {
                        if (detail.itemId != ItemID && detail.quantity != 0) {
                            details.filter(function (detail) {
                                return details.splice(detail)
                            })
                            $('#selectedItems').empty();
                            AppendToSelectedItems(detail.quantity, detail.itemId, detail.itemName, "");
                            $('#serialTable').empty();
                            addSerialNumbers(detail.quantity, detail.itemName, detail.itemId);
                        }
                    });
                }
            }
            else {
                // Fill Details Array With Data
                details.push({
                    quantity: SumOfValue,
                    itemName: ItemName,
                    itemId: ItemID
                });
                details.some(function (detail) {
                    //------------ Set items From Details Table To Serial DropDown -----------
                    $('#selectedItems').append($('<option>', {
                        value: detail.itemId,
                        text: detail.itemName
                    }));
                    var selectedItems = [];
                    $('#selectedItems').each(function () {
                        $(this).children('option').each(function () {

                            if ($.inArray(this.value, selectedItems) > -1) {
                                $(this).remove()
                            } else {
                                selectedItems.push(this.value);
                            }
                        });
                        selectedItems = [];
                    });
                    $('#selectedItems').val(detail.itemId);
                    $('#selectedItems option:selected').text(detail.itemName);
                    $('#selectedItems').trigger('change');
                });
            }
        })
    }
    function addSerialNumbers(rows, itemName, itemId) {
        for (var i = 1; i <= rows; i++) {
            $('#serialTable').append('<tr class="SerialRow" value="' + itemId + '"><td><label">' + i + '</label"></td><td ><input class="itemId" value="' + itemId + '" hidden /><input onkeypress="checkEnter(event,this);" class="serialNumber form-control tabledit-input form-control-sm" /></td></tr>')
        }
    }
    function checkEnter(e, obj) {
        var keycode = (e.keyCode ? e.keyCode : e.which);
        if (keycode == '13') {
            let serial = $(obj).closest('tr').closest('tr').find('.serialNumber').val();
            let exists = 0;
            $('.serialNumber').each(function () {
                if (serial == $(this).val())
                    exists = exists + 1
            });
            if (exists == 1)//existing one time only
            {
                $(obj).closest('tr').next('tr').find('.serialNumber').focus();
            }
            else {
                Swal.fire({
                            title: '@MyERP.Properties.Resources.ThisSerialHasBeenEnteredBefore',
                            text: " ",
                            icon: 'info',
                            showCancelButton: false,
                            confirmButtonText: '@MyERP.Properties.Resources.Ok',
                            confirmButtonColor: '#3085d6'
                        });
                $(obj).closest('tr').closest('tr').find('.serialNumber').val('');
            }
        }
    }
