    function AddRecord(e)
    {
        $('#WarehousesAndQuantitiesDetails tr').each(function () {
            let tr = $(this);
            totalItems += parseFloat(tr.closest('tr').find('.RequestedQuantity').val());
        })

        if (totalItems > parseFloat($('#ItemQuantity').val()) || totalItems < parseFloat($('#ItemQuantity').val())) {
            Swal.fire({
                    title: '@MyERP.Properties.Resources.TheQuantityDisbursedFromWarehousesIsGreaterThanThequantityAvailable',
                    text: " ",
                    icon: 'info',
                    showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    confirmButtonColor: '#3085d6'
                });
            //$(this).closest('tr').find('.RequestedQuantity').val(0);
            totalItems = 0.0;
        }
        else
        {
            $('#container tr').each(function () {
                let tr = $(this);
                if (tr.closest('tr').find('.ItemId').val() == parseInt($('#Items').val())) {
                    tr.remove();
                }
            });
            let price = $('#SalesInvoiceDetails .price:last').inputmask('unmaskedvalue');
            let quantityOnSystem = $('#SalesInvoiceDetails .quantityOnSystem:last').val();
            let Record = '';
            let salesInvoiceItemDistributions = [];
            $('#WarehousesAndQuantitiesDetails tr').each(function () {
                let tr = $(this);
                var salesInvoiceItemDistribution = {
                    SalesInvoiceId: $('#Id').val(),
                    ItemId: parseInt($('#ItemPriceId').val()),
                    WarehouseId: parseInt(tr.closest('tr').find('.WarehouseId').val()),
                    Qty: parseFloat(tr.closest('tr').find('.RequestedQuantity').val())
                };
              //  if (salesInvoiceItemDistribution.Qty != 0)
              //---  {
                    let item = items.filter(function (i) { return i.ItemPriceId == $('#ItemPriceId').val(); })[0];
                    $('#SalesInvoiceDetails .barcode:last').val(item.Barcode);
                    //itemPrice.closest('tr').find('.price').val(item.Price);
                    $('#SalesInvoiceDetails .item-unit:last').empty().append('<option value="' + item.ItemUnitId + '">' + item.ItemUnitArName + '</option>');
                    $('#SalesInvoiceDetails .unit-equavalent:last').val(item.Equivalent);

                    $('#SalesInvoiceDetails .item:last').val($('#ItemPriceId').val());
                    $('#SalesInvoiceDetails .item-name:last').val($('#Items').text());
                    $('#SalesInvoiceDetails .name:last').text($('#Items').text());
                   // $('#SalesInvoiceDetails .item:last').trigger('change');
