                sumInsallmentAmounts += tr.find('.InstallmentAmount').inputmask('unmaskedvalue') * 1;
            });
            sumInsallmentAmounts -= $('#InstallmentAdvance').inputmask('unmaskedvalue') * 1;
            if (sumInsallmentAmounts.toFixed(3) != $('#TotalInstallmentAfterProfit').inputmask('unmaskedvalue') * 1) {
