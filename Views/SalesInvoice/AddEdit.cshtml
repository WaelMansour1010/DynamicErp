    function addToSalesInvoiceDetails(e)
    {
        let itemid = $(e).find('.item').val();
        if ($('.item-name').last().val() != "") {
            if ($('#DepartmentId').val() == 28 && '@ViewBag.ProjectName' == "Genoise") {
                $('#SalesInvoiceDetails').find('.item,  .item-unit, .quantity, .unit-equavalent').prop('required', 'required');
            }
            else {
                $('#SalesInvoiceDetails').find('.item,  .item-unit, .quantity, .unit-equavalent, .price').prop('required', 'required');
            }
        }
        if ($('#SalesInvoiceDetails .form-control:invalid').length > 0)
        {
            $('#SalesInvoiceDetails').closest('.form-horizontal').addClass('was-validated');
            $('html, body').animate({
                scrollTop: $("#SalesInvoiceDetails").find(".form-control:invalid").eq(0).offset().top - 80
            }, 500);

        }
        else if ($('#SalesInvoiceDetails .quantity:last').val() && $('#SalesInvoiceDetails .item-name:last').val())
        {
            let conditon = $('#UseMultiWarehousesInSalesInvoice').prop('checked');

            if (conditon == true)
            {
                state = 'table-cell';
            }
            else
            {
