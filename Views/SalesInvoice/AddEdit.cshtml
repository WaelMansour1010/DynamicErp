    function addEdit(n) {
        var serialNumbers = [];
        let valid = true;
        if ($(".form-control:invalid").length > 0) {
            $('.form-horizontal').addClass('was-validated');
            $('html, body').animate({
                scrollTop: $(".form-control:invalid").eq(0).offset().top - 80
            }, 500);
            console.log($(".form-control:invalid"));
            valid = false;
        }
        if ($('#Id').val() > 0 && '@ViewBag.check' > 0) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.EditDoesNotSucceededBecauseSalesInvoiceExistInCashReceiptVoucher',
                text: " ",
                icon: 'error',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
            valid = false;
            window.location.replace('/SalesInvoice');
        }
        if (valid && $('#CashAmount').inputmask('unmaskedvalue') * 1 > 0) {
            if (!$('#CashBoxId').val()) {
                Swal.fire({
                    title: '@MyERP.Properties.Resources.ChooseCashBoxofPaidMoney',
                    text: " ",
                    icon: 'info',
                    showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    confirmButtonColor: '#3085d6'
                });
                valid = false;
            }
        }
        if (valid && $('#ChequeAmount').inputmask('unmaskedvalue') * 1 > 0) {
            if (!$('#BankIdForCheque').val()) {
                Swal.fire({
                    title: '@MyERP.Properties.Resources.ChooseBankofPaidMoney',
                    text: " ",
                    icon: 'info',
                    showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    confirmButtonColor: '#3085d6'
                });
                valid = false;
            } else if (!$('#BankAccountIdForCheque').val()) {
                Swal.fire({
                    title: '@MyERP.Properties.Resources.ChooseBankAccofPaidMoney',
                    text: " ",
                    icon: 'info',
                    showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    confirmButtonColor: '#3085d6'
                });
                valid = false;
            }
        }
        if (valid && $('#VisaAmount').inputmask('unmaskedvalue') * 1 > 0) {
            if (!$('#BankIdForVisa').val()) {
                Swal.fire({
                    title: '@MyERP.Properties.Resources.ChooseBankofPaidVisa',
                    text: " ",
                    icon: 'info',
                    showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    confirmButtonColor: '#3085d6'
                });
                valid = false;
            } else if (!$('#BankAccountIdForVisa').val()) {
                Swal.fire({
                    title: '@MyERP.Properties.Resources.ChooseBankAccofPaidVisa',
                    text: " ",
                    icon: 'info',
                    showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    confirmButtonColor: '#3085d6'
                });
                valid = false;
            }
        }
        if (valid) {
            if ($('#hasTaxes').prop('checked') == false) {
                $('#TotalAfterTaxes').val($('#NetTotal').inputmask('unmaskedvalue') * 1);
                //  $('#TotalAfterTaxes').val($('#NetTotal').inputmask('unmaskedvalue') * 1 + $('#ServiceFees').inputmask('unmaskedvalue') * 1);
            }
        }
        var SalesInvoiceItemDistributions = [];
        $('#container tr').each(function () {
            let tr = $(this);
            var SalesInvoiceItemDistribution = {
                SalesInvoiceId: $('#Id').val(),
                ItemId: parseInt(tr.closest('tr').find('.ItemId').val()),
                WarehouseId: parseInt(tr.closest('tr').find('.WarehouseId').val()),
                Qty: parseInt(tr.closest('tr').find('.Qty').val())
            };
            SalesInvoiceItemDistributions.push(SalesInvoiceItemDistribution);
        });
        var SalesInvoiceDetails = [];
        if (valid) {
            $('#SalesInvoiceDetails tr').each(function () {
                var td = $(this);
                if (td.find('.quantity').val() * 1 != 0 && td.find('.item').val() > 0) {
                    let itemId = items.filter(function (i) { return i.ItemPriceId == td.find('.item').val(); })[0].Id;
                    var salesInvoiceDetail = {
                        ItemId: itemId,
                        ItemPriceId: td.find('.item').val(),
                        ItemUnitId: td.find('.item-unit').val(),
                        UnitEquivalent: td.find('.unit-equavalent').val(),
                        Price: td.find('.price').inputmask('unmaskedvalue'),
                        Qty: td.find('.quantity').val(),
                        CostPrice: td.find('.avgCost').val(),
                        WareHouseId: $('#UseMultiWarehousesInSalesInvoice').prop('checked') == true ? td.find('.item-warehouseId').val() : $('#WarehouseId').val(),
                        IsActive: true,
                        IsDeleted: false,
                        Notes: td.find('.Notes').val(),
                        DiscountValue: td.find('.DiscountValue').val(),
                        DiscountPerc: td.find('.DiscountPerc').val(),
                        ExpireDate: td.find('.ExpiryDate').val(),
                        PatchId: td.find('.PatchId').val() > 0 ? td.find('.PatchId').val():null,
                        Width: td.find('.Width').val(),
                        Height: td.find('.Height').val(),
                        Area: td.find('.Area').val(),
                        ItemTaxPercentage: td.find('.ItemTaxPercentage').val(),
                        ItemTaxValue: td.find('.ItemTaxValue').inputmask('unmaskedvalue'),

                    };
                    if ($('#UseMultiWarehousesInSalesInvoice').prop('checked') && td.find('.item-warehouseId').val() == 0) {
                        Swal.fire({
                            title: '@MyERP.Properties.Resources.All @MyERP.Properties.Resources.Warehouses @MyERP.Properties.Resources.Required',
                            text: " ",
                            icon: 'info',
                            showCancelButton: false,
                            confirmButtonText: '@MyERP.Properties.Resources.Ok',
                            confirmButtonColor: '#3085d6'
                        });
                        valid = false;
                        return false;
                    }
                    else
                        SalesInvoiceDetails.push(salesInvoiceDetail);
                }
            });
            if (valid) {
                valid = SalesInvoiceDetails.length > 0 ? true : false;
                !valid ? Swal.fire({
                    title: '@MyERP.Properties.Resources.AllDetailsRequired',
                    text: " ", icon: 'info', showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok', confirmButtonColor: '#3085d6'
                }) : null;
            }
        }

        if (valid) {
            var paymentMethods = [];
            let totalPaied = 0;
            $('#SalesInvoicePaymentMethods tr').each(function () {
                var td = $(this);
                totalPaied += td.find('.PaymentAmount').inputmask('unmaskedvalue') * 1;
                var paymentMethod = {
                    SalesInvoiceId: $('#Id').val(),
                    PaymentMethodId: td.find('.PaymentMethodId').val(),
                    CashBoxId: td.find('.PaymentAmount').inputmask('unmaskedvalue') ? td.find('.CashBoxId').val() : null,
