            });
            serialNumbers.some(function (serialNumber) {
                if (serialNumber.ItemId) {
                    valid = true;
                } else {
                    valid = false;
                    Swal.fire({
                        title: '@MyERP.Properties.Resources.MakeSureAllSerialDataCompleted',
                        text: " ",
                        icon: 'info',
                        showCancelButton: false,
                        confirmButtonText: '@MyERP.Properties.Resources.Ok',
                        confirmButtonColor: '#3085d6'
                    });
                    return true;
                }
            });
