    function decodeImageFromBase64(data, callback) {
        // set callback
        qrcode.callback = callback;
        // Start decoding
        qrcode.decode(data)
    }
    function readURL(input) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();

            reader.onload = function (e) {
                $(".imgnew").removeClass("hidden");

                $('#imgnew')
                    .attr('src', e.target.result)
            };
            reader.readAsDataURL(input.files[0]);

            fileReader = reader;
            decodeImageFromBase64(reader["result"], function (decodedInformation) {
                imageURI = fileReader.result;
                decodeImageFromBase64(imageURI, function (decodedInformation) {
                    $('.barcode').last().val(decodedInformation);
                    let elem = $('.barcode').last();
                    GetItemsData(elem);
                  //  $('#QrText').text(decodedInformation);
                });
            });
        }
    }
