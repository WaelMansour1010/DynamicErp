@model MyERP.Models.SalesInvoice
@{
    if (System.Web.Configuration.WebConfigurationManager.AppSettings["ECommerce"] == "true")
    {
        Layout = "~/Views/Shared/_EcommerceLayout.cshtml";
    }

    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.SalesInvoice;
}

<script src="~/Scripts/BarcodeScan.js"></script>
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                @if (Model != null)
                {
                    if (Model.IsDeleted == false)
                    {
                        if (ViewBag.Previous > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.First })" class="btn btn-info">@MyERP.Properties.Resources.First</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Previous })" class=" btn btn-info">&#8250;</a>
                        }
                        if (ViewBag.Next > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Next })" class="btn btn-info">&#8249;</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Last })" class="btn btn-info">@MyERP.Properties.Resources.Last</a>
                        }
                    }
                }
                <a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
            </div>
            <h4 class="page-title">@MyERP.Properties.Resources.SalesInvoice :</h4>
        </div>
    </div>
</div>
@if (Model != null)
{
    if (Model.Id > 0)
    {
        @Html.HiddenFor(model => model.Id)
    }
    @Html.HiddenFor(model => model.IsActive)
    @Html.HiddenFor(model => model.UserId)
    @Html.HiddenFor(model => model.IsLinked)
    @Html.HiddenFor(model => model.IsPosted)
    @Html.HiddenFor(model => model.IsDeleted)
    @Html.HiddenFor(model => model.IsAccepted)
    @Html.HiddenFor(model => model.IsCompleted)
    @Html.HiddenFor(model => model.SelectedId)
    @Html.HiddenFor(model => model.SystemPageId)
    @Html.HiddenFor(model => model.WaiterId)
}
@*<input type="hidden" id="ServiceFeesPercentage" value="@ViewBag.ServiceFeesPercentage" />*@
<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal needs-validation" role="form">

                        <div class="card">
                            <div class="card-body">
                                <h5 class="header-title">
                                    @MyERP.Properties.Resources.MainData
                                </h5>
                                <div class="form-group row">
                                    <label class=" col-sm-2 control-label" for="DocumentNumber">@MyERP.Properties.Resources.DocNo</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.DocumentNumber, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly", placeholder = @MyERP.Properties.Resources.DocNo, required = "required", hidden = "hidden" } })
                                        <input id="DocumentNumbers" class="form-control" placeholder=@MyERP.Properties.Resources.Code required readonly />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>

                                    <label for="VoucherDate" class="control-label col-sm-2">@MyERP.Properties.Resources.Date</label>
                                    <div class="col-sm-4">
                                        <input id="VoucherDate" name="VoucherDate" class="form-control" type="datetime-local" value="@ViewBag.VoucherDate" required />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="DepartmentId" class="col-sm-2 control-label">@MyERP.Properties.Resources.Department</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("DepartmentId", null, null, htmlAttributes: new { @class = "form-control", @required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>

                                    <label for="WarehouseId" class="col-sm-2 control-label">@MyERP.Properties.Resources.WareHouse</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("WarehouseId", null, null, htmlAttributes: new { @class = "form-control", @required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Select
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="VendorOrCustomerId" class="control-label col-sm-2">@MyERP.Properties.Resources.Customer </label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("VendorOrCustomerId", null, null, htmlAttributes: new { @class = "form-control", @required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Select
                                        </div>
                                    </div>
                                    <label for="VendorOrCustomerId" class="control-label col-sm-2">
                                        @MyERP.Properties.Resources.Representative
                                    </label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("CustomerRepId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>


                                <div class="form-group row">
                                    <label class="control-label col-sm-2" for="PaymentType">@MyERP.Properties.Resources.PaymentType</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("PaymentType", null, null, htmlAttributes: new { @class = "form-control", @required = "required" })
                                    </div>
                                    <div class="invalid-feedback">
                                        @MyERP.Properties.Resources.Required
                                    </div>

                                    <label for="DueDate" class="control-label col-sm-2">@MyERP.Properties.Resources.DueDate</label>
                                    <div class="col-sm-4">
                                        <input id="DueDate" name="DueDate" class="form-control" type="datetime-local" value="@ViewBag.VoucherDate" required />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>

                                </div>

                                <div class="form-group row">
                                    <label class="control-label col-sm-2" for="Notes">@MyERP.Properties.Resources.Notes</label>
                                    <div class="col-sm-4">
                                        <textarea id="Notes" name="Notes" class="form-control" rows="1" cols="5">@if (Model != null) { @Model.Notes; }</textarea>
                                    </div>
                                    <label class="control-label col-sm-2" for="IssueMethodId">@MyERP.Properties.Resources.IssueMethod</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("IssueMethodId", null, null, htmlAttributes: new { @class = "form-control", @required = "required" })
                                    </div>
                                    <div class="invalid-feedback">
                                        @MyERP.Properties.Resources.Required
                                    </div>

                                </div>

                                @if (ViewBag.UseCostCenter == true)
                                {
                                    <div class="form-group row">
                                        <label for="CostCenterId" class="control-label col-sm-2">@MyERP.Properties.Resources.CostCenter</label>
                                        <div class="col-sm-4">
                                            @Html.DropDownList("CostCenterId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })
                                        </div>
                                    </div>
                                }
                                <div class="form-group row">
                                    <div class="col-sm-12">
                                        <button class="btn btn-primary" data-toggle="modal" data-target="#LinkWithOtherDocModal">@MyERP.Properties.Resources.LinkWithOtherDoc</button>
                                        <label id="SalesInvoiceDocNum">
                                            @if (Model != null && Model.SystemPageId.HasValue && Model.SelectedId.HasValue)
                                            {
                                                @Html.Raw(@MyERP.Properties.Resources.DocNo + ViewBag.SalesInoiveDocNum)
                                            }
                                        </label>
                                        <button id="cancelSalesInvoice" onclick="cancelSalesInvoice()" class="btn btn-icon waves-effect waves-light btn-danger btn-xs" style="display:none;"> <i class="fas fa-times"></i> </button>

                                        <label id="PurchaseRequestDocNum"></label>
                                        <input hidden id="DocName" />
                                        <input hidden id="DocId" />
                                        <button id="cancelPurchaseRequest" onclick="cancelPurchaseRequest()" class="btn btn-icon waves-effect waves-light btn-danger btn-xs" style="display:none;"> <i class="fas fa-times"></i> </button>

                                    </div>

                                    @if (ViewBag.UseAvgCostPrice == true)
                                    {
                                        <label class="control-label col-sm-3">
                                            @MyERP.Properties.Resources.UseAvgCostPrice
                                        </label>
                                        <div class="col-sm-2">
                                            <input type="checkbox" id="useAvgCostPrice" />
                                        </div>
                                    }

                                    <!-- Qr Code  -->
                                    @if (ViewBag.BarcodeUsingCameraInSalesInvoice == true)
                                    {
                                        <label class="control-label col-sm-3">
                                            @MyERP.Properties.Resources.EnterItemsByBarcode
                                        </label>
                                        <div class="col-sm-2">
                                            <input type="file" name="Upload" Class="photo" id="QRCodeText" onchange="readURL(this)" onclick="EmptyImg()" /><br />
                                            <img style='height:100px; width: 100px;  border-radius: 50px; display:none' id="imgnew" src="#" alt="" class="hidden imgnew" />
                                        </div>
                                    }
                                    <!------------------------------------------------------------------------>
                                </div>

                                <div class="form-group row">
                                    @if (ViewBag.UseMultiWarehousesInSalesInvoice == true)
                                    {
                                        <label class="control-label col-sm-3">
                                            @MyERP.Properties.Resources.UseMultiWarehousesToExchangeItems
                                        </label>
                                        <div class="col-sm-2">
                                            <input type="checkbox" id="UseMultiWarehousesInSalesInvoice" @Html.Raw(Model != null ? (Model.WarehouseItemDistribution == true ? "checked" : "") : "") />
                                        </div>
                                    }
                                    @*@if (ViewBag.ShowCost == true)*@
                                    @if (ViewBag.ShowCost == true && ViewBag.ShowSalesInvoiceProfit == true)
                                    {
                                        <label class="control-label col-sm-3">
                                            @MyERP.Properties.Resources.ShowInvoiceProfit
                                        </label>
                                        <div class="col-sm-1">
                                            <input type="checkbox" id="showInvoiceProfit" />
                                        </div>
                                    }
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
            </div>


            <!--  ده الجدول الى بيتحفظ فيه كل صنف مصروف منه قد ايه ومن انه مخزن -->
            <div style="display:none" class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-body">
                            <h5 class=" pb-2 header-title">
                                @MyERP.Properties.Resources.ItemsExchangedFromMultiWareHouses
                            </h5>
                            <div class="table-responsive">
                                <table class="table table-centered mb-0">
                                    <thead id="TitleWarehouses">
                                        <tr id="TitleWarehouses">
                                            <th> @MyERP.Properties.Resources.Code</th>
                                            <th>
                                                @MyERP.Properties.Resources.SalesInvoice  @MyERP.Properties.Resources.Code
                                            </th>
                                            <th>
                                                @MyERP.Properties.Resources.Item  @MyERP.Properties.Resources.Code
                                            </th>
                                            <th>
                                                @MyERP.Properties.Resources.WareHouse  @MyERP.Properties.Resources.Code
                                            </th>
                                            <th> @MyERP.Properties.Resources.Qty</th>
                                        </tr>
                                    </thead>
                                    <tbody id="container">
                                        @if (Model != null)
                                        {
                                            foreach (var item in Model.SalesInvoiceItemDistributions)
                                            {
                                                <tr>
                                                    <td>
                                                        <input class="form-control" value="@item.Id" />
                                                    </td>
                                                    <td>
                                                        <input class="form-control" value="@item.SalesInvoiceId" />
                                                    </td>
                                                    <td>
                                                        <input class="form-control ItemId" value="@item.ItemId" />
                                                    </td>
                                                    <td>
                                                        <input class="form-control WarehouseId" value="@item.WarehouseId" />
                                                    </td>
                                                    <td>
                                                        <input class="form-control Qty" value="@item.Qty" />
                                                    </td>
                                                </tr>

                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            @Html.Partial("_LinkWithDocModal")


            <!-- Patch Modal-->
            <div id="patchModal" class="modal fade bs-example-modal-lg" tabindex="-1" role="dialog" aria-labelledby="myLargeModalLabel" data-backdrop="false" style="background-color: rgba(0, 0, 0, 0.5);">
                <div class="modal-dialog modal-lg" role="document">
                    <div class="modal-content">
                        <div class="modal-header">
                            <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                        </div>
                        <div class="modal-body">

                            <div class="row">
                                <div class="col-sm-12">
                                    <table class="table table-condensed">
                                        <thead>
                                            <tr>
                                                <th>
                                                    @MyERP.Properties.Resources.PatchCode
                                                </th>
                                                <th> @MyERP.Properties.Resources.ExpiryDate </th>
                                                <th> @MyERP.Properties.Resources.Qty</th>
                                                <th> @MyERP.Properties.Resources.Add</th>
                                            </tr>
                                        </thead>
                                        <tbody id="item-patches"></tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-default" onclick=" $('.bs-example-modal-lg').modal('hide');" data-dismiss="modal"> @MyERP.Properties.Resources.Close</button>
                        </div>
                    </div>

                </div>
            </div>

            <!-- بتاع صرف الكمية من اكتر من مخزن ومش بيظهر غير لما يكون الاوبشن بتاع البيع من اكتر من مخزن متفعل فى الاعدادات Modal -->
            <div class="modal fade" id="exampleModalCenter" tabindex="-1" role="dialog" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered" style="max-width:700px;" role="document">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="exampleModalLongTitle"> @MyERP.Properties.Resources.UseMultiWarehousesToExchangeItems</h5>
                            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                        <div class="modal-body">
                            <div class="form-horizontal needs-validation" role="form">

                                <div class="form-group row">
                                    <label class="control-label col-sm-2" for="Notes"> @MyERP.Properties.Resources.Item</label>
                                    <div class="col-sm-5">
                                        <input hidden id="ItemPriceId" type="text" />
                                        @*<input id="Item" class="form-control" type="text" readonly />*@
                                        @*<select class="form-control" id="Items"></select>*@
                                        <label class="control-label" id="Items"></label>
                                    </div>
                                    @*<label class="control-label col-sm-3" for="Notes">الكمية المطلوبة</label>
                                        <div class="col-sm-2">
                                            <input id="ItemQuantity" class="form-control" type="number" step="any" value="0" />
                                        </div>*@
                                </div>

                                <div class="form-group row">
                                    <label class=" control-label text-danger col-sm-4" for="Notes">
                                        @MyERP.Properties.Resources.AvailableQtyInAllWareHouses
                                    </label>
                                    <div class="col-sm-3">
                                        <input id="AvailabelQuantityInAllWarehouses" class="form-control" type="text" readonly />
                                    </div>
                                </div>

                                <div class="table-responsive">
                                    <table class="table table-centered mb-0">
                                        <thead>
                                            <tr>
                                                <th> @MyERP.Properties.Resources.WareHouse</th>
                                                <th>

                                                    @MyERP.Properties.Resources.SoldOutQty
                                                </th>
                                                <th>
                                                    @MyERP.Properties.Resources.AvailableQty
                                                </th>
                                            </tr>
                                        </thead>
                                        <tbody id="WarehousesAndQuantitiesDetails">

                                            @*stores from ajax to be append here*@

                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" onclick="AddRecord(this)" class="btn btn-primary">@MyERP.Properties.Resources.Add</button>
                            <button type="button" class="btn btn-secondary" data-dismiss="modal">@MyERP.Properties.Resources.Close</button>
                        </div>
                    </div>
                </div>
            </div>

            @Html.Partial("ItemSearch")

            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="header-title">@MyERP.Properties.Resources.Details</h5>
                            <div class="form-horizontal needs-validation" role="form">
                                <div class="table-responsive">
                                    <table class="table table-centered mb-0">
                                        <thead>
                                            <tr>
                                                <th>@MyERP.Properties.Resources.Barcode</th>
                                                <th> @MyERP.Properties.Resources.Item</th>
                                                <th class="expiry" style="display:none;"> @MyERP.Properties.Resources.PatchCode </th>
                                                <th class="expiry" style="display:none;"> @MyERP.Properties.Resources.ExpiryDate </th>

                                                <th>@MyERP.Properties.Resources.Qty</th>
                                                <th class="UnitClass" style="display:none;">@MyERP.Properties.Resources.Unit</th>
                                                <th class="UnitEquivClass" style="display:none;">@MyERP.Properties.Resources.Equivalent</th>

                                                <th>
                                                    @MyERP.Properties.Resources.SellingPrice
                                                </th>
                                                <th class="IsDiscountTrue" style="display:none;">
                                                    @MyERP.Properties.Resources.DiscountPercentage
                                                </th>

                                                <th class="IsDiscountTrue" style="display:none;">
                                                    @MyERP.Properties.Resources.DiscountValue
                                                </th>
                                                <th class="ItemTax" style="display:none;">
                                                    @MyERP.Properties.Resources.TaxPercentage
                                                </th>
                                                <th class="ItemTax" style="display:none;">
                                                    @MyERP.Properties.Resources.TaxValue
                                                </th>
                                                <th>@MyERP.Properties.Resources.Total</th>

                                                <th class="showProfit">
                                                    @MyERP.Properties.Resources.ItemCost
                                                </th>

                                                <th class="showProfit">
                                                    @MyERP.Properties.Resources.TotalItemProfit
                                                </th>

                                                <th>@MyERP.Properties.Resources.AvailableQty</th>

                                                <th class="item-warehouseIdTh" style="display:none">@MyERP.Properties.Resources.WareHouse</th>
                                                <th class="ItemArea" style="display:none;">@MyERP.Properties.Resources.Width</th>
                                                <th class="ItemArea" style="display:none;">@MyERP.Properties.Resources.Height</th>
                                                <th class="ItemArea" style="display:none;">@MyERP.Properties.Resources.ItemArea</th>
                                                @*<th class="Warranty">@MyERP.Properties.Resources.Warranty</th>*@
                                                <th>@MyERP.Properties.Resources.Details</th>
                                                <th>@MyERP.Properties.Resources.AlternativeItems</th>
                                                <th>@MyERP.Properties.Resources.Delete</th>
                                            </tr>
                                        </thead>
                                        <tbody id="SalesInvoiceDetails">
                                            @if (Model != null)
                                            {
                                                foreach (var item in Model.SalesInvoiceDetails)
                                                {
                                                    <tr>
                                                        <td class="tabledit-edit-mode"><input class="barcode form-control tabledit-input form-control-sm" value="@Html.Raw(item.ItemPrice!=null?item.ItemPrice.Barcode:"")" /></td>
                                                        <td class="tabledit-edit-mode popupCell">
                                                            <input type="hidden" class="item IsUpdated form-control tabledit-input form-control-sm" value="@item.ItemPriceId" required />
                                                            <input hidden type="text" class="item-name form-control tabledit-input form-control-sm" value="@item.Item.ArName - @item.ItemPrice.Barcode" required />
                                                            <label style="width:200px" class="name control-label tabledit-input ">@item.Item.ArName - @item.ItemPrice.Barcode</label>
                                                            <input hidden class="itemUnitArName" value=@item.ItemUnit.ArName />

                                                        </td>
                                                        <td class="tabledit-edit-mode expiry" style="display:none;">
                                                            @if (item.Patch != null && item.Patch.Code != null)
                                                            {
                                                                <input class="PatchCode form-control tabledit-input form-control-sm" readonly value="@item.Patch.Code" />
                                                            }
                                                            else
                                                            {
                                                                <input class="PatchCode form-control tabledit-input form-control-sm" readonly />
                                                            }

                                                        </td>
                                                        <td class="tabledit-edit-mode expiry" style="display:none;">
                                                            @if (item.ExpireDate.HasValue)
                                                            {
                                                                <input class="ExpiryDate form-control tabledit-input form-control-sm" readonly value="@item.ExpireDate.Value.ToString("MM/dd/yyyy")" />
                                                            }
                                                            else
                                                            {
                                                                <input class="ExpiryDate form-control tabledit-input form-control-sm" readonly />
                                                            }
                                                            <input class="PatchId form-control tabledit-input form-control-sm" hidden value="@item.PatchId" />
                                                            <input class="itemId form-control tabledit-input form-control-sm" hidden value="@item.ItemId" />

                                                        </td>
                                                        <td class="tabledit-edit-mode">
                                                            <input class="quantity form-control tabledit-input form-control-sm" type="number" step="any" value="@item.Qty" required />
                                                        </td>
                                                        <td class="tabledit-edit-mode UnitClass" style="display:none;"><select class="item-unit form-control tabledit-input form-control-sm" required disabled><option value="@item.ItemUnitId">@item.ItemUnit.ArName</option></select></td>
                                                        <td class="tabledit-edit-mode UnitEquivClass" style="display:none;"><input class="unit-equavalent form-control tabledit-input form-control-sm small-number" type="number" step="any" value="@item.UnitEquivalent" required /></td>
                                                        <td class="tabledit-edit-mode"><input type="text" class="money price form-control tabledit-input form-control-sm" value="@item.Price" required /></td>

                                                        <td class="tabledit-edit-mode IsDiscountTrue" style="display:none;"><input type="number" step="any" class="DiscountPerc form-control tabledit-input form-control-sm" value="@item.DiscountPerc" /></td>
                                                        <td class="tabledit-edit-mode IsDiscountTrue" style="display:none;"><input type="number" step="any" class="DiscountValue form-control tabledit-input form-control-sm" value="@item.DiscountValue" /></td>
                                                        <td class="tabledit-edit-mode ItemTax" style="display:none;"><input type="text" class="ItemTaxPercentage form-control tabledit-input form-control-sm" value="@item.ItemTaxPercentage" /></td>
                                                        <td class="tabledit-edit-mode ItemTax" style="display:none;"><input type="text" class="ItemTaxValue form-control tabledit-input form-control-sm money" value="@item.ItemTaxValue" /></td>

                                                        <td class="tabledit-edit-mode"><input class="total money form-control tabledit-input form-control-sm" type="text" readonly value="0" /></td>
                                                        <td class="tabledit-edit-mode showProfit">
                                                            <input type="number" step="any" class="showProfit avgCost form-control form-control-sm" readonly value="@item.CostPrice" />
                                                        </td>
                                                        <td class="tabledit-edit-mode showProfit">
                                                            <input type="text" class="showProfit avgCostProfit quantityInWarehouse form-control form-control-sm" readonly />
                                                        </td>

                                                        <td class="tabledit-edit-mode"><input type="number" step="any" class="quantityOnSystem form-control tabledit-input form-control-sm" readonly /></td>

                                                        <td class="tabledit-edit-mode" style="display:none;"><select class="item-warehouseId form-control tabledit-input form-control-sm" @Html.Raw(Model != null ? "" : "")><option value="@item.WareHouseId">@Html.Raw(item.WareHouseId != null ? item.Warehouse.ArName : "")</option></select></td>
                                                        <td class="tabledit-edit-mode ItemArea" style="display:none;"><input class="Width form-control tabledit-input form-control-sm" type="text" value="@item.Width" /></td>
                                                        <td class="tabledit-edit-mode ItemArea" style="display:none;"><input class="Height form-control tabledit-input form-control-sm" type="text" value="@item.Height" /></td>
                                                        <td class="tabledit-edit-mode ItemArea" style="display:none;"><input class="Area form-control tabledit-input form-control-sm" disabled type="text" value="@item.Area" /></td>
