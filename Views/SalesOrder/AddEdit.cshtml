    function setBankAccounts(bankAccount, id) {
        $(bankAccount).empty();
        return requestData('/SalesOrder/SetBankAccounts?bankId=' + $(bankAccount).closest('tr').find('.BankId').val())
             .done(function (r) {
                 let BankAccounts = r;
                 $(bankAccount).append('<option value>' +'@MyERP.Properties.Resources.SelectTheBankAccount'+'</option>');
                for (var i = 0; i < BankAccounts.length; i++) {
                    $(bankAccount).append($('<option>', {
