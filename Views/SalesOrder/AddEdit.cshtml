    $(document).on('click', '#calculatenInstallmentPayments', function () {
        let DaysBetweenInstallments = ($('#DaysBetweenInstallments').inputmask('unmaskedvalue') * 1).toFixed(0) * 1;
        let InstallmentAdvance = $('#InstallmentAdvance').inputmask('unmaskedvalue') * 1;
        let InstallmentPaymentCount = $('#InstallmentPaymentCount').val();
        if (InstallmentPaymentCount && !isNaN(InstallmentPaymentCount)) {
            let FirstInstallmentPaymentDueDate = $('#FirstInstallmentPaymentDueDate').val();
            let TotalInstallmentAfterProfit = $('#TotalInstallmentAfterProfit').inputmask('unmaskedvalue');
            let InstallmentPaymentAmount = TotalInstallmentAfterProfit / InstallmentPaymentCount;
            let firstDate = new Date(FirstInstallmentPaymentDueDate);
            $('#InstallmentPlan-tbody').empty();
            let tr = '<tr><td><input type="date" class="InstallmentDueDate form-control" /></td><td><input type="text" class="InstallmentAmount money form-control" value="' + InstallmentAdvance + '"/></td><td class="InstallmentPaid">0.0</td><td class="InstallmentRemaining">' + InstallmentAdvance + '</td><td><textarea class="form-control InstallmentNotes"></textarea></td></tr>';
            $('#InstallmentPlan-tbody').append(tr);
            document.getElementsByClassName('InstallmentDueDate').item(0).valueAsDate = new Date($('#VoucherDate').val());
            for (var i = 0; i < InstallmentPaymentCount; i++) {
                let dueDate = new Date().setDate(firstDate.getDate() + (i * DaysBetweenInstallments));
                tr = '<tr><td><input type="date" class="InstallmentDueDate form-control" /></td><td><input type="text" class="InstallmentAmount money form-control" value="' + InstallmentPaymentAmount.toFixed(2) + '"/></td><td class="InstallmentPaid">0.0</td><td class="InstallmentRemaining">' + InstallmentPaymentAmount.toFixed(2) + '</td><td><textarea class="form-control InstallmentNotes"></textarea></td></tr>';
                $('#InstallmentPlan-tbody').append(tr);
                document.getElementsByClassName('InstallmentDueDate').item(i + 1).valueAsDate = new Date(dueDate);
            }
            $('#InstallmentPlan-tbody').find('.money').inputmask({
                alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
            });
        } else {
            //alert('@MyERP.Properties.Resources.PleaseEnterTheNumberOfInstallments' + '!');
            Swal.fire({
                title: '@MyERP.Properties.Resources.PleaseEnterTheNumberOfInstallments' + '!',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        }
    });

