    function AppendInstallmentPlanTbody(r) {
        $('#SalesOrderInstallmentActualPayments').empty();
        if (r.InstallmentActualPayments) {
            for (var i = 0; i < r.InstallmentActualPayments.length; i++) {
                let tr = '<tr><td>' + ToJavaScriptDate(r.InstallmentActualPayments[i].Date) + '<input type="hidden" class="InstallmentActualPaymentId" value="' + r.InstallmentActualPayments[i].Id + '"/></td><td>' + r.InstallmentActualPayments[i].Amount + '</td><td>' + r.InstallmentActualPayments[i].ArName + '</td><td><button class="btn btn-danger InstallmentActualPaymentDelete disabled" disabled onclick="DeleteInstallmentActualPayment('+r.InstallmentActualPayments[i].Id+')">حذف</button></td></tr>';
                $('#SalesOrderInstallmentActualPayments').append(tr);
            }
            $('.InstallmentActualPaymentDelete').last().removeClass('disabled').removeProp('disabled');
        }
        $('#InstallmentPlan-tbody').empty();
        if (r.InstallmentDetails) {
            let totalInstallmentPaid = 0;
            let totalInstallmentRemainings = 0;
            let totalInsallmentAmounts = 0;
            for (var i = 0; i < r.InstallmentDetails.length; i++) {
                totalInstallmentPaid += r.InstallmentDetails[i].Paid * 1;
                totalInsallmentAmounts += r.InstallmentDetails[i].InstallmentAmount * 1;
                totalInstallmentRemainings += r.InstallmentDetails[i].Remaining * 1;
                let tr = '<tr><td><input type="date" class="InstallmentDueDate form-control" value="' + ToJavaScriptDate(r.InstallmentDetails[i].DueDate) + '" /></td><td><input type="text" class="InstallmentAmount money form-control" value="' + r.InstallmentDetails[i].InstallmentAmount + '"/></td><td class="InstallmentPaid">' + r.InstallmentDetails[i].Paid + '</td><td class="InstallmentRemaining">' + r.InstallmentDetails[i].Remaining + '</td><td><textarea class="form-control InstallmentNotes">' + (r.InstallmentDetails[i].Notes ? r.InstallmentDetails[i].Notes : '') + '</textarea></td></tr>';
                $('#InstallmentPlan-tbody').append(tr);
            }
            $('#total-InstallmentPaid').val(totalInstallmentPaid);
            $('#total-InstallmentAmounts').val(totalInsallmentAmounts);
            $('#total-InstallmentRemaings').val(totalInstallmentRemainings);
        }
        $('#InstallmentPlan tbody').find('.money').inputmask({
            alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
        });
        $('#JournalEntryDetails-tbody').empty();
        if (r.JournalEntryDetails) {
            for (var i = 0; i < r.JournalEntryDetails.length; i++) {
                let tr = '<tr><td>'+r.JournalEntryDetails[i].Debit+'</td><td>'+r.JournalEntryDetails[i].Credit+'</td><td>'+r.JournalEntryDetails[i].ArName+'<input type="hidden" class="JournalAccountId" value="'+r.JournalEntryDetails[i].AccountId+'" /></td></tr>';
                $('#JournalEntryDetails-tbody').append(tr);
            }
        }
    }

