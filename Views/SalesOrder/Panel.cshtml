    function showPaymentMethodsModal() {
        $('#paymentMethodsModal').modal("show");
        //  $("#TotalAfterTaxes").trigger('change');
    }
    function showUnpaidInvoicesModal() {
        var depId = $("#DepartmentId").val();
        getUnpaidInvoices(depId);

        $("#UnpaidInvoicesModal").modal("show");
    }
    function showDriversModal() {
        getDriversWithOrders();

        $("#DriversModal").modal("show");
    }
    function getDriversWithOrders() {
        $('#DriversModalTable').empty().append('<div class="col-sm-12"><div class="d-flex align-items-center"><div class="spinner-border ml-auto" role="status" aria-hidden="true"></div></div></div>');
        $.get('/PointOfSale/DriversWithOrdersByDepartment?depId=' + $("#DepartmentId").val()).done(function (r) {
            $('#DriversModalTable').empty().append(r);
        });
    }
    function showInvoiceTypeModal() {
        $("#invoiceTypeModal").modal('show');

    }
    function cashBoxBalance() {
        if ($('#CashBoxId').val())
            $.get('/Helper/CashBoxBalance/' + $('#CashBoxId').val()).done(function (r) {
                $('#cashBoxBalance').val(r);
            });
    }
    function getUnpaidInvoices(depId) {
        $('#UnpaidInvoicesModalTable').empty().append('<div class="col-sm-12"><div class="d-flex align-items-center"><div class="spinner-border ml-auto" role="status" aria-hidden="true"></div></div></div>');
        $.get('/PointOfSale/UnpaidSalesInvoicesByDepartment?id=' + depId).done(function (r) {
            $('#UnpaidInvoicesModalTable').empty().append(r);
        });
    }
    function getDrivers() {
        return requestData('/Helper/GetDriversByDep?depId='+$("#DepartmentId").val()).done(function (r) {
            $('.DriverId').empty();
            $('.DriverId').append($('<option>', {
                value: "",
                text: '@MyERP.Properties.Resources.Select'
            }));
            for (var i = 0; i < r.length; i++) {
                $('.DriverId').append($('<option>', {
                    value: r[i].Id,
                    text: r[i].ArName
                }));
            }

            //$('#GovernorateId').trigger('change');
        });
    }
    function GetCurrentTaxPercentage() {
        $.get('/TaxesPercentages/GetCurrentTaxPercentage?date=' + $('#VoucherDate').val()).done(function (r) {
            taxPercentage = r / 100;
            CalculateTotals();
        });

    }
    $(document).on('change', '.PaymentAmount', function () {
        let totalPaied = 0;
        $('#SalesOrderPaymentMethods tr').each(function () {
            var td = $(this);
            totalPaied += td.find('.PaymentAmount').inputmask('unmaskedvalue') * 1;
        });
        $('#Paid').val(totalPaied);
        $('#Remaining').val(($('#Paid').inputmask('unmaskedvalue') - $('#TotalAfterTaxes').inputmask('unmaskedvalue')).toFixed(2))
    });
    $('.PaymentAmount').on('click', function () {
        selectedPaymentMethodInput = $(this);
    });
    $('.drivers').on('click', function () {
        //window.location.replace('/Drivers/AddEdit');
        showDriversModal();
    });
    $(document).on('click', '.getForm', function () {
        var btn = $(this);
        var customerType = btn.attr("customerType");
        //window.location.replace("/PointOfSale/AddEdit?selectedcustomerType=" + customerType);
        $("#invoiceTypeModal").modal('hide');
        $('#CustomerType').val(customerType).trigger('change').attr('disabled', 'disabled');
    });
    $(document).on('change', '#CashBoxId', function () {
        cashBoxBalance();
    });
    $('#hasTaxes').on('click', function () {

        CalculateTotals();
    });
    $('#VoucherDate').on('change', function () {
        GetCurrentTaxPercentage();
    });
    $(document).on('change', '#DeliveryCost', function () {
        CalculateTotals();
        $('#TotalAfterTaxes').trigger('change');
        //CalculateTotalRefundableInsurance();
    });
    $(document).on('change', "#TotalAfterTaxes", function () {
        if ($("#CustomerType").val() == 2 || $("#CustomerType").val() == 3) {
            $("#PayMethod2").val($("#TotalAfterTaxes").val());
            $("#PayMethod1").val('');
            //$(".PaymentAmount").val($("#TotalAfterTaxes").val());

            $(".PaymentAmount").trigger('change');

        }
        else if ($("#CustomerType").val() == 1) {
            $("#PayMethod1").val($("#TotalAfterTaxes").val());
            $("#PayMethod2").val('');

            $(".PaymentAmount").trigger('change');
        }
    });

