dit-input form-control-sm" type="text" /></td><td class="tabledit-edit-mode" > <button class="btn btn-info" data-toggle="modal" data-target="#itemDetails" onclick="showItemDetials(this)">' + '@MyERP.Properties.Resources.Details' + '</button></td><td class="tabledit-edit-mode"><input type="hidden" class="car-type-id" /><input type="hidden" class="car-model-id" /><input type="hidden" class="car-color-id" /><input type="hidden" class="chassis-no" /><input type="hidden" class="engine-no" /><input type="hidden" class="manufacturing-year" /><input type="hidden" class="plate-no" /><input type="hidden" class="vehicle-notes" /><button class="btn btn-secondary vehicle-details-btn" data-toggle="modal" data-target="#vehicleDetailsModal" onclick="showVehicleDetails(this)">بيانات السيارة</button></td><td><a href="javascript:void(0);" onclick="deleteElement(this)"><i class="fas fa-trash-alt"></i></a></td></tr>';
             $('#SalesQuotationDetails').append(tr);
             if (window.sessionStorage.getItem("UseItemUnit") == 'true') {
                 $('.UnitClass').show();
                 $('.UnitEquivClass').show();
             }
             if (ShowItemWidthAndHeightAndAreaInTransactions == 'True') {
                 $('.ItemArea').show();
             }

            $('#SalesQuotationDetails .money').inputmask({
                alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
            });
             $('#SalesQuotationDetails input[type=number]').removeProp('oninput').prop('type', 'text').inputmask({
                alias: 'numeric', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
             });
            $('#SalesQuotationDetails input.small-number').removeProp('oninput').prop('type', 'text').inputmask({
                alias: 'numeric', autoGroup: true, digits: 4, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
            });
            $('#SalesQuotationDetails tr:last select').select2({
                matcher: matchCustom
            });
        }
    }

    $(document).on('change', '#DiscountValue', function () {
        var total = 0;
        $('.total').each(function () {
            total += $(this).inputmask('unmaskedvalue') * 1;
        });
        if (($(this).inputmask('unmaskedvalue') / total) >= 1) {
            $(this).val(0);
        }
        $('#VoucherDiscountPercentage').val(($(this).inputmask('unmaskedvalue') * 100 / total));
        CalculateTotals();
    });

    $(document).on('change', '#VoucherDiscountPercentage', function () {
            CalculateTotals();
    });

    $(document).on('change', '#SalesTaxes', function () {
        CalculateTotals();
    });

    $('#hasTaxes').on('click', function () {
        if ($('#hasTaxes').prop('checked')) {
            $('.taxes').show();
        }
        else {
            $('.taxes').hide();
            $('.comercialTaxes').hide();
            $('#hasComercialTaxes').removeAttr('checked');
            hideShowComercialTax(false);
            $('#SalesTaxes').val(0);
            $('#TotalAfterTaxes').val(0);
        }
        CalculateTotals();
    });

    $('#hasComercialTaxes').on('click', function () {
        hideShowComercialTax($('#hasComercialTaxes').prop('checked'));
        CalculateTotals();
    });

    function hideShowComercialTax(show) {
        var totalAfterTaxesLabel = $('label[for="TotalAfterTaxes"]');
        var colsm2 = $('#TotalAfterTaxes').closest('.col-sm-2');
        if (show) {
            $('label[for="TotalAfterTaxes"]').remove();
            $('#TotalAfterTaxes').closest('.col-sm-2').remove();
            $('#CommercialRevenueTaxAmount').closest('.form-group').append($(totalAfterTaxesLabel));
            $('#CommercialRevenueTaxAmount').closest('.form-group').append($(colsm2));
            $('.comercialTaxes').show();
        }
        else {
            $('label[for="TotalAfterTaxes"]').remove();
            $('#TotalAfterTaxes').closest('.col-sm-2').remove();
            $(totalAfterTaxesLabel).insertAfter($('#SalesTaxes').closest('.col-sm-2'));
            $(colsm2).insertBefore($('#hasComercialTaxes').closest('.col-sm-2'));
            $('.comercialTaxes').hide();
            $('#CommercialRevenueTaxAmount').val(0);
            $('#TotalAfterTaxes').val(0);
        }
        $('#TotalAfterTaxes').inputmask({
            alias: 'numeric', groupSeparator: ',', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
        });
    }

    function CalculateTotals() {
        var total = 0;
        $('.total').each(function () {
            total += $(this).inputmask('unmaskedvalue') * 1;
        });
        $('#Total').val(total);
        if ($('#VoucherDiscountPercentage').inputmask('unmaskedvalue') < 100) {
            $('#DiscountValue').val(($('#VoucherDiscountPercentage').inputmask('unmaskedvalue') / 100) * total);
        } else {
            $('#VoucherDiscountPercentage').val(0);
            $('#DiscountValue').val(0);
        }
        if ($('#DiscountValue').val()) {
            total -= $('#DiscountValue').inputmask('unmaskedvalue');
        }
        $('#NetTotal').val(total);
        if (includeFees) {
            let ServiceFees = $('#ServiceFeesPercentage').val() * total;
            $('#ServiceFees').val(ServiceFees);
            total += ServiceFees;
        }

        if ($('#hasTaxes').prop('checked')) {
            $('#SalesTaxes').val(total * taxPercentage);
            if ($('#hasComercialTaxes').prop('checked')) {
                $('#CommercialRevenueTaxAmount').val(total * .01);
                total -= total * .01;
            }
            total += $('#SalesTaxes').inputmask('unmaskedvalue') * 1;
        }
        //console.log(total);
        $('#TotalAfterTaxes').val(total);

        $('#InstallmentAmount').val('0');
        $('#CashAmount').val(total);
        if ($('#IsInstallmentPlan').prop('checked')) {
            $('#InstallmentAdvance').trigger('change');
        }
    }

    $(document).on('change', '#CashAmount', function () {
        var total=0;
        total = $('#TotalAfterTaxes').inputmask('unmaskedvalue');
        var CashAmount = PayViaCash == 'True' ? $('#CashAmount').inputmask('unmaskedvalue') * 1 : 0;
        var InstallmentAmount = PayViaCarryOver == 'True' ? $('#InstallmentAmount').inputmask('unmaskedvalue') * 1 : 0;
        var VisaAmount = PayViaVisa == 'True' ? $('#VisaAmount').inputmask('unmaskedvalue') * 1 : 0;
        var ChequeAmount = PayViaCheque == 'True' ? $('#ChequeAmount').inputmask('unmaskedvalue') * 1 : 0;
        var diff = total - (CashAmount + InstallmentAmount + VisaAmount + ChequeAmount);
        if (diff > 0) {
            $('#InstallmentAmount').val(diff);
        }
        else {
            $('#CashAmount').val(total);
            $('#InstallmentAmount').val(0);
            $('#VisaAmount').val(0);
            $('#ChequeAmount').val(0);
        }
    });

    $(document).on('change', '#InstallmentAmount', function () {
        var total = 0;

        total = $('#TotalAfterTaxes').inputmask('unmaskedvalue');
        var CashAmount = PayViaCash == 'True' ? $('#CashAmount').inputmask('unmaskedvalue') * 1 : 0;
        var InstallmentAmount = PayViaCarryOver == 'True' ? $('#InstallmentAmount').inputmask('unmaskedvalue') * 1 : 0;
        var VisaAmount = PayViaVisa == 'True' ? $('#VisaAmount').inputmask('unmaskedvalue') * 1 : 0;
        var ChequeAmount = PayViaCheque == 'True' ? $('#ChequeAmount').inputmask('unmaskedvalue') * 1 : 0;
        var diff = total - (CashAmount + InstallmentAmount + VisaAmount + ChequeAmount);
        if (diff > 0) {
            $('#ChequeAmount').val(diff);
        }
        else {
            $('#InstallmentAmount').val(total - CashAmount);
            $('#VisaAmount').val(0);
            $('#ChequeAmount').val(0);
        }
    });

    $(document).on('change', '#ChequeAmount', function () {
