             $('#SalesQuotationDetails').closest('.form-horizontal').addClass('was-validated');
            $('html, body').animate({
                scrollTop: $("#SalesQuotationDetails").find(".form-control:invalid").eq(0).offset().top - 80
            }, 500);
         } else if ($('#SalesQuotationDetails .quantity:last').val() && $('#SalesQuotationDetails .item-name:last').val()) {
