    function validateChassisNumbersForSalesQuotation() {
        let map = {};
        let valid = true;
        $('#SalesQuotationDetails tr').each(function () {
            let chassisNo = ($(this).find('.chassis-no').val() || '').trim().toLowerCase();
            if (chassisNo) {
                if (map[chassisNo]) { valid = false; return false; }
                map[chassisNo] = true;
            }
        });
        if (!valid) {
            Swal.fire({ title: 'رقم الشاسيه مكرر داخل نفس عرض السعر', text: ' ', icon: 'info', confirmButtonText: '@MyERP.Properties.Resources.Ok', confirmButtonColor: '#3085d6' });
        }
        return valid;
    }
