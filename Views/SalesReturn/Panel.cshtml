                        VoucherDiscountPercentage: $('#VoucherDiscountPercentage').inputmask('unmaskedvalue'),
                        NetTotal: $('#NetTotal').inputmask('unmaskedvalue'),
                        TotalItemDirectExpenses: $('#TotalItemDirectExpenses').inputmask('unmaskedvalue'),
                        SystemPageId: $('#SystemPageId').val(),
                        DepartmentId: $('#DepartmentId').val(),
                        SalesReturnsDetails: SalesReturnsDetails,
                        IsActive: $('#IsActive').val(),
                        IsDeleted: $('#IsDeleted').val(),
                        Notes: $('#Notes').val(),
                        SalesReturnPaymentMethods: paymentMethods,
                        IsCompleted: false
