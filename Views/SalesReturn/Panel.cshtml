                        SalesTaxes: $('#SalesTaxes').inputmask('unmaskedvalue'),
                        CommercialRevenueTaxAmount: $('#CommercialRevenueTaxAmount').inputmask('unmaskedvalue'),
                        TotalAfterTaxes: $('#TotalAfterTaxes').inputmask('unmaskedvalue'),
