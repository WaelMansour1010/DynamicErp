                                CurrencyEquivalent: $('#CurrencyEquivalent').val(),
                                Total: $('#Total').inputmask('unmaskedvalue'),
                                SalesTaxes: $('#SalesTaxes').inputmask('unmaskedvalue'),
                                TotalAfterTaxes: $('#TotalAfterTaxes').inputmask('unmaskedvalue'),
                                VoucherDiscountValue: $('#VoucherDiscountValue').inputmask('unmaskedvalue'),
                                VoucherDiscountPercentage: $('#VoucherDiscountPercentage').inputmask('unmaskedvalue'),
                                NetTotal: $('#NetTotal').inputmask('unmaskedvalue'),
                                CostCenterId: $('#CostCenterId').val(),
                                SystemPageId: $('#SystemPageId').val(),
                                SelectedId: $('#SelectedId').val(),
                                TotalItemDirectExpenses: $('#TotalItemDirectExpenses').inputmask('unmaskedvalue'),
                                CustomerRepId: $('#CustomerRepId').val(),
                                DueDate: $('#DueDate').val(),
                                PaymentType: $('#PaymentType').val(),
                                CommercialRevenueTaxAmount: $('#CommercialRevenueTaxAmount').inputmask('unmaskedvalue'),
                                IsActive: $('#IsActive').val(),
                                IsDeleted: $('#IsDeleted').val(),
                                IsDelivered: $('#IsDelivered').val(),
                                IsAccepted: $('#IsAccepted').val(),
                                IsLinked: $('#IsLinked').val(),
                                IsCompleted: $('#IsCompleted').val(),
                                IsPosted: $('#IsPosted').val(),
                                Notes: $('#Notes').val(),
                                UserId: $('#UserId').val(),
                                Image: $('#Image').val(),
                                ServiceInvoiceDetails: ServiceInvoiceDetails,
                                ServiceInvoicePaymentMethods: paymentMethods,
                               }),
                        success: function (r) {
                            if (r.success == "true") {
                                Swal.fire(
                                    {
                                        title: '@MyERP.Properties.Resources.Saved',
                                        text: " ",
                                        icon: 'success',
                                        showCancelButton: false,
                                        confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                        confirmButtonColor: '#3085d6'
                                    });
                                $('#preloader, #status').fadeOut();
                                if (n == "new") {
                                    window.location.replace("/ServiceInvoice/AddEdit");
                                } else if (n == "report") {

                                   // if (printMiniInvoice == "True") {
                                        EncodeId(r.id);
                                       // //window.open("/Report/CashierInvoice2?print=true&id=" + r.id, "_blank");
                                    @*}
                                    else if ('@System.Web.Configuration.WebConfigurationManager.AppSettings["ProjectName"]' == "Kimo") {
                                        window.open("/Report/KimoServiceInvoice/" + r.id);
                                    }
                                    else {
                                        window.open("/Report/E_Invoice/" + r.id +"?print=True");
                                        //window.open("/Report/ServiceInvoice/" + r.id);

                                    }*@
                                    window.location.replace("/ServiceInvoice");
                                }
                                else {
                                    window.location.replace("/ServiceInvoice");
                                }
                            }
                            else if (r.success == 'IsLinkedWithOrderServiceInvoice')
                            {
                                $('#preloader, #status').fadeOut();
                                 Swal.fire({
                                    title: '@MyERP.Properties.Resources.YouCantEditThisDocument',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });

                            }
                            else if (r.success == "Cannot Be Edited")
                            {
                                $('#preloader, #status').fadeOut();
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.TheInvoiceHasBeenGeneratedAndCannotBeEdited',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });

                            }
                            else {
                                $('#preloader, #status').fadeOut();
                                $('#newbtn').prop('disabled', false);
                                $('#save').prop('disabled', false);
                                $('#saveAndPrint').prop('disabled', false);
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.NotSaved',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                            }
                        },
                        error: function (r) {
                            $('#preloader, #status').fadeOut();
                            $('#newbtn').prop('disabled', false);
                            $('#save').prop('disabled', false);
                            $('#saveAndPrint').prop('disabled', false);
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.NotSaved',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                        }
                    });
                }
                else { result.dismiss; }
            });
        }
       }

