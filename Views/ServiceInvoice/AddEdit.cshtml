@model MyERP.Models.ServiceInvoice
@{
    if (System.Web.Configuration.WebConfigurationManager.AppSettings["ECommerce"] == "true")
    {
        Layout = "~/Views/Shared/_EcommerceLayout.cshtml";
    }

    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.ServiceInvoice;
}

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                @if (Model != null)
                {
                    if (Model.IsDeleted == false)
                    {
                        if (ViewBag.Previous > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.First })" class="btn btn-info">@MyERP.Properties.Resources.First</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Previous })" class=" btn btn-info">&#8250;</a>
                        }
                        if (ViewBag.Next > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Next })" class="btn btn-info">&#8249;</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Last })" class="btn btn-info">@MyERP.Properties.Resources.Last</a>
                        }
                    }
                }
                <a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
            </div>
            <h4 class="page-title">@MyERP.Properties.Resources.ServiceInvoice :</h4>
        </div>
    </div>
</div>
@if (Model != null)
{
    if (Model.Id > 0)
    {
        @Html.HiddenFor(model => model.Id)
    }
    @Html.HiddenFor(model => model.IsActive)
    @Html.HiddenFor(model => model.UserId)
    @Html.HiddenFor(model => model.IsLinked)
    @Html.HiddenFor(model => model.IsPosted)
    @Html.HiddenFor(model => model.IsDelivered)
    @Html.HiddenFor(model => model.IsDeleted)
    @Html.HiddenFor(model => model.IsAccepted)
    @Html.HiddenFor(model => model.IsCompleted)
    @Html.HiddenFor(model => model.SelectedId)
    @Html.HiddenFor(model => model.SystemPageId)
    @Html.HiddenFor(model => model.Image)
}
<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal needs-validation" role="form">

                        <div class="card">
                            <div class="card-body">
                                <h5 class="header-title">
                                    @MyERP.Properties.Resources.MainData
                                </h5>
                                <div class="form-group row">
                                    <label class=" col-sm-2 control-label" for="DocumentNumber">@MyERP.Properties.Resources.DocNo</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.DocumentNumber, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly", placeholder = @MyERP.Properties.Resources.DocNo, required = "required", hidden = "hidden" } })
                                        <input id="DocumentNumbers" class="form-control" placeholder=@MyERP.Properties.Resources.Code required readonly />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>

                                    <label for="VoucherDate" class="control-label col-sm-2">@MyERP.Properties.Resources.Date</label>
                                    <div class="col-sm-4">
                                        <input id="VoucherDate" name="VoucherDate" class="form-control" type="datetime-local" value="@ViewBag.VoucherDate" required />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="DepartmentId" class="col-sm-2 control-label">@MyERP.Properties.Resources.Department</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("DepartmentId", null, null, htmlAttributes: new { @class = "form-control", @required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>

                                    <label for="VendorOrCustomerId" class="control-label col-sm-2">@MyERP.Properties.Resources.Customer </label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("CustomerId", null, null, htmlAttributes: new { @class = "form-control", @required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Select
                                        </div>
                                    </div>

                                </div>


                                <div class="form-group row">
                                    <label class="control-label col-sm-2" for="PaymentType">@MyERP.Properties.Resources.Representative</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("CustomerRepId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })
                                    </div>
                                    <div class="invalid-feedback">
                                        @MyERP.Properties.Resources.Required
                                    </div>

                                    <label for="DueDate" class="control-label col-sm-2">@MyERP.Properties.Resources.DueDate</label>
                                    <div class="col-sm-4">
                                        <input id="DueDate" name="DueDate" class="form-control" type="datetime-local" value="@ViewBag.DueDate" required />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>

                                </div>

                                <div class="form-group row">
                                    <label class="control-label col-sm-2" for="Notes">@MyERP.Properties.Resources.Notes</label>
                                    <div class="col-sm-4">
                                        <textarea id="Notes" name="Notes" class="form-control" rows="1" cols="5">@if (Model != null) { @Model.Notes; }</textarea>
                                    </div>

                                </div>

                                @if (ViewBag.UseCostCenter == true)
                                {
                                    <div class="form-group row">
                                        <label for="CostCenterId" class="control-label col-sm-2">@MyERP.Properties.Resources.CostCenter</label>
                                        <div class="col-sm-4">
                                            @Html.DropDownList("CostCenterId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })
                                        </div>
                                    </div>
                                }

                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Details -->


            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="header-title">@MyERP.Properties.Resources.Details</h5>
                            <div class="form-horizontal needs-validation" role="form">
                                <div class="table-responsive">
                                    <table class="table table-centered mb-0">
                                        <thead>
                                            <tr>
                                                <th> @MyERP.Properties.Resources.ServiceName</th>
                                                <th>
                                                    @MyERP.Properties.Resources.Price
                                                </th>
                                                <th class="IsDiscountTrue" style="display:none;">
                                                    @MyERP.Properties.Resources.DiscountPercentage
                                                </th>

                                                <th class="IsDiscountTrue" style="display:none;">
                                                    @MyERP.Properties.Resources.DiscountValue
                                                </th>
                                                <th class="ItemTax" style="display:none;">
                                                    @MyERP.Properties.Resources.TaxPercentage
                                                </th>
                                                <th class="ItemTax" style="display:none;">
                                                    @MyERP.Properties.Resources.TaxValue
                                                </th>
                                                <th>@MyERP.Properties.Resources.Total</th>
                                                <th>@MyERP.Properties.Resources.Delete</th>
                                            </tr>
                                        </thead>
                                        <tbody id="ServiceInvoiceDetails">
                                            @if (Model != null)
                                            {
                                                foreach (var item in Model.ServiceInvoiceDetails)
                                                {
                                                    <tr>
                                                        <td class="tabledit-edit-mode">
                                                            <input type="text" class="ServiceName IsUpdated form-control tabledit-input form-control-sm" value="@item.ServiceName" />
                                                        </td>

                                                        <td class="tabledit-edit-mode"><input type="text" class="money price form-control tabledit-input form-control-sm" value="@item.Price" /></td>

                                                        <td class="tabledit-edit-mode IsDiscountTrue" style="display:none;"><input type="number" step="any" class="DiscountPerc form-control tabledit-input form-control-sm" value="@item.DiscountPerc" /></td>
                                                        <td class="tabledit-edit-mode IsDiscountTrue" style="display:none;"><input type="number" step="any" class="DiscountValue form-control tabledit-input form-control-sm" value="@item.DiscountValue" /></td>
                                                        <td class="tabledit-edit-mode ItemTax" style="display:none;"><input type="text" class="ItemTaxPercentage form-control tabledit-input form-control-sm" value="@item.ItemTaxPercentage" /></td>
                                                        <td class="tabledit-edit-mode ItemTax" style="display:none;"><input type="text" class="ItemTaxValue form-control tabledit-input form-control-sm money" value="@item.ItemTaxValue" /></td>

                                                        <td class="tabledit-edit-mode"><input class="total money form-control tabledit-input form-control-sm" type="text" readonly value="0" /></td>
                                                        <td>
                                                            <a href="javascript:void(0);" onclick="deleteElement(this)">
                                                                <i class="fas fa-trash-alt"></i>
                                                            </a>
                                                        </td>
                                                    </tr>
                                                }
                                            }

                                            <tr>
                                                <td class="tabledit-edit-mode">
                                                    <input type="text" class="ServiceName IsUpdated form-control tabledit-input form-control-sm" value="" />
                                                </td>

                                                <td class="tabledit-edit-mode"><input type="text" class="money price form-control tabledit-input form-control-sm" value="" /></td>

                                                <td class="tabledit-edit-mode IsDiscountTrue" style="display:none;"><input type="number" step="any" class="DiscountPerc form-control tabledit-input form-control-sm" value="" /></td>
                                                <td class="tabledit-edit-mode IsDiscountTrue" style="display:none;"><input type="number" step="any" class="DiscountValue form-control tabledit-input form-control-sm" value="" /></td>
                                                <td class="tabledit-edit-mode ItemTax" style="display:none;"><input type="text" class="ItemTaxPercentage form-control tabledit-input form-control-sm" value="" /></td>
                                                <td class="tabledit-edit-mode ItemTax" style="display:none;"><input type="text" class="ItemTaxValue form-control tabledit-input form-control-sm money" value="" /></td>

                                                <td class="tabledit-edit-mode"><input class="total money form-control tabledit-input form-control-sm" type="text" readonly value="0" /></td>
                                                <td>
                                                    <a href="javascript:void(0);" onclick="deleteElement(this)">
                                                        <i class="fas fa-trash-alt"></i>
                                                    </a>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                                <hr />
                                <div class="form-group row">
                                    <label for="Total" class="control-label col-sm-2">@MyERP.Properties.Resources.Total:</label>
                                    <div class="col-sm-2">
                                        @Html.EditorFor(model => model.Total, new { htmlAttributes = new { @class = "form-control money", type = "text", id = "Total", @readonly = "readonly" } })

                                    </div>
                                    <label for="VoucherDiscountValue" class="control-label col-sm-1">@MyERP.Properties.Resources.DiscountValue: </label>
                                    <div class="col-sm-2">
                                        @Html.EditorFor(model => model.VoucherDiscountValue, new { htmlAttributes = new { @class = "form-control money", id = "VoucherDiscountValue", type = "text", value = "0" } })

                                    </div>
                                    <label for="VoucherDiscountPercentage" class="control-label col-sm-1">@MyERP.Properties.Resources.DiscountPercentage: </label>
                                    <div class="col-sm-2">
                                        @Html.EditorFor(model => model.VoucherDiscountPercentage, new { htmlAttributes = new { @class = "form-control", value = "0" } })

                                    </div>
                                </div>

                                <div class="form-group row">
                                    <label for="NetTotal" class="control-label col-sm-2">
                                        @MyERP.Properties.Resources.TotalAfterDiscount

                                    </label>
                                    <div class="col-sm-2">
                                        @Html.EditorFor(model => model.NetTotal, new { htmlAttributes = new { @class = "form-control money", type = "text", @readonly = "readonly", id = "NetTotal", value = "0" } })

                                    </div>
                                    <label for="totalInvoiceProfit" class="showProfit control-label col-sm-2">
                                        @MyERP.Properties.Resources.TotallnvoiceProfit
                                    </label>
                                    <div class="col-sm-2 showProfit">
                                        <input type="text" readonly="readonly" class="showProfit form-control " id="totalProfit" />
                                    </div>

                                    @if (Model != null)
                                    {
                                        <div class="col-sm-4">
                                            <input type="checkbox" id="hasTaxes" @Html.Raw(Model != null && Model.SalesTaxes > 0 ? "checked" : "") />

                                            @MyERP.Properties.Resources.ApplySalesTaxesValue
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="col-sm-4">
                                            <input type="checkbox" id="hasTaxes" @Html.Raw(ViewBag.ApplyTaxes == true ? "checked" : "") />
                                            @MyERP.Properties.Resources.ApplySalesTaxesValue

                                        </div>
                                    }
                                </div>

                                <div class="form-group row taxes" style="display:none;">
                                    <label for="SalesTaxes" class="control-label  col-sm-2  taxes" style="display:none;">
                                        @MyERP.Properties.Resources.SalesTaxesValue
                                    </label>
                                    <div class="col-sm-2 taxes" style="display:none;">
                                        @Html.EditorFor(model => model.SalesTaxes, new { htmlAttributes = new { @class = "form-control money taxes", id = "SalesTaxes", type = "text", value = "0" } })
                                        @Html.ValidationMessageFor(model => model.SalesTaxes, "", new { @class = "text-danger" })
                                    </div>
                                    <label for="TotalAfterTaxes" class="control-label col-sm-2 taxes" style="display:none;">
                                        @MyERP.Properties.Resources.TotalAfterTaxes
                                    </label>
                                    <div class="col-sm-2 taxes" style="display:none;">
                                        @Html.EditorFor(model => model.TotalAfterTaxes, new { htmlAttributes = new { @class = "form-control taxes money ", type = "text", id = "TotalAfterTaxes", @readonly = "readonly ", value = "0" } })
                                        @Html.ValidationMessageFor(model => model.TotalAfterTaxes, "", new { @class = "text-danger" })
                                    </div>
                                    <div class="col-sm-2 taxes" style="display:none;">
                                        <input type="checkbox" id="hasComercialTaxes" @Html.Raw(Model != null && Model.CommercialRevenueTaxAmount > 0 ? "checked" : "") />
                                        @MyERP.Properties.Resources.ApplyCommericalRevenueTaxAmount
                                    </div>
                                </div>

                                <div class="form-group row comercialTaxes" style="display:none;">
                                    <label for="CommercialRevenueTaxAmount" class="control-label  col-sm-2 comercialTaxes" style="display:none;">
                                        @MyERP.Properties.Resources.CommercialRevenueTaxAccount
                                    </label>
                                    <div class="col-sm-2 comercialTaxes" style="display:none;">
                                        @Html.EditorFor(model => model.CommercialRevenueTaxAmount, new { htmlAttributes = new { @class = "form-control money comercialTaxes", id = "CommercialRevenueTaxAmount", type = "text", value = "0" } })
                                        @Html.ValidationMessageFor(model => model.CommercialRevenueTaxAmount, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>


            <!-- Payment Methods -->
            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="header-title">@MyERP.Properties.Resources.PaymentMethods</h5>
                            <div class="form-horizontal needs-validation" role="form">
                                <div class="table-responsive">
                                    <table class="table table-centered mb-0">
                                        <thead>
                                            <tr>
                                                <th>@MyERP.Properties.Resources.PaymentMethod</th>
                                                <th>@MyERP.Properties.Resources.Amount</th>
                                                <th>@MyERP.Properties.Resources.CashBox</th>
                                                @*<th>الحساب البنكى</th>*@
                                            </tr>
                                        </thead>
                                        <tbody id="ServiceInvoicePaymentMethods">
                                            @if (Model != null && Model.Id > 0)
                                            {
                                                foreach (var method in Model.ServiceInvoicePaymentMethods)
                                                {
                                                    <tr>
                                                        <td class="tabledit-edit-mode">
                                                            <input value="@method.PaymentMethod.Id" class="PaymentMethodId" type="hidden" />
                                                            <label>@method.PaymentMethod.ArName</label>
                                                        </td>
                                                        @if (method.PaymentMethod.Id == 1)
                                                        {
                                                            <td class="tabledit-edit-mode"><input class="money PaymentAmount form-control tabledit-input form-control-sm" type="text" value="@method.Amount" id="CashAmount" /></td>
                                                            <td class="tabledit-edit-mode">
                                                                @Html.DropDownList("CashBoxId", null, null, htmlAttributes: new { @class = "CashBoxId form-control tabledit-input form-control-sm" })
                                                            </td>
                                                            <td></td>
                                                        }
                                                        else if (method.PaymentMethod.Id == 2)
                                                        {
                                                            <td class="tabledit-edit-mode"><input class="money PaymentAmount form-control tabledit-input form-control-sm" type="text" value="@method.Amount" id="DebitAmount" /></td>
                                                            <td></td>
                                                            <td></td>
                                                        }
                                                        else
                                                        {
                                                            <td class="tabledit-edit-mode"><input class="money PaymentAmount form-control tabledit-input form-control-sm" type="text" value="@method.Amount" /></td>
                                                            <td></td>
                                                            <td></td>
                                                        }

                                                    </tr>
                                                }
                                            }
                                            else
                                            {

                                                foreach (var method in (List<MyERP.Models.PaymentMethod>)ViewBag.PaymentMethods)
                                                {
                                                    <tr>
                                                        <td class="tabledit-edit-mode">
                                                            <input value="@method.Id" class="PaymentMethodId" type="hidden" />
                                                            <label>@method.ArName</label>
                                                        </td>
                                                        @if (method.Id == 1)
                                                        {
                                                            <td class="tabledit-edit-mode"><input class="money PaymentAmount form-control tabledit-input form-control-sm" type="text" id="CashAmount" /></td>
                                                            <td class="tabledit-edit-mode">
                                                                @Html.DropDownList("CashBoxId", null, null, htmlAttributes: new { @class = "CashBoxId form-control tabledit-input form-control-sm" })
                                                            </td>
                                                            <td></td>
                                                        }
                                                        else if (method.Id == 2)
                                                        {
                                                            <td class="tabledit-edit-mode"><input class="money PaymentAmount form-control tabledit-input form-control-sm" type="text" id="DebitAmount" /></td>
                                                            <td></td>
                                                            <td></td>
                                                        }
                                                        else
                                                        {
                                                            <td class="tabledit-edit-mode"><input class="money PaymentAmount form-control tabledit-input form-control-sm" type="text" /></td>
                                                            <td></td>
                                                            <td></td>
                                                        }

                                                    </tr>
                                                }

                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-------------- Saves Buttons -------------->
            <div class="row">
                <div class="col-sm-offset-2">
                    @if (Model == null)
                    {

                        <button type="submit" id="saveAndPrint" onclick="addEdit('report')" class="btn btn-success">
                            @MyERP.Properties.Resources.SaveAndPrint
                        </button>
                        <button type="submit" id="newbtn" onclick="addEdit('new')" class="btn btn-success">
                            @MyERP.Properties.Resources.SaveAndNew
                        </button>
                        <button class="btn btn-success" id="save" onclick="addEdit()">
                            @MyERP.Properties.Resources.Save
                        </button>
                        <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                    }
                    else if (Model.IsDeleted == false)
                    {
                        <a id="printReport" class="btn btn-success" href="javascript:void(0);" onclick="EncodeId2(@Model.Id)" role="button">@MyERP.Properties.Resources.PrintInvoice</a>

                        @*if (ViewBag.PrintReceiptInsteadOfServiceInvoice == true)
            {
                <a id="printReport" class="btn btn-success"  href="javascript:void(0);" onclick="EncodeId(@Model.Id)" role="button">@MyERP.Properties.Resources.Print</a>
            }
            else
            {
                <a id="printReport" class="btn btn-success" target="_blank" href="/Report/ServiceInvoice?print=true&id=@Model.Id" role="button">@MyERP.Properties.Resources.Print</a>
            }*@
                        <button type="submit" id="saveAndPrint" onclick="addEdit('report')" class="btn btn-success">
                            @MyERP.Properties.Resources.SaveAndPrint
                        </button>
                        <button class="btn btn-success" id="save" onclick="addEdit()">
                            @MyERP.Properties.Resources.Save
                        </button>
                        <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                        <button class="btn btn-danger" onclick="Delete(@Model.Id)">
                            @MyERP.Properties.Resources.Delete
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
@if (Model != null && ViewBag.Journal != null)
{
    <div class="card">
        <div class="card-body">
            <h5 class="header-title">
                @MyERP.Properties.Resources.JournalEntry

            </h5>
            <div class="form-horizontal">
                <div class="form-group row">
                    <label for="JournalDocNo" class="col-sm-1 control-label">
                        @MyERP.Properties.Resources.JournalEntrieNo
                    </label>
                    <div class="col-sm-5">
                        <input type="text" class="form-control" name="JournalDocNo" value="@ViewBag.Journal.DocumentNumber" id="JournalDocNo" placeholder="@MyERP.Properties.Resources.JournalEntrieNo" readonly>

                    </div>
                    <label for="JournalDate" class="col-sm-2 control-label">@MyERP.Properties.Resources.Date </label>
                    <div class="col-sm-4">
                        <input type="datetime-local" class="form-control" name="JournalDate" value="@ViewBag.VoucherDate" id="JournalDate" placeholder="@MyERP.Properties.Resources.ReleaseDate" readonly>

                    </div>
                </div>
                <div class="form-group row">
                    <label for="JournalNotes" class="col-2 control-label">@MyERP.Properties.Resources.Notes</label>
                    <div class="col-sm-4">
                        <textarea class="form-control" id="JournalNotes" value="@ViewBag.Journal.Notes" readonly name="JournalNotes" placeholder="@MyERP.Properties.Resources.Notes"></textarea>
                    </div>

                    <label for="JournalIsPosted" class="col-sm-2 control-label">@MyERP.Properties.Resources.CarriedOver</label>
                    <div class="col-sm-4">
                        <input type="checkbox" id="JournalIsPosted" name="JournalIsPosted" disabled @Html.Raw(Model.IsPosted == true ? "checked" : null)>

                    </div>
                </div>
                <div class="card">
                    <div class="card-body">
                        <h5 class="header-title"> @MyERP.Properties.Resources.JournalEntryDetails</h5>
                        <div class="table-responsive">
                            <table class="table table-centered mb-0">
                                <thead>
                                    <tr>
                                        <th>@MyERP.Properties.Resources.Debit</th>
                                        <th>@MyERP.Properties.Resources.Credit</th>
                                        <th>@MyERP.Properties.Resources.Account</th>
                                        <th>@MyERP.Properties.Resources.Explanation</th>
                                        <th>@MyERP.Properties.Resources.CostCenter</th>
                                    </tr>
                                </thead>
                                <tbody id="JournalEntryDetails-tbody">
                                    @foreach (var item in ViewBag.Journal.JournalEntryDetails)
                                    {
                                        if (item.Debit > 0 || item.Credit > 0)
                                        {
                                            <tr>
                                                <td>@item.Debit</td>
                                                <td>@item.Credit</td>
                                                <td>
                                                    @Html.Raw(item.ChartOfAccount != null ? item.ChartOfAccount.ArName : null)
                                                    <input type="hidden" class="JournalAccountId" value="@item.AccountId" />
                                                </td>
                                                <td>@item.Notes</td>
                                                <td>
                                                    @Html.Raw(item.CostCenter != null ? item.CostCenter.ArName : null)
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}



<!--- \\ ------------ Modal Section ------------ // --->
<!--- \\ ------------ End Of Modal Section ------------ // --->

<script>
    //------- Variables Declaration ------- //
    var taxPercentage = 0.14;
    let customerRepOptions = '';
    let items = [];
    let custIems = [];
    let details = [];
    var totalInvoiceProfit = 0;

    //*********************************************************//
    //--------------- Ready Function -------------------//
     $(document).ready(function ()
     {
         //$('.showProfit').hide();//hide profit by default
         $('.IsDiscountTrue').show();

        $('#VoucherDiscountPercentage').inputmask({
