    function hideShowComercialTax(show) {
        var totalAfterTaxesLabel = $('label[for="TotalAfterTaxes"]');
        var colsm2 = $('#TotalAfterTaxes').closest('.col-sm-2');
        if (show) {
            $('label[for="TotalAfterTaxes"]').remove();
