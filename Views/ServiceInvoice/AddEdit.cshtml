                $('#TotalAfterTaxes').val($('#NetTotal').inputmask('unmaskedvalue') * 1);
                //  $('#TotalAfterTaxes').val($('#NetTotal').inputmask('unmaskedvalue') * 1 + $('#ServiceFees').inputmask('unmaskedvalue') * 1);
            }
        }

        var ServiceInvoiceDetails = [];
        if (valid) {
            $('#ServiceInvoiceDetails tr').each(function () {
                var td = $(this);
                if (td.find('.price').val() * 1 != 0 && td.find('.ServiceName').val()) {
                    var ServiceInvoiceDetail = {
                        ServiceName: td.find('.ServiceName').val(),
                        Price: td.find('.price').inputmask('unmaskedvalue'),
                        CurrencyId: td.find('.CurrencyId').val(),
                        CurrencyEquivalent: td.find('.CurrencyEquivalent').val(),
                        DiscountValue: td.find('.DiscountValue').val(),
                        DiscountPerc: td.find('.DiscountPerc').val(),
                        ItemTaxPercentage: td.find('.ItemTaxPercentage').val(),
                        ItemTaxValue: td.find('.ItemTaxValue').inputmask('unmaskedvalue'),
                        IsDeleted: false,
                        Notes: td.find('.Notes').val(),
                    };
                    ServiceInvoiceDetails.push(ServiceInvoiceDetail);
                }
            });
            if (valid) {
                valid = ServiceInvoiceDetails.length > 0 ? true : false;
                !valid ? Swal.fire({
                    title: '@MyERP.Properties.Resources.AllDetailsRequired',
                    text: " ", icon: 'info', showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok', confirmButtonColor: '#3085d6'
                }) : null;
            }
        }

        if (valid) {
            var paymentMethods = [];
            let totalPaied = 0;
            $('#ServiceInvoicePaymentMethods tr').each(function () {
                var td = $(this);
                totalPaied += td.find('.PaymentAmount').inputmask('unmaskedvalue') * 1;
                var paymentMethod = {
                    ServiceInvoiceId: $('#Id').val(),
                    PaymentMethodId: td.find('.PaymentMethodId').val(),
                    CashBoxId: td.find('.PaymentAmount').inputmask('unmaskedvalue') ? td.find('.CashBoxId').val() : null,
                    Amount: td.find('.PaymentAmount').inputmask('unmaskedvalue'),
                    BankId: td.find('.PaymentAmount').inputmask('unmaskedvalue') && td.find('.BankId').val() > 0 ? td.find('.BankId').val() : null,
                    BankAccountId: td.find('.PaymentAmount').inputmask('unmaskedvalue') && td.find('.BankAccountId').val() > 0 ? td.find('.BankAccountId').val() : null
                };
                paymentMethods.push(paymentMethod);
            });
             let finalTotal = $('#TotalAfterTaxes').inputmask('unmaskedvalue');
            if (finalTotal * 1 != totalPaied) {
                Swal.fire({
                    title: '@MyERP.Properties.Resources.TheTotalValueIsNotEqualToTotalAmountPaid',
                    text: " ",
                    icon: 'info',
                    showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    confirmButtonColor: '#3085d6'
                });
                valid = false;
            }
        }
        var _voucher = new Date($('#VoucherDate').val());
        var _due = new Date($('#DueDate').val());
        if (_voucher > _due) {
            valid = false;
            Swal.fire({
                title: '@MyERP.Properties.Resources.VoucherDateMustBeGreaterThanDueDate',
                text: " ",
                icon: 'info',
                showCancelButton: false,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                confirmButtonColor: '#3085d6'
            });
        }
        if (valid) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.AreYouSureYouWantToSave',
                text: " ",
                icon: 'info',
                showCancelButton: true,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                cancelButtonText: '@MyERP.Properties.Resources.Cancel',
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
