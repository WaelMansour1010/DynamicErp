@{
    var hrArea = (ViewBag.SharedHrArea as string) ?? (ViewContext.RouteData.DataTokens["area"] as string) ?? string.Empty;
    var hrReadOnly = ViewBag.SharedHrReadOnly is bool && (bool)ViewBag.SharedHrReadOnly;
    Func<string, string> hrUrl = action => Url.Action(action, "EmployeePayroll", new { area = hrArea });
}
<main class="ep-page ep-employee-command-center" data-screen="employees"
      data-read-only="@(hrReadOnly ? "true" : "false")"
      data-lookups-url="@hrUrl("Lookups")"
      data-search-url="@hrUrl("Search")"
      data-get-url="@hrUrl("Get")"
      data-save-url="@(hrReadOnly ? string.Empty : hrUrl("Save"))"
      data-active-url="@(hrReadOnly ? string.Empty : hrUrl("SetActive"))"
      data-plan-defaults-url="@hrUrl("PlanDefaults")">

    <header class="ep-emp-hero">
        <section class="ep-emp-title">
            <span class="ep-eyebrow">Employee Workspace</span>
            <h1>ملفات الموظفين</h1>
            <p>إدارة ملف الموظف الوظيفي والمالي والتأمين الطبي من شاشة واحدة، مع بحث سريع وملخص واضح قبل فتح أي تفاصيل.</p>
            <div class="ep-emp-actions">
                <a class="ep-link" href="@hrUrl("SalaryRun")"><i class="fas fa-file-invoice-dollar"></i> مسير الرواتب</a>
                <a class="ep-link" href="@hrUrl("MedicalInsurance")"><i class="fas fa-briefcase-medical"></i> التأمين الطبي</a>
                <button type="button" class="ep-primary" id="epNewEmployee" @(hrReadOnly ? "hidden disabled" : "")><i class="fas fa-plus"></i> موظف جديد</button>
            </div>
        </section>
        <aside class="ep-emp-focus-card">
            <span>وضع الشاشة</span>
            <strong>@(hrReadOnly ? "استعراض" : "إدارة")</strong>
            <small>لا يتم إنشاء قيود محاسبية من شاشة الموظفين.</small>
        </aside>
    </header>

    <section class="ep-emp-kpis" aria-label="مؤشرات الموظفين">
        <article><i class="fas fa-users"></i><span>إجمالي النتائج</span><strong id="epDashEmployees">0</strong><small>حسب الفلاتر الحالية</small></article>
        <article class="success"><i class="fas fa-user-shield"></i><span>موظفون مؤمنون</span><strong id="epDashInsured">0</strong><small>تأمين نشط أو محفوظ</small></article>
        <article class="warning"><i class="fas fa-exclamation-triangle"></i><span>تحتاج مراجعة</span><strong id="epDashPendingInsurance">0</strong><small>تأمين ناقص أو غير مربوط</small></article>
        <article><i class="fas fa-code-branch"></i><span>الفروع الظاهرة</span><strong id="epDashBranches">0</strong><small>من نتائج البحث</small></article>
    </section>

    <section class="ep-emp-filter-card">
        <div class="ep-emp-search">
            <i class="fas fa-search"></i>
            <input id="epSearchTerm" type="search" placeholder="ابحث بالكود، الاسم، الجوال..." />
        </div>
        <label>الفرع<select id="epBranchFilter"><option value="">كل الفروع</option></select></label>
        <label>الإدارة<select id="epDepartmentFilter"><option value="">كل الإدارات</option></select></label>
        <label>الحالة<select id="epActiveFilter"><option value="">الكل</option><option value="true">نشط</option><option value="false">غير نشط</option></select></label>
        <button type="button" class="ep-primary" id="epSearchBtn"><i class="fas fa-search"></i> بحث</button>
    </section>

    <section class="ep-recent-strip" id="epRecentEmployees" hidden></section>

    <section class="ep-emp-workspace">
        <aside class="ep-emp-profile" id="epProfileSummary">
            <div class="ep-profile-empty">
                <i class="fas fa-user-circle"></i>
                <strong>اختر موظفاً</strong>
                <span>سيظهر هنا ملخص الفرع، الإدارة، الراتب، التأمين، والحسابات المرتبطة.</span>
            </div>
        </aside>

        <section class="ep-emp-list-card">
            <div class="ep-panel-head">
                <div>
                    <h2>قائمة الموظفين</h2>
                    <p>البحث لا يحمّل كل الموظفين دفعة واحدة. استخدم كلمة بحث أو فرع أو إدارة لتسريع النتائج.</p>
                </div>
                <span class="ep-status-badge active" id="epEmployeeLoadState">جاهز</span>
            </div>
            <div class="ep-table-shell">
                <table class="ep-table ep-employee-table">
                    <thead>
                        <tr>
                            <th>الكود</th>
                            <th>الاسم</th>
                            <th>الفرع</th>
                            <th>الإدارة</th>
                            <th>الوظيفة</th>
                            <th>الراتب</th>
                            <th>التأمين</th>
                            <th>الحالة</th>
                            <th>إجراءات</th>
                        </tr>
                    </thead>
                    <tbody id="epEmployeesRows">
                        <tr><td colspan="9" class="ep-empty-row">ابدأ البحث لعرض الموظفين.</td></tr>
                    </tbody>
                </table>
            </div>
        </section>
    </section>

    <section class="ep-employee-drawer" id="epEmployeeEditor" hidden>
        <form id="epEmployeeForm" class="ep-employee-drawer-content">
            <input type="hidden" id="epEmployeeId" />
            <input type="hidden" id="epInsuranceId" />
            <input type="hidden" id="epPhotoDataUrl" />
            <header class="ep-drawer-header">
                <div>
                    <span>Employee Profile</span>
                    <h2 id="epEditorTitle">بيانات الموظف</h2>
                    <p>بيانات العمل والراتب والتأمين الطبي في ملف واحد قابل للمراجعة.</p>
                </div>
                <div class="ep-drawer-header-actions">
                    <button type="button" class="ep-secondary" id="epPrintEmployeeCard"><i class="fas fa-id-badge"></i> طباعة كارت الموظف</button>
                    <button type="button" class="ep-secondary" id="epPrintEmployeeInsuranceCard"><i class="fas fa-briefcase-medical"></i> طباعة كارت التأمين</button>
                    <button type="button" class="ep-secondary" id="epCloseEditor">إغلاق</button>
                    <button type="submit" class="ep-primary" @(hrReadOnly ? "hidden disabled" : "")><i class="fas fa-save"></i> حفظ الملف</button>
                </div>
            </header>

            <nav class="ep-drawer-tabs" role="tablist">
                <button type="button" class="active" data-tab="basic"><i class="fas fa-id-card"></i> بيانات أساسية</button>
                <button type="button" data-tab="job"><i class="fas fa-sitemap"></i> وظيفية</button>
                <button type="button" data-tab="finance"><i class="fas fa-coins"></i> مالية</button>
                <button type="button" data-tab="insurance"><i class="fas fa-briefcase-medical"></i> التأمين الطبي</button>
                <button type="button" data-tab="notes"><i class="fas fa-stream"></i> السجل</button>
            </nav>

            <div class="ep-drawer-body">
                <section class="ep-tab active ep-form-grid three" data-tab-panel="basic">
                    <div class="ep-photo-editor ep-span-all">
                        <div class="ep-photo-preview" id="epPhotoPreview"><i class="fas fa-user"></i></div>
                        <div class="ep-photo-tools">
                            <strong>صورة الموظف</strong>
                            <span>تظهر في ملف الموظف وكارت الموظف وكارت التأمين الطبي. يفضل صورة واضحة بخلفية هادئة.</span>
                            <div>
                                <label class="ep-secondary ep-photo-upload" for="epPhotoInput"><i class="fas fa-camera"></i> اختيار صورة</label>
                                <input id="epPhotoInput" type="file" accept="image/png,image/jpeg,image/webp" hidden />
                                <button type="button" class="ep-secondary" id="epRemovePhoto"><i class="fas fa-trash-alt"></i> حذف الصورة</button>
                            </div>
                        </div>
                    </div>
                    <label class="ep-field"><span>كود الموظف</span><input id="epCode" required maxlength="50" /></label>
                    <label class="ep-field"><span>اسم الموظف</span><input id="epName" required maxlength="255" /></label>
                    <label class="ep-field"><span>الجوال</span><input id="epMobile" /></label>
                    <label class="ep-field"><span>الهاتف</span><input id="epPhone" /></label>
                    <label class="ep-field"><span>البريد</span><input id="epEmail" type="email" /></label>
                    <label class="ep-switch ep-field-inline"><input id="epIsActive" type="checkbox" checked /> موظف نشط</label>
                </section>

                <section class="ep-tab ep-form-grid three" data-tab-panel="job">
                    <label class="ep-field"><span>الفرع</span><select id="epBranch"><option value="">غير محدد</option></select></label>
                    <label class="ep-field"><span>الإدارة</span><select id="epDepartment"><option value="">غير محدد</option></select></label>
                    <label class="ep-field"><span>الوظيفة</span><select id="epJob"><option value="">غير محدد</option></select></label>
                    <label class="ep-field"><span>تاريخ التعيين</span><input id="epHiringDate" type="date" /></label>
                </section>

                <section class="ep-tab ep-form-grid three" data-tab-panel="finance">
                    <label class="ep-field"><span>الراتب الأساسي</span><input id="epSalary" type="number" step="0.01" min="0" /></label>
                    <input id="epAccountCode" type="hidden" />
                    <input id="epAccruedAccountCode" type="hidden" />
                    <div class="ep-span-all ep-inline-hint"><i class="fas fa-lock"></i> الحسابات الداخلية محفوظة للنظام ولا تعرض للمستخدم. مراجعة الحسابات تتم من معاينة القيد في مسير الرواتب بأسماء حسابات واضحة.</div>
                </section>

                <section class="ep-tab ep-form-grid three" data-tab-panel="insurance">
                    <label class="ep-switch ep-field-inline"><input id="epInsuranceActive" type="checkbox" /> تأمين نشط</label>
                    <label class="ep-field"><span>خطة التأمين</span><select id="epInsurancePlan"><option value="">غير محدد</option></select></label>
                    <label class="ep-field"><span>رقم الوثيقة</span><input id="epInsurancePolicyNumber" maxlength="100" /></label>
                    <label class="ep-field"><span>رقم البطاقة</span><input id="epInsuranceCardNumber" maxlength="100" /></label>
                    <label class="ep-field"><span>نسبة التغطية %</span><input id="epInsuranceCoveragePercent" type="number" step="0.01" min="0" max="100" /></label>
                    <label class="ep-field"><span>تكلفة شهرية</span><input id="epInsuranceMonthlyCost" type="number" step="0.01" min="0" /></label>
                    <label class="ep-field"><span>نصيب الموظف</span><select id="epEmployeeShareType"><option value="Amount">مبلغ</option><option value="Percent">نسبة</option></select></label>
                    <label class="ep-field"><span>قيمة نصيب الموظف</span><input id="epEmployeeShareValue" type="number" step="0.01" min="0" /></label>
                    <label class="ep-field"><span>نصيب الشركة</span><select id="epCompanyShareType"><option value="AutoBalance">الباقي تلقائياً</option><option value="Amount">مبلغ</option><option value="Percent">نسبة</option></select></label>
                    <label class="ep-field"><span>قيمة نصيب الشركة</span><input id="epCompanyShareValue" type="number" step="0.01" min="0" /></label>
                    <label class="ep-field"><span>خصم الموظف الشهري</span><input id="epEmployeeDeductionPreview" type="number" step="0.01" min="0" readonly /></label>
                    <label class="ep-field"><span>تكلفة الشركة الشهرية</span><input id="epCompanyCostPreview" type="number" step="0.01" min="0" readonly /></label>
                    <label class="ep-field"><span>بداية الاشتراك</span><input id="epInsuranceStart" type="date" /></label>
                    <label class="ep-field"><span>نهاية الاشتراك</span><input id="epInsuranceEnd" type="date" /></label>
                    <label class="ep-switch ep-field-inline"><input id="epInsuranceMonthly" type="checkbox" checked /> خصم شهري دوري</label>
                    <div class="ep-span-all ep-inline-warning">
                        <i class="fas fa-info-circle"></i>
                        <span>لا تحذف اشتراكاً مرتبطاً بالمسير. استخدم إنهاء الاشتراك لإيقاف الخصم مع حفظ الأثر السابق.</span>
                        <button type="button" id="epEndInsuranceSubscription"><i class="fas fa-calendar-times"></i> إنهاء الاشتراك</button>
                    </div>
                    <div class="ep-span-all ep-insurance-dependent-box">
                        <div class="ep-dependent-box-head">
                            <div>
                                <strong>تابعو الموظف</strong>
                                <span>أضف الزوج أو الأبناء الفعليين المرتبطين باشتراك هذا الموظف. الخطة تحدد القواعد والحدود فقط.</span>
                            </div>
                            <b><span id="epEmployeeDependentsCount">0</span> تابع</b>
                        </div>
                        <div class="ep-inline-add ep-employee-dependent-add">
                            <input id="epEmployeeDependentName" placeholder="اسم التابع" />
                            <select id="epEmployeeDependentRelation">
                                <option value="Spouse">زوجة/زوج</option>
                                <option value="Son">ابن</option>
                                <option value="Daughter">ابنة</option>
                                <option value="Father">أب</option>
                                <option value="Mother">أم</option>
                                <option value="Other">أخرى</option>
                            </select>
                            <input id="epEmployeeDependentBirthDate" type="date" aria-label="تاريخ الميلاد" />
                            <input id="epEmployeeDependentNationalId" maxlength="50" placeholder="الرقم القومي/الإقامة" />
                            <select id="epEmployeeDependentCovered"><option value="true">مشمول</option><option value="false">غير مشمول</option></select>
                            <input id="epEmployeeDependentStart" type="date" aria-label="بداية التغطية" />
                            <input id="epEmployeeDependentEnd" type="date" aria-label="نهاية التغطية" />
                            <select id="epEmployeeDependentStatus"><option value="Active">نشط</option><option value="Stopped">موقوف</option><option value="Expired">منتهي</option></select>
                            <input id="epEmployeeDependentCoverage" type="number" min="0" max="100" step="0.01" value="100" aria-label="نسبة التغطية" />
                            <input id="epEmployeeDependentManualPremium" type="number" min="0" step="0.01" placeholder="سعر يدوي/استثناء" />
                            <input id="epEmployeeDependentExceptionReason" placeholder="سبب الاستثناء" />
                            <input id="epEmployeeDependentNotes" placeholder="ملاحظات" />
                            <button type="button" id="epAddEmployeeDependent"><i class="fas fa-plus"></i> إضافة تابع</button>
                        </div>
                        <div class="ep-employee-dependent-grid" id="epEmployeeDependentsCards"></div>
                    </div>
                    <label class="ep-field ep-span-all"><span>ملاحظات التأمين</span><textarea id="epInsuranceNotes"></textarea></label>
                    <div class="ep-span-all ep-insurance-state-bar" id="epInsuranceStateBar"></div>
                    <div class="ep-span-all ep-history-card">
                        <h3>سجل الاشتراكات</h3>
                        <div class="ep-table-shell">
                            <table class="ep-table ep-mini-table">
                                <thead><tr><th>الخطة</th><th>البداية</th><th>النهاية</th><th>خصم الموظف</th><th>تكلفة الشركة</th><th>الحالة</th></tr></thead>
                                <tbody id="epInsuranceHistory"></tbody>
                            </table>
                        </div>
                    </div>
                </section>

                <section class="ep-tab ep-form-grid" data-tab-panel="notes">
                    <ol class="ep-clean-timeline ep-span-all">
                        <li><strong>ملف الموظف</strong><span>مصدر واحد للبيانات الوظيفية والمالية.</span></li>
                        <li><strong>التأمين الطبي</strong><span>الخصم الشهري وتكلفة الشركة تظهر في المسير عند التفعيل.</span></li>
                        <li><strong>مسير الرواتب</strong><span>أي أثر مالي يراجع ويُرحل من شاشة المسير فقط.</span></li>
                    </ol>
                    <label class="ep-field ep-span-all"><span>ملاحظات</span><textarea id="epNotes"></textarea></label>
                </section>
            </div>
        </form>
    </section>

    <section class="ep-card-print-stage" id="epCardPrintStage" aria-hidden="true"></section>

    <div class="ep-message" id="epMessage" role="status" aria-live="polite"></div>
    <div class="ep-loading-shade" id="epLoadingShade" hidden>
        <div><i class="fas fa-spinner fa-spin"></i><span id="epLoadingText">جار التنفيذ...</span></div>
    </div>
</main>
