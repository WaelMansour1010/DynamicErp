@{
    var hrArea = (ViewBag.SharedHrArea as string) ?? (ViewContext.RouteData.DataTokens["area"] as string) ?? string.Empty;
    var hrReadOnly = ViewBag.SharedHrReadOnly is bool && (bool)ViewBag.SharedHrReadOnly;
    var hrAdvancedPayroll = !hrReadOnly && string.Equals(hrArea, "MainErp", StringComparison.OrdinalIgnoreCase);
    Func<string, string> hrUrl = action => Url.Action(action, "EmployeePayroll", new { area = hrArea });
}
<main class="ep-page ep-demo-workspace" data-screen="salary"
      data-read-only="@(hrReadOnly ? "true" : "false")"
      data-lookups-url="@hrUrl("Lookups")"
      data-preview-url="@hrUrl("PreviewSalaryRun")"
      data-save-url="@(hrReadOnly ? string.Empty : hrUrl("SaveSalaryRun"))"
      data-parity-url="@(hrAdvancedPayroll ? hrUrl("PayrollCompatibilityParity") : string.Empty)"
      data-explain-url="@(hrAdvancedPayroll ? hrUrl("PayrollCompatibilityExplain") : string.Empty)"
      data-replay-url="@(hrAdvancedPayroll ? hrUrl("PayrollAccountingReplay") : string.Empty)"
      data-test-posting-dry-run-url="@(hrAdvancedPayroll ? hrUrl("PayrollTestPostingDryRun") : string.Empty)"
      data-test-posting-generate-url="@(hrAdvancedPayroll ? hrUrl("GeneratePayrollTestPosting") : string.Empty)"
      data-test-posting-cleanup-url="@(hrAdvancedPayroll ? hrUrl("CleanupPayrollTestPosting") : string.Empty)">
    <header class="ep-exec-hero">
        <div>
            <span class="ep-eyebrow">مسير الرواتب</span>
            <h1>معاينة مسير الرواتب الآمنة</h1>
            <p>معاينة قابلة للتفسير توضح الرواتب، المكونات، التأمين، السلف، وحالة التوافق قبل أي أثر محاسبي فعلي.</p>
        </div>
        <div class="ep-header-actions">
            <a class="ep-link" href="@hrUrl("Employees")"><i class="fas fa-users"></i> الموظفون</a>
            <a class="ep-link" href="@hrUrl("MedicalInsuranceReports")"><i class="fas fa-chart-bar"></i> تقارير التأمين</a>
            @if (hrAdvancedPayroll)
            {
                <a class="ep-link" href="@Url.Action("Components", "LegacyHrFinance", new { area = "MainErp" })"><i class="fas fa-layer-group"></i> مكونات الرواتب</a>
            }
        </div>
    </header>

    <section class="ep-exec-dashboard" aria-label="مؤشرات المسير">
        <article><span>موظفو المعاينة</span><strong id="epRunRowsCount">0</strong><small>حسب النطاق الحالي</small></article>
        <article class="success"><span>لقطات محفوظة</span><strong id="epLegacyRowsCount">0</strong><small>صفوف تاريخية موثقة</small></article>
        <article class="warning"><span>صفوف محسوبة</span><strong id="epReconstructedRowsCount">0</strong><small>محظورة من الترحيل</small></article>
        <article><span>تقدم المطابقة</span><strong id="epParityProgress">--</strong><small>فحص تفصيلي للمكونات</small></article>
        <article class="safe"><span>السلامة المالية</span><strong>محمي</strong><small>لا يتم إنشاء قيود من المعاينة</small></article>
    </section>

    <section class="ep-safety-banner">
        <i class="fas fa-shield-alt"></i>
        <div>
            <strong>ترحيل الرواتب محمي حتى اكتمال مطابقة الحسابات.</strong>
            <span>يمكن للإدارة رؤية الحسابات والتفسيرات بوضوح، لكن Notes و DOUBLE_ENTREY_VOUCHERS و SendTopost لا يتم إنشاؤها من الصفوف المعاد بناؤها.</span>
        </div>
    </section>

    <section class="ep-wizard ep-demo-wizard">
        <div class="ep-step active">1. الفترة</div>
        <div class="ep-step active">2. النطاق</div>
        <div class="ep-step active">3. معاينة</div>
        <div class="ep-step protected">4. تفسير</div>
        <div class="ep-step locked">5. ترحيل محمي</div>
    </section>

    <section class="ep-toolbar ep-demo-toolbar">
        <label>السنة<input id="epRunYear" type="number" min="2000" max="2100" value="@DateTime.Today.Year" /></label>
        <label>الشهر<input id="epRunMonth" type="number" min="1" max="12" value="@DateTime.Today.Month" /></label>
        <label>الفرع<select id="epRunBranch"><option value="">كل الفروع</option></select></label>
        <label>الإدارة<select id="epRunDepartment"><option value="">كل الإدارات</option></select></label>
        <label>رقم موظف<input id="epRunEmployee" type="number" min="1" placeholder="اختياري" /></label>
        <button type="button" class="ep-primary" id="epPreviewRun"><i class="fas fa-calculator"></i> حساب المعاينة</button>
        <button type="button" id="epPrevMonth"><i class="fas fa-chevron-right"></i> الشهر السابق</button>
        <button type="button" id="epCurrentMonth"><i class="fas fa-calendar-day"></i> الشهر الحالي</button>
        <button type="button" id="epNextMonth">الشهر التالي <i class="fas fa-chevron-left"></i></button>
        <button type="button" id="epLoadParity"><i class="fas fa-microscope"></i> فحص التوافق</button>
        <button type="button" id="epLoadReplay"><i class="fas fa-project-diagram"></i> محاكاة القيود</button>
        <button type="button" id="epSaveRun" class="ep-protected-action"><i class="fas fa-lock"></i> حفظ محمي</button>
    </section>

    <section class="ep-operator-strip" aria-label="Operational shortcuts">
        <article><strong>Ctrl + Enter</strong><span>حساب المعاينة</span></article>
        <article><strong>Alt + P</strong><span>فحص التوافق</span></article>
        <article><strong>Alt + R</strong><span>محاكاة محاسبية للقراءة فقط</span></article>
        <article class="is-protected"><strong>محمي</strong><span>الترحيل المالي مغلق لحين اعتماد المطابقة</span></article>
    </section>

    <section class="ep-kpis ep-demo-kpis">
        <div><span>إجمالي الأساسي</span><strong id="epTotalBasic">0.00</strong></div>
        <div><span>الإضافات</span><strong id="epTotalAdditions">0.00</strong></div>
        <div><span>الخصومات</span><strong id="epTotalDeductions">0.00</strong></div>
        <div><span>تأمين الموظف</span><strong id="epTotalMedical">0.00</strong></div>
        <div><span>تكلفة الشركة</span><strong id="epTotalCompanyMedical">0.00</strong></div>
        <div><span>صافي الرواتب</span><strong id="epTotalNet">0.00</strong></div>
    </section>

    <section class="ep-payroll-grid">
        <div class="ep-table-card">
            <div class="ep-card-title">
                <div>
                    <h2>تفاصيل الموظفين</h2>
                    <p>اضغط على "شرح" لفتح مصدر المكونات وقواعد التأمين والـ proration.</p>
                </div>
                <span class="ep-status-badge pending-approval" id="epPreviewStatus">بانتظار المعاينة</span>
            </div>
            <table class="ep-table ep-payroll-table">
                <thead>
                    <tr>
                        <th>الموظف</th><th>الفرع</th><th>الحالة</th><th>الأساسي</th><th>الإضافات</th><th>السلف</th><th>خصومات</th><th>التأمين</th><th>الصافي</th><th></th>
                    </tr>
                </thead>
                <tbody id="epSalaryRows">
                    <tr><td colspan="10" class="ep-empty-row">اختر الفترة واضغط حساب المعاينة.</td></tr>
                </tbody>
            </table>
        </div>

        <aside class="ep-insight-panel">
            <h2>ملخص تنفيذي</h2>
            <div class="ep-insight-list">
                <div><strong>لقطات محفوظة</strong><span>صف تاريخي محفوظ يمكن قراءته بثقة أعلى.</span></div>
                <div><strong>صفوف محسوبة</strong><span>صف تم إعادة بنائه من مصادر التشغيل ولا يسمح له بالترحيل حتى تثبت المطابقة.</span></div>
                <div><strong>محاكاة</strong><span>محاكاة قيود في الذاكرة فقط لمقارنة الحسابات والفروع والإدارات.</span></div>
            </div>
        </aside>
    </section>

    <section class="ep-table-card">
        <div class="ep-card-title">
            <div>
                <h2>معاينة القيد الناتج</h2>
                <p>عرض توضيحي فقط. لا يتم إنشاء Notes أو DOUBLE_ENTREY_VOUCHERS من هذه المعاينة.</p>
            </div>
            <span class="ep-status-badge active">قراءة فقط</span>
        </div>
        <table class="ep-table">
            <thead><tr><th>الحساب</th><th>مدين</th><th>دائن</th><th>البيان</th><th>الموظف</th></tr></thead>
            <tbody id="epJournalRows">
                <tr><td colspan="5" class="ep-empty-row">ستظهر معاينة القيد بعد حساب المسير.</td></tr>
            </tbody>
        </table>
    </section>

    <section class="ep-table-card" id="epParityPanel" hidden>
        <div class="ep-card-title">
            <div>
                <h2>فحص المطابقة</h2>
                <p>تصنيف اختلافات المكونات والتأمين والتوزيع المحاسبي.</p>
            </div>
            <span class="ep-status-badge pending-approval">تشخيص</span>
        </div>
        <div class="ep-diagnostic-grid">
            <article><span>اختلافات المكونات</span><strong id="epParityComponentRows">0</strong></article>
            <article><span>إجمالي الاختلافات</span><strong id="epParityTotalRows">0</strong></article>
            <article><span>فرق الصافي</span><strong id="epParityNetDiff">0.00</strong></article>
        </div>
        <div id="epParityCategories" class="ep-category-list"></div>
    </section>

    <section class="ep-table-card" id="epReplayPanel" hidden>
        <div class="ep-card-title">
            <div>
                <h2>محاكاة محاسبية</h2>
                <p>محاكاة قراءة فقط لقرارات الترحيل ومقارنتها بالقيود التاريخية.</p>
            </div>
            <span class="ep-status-badge suspended">الترحيل مغلق</span>
        </div>
        <div class="ep-diagnostic-grid">
            <article><span>مدين تاريخي</span><strong id="epReplayLegacyDebit">0.00</strong></article>
            <article><span>مدين المحاكاة</span><strong id="epReplayDebit">0.00</strong></article>
            <article><span>فرق المدين</span><strong id="epReplayDebitDiff">0.00</strong></article>
            <article><span>دائن تاريخي</span><strong id="epReplayLegacyCredit">0.00</strong></article>
            <article><span>دائن المحاكاة</span><strong id="epReplayCredit">0.00</strong></article>
            <article><span>فرق الدائن</span><strong id="epReplayCreditDiff">0.00</strong></article>
        </div>
        <div id="epReplayComparisons" class="ep-category-list"></div>
    </section>

    <section class="ep-table-card">
        <div class="ep-card-title">
            <div>
                <h2>&#1605;&#1585;&#1575;&#1580;&#1593;&#1577; &#1575;&#1604;&#1605;&#1581;&#1575;&#1587;&#1576;</h2>
                <p>Dry-run shows the expected debit/credit effect without writing. Protected generate writes marked test-only Notes and DOUBLE_ENTREY_VOUCHERS only on an allowlisted database, and cleanup removes the same batch marker.</p>
            </div>
            <span class="ep-status-badge protected">Finance review</span>
        </div>
        <div class="ep-diagnostic-grid">
            <article><span>Step 1</span><strong>Dry-run</strong><small>No rows are created.</small></article>
            <article><span>Step 2</span><strong>Review totals</strong><small>Accounts, branches, projects, and departments are grouped for finance.</small></article>
            <article><span>Step 3</span><strong>Protected test write</strong><small>Requires password and confirmation phrase.</small></article>
            <article><span>Step 4</span><strong>Cleanup by batch</strong><small>Deletes only rows carrying the generated test marker.</small></article>
        </div>
    </section>

    <section class="ep-table-card ep-test-posting-panel" id="epTestPostingPanel">
        <div class="ep-card-title">
            <div>
                <h2>ترحيل اختباري محمي</h2>
                <p>ينشئ الترحيل الاختباري قيودًا محاسبية موسومة داخل قاعدة الاختبار فقط، ولا يفعّل أي ترحيل إنتاجي.</p>
            </div>
            <span class="ep-status-badge protected"><i class="fas fa-vial"></i> وضع اختبار فقط</span>
        </div>
        <div class="ep-safety-banner compact">
            <i class="fas fa-shield-alt"></i>
            <div>
                <strong>إنشاء ترحيل اختباري</strong>
                <span>ابدأ بالمعاينة، راجع إجمالي المدين والدائن والحسابات المتأثرة، ثم أنشئ القيود الموسومة بعد كلمة المرور وعبارة التأكيد.</span>
            </div>
        </div>
        <div class="ep-test-posting-grid">
            <article>
                <span>قاعدة البيانات</span>
                <strong id="epTestPostingDatabase">--</strong>
                <small id="epTestPostingAllowed">المعاينة غير محملة</small>
            </article>
            <article>
                <span>الإشعارات</span>
                <strong id="epTestPostingNotes">0</strong>
                <small>تنشأ لكل فرع في وضع الاختبار</small>
            </article>
            <article>
                <span>سطور القيود</span>
                <strong id="epTestPostingLines">0</strong>
                <small>من محرك إعادة البناء</small>
            </article>
            <article>
                <span>الاتزان</span>
                <strong id="epTestPostingBalance">0.00</strong>
                <small>المدين ناقص الدائن</small>
            </article>
        </div>
        <div class="ep-test-posting-form">
            <label>كلمة المرور<input id="epTestPostingPassword" type="password" autocomplete="off" placeholder="كلمة مرور الترحيل الاختباري" /></label>
            <label>عبارة التأكيد<input id="epTestPostingPhrase" type="text" autocomplete="off" placeholder="اكتب عبارة التأكيد" /></label>
            <label>تنظيف دفعة<input id="epTestPostingBatchId" type="text" autocomplete="off" placeholder="رقم دفعة الاختبار" /></label>
            <button type="button" id="epTestPostingDryRun"><i class="fas fa-search-dollar"></i> معاينة الترحيل الاختباري</button>
            <button type="button" class="ep-primary" id="epGenerateTestPosting"><i class="fas fa-file-invoice-dollar"></i> إنشاء الترحيل الاختباري</button>
            <button type="button" class="ep-danger-soft" id="epCleanupTestPosting"><i class="fas fa-broom"></i> تنظيف الدفعة</button>
        </div>
        <div id="epTestPostingWarnings" class="ep-test-posting-warnings"></div>
        <div class="ep-test-posting-lists">
            <div><h3>الحسابات المتأثرة</h3><div id="epTestPostingAccounts"></div></div>
            <div><h3>الفروع / المشاريع / الإدارات</h3><div id="epTestPostingDimensions"></div></div>
        </div>
    </section>

    <aside class="ep-explain-drawer" id="epExplainDrawer" hidden>
        <div class="ep-explain-head">
            <div>
                <span class="ep-eyebrow">Explainability</span>
                <h2 id="epExplainTitle">شرح المكون</h2>
            </div>
            <button type="button" id="epCloseExplain"><i class="fas fa-times"></i></button>
        </div>
        <div id="epExplainBody" class="ep-explain-body"></div>
    </aside>
    <div class="ep-drawer-backdrop" id="epExplainBackdrop" hidden></div>

    <div class="ep-message" id="epMessage"></div>
</main>
