@{
    var hrArea = (ViewBag.SharedHrArea as string) ?? (ViewContext.RouteData.DataTokens["area"] as string) ?? string.Empty;
    var hrReadOnly = ViewBag.SharedHrReadOnly is bool && (bool)ViewBag.SharedHrReadOnly;
    var salaryWriteEnabled = ViewBag.SharedHrSalaryWriteEnabled is bool && (bool)ViewBag.SharedHrSalaryWriteEnabled;
    var hrAdvancedPayroll = !hrReadOnly && string.Equals(hrArea, "MainErp", StringComparison.OrdinalIgnoreCase);
    Func<string, string> hrUrl = action => Url.Action(action, "EmployeePayroll", new { area = hrArea });
}
<main class="ep-page ep-payroll-command-center" data-screen="salary"
      data-read-only="@(hrReadOnly ? "true" : "false")"
      data-lookups-url="@hrUrl("Lookups")"
      data-preview-url="@hrUrl("PreviewSalaryRun")"
      data-save-url="@(salaryWriteEnabled ? hrUrl("SaveSalaryRun") : string.Empty)"
      data-runs-url="@hrUrl("PayrollRuns")"
      data-compare-runs-url="@hrUrl("ComparePayrollRuns")"
      data-parity-url="@(hrAdvancedPayroll ? hrUrl("PayrollCompatibilityParity") : string.Empty)"
      data-explain-url="@(hrAdvancedPayroll ? hrUrl("PayrollCompatibilityExplain") : string.Empty)"
      data-replay-url="@((hrAdvancedPayroll || salaryWriteEnabled) ? hrUrl("PayrollAccountingReplay") : string.Empty)"
      data-salary-sheet-url="@(!hrReadOnly ? hrUrl("PayrollSalarySheet") : string.Empty)"
      data-posting-dry-run-url="@(!hrReadOnly ? hrUrl("PayrollPostingDryRun") : string.Empty)"
      data-posting-url="@(salaryWriteEnabled ? hrUrl("PostPayrollJournal") : string.Empty)"
      data-test-posting-dry-run-url="@(hrAdvancedPayroll ? hrUrl("PayrollTestPostingDryRun") : string.Empty)"
      data-test-posting-generate-url="@(hrAdvancedPayroll ? hrUrl("GeneratePayrollTestPosting") : string.Empty)"
      data-test-posting-cleanup-url="@(hrAdvancedPayroll ? hrUrl("CleanupPayrollTestPosting") : string.Empty)">

    <header class="ep-payroll-hero">
        <div class="ep-payroll-title">
            <span class="ep-eyebrow">مركز إدارة مسير الرواتب</span>
            <h1>مسير الرواتب</h1>
            <p>مساحة عمل واحدة لمراجعة الموظفين، المتغيرات، التأمين، صافي الرواتب، والقيد المحاسبي قبل الاعتماد والترحيل.</p>
        </div>
        <div class="ep-payroll-state-card">
            <span>حالة المسير</span>
            <strong id="epRunPostingSummary">غير مرحل</strong>
            <small id="epRunPostingSummaryHint">سيتم إنشاء القيد عند اعتماد المسير</small>
        </div>
    </header>

    <section class="ep-payroll-filter-card" aria-label="فلاتر المسير">
        <div class="ep-filter-grid">
            <label>الشهر
                <select id="epRunMonth">
                    @for (var m = 1; m <= 12; m++)
                    {
                        <option value="@m" @(m == DateTime.Today.Month ? "selected" : "")>@m</option>
                    }
                </select>
            </label>
            <label>السنة
                <input id="epRunYear" type="number" min="2000" max="2100" value="@DateTime.Today.Year" />
            </label>
            <label>الفرع
                <select id="epRunBranch"><option value="">كل الفروع</option></select>
            </label>
            <label>الإدارة
                <select id="epRunDepartment"><option value="">كل الإدارات</option></select>
            </label>
            <label>حالة الترحيل
                <select id="epPostingStatus">
                    <option value="">الكل</option>
                    <option value="Unposted">غير مرحل</option>
                    <option value="Posted">مرحل</option>
                </select>
            </label>
            <label class="ep-filter-search">بحث موظف
                <input id="epRunEmployee" type="number" min="1" placeholder="رقم الموظف اختياري" />
            </label>
        </div>
        <div class="ep-filter-actions">
            <button type="button" id="epPrevMonth" title="الشهر السابق"><i class="fas fa-chevron-right"></i></button>
            <button type="button" id="epCurrentMonth" title="الشهر الحالي"><i class="fas fa-calendar-day"></i></button>
            <button type="button" id="epNextMonth" title="الشهر التالي"><i class="fas fa-chevron-left"></i></button>
            <button type="button" class="ep-primary" id="epPreviewRun" data-busy-text="جار حساب المعاينة..."><i class="fas fa-calculator"></i> معاينة المسير</button>
        </div>
        <details class="ep-run-snapshot-options">
            <summary>إعدادات المسير المحفوظ</summary>
            <div class="ep-filter-grid">
                <label>رقم المسير
                    <input id="epPayrollRunId" type="number" min="1" placeholder="اتركه فارغا لإنشاء مسير جديد" />
                </label>
                <label>اسم المسير
                    <input id="epRunName" type="text" placeholder="مثال: مسير فرع القاهرة - مايو" />
                </label>
                <label class="ep-filter-search">اختيار موظفين يدويا
                    <input id="epManualEmployeeIds" type="text" placeholder="أرقام الموظفين مفصولة بفواصل" />
                </label>
                <label class="ep-checkline"><input id="epExcludeAlreadyIncluded" type="checkbox" checked /> استبعاد من سبق إدراجه في نفس الشهر</label>
                <label class="ep-checkline"><input id="epOnlyUnincluded" type="checkbox" /> عرض غير المدرجين فقط</label>
                <label class="ep-checkline danger"><input id="epAllowDuplicateEmployees" type="checkbox" /> السماح بتكرار الموظف بتحذير</label>
                <label class="ep-checkline danger"><input id="epRebuildEmployees" type="checkbox" /> إعادة تكوين الموظفين من الشروط الحالية</label>
            </div>
            <p class="ep-help-text" id="epSnapshotHint">إعادة حفظ مسير برقم موجود تستخدم نفس Snapshot ولا تعيد جلب الموظفين إلا عند اختيار إعادة التكوين.</p>
        </details>
    </section>

    <section class="ep-payroll-kpis" aria-label="ملخص المسير">
        <article><i class="fas fa-users"></i><span>عدد الموظفين</span><strong id="epRunRowsCount">0</strong><small>بعد تطبيق قواعد الاستحقاق</small></article>
        <article><i class="fas fa-wallet"></i><span>إجمالي الأساسي</span><strong id="epTopTotalBasic">0.00</strong><small>رواتب أساسية</small></article>
        <article><i class="fas fa-plus-circle"></i><span>الإضافات والبدلات</span><strong id="epTopTotalAdditions">0.00</strong><small>بدلات ومتغيرات موجبة</small></article>
        <article><i class="fas fa-minus-circle"></i><span>الخصومات</span><strong id="epTopTotalDeductions">0.00</strong><small>خصومات وسلف وتأمين</small></article>
        <article class="net"><i class="fas fa-hand-holding-usd"></i><span>صافي الرواتب</span><strong id="epTopTotalNet">0.00</strong><small>المبلغ المستحق للموظفين</small></article>
        <article class="issues"><i class="fas fa-exclamation-triangle"></i><span>أخطاء المراجعة</span><strong id="epIssueCount">0</strong><small id="epIssueHint">لا توجد ملاحظات حتى الآن</small></article>
    </section>

    <section class="ep-readiness-strip" aria-label="جاهزية المسير">
        <article id="epReadinessEmployees" class="waiting">
            <span><i class="fas fa-user-check"></i> الموظفون</span>
            <strong>لم تتم المعاينة</strong>
            <small>اضغط معاينة لتحميل الموظفين المؤهلين فقط.</small>
        </article>
        <article id="epReadinessSnapshot" class="waiting">
            <span><i class="fas fa-camera-retro"></i> الحفظ</span>
            <strong>لم يحفظ بعد</strong>
            <small>بعد الحفظ يتم تثبيت Snapshot الموظفين.</small>
        </article>
        <article id="epReadinessJournal" class="waiting">
            <span><i class="fas fa-scale-balanced"></i> القيد</span>
            <strong>بانتظار المراجعة</strong>
            <small>راجع المدين والدائن قبل الترحيل.</small>
        </article>
        <article id="epReadinessIssues" class="waiting">
            <span><i class="fas fa-shield-alt"></i> الملاحظات</span>
            <strong>لا توجد بيانات</strong>
            <small>سيظهر هنا أي مانع قبل الاعتماد.</small>
        </article>
    </section>

    <section class="ep-payroll-process">
        <button type="button" class="active" data-run-tab="employees"><span>1</span><strong>الموظفون</strong><small>من داخل النطاق</small></button>
        <button type="button" data-run-tab="variables"><span>2</span><strong>المفردات والمتغيرات</strong><small>بدلات، خصومات، سلف، تأمين</small></button>
        <button type="button" data-run-tab="journal"><span>3</span><strong>المراجعة المحاسبية</strong><small>قيد متوازن ومفهوم</small></button>
        <button type="button" data-run-tab="issues"><span>4</span><strong>الأخطاء والتحذيرات</strong><small>مركز معالجة الملاحظات</small></button>
        <button type="button" data-run-tab="approval"><span>5</span><strong>الاعتماد والنشر</strong><small>حفظ، طباعة، ترحيل</small></button>
        <button type="button" data-run-tab="history"><span>6</span><strong>السجل والحركات</strong><small>تقرير المسير والتتبع</small></button>
    </section>

    <section class="ep-payroll-panel active" data-run-panel="employees">
        <div class="ep-panel-head">
            <div>
                <h2>الموظفون داخل المسير</h2>
                <p>عرض مضغوط للموظفين الذين دخلوا حساب المسير فعلياً بعد تطبيق الفرع والإدارة وحالة العمل وفترة المسير.</p>
            </div>
            <span class="ep-status-badge pending-approval" id="epPreviewStatus">بانتظار المعاينة</span>
        </div>
        <div class="ep-panel-tools">
            <div class="ep-search-box"><i class="fas fa-search"></i><input id="epSalarySearch" type="search" placeholder="ابحث باسم الموظف، الكود، الفرع، أو الإدارة" /></div>
            <span><strong id="epPostedRowsCount">0</strong> مرحل</span>
            <span><strong id="epUnpostedRowsCount">0</strong> غير مرحل</span>
        </div>
        <div class="ep-table-shell ep-payroll-table-shell">
            <table class="ep-table ep-payroll-table">
                <thead>
                    <tr>
                        <th>كود الموظف</th>
                        <th>اسم الموظف</th>
                        <th>الفرع</th>
                        <th>القسم</th>
                        <th>الأساسي</th>
                        <th>البدلات</th>
                        <th>الخصومات</th>
                        <th>التأمين</th>
                        <th>السلف</th>
                        <th>الصافي</th>
                        <th>الحالة</th>
                        <th>ملاحظات التحقق</th>
                    </tr>
                </thead>
                <tbody id="epSalaryRows">
                    <tr><td colspan="12" class="ep-empty-row">اختر الفترة ثم اضغط معاينة المسير.</td></tr>
                </tbody>
                <tfoot>
                    <tr>
                        <th colspan="4">الإجمالي</th>
                        <th id="epFooterTotalBasic">0.00</th>
                        <th id="epFooterTotalAdditions">0.00</th>
                        <th id="epFooterTotalDeductions">0.00</th>
                        <th id="epFooterTotalMedical">0.00</th>
                        <th id="epFooterTotalAdvance">0.00</th>
                        <th id="epFooterTotalNet">0.00</th>
                        <th colspan="2" id="epFooterTotalRows">0 موظف</th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </section>

    <section class="ep-payroll-panel" data-run-panel="variables" hidden>
        <div class="ep-panel-head">
            <div>
                <h2>المفردات والمتغيرات</h2>
                <p>تجميع سريع لتأثير البدلات، الخصومات، التأمين الطبي، والسلف على المسير الحالي.</p>
            </div>
        </div>
        <div class="ep-variable-grid">
            <article><span>إجمالي الأساسي</span><strong id="epTotalBasic">0.00</strong></article>
            <article><span>إجمالي البدلات</span><strong id="epTotalAdditions">0.00</strong></article>
            <article><span>إجمالي الخصومات</span><strong id="epTotalDeductions">0.00</strong></article>
            <article><span>تأمين الموظفين</span><strong id="epTotalMedical">0.00</strong></article>
            <article><span>حصة الشركة في التأمين</span><strong id="epTotalCompanyMedical">0.00</strong></article>
            <article class="net"><span>صافي الرواتب</span><strong id="epTotalNet">0.00</strong></article>
        </div>
        <div class="ep-run-detail-panel" id="epRunDetailPanel" hidden>
            <div class="ep-panel-head compact">
                <div>
                    <h3 id="epRunDetailTitle">تفاصيل الموظف</h3>
                    <p id="epRunDetailSubtitle">اختر موظفاً من تبويب الموظفين لمراجعة تأثير المتغيرات.</p>
                </div>
                <span class="ep-status-badge pending-approval" id="epRunDetailStatus">غير محدد</span>
            </div>
            <div class="ep-run-detail-grid">
                <article><span>الأساسي</span><strong id="epDetailBasic">0.00</strong></article>
                <article><span>البدلات</span><strong id="epDetailAdditions">0.00</strong></article>
                <article><span>السلف</span><strong id="epDetailAdvance">0.00</strong></article>
                <article><span>الخصومات</span><strong id="epDetailDiscounts">0.00</strong></article>
                <article><span>التأمين</span><strong id="epDetailInsurance">0.00</strong></article>
                <article class="net"><span>الصافي</span><strong id="epDetailNet">0.00</strong></article>
            </div>
        </div>
    </section>

    <section class="ep-payroll-panel" data-run-panel="journal" hidden>
        <div class="ep-panel-head">
            <div>
                <h2>معاينة القيد قبل الترحيل</h2>
                <p>القيد يعرض رقم الحساب واسم الحساب والبيان والمدين والدائن بصورة قابلة للمراجعة المالية.</p>
            </div>
            <span class="ep-status-badge pending-approval" id="epJournalBalanceStatus">لم يتم الترحيل بعد</span>
        </div>
        <div class="ep-journal-summary">
            <article><span>إجمالي المدين</span><strong id="epJournalDebitTotal">0.00</strong></article>
            <article><span>إجمالي الدائن</span><strong id="epJournalCreditTotal">0.00</strong></article>
            <article><span>الفرق</span><strong id="epJournalBalanceDiff">0.00</strong></article>
        </div>
        <div class="ep-table-shell">
            <table class="ep-table ep-journal-table">
                <thead>
                    <tr>
                        <th>رقم الحساب</th>
                        <th>اسم الحساب</th>
                        <th>البيان</th>
                        <th>رقم المسير</th>
                        <th>مدين</th>
                        <th>دائن</th>
                    </tr>
                </thead>
                <tbody id="epJournalRows">
                    <tr><td colspan="6" class="ep-empty-row">ستظهر معاينة القيد بعد حساب المسير.</td></tr>
                </tbody>
            </table>
        </div>
    </section>

    <section class="ep-payroll-panel" data-run-panel="issues" hidden>
        <div class="ep-panel-head">
            <div>
                <h2>مركز ملاحظات المسير</h2>
                <p>مكان واحد لمراجعة الحسابات الناقصة، القيود غير المتوازنة، الموظفين المستبعدين، أو أي إعداد غير مكتمل.</p>
            </div>
            <span class="ep-status-badge active" id="epIssuesStatus">لا توجد ملاحظات</span>
        </div>
        <div id="epPayrollIssues" class="ep-payroll-issues">
            <div class="ep-empty-row">لا توجد ملاحظات حتى الآن.</div>
        </div>
    </section>

    <section class="ep-payroll-panel" data-run-panel="approval" hidden>
        <div class="ep-panel-head">
            <div>
                <h2>الاعتماد والنشر</h2>
                <p>راجع المعاينة أولاً، ثم احفظ المسير أو افحص القيد أو رحله حسب صلاحياتك.</p>
            </div>
        </div>
        <div class="ep-approval-grid">
            <article>
                <i class="fas fa-calculator"></i>
                <h3>1. معاينة</h3>
                <p>تحميل الموظفين وحساب الإجماليات قبل أي حفظ أو ترحيل.</p>
            </article>
            <article>
                <i class="fas fa-balance-scale"></i>
                <h3>2. مراجعة محاسبية</h3>
                <p>فحص الحسابات والتأكد من توازن القيد قبل الاعتماد.</p>
            </article>
            <article>
                <i class="fas fa-file-signature"></i>
                <h3>3. اعتماد وترحيل</h3>
                <p>لا يسمح بالترحيل عند وجود حساب ناقص أو فرق في المدين والدائن.</p>
            </article>
        </div>
    </section>

    <section class="ep-payroll-panel" data-run-panel="history" hidden>
        <div class="ep-panel-head">
            <div>
                <h2 id="epSheetTitle">مسير الرواتب</h2>
                <p id="epSheetPeriod">اختر الفترة ثم اضغط معاينة أو طباعة.</p>
            </div>
            <span class="ep-status-badge active" id="epSheetJournalStatus">جاهز للطباعة</span>
        </div>
        <div class="ep-sheet-meta">
            <span id="epSheetPeriodRange">الفترة: --</span>
            <span id="epSheetGeneratedAt">وقت الإنشاء: --</span>
            <span id="epSheetPostingFilter">حالة الترحيل: الكل</span>
        </div>
        <div class="ep-run-compare-box">
            <label>المسير الأول <input id="epCompareRunA" type="number" min="1" /></label>
            <label>المسير الثاني <input id="epCompareRunB" type="number" min="1" /></label>
            <button type="button" id="epCompareRuns"><i class="fas fa-code-compare"></i> مقارنة مسيرين</button>
            <div class="ep-compare-summary" aria-label="ملخص مقارنة مسيرين">
                <article><span>المشتركون</span><strong id="epCompareCommon">--</strong></article>
                <article><span>في الأول فقط</span><strong id="epCompareFirstOnly">--</strong></article>
                <article><span>في الثاني فقط</span><strong id="epCompareSecondOnly">--</strong></article>
                <article><span>فرق الصافي</span><strong id="epCompareNetDiff">--</strong></article>
                <article><span>فرق القيد</span><strong id="epCompareJournalDiff">--</strong></article>
            </div>
            <div id="epCompareResult" class="ep-help-text">اختر رقمين لمسيرين محفوظين لعرض فروق الموظفين والمبالغ والقيد.</div>
        </div>
        <div class="ep-table-shell">
            <table class="ep-table ep-sheet-table">
                <thead><tr><th>الموظف</th><th>الفرع / الإدارة</th><th>الأساسي</th><th>الإضافات</th><th>السلف</th><th>الخصومات</th><th>التأمين</th><th>الصافي</th><th>حالة الترحيل</th></tr></thead>
                <tbody id="epSalarySheetRows"><tr><td colspan="9" class="ep-empty-row">لم يتم توليد التقرير بعد.</td></tr></tbody>
                <tfoot><tr><th colspan="2">الإجمالي</th><th id="epSheetTotalBasic">0.00</th><th id="epSheetTotalAllowances">0.00</th><th id="epSheetTotalAdvances">0.00</th><th id="epSheetTotalDeductions">0.00</th><th id="epSheetTotalInsurance">0.00</th><th id="epSheetTotalNet">0.00</th><th id="epSheetTotalRows">0</th></tr></tfoot>
            </table>
        </div>
        <div class="ep-sheet-journal-totals">
            <span>إجمالي المدين: <strong id="epSheetJournalDebit">0.00</strong></span>
            <span>إجمالي الدائن: <strong id="epSheetJournalCredit">0.00</strong></span>
            <span>الفرق: <strong id="epSheetJournalBalance">0.00</strong></span>
        </div>
    </section>

    <section class="ep-table-card" id="epParityPanel" hidden></section>
    <section class="ep-table-card" id="epReplayPanel" hidden></section>
    <section class="ep-table-card ep-test-posting-panel" id="epTestPostingPanel" hidden>
        <div id="epTestPostingWarnings"></div>
        <div id="epTestPostingAccounts"></div>
        <div id="epTestPostingDimensions"></div>
        <span id="epTestPostingDatabase"></span>
        <span id="epTestPostingAllowed"></span>
        <span id="epTestPostingNotes"></span>
        <span id="epTestPostingLines"></span>
        <span id="epTestPostingBalance"></span>
        <input id="epTestPostingPassword" type="password" />
        <input id="epTestPostingPhrase" type="text" />
        <input id="epTestPostingBatchId" type="text" />
        <button type="button" id="epTestPostingDryRun"></button>
        <button type="button" id="epGenerateTestPosting"></button>
        <button type="button" id="epCleanupTestPosting"></button>
    </section>

    <div class="ep-sticky-payroll-actions" aria-label="أوامر المسير">
        <button type="button" class="ep-primary" id="epPreviewRunSticky" data-busy-text="جار حساب المعاينة..."><i class="fas fa-calculator"></i> معاينة</button>
        @if (salaryWriteEnabled)
        {
            <button type="button" id="epSaveRun" data-busy-text="جار إنشاء المسير..."><i class="fas fa-save"></i> إنشاء المسير</button>
            <button type="button" id="epPostingDryRun" data-busy-text="جار فحص القيد..."><i class="fas fa-balance-scale"></i> مراجعة القيد</button>
            <button type="button" class="ep-success" id="epPostPayroll" data-busy-text="جار الترحيل..."><i class="fas fa-file-invoice-dollar"></i> ترحيل القيد</button>
        }
        <button type="button" id="epPrintRun"><i class="fas fa-print"></i> طباعة</button>
        <button type="button" id="epExportRun"><i class="fas fa-file-export"></i> تصدير</button>
        <button type="button" id="epLoadParity" hidden></button>
        <button type="button" id="epLoadReplay" hidden></button>
    </div>

    <aside class="ep-explain-drawer" id="epExplainDrawer" hidden>
        <div class="ep-explain-head">
            <div><span class="ep-eyebrow">شرح</span><h2 id="epExplainTitle">شرح البند</h2></div>
