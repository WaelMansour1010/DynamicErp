@model MyERP.Common.EnterpriseHr.LegacyHrFinancePageViewModel
@using System.Linq
@using System.Globalization
@{
    var advanceRows = Model.Advances ?? Enumerable.Empty<MyERP.Common.EnterpriseHr.EmployeeAdvanceViewModel>();
    var advanceCount = advanceRows.Count();
    var advanceTotal = advanceRows.Sum(x => x.AdvanceValue);
    var advancePaid = advanceRows.Sum(x => x.PaidAmount);
    var advanceRemaining = advanceRows.Sum(x => x.RemainingAmount);
    var advanceApproved = advanceRows.Count(x => x.Approved && !x.Rejected);
    var advanceDisbursed = advanceRows.Count(x => x.IsDisbursed);
    var advanceLocked = advanceRows.Count(x => !x.CanEdit || x.IsDisbursed || x.PaidPartsCount > 0);
    var vacationRows = Model.Vacations ?? Enumerable.Empty<MyERP.Common.EnterpriseHr.EmployeeVacationRequestViewModel>();
    var vacationCount = vacationRows.Count();
    var vacationDays = vacationRows.Sum(x => x.NoVacation);
    var vacationPending = vacationRows.Count(x => x.Submitted && !x.ManagerApproved && !x.Rejected);
    var vacationManagerApproved = vacationRows.Count(x => x.ManagerApproved && !x.HrApproved && !x.Rejected);
    var vacationHrApproved = vacationRows.Count(x => x.HrApproved && !x.Rejected);
    var vacationRejected = vacationRows.Count(x => x.Rejected);
    var vacationLocked = vacationRows.Count(x => !x.CanEdit);
    var changedRows = Model.ChangedComponents ?? Enumerable.Empty<MyERP.Common.EnterpriseHr.ChangedComponentEntryViewModel>();
    var changedCount = changedRows.Count();
    var changedAdditions = changedRows.Where(x => x.AddOrDiscount).Sum(x => x.Value);
    var changedDeductions = changedRows.Where(x => !x.AddOrDiscount).Sum(x => x.Value);
    var changedLocked = changedRows.Count(x => x.PayrollUsed || !x.CanEdit);
    var changedOpen = changedRows.Count(x => x.CanEdit && !x.PayrollUsed);
    var changedEmployeeGroups = changedRows
        .GroupBy(x => new { x.EmployeeId, x.EmployeeCode, x.EmployeeName })
        .Select(g => new { g.Key.EmployeeCode, g.Key.EmployeeName, Total = g.Sum(x => x.AddOrDiscount ? x.Value : -x.Value), Count = g.Count() })
        .OrderByDescending(x => Math.Abs(x.Total))
        .Take(6)
        .ToList();
    var moduleTitle = Model.Title;
    var moduleSubtitle = "مساحة عمل موحدة لشؤون الموظفين تعمل بنفس منطق العمل داخل POS و MainERP مع الحفاظ على سياق النظام المفتوح.";
    var moduleTone = "info";
    var nextAction = "راجع النتائج وحدد الإجراء المناسب حسب الصلاحيات وحالة السجل.";
    var blockedHint = "أي إجراء غير متاح يظهر بسبب الصلاحية أو حالة الاعتماد أو الارتباط بالرواتب/المستندات.";
    var workflowSteps = new[] { "بحث ومراجعة", "تسجيل", "اعتماد", "متابعة" };
    if (Model.ModuleKey == "advances")
    {
        moduleSubtitle = "إدارة طلب السلفة من التسجيل والاعتماد وحتى إنشاء السلفة الفعلية ومتابعة الأقساط بدون إنشاء قيود مباشرة من شاشة HR.";
        moduleTone = advanceLocked > 0 ? "warning" : "success";
        nextAction = Model.Permissions.CanAdd ? "يمكنك إنشاء طلب سلفة جديد أو متابعة الطلبات المفتوحة من الجدول." : "راجع طلبات السلف الحالية حسب الصلاحيات المتاحة.";
        workflowSteps = new[] { "طلب السلفة", "الاعتماد", "صرف السلفة", "الأقساط والرواتب" };
    }
    else if (Model.ModuleKey == "vacations")
    {
        moduleSubtitle = "دورة الإجازة من الطلب وحساب الرصيد والاعتماد إلى مستحقات الإجازة ومباشرة العمل، بدون ترحيل رواتب أو حسابات من هذه الشاشة.";
        moduleTone = vacationPending > 0 || vacationRejected > 0 ? "warning" : "success";
        nextAction = Model.Permissions.CanAdd ? "ابدأ بطلب إجازة جديد أو احسب رصيد الموظف قبل الاعتماد." : "راجع طلبات الإجازة وحالات الاعتماد والارتباط بالمستحقات.";
        workflowSteps = new[] { "طلب الإجازة", "الرصيد", "الاعتماد", "المستحقات", "مباشرة العمل" };
    }
    else if (Model.ModuleKey == "changed-components")
    {
        moduleSubtitle = "تسجيل المفردات المتغيرة التي يقرأها مسير الرواتب مع توضيح المفتوح والمقفل بسبب استخدامه في مسير.";
        moduleTone = changedLocked > 0 ? "warning" : "success";
        nextAction = Model.Permissions.CanAdd ? "سجل مفردة متغيرة أو استخدم الإدخال الجماعي مع مراجعة القيم قبل الحفظ." : "راجع المفردات المتغيرة وحالة استخدامها في المسير.";
        workflowSteps = new[] { "اختيار الموظف", "اختيار المفردة", "حفظ القيمة", "قفل بالمسير" };
    }
    else if (Model.ModuleKey == "components" || Model.ModuleKey == "payroll-items")
    {
        moduleSubtitle = "كتالوج مفردات الرواتب والبدلات والخصومات المستخدمة في دورة المسير.";
        workflowSteps = new[] { "تعريف المفردة", "تصنيف التأثير", "مراجعة الحساب", "ظهور بالمسير" };
    }
    else if (Model.ModuleKey == "leave")
    {
        moduleSubtitle = "متابعة أرصدة الإجازات والمستحقات المرتبطة بها من نقطة مركزية.";
        workflowSteps = new[] { "الرصيد", "الطلبات", "المستحقات", "المباشرة" };
    }
    else if (Model.ModuleKey == "absences")
    {
        moduleSubtitle = "متابعة الغياب والتأثيرات المرتبطة بالموظف قبل وصولها إلى دورة الرواتب.";
        workflowSteps = new[] { "تسجيل", "مراجعة", "تأثير الراتب", "متابعة" };
    }
    else if (Model.ModuleKey == "allowances")
    {
        moduleSubtitle = "إدارة البدلات وعناصر الاستحقاق المتاحة للموظفين ضمن منظومة الرواتب.";
        workflowSteps = new[] { "تعريف", "ربط", "مراجعة", "تفعيل" };
    }
    else if (Model.ModuleKey == "end-service")
    {
        moduleSubtitle = "متابعة تسويات نهاية الخدمة ومؤشرات الإغلاق بدون فتح أي مسار محاسبي غير معتمد.";
        workflowSteps = new[] { "بيانات الموظف", "المستحقات", "الخصومات", "التسوية" };
    }
}

<section class="lhf-page lhf-workspace lhf-module-@Model.ModuleKey" data-lhf-page="@Model.ModuleKey"
         data-host-context="@Model.HostContext"
         data-screen-key="@Model.ScreenKey"
         data-component-details-url="@Model.ComponentDetailsUrl"
         data-save-component-url="@Model.SaveComponentUrl"
         data-changed-component-details-url="@Model.ChangedComponentDetailsUrl"
         data-save-changed-component-url="@Model.SaveChangedComponentUrl"
         data-delete-changed-component-url="@Model.DeleteChangedComponentUrl"
         data-preview-changed-component-bulk-url="@Model.PreviewChangedComponentBulkUrl"
         data-save-changed-component-bulk-url="@Model.SaveChangedComponentBulkUrl"
         data-advance-details-url="@Model.AdvanceDetailsUrl"
         data-save-advance-url="@Model.SaveAdvanceUrl"
         data-delete-advance-url="@Model.DeleteAdvanceUrl"
         data-disburse-advance-url="@Model.DisburseAdvanceUrl"
         data-send-advance-approval-url="@Model.SendAdvanceForApprovalUrl"
         data-approve-advance-url="@Model.ApproveAdvanceUrl"
         data-cancel-advance-url="@Model.CancelAdvanceUrl"
         data-advance-accounting-boundary-url="@Model.AdvanceAccountingBoundaryUrl"
         data-vacation-balance-url="@Model.VacationBalanceUrl"
         data-vacation-details-url="@Model.VacationDetailsUrl"
         data-save-vacation-url="@Model.SaveVacationUrl"
         data-manager-approve-vacation-url="@Model.ManagerApproveVacationUrl"
         data-hr-approve-vacation-url="@Model.HrApproveVacationUrl"
         data-reject-vacation-url="@Model.RejectVacationUrl"
         data-cancel-vacation-url="@Model.CancelVacationUrl"
         data-delete-vacation-url="@Model.DeleteVacationUrl"
         data-create-vacation-entitlement-url="@Model.CreateVacationEntitlementUrl"
         data-delete-vacation-entitlement-url="@Model.DeleteVacationEntitlementUrl"
         data-save-vacation-return-url="@Model.SaveVacationReturnToWorkUrl"
         data-delete-vacation-return-url="@Model.DeleteVacationReturnToWorkUrl"
         data-employee-lookup-url="@Model.EmployeeLookupUrl">
    @Html.AntiForgeryToken()
    <header class="lhf-hero lhf-workspace-header">
        <div class="lhf-title-block">
            <span class="lhf-host-chip">@Model.HostContext</span>
            <span class="lhf-source-chip">@Model.SourceSystem</span>
            <h2>@moduleTitle</h2>
            <p>@moduleSubtitle</p>
            <div class="lhf-command-card @moduleTone">
                <span>الإجراء التالي</span>
                <strong>@nextAction</strong>
                <small>@blockedHint</small>
            </div>
            <nav class="lhf-workflow-strip" aria-label="دورة العمل">
                @for (var i = 0; i < workflowSteps.Length; i++)
                {
                    <span class="lhf-workflow-step @(i == 0 ? "active" : "")"><b>@(i + 1)</b>@workflowSteps[i]</span>
                }
            </nav>
            <p>شاشة مشتركة بين POS و MainERP ضمن شؤون الموظفين، مع الحفاظ على سياق النظام المفتوح.</p>
        </div>
        <form method="get" class="lhf-search @(Model.ModuleKey == "advances" || Model.ModuleKey == "vacations" ? "lhf-search-wide" : Model.ModuleKey == "changed-components" ? "lhf-search-changed lhf-filter-panel" : "") @(Model.ModuleKey == "vacations" ? "lhf-search-vacations lhf-filter-panel" : "")">
            <input type="search" name="searchText" value="@Model.SearchText" placeholder="بحث بالكود أو الموظف أو البيان" />
            <select name="employeeStatus" title="حالة الموظف">
                <option value="active" @(Model.EmployeeStatus == "active" ? "selected" : "")>الموظفون النشطون</option>
                <option value="stopped" @(Model.EmployeeStatus == "stopped" ? "selected" : "")>الموظفون الموقوفون</option>
                <option value="all" @(Model.EmployeeStatus == "all" ? "selected" : "")>كل الموظفين</option>
            </select>
            @if (Model.ModuleKey == "advances")
            {
                <select name="employeeId" title="الموظف">
                    <option value="">كل الموظفين</option>
                    @foreach (var employee in Model.Employees)
                    {
                        <option value="@employee.Id" @(Model.EmployeeId == employee.Id ? "selected" : "")>@employee.Code - @employee.Name</option>
                    }
                </select>
                <select name="branchId" title="الفرع">
                    <option value="">كل الفروع</option>
                    @foreach (var branch in Model.Branches)
                    {
                        <option value="@branch.Id" @(Model.BranchId == branch.Id ? "selected" : "")>@branch.Name</option>
                    }
                </select>
                <select name="departmentId" title="الإدارة">
                    <option value="">كل الإدارات</option>
                    @foreach (var department in Model.Departments)
                    {
                        <option value="@department.Id" @(Model.DepartmentId == department.Id ? "selected" : "")>@department.Name</option>
                    }
                </select>
                <input type="date" name="dateFrom" value="@Model.DateFrom" title="من تاريخ" />
                <input type="date" name="dateTo" value="@Model.DateTo" title="إلى تاريخ" />
                <select name="advanceStatus" title="حالة السلفة">
                    <option value="all" @(Model.AdvanceStatus == "all" ? "selected" : "")>كل الحالات</option>
                    <option value="draft" @(Model.AdvanceStatus == "draft" ? "selected" : "")>مسودة</option>
                    <option value="pending" @(Model.AdvanceStatus == "pending" ? "selected" : "")>قيد الاعتماد</option>
                    <option value="approved" @(Model.AdvanceStatus == "approved" ? "selected" : "")>معتمدة</option>
                    <option value="posted" @(Model.AdvanceStatus == "posted" ? "selected" : "")>مرسلة/مرحلة</option>
                    <option value="accounting-approved" @(Model.AdvanceStatus == "accounting-approved" ? "selected" : "")>معتمدة محاسبياً</option>
                    <option value="rejected" @(Model.AdvanceStatus == "rejected" ? "selected" : "")>مرفوضة</option>
                </select>
            }
            @if (Model.ModuleKey == "vacations")
            {
                <select name="branchId" title="الفرع">
                    <option value="">كل الفروع</option>
                    @foreach (var branch in Model.Branches)
                    {
                        <option value="@branch.Id" @(Model.BranchId == branch.Id ? "selected" : "")>@branch.Name</option>
                    }
                </select>
                <select name="departmentId" title="الإدارة">
                    <option value="">كل الإدارات</option>
                    @foreach (var department in Model.Departments)
                    {
                        <option value="@department.Id" @(Model.DepartmentId == department.Id ? "selected" : "")>@department.Name</option>
                    }
                </select>
                <select name="employeeId" title="الموظف">
                    <option value="">كل الموظفين</option>
                    @foreach (var employee in Model.Employees)
                    {
                        <option value="@employee.Id" @(Model.EmployeeId == employee.Id ? "selected" : "")>@employee.Code - @employee.Name</option>
                    }
                </select>
                <input type="date" name="dateFrom" value="@Model.DateFrom" title="من تاريخ بداية الإجازة" />
                <input type="date" name="dateTo" value="@Model.DateTo" title="إلى تاريخ بداية الإجازة" />
                <select name="vacationType" title="نوع الإجازة">
                    <option value="">كل أنواع الإجازات</option>
                    @foreach (var type in Model.VacationTypes)
                    {
                        <option value="@type.Value" @(Model.VacationType == type.Value ? "selected" : "")>@type.Text</option>
                    }
                </select>
                <select name="status" title="حالة الطلب">
                    <option value="all" @(Model.VacationStatus == "all" ? "selected" : "")>كل الحالات</option>
                    <option value="draft" @(Model.VacationStatus == "draft" ? "selected" : "")>مسودة</option>
                    <option value="pending-manager" @(Model.VacationStatus == "pending-manager" ? "selected" : "")>قيد مراجعة المدير</option>
                    <option value="pending-hr" @(Model.VacationStatus == "pending-hr" ? "selected" : "")>قيد اعتماد الموارد البشرية</option>
                    <option value="approved" @(Model.VacationStatus == "approved" ? "selected" : "")>معتمدة</option>
                    <option value="rejected" @(Model.VacationStatus == "rejected" ? "selected" : "")>مرفوضة / ملغاة</option>
                    <option value="paid" @(Model.VacationStatus == "paid" ? "selected" : "")>مرتبطة بمستحقات</option>
                </select>
            }
            @if (Model.ModuleKey == "changed-components")
            {
                <input type="search" class="lhf-select-search" data-filter-select="lhfFilterEmployeeId" placeholder="تصفية الموظفين..." autocomplete="off" />
                <select id="lhfFilterEmployeeId" name="employeeId" title="الموظف">
                    <option value="">كل الموظفين</option>
                    @foreach (var employee in Model.Employees)
                    {
                        <option value="@employee.Id" @(Model.EmployeeId == employee.Id ? "selected" : "")>@employee.Code - @employee.Name</option>
                    }
                </select>
                <input type="search" class="lhf-select-search" data-filter-select="lhfFilterComponentId" placeholder="تصفية المفردات..." autocomplete="off" />
                <select id="lhfFilterComponentId" name="componentId" title="المفردة">
                    <option value="">كل المفردات</option>
                    @foreach (var component in Model.Components)
                    {
                        <option value="@component.Id" @(Model.ComponentId == component.Id ? "selected" : "")>@component.Name (@(component.AddOrDiscount ? "إضافة" : "خصم"))</option>
                    }
                </select>
                <select name="branchId" title="الفرع">
                    <option value="">كل الفروع</option>
                    @foreach (var branch in Model.Branches)
                    {
                        <option value="@branch.Id" @(Model.BranchId == branch.Id ? "selected" : "")>@branch.Name</option>
                    }
                </select>
                <select name="departmentId" title="الإدارة">
                    <option value="">كل الإدارات</option>
                    @foreach (var department in Model.Departments)
                    {
                        <option value="@department.Id" @(Model.DepartmentId == department.Id ? "selected" : "")>@department.Name</option>
                    }
                </select>
                <input type="date" name="dateFrom" value="@Model.DateFrom" title="من تاريخ" />
                <input type="date" name="dateTo" value="@Model.DateTo" title="إلى تاريخ" />
                <input type="number" name="year" min="1900" max="2100" value="@(Model.YearFilter.HasValue ? Model.YearFilter.Value.ToString() : "")" placeholder="السنة" title="السنة الفعلية" />
                <select name="month" title="الشهر الفعلي">
                    <option value="">كل الشهور</option>
                    @for (var m = 1; m <= 12; m++)
                    {
                        <option value="@m" @(Model.MonthFilter == m ? "selected" : "")>@m.ToString("00")</option>
                    }
                </select>
                <select name="componentType" title="نوع المفردة">
                    <option value="all" @(Model.ComponentType == "all" ? "selected" : "")>إضافة وخصم</option>
                    <option value="addition" @(Model.ComponentType == "addition" ? "selected" : "")>إضافات فقط</option>
                    <option value="deduction" @(Model.ComponentType == "deduction" ? "selected" : "")>خصومات فقط</option>
                </select>
                <select name="status" title="حالة المسير">
                    <option value="all" @(Model.StatusFilter == "all" ? "selected" : "")>كل الحالات</option>
                    <option value="open" @(Model.StatusFilter == "open" ? "selected" : "")>مفتوح</option>
                    <option value="used" @(Model.StatusFilter == "used" ? "selected" : "")>مستخدم في المسير</option>
                </select>
            }
            <button type="submit"><i class="fas fa-search"></i><span>بحث</span></button>
        </form>
    </header>

    @if (!string.IsNullOrWhiteSpace(Model.Warning))
    {
        <div class="lhf-warning"><i class="fas fa-exclamation-triangle"></i><span>@Model.Warning</span></div>
    }

    @if (Model.ModuleKey != "changed-components")
    {
        <div class="lhf-metrics">
            @foreach (var metric in Model.Metrics)
            {
                <article><span>@metric.Label</span><strong>@metric.Value</strong><small>@metric.Hint</small></article>
            }
        </div>
    }

    @if (Model.ModuleKey == "changed-components")
    {
        <section class="lhf-changed-snapshot" aria-label="ملخص المفردات المتغيرة">
            <article class="addition"><span>إجمالي الإضافات</span><strong>@changedAdditions.ToString("N2")</strong><small>@changedRows.Count(x => x.AddOrDiscount).ToString("N0") حركة إضافة</small></article>
            <article class="deduction"><span>إجمالي الخصومات</span><strong>@changedDeductions.ToString("N2")</strong><small>@changedRows.Count(x => !x.AddOrDiscount).ToString("N0") حركة خصم</small></article>
            <article class="net"><span>صافي التأثير</span><strong>@((changedAdditions - changedDeductions).ToString("N2"))</strong><small>الإضافات ناقص الخصومات</small></article>
            <article><span>الموظفون المتأثرون</span><strong>@changedRows.Select(x => x.EmployeeId).Distinct().Count().ToString("N0")</strong><small>@changedCount.ToString("N0") سطر حسب الفلاتر</small></article>
        </section>

        <section class="lhf-changed-lock-guide @(changedLocked > 0 ? "has-locks" : "is-clear")">
            <div>
                <strong>@(changedLocked > 0 ? "توجد مفردات مقفلة بالمسير" : "كل السطور المعروضة قابلة للمراجعة")</strong>
                <span>@(changedLocked > 0 ? "السطر المقفل تم استخدامه في مسير رواتب أو سند راتب، لذلك يظهر للقراءة فقط لحماية نتيجة payroll." : "أي قفل سيظهر هنا بوضوح عند ارتباط السطر بمسير رواتب أو سند راتب.")</span>
            </div>
            <small>@changedLocked.ToString("N0") مقفل / @changedOpen.ToString("N0") مفتوح</small>
        </section>

        if (changedEmployeeGroups.Any())
        {
            <section class="lhf-panel lhf-employee-totals">
                <header><h3>إجماليات الموظفين</h3><span>أعلى الموظفين أثراً ضمن نتيجة البحث الحالية.</span></header>
                <div>
                    @foreach (var item in changedEmployeeGroups)
                    {
                        <article class="@(item.Total >= 0 ? "addition" : "deduction")">
                            <strong>@item.EmployeeName</strong>
                            <small>@item.EmployeeCode - @item.Count.ToString("N0") سطر</small>
                            <span>@item.Total.ToString("N2")</span>
                        </article>
                    }
                </div>
            </section>
        }
    }

    @if (Model.ModuleKey == "advances")
    {
        <div class="lhf-advance-dashboard" aria-label="ملخص السلف">
            <article>
                <span>عدد الطلبات</span>
                <strong>@advanceCount.ToString("N0")</strong>
                <small>حسب الفلاتر الحالية</small>
            </article>
            <article>
                <span>إجمالي السلف</span>
                <strong>@advanceTotal.ToString("N2")</strong>
                <small>قيمة الطلبات المعروضة</small>
            </article>
            <article>
                <span>المسدد</span>
                <strong>@advancePaid.ToString("N2")</strong>
                <small>أقساط تم ترحيلها أو سدادها</small>
            </article>
            <article>
                <span>المتبقي</span>
                <strong>@advanceRemaining.ToString("N2")</strong>
                <small>رصيد مفتوح للمتابعة</small>
            </article>
            <article>
                <span>الاعتماد والصرف</span>
                <strong>@advanceApproved / @advanceDisbursed</strong>
                <small>معتمدة / مصروفة</small>
            </article>
            <article class="@(advanceLocked > 0 ? "has-warning" : "")">
                <span>طلبات مقفلة</span>
                <strong>@advanceLocked.ToString("N0")</strong>
                <small>لا تعدل إلا عبر دورة الإلغاء الآمن</small>
            </article>
        </div>

        <section class="lhf-panel lhf-advances-panel">
            <header>
                <div>
                    <h3>طلبات السلف</h3>
                    <span>هذه الشاشة تحفظ طلب السلفة وأقساطها، ويمكن منها إنشاء السلفة الفعلية بعد الاعتماد. لا يتم إنشاء قيد محاسبي تلقائياً من هذا المسار لأن منطق VB6 الرئيسي لا يرحل قيداً مؤكداً هنا.</span>
                </div>
                <div class="lhf-panel-tools">
                    <input type="search" id="lhfAdvanceTableSearch" placeholder="بحث سريع داخل النتائج..." autocomplete="off" />
                    @if (Model.Permissions.CanAdd)
                    {
                        <button type="button" class="lhf-primary" data-new-advance><i class="fas fa-plus"></i><span>طلب سلفة جديد</span></button>
                    }
                </div>
            </header>
            <div class="lhf-table-wrap">
                <table class="lhf-table lhf-advance-table">
                    <thead>
                        <tr>
                            <th>رقم</th>
                            <th>الموظف</th>
                            <th>الفرع / الإدارة</th>
                            <th>التاريخ</th>
                            <th>القيمة</th>
                            <th>الأقساط</th>
                            <th>المتبقي</th>
                            <th>الحالة</th>
                            <th>ملاحظات</th>
                            <th>إجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Advances)
                        {
                            var estimatedPart = row.PaymentCounts > 0 ? row.AdvanceValue / row.PaymentCounts : 0;
                            var statusClass = row.Rejected ? "danger" : row.AccountingApproved || row.IsDisbursed || row.Approved ? "success" : row.Submitted ? "warning" : "info";
                            <tr data-advance-id="@row.Id" data-advance-search="@((row.Id + " " + row.EmployeeCode + " " + row.EmployeeName + " " + row.BranchName + " " + row.DepartmentName + " " + row.StatusText + " " + row.Reason).ToLowerInvariant())" class="@(row.CanEdit ? "" : "lhf-row-locked")">
                                <td><code>@row.Id</code></td>
                                <td>
                                    <strong>@row.EmployeeName</strong>
                                    <small>@row.EmployeeCode</small>
                                    <small>الراتب الأساسي: @row.BasicSalary.ToString("N2")</small>
                                </td>
                                <td>
                                    <strong>@row.BranchName</strong>
                                    <small>@row.DepartmentName</small>
                                    <small>رصيد سابق: @row.OldAdvance.ToString("N2")</small>
                                </td>
                                <td>@row.AdvanceDate</td>
                                <td class="lhf-num">@row.AdvanceValue.ToString("N2")</td>
                                <td>
                                    <div class="lhf-installment-summary">
                                        <strong>@row.PaymentCounts قسط</strong>
                                        <small>قيمة تقريبية: @estimatedPart.ToString("N2")</small>
                                        <small>أول قسط: @row.FirstMonthPayment / @row.FirstYearPayment</small>
                                        <span class="lhf-installment-chip">@row.PaidPartsCount / @row.PartsCount مسدد</span>
                                    </div>
                                </td>
                                <td class="lhf-num">@row.RemainingAmount.ToString("N2")</td>
                                <td>
                                    <div class="lhf-status-stack">
                                        <span class="lhf-badge @statusClass">@row.StatusText</span>
                                        @if (row.IsDisbursed) { <span class="lhf-badge success">مصروفة: @row.ActualAdvanceId</span> }
                                        @if (row.PaidPartsCount > 0) { <span class="lhf-badge warning">بها أقساط مسددة</span> }
                                        @if (!row.CanEdit) { <span class="lhf-badge locked">مقفلة</span> }
                                    </div>
                                </td>
                                <td>
                                    <span>@row.Reason</span>
                                    @if (!string.IsNullOrWhiteSpace(row.LockReason))
                                    {
                                        <small class="lhf-lock-note">@row.LockReason</small>
                                    }
                                </td>
                                <td class="lhf-actions">
                                    @if (Model.Permissions.CanEdit && row.CanEdit)
                                    {
                                        <button type="button" data-edit-advance="@row.Id">تعديل</button>
                                    }
                                    @if (Model.Permissions.CanDelete && row.CanDelete)
                                    {
                                        <button type="button" data-delete-advance="@row.Id">حذف</button>
                                    }
                                    @if (Model.Permissions.CanEdit && row.CanApprove)
                                    {
                                        <button type="button" data-approve-advance="@row.Id">اعتماد</button>
                                    }
                                    @if (Model.Permissions.CanEdit && row.CanSendApproval)
                                    {
                                        <button type="button" data-send-advance-approval="@row.Id">إرسال للاعتماد</button>
                                    }
                                    @if (Model.Permissions.CanDelete && row.CanCancel)
                                    {
                                        <button type="button" data-cancel-advance="@row.Id">إلغاء آمن</button>
                                    }
                                    @if (Model.Permissions.CanEdit && row.CanDisburse)
                                    {
                                        <button type="button" data-disburse-advance="@row.Id">صرف السلفة</button>
                                    }
                                    @if (!row.CanEdit && !string.IsNullOrWhiteSpace(row.LockReason))
                                    {
                                        <span class="lhf-action-note">مقفلة</span>
                                    }
                                </td>
                            </tr>
                        }
                        @if (!Model.Advances.Any())
                        {
                            <tr><td colspan="10" class="lhf-empty">لا توجد طلبات سلف مطابقة للفلاتر الحالية.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    }
    else if (Model.ModuleKey == "components")
    {
        <section class="lhf-panel">
            <header>
                <h3>كتالوج مكونات الرواتب</h3>
                @if (Model.Permissions.CanAdd)
                {
                    <button type="button" class="lhf-primary" data-new-component><i class="fas fa-plus"></i><span>مكون جديد</span></button>
                }
            </header>
            <div class="lhf-table-wrap">
                <table class="lhf-table">
                    <thead><tr><th>المكون</th><th>الحساب</th><th>التصنيف</th><th>طريقة الحساب</th><th>ظهور</th></tr></thead>
                    <tbody>
                        @foreach (var row in Model.Components)
                        {
                            <tr data-component-id="@row.Id">
                                <td><strong>@row.Name</strong><small>@row.NameEnglish</small></td>
                                <td><span class="lhf-muted-account">يتم عرض الحسابات من شاشة معاينة القيد بأسماء واضحة</span></td>
                                <td>
                                    <span class="lhf-badge @(row.AddOrDiscount ? "success" : "danger")">@(row.AddOrDiscount ? "إضافة" : "خصم")</span>
                                    @if (row.Salary) { <span class="lhf-badge info">راتب</span> }
                                    @if (row.Insurance) { <span class="lhf-badge warning">تأمين</span> }
                                    @if (row.Reward) { <span class="lhf-badge success">مكافأة</span> }
                                </td>
                                <td>@(row.FixedOrChanged ? "متغير" : "ثابت") - وحدة @row.Unit</td>
                                <td>@(row.ViewComponent ? "ظاهر" : "مخفي")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    }
    else if (Model.ModuleKey == "changed-components")
    {
        <section class="lhf-panel lhf-changed-components">
            <header>
                <div>
                    <h3>نتائج المفردات المتغيرة</h3>
                    <span>راجع السطور حسب الفلاتر. السطور المقفلة تظهر للقراءة فقط لحماية مسير الرواتب.</span>
                </div>
                @if (Model.Permissions.CanAdd)
                {
                    <div class="lhf-panel-tools">
                        <button type="button" data-open-changed-bulk="bulk"><i class="fas fa-layer-group"></i><span>إدخال جماعي</span></button>
                        <button type="button" data-open-changed-bulk="copy"><i class="fas fa-copy"></i><span>نسخ شهر</span></button>
                    </div>
                }
            </header>
            <div class="lhf-table-wrap">
                <table class="lhf-table lhf-changed-table">
                    <thead>
                        <tr>
                            <th>رقم</th>
                            <th>الموظف</th>
                            <th>المفردة</th>
                            <th>الفترة</th>
                            <th>القيمة</th>
                            <th>القياس</th>
                            <th>الحالة</th>
                            <th>ملاحظات</th>
                            <th>إجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.ChangedComponents)
                        {
                            <tr data-changed-component-id="@row.Id" class="@(row.CanEdit ? "" : "lhf-row-locked") @(row.PayrollUsed ? "lhf-row-payroll-locked" : "") @(row.AddOrDiscount ? "lhf-row-addition" : "lhf-row-deduction")">
                                <td><code>@row.HeaderId / @row.Id</code></td>
                                <td class="lhf-employee-cell">
                                    <strong>@row.EmployeeName</strong>
                                    <small>@row.EmployeeCode</small>
                                    <small>@row.BranchName @(!string.IsNullOrWhiteSpace(row.DepartmentName) ? " / " + row.DepartmentName : "")</small>
                                </td>
                                <td>
                                    <strong>@row.ComponentName</strong>
                                    <span class="lhf-badge @(row.AddOrDiscount ? "success" : "danger")">@(row.AddOrDiscount ? "إضافة" : "خصم")</span>
                                </td>
                                <td><strong>@row.Month.ToString("00") / @row.Year</strong><small>@row.RecordDate</small></td>
                                <td class="lhf-num @(row.AddOrDiscount ? "lhf-value-addition" : "lhf-value-deduction")">@row.Value.ToString("N2")</td>
                                <td>
                                    @if (row.NoOfDays > 0) { <small>أيام: @row.NoOfDays.ToString("N2")</small> }
                                    @if (row.NoOfHours > 0 || row.NoOfMinutes > 0) { <small>ساعات: @row.NoOfHours.ToString("N2") : @row.NoOfMinutes.ToString("N2")</small> }
                                    @if (row.HourRate > 0) { <small>معدل: @row.HourRate.ToString("N2")</small> }
                                    @if (row.Salary > 0) { <small>أساس: @row.Salary.ToString("N2")</small> }
                                </td>
                                <td>
                                    @if (row.PayrollUsed) { <span class="lhf-badge locked">مقفلة بالمسير</span> }
                                    else { <span class="lhf-badge info">قابلة للتعديل</span> }
                                    @if (row.PayrollRunId.HasValue && !string.IsNullOrWhiteSpace(Model.PayrollRunUrl))
                                    {
                                        <a class="lhf-run-link" href="@(Model.PayrollRunUrl + "?payrollRunId=" + row.PayrollRunId.Value + "&year=" + row.Year + "&month=" + row.Month)">
                                            مسير #@row.PayrollRunId.Value
                                        </a>
                                        <small>@(string.IsNullOrWhiteSpace(row.PayrollRunName) ? "Snapshot payroll run" : row.PayrollRunName)</small>
                                        <span class="lhf-badge @(row.PayrollRunPosted ? "locked" : "warning")">@(row.PayrollRunPosted ? "مرحل" : "محفوظ")</span>
                                    }
                                    else if (row.PayrollUsed && !string.IsNullOrWhiteSpace(row.PayrollUsageSource))
                                    {
                                        <small>@row.PayrollUsageSource</small>
                                    }
                                    @if (row.IsLegacyBulk) { <span class="lhf-badge warning">دفعة متعددة</span> }
                                </td>
                                <td>
                                    <span>@row.Remarks</span>
                                    @if (!string.IsNullOrWhiteSpace(row.LockReason)) { <small class="lhf-lock-note">@row.LockReason</small> }
                                </td>
                                <td class="lhf-actions">
                                    @if (Model.Permissions.CanEdit && row.CanEdit)
                                    {
                                        <button type="button" data-edit-changed-component="@row.Id">تعديل</button>
                                    }
                                    @if (Model.Permissions.CanDelete && row.CanDelete)
                                    {
                                        <button type="button" data-delete-changed-component="@row.Id">حذف</button>
                                    }
                                    @if (!row.CanEdit)
                                    {
                                        <span class="lhf-action-note">للقراءة فقط</span>
                                    }
                                </td>
                            </tr>
                        }
                        @if (!Model.ChangedComponents.Any())
                        {
                            <tr><td colspan="9" class="lhf-empty"><strong>لا توجد مفردات متغيرة</strong><span>غيّر الفلاتر أو استخدم لوحة الإدخال السريع لتسجيل حركة جديدة.</span></td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <div class="lhf-editor lhf-quick-entry" id="lhfChangedComponentEditor">
            <form id="lhfChangedComponentForm" class="lhf-editor-card">
                <input type="hidden" id="lhfChangedDetailId" name="Id" />
                <header>
                    <div>
                        <span>إدخال سريع</span>
                        <h3>سجل مفردة متغيرة</h3>
                        <small>اختر الموظف ثم المفردة والقيمة. نفس قواعد التحقق وقفل المسير ما زالت تعمل من الخادم.</small>
                    </div>
                    <button type="button" data-new-changed-component title="تفريغ الحقول"><i class="fas fa-rotate-right"></i></button>
                </header>
                <ol class="lhf-entry-steps" aria-label="ترتيب الإدخال">
                    <li>اختر الموظف</li>
                    <li>اختر المفردة</li>
                    <li>حدد إضافة أو خصم</li>
                    <li>أدخل القيمة والفترة</li>
                    <li>احفظ</li>
                </ol>
                <div class="lhf-form-grid">
                    <label><span>الموظف</span>
                        <input type="search" id="lhfChangedEmployeeSearch" class="lhf-select-search lhf-editor-search" data-filter-select="lhfChangedEmployeeId" placeholder="بحث سريع بالاسم أو الكود" autocomplete="off" />
                        <select id="lhfChangedEmployeeId" name="EmployeeId" required>
                            <option value="">اختر الموظف</option>
                            @foreach (var employee in Model.Employees)
                            {
                                <option value="@employee.Id" data-salary="@employee.BasicSalary">@employee.Code - @employee.Name</option>
                            }
                        </select>
                    </label>
                    <label><span>المفردة</span>
                        <input type="search" id="lhfChangedComponentSearch" class="lhf-select-search lhf-editor-search" data-filter-select="lhfChangedComponentId" placeholder="بحث سريع في المفردات" autocomplete="off" />
                        <select id="lhfChangedComponentId" name="ComponentId" required>
                            <option value="">اختر المفردة</option>
                            @foreach (var component in Model.Components)
                            {
                                <option value="@component.Id" data-add="@component.AddOrDiscount.ToString().ToLowerInvariant()" data-unit="@component.Unit">@component.Name (@(component.AddOrDiscount ? "إضافة" : "خصم"))</option>
                            }
                        </select>
                    </label>
                    <label><span>التاريخ</span><input type="date" id="lhfChangedRecordDate" name="RecordDate" required /></label>
                    <label><span>السنة</span><input type="number" id="lhfChangedYear" name="Year" min="2006" max="3000" required /></label>
                    <label><span>الشهر</span><input type="number" id="lhfChangedMonth" name="Month" min="1" max="12" required /></label>
                    <label><span>القيمة</span><input type="number" id="lhfChangedValue" name="Value" min="0.01" step="0.01" required /></label>
                    <label><span>عدد الأيام</span><input type="number" id="lhfChangedDays" name="NoOfDays" min="0" step="0.01" /></label>
                    <label><span>عدد الساعات</span><input type="number" id="lhfChangedHours" name="NoOfHours" min="0" step="0.01" /></label>
                    <label><span>الدقائق</span><input type="number" id="lhfChangedMinutes" name="NoOfMinutes" min="0" step="0.01" /></label>
                    <label><span>معدل الساعة/اليوم</span><input type="number" id="lhfChangedHourRate" name="HourRate" min="0" step="0.01" /></label>
                    <label><span>الراتب الأساسي</span><input type="number" id="lhfChangedSalary" name="Salary" min="0" step="0.01" /></label>
                    <label class="lhf-field-wide"><span>ملاحظات</span><textarea id="lhfChangedRemarks" name="Remarks" rows="3"></textarea></label>
                </div>
                <div class="lhf-changed-entry-preview" id="lhfChangedEntryPreview">اختر الموظف والمفردة لمراجعة اتجاه التأثير قبل الحفظ.</div>
                <div id="lhfChangedMessage" class="lhf-editor-message"></div>
                <footer>
                    <button type="button" data-new-changed-component>تفريغ</button>
                    <button type="submit" class="lhf-primary">حفظ</button>
                </footer>
            </form>
        </div>

        <div class="lhf-editor" id="lhfChangedBulkEditor" hidden>
            <form id="lhfChangedBulkForm" class="lhf-editor-card lhf-wide-editor">
                <input type="hidden" id="lhfChangedBulkMode" name="Mode" value="bulk" />
                <header>
                    <h3 id="lhfChangedBulkTitle">إدخال جماعي للمفردات المتغيرة</h3>
                    <button type="button" data-close-changed-bulk aria-label="إغلاق">×</button>
                </header>
                <div class="lhf-form-grid">
                    <label class="lhf-field-wide"><span>الموظفون</span><textarea id="lhfChangedBulkEmployees" name="EmployeeTokens" rows="3" placeholder="اكتب رقم الموظف أو الكود، وافصل بين الموظفين بفاصلة أو سطر جديد"></textarea></label>
                    <label><span>المفردة</span>
                        <select id="lhfChangedBulkComponentId" name="ComponentId">
                            <option value="">اختر المفردة</option>
                            @foreach (var component in Model.Components)
                            {
                                <option value="@component.Id" data-add="@component.AddOrDiscount.ToString().ToLowerInvariant()" data-unit="@component.Unit">@component.Name (@(component.AddOrDiscount ? "إضافة" : "خصم"))</option>
                            }
                        </select>
                    </label>
                    <label class="lhf-copy-only"><span>مفردة المصدر</span>
                        <select id="lhfChangedBulkSourceComponentId" name="SourceComponentId">
                            <option value="">كل المفردات</option>
                            @foreach (var component in Model.Components)
                            {
                                <option value="@component.Id">@component.Name (@(component.AddOrDiscount ? "إضافة" : "خصم"))</option>
                            }
                        </select>
                    </label>
                    <label class="lhf-copy-only"><span>سنة المصدر</span><input type="number" id="lhfChangedBulkSourceYear" name="SourceYear" min="2006" max="3000" /></label>
                    <label class="lhf-copy-only"><span>شهر المصدر</span><input type="number" id="lhfChangedBulkSourceMonth" name="SourceMonth" min="1" max="12" /></label>
                    <label><span>تاريخ التسجيل</span><input type="date" id="lhfChangedBulkRecordDate" name="RecordDate" /></label>
                    <label><span>سنة الهدف</span><input type="number" id="lhfChangedBulkYear" name="Year" min="2006" max="3000" required /></label>
                    <label><span>شهر الهدف</span><input type="number" id="lhfChangedBulkMonth" name="Month" min="1" max="12" required /></label>
                    <label class="lhf-bulk-only"><span>القيمة</span><input type="number" id="lhfChangedBulkValue" name="Value" min="0.01" step="0.01" /></label>
                    <label class="lhf-bulk-only"><span>عدد الأيام</span><input type="number" id="lhfChangedBulkDays" name="NoOfDays" min="0" step="0.01" /></label>
                    <label class="lhf-bulk-only"><span>عدد الساعات</span><input type="number" id="lhfChangedBulkHours" name="NoOfHours" min="0" step="0.01" /></label>
                    <label class="lhf-bulk-only"><span>الدقائق</span><input type="number" id="lhfChangedBulkMinutes" name="NoOfMinutes" min="0" step="0.01" /></label>
                    <label class="lhf-bulk-only"><span>معدل الساعة/اليوم</span><input type="number" id="lhfChangedBulkHourRate" name="HourRate" min="0" step="0.01" /></label>
                    <label class="lhf-bulk-only"><span>الراتب الأساسي</span><input type="number" id="lhfChangedBulkSalary" name="Salary" min="0" step="0.01" /></label>
                    <label class="lhf-field-wide"><span>ملاحظات</span><textarea id="lhfChangedBulkRemarks" name="Remarks" rows="2"></textarea></label>
                </div>
                <div class="lhf-bulk-summary" id="lhfChangedBulkSummary">المعاينة مطلوبة قبل الحفظ.</div>
                <div class="lhf-table-wrap lhf-bulk-preview-wrap" hidden>
                    <table class="lhf-table">
                        <thead><tr><th>#</th><th>الموظف</th><th>المفردة</th><th>الفترة</th><th>القيمة</th><th>الحالة</th><th>التقرير</th></tr></thead>
                        <tbody id="lhfChangedBulkPreviewRows"></tbody>
                    </table>
                </div>
                <footer>
                    <span id="lhfChangedBulkMessage" class="lhf-editor-message"></span>
                    <button type="button" data-close-changed-bulk>إلغاء</button>
                    <button type="button" data-preview-changed-bulk>معاينة</button>
                    <button type="button" class="lhf-primary" data-save-changed-bulk disabled>حفظ السطور الصالحة</button>
                </footer>
            </form>
        </div>
    }
    else if (Model.ModuleKey == "leave")
    {
        <section class="lhf-panel lhf-vacation-engine">
            <header>
                <div>
                    <h3>محرك رصيد الإجازات</h3>
                    <span>حساب موحد للاستحقاق، المرحل، المستهلك، الإجازات بدون راتب، والمتبقي قبل اعتماد أي إجازة مدفوعة.</span>
                </div>
            </header>
            <div class="lhf-vacation-balance-form">
                    <label><span>الموظف</span>
                        <select id="lhfVacationEmployeeId">
                            <option value="">اختر موظف</option>
                            @foreach (var employee in Model.Employees)
                            {
                                <option value="@employee.Id" @(Model.EmployeeId == employee.Id ? "selected" : "") data-branch="@employee.BranchName" data-department="@employee.DepartmentName">@employee.Code - @employee.Name</option>
                            }
                        </select>
                    </label>
                <label><span>تاريخ الحساب</span><input type="date" id="lhfVacationAsOfDate" /></label>
                <label><span>من تاريخ</span><input type="date" id="lhfVacationStartDate" /></label>
                <label><span>إلى تاريخ</span><input type="date" id="lhfVacationEndDate" /></label>
                <button type="button" class="lhf-primary" data-calc-vacation-balance>حساب الرصيد</button>
            </div>
            <div class="lhf-vacation-balance-result" id="lhfVacationBalanceResult">
                اختر موظفا لحساب رصيد الإجازات قبل الحفظ أو الاعتماد.
            </div>
        </section>
        <section class="lhf-panel">
            <header><h3>السجلات</h3><span>طلبات ومستحقات الإجازات حسب الشاشة الحالية</span></header>
            <div class="lhf-table-wrap">
                <table class="lhf-table">
