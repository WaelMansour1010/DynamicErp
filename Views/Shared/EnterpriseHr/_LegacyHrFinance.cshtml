                        @foreach (var employee in Model.Employees)
                        {
                            <option value="@employee.Id" data-salary="@employee.BasicSalary.ToString(CultureInfo.InvariantCulture)" data-branch="@employee.BranchName" data-department="@employee.DepartmentName">@employee.Code - @employee.Name</option>
                        }
                    </select>
                </label>
                <label><span>من تاريخ</span><input id="lhfVacationRequestFromDate" name="FromDate" type="date" required /></label>
                <label><span>إلى تاريخ</span><input id="lhfVacationRequestToDate" name="ToDate" type="date" required /></label>
                <label><span>عودة العمل</span><input id="lhfVacationRequestResumeWork" name="ResumeWork" type="date" /></label>
                <label><span>نوع الإجازة</span>
                    <select id="lhfVacationRequestType" name="VacationType">
                        @foreach (var type in Model.VacationTypes)
                        {
                            <option value="@type.Value">@type.Text</option>
                        }
                    </select>
                </label>
                <label class="lhf-check"><input id="lhfVacationWithSalary" name="WithSalary" type="checkbox" checked /><span>براتب</span></label>
                <label class="lhf-check"><input id="lhfVacationWithoutSalary" name="WithoutSalary" type="checkbox" /><span>بدون راتب</span></label>
                <label class="lhf-span-3"><span>السبب / الملاحظات</span><input id="lhfVacationReason" name="Reason" maxlength="4000" /></label>
                <div class="lhf-vacation-request-summary lhf-span-3">
                    <span id="lhfVacationEmployeeMeta">اختر موظفا لعرض الفرع والإدارة والراتب الأساسي.</span>
                    <span id="lhfVacationDateSummary">حدد فترة الإجازة لحساب الأيام وموعد العودة.</span>
                </div>
                <div class="lhf-vac-conflict lhf-span-3" id="lhfVacationConflict" hidden></div>
                <div class="lhf-vacation-balance-result lhf-span-3" id="lhfVacationRequestBalance">سيتم حساب الرصيد قبل الحفظ.</div>
            </div>
            <footer><span id="lhfVacationMessage"></span><button type="button" data-close-vacation>إلغاء</button><button type="submit" class="lhf-primary">حفظ وإرسال</button></footer>
        </form>
    </aside>
</section>
