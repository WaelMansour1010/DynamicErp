                        <button type="button" class="lhf-primary" data-new-vacation><i class="fas fa-plus"></i><span>طلب إجازة جديد</span></button>
                    }
                </header>
                <div class="lhf-vacation-calendar-strip">
                    @foreach (var row in vacationRows.Take(8))
                    {
                        var badgeClass = row.Rejected ? "danger" : row.HrApproved ? "success" : row.ManagerApproved ? "warning" : row.Submitted ? "info" : "locked";
                        <article class="lhf-vacation-date-card @badgeClass">
                            <small>@row.FromDate</small>
                            <strong>@row.EmployeeName</strong>
                            <span>@row.NoVacation.ToString("N2") يوم</span>
                            <em>@row.StatusText</em>
                        </article>
                    }
                    @if (!vacationRows.Any())
                    {
                        <div class="lhf-empty">لا توجد طلبات إجازات مطابقة للفلاتر الحالية.</div>
                    }
                </div>
            </section>

            <section class="lhf-panel lhf-vacations-panel">
                <header>
                    <div>
                        <h3>طلبات الإجازات ومسار الاعتماد</h3>
                        <span>مراجعة مركزة للحالة، الرصيد، الاعتماد، ومنع التداخل أو التكرار قبل الحفظ.</span>
                    </div>
                    <div class="lhf-panel-tools">
                        <input type="search" id="lhfVacationTableSearch" placeholder="بحث داخل الطلبات..." autocomplete="off" />
                    </div>
                </header>
                <div class="lhf-table-wrap">
                    <table class="lhf-table lhf-vacation-table">
                        <thead><tr><th>رقم</th><th>الموظف</th><th>الفترة</th><th>الأيام</th><th>النوع</th><th>الحالة</th><th>مسار الاعتماد</th><th>ملاحظات</th><th>إجراءات</th></tr></thead>
                        <tbody>
                            @foreach (var row in Model.Vacations)
                            {
                                var badgeClass = row.Rejected ? "danger" : row.HrApproved ? "success" : row.ManagerApproved ? "warning" : row.Submitted ? "info" : "locked";
                                <tr class="@(row.CanEdit ? "" : "lhf-row-locked")" data-vacation-search="@((row.EmployeeCode + " " + row.EmployeeName + " " + row.BranchName + " " + row.DepartmentName + " " + row.StatusText + " " + row.Reason).ToLowerInvariant())" data-vacation-employee="@row.EmployeeId" data-vacation-from="@row.FromDate" data-vacation-to="@row.ToDate" data-vacation-id="@row.Id">
                                    <td><code>@row.Id</code></td>
                                    <td><strong>@row.EmployeeName</strong><small>@row.EmployeeCode</small><small>@row.BranchName - @row.DepartmentName</small></td>
                                    <td><strong>@row.FromDate</strong><small>إلى @row.ToDate</small><small>عودة العمل: @row.ResumeWork</small></td>
                                    <td class="lhf-num">@row.NoVacation.ToString("N2")</td>
                                    <td>@(row.WithoutSalary ? "بدون راتب" : "براتب")</td>
                                    <td>
                                        <div class="lhf-status-stack">
                                            <span class="lhf-badge @badgeClass">@row.StatusText</span>
                                            @if (row.EntitlementId.HasValue)
                                            {
                                                <span class="lhf-badge info">مستحقات #@row.EntitlementId.Value</span>
                                            }
                                            @if (row.EmbarkationId.HasValue)
                                            {
                                                <span class="lhf-badge success">تمت المباشرة</span>
                                                <small>فعلي: @row.ActualReturnDate</small>
                                                <small>أيام فعلية: @row.ActualVacationDays.ToString("N2") / تأخير: @row.DelayDays.ToString("N2")</small>
                                            }
                                            else if (row.LinkedToEntitlement)
                                            {
                                                <small>لم تسجل مباشرة العمل بعد.</small>
                                            }
                                        </div>
                                    </td>
                                    <td><div class="lhf-approval-mini"><span class="@(row.Submitted ? "done" : "")">إرسال</span><span class="@(row.ManagerApproved ? "done" : "")">المدير</span><span class="@(row.HrApproved ? "done" : "")">HR</span></div></td>
                                    <td><span>@row.Reason</span>@if (!string.IsNullOrWhiteSpace(row.LockReason)) { <small class="lhf-lock-note">@row.LockReason</small> }</td>
                                    <td class="lhf-actions">
                                        @if (Model.Permissions.CanEdit && row.CanRecordReturnToWork && row.EntitlementId.HasValue) { <button type="button" data-save-vacation-return="@row.EntitlementId.Value" data-vacation-start="@row.FromDate" data-vacation-end="@row.ToDate" data-vacation-actual="@row.ActualReturnDate" data-vacation-actual-days="@row.ActualVacationDays.ToString(CultureInfo.InvariantCulture)" data-vacation-delay-days="@row.DelayDays.ToString(CultureInfo.InvariantCulture)">@(row.EmbarkationId.HasValue ? "تعديل مباشرة" : "تسجيل مباشرة")</button> }
                                        @if (Model.Permissions.CanDelete && row.CanDeleteReturnToWork && row.EntitlementId.HasValue) { <button type="button" data-delete-vacation-return="@row.EntitlementId.Value">حذف المباشرة</button> }
                                        @if (Model.Permissions.CanAdd && row.CanCreateEntitlement) { <button type="button" data-create-vacation-entitlement="@row.Id">إنشاء مستحقات</button> }
                                        @if (Model.Permissions.CanDelete && row.CanDeleteEntitlement && row.EntitlementId.HasValue) { <button type="button" data-delete-vacation-entitlement="@row.EntitlementId.Value">حذف المستحقات</button> }
                                        @if (Model.Permissions.CanEdit && row.CanEdit) { <button type="button" data-edit-vacation="@row.Id">تعديل</button> }
                                        @if (Model.Permissions.CanEdit && row.CanManagerApprove) { <button type="button" data-manager-approve-vacation="@row.Id">اعتماد المدير</button> }
                                        @if (Model.Permissions.CanEdit && row.CanHrApprove) { <button type="button" data-hr-approve-vacation="@row.Id">اعتماد HR</button> }
                                        @if (Model.Permissions.CanEdit && row.CanReject) { <button type="button" data-reject-vacation="@row.Id">رفض</button> }
                                        @if (Model.Permissions.CanDelete && row.CanCancel) { <button type="button" data-cancel-vacation="@row.Id">إلغاء آمن</button> }
                                    </td>
                                </tr>
                            }
                            @if (!Model.Vacations.Any())
                            {
                                <tr><td colspan="9" class="lhf-empty">لا توجد طلبات إجازات مطابقة للفلاتر الحالية.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        </section>
    }

