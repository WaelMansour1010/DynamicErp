                    <label><span>من تاريخ</span><input type="date" id="lhfVacationStartDate" value="@Model.DateFrom" /></label>
                    <label><span>إلى تاريخ</span><input type="date" id="lhfVacationEndDate" value="@Model.DateTo" /></label>
                    <button type="button" class="lhf-primary" data-calc-vacation-balance>حساب الرصيد</button>
                </div>
