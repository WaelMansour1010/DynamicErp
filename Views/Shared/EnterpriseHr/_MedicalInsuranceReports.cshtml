@{ var hrArea = (ViewBag.SharedHrArea as string) ?? (ViewContext.RouteData.DataTokens["area"] as string) ?? string.Empty; Func<string, string> hrUrl = action => Url.Action(action, "EmployeePayroll", new { area = hrArea }); }
<main class="ep-page" data-screen="insurance-reports"
      data-lookups-url="@hrUrl("Lookups")"
      data-subscriptions-url="@hrUrl("InsuranceSubscriptionReport")"
      data-deductions-url="@hrUrl("InsuranceDeductionReport")">
    <header class="ep-header">
        <div>
            <h1>تقارير التأمين الطبي</h1>
            <p>متابعة الموظفين المشتركين وخصومات التأمين وتكلفة الشركة حسب الفترة.</p>
        </div>
        <div class="ep-header-actions">
            <a class="ep-link" href="@hrUrl("Employees")"><i class="fas fa-users"></i> الموظفون</a>
            <a class="ep-link" href="@hrUrl("SalaryRun")"><i class="fas fa-file-invoice-dollar"></i> مسير الرواتب</a>
                    </div>
    </header>

    <section class="ep-toolbar">
        <label>من<input id="epReportFrom" type="date" /></label>
        <label>إلى<input id="epReportTo" type="date" /></label>
        <label>شركة التأمين<select id="epReportProvider"><option value="">كل الشركات</option></select></label>
        <label>الخطة<select id="epReportPlan"><option value="">كل الخطط</option></select></label>
        <label class="ep-check"><input id="epReportActiveOnly" type="checkbox" checked /> النشط فقط</label>
        <button type="button" class="ep-primary" id="epLoadReports"><i class="fas fa-search"></i> عرض</button>
    </section>

    <section class="ep-kpis">
        <div><span>عدد الاشتراكات</span><strong id="epReportSubscriptionCount">0</strong></div>
        <div><span>إجمالي خصم الموظفين</span><strong id="epReportEmployeeTotal">0.00</strong></div>
        <div><span>إجمالي تكلفة الشركة</span><strong id="epReportCompanyTotal">0.00</strong></div>
    </section>

    <section class="ep-grid-wrap">
        <h2>الموظفون المشتركون</h2>
        <table class="ep-table">
            <thead><tr><th>الموظف</th><th>الشركة</th><th>الخطة</th><th>البداية</th><th>النهاية</th><th>التكلفة</th><th>خصم الموظف</th><th>تكلفة الشركة</th><th>الحالة</th></tr></thead>
            <tbody id="epSubscriptionsReportRows"></tbody>
        </table>
    </section>

    <section class="ep-grid-wrap">
        <h2>خصومات التأمين المحفوظة في المسير</h2>
        <table class="ep-table">
            <thead><tr><th>الموظف</th><th>الخطة</th><th>من</th><th>إلى</th><th>خصم الموظف</th><th>تكلفة الشركة</th></tr></thead>
            <tbody id="epDeductionsReportRows"></tbody>
        </table>
    </section>
    <div class="ep-message" id="epMessage"></div>
</main>

