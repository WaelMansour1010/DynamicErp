@{
    var hrArea = (ViewBag.SharedHrArea as string) ?? (ViewContext.RouteData.DataTokens["area"] as string) ?? string.Empty;
    var hrReadOnly = ViewBag.SharedHrReadOnly is bool && (bool)ViewBag.SharedHrReadOnly;
    Func<string, string> hrUrl = action => Url.Action(action, "EmployeePayroll", new { area = hrArea });
}
<main class="ep-page ep-insurance-enterprise ep-ui-rescue ep-master-detail ep-insurance-command-center" data-screen="insurance-settings"
      data-read-only="@(hrReadOnly ? "true" : "false")"
      data-lookups-url="@hrUrl("Lookups")"
      data-search-url="@hrUrl("Search")"
      data-providers-url="@hrUrl("Providers")"
      data-save-provider-url="@(hrReadOnly ? string.Empty : hrUrl("SaveProvider"))"
      data-plans-url="@hrUrl("Plans")"
      data-save-plan-url="@(hrReadOnly ? string.Empty : hrUrl("SavePlan"))"
      data-subscriptions-url="@hrUrl("InsuranceSubscriptionReport")"
      data-deductions-url="@hrUrl("InsuranceDeductionReport")">

    <header class="ep-md-hero">
        <div class="ep-md-title">
            <div class="ep-breadcrumb">شؤون الموظفين / التأمين الطبي</div>
            <h1>إدارة التأمين الطبي</h1>
            <p>مساحة عمل لإدارة شركات التأمين والخطط والربط مع مسير الرواتب، مع توضيح أثر خصم الموظف وتكلفة الشركة قبل أي ترحيل.</p>
        </div>
        <div class="ep-md-actions">
            <button type="button" class="ep-secondary" id="epOpenProviderDrawer" @(hrReadOnly ? "hidden disabled" : "")><i class="fas fa-plus"></i> شركة تأمين</button>
            <button type="button" class="ep-primary" id="epOpenPlanDrawer" @(hrReadOnly ? "hidden disabled" : "")><i class="fas fa-plus"></i> خطة جديدة</button>
            <a class="ep-link" href="@hrUrl("SalaryRun")"><i class="fas fa-file-invoice-dollar"></i> المسير</a>
            <a class="ep-link" href="@hrUrl("MedicalInsuranceReports")"><i class="fas fa-chart-bar"></i> التقارير</a>
        </div>
    </header>

    <section class="ep-md-kpis" aria-label="ملخص التأمين الطبي">
        <article><i class="fas fa-user-shield"></i><span>المؤمن عليهم</span><strong id="epStatCovered">0</strong><small>اشتراكات نشطة</small></article>
        <article><i class="fas fa-building"></i><span>تحمل الشركة</span><strong id="epStatCompanyCost">0.00</strong><small>شهريا</small></article>
        <article><i class="fas fa-wallet"></i><span>تحمل الموظفين</span><strong id="epStatEmployeeCost">0.00</strong><small>شهريا</small></article>
        <article><i class="fas fa-layer-group"></i><span>الخطط النشطة</span><strong id="epStatActivePlans">0</strong><small>جاهزة للربط</small></article>
        <article><i class="fas fa-hourglass-end"></i><span>الخطط المنتهية</span><strong id="epStatExpired">0</strong><small>تحتاج مراجعة</small></article>
    </section>

    <section class="ep-md-toolbar">
        <div class="ep-search-box">
            <i class="fas fa-search"></i>
            <input id="epMasterSearch" placeholder="بحث عن شركة أو خطة أو حالة..." />
        </div>
        <select id="epMasterStatus">
            <option value="">كل الحالات</option>
            <option value="Active">نشط</option>
            <option value="Draft">مسودة</option>
            <option value="Pending Approval">بانتظار الاعتماد</option>
            <option value="Suspended">موقوف مؤقتا</option>
            <option value="Expired">منتهي</option>
            <option value="Cancelled">ملغي</option>
        </select>
    </section>

    <section class="ep-md-main">
        <div class="ep-md-column">
            <div class="ep-md-section-head">
                <div>
            <span>شركات التأمين</span>
                    <h2>شركات التأمين</h2>
                </div>
                <button type="button" class="ep-ghost" id="epOpenProviderDrawer2" @(hrReadOnly ? "hidden disabled" : "")><i class="fas fa-plus"></i></button>
            </div>
            <div class="ep-provider-card-list" id="epProvidersCards"></div>
            <div class="ep-table-shell ep-md-hidden-table" aria-hidden="true">
                <table class="ep-table ep-provider-table">
                    <tbody id="epProvidersRows"></tbody>
                </table>
            </div>
        </div>

        <div class="ep-md-column ep-md-plans-column">
            <div class="ep-md-section-head">
                <div>
                    <span>خطط التأمين</span>
                    <h2>خطط التأمين</h2>
                </div>
                <button type="button" class="ep-ghost" id="epOpenPlanDrawer2" @(hrReadOnly ? "hidden disabled" : "")><i class="fas fa-plus"></i></button>
            </div>
            <div class="ep-plan-card-grid" id="epPlansCards"></div>
            <div class="ep-table-shell ep-md-hidden-table" aria-hidden="true">
                <table class="ep-table ep-plan-table">
                    <tbody id="epPlansRows"></tbody>
                </table>
            </div>
        </div>
    </section>

    <section class="ep-md-mini-analytics">
        <article><span>إجمالي التكلفة الشهرية</span><strong id="epAnalyticsMonthly">0.00</strong></article>
        <article><span>التكلفة السنوية المتوقعة</span><strong id="epAnalyticsAnnual">0.00</strong></article>
        <article><span>خصم الموظفين الشهري</span><strong id="epAnalyticsEmployee">0.00</strong></article>
        <article><span>تحمل الشركة الشهري</span><strong id="epAnalyticsCompany">0.00</strong></article>
    </section>
    <div class="ep-table-shell ep-md-hidden-table" aria-hidden="true">
        <table class="ep-table">
            <tbody id="epCoverageRows"></tbody>
        </table>
    </div>
    <input id="epCoverageSearch" type="hidden" />
    <select id="epCoverageStatus" hidden><option value="">كل الحالات</option></select>

    <div class="ep-drawer-backdrop" id="epDrawerBackdrop" hidden></div>

    <aside class="ep-side-drawer ep-provider-drawer" id="epProviderDrawer" hidden aria-label="بيانات شركة التأمين">
        <form id="epProviderForm" class="ep-drawer-content">
            <input type="hidden" id="epProviderId" />
            <header class="ep-drawer-header">
                <div>
                    <span>بيانات الشركة</span>
                    <h2>شركة التأمين</h2>
                </div>
                <button type="button" class="ep-icon-button" data-close-drawer><i class="fas fa-times"></i></button>
            </header>
            <div class="ep-drawer-body">
                <label class="ep-switch ep-quiet-switch"><input id="epProviderActive" type="checkbox" checked /> نشط</label>
                <div class="ep-form-grid rescue-grid-2">
                    <label class="ep-field"><span>اسم عربي</span><input id="epProviderNameAr" required maxlength="200" placeholder="مثال: بوبا العربية" /></label>
                    <label class="ep-field"><span>اسم آخر / إنجليزي اختياري</span><input id="epProviderNameEn" maxlength="200" placeholder="الاسم القانوني أو المختصر إن وجد" /></label>
                    <label class="ep-field"><span>هاتف</span><input id="epProviderPhone" maxlength="50" placeholder="+966..." /></label>
                    <label class="ep-field ep-span-all"><span>ملاحظات</span><textarea id="epProviderNotes" placeholder="جهة الاتصال، شروط التجديد، أو أي ملاحظات داخلية"></textarea></label>
                </div>
            </div>
            <footer class="ep-drawer-footer">
                <button type="button" class="ep-secondary" data-close-drawer>إلغاء</button>
                <button type="submit" class="ep-primary"><i class="fas fa-save"></i> حفظ الشركة</button>
            </footer>
        </form>
    </aside>

    <aside class="ep-side-drawer ep-plan-drawer" id="epPlanDrawer" hidden aria-label="تفاصيل خطة التأمين">
        <form id="epPlanForm" class="ep-drawer-content">
            <input type="hidden" id="epPlanId" />
            <header class="ep-drawer-header">
                <div>
                    <span id="epHeroProviderMeta" class="ep-hidden-compat"></span>
                    <span id="epHeroDateRange" class="ep-hidden-compat"></span>
                    <span id="epHeroActiveState" class="ep-hidden-compat"></span>
                    <span>بيانات الخطة</span>
                    <h2 id="epHeroPlanName">تفاصيل الخطة</h2>
                    <p id="epHeroProviderName">اختر شركة التأمين واضبط بيانات الخطة.</p>
                </div>
                <div class="ep-drawer-header-actions">
                    <span class="ep-status-badge draft" id="epLifecycleBadge">مسودة</span>
                    <span class="ep-status-badge draft" id="epHeroLifecycleBadge">مسودة</span>
                    <button type="button" class="ep-icon-button" data-close-drawer><i class="fas fa-times"></i></button>
                </div>
            </header>

            <nav class="ep-drawer-tabs">
                <button type="button" class="active" data-drawer-tab="general">البيانات الأساسية</button>
                <button type="button" data-drawer-tab="payroll">أثر الراتب</button>
                <button type="button" data-drawer-tab="dependents">قواعد التابعين</button>
                <button type="button" data-drawer-tab="rules">قواعد التحمل</button>
                <button type="button" data-drawer-tab="accounting">الحسابات</button>
                <button type="button" data-drawer-tab="history">السجل</button>
            </nav>

            <div class="ep-drawer-body ep-plan-drawer-body">
                <section class="ep-drawer-panel active" data-drawer-panel="general">
                    <div class="ep-form-grid rescue-grid-2">
                        <label class="ep-field"><span>شركة التأمين</span><select id="epPlanProvider" required><option value="">اختر الشركة</option></select></label>
                        <label class="ep-field"><span>اسم الخطة عربي</span><input id="epPlanNameAr" required maxlength="200" placeholder="مثال: عائلي شامل" /></label>
                        <label class="ep-field"><span>اسم آخر / إنجليزي اختياري</span><input id="epPlanNameEn" maxlength="200" /></label>
                        <label class="ep-field"><span>الحالة</span><select id="epPlanLifecycleStatus"><option value="Draft">مسودة</option><option value="Pending Approval">بانتظار الاعتماد</option><option value="Active">نشط</option><option value="Suspended">موقوف مؤقتا</option><option value="Expired">منتهي</option><option value="Cancelled">ملغي</option></select></label>
                        <label class="ep-switch ep-field-inline"><input id="epPlanActive" type="checkbox" checked /> متاح للربط بالموظفين</label>
                    </div>
                    <details class="ep-advanced" open>
                        <summary>تواريخ السريان</summary>
                        <div class="ep-form-grid rescue-grid-3">
                            <label class="ep-field"><span>تاريخ البداية</span><input id="epPlanStartDate" type="date" /></label>
                            <label class="ep-field"><span>تاريخ النهاية</span><input id="epPlanEndDate" type="date" /></label>
                            <label class="ep-field"><span>بداية الخصم بالمسير</span><input id="epPlanPayrollStartDate" type="date" /></label>
                            <label class="ep-field"><span>تاريخ الإيقاف</span><input id="epPlanSuspensionDate" type="date" /></label>
                            <label class="ep-field"><span>تاريخ الإلغاء</span><input id="epPlanCancellationDate" type="date" /></label>
                        </div>
                    </details>
                </section>

                <section class="ep-drawer-panel" data-drawer-panel="payroll">
                    <div class="ep-payroll-drawer-grid">
                        <div class="ep-section-card">
                            <div class="ep-form-grid rescue-grid-2">
                                <label class="ep-field"><span>التكلفة الشهرية</span><input id="epPlanMonthlyCost" type="number" step="0.01" min="0" value="0" /></label>
                                <label class="ep-field"><span>راتب المعاينة</span><input id="epPreviewSalary" type="number" step="0.01" min="0" value="8000" /></label>
                                <label class="ep-field"><span>تحمل الموظف</span><select id="epPlanEmployeeShareType"><option value="Amount">مبلغ ثابت</option><option value="Percent">نسبة</option></select></label>
                                <label class="ep-field"><span>قيمة تحمل الموظف</span><input id="epPlanEmployeeShareValue" type="number" step="0.01" min="0" value="0" /></label>
                                <label class="ep-field"><span>تحمل الشركة</span><select id="epPlanCompanyShareType"><option value="AutoBalance">الباقي تلقائيا</option><option value="Amount">مبلغ ثابت</option><option value="Percent">نسبة</option></select></label>
                                <label class="ep-field"><span>قيمة تحمل الشركة</span><input id="epPlanCompanyShareValue" type="number" step="0.01" min="0" value="0" /></label>
                            </div>
                        </div>
                        <aside class="ep-financial-preview-card" aria-label="أثر الخطة على الراتب">
                            <div class="ep-preview-title">أثر الخطة على الراتب</div>
                            <div class="ep-preview-main"><span>الراتب قبل الخصم</span><strong><b id="epPreviewSalaryOut">8,000.00</b></strong></div>
                            <div class="ep-preview-lines">
                                <div><span>تتحمله الشركة</span><strong><b id="epPreviewCompanyOut">0.00</b></strong></div>
                                <div><span>يخصم من الموظف</span><strong><b id="epPreviewEmployeeOut">0.00</b></strong></div>
                                <div><span>تكلفة الاشتراك الشهرية</span><strong><b id="epPreviewCostOut">0.00</b></strong></div>
                            </div>
                            <div class="ep-preview-net"><span>صافي الراتب المتوقع</span><strong><b id="epPreviewNetOut">8,000.00</b></strong></div>
                        </aside>
                    </div>
                </section>

                <section class="ep-drawer-panel" data-drawer-panel="dependents">
                    <div class="ep-plan-rule-explainer">
                        <strong>هذه قواعد الخطة وليست تابعين حقيقيين لموظف محدد.</strong>
                        <span>هنا يتم تحديد العدد المسموح والتكلفة الافتراضية لأنواع التابعين. إضافة الزوج أو الأبناء الفعليين تتم من ملف الموظف داخل تبويب التأمين الطبي.</span>
                    </div>
                    <div class="ep-form-grid rescue-grid-3">
                        <label class="ep-field"><span>أقصى عدد تابعين للموظف</span><input id="epMaxDependents" type="number" min="0" value="4" /></label>
                        <label class="ep-field"><span>العمر الأقصى للأبناء</span><input id="epChildrenMaxAge" type="number" min="0" value="21" /></label>
                        <label class="ep-field"><span>نسبة التغطية الافتراضية</span><input id="epDefaultCoveragePercent" type="number" min="0" max="100" value="100" /></label>
                    </div>
                    <details class="ep-advanced">
                        <summary>تكلفة أنواع التابعين</summary>
                        <div class="ep-form-grid rescue-grid-3">
                            <label class="ep-field"><span>تكلفة الزوج/الزوجة</span><input id="epSpouseCost" type="number" step="0.01" min="0" value="0" /></label>
                            <label class="ep-field"><span>تكلفة الطفل</span><input id="epChildCost" type="number" step="0.01" min="0" value="0" /></label>
                            <label class="ep-field"><span>تكلفة الوالدين</span><input id="epParentCost" type="number" step="0.01" min="0" value="0" /></label>
                        </div>
                    </details>
                    <div class="ep-inline-add ep-dependent-add">
                        <input id="epDependentName" placeholder="اسم/نوع القاعدة مثال: زوجة أو ابن" />
                        <select id="epDependentRelation"><option value="Spouse">زوجة/زوج</option><option value="Child">ابن/ابنة</option><option value="Parent">والد/والدة</option></select>
                        <input id="epDependentBirthDate" type="date" />
                        <button type="button" id="epAddDependent"><i class="fas fa-plus"></i> إضافة قاعدة تابع</button>
                    </div>
                    <div class="ep-dependent-card-grid" id="epDependentsCards"></div>
                    <table class="ep-table ep-md-hidden-table"><tbody id="epDependentsRows"></tbody></table>
                </section>

                <section class="ep-drawer-panel" data-drawer-panel="rules">
                    <div class="ep-rule-builder">
                        <div class="ep-rule-word">IF</div>
                        <label class="ep-field"><span>الشرط</span><select id="epRuleScope"><option value="JobGrade">الدرجة الوظيفية</option><option value="Branch">الفرع</option><option value="Department">القسم</option><option value="Job">الوظيفة</option></select></label>
                        <label class="ep-field"><span>يساوي</span><input id="epRuleValue" placeholder="Sales / Manager / Grade A" /></label>
                        <div class="ep-rule-word">THEN</div>
                        <label class="ep-field"><span>تحمل الشركة %</span><input id="epRuleCompanyPercent" type="number" min="0" max="100" value="80" /></label>
                    </div>
                    <div class="ep-rules-toolbar">
                        <button type="button" data-rule-template="Managers100">المديرين 100%</button>
                        <button type="button" data-rule-template="Department80">الإدارة 80%</button>
                        <button type="button" data-rule-template="NewHire50">الموظفون الجدد 50%</button>
                    </div>
                    <div class="ep-rule-card-list" id="epRulesCards"></div>
                    <table class="ep-table ep-md-hidden-table"><tbody id="epRulesRows"></tbody></table>
                    <details class="ep-advanced">
                        <summary>إعدادات الضم التلقائي</summary>
                        <div class="ep-form-grid rescue-grid-2">
                            <label class="ep-field"><span>ضم تلقائي بعد X يوم</span><input id="epAutoEnrollAfterDays" type="number" min="0" value="30" /></label>
                            <label class="ep-field ep-span-all"><span>معايير الضم</span><textarea id="epAutoEnrollCriteria" placeholder="حسب الوظيفة / القسم / الفرع / الدرجة الوظيفية"></textarea></label>
                        </div>
                    </details>
                </section>

                <section class="ep-drawer-panel" data-drawer-panel="accounting">
                    <div class="ep-accounting-auto-card">
                        <i class="fas fa-shield-alt"></i>
                        <div>
                            <h3>تهيئة محاسبية تلقائية</h3>
                            <p>عند حفظ خطة نشطة تظهر في المسير، سيقوم النظام بإنشاء أو استخدام حساب مستحق شركة التأمين وحساب مصروف التأمين الطبي تلقائيا. لا يتم عرض الأكواد الداخلية للمستخدم.</p>
                            <small id="epPlanAccountingState">سيتم التحقق من الحسابات عند الحفظ وقبل ترحيل قيد الرواتب.</small>
                        </div>
                    </div>
                    <div class="ep-form-grid rescue-grid-2">
                        <input id="epPlanEmployeeAccount" type="hidden" />
                        <input id="epPlanCompanyAccount" type="hidden" />
                        <label class="ep-field"><span>مركز التكلفة</span><input id="epPlanCostCenter" maxlength="110" placeholder="Cost Center" /></label>
                        <label class="ep-field"><span>نوع الخصم</span><select id="epPlanPayrollDeductionType"><option value="Fixed">مبلغ ثابت</option><option value="Percentage">نسبة</option></select></label>
                        <label class="ep-field"><span>المعالجة الضريبية</span><select id="epPlanTaxMode"><option value="AfterTax">بعد الضريبة</option><option value="BeforeTax">قبل الضريبة</option></select></label>
                    </div>
                    <div class="ep-inline-hint">يتم التحقق من حساب الاستحقاق وحساب مصروف الشركة قبل حفظ الخطة النشطة وقبل ترحيل مسير الرواتب، ولا يسمح النظام بالترحيل على حساب افتراضي أو غير نهائي.</div>
                    <details class="ep-advanced">
                        <summary>إعدادات متقدمة</summary>
                        <div class="ep-toggle-grid">
                            <label class="ep-switch"><input id="epPlanIsMonthlyDeduction" type="checkbox" checked /> الخصم شهري</label>
                            <label class="ep-switch"><input id="epPlanAutoStop" type="checkbox" checked /> إيقاف تلقائي عند انتهاء الخطة</label>
                            <label class="ep-switch"><input id="epPlanShowInPayroll" type="checkbox" checked /> يظهر في المسير</label>
                            <label class="ep-switch"><input id="epPlanDistributeDepartments" type="checkbox" /> توزيع على الإدارات</label>
                            <label class="ep-switch"><input id="epPlanDistributeCostCenter" type="checkbox" /> توزيع حسب مركز التكلفة</label>
                        </div>
                    </details>
                </section>

                <section class="ep-drawer-panel" data-drawer-panel="history">
                    <ol class="ep-timeline" id="epActivityTimeline">
                        <li><strong>مسودة</strong><span>ابدأ بتعريف الشركة والخطة.</span></li>
                        <li><strong>مراجعة أثر الراتب</strong><span>راجع الخصم وصافي الراتب قبل التفعيل.</span></li>
                        <li><strong>تفعيل</strong><span>عند الحفظ بحالة نشط تصبح الخطة جاهزة للربط بالموظفين.</span></li>
                    </ol>
                </section>

                <label class="ep-field ep-plan-notes"><span>ملاحظات الخطة</span><textarea id="epPlanNotes" placeholder="ملاحظات الاعتماد والتجديد والربط المحاسبي"></textarea></label>
                <div class="ep-validation-list" id="epInsuranceValidation"></div>
            </div>

            <footer class="ep-drawer-footer">
                <button type="button" class="ep-secondary" data-close-drawer>إلغاء</button>
                <button type="button" class="ep-secondary" id="epSaveDraftPlan"><i class="fas fa-archive"></i> حفظ مسودة</button>
                <button type="button" class="ep-success" id="epActivatePlan"><i class="fas fa-check-circle"></i> تفعيل</button>
                <button type="submit" class="ep-primary"><i class="fas fa-save"></i> حفظ</button>
            </footer>
        </form>
    </aside>

    <div class="ep-message" id="epMessage"></div>
    <div class="ep-loading-shade" id="epLoadingShade" hidden>
        <div><i class="fas fa-spinner fa-spin"></i><span id="epLoadingText">جار التنفيذ...</span></div>
    </div>
</main>


