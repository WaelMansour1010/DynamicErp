    <script src="~/Scripts/jquery-3.3.1.min.js"></script>
    <script>
        var requestCache = {};

        function requestData(apiUrl) {
            if (!requestCache[apiUrl]) {
                requestCache[apiUrl] = $.get(apiUrl);
            }
            return requestCache[apiUrl];
        }
    </script>
    <!-- Vendor js -->
