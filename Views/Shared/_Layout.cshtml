    <style>
        .hide {
            display: none;
        }

        .was-validated select.form-control:invalid + .select2 .selection .select2-selection {
            border: 1px solid #f1556c;
        }

        .was-validated select.form-control:valid + .select2 .selection .select2-selection {
            border: 1px solid #1abc9c;
        }

        .header-title, .page-title {
