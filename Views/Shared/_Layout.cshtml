    function addMonths(date, months) {

        let result = new Date(date);
        let currentDay = result.getDate();
        result.setMonth(result.getMonth() + months);
        if (result.getDate() < currentDay) {
            result.setDate(0);  // Move to the last day of the previous month
        }
        if ($('#FirstBatchDate')) {
            let _FirstBatchDate = new Date($('#FirstBatchDate').val());
            if ((result.getDate() != _FirstBatchDate.getDate()) && (result.getMonth()+1) != 2) {
                result = setDayWithinMonth(result, _FirstBatchDate.getDate());
               
            }
        }

        return result;
    }
    function setDayWithinMonth(date, newDay) {
        let tempDate = new Date(date);
        tempDate.setDate(newDay);
        // Check if the month changes after setting the new day
        if (tempDate.getMonth() !== date.getMonth()) {
            console.log("Invalid day for the current month");
    
            return date;  // Return the original date if the day is invalid
        }

        return tempDate;  // Return the new date if valid
    }


    function addYears(date, years) {
        let result = new Date(date);
        let currentDay = result.getDate();
    
        result.setFullYear(result.getFullYear() + years);
    
        // Handle cases where the year adjustment lands in a shorter month (like February)
        if (result.getDate() < currentDay) {
            result.setDate(0); // Move to the last day of the previous month
        }

        if ($('#FirstBatchDate')) {
            let _FirstBatchDate = new Date($('#FirstBatchDate').val());
            if ((result.getDate() != _FirstBatchDate.getDate()) && (result.getMonth()+1) != 2) {
                result = setDayWithinMonth(result, _FirstBatchDate.getDate());
               
            }
        }
        return result;
    }
