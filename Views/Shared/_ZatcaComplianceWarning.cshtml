@{
    bool zatcaWarningRequired = ViewBag.ZatcaComplianceWarningRequired == true;
    bool zatcaWarningShowOnOpen = ViewBag.ZatcaComplianceWarningShowOnOpen == true;
    string zatcaWarningContext = ViewBag.ZatcaComplianceWarningContext as string ?? "";
}

@if (zatcaWarningRequired)
{
    <style>
        .zatca-warning-modal .modal-dialog {
            max-width: 760px;
        }

        .zatca-warning-modal .modal-content {
            border: 0;
            border-radius: 8px;
            box-shadow: 0 20px 60px rgba(34, 34, 34, 0.25);
            overflow: hidden;
        }

        .zatca-warning-modal .modal-header {
            align-items: center;
            background: #fff7e6;
            border-bottom: 1px solid #ffd591;
            color: #7a3f00;
        }

        .zatca-warning-modal .zatca-warning-icon {
            align-items: center;
            background: #faad14;
            border-radius: 50%;
            color: #fff;
            display: inline-flex;
            flex: 0 0 46px;
            font-size: 26px;
            height: 46px;
            justify-content: center;
            margin-left: 14px;
            width: 46px;
        }

        .zatca-warning-modal .modal-title {
            color: #7a3f00;
            font-size: 22px;
            font-weight: 700;
            margin: 0;
        }

        .zatca-warning-modal .modal-body {
            direction: rtl;
            font-size: 17px;
            line-height: 1.9;
            padding: 26px 30px 20px;
            text-align: right;
        }

        .zatca-warning-modal .zatca-warning-body {
            color: #3d3d3d;
            margin-bottom: 18px;
        }

        .zatca-warning-modal .zatca-warning-countdown {
            background: #fff3cd;
            border: 1px solid #ffe08a;
            border-radius: 6px;
            color: #856404;
            font-weight: 700;
            margin: 18px 0;
            padding: 12px 16px;
            text-align: center;
        }

        .zatca-warning-modal .zatca-warning-ack {
            align-items: center;
            background: #f8f9fa;
            border-radius: 6px;
            display: flex;
            gap: 10px;
            padding: 12px 14px;
        }

        .zatca-warning-modal .zatca-warning-ack input {
            height: 20px;
            margin: 0;
            width: 20px;
        }

        .zatca-warning-modal .modal-footer {
            border-top: 1px solid #f1f1f1;
            padding: 16px 30px 24px;
        }

        .zatca-warning-modal .btn-zatca-continue:disabled {
            cursor: not-allowed;
            opacity: .65;
        }
    </style>

    <div class="modal fade zatca-warning-modal" id="zatcaComplianceWarningModal" tabindex="-1" role="dialog" aria-labelledby="zatcaComplianceWarningTitle" aria-hidden="true" data-context="@zatcaWarningContext" data-show-on-open="@zatcaWarningShowOnOpen.ToString().ToLowerInvariant()">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <span class="zatca-warning-icon" aria-hidden="true"><i class="fas fa-exclamation-triangle"></i></span>
                    <h5 class="modal-title" id="zatcaComplianceWarningTitle">&#1578;&#1606;&#1576;&#1610;&#1607; &#1606;&#1592;&#1575;&#1605;&#1610; &#1607;&#1575;&#1605;</h5>
                </div>
                <div class="modal-body">
                    <div class="zatca-warning-body">
                        <p>&#1578;&#1588;&#1610;&#1585; &#1573;&#1593;&#1583;&#1575;&#1583;&#1575;&#1578; &#1575;&#1604;&#1606;&#1592;&#1575;&#1605; &#1573;&#1604;&#1609; &#1571;&#1606; &#1607;&#1584;&#1607; &#1575;&#1604;&#1605;&#1606;&#1588;&#1571;&#1577; &#1604;&#1605; &#1578;&#1587;&#1578;&#1603;&#1605;&#1604; &#1581;&#1578;&#1609; &#1575;&#1604;&#1570;&#1606; &#1573;&#1580;&#1585;&#1575;&#1569;&#1575;&#1578; &#1575;&#1604;&#1585;&#1576;&#1591; &#1608;&#1575;&#1604;&#1578;&#1603;&#1575;&#1605;&#1604; &#1605;&#1593; &#1607;&#1610;&#1574;&#1577; &#1575;&#1604;&#1586;&#1603;&#1575;&#1577; &#1608;&#1575;&#1604;&#1590;&#1585;&#1610;&#1576;&#1577; &#1608;&#1575;&#1604;&#1580;&#1605;&#1575;&#1585;&#1603;.</p>
                        <p>&#1575;&#1587;&#1578;&#1605;&#1585;&#1575;&#1585; &#1575;&#1587;&#1578;&#1582;&#1583;&#1575;&#1605; &#1575;&#1604;&#1606;&#1592;&#1575;&#1605; &#1608;&#1573;&#1589;&#1583;&#1575;&#1585; &#1575;&#1604;&#1593;&#1605;&#1604;&#1610;&#1575;&#1578; &#1575;&#1604;&#1605;&#1581;&#1575;&#1587;&#1576;&#1610;&#1577; &#1583;&#1608;&#1606; &#1575;&#1587;&#1578;&#1603;&#1605;&#1575;&#1604; &#1605;&#1578;&#1591;&#1604;&#1576;&#1575;&#1578; &#1575;&#1604;&#1585;&#1576;&#1591; &#1602;&#1583; &#1610;&#1593;&#1585;&#1590; &#1575;&#1604;&#1605;&#1606;&#1588;&#1571;&#1577; &#1604;&#1605;&#1582;&#1575;&#1604;&#1601;&#1575;&#1578; &#1571;&#1608; &#1594;&#1585;&#1575;&#1605;&#1575;&#1578; &#1606;&#1592;&#1575;&#1605;&#1610;&#1577; &#1608;&#1601;&#1602; &#1605;&#1578;&#1591;&#1604;&#1576;&#1575;&#1578; &#1575;&#1604;&#1601;&#1608;&#1578;&#1585;&#1577; &#1575;&#1604;&#1573;&#1604;&#1603;&#1578;&#1585;&#1608;&#1606;&#1610;&#1577; &#1575;&#1604;&#1605;&#1593;&#1578;&#1605;&#1583;&#1577; &#1583;&#1575;&#1582;&#1604; &#1575;&#1604;&#1605;&#1605;&#1604;&#1603;&#1577; &#1575;&#1604;&#1593;&#1585;&#1576;&#1610;&#1577; &#1575;&#1604;&#1587;&#1593;&#1608;&#1583;&#1610;&#1577;.</p>
                        <p>&#1610;&#1585;&#1580;&#1609; &#1575;&#1604;&#1578;&#1608;&#1575;&#1589;&#1604; &#1605;&#1593; &#1575;&#1604;&#1573;&#1583;&#1575;&#1585;&#1577; &#1571;&#1608; &#1575;&#1604;&#1583;&#1593;&#1605; &#1575;&#1604;&#1601;&#1606;&#1610; &#1604;&#1575;&#1587;&#1578;&#1603;&#1605;&#1575;&#1604; &#1573;&#1580;&#1585;&#1575;&#1569;&#1575;&#1578; &#1575;&#1604;&#1585;&#1576;&#1591; &#1601;&#1610; &#1571;&#1602;&#1585;&#1576; &#1608;&#1602;&#1578; &#1605;&#1605;&#1603;&#1606;.</p>
                        <p>&#1607;&#1584;&#1575; &#1575;&#1604;&#1578;&#1606;&#1576;&#1610;&#1607; &#1610;&#1592;&#1607;&#1585; &#1578;&#1604;&#1602;&#1575;&#1574;&#1610;&#1611;&#1575; &#1604;&#1581;&#1605;&#1575;&#1610;&#1577; &#1575;&#1604;&#1605;&#1606;&#1588;&#1571;&#1577; &#1608;&#1575;&#1604;&#1578;&#1606;&#1576;&#1610;&#1607; &#1576;&#1575;&#1604;&#1605;&#1578;&#1591;&#1604;&#1576;&#1575;&#1578; &#1575;&#1604;&#1606;&#1592;&#1575;&#1605;&#1610;&#1577; &#1575;&#1604;&#1581;&#1575;&#1604;&#1610;&#1577;.</p>
                    </div>
                    <div class="zatca-warning-countdown" id="zatcaWarningCountdown">&#1610;&#1605;&#1603;&#1606; &#1575;&#1604;&#1605;&#1578;&#1575;&#1576;&#1593;&#1577; &#1576;&#1593;&#1583; 20 &#1579;&#1575;&#1606;&#1610;&#1577;</div>
                    <label class="zatca-warning-ack" for="zatcaWarningAcknowledgement">
                        <input type="checkbox" id="zatcaWarningAcknowledgement" />
                        <span>&#1571;&#1602;&#1585; &#1576;&#1571;&#1606;&#1606;&#1610; &#1575;&#1591;&#1604;&#1593;&#1578; &#1593;&#1604;&#1609; &#1575;&#1604;&#1578;&#1581;&#1584;&#1610;&#1585; &#1575;&#1604;&#1606;&#1592;&#1575;&#1605;&#1610;</span>
                    </label>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-warning btn-lg btn-zatca-continue" id="zatcaWarningContinue" disabled>&#1610;&#1605;&#1603;&#1606; &#1575;&#1604;&#1605;&#1578;&#1575;&#1576;&#1593;&#1577; &#1576;&#1593;&#1583; 20 &#1579;&#1575;&#1606;&#1610;&#1577;</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        window.ZatcaComplianceWarning = (function () {
            var countdownSeconds = 20;
            var bypass = {};
            var activeDeferred = null;
            var timer = null;
            var throttleMinutes = 15;
            var throttleMilliseconds = throttleMinutes * 60 * 1000;
            var storageKey = 'MyERP.ZatcaComplianceWarning.LastAcknowledgedAt';
            var waitPrefix = '\u064a\u0645\u0643\u0646 \u0627\u0644\u0645\u062a\u0627\u0628\u0639\u0629 \u0628\u0639\u062f ';
            var waitSuffix = ' \u062b\u0627\u0646\u064a\u0629';
            var continueText = '\u0627\u0644\u0645\u062a\u0627\u0628\u0639\u0629 \u0639\u0644\u0649 \u0645\u0633\u0624\u0648\u0644\u064a\u0629 \u0627\u0644\u0645\u0633\u062a\u062e\u062f\u0645';
            var acknowledgeRequiredText = '\u064a\u062c\u0628 \u062a\u062d\u062f\u064a\u062f \u0627\u0644\u0625\u0642\u0631\u0627\u0631 \u0642\u0628\u0644 \u0627\u0644\u0645\u062a\u0627\u0628\u0639\u0629';

            function readLastAcknowledgedAt() {
                try {
                    return parseInt(window.localStorage.getItem(storageKey), 10) || 0;
                } catch (e) {
                    return 0;
                }
            }

            function markAcknowledged() {
                try {
                    window.localStorage.setItem(storageKey, String(new Date().getTime()));
                } catch (e) {
                }
            }

            function isThrottled() {
                var lastAcknowledgedAt = readLastAcknowledgedAt();
                return lastAcknowledgedAt > 0 && (new Date().getTime() - lastAcknowledgedAt) < throttleMilliseconds;
            }

            function resetModal() {
                clearInterval(timer);
                timer = null;
                $('#zatcaWarningAcknowledgement').prop('checked', false);
                $('#zatcaWarningContinue').prop('disabled', true).text(waitPrefix + countdownSeconds + waitSuffix);
                $('#zatcaWarningCountdown').text(waitPrefix + countdownSeconds + waitSuffix);
            }

            function refreshContinueButton(secondsLeft) {
                var acknowledged = $('#zatcaWarningAcknowledgement').prop('checked') === true;
                var canContinue = secondsLeft <= 0 && acknowledged;
                $('#zatcaWarningContinue')
                    .prop('disabled', !canContinue)
                    .text(secondsLeft > 0 ? waitPrefix + secondsLeft + waitSuffix : continueText);
            }

            function show() {
                if (isThrottled()) {
                    return $.Deferred().resolve().promise();
                }

                if (activeDeferred) {
                    return activeDeferred.promise();
                }

                activeDeferred = $.Deferred();
                resetModal();

                var secondsLeft = countdownSeconds;
                $('#zatcaComplianceWarningModal').modal({
                    backdrop: 'static',
                    keyboard: false,
                    show: true
                });

                timer = setInterval(function () {
                    secondsLeft -= 1;
                    if (secondsLeft <= 0) {
                        clearInterval(timer);
                        timer = null;
                        secondsLeft = 0;
                    }

                    $('#zatcaWarningCountdown').text(secondsLeft > 0 ? waitPrefix + secondsLeft + waitSuffix : acknowledgeRequiredText);
                    refreshContinueButton(secondsLeft);
                }, 1000);

                $('#zatcaWarningAcknowledgement').off('change.zatca').on('change.zatca', function () {
                    refreshContinueButton(secondsLeft);
                });

                $('#zatcaWarningContinue').off('click.zatca').on('click.zatca', function () {
                    if ($(this).prop('disabled')) {
                        return;
                    }

                    $('#zatcaComplianceWarningModal').modal('hide');
                    markAcknowledged();
                    activeDeferred.resolve();
                    activeDeferred = null;
                });

                return activeDeferred.promise();
            }

            function requiresConfirmation(context) {
                if (bypass[context]) {
                    delete bypass[context];
                    return false;
                }

                return !isThrottled();
            }

            function confirm(context, continuation) {
                if (isThrottled()) {
                    bypass[context] = true;
                    if (typeof continuation === 'function') {
                        continuation();
                    }
                    return;
                }

                show().done(function () {
                    bypass[context] = true;
                    if (typeof continuation === 'function') {
                        continuation();
                    }
                });
            }

            $(function () {
                if ($('#zatcaComplianceWarningModal').data('show-on-open') === true && !isThrottled()) {
                    show();
                }
            });

            return {
                confirm: confirm,
                requiresConfirmation: requiresConfirmation,
                show: show
            };
        })();
    </script>
}
