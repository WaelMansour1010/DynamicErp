    // Patch table
    function showPatch() {

        let itemPatches = [];
        let selectedId = $("#selectedId").val() !== "" ? $("#selectedId").val() : null;


        $.get('/Helper/PatchesPerDoc?systemPageId=55' + '&selectedId=' + selectedId).done(function (r) {
            itemPatches = r;
            let tr = '';
            console.log(itemPatches);
            for (var i = 0; i < itemPatches.length; i++) {
                tr += ('<tr><td><label>' + itemPatches[i].ItemArName + '</label></td><td><input hidden class="itemId" value="' + itemPatches[i].ItemId + '" /><input hidden class="itemPatchId" value="' + itemPatches[i].PatchId + '" /><input hidden class="itemBarcode" value="' + itemPatches[i].ItemBarcode + '" /><label class="itemPatchExpireDate">' + (itemPatches[i].ExpiryDate != null ? convertToJavaScriptDate(itemPatches[i].ExpiryDate) : '') + '</label></td ><td>' + itemPatches[i].Qty + '</td><td><button class="btn btn-info js-patch">' + '@MyERP.Properties.Resources.Print' + '</button></td></tr > ');
            }

            $('#item-patches').empty().append(tr);
        });
    }

    //------------------- ConvertDate-------------
    function convertToJavaScriptDate(value) {
        console.log(value)
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        return ((dt.getMonth() + 1 + "/" + dt.getDate() + "/" + dt.getFullYear()));
        // return (dt)
    }

    $("#patchTable").on('click', ".js-patch", function () {
        var button = $(this);
        var tr = button.closest("tr");
        var itemBarcode = tr.find(".itemBarcode").val();
        var expireDate = tr.find(".itemPatchExpireDate").text();
        var barcode = itemBarcode +"-*-"+ expireDate;
        var url = "/PurchaseInvoice/Barcode?barcode=" + barcode;
        window.open(url, '_blank');

    });

