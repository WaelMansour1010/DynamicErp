    function setWarehouseValues(warehouseId) {
        $('#WarehouseId').empty();
        $.get('/Helper/WarehousesByDepartmentId?id=' + $('#DepartmentId').val())
            .done(function (r) {
                Warehouses = r;
                $('#WarehouseId').append($('<option>', {
                    value: 0,
                    text: "@MyERP.Properties.Resources.Select"
                }));
                for (var i = 0; i < Warehouses.length; i++) {
                    $('#WarehouseId').append($('<option>', {
                        value: Warehouses[i].Id,
                        text: Warehouses[i].ArName
                    }));
                }
                warehouseId > 0 ? $('#WarehouseId').val(warehouseId).trigger('change') : null;
                $('.WarehouseId').each(function () {
                    var selectedWarehouse = $(this).val();
                    $(this).empty();
                    $(this).append($('<option>', {
                        value: 0,
                        text: "@MyERP.Properties.Resources.Select"
                    }));
                    for (var i = 0; i < Warehouses.length; i++) {
                        $(this).append($('<option>', {
                            value: Warehouses[i].Id,
                            text: Warehouses[i].ArName
                        }));
                    }
                    selectedWarehouse > 0 ? $(this).val(selectedWarehouse).trigger('change') : null;
                });
            });
    }

