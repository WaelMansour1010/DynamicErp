@model IEnumerable<MyERP.ViewModels.AllowedScreensViewModel>

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = "AllowedScreens";
    var groups = Model.GroupBy(x => string.IsNullOrEmpty(x.ModuleName) ? "Other" : x.ModuleName);
}

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <h4 class="page-title">Allowed Screens</h4>
        </div>
    </div>
</div>

@if (ViewBag.SchemaMissing == true)
{
    <div class="alert alert-warning">
        CompanyAllowedPages table is not installed. Run Scripts/CompanyAllowedPages_Setup.sql before saving.
    </div>
}

<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="form-horizontal needs-validation" role="form">
                <div class="card">
                    <div class="card-body">
                        <div class="form-group">
                            <label>
                                <input id="AllScreens" type="checkbox" onclick="checkAllScreens(this)" />
                                @MyERP.Properties.Resources.All
                            </label>
                        </div>

                        <div id="AllowedScreens">
                            @foreach (var group in groups)
                            {
                                <div class="panel panel-default allowed-screen-group">
                                    <div class="panel-heading">
                                        <label>
                                            <input type="checkbox" class="group-check" onclick="checkGroup(this)" />
                                            @group.Key
                                        </label>
                                    </div>
                                    <div class="panel-body">
                                        <table class="table table-hover table-condensed">
                                            <thead>
                                                <tr>
                                                    <th class="col-sm-5">@MyERP.Properties.Resources.Page</th>
                                                    <th class="col-sm-4">Controller</th>
                                                    <th class="col-sm-3">@MyERP.Properties.Resources.IsSelected</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var item in group)
                                                {
                                                    <tr>
                                                        <td>
                                                            @item.SystemPageName
                                                            <input type="hidden" class="SystemPageId" value="@item.SystemPageId" />
                                                        </td>
                                                        <td>@item.ControllerName</td>
                                                        <td>
                                                            <input class="IsSelected" type="checkbox"
                                                                   @Html.Raw(item.IsSelected ? "checked" : "")
                                                                   @Html.Raw(item.IsCritical ? "disabled data-critical=\"true\"" : "") />
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="col-sm-offset-2">
                            <button class="btn btn-success" onclick="saveAllowedScreens()">
                                @MyERP.Properties.Resources.Save
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function checkAllScreens(e) {
        $('.IsSelected:not([data-critical="true"])').prop('checked', $(e).prop('checked'));
    }

    function checkGroup(e) {
        $(e).closest('.allowed-screen-group').find('.IsSelected:not([data-critical="true"])').prop('checked', $(e).prop('checked'));
    }

    function saveAllowedScreens() {
        var allowedScreens = [];
        $('#AllowedScreens tr').each(function () {
            var row = $(this);
            var pageId = row.find('.SystemPageId').val();
            if (pageId) {
                allowedScreens.push({
                    SystemPageId: pageId,
                    IsSelected: row.find('.IsSelected').prop('checked')
                });
            }
        });

        $('#preloader, #status').fadeIn();
        $.ajax({
            type: 'POST',
            contentType: 'application/json',
            url: '/SystemSetting/AllowedScreens/',
            data: JSON.stringify({ allowedScreens: allowedScreens }),
            success: function (r) {
                if (r == 'true') {
                    alert('@MyERP.Properties.Resources.Saved' + '!');
                    window.location.reload();
                } else if (r == 'schema-missing') {
                    alert('CompanyAllowedPages table is not installed.');
                } else {
                    alert('@MyERP.Properties.Resources.NotSaved' + '!');
                }
                $('#preloader, #status').fadeOut();
            },
            error: function (r) {
                alert('@MyERP.Properties.Resources.NotSaved' + '!');
                console.log(r);
                $('#preloader, #status').fadeOut();
            }
        });
    }
</script>
