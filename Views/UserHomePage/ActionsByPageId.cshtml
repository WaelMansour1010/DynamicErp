@model IEnumerable<MyERP.Models.GetUserHomePage_Result>



@foreach (var item in Model)
{
<tr>
  @if(item.ArName!=null)
  {<td class="col-sm-8">

    <input class="pageid" type="hidden" value="@item.PageId" />
    @Html.DisplayFor(modelItem => item.ArName)

</td>
<td class="col-sm-4">
    <input type="checkbox" class="UserHome" @Html.Raw(item.Appear == 1 ? "checked" : "") />
</td>
  }
</tr>
}


