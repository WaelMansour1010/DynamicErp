@model MyERP.Models.UserHomePage
@{
    UICulture = Session["lang"] != null?Session["lang"].ToString():"ar";

    ViewBag.Title = MyERP.Properties.Resources.CustomizeUserIcons;
}

<div class="panel panel-widget forms-panel">
    <div class="row">
        <div class="col-12">
            <div class="page-title-box">
                <div class="hed page-title">@MyERP.Properties.Resources.CustomizeUserIcons</div>
            </div>
        </div>
    </div>
</div>  

@Html.ValidationSummary(true, "", new { @class = "text-danger" })
@if (Model != null)
{
    @Html.HiddenFor(model => model.Id)
}
<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal needs-validation" role="form">


                        <div class="card">
                            <div class="card-body">
                                <div class="form-group row">
                                    <label class=" col-sm-1 control-label" for="UserId">@MyERP.Properties.Resources.User</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("UserId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control" })
                                        @Html.ValidationMessageFor(model => model.UserId, "", new { @class = "text-danger" })
                                    </div>

                                    @*<label class="col-sm-1 control-label" for="PageId">الشاشة</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("PageId", null, "اختر", htmlAttributes: new { @class = "form-control" })
                                            @Html.ValidationMessageFor(model => model..PageId, "", new { @class = "text-danger" })
                                        </div>*@
                                </div>
                            </div>
                            <div class="card-body">
                                <div class="form-group row">
                                    <table class="table table-hover table-condensed">
                                        <thead>
                                            <tr>
                                                <th class="col-sm-8">@MyERP.Properties.Resources.Screen</th>
                                                <th class="col-sm-4">@MyERP.Properties.Resources.Show</th>
                                            </tr>
                                        </thead>
                                        <tbody id="UserHomePage"></tbody>
                                    </table>
                                </div>

                                <div style="float:left">

                                    <button class="btn btn-success" onclick="addEdit()">
                                        @MyERP.Properties.Resources.Save
                                    </button>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
            $(document).on('change', '#UserId', function () {
                $('#UserId').val() ? $('#preloader, #status').fadeIn() : null;
                $.get('/UserHomePage/ActionsByPageId?userId=' + $('#UserId').val()).done(function (r) {
                    $('#UserHomePage').empty();
                    $('#UserHomePage').append('<tr><td class="col-sm-8">' + '@MyERP.Properties.Resources.All' + '</td><td class="col-sm-4"><input type="checkbox" id="checkAll" onclick="checkAll()" /></td></tr>' + r);
                    $('#preloader, #status').fadeOut();
                });
            });
            $(document).on('change', 'input[type="checkbox"]:not("#checkAll")', function () {
                $(this).prop('checked') ? null : $('#checkAll').removeAttr('checked');
            });

            function checkAll() {
                if ($('#checkAll').prop('checked')) {
                    $('input[type="checkbox"]').prop('checked', 'checked');
                } else {
                    $('input[type="checkbox"]').prop('checked', false);;
                }
            }

            function addEdit() {
                var UserHomePage = [];
                $('#UserHomePage tr').each(function () {
                    var td = $(this);
                    var userhome = {
                        PageId: td.find('.pageid').val(),

                        UserId: $('#UserId').val(),
                        Appear: td.find('.UserHome').prop('checked')
                    };
                    UserHomePage.push(userhome);
                });

                $('#preloader, #status').fadeIn();
                $.ajax({
                    type: "POST",
                    contentType: "application/json",
                    url: '/userhomepage/Index/',
                    data: JSON.stringify({
                        userHomePage: UserHomePage
                    }),
                    success: function (r) {
                        if (r == 'true') {
                            alert('@MyERP.Properties.Resources.Saved'+'!');
                        } else {
                            alert('@MyERP.Properties.Resources.NotSaved'+'!');
                        }
                        $('#preloader, #status').fadeOut();
                    },
                    error: function (r) {
                        alert('@MyERP.Properties.Resources.NotSaved'+'!');
                        console.log(r);
                        $('#preloader, #status').fadeOut();
                    }
                })
            }
</script>
