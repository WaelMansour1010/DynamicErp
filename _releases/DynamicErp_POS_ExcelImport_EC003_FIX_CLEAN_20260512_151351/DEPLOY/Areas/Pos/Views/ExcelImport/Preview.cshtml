@model MyERP.Areas.Pos.Models.PosExcelImportPreviewViewModel
@{
    Layout = null;
    ViewBag.Title = "نتيجة معاينة Excel";
    var preview = Model != null ? Model.Preview : null;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title</title>
    <link href="@Url.Content("~/Areas/Pos/Content/pos-transaction.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Areas/Pos/Content/html-reports.css")" rel="stylesheet" />
    <style>
        .excel-import-page { padding: 18px; background: #f5f7fa; min-height: 100vh; }
        .import-kpis { display: grid; grid-template-columns: repeat(5, minmax(130px, 1fr)); gap: 10px; }
        .import-kpi { background: #fff; border: 1px solid #d8dee6; border-radius: 8px; padding: 12px; }
        .import-kpi span { color: #64748b; display: block; font-size: 12px; font-weight: 700; }
        .import-kpi strong { color: #0f172a; display: block; font-size: 22px; margin-top: 4px; }
        .status-chip { border-radius: 999px; display: inline-block; font-size: 12px; font-weight: 700; padding: 4px 9px; }
        .status-ready { background: #dcfce7; color: #166534; }
        .status-warning { background: #fef3c7; color: #92400e; }
        .status-rejected { background: #fee2e2; color: #991b1b; }
        .status-unmatched { background: #e0f2fe; color: #075985; }
        .preflight-list { display: grid; gap: 8px; }
        .preflight-item { border: 1px solid #d8dee6; border-radius: 8px; padding: 10px 12px; }
        .preflight-item strong { display: block; }
        .preflight-item small { color: #64748b; display: block; margin-top: 4px; }
        .import-error { background: #fee2e2; border: 1px solid #fecaca; border-radius: 8px; color: #991b1b; padding: 12px; }
        .reason-list { margin: 0; padding-right: 16px; }
        @@media (max-width: 900px) { .import-kpis { grid-template-columns: 1fr 1fr; } }
    </style>
</head>
<body>
<main class="html-report-page erp-ui-page excel-import-page">
    <header class="erp-hero-card">
        <div>
            <h1>نتيجة معاينة Excel</h1>
            <p>مطابقة وتحذيرات قبل الترحيل. الترحيل متاح بعد نجاح كل فحوصات preflight.</p>
        </div>
        <a class="erp-btn erp-btn-secondary" href="@Url.Action("Index", "ExcelImport", new { area = "Pos" })">ملف آخر</a>
    </header>

    @if (Model != null && !string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <section class="import-error">@Model.ErrorMessage</section>
    }

    @if (preview != null)
    {
        var canExecuteImport = ViewBag.CanImportExcel is bool && (bool)ViewBag.CanImportExcel;
        var canCommit = canExecuteImport && preview.EffectiveDefaults != null && preview.Rows.Any(x => x.Status != "Rejected" && x.Status != "ImportedBefore" && !string.IsNullOrWhiteSpace(x.InternalServiceType) && (x.InternalServiceType != "card" || !string.IsNullOrWhiteSpace(x.MatchedToken)));
        if (Model.CommitResult != null)
        {
            <section class="erp-card">
                <div class="erp-card-head">
                    <div>
                        <h2>نتيجة الترحيل</h2>
                        <p>Batch: @Model.CommitResult.BatchId - @Model.CommitResult.Status</p>
                    </div>
                </div>
                <div class="import-kpis">
                    <div class="import-kpi"><span>تم ترحيلها</span><strong>@Model.CommitResult.ImportedCount</strong></div>
                    <div class="import-kpi"><span>فشل</span><strong>@Model.CommitResult.FailedCount</strong></div>
                    <div class="import-kpi"><span>تم تركها</span><strong>@Model.CommitResult.SkippedCount</strong></div>
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.CommitResult.MarkedWorkbookFileName))
                {
                    <p style="margin-top:10px;">
                        <a class="erp-btn erp-btn-secondary" href="@Url.Action("DownloadMarked", "ExcelImport", new { area = "Pos", file = Model.CommitResult.MarkedWorkbookFileName })">
                            تحميل ملف Excel المعلّم
                        </a>
                    </p>
                }
                <div class="responsive-table" style="margin-top:12px;">
                    <table class="pos-table">
                        <thead><tr><th>الحالة</th><th>الشيت</th><th>الصف</th><th>IPN</th><th>الخدمة</th><th>الفاتورة</th><th>الرسالة</th></tr></thead>
                        <tbody>
                        @foreach (var item in Model.CommitResult.Rows)
                        {
                            <tr>
                                <td>@item.Status</td>
                                <td>@item.SheetName</td>
                                <td>@item.RowNumber</td>
                                <td>@item.IPN</td>
                                <td>@item.ServiceType</td>
                                <td>@item.TransactionId</td>
                                <td>@item.Message</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </section>
        }

        <section class="erp-card">
            <div class="erp-card-head">
                <div>
                    <h2>ملخص الملف</h2>
                    <p>@preview.SourceFileName</p>
                </div>
                <span class="status-chip status-unmatched">@preview.WorkbookType</span>
            </div>
            <div class="import-kpis">
                <div class="import-kpi"><span>جاهز</span><strong>@preview.ReadyCount</strong></div>
                <div class="import-kpi"><span>تحذيرات</span><strong>@preview.WarningCount</strong></div>
                <div class="import-kpi"><span>مرفوض</span><strong>@preview.RejectedCount</strong></div>
                <div class="import-kpi"><span>توكنات غير مطابقة</span><strong>@preview.UnmatchedTokenCount</strong></div>
                <div class="import-kpi"><span>الإجمالي</span><strong>@preview.TotalGross.ToString("N2")</strong></div>
            </div>
            <div class="preflight-list" style="margin-top:12px;">
                <div class="preflight-item">
                    <strong>هاش الملف</strong>
                    <small>@preview.SourceFileHash</small>
                </div>
                <div class="preflight-item">
                    <strong>الفرع المكتشف</strong>
                    @if (preview.DetectedBranch != null)
                    {
                        <small>@preview.DetectedBranch.BranchCode - @preview.DetectedBranch.BranchName (@preview.DetectedBranch.MatchRule)</small>
                    }
                    else
                    {
                        <small>@(string.IsNullOrWhiteSpace(preview.DetectedBranchHint) ? "غير معروف" : preview.DetectedBranchHint)</small>
                    }
                </div>
                <div class="preflight-item">
                    <strong>defaults الفعالة</strong>
                    @if (preview.EffectiveDefaults != null)
                    {
                        <small>المستخدم: @preview.EffectiveDefaults.UserId - @preview.EffectiveDefaults.UserName</small>
                        <small>المندوب: @preview.EffectiveDefaults.EmpId - @preview.EffectiveDefaults.EmpName</small>
                        <small>المخزن: @preview.EffectiveDefaults.StoreId - @preview.EffectiveDefaults.StoreName</small>
                        <small>الخزنة: @preview.EffectiveDefaults.BoxId - @preview.EffectiveDefaults.BoxName</small>
                        <small>الدفع: @preview.EffectiveDefaults.PaymentTypeId - @preview.EffectiveDefaults.PaymentName</small>
                    }
                    else
                    {
                        <small>لم تكتمل defaults بعد.</small>
                    }
                </div>
                <div class="preflight-item">
                    <strong>استراتيجية التوكن</strong>
                    <small>@preview.TokenMatchingStrategy</small>
                </div>
            </div>
        </section>

        <section class="erp-card">
            <div class="erp-card-head">
                <div>
                    <h2>Preflight</h2>
                    <p>حقول لا يسمح بتجاوزها بصمت قبل مرحلة الحفظ.</p>
                </div>
            </div>
            <div class="preflight-list">
                @foreach (var item in preview.PreflightItems)
                {
                    var statusClass = item.Status == "Mapped" ? "status-ready" : (item.Status == "Required" ? "status-rejected" : "status-warning");
                    <div class="preflight-item">
                        <strong>@item.FieldName <span class="status-chip @statusClass">@item.Status</span></strong>
                        <small>@item.Message</small>
                        @if (!string.IsNullOrWhiteSpace(item.Value))
                        {
                            <small>القيمة: @item.Value</small>
                        }
                    </div>
                }
            </div>
        </section>

        <section class="erp-card">
            <div class="erp-card-head">
                <div>
                    <h2>الشيتات المكتشفة</h2>
                    <p>الشيتات اليومية فقط يتم تحليلها.</p>
                </div>
            </div>
            <div class="responsive-table">
                <table class="pos-table">
                    <thead><tr><th>الشيت</th><th>التاريخ</th><th>صفوف العمليات</th><th>التوكنات</th><th>الإجمالي</th></tr></thead>
                    <tbody>
                    @foreach (var sheet in preview.Sheets)
                    {
                        <tr>
                            <td>@sheet.SheetName</td>
                            <td>@sheet.SheetDateText</td>
                            <td>@sheet.TransactionRows</td>
                            <td>@sheet.TokenRows</td>
                            <td>@sheet.SheetTotal.ToString("N2")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="erp-card">
            <div class="erp-card-head">
                <div>
                    <h2>مطابقة التوكنات</h2>
                    <p>المطابقة الحالية متسلسلة داخل نفس الشيت، ومرئية قبل أي commit.</p>
                </div>
            </div>
            <div class="responsive-table">
                <table class="pos-table">
                    <thead><tr><th>الشيت</th><th>صف العملية</th><th>IPN</th><th>العميل</th><th>الإجمالي</th><th>صف التوكن</th><th>التوكن</th><th>الحالة</th></tr></thead>
                    <tbody>
                    @if (preview.TokenMatches.Count == 0)
                    {
                        <tr><td colspan="8">لا توجد مطابقات توكن.</td></tr>
                    }
                    else
                    {
                        foreach (var match in preview.TokenMatches)
                        {
                            <tr>
                                <td>@match.SheetName</td>
                                <td>@match.SourceRowNumber</td>
                                <td>@match.IPN</td>
                                <td>@match.CustomerName</td>
                                <td>@(match.GrossTotal.HasValue ? match.GrossTotal.Value.ToString("N2") : "")</td>
                                <td>@match.TokenRowNumber</td>
                                <td>@match.Token</td>
                                <td><span class="status-chip status-ready">@match.MatchStatus</span></td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="erp-card">
            <div class="erp-card-head">
                <div>
                    <h2>نتائج الصفوف</h2>
                    <p>جاهز / تحذير / مرفوض مع السبب.</p>
                </div>
            </div>
            <div class="responsive-table">
                <table class="pos-table">
                    <thead>
                        <tr>
                            <th>الحالة</th>
                            <th>الشيت</th>
                            <th>الصف</th>
                            <th>IPN</th>
                            <th>العميل</th>
                            <th>الهاتف</th>
                            <th>الخدمة</th>
                            <th>نوع POS</th>
                            <th>صنف POS الافتراضي</th>
                            <th>KYC</th>
                            <th>التاريخ</th>
                            <th>الشحنة</th>
                            <th>الرسوم</th>
                            <th>الإجمالي</th>
                            <th>الأسباب</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var row in preview.Rows)
                    {
                        var statusClass = row.Status == "Ready" ? "status-ready" : (row.Status == "Warning" ? "status-warning" : "status-rejected");
                        <tr>
                            <td><span class="status-chip @statusClass">@row.Status</span></td>
                            <td>@row.SheetName</td>
                            <td>@row.RowNumber</td>
                            <td>@row.IPN</td>
                            <td>@row.CustomerName</td>
                            <td>@row.Phone</td>
                            <td>@row.ServiceType</td>
                            <td>@row.InternalServiceName</td>
                            <td>@(row.ServiceItemId.HasValue ? row.ServiceItemId.Value.ToString() + " - " + row.ServiceItemName : "")</td>
                            <td>@(row.RequiresKycCreation ? "إنشاء KYC قبل الحفظ" : "")</td>
                            <td>@(row.TransactionDate.HasValue ? row.TransactionDate.Value.ToString("yyyy-MM-dd") : row.TransactionDateText)</td>
                            <td>@(row.Amount.HasValue ? row.Amount.Value.ToString("N2") : "")</td>
                            <td>@(row.Fee.HasValue ? row.Fee.Value.ToString("N2") : "")</td>
                            <td>@(row.GrossTotal.HasValue ? row.GrossTotal.Value.ToString("N2") : "")</td>
                            <td>
                                @if (row.Reasons.Count > 0)
                                {
                                    <ul class="reason-list">
                                        @foreach (var reason in row.Reasons)
                                        {
                                            <li>@reason</li>
                                        }
                                    </ul>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="erp-card">
            <div class="erp-card-head">
                <div>
                    <h2>التوكنات غير المطابقة</h2>
                    <p>لا يسمح بحفظ توكن غير مطابق بشكل حتمي ومرئي.</p>
                </div>
            </div>
            <div class="responsive-table">
                <table class="pos-table">
                    <thead><tr><th>الحالة</th><th>الشيت</th><th>الصف</th><th>التوكن</th><th>الأسباب</th></tr></thead>
                    <tbody>
                    @foreach (var token in preview.Tokens)
                    {
                        if (token.Status == "Matched")
                        {
                            continue;
                        }
                        <tr>
                            <td><span class="status-chip status-unmatched">@token.Status</span></td>
                            <td>@token.SheetName</td>
                            <td>@token.RowNumber</td>
                            <td>@token.Token</td>
                            <td>
                                <ul class="reason-list">
                                    @foreach (var reason in token.Reasons)
                                    {
                                        <li>@reason</li>
                                    }
                                </ul>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="erp-card">
            <form id="excelCommitForm" method="post" action="@Url.Action("Commit", "ExcelImport", new { area = "Pos" })" data-start-url="@Url.Action("StartCommit", "ExcelImport", new { area = "Pos" })" data-rollback-url="@Url.Action("StartRollback", "ExcelImport", new { area = "Pos" })" data-progress-url="@Url.Action("CommitProgress", "ExcelImport", new { area = "Pos" })" data-download-url="@Url.Action("DownloadMarked", "ExcelImport", new { area = "Pos" })" data-can-execute-import="@(canExecuteImport ? "true" : "false")">
                @Html.AntiForgeryToken()
                @if (!canExecuteImport)
                {
                    <p style="margin-top:8px;color:#991b1b;">&#1604;&#1610;&#1587;&#1578; &#1604;&#1583;&#1610;&#1603; &#1589;&#1604;&#1575;&#1581;&#1610;&#1577; &#1578;&#1606;&#1601;&#1610;&#1584; &#1575;&#1587;&#1578;&#1610;&#1585;&#1575;&#1583; Excel.</p>
                }
                else
                {
                <button id="excelCommitButton" type="submit" class="erp-btn erp-btn-primary" @(canCommit ? "" : "disabled")>
                    <i class="fas fa-check" aria-hidden="true"></i>
                    <span>ترحيل الفواتير الجاهزة</span>
                </button>
                <button id="excelRollbackButton" type="button" class="erp-btn erp-btn-secondary" style="display:none;margin-inline-start:8px;">
                    <i class="fas fa-undo" aria-hidden="true"></i>
                    <span>تراجع عن فواتير Excel</span>
                </button>
                }
                @if (!canCommit)
                {
                    <p style="margin-top:8px;color:#991b1b;">لا توجد صفوف جاهزة للترحيل أو أن defaults غير مكتملة. الصفوف المرفوضة لن تمنع ترحيل الصفوف السليمة.</p>
                }
            </form>
            <div id="excelCommitProgress" style="display:none;margin-top:14px;">
                <div style="display:flex;justify-content:space-between;gap:12px;align-items:center;margin-bottom:8px;">
                    <strong id="excelCommitProgressTitle">جاري الترحيل...</strong>
                    <span id="excelCommitProgressPercent">0%</span>
                </div>
                <div style="height:12px;background:#e5e7eb;border-radius:999px;overflow:hidden;">
                    <div id="excelCommitProgressBar" style="height:12px;width:0%;background:#16a34a;border-radius:999px;transition:width .25s ease;"></div>
                </div>
                <div class="import-kpis" style="margin-top:12px;">
                    <div class="import-kpi"><span>المعالج</span><strong id="excelCommitProcessed">0 / 0</strong></div>
                    <div class="import-kpi"><span>تم ترحيلها</span><strong id="excelCommitImported">0</strong></div>
                    <div class="import-kpi"><span>تم تركها</span><strong id="excelCommitSkipped">0</strong></div>
                    <div class="import-kpi"><span>فشل</span><strong id="excelCommitFailed">0</strong></div>
                </div>
                <p id="excelCommitCurrent" style="margin-top:10px;color:#374151;"></p>
                <p id="excelCommitDownload" style="display:none;margin-top:10px;"></p>
            </div>
        </section>
    }
</main>
<script>
(function () {
    var form = document.getElementById('excelCommitForm');
    if (!form) { return; }

    var button = document.getElementById('excelCommitButton');
    var panel = document.getElementById('excelCommitProgress');
    var bar = document.getElementById('excelCommitProgressBar');
    var percentText = document.getElementById('excelCommitProgressPercent');
    var title = document.getElementById('excelCommitProgressTitle');
    var processed = document.getElementById('excelCommitProcessed');
    var imported = document.getElementById('excelCommitImported');
    var skipped = document.getElementById('excelCommitSkipped');
    var failed = document.getElementById('excelCommitFailed');
    var current = document.getElementById('excelCommitCurrent');
    var download = document.getElementById('excelCommitDownload');
    var rollbackButton = document.getElementById('excelRollbackButton');
    var currentJobId = null;
    var canExecuteImport = form.getAttribute('data-can-execute-import') === 'true';

    function token() {
        var input = form.querySelector('input[name="__RequestVerificationToken"]');
        return input ? input.value : '';
    }

    function post(url, body, callback) {
        var xhr = new XMLHttpRequest();
        xhr.open('POST', url, true);
        xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded; charset=UTF-8');
        xhr.onreadystatechange = function () {
            if (xhr.readyState === 4) {
                callback(xhr.status, xhr.responseText);
            }
        };
        xhr.send(body);
    }

    function getJson(url, callback) {
        var xhr = new XMLHttpRequest();
        xhr.open('GET', url, true);
        xhr.onreadystatechange = function () {
            if (xhr.readyState === 4) {
                callback(xhr.status, xhr.responseText);
            }
        };
        xhr.send();
    }

    function updateProgress(data) {
        var pct = data.percent || 0;
        panel.style.display = 'block';
        bar.style.width = pct + '%';
        percentText.textContent = pct + '%';
        processed.textContent = (data.processedCount || 0) + ' / ' + (data.totalCount || 0);
        imported.textContent = data.importedCount || 0;
        skipped.textContent = data.skippedCount || 0;
        failed.textContent = data.failedCount || 0;
        title.textContent = data.isDone ? 'انتهى الترحيل' : 'جاري الترحيل...';
        current.textContent = (data.currentSheet ? ('الشيت: ' + data.currentSheet + ' - صف: ' + data.currentRowNumber + ' - ') : '') + (data.currentMessage || '');

        if (data.markedWorkbookFileName) {
            var href = form.getAttribute('data-download-url') + '?file=' + encodeURIComponent(data.markedWorkbookFileName);
            download.style.display = 'block';
            download.innerHTML = '<a class="erp-btn erp-btn-secondary" href="' + href + '">تحميل ملف Excel المعلّم</a>';
        }

        if (rollbackButton) {
            rollbackButton.style.display = data.canRollback ? 'inline-flex' : 'none';
            rollbackButton.disabled = false;
        }
    }

    function poll(jobId) {
        var url = form.getAttribute('data-progress-url') + '?jobId=' + encodeURIComponent(jobId);
        getJson(url, function (status, text) {
            var data;
            try { data = JSON.parse(text); } catch (e) { data = { ok: false, message: text }; }
            if (!data.ok) {
                current.textContent = data.message || 'تعذر قراءة حالة الترحيل.';
                if (button) { button.disabled = false; }
                return;
            }

            currentJobId = jobId;
            updateProgress(data);
            if (!data.isDone) {
                window.setTimeout(function () { poll(jobId); }, 1000);
            } else if (button) {
                button.disabled = false;
            }
        });
    }

    form.addEventListener('submit', function (event) {
        event.preventDefault();
        if (!canExecuteImport) {
            current.textContent = '\u0644\u064a\u0633\u062a \u0644\u062f\u064a\u0643 \u0635\u0644\u0627\u062d\u064a\u0629 \u062a\u0646\u0641\u064a\u0630 \u0627\u0633\u062a\u064a\u0631\u0627\u062f Excel.';
            return;
        }
        if (button && button.disabled) { return; }

        var adminPassword = window.prompt('\u0623\u062f\u062e\u0644 \u0643\u0644\u0645\u0629 \u0645\u0631\u0648\u0631 \u0627\u0644\u0645\u0633\u062a\u062e\u062f\u0645 \u0644\u062a\u0623\u0643\u064a\u062f \u062a\u0646\u0641\u064a\u0630 \u0627\u0633\u062a\u064a\u0631\u0627\u062f Excel');
        if (!adminPassword) {
            current.textContent = '\u0644\u0645 \u064a\u062a\u0645 \u0627\u0644\u062a\u0646\u0641\u064a\u0630: \u0643\u0644\u0645\u0629 \u0627\u0644\u0645\u0631\u0648\u0631 \u0645\u0637\u0644\u0648\u0628\u0629.';
            return;
        }

        if (button) { button.disabled = true; }
        panel.style.display = 'block';
        current.textContent = 'بدء عملية الترحيل...';
        download.style.display = 'none';

        post(form.getAttribute('data-start-url'), '__RequestVerificationToken=' + encodeURIComponent(token()) + '&adminPassword=' + encodeURIComponent(adminPassword), function (status, text) {
            var data;
            try { data = JSON.parse(text); } catch (e) { data = { ok: false, message: text }; }
            if (!data.ok) {
                current.textContent = data.message || 'تعذر بدء الترحيل.';
                if (button) { button.disabled = false; }
                return;
            }

            currentJobId = data.jobId;
            poll(data.jobId);
        });
    });

    if (rollbackButton) {
        rollbackButton.addEventListener('click', function () {
            if (!currentJobId || rollbackButton.disabled) { return; }
            if (!canExecuteImport) { return; }
            if (!window.confirm('سيتم حذف كل الفواتير التي تم إنشاؤها من ملف Excel الحالي وحذف قيودها وسنداتها إن وجدت. هل تريد المتابعة؟')) {
                return;
            }

            var adminPassword = window.prompt('\u0623\u062f\u062e\u0644 \u0643\u0644\u0645\u0629 \u0645\u0631\u0648\u0631 \u0627\u0644\u0645\u0633\u062a\u062e\u062f\u0645 \u0644\u062a\u0623\u0643\u064a\u062f \u0627\u0644\u062a\u0631\u0627\u062c\u0639');
            if (!adminPassword) {
                current.textContent = '\u0644\u0645 \u064a\u062a\u0645 \u0627\u0644\u062a\u0631\u0627\u062c\u0639: \u0643\u0644\u0645\u0629 \u0627\u0644\u0645\u0631\u0648\u0631 \u0645\u0637\u0644\u0648\u0628\u0629.';
                return;
            }

            rollbackButton.disabled = true;
            if (button) { button.disabled = true; }
            title.textContent = 'جاري التراجع...';
            current.textContent = 'بدء التراجع عن فواتير Excel...';

            post(form.getAttribute('data-rollback-url'), '__RequestVerificationToken=' + encodeURIComponent(token()) + '&jobId=' + encodeURIComponent(currentJobId) + '&adminPassword=' + encodeURIComponent(adminPassword), function (status, text) {
                var data;
                try { data = JSON.parse(text); } catch (e) { data = { ok: false, message: text }; }
                if (!data.ok) {
                    current.textContent = data.message || 'تعذر بدء التراجع.';
                    rollbackButton.disabled = false;
                    if (button) { button.disabled = false; }
                    return;
                }

                poll(data.jobId);
            });
        });
    }
})();
</script>
</body>
</html>
