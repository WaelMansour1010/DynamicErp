@model MyERP.Areas.MainErp.ViewModels.AccountCharts.AccountChartsIndexViewModel
@using Newtonsoft.Json
@{
    Layout = "~/Areas/MainErp/Views/Shared/_MainErpLayout.cshtml";
    ViewBag.Title = "دليل الحسابات";
}

<link href="@Url.Content("~/Areas/MainErp/Content/account-charts.css")" rel="stylesheet" />

<section class="account-charts-page" dir="rtl"
         data-details-url="@Url.Action("Details", "AccountCharts", new { area = "MainErp" })"
         data-tree-url="@Url.Action("Tree", "AccountCharts", new { area = "MainErp" })"
         data-create-url="@Url.Action("Create", "AccountCharts", new { area = "MainErp" })"
         data-update-url="@Url.Action("Update", "AccountCharts", new { area = "MainErp" })"
         data-delete-url="@Url.Action("Delete", "AccountCharts", new { area = "MainErp" })">
    @Html.AntiForgeryToken()

    <header class="erp-page-header account-charts-header">
        <div>
            <span class="account-charts-kicker">FrmAccountCharts</span>
            <h1>دليل الحسابات</h1>
            <p>شجرة الحسابات المحاسبية مع البحث والإضافة والتعديل والحذف الآمن وفق صلاحيات النظام.</p>
        </div>
        <div class="account-charts-actions">
            <button type="button" class="erp-icon-btn" id="accountChartsRefresh" title="تحديث"><i class="fas fa-sync-alt"></i></button>
            <button type="button" class="erp-icon-btn" id="accountChartsPrint" title="طباعة" @(Model.Permissions.CanPrint ? "" : "disabled")><i class="fas fa-print"></i></button>
            <button type="button" class="erp-primary-btn" id="accountChartsNew" @(Model.Permissions.CanAdd ? "" : "disabled")><i class="fas fa-plus"></i><span>حساب جديد</span></button>
        </div>
    </header>

    <div class="account-charts-shell">
        <aside class="account-charts-tree-panel">
            <div class="account-charts-search">
                <i class="fas fa-search"></i>
                <input type="search" id="accountChartsSearch" placeholder="بحث بالاسم أو رقم الحساب" autocomplete="off" />
            </div>
            <div class="account-charts-count"><strong>@Model.TotalAccounts</strong><span>حساب</span></div>
            <div id="accountChartsTree" class="account-charts-tree" aria-label="شجرة الحسابات"></div>
        </aside>

        <main class="account-charts-editor">
            <div class="account-charts-toolbar">
                <div>
                    <h2 id="accountChartsEditorTitle">بيانات الحساب</h2>
                    <span id="accountChartsModeLabel">عرض</span>
                </div>
                <div class="account-charts-toolbar-actions">
                    <button type="button" class="erp-secondary-btn" id="accountChartsEdit" @(Model.Permissions.CanEdit ? "" : "disabled")><i class="fas fa-pen"></i><span>تعديل</span></button>
                    <button type="button" class="erp-danger-btn" id="accountChartsDelete" @(Model.Permissions.CanDelete ? "" : "disabled")><i class="fas fa-trash"></i><span>حذف</span></button>
                    <button type="button" class="erp-secondary-btn" id="accountChartsCancel"><i class="fas fa-undo"></i><span>تراجع</span></button>
                    <button type="button" class="erp-primary-btn" id="accountChartsSave"><i class="fas fa-save"></i><span>حفظ</span></button>
                </div>
            </div>

            <div id="accountChartsMessage" class="account-charts-message" hidden></div>

            <form id="accountChartsForm" class="account-charts-form" novalidate>
                <input type="hidden" name="Mode" id="accountChartsMode" value="view" />
                <input type="hidden" name="AccountCode" id="AccountCode" />
                <input type="hidden" name="AccountId" id="AccountId" />

                <section class="account-charts-section">
                    <h3>البيانات الأساسية</h3>
                    <div class="account-charts-grid">
                        <label>
                            <span>رقم الحساب</span>
                            <input type="text" name="AccountSerial" id="AccountSerial" maxlength="100" required />
                        </label>
                        <label>
                            <span>اسم الحساب عربي</span>
                            <input type="text" name="AccountName" id="AccountName" maxlength="4000" required />
                        </label>
                        <label>
                            <span>اسم الحساب إنجليزي</span>
                            <input type="text" name="AccountNameEnglish" id="AccountNameEnglish" maxlength="4000" />
                        </label>
                        <label>
                            <span>الحساب الأب</span>
                            <select name="ParentAccountCode" id="ParentAccountCode">
                            </select>
                        </label>
                        <label>
                            <span>العملة</span>
                            <select name="CurrencyCode" id="CurrencyCode">
                                @foreach (var item in Model.Currencies)
                                {
                                    <option value="@item.Id">@item.Text</option>
                                }
                            </select>
                        </label>
                        <label>
                            <span>طبيعة النشاط</span>
                            <select name="ActivityTypeId" id="ActivityTypeId">
                                <option value="">بدون</option>
                                @foreach (var item in Model.ActivityTypes)
                                {
                                    <option value="@item.Id">@item.Text</option>
                                }
                            </select>
                        </label>
                    </div>
                </section>

                <section class="account-charts-section">
                    <h3>تصنيف الحساب</h3>
                    <div class="account-charts-options">
                        <label><input type="radio" name="IsLastAccount" value="true" id="IsLastAccountFinal" /> حساب نهائي</label>
                        <label><input type="radio" name="IsLastAccount" value="false" id="IsLastAccountMaster" /> حساب رئيسي</label>
                        <label><input type="checkbox" name="HasBudget" id="HasBudget" value="true" /> له موازنة</label>
                        <label><input type="checkbox" name="IsSummaryAccount" id="IsSummaryAccount" value="true" /> حساب تجميعي</label>
                        <label><input type="checkbox" name="IsBlocked" id="IsBlocked" value="true" /> إيقاف التعامل</label>
                    </div>
                    <div class="account-charts-grid">
                        <label>
                            <span>طبيعة الحساب</span>
                            <select name="AccountTypes" id="AccountTypes">
                                <option value="0">Without</option>
                                <option value="1">Balance Sheet</option>
                                <option value="2">Income Statement</option>
                            </select>
                        </label>
                        <label>
                            <span>تبويب الحساب</span>
                            <select name="AccountTab" id="AccountTab">
                                <option value="0">Assets</option>
                                <option value="1">Liabilities</option>
                                <option value="2">Revenue</option>
                                <option value="3">Expenses</option>
                                <option value="4">Legal Acc.</option>
                            </select>
                        </label>
                        <label>
                            <span>طبيعة الرصيد</span>
                            <select name="DebitOrCredit" id="DebitOrCredit">
                                <option value="0">مدين</option>
                                <option value="1">دائن</option>
                            </select>
                        </label>
                        <label>
                            <span>عند مخالفة طبيعة الحساب</span>
                            <select name="DifferentType" id="DifferentType">
                                <option value="0">منع العملية</option>
                                <option value="1">تحذير فقط</option>
                            </select>
                        </label>
                    </div>
                </section>

                <section class="account-charts-section">
                    <h3>مركز التكلفة والصلاحية</h3>
                    <div class="account-charts-options">
                        <label><input type="checkbox" name="HasCostCenter" id="HasCostCenter" value="true" /> له مركز تكلفة</label>
                        <label><input type="radio" name="CostCenterType" value="0" id="CostCenterNone" /> غير محدد</label>
                        <label><input type="radio" name="CostCenterType" value="1" id="CostCenterFixed" /> محدد</label>
                    </div>
                    <div class="account-charts-grid">
                        <label>
                            <span>مركز التكلفة</span>
                            <select name="CostCenterId" id="CostCenterId">
                                <option value="">بدون</option>
                                @foreach (var item in Model.CostCenters)
                                {
                                    <option value="@item.Id">@item.Text</option>
                                }
                            </select>
                        </label>
                        <label>
                            <span>صلاحية التعامل</span>
                            <select name="Authority" id="Authority">
                                <option value="0">كل المستخدمين</option>
                                <option value="1">مجموعة</option>
                                <option value="2">مستخدم</option>
                            </select>
                        </label>
                        <label>
                            <span>المجموعة</span>
                            <select name="UserGroupId" id="UserGroupId">
                                <option value="">بدون</option>
                                @foreach (var item in Model.Groups)
                                {
                                    <option value="@item.Id">@item.Text</option>
                                }
                            </select>
                        </label>
                        <label>
                            <span>المستخدم</span>
                            <select name="UserId" id="UserId">
                                <option value="">بدون</option>
                                @foreach (var item in Model.Users)
                                {
                                    <option value="@item.Id">@item.Text</option>
                                }
                            </select>
                        </label>
                    </div>
                </section>

                <section class="account-charts-section account-charts-lists">
                    <h3>الفروع والمستخدمون</h3>
                    <div class="account-charts-grid two">
                        <label>
                            <span>الفروع المسموحة</span>
                            <select name="BranchIds" id="BranchIds" multiple size="8">
                                @foreach (var item in Model.Branches)
                                {
                                    <option value="@item.Id">@item.Text</option>
                                }
                            </select>
                        </label>
                        <label>
                            <span>المستخدمون المسموحون</span>
                            <select name="UserIds" id="UserIds" multiple size="8">
                                @foreach (var item in Model.Users)
                                {
                                    <option value="@item.Id">@item.Text</option>
                                }
                            </select>
                        </label>
                    </div>
                </section>
            </form>
        </main>
    </div>
</section>

<script id="accountChartsInitialTree" type="application/json">[]</script>
<script id="accountChartsPermissions" type="application/json">@Html.Raw(JsonConvert.SerializeObject(Model.Permissions))</script>
<script src="@Url.Content("~/Areas/MainErp/Scripts/account-charts.js")"></script>
