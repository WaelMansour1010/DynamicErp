@model MyERP.Areas.MainErp.ViewModels.JournalEntries.JournalEntryDetailsViewModel
@using MyERP.Areas.MainErp.Infrastructure.Localization
@{
    Layout = "~/Areas/MainErp/Views/Shared/_MainErpLayout.cshtml";
    Func<string, string> T = MainErpLocalizationService.T;
    ViewBag.Title = T("JournalEntryDetails");
    ViewBag.ActiveScreen = "journal-entries";
}

<section class="main-erp-panel main-erp-journal-details">
    <div class="main-erp-title-row">
        <div>
            <span class="main-erp-kicker">@T("ReadOnly")</span>
            <h3>@T("JournalEntryDetails")</h3>
            <p>@T("JournalEntryDetailsIntro")</p>
        </div>
        <span class="main-erp-badge">@T("ReadOnly")</span>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Warning))
    {
        <div class="main-erp-warning">@Model.Warning</div>
    }
    @foreach (var warning in Model.Warnings)
    {
        <div class="main-erp-warning">@warning</div>
    }

    <div class="main-erp-vb6-toolbar">
        <a href="@Url.Action("Index", "JournalEntries", new { area = "MainErp" })">@T("Back")</a>
        @if (Model.TblLCID.HasValue)
        {
            <a href="@Url.Action("Open", "LC", new { area = "MainErp", id = Model.TblLCID.Value })">@T("LettersOfCredit")</a>
        }
        <button type="button" class="is-disabled-action">@T("Edit")</button>
        <button type="button" class="is-disabled-action">@T("Reports")</button>
    </div>

    <section class="main-erp-lc-strip">
        <div><span>@T("Source")</span><strong>@Model.SourceTable</strong></div>
        <div><span>NoteID</span><strong>@Model.NoteId</strong></div>
        <div><span>@T("Voucher")</span><strong>@Model.VoucherId</strong></div>
        <div><span>@T("NoteSerial")</span><strong>@Model.NoteSerial</strong></div>
        <div><span>@T("NoteType")</span><strong>@Model.NoteType</strong></div>
        <div><span>@T("Date")</span><strong>@String.Format("{0:yyyy-MM-dd}", Model.NoteDate)</strong></div>
        <div><span>LC</span><strong>@Model.TblLCID</strong></div>
        <div><span>@T("Difference")</span><strong>@Model.Difference.ToString("N2")</strong></div>
    </section>

    <dl class="main-erp-details">
        <dt>@T("Description")</dt>
        <dd>@Model.Remark</dd>
        <dt>@T("Value")</dt>
        <dd>@String.Format("{0:n2}", Model.NoteValue)</dd>
    </dl>

    <table class="main-erp-table">
        <thead>
            <tr>
                <th>@T("Source")</th>
                <th>@T("Voucher")</th>
                <th>Line</th>
                <th>@T("Note")</th>
                <th>@T("Date")</th>
                <th>@T("Account")</th>
                <th>@T("Debit")</th>
                <th>@T("Credit")</th>
                <th>@T("Branch")</th>
                <th>@T("Projects")</th>
                <th>@T("Description")</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Lines.Count == 0)
            {
                <tr><td colspan="11">@T("NoRows")</td></tr>
            }
            else
            {
                foreach (var line in Model.Lines)
                {
                    <tr>
                        <td>@line.SourceTable</td>
                        <td>@line.VoucherId</td>
                        <td>@line.LineNo</td>
                        <td>@line.NoteId</td>
                        <td>@String.Format("{0:yyyy-MM-dd}", line.RecordDate)</td>
                        <td>@(string.IsNullOrWhiteSpace(line.AccountDisplay) ? T("AccountNotFound") : line.AccountDisplay)</td>
                        <td>@line.Debit.ToString("N2")</td>
                        <td>@line.Credit.ToString("N2")</td>
                        <td>@line.BranchId</td>
                        <td>@line.ProjectId</td>
                        <td>@line.Description</td>
                    </tr>
                }
            }
        </tbody>
        <tfoot>
            <tr>
                <th colspan="6">@T("Totals")</th>
                <th>@Model.TotalDebit.ToString("N2")</th>
                <th>@Model.TotalCredit.ToString("N2")</th>
                <th colspan="3">@T("Difference"): @Model.Difference.ToString("N2")</th>
            </tr>
        </tfoot>
    </table>
</section>

<script>
    (function () {
        var buttons = document.querySelectorAll(".main-erp-journal-details .is-disabled-action");
        for (var i = 0; i < buttons.length; i++) {
            buttons[i].addEventListener("click", function () {
                alert("@T("DisabledReadOnlyMessage")");
            });
        }
    })();
</script>
