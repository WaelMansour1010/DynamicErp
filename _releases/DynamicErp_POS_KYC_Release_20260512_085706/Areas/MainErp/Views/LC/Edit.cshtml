@model MyERP.Areas.MainErp.ViewModels.LC.LCEditViewModel
@{
    Layout = "~/Areas/MainErp/Views/Shared/_MainErpLayout.cshtml";
    var isEdit = Model.TblLCID.HasValue && Model.TblLCID.Value > 0;
    ViewBag.Title = isEdit ? "تعديل اعتماد مستندي" : "إضافة اعتماد مستندي";
    Func<decimal?, string> money = v => String.Format("{0:n2}", v ?? 0m);
    var marginVoucherValue = (Model.Value ?? 0m) * ((Model.PercentV ?? 0m) / 100m) * (Model.CurrencyRate ?? 1m);
    var expenseVoucherValue = (Model.OpenValue ?? 0m) * (Model.CurrencyRate ?? 1m);
}

<section class="main-erp-lc-editor" dir="rtl">
    <header class="lc-editor-hero">
        <div>
            <span class="main-erp-kicker">FrmLC Real Migration</span>
            <h2>@ViewBag.Title</h2>
            <p>شاشة تشغيل للاعتمادات المستندية مطابقة لمنطق VB6 قدر الإمكان، مع حفظ آمن وإنشاء قيود الاعتماد المؤكدة فقط.</p>
        </div>
        <div class="lc-editor-actions">
            <a href="@Url.Action("Index", "LC", new { area = "MainErp", selectedId = Model.TblLCID })">رجوع للـ Workbench</a>
            @if (isEdit)
            {
                <a href="@Url.Action("Index", "LC", new { area = "MainErp", selectedId = Model.TblLCID })">فتح الاعتماد</a>
            }
            <button type="button" class="lc-disabled-action">حذف</button>
            <button type="button" class="lc-disabled-action">إعادة بناء القيود</button>
        </div>
    </header>

    @if (!String.IsNullOrWhiteSpace(Model.Warning))
    {
        <div class="main-erp-warning">@Model.Warning</div>
    }

    @if (Model.HasPostedVoucher)
    {
        <div class="main-erp-warning">
            يوجد قيود مرتبطة بهذا الاعتماد. التعديل هنا لا يعيد بناء القيود تلقائيًا، وأي تعديل مالي يحتاج مراجعة قبل إعادة الترحيل.
        </div>
    }

    <section class="lc-editor-summary">
        <article>
            <span>رقم الاعتماد</span>
            <strong>@(String.IsNullOrWhiteSpace(Model.LCNO) ? "اعتماد جديد" : Model.LCNO)</strong>
            <small>LCNO</small>
        </article>
        <article>
            <span>قيمة الاعتماد</span>
            <strong>@money(Model.Value)</strong>
            <small>قبل تأثير سعر الصرف</small>
        </article>
        <article>
            <span>قيد فتح الاعتماد المتوقع</span>
            <strong>@money(marginVoucherValue)</strong>
            <small>Value * PercentV / 100 * Rate</small>
        </article>
        <article>
            <span>قيد مصاريف الفتح المتوقع</span>
            <strong>@money(expenseVoucherValue)</strong>
            <small>OpenValue * Rate</small>
        </article>
        <article class="@(Model.Locked ? "is-warning" : "is-ok")">
            <span>الحالة</span>
            <strong>@(Model.Locked ? "مغلق" : "نشط / مسودة")</strong>
            <small>تتحكم في الإغلاق فقط</small>
        </article>
    </section>

    @using (Html.BeginForm("Save", "LC", new { area = "MainErp" }, FormMethod.Post, new { @class = "lc-editor-form", data_lc_editor = "1" }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(x => x.TblLCID)
        @Html.HiddenFor(x => x.HasPostedVoucher)

        <div class="lc-editor-shell">
            <nav class="lc-editor-tabs">
                <button type="button" class="is-active" data-tab-target="lc-edit-basic">بيانات الاعتماد</button>
                <button type="button" data-tab-target="lc-edit-bank">البنك والعملة</button>
                <button type="button" data-tab-target="lc-edit-accounts">الحسابات</button>
                <button type="button" data-tab-target="lc-edit-grids">جريدات الاعتماد</button>
                <button type="button" data-tab-target="lc-edit-dates">التواريخ والسداد</button>
                <button type="button" data-tab-target="lc-edit-notes">ملاحظات وتحكم</button>
            </nav>

            <main class="lc-editor-stage">
                <section id="lc-edit-basic" class="lc-editor-pane is-active">
                    <div class="lc-pane-title">
                        <h3>بيانات الاعتماد</h3>
                        <p>الحقول الأساسية المقابلة لرأس شاشة `FrmLC.frm`.</p>
                    </div>
                    <div class="lc-field-grid">
                        <label><span>رقم الاعتماد</span>@Html.TextBoxFor(x => x.LCNO, new { @class = "main-erp-input", autocomplete = "off" })</label>
                        <label><span>نوع الاعتماد</span>@Html.DropDownListFor(x => x.LCTyperId, new SelectList(Model.LcTypes, "Value", "Text", Model.LCTyperId), "-- اختر --", new { @class = "main-erp-input" })</label>
                        <label><span>المورد</span>@Html.DropDownListFor(x => x.VendorId, new SelectList(Model.Vendors, "Value", "Text", Model.VendorId), "-- اختر --", new { @class = "main-erp-input" })</label>
                        <label><span>الدولة</span>@Html.DropDownListFor(x => x.CountryId, new SelectList(Model.Countries, "Value", "Text", Model.CountryId), "-- اختر --", new { @class = "main-erp-input" })</label>
                        <label><span>الفرع</span>@Html.DropDownListFor(x => x.BranchID, new SelectList(Model.Branches, "Value", "Text", Model.BranchID), "-- اختر --", new { @class = "main-erp-input" })</label>
                        <label><span>المشروع</span>@Html.TextBoxFor(x => x.ProjectName, new { @class = "main-erp-input" })</label>
                        <label><span>رقم المشروع</span>@Html.TextBoxFor(x => x.ProjectId, new { @class = "main-erp-input", type = "number" })</label>
                        <label class="lc-check-field"><span>مغلق</span>@Html.CheckBoxFor(x => x.Locked)</label>
                    </div>
                </section>

                <section id="lc-edit-bank" class="lc-editor-pane" hidden>
                    <div class="lc-pane-title">
                        <h3>البنك والعملة والقيمة</h3>
                        <p>هذا الجزء يؤثر مباشرة في قيود الفتح والمصاريف؛ راجع القيم قبل إنشاء القيود.</p>
                    </div>
                    <div class="lc-field-grid">
                        <label><span>البنك</span>@Html.DropDownListFor(x => x.BankId, new SelectList(Model.Banks, "Value", "Text", Model.BankId), "-- اختر --", new { @class = "main-erp-input" })</label>
                        <label><span>بنك السداد</span>@Html.DropDownListFor(x => x.BankID2, new SelectList(Model.Banks, "Value", "Text", Model.BankID2), "-- اختر --", new { @class = "main-erp-input" })</label>
                        <label><span>الصندوق</span>@Html.DropDownListFor(x => x.BoxID, new SelectList(Model.Boxes, "Value", "Text", Model.BoxID), "-- اختر --", new { @class = "main-erp-input" })</label>
                        <label><span>العملة</span>@Html.DropDownListFor(x => x.CurrencyId, new SelectList(Model.Currencies, "Value", "Text", Model.CurrencyId), "-- اختر --", new { @class = "main-erp-input" })</label>
                        <label><span>سعر الصرف</span>@Html.TextBoxFor(x => x.CurrencyRate, new { @class = "main-erp-input", type = "number", step = "0.0001" })</label>
                        <label><span>قيمة الاعتماد</span>@Html.TextBoxFor(x => x.Value, new { @class = "main-erp-input", type = "number", step = "0.0001" })</label>
                        <label><span>نسبة الهامش</span>@Html.TextBoxFor(x => x.PercentV, new { @class = "main-erp-input", type = "number", step = "0.0001" })</label>
                        <label><span>مصاريف / قيمة فتح الاعتماد</span>@Html.TextBoxFor(x => x.OpenValue, new { @class = "main-erp-input", type = "number", step = "0.0001" })</label>
                    </div>
                    <div class="lc-impact-strip">
                        <article><span>قيد الهامش المتوقع</span><strong>@money(marginVoucherValue)</strong></article>
                        <article><span>قيد المصاريف المتوقع</span><strong>@money(expenseVoucherValue)</strong></article>
                        <article><span>سعر الصرف</span><strong>@money(Model.CurrencyRate)</strong></article>
                    </div>
                </section>

                <section id="lc-edit-accounts" class="lc-editor-pane" hidden>
                    <div class="lc-pane-title">
                        <h3>الحسابات المرتبطة</h3>
                        <p>الأكواد هنا مفاتيح داخلية مؤقتة للحفظ والترحيل. العرض النهائي للمستخدم يتم بصيغة: Account_Serial - Account_Name.</p>
                    </div>
                    <div class="main-erp-warning">
                        عند تفعيل "إنشاء الحسابات الناقصة"، سيتم إنشاء حساب ابن تحت الحساب الأب المحدد بنفس نمط VB6 وبقفل `sp_getapplock`.
                    </div>
                    <div class="lc-account-editor-grid">
                        <article>
                            <h4>حساب الاعتماد</h4>
                            <label><span>الحساب الرئيسي للاعتماد</span>@Html.DropDownListFor(x => x.AccountLGParent, new SelectList(Model.Accounts, "Value", "Text", Model.AccountLGParent), "-- اختر --", new { @class = "main-erp-input" })</label>
                            <label><span>حساب الاعتماد</span>@Html.DropDownListFor(x => x.LCAccountCode, new SelectList(Model.Accounts, "Value", "Text", Model.LCAccountCode), "-- يترك فارغًا للإنشاء --", new { @class = "main-erp-input" })</label>
                        </article>
                        <article>
                            <h4>حساب الهامش</h4>
                            <label><span>الحساب الرئيسي للهامش</span>@Html.DropDownListFor(x => x.AccountMarginParent, new SelectList(Model.Accounts, "Value", "Text", Model.AccountMarginParent), "-- اختر --", new { @class = "main-erp-input" })</label>
                            <label><span>حساب الهامش</span>@Html.DropDownListFor(x => x.MarginAccountCode, new SelectList(Model.Accounts, "Value", "Text", Model.MarginAccountCode), "-- يترك فارغًا للإنشاء --", new { @class = "main-erp-input" })</label>
                        </article>
                        <article>
                            <h4>حساب القبول</h4>
                            <label><span>الحساب الرئيسي للقبول</span>@Html.DropDownListFor(x => x.AccountAcceptanceParent, new SelectList(Model.Accounts, "Value", "Text", Model.AccountAcceptanceParent), "-- اختر --", new { @class = "main-erp-input" })</label>
                            <label><span>حساب القبول</span>@Html.DropDownListFor(x => x.AcceptanceAccountCode, new SelectList(Model.Accounts, "Value", "Text", Model.AcceptanceAccountCode), "-- يترك فارغًا للإنشاء --", new { @class = "main-erp-input" })</label>
                        </article>
                        <article>
                            <h4>حسابات المصروفات</h4>
                            <label><span>الحساب الرئيسي للمصروفات</span>@Html.DropDownListFor(x => x.AccountExpensParent, new SelectList(Model.Accounts, "Value", "Text", Model.AccountExpensParent), "-- اختر --", new { @class = "main-erp-input" })</label>
                            <label><span>حساب المصروفات</span>@Html.DropDownListFor(x => x.ExpenseAccountCode, new SelectList(Model.Accounts, "Value", "Text", Model.ExpenseAccountCode), "-- يترك فارغًا للإنشاء --", new { @class = "main-erp-input" })</label>
                            <label><span>حساب مصروف المشروع</span>@Html.DropDownListFor(x => x.ProjectExpenseAccountCode, new SelectList(Model.Accounts, "Value", "Text", Model.ProjectExpenseAccountCode), "-- اختر --", new { @class = "main-erp-input" })</label>
                        </article>
                    </div>
                    <label class="lc-toggle-card">
                        @Html.CheckBoxFor(x => x.AutoCreateMissingAccounts)
                        <span>
                            <strong>إنشاء الحسابات الناقصة عند الحفظ</strong>
                            <small>يستخدم الحساب الأب المحدد، ولا ينشئ تحت حساب معلّم كآخر حساب.</small>
                        </span>
                    </label>
                </section>

                <section id="lc-edit-grids" class="lc-editor-pane" hidden>
                    <div class="lc-pane-title">
                        <h3>جريدات الاعتماد</h3>
                        <p>تم تفعيل حفظ وتعديل الصفوف الأساسية فقط. ترحيل قيود الجريدات ما زال محميًا حتى اكتمال مطابقة منطق VB6.</p>
                    </div>

                    <div class="main-erp-warning">
                        ملاحظة مهمة: حفظ الصفوف لا ينشئ قيودًا محاسبية لهذه الجريدات الآن، ولا يعدل `NoteID / NoteSerial` الموجودة.
                    </div>

                    <div class="lc-grid-editor-block">
                        <h4>تاريخ الاعتماد - TBLLCHistory</h4>
                        <div class="main-erp-table-wrap">
                            <table class="main-erp-table lc-edit-grid-table">
                                <thead><tr><th>#</th><th>ضمان</th><th>إضافة</th><th>خصم</th><th>الإجمالي</th><th>رقم الهامش</th><th>كود</th><th>اسم</th><th>قيد</th></tr></thead>
                                <tbody>
                                    @for (var i = 0; i < Model.HistoryRows.Count; i++)
                                    {
                                        <tr>
                                            <td>@Html.HiddenFor(x => x.HistoryRows[i].ID)@Html.TextBoxFor(x => x.HistoryRows[i].Serial, new { type = "number" })</td>
                                            <td>@Html.TextBoxFor(x => x.HistoryRows[i].GuaranteeAmount, new { type = "number", step = "0.0001" })</td>
                                            <td>@Html.TextBoxFor(x => x.HistoryRows[i].AmountPlus, new { type = "number", step = "0.0001" })</td>
                                            <td>@Html.TextBoxFor(x => x.HistoryRows[i].AmountMin, new { type = "number", step = "0.0001" })</td>
                                            <td>@Html.TextBoxFor(x => x.HistoryRows[i].Total, new { type = "number", step = "0.0001" })</td>
                                            <td>@Html.TextBoxFor(x => x.HistoryRows[i].MarginNo, new { type = "number" })</td>
                                            <td>@Html.TextBoxFor(x => x.HistoryRows[i].Code)</td>
                                            <td>@Html.TextBoxFor(x => x.HistoryRows[i].Name)</td>
                                            <td>@Html.DisplayFor(x => x.HistoryRows[i].NoteID)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="lc-grid-editor-block">
                        <h4>هامش الاعتماد - TBLLCMargin</h4>
                        <div class="main-erp-table-wrap">
                            <table class="main-erp-table lc-edit-grid-table">
                                <thead><tr><th>#</th><th>رقم</th><th>تاريخ ضمان</th><th>مبلغ</th><th>حساب هامش</th><th>حساب بنك</th><th>مدفوع</th><th>متبقي</th><th>تاريخ أمر</th><th>تاريخ دفع</th><th>تم السداد</th><th>قيد</th></tr></thead>
                                <tbody>
                                    @for (var i = 0; i < Model.MarginRows.Count; i++)
                                    {
                                        <tr>
                                            <td>@Html.HiddenFor(x => x.MarginRows[i].ID)@Html.TextBoxFor(x => x.MarginRows[i].Serial, new { type = "number" })</td>
                                            <td>@Html.TextBoxFor(x => x.MarginRows[i].MarginNo, new { type = "number" })</td>
                                            <td>@Html.TextBoxFor(x => x.MarginRows[i].GuaranteeDate, "{0:yyyy-MM-dd}", new { type = "date" })</td>
                                            <td>@Html.TextBoxFor(x => x.MarginRows[i].Amount, new { type = "number", step = "0.0001" })</td>
                                            <td>@Html.DropDownListFor(x => x.MarginRows[i].MarginAccountCode, new SelectList(Model.Accounts, "Value", "Text", Model.MarginRows[i].MarginAccountCode), "-- اختر --")</td>
                                            <td>@Html.DropDownListFor(x => x.MarginRows[i].BankAccountCode, new SelectList(Model.Accounts, "Value", "Text", Model.MarginRows[i].BankAccountCode), "-- اختر --")</td>
                                            <td>@Html.TextBoxFor(x => x.MarginRows[i].PayedAmount, new { type = "number", step = "0.0001" })</td>
                                            <td>@Html.TextBoxFor(x => x.MarginRows[i].StillAmount, new { type = "number", step = "0.0001" })</td>
                                            <td>@Html.TextBoxFor(x => x.MarginRows[i].OrderDate, "{0:yyyy-MM-dd}", new { type = "date" })</td>
                                            <td>@Html.TextBoxFor(x => x.MarginRows[i].PayDate, "{0:yyyy-MM-dd}", new { type = "date" })</td>
                                            <td>@Html.CheckBoxFor(x => x.MarginRows[i].IsFullPayed)</td>
                                            <td>@Html.DisplayFor(x => x.MarginRows[i].NoteID)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="lc-grid-editor-block">
                        <h4>دفعات / تمويل الهامش - TBLLCMargin2</h4>
                        <div class="main-erp-table-wrap">
                            <table class="main-erp-table lc-edit-grid-table">
                                <thead><tr><th>#</th><th>رقم</th><th>تاريخ ضمان</th><th>مبلغ</th><th>حساب هامش</th><th>حساب بنك</th><th>حساب إضافي</th><th>قيمة هامش</th><th>مدفوع</th><th>متبقي</th><th>رصيد افتتاحي</th><th>قيد</th></tr></thead>
                                <tbody>
                                    @for (var i = 0; i < Model.Margin2Rows.Count; i++)
                                    {
                                        <tr>
                                            <td>@Html.HiddenFor(x => x.Margin2Rows[i].ID)@Html.TextBoxFor(x => x.Margin2Rows[i].Serial, new { type = "number" })</td>
                                            <td>@Html.TextBoxFor(x => x.Margin2Rows[i].MarginNo, new { type = "number" })</td>
                                            <td>@Html.TextBoxFor(x => x.Margin2Rows[i].GuaranteeDate, "{0:yyyy-MM-dd}", new { type = "date" })</td>
                                            <td>@Html.TextBoxFor(x => x.Margin2Rows[i].Amount, new { type = "number", step = "0.0001" })</td>
                                            <td>@Html.DropDownListFor(x => x.Margin2Rows[i].MarginAccountCode, new SelectList(Model.Accounts, "Value", "Text", Model.Margin2Rows[i].MarginAccountCode), "-- اختر --")</td>
                                            <td>@Html.DropDownListFor(x => x.Margin2Rows[i].BankAccountCode, new SelectList(Model.Accounts, "Value", "Text", Model.Margin2Rows[i].BankAccountCode), "-- اختر --")</td>
                                            <td>@Html.DropDownListFor(x => x.Margin2Rows[i].AccountMargen2, new SelectList(Model.Accounts, "Value", "Text", Model.Margin2Rows[i].AccountMargen2), "-- اختر --")</td>
                                            <td>@Html.TextBoxFor(x => x.Margin2Rows[i].MargenValue, new { type = "number", step = "0.0001" })</td>
                                            <td>@Html.TextBoxFor(x => x.Margin2Rows[i].PayedAmount, new { type = "number", step = "0.0001" })</td>
                                            <td>@Html.TextBoxFor(x => x.Margin2Rows[i].StillAmount, new { type = "number", step = "0.0001" })</td>
                                            <td>@Html.CheckBoxFor(x => x.Margin2Rows[i].IsOpenBalance)</td>
                                            <td>@Html.DisplayFor(x => x.Margin2Rows[i].NoteID)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="lc-grid-editor-block">
                        <h4>الرصيد الافتتاحي - tblLCOpenB</h4>
                        <div class="main-erp-table-wrap">
                            <table class="main-erp-table lc-edit-grid-table">
                                <thead><tr><th>#</th><th>رقم</th><th>تاريخ</th><th>مبلغ</th><th>مدفوع</th><th>الإجمالي</th><th>مصروف</th><th>تأمين</th><th>%</th><th>حساب هامش</th><th>حساب بنك</th><th>تاريخ دفع</th><th>قيد</th></tr></thead>
                                <tbody>
                                    @for (var i = 0; i < Model.OpenBalanceRows.Count; i++)
                                    {
                                        <tr>
                                            <td>@Html.HiddenFor(x => x.OpenBalanceRows[i].ID)@Html.TextBoxFor(x => x.OpenBalanceRows[i].Serial, new { type = "number" })</td>
                                            <td>@Html.TextBoxFor(x => x.OpenBalanceRows[i].MarginNo, new { type = "number" })</td>
                                            <td>@Html.TextBoxFor(x => x.OpenBalanceRows[i].GuaranteeDate, "{0:yyyy-MM-dd}", new { type = "date" })</td>
                                            <td>@Html.TextBoxFor(x => x.OpenBalanceRows[i].Amount, new { type = "number", step = "0.0001" })</td>
                                            <td>@Html.TextBoxFor(x => x.OpenBalanceRows[i].AmountP, new { type = "number", step = "0.0001" })</td>
                                            <td>@Html.TextBoxFor(x => x.OpenBalanceRows[i].TotalAmount, new { type = "number", step = "0.0001" })</td>
                                            <td>@Html.TextBoxFor(x => x.OpenBalanceRows[i].ExpAmount, new { type = "number", step = "0.0001" })</td>
                                            <td>@Html.TextBoxFor(x => x.OpenBalanceRows[i].InsuranceAmount, new { type = "number", step = "0.0001" })</td>
                                            <td>@Html.TextBoxFor(x => x.OpenBalanceRows[i].PercentA, new { type = "number", step = "0.0001" })</td>
                                            <td>@Html.DropDownListFor(x => x.OpenBalanceRows[i].MarginAccountCode, new SelectList(Model.Accounts, "Value", "Text", Model.OpenBalanceRows[i].MarginAccountCode), "-- اختر --")</td>
                                            <td>@Html.DropDownListFor(x => x.OpenBalanceRows[i].BankAccountCode, new SelectList(Model.Accounts, "Value", "Text", Model.OpenBalanceRows[i].BankAccountCode), "-- اختر --")</td>
                                            <td>@Html.TextBoxFor(x => x.OpenBalanceRows[i].PayDate, "{0:yyyy-MM-dd}", new { type = "date" })</td>
                                            <td>@Html.DisplayFor(x => x.OpenBalanceRows[i].NoteID)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </section>

                <section id="lc-edit-dates" class="lc-editor-pane" hidden>
                    <div class="lc-pane-title">
                        <h3>التواريخ والسداد</h3>
                        <p>تواريخ الاعتماد والشحن والشيكات كما تظهر في Workflow الأصلي.</p>
                    </div>
                    <div class="lc-field-grid">
                        <label><span>من تاريخ</span>@Html.TextBoxFor(x => x.FromDate, "{0:yyyy-MM-dd}", new { @class = "main-erp-input", type = "date" })</label>
                        <label><span>إلى تاريخ</span>@Html.TextBoxFor(x => x.ToDate, "{0:yyyy-MM-dd}", new { @class = "main-erp-input", type = "date" })</label>
                        <label><span>تاريخ الإغلاق</span>@Html.TextBoxFor(x => x.CloseDate, "{0:yyyy-MM-dd}", new { @class = "main-erp-input", type = "date" })</label>
                        <label><span>آخر شحنة</span>@Html.TextBoxFor(x => x.LastParcilDate, "{0:yyyy-MM-dd}", new { @class = "main-erp-input", type = "date" })</label>
                        <label><span>تاريخ الرصيد الافتتاحي</span>@Html.TextBoxFor(x => x.OpenBalanceDate, "{0:yyyy-MM-dd}", new { @class = "main-erp-input", type = "date" })</label>
                        <label><span>قيمة الرصيد الافتتاحي</span>@Html.TextBoxFor(x => x.OpenBalance, new { @class = "main-erp-input", type = "number", step = "0.0001" })</label>
                        <label><span>نوع الرصيد الافتتاحي</span>@Html.DropDownListFor(x => x.OpenBalanceType, new SelectList(new[] { new { Value = "", Text = "-- بدون --" }, new { Value = "0", Text = "مدين" }, new { Value = "1", Text = "دائن" } }, "Value", "Text", Model.OpenBalanceType), new { @class = "main-erp-input" })</label>
                        <label><span>مجموعة قيد الرصيد الافتتاحي</span>@Html.TextBoxFor(x => x.OpeningBalanceVoucherId, new { @class = "main-erp-input", @readonly = "readonly" })</label>
                        <label><span>طريقة الدفع</span>@Html.TextBoxFor(x => x.PaymentTypeID, new { @class = "main-erp-input", type = "number" })</label>
                        <label><span>رقم الشيك</span>@Html.TextBoxFor(x => x.ChequeNumber, new { @class = "main-erp-input" })</label>
                        <label><span>تاريخ الشيك</span>@Html.TextBoxFor(x => x.ChequeDueDate, "{0:yyyy-MM-dd}", new { @class = "main-erp-input", type = "date" })</label>
                    </div>
                </section>

                <section id="lc-edit-notes" class="lc-editor-pane" hidden>
                    <div class="lc-pane-title">
                        <h3>ملاحظات وتحكم</h3>
                        <p>الحفظ متاح، أما الحذف وإعادة بناء القيود والجريدات المالية فهي مؤجلة حتى اعتماد كل تفاصيل VB6.</p>
                    </div>
                    <label class="lc-wide-label"><span>ملاحظات الاعتماد</span>@Html.TextAreaFor(x => x.Remarks, new { @class = "main-erp-input", rows = "6" })</label>
                    <div class="lc-disabled-panel">
                        <button type="button" class="lc-disabled-action">إنشاء قيود الجريدات</button>
                        <button type="button" class="lc-disabled-action">ترحيل الرصيد الافتتاحي</button>
                        <button type="button" class="lc-disabled-action">حذف الاعتماد</button>
                        <button type="button" class="lc-disabled-action">طباعة التقرير</button>
                    </div>
                </section>
            </main>
        </div>

        <footer class="lc-editor-footer">
            <button type="submit">حفظ الاعتماد</button>
            <a href="@Url.Action("Index", "LC", new { area = "MainErp", selectedId = Model.TblLCID })">إلغاء</a>
            <span>الحفظ لا ينفذ حذفًا ولا يعيد بناء قيود قديمة تلقائيًا.</span>
        </footer>
    }
</section>

<script>
    (function () {
        var root = document.querySelector("[data-lc-editor]");
        if (!root) return;

        var buttons = root.querySelectorAll("[data-tab-target]");
        for (var i = 0; i < buttons.length; i++) {
            buttons[i].addEventListener("click", function () {
                for (var b = 0; b < buttons.length; b++) buttons[b].classList.remove("is-active");
                var panes = root.querySelectorAll(".lc-editor-pane");
                for (var p = 0; p < panes.length; p++) {
                    panes[p].hidden = true;
                    panes[p].classList.remove("is-active");
                }
                this.classList.add("is-active");
                var target = document.getElementById(this.getAttribute("data-tab-target"));
                if (target) {
                    target.hidden = false;
                    target.classList.add("is-active");
                }
            });
        }

        var disabled = document.querySelectorAll(".lc-disabled-action");
        for (var d = 0; d < disabled.length; d++) {
            disabled[d].addEventListener("click", function () {
                alert("هذه الوظيفة لم يتم ترحيلها بعد - Read Only / Protected Mode");
            });
        }
    })();
</script>
