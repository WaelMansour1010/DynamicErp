@model MyERP.Areas.Pos.Models.PosFinancialIntelligencePageModel
@{
    Layout = null;
    ViewBag.Title = "تشخيص ذمم الموظفين";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title</title>
    <link href="@Url.Content("~/assets/css/Courses/css/fontawesome-all.min.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Areas/Pos/Content/financial-intelligence.css?v=20260506-clean")" rel="stylesheet" />
</head>
<body data-fi-endpoint="@Url.Action("EmployeeReceivablesData", "FinancialIntelligence", new { area = "Pos" })"
      data-fi-mode="diagnostic"
      data-fi-root-url="@Url.Action("RootCause", "FinancialIntelligence", new { area = "Pos" })"
      data-fi-journal-details-url="@Url.Action("JournalDetails", "FinancialIntelligence", new { area = "Pos" })"
      data-fi-journal-url="@Url.Content("~/Pos/JournalEntries/Index")"
      data-fi-account-url="@Url.Content("~/Pos/AccountingReports/Index")"
      data-fi-source-url="@Url.Content("~/Pos/PosTransaction/Index")">
    <main class="fi-page">
        @Html.Partial("_Nav", Model, new ViewDataDictionary { { "Active", "employee" } })
        <section class="fi-filter">
            @Html.Partial("_Filters", Model)
            <label class="fi-field"><span>رقم الموظف</span><input type="number" data-fi-employee placeholder="اختياري" /></label>
            <label class="fi-field"><span>كود الحساب</span><input type="text" data-fi-account placeholder="اختياري" /></label>
            <label class="fi-field"><span>Serial حساب الذمم الأب</span><input type="number" data-fi-receivable-parent placeholder="اختياري" /></label>
            <div class="fi-actions">
                <button type="button" class="fi-btn fi-btn-primary" data-fi-load><i class="fas fa-search"></i>تحميل التشخيص</button>
                <button type="button" class="fi-btn" data-fi-export><i class="fas fa-file-excel"></i>تصدير Excel</button>
            </div>
        </section>
        <div data-fi-error></div>
        <section class="fi-grid">
            <article class="fi-panel"><h2>حسابات تحتاج متابعة</h2><div data-fi-main-table></div></article>
            <article class="fi-panel"><h2>أكبر الحركات المؤثرة</h2><div data-fi-side-table></div></article>
            <article class="fi-panel fi-panel-wide"><h2>تطور الحركة</h2><div class="fi-chart-box"><canvas data-fi-chart></canvas></div></article>
        </section>
    </main>
    <script src="@Url.Content("~/assets/libs/chart-js/Chart.bundle.min.js")"></script>
    <script src="@Url.Content("~/Areas/Pos/Scripts/financial-intelligence.js?v=20260506-clean")"></script>
</body>
</html>
