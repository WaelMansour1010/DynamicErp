@model MyERP.Areas.Pos.Models.PosFinancialIntelligencePageModel
<label class="fi-field">
    <span>من تاريخ</span>
    <input type="date" data-fi-from value="@Model.FromDate.ToString("yyyy-MM-dd")" />
</label>
<label class="fi-field">
    <span>إلى تاريخ</span>
    <input type="date" data-fi-to value="@Model.ToDate.ToString("yyyy-MM-dd")" />
</label>
<label class="fi-field">
    <span>الفرع</span>
    <select data-fi-branch @(Model.LockedBranchId.HasValue ? "disabled" : "")>
        <option value="">كل الفروع</option>
        @foreach (var branch in Model.Branches)
        {
            <option value="@branch.BranchId" @(Model.LockedBranchId == branch.BranchId ? "selected" : "")>@branch.BranchName</option>
        }
    </select>
</label>
