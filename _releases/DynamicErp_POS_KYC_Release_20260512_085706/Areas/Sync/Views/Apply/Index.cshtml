@model MyERP.Areas.Sync.ViewModels.DiagnosticViewModel
@{
    Layout = "~/Areas/Sync/Views/Shared/_SyncLayout.cshtml";
    ViewBag.Title = "استعداد التنفيذ";
}
<div class="sync-card apply-blocked">
    <div class="card-title">استعداد التنفيذ التجريبي</div>
    <p>هذه الشاشة تعرض التحذيرات والفحوصات فقط. لا يوجد تنفيذ ApplyMode من المتصفح.</p>
    <p class="sync-danger-text">قد يؤدي التنفيذ إلى تعديل قاعدة البيانات المستهدفة.</p>
    <p><a class="btn btn-warning" href="/sync/AdminOperations?SyncKey=@Url.Encode(Model.SyncKey)&ApplySingleSyncKeyOnly=true&MaxInvoicesPerRun=1">إنشاء طلب معلّق عبر قائمة الانتظار</a></p>
    @using (Html.BeginForm("RequestApply", "Apply", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        <input type="hidden" name="syncKey" value="@Model.SyncKey" />
        <button class="btn btn-danger" type="submit" disabled>التنفيذ محجوب</button>
    }
</div>
<div class="sync-grid two">
    <div class="sync-card">
        <div class="card-title">العنصر المحدد</div>
        @if (Model.QueueRow == null)
        {
            <div class="empty-state">لم يتم تحديد SyncKey أو لا يوجد عنصر مطابق.</div>
        }
        else
        {
            <dl class="details-list">
                <dt>SyncKey</dt><dd class="mono">@Model.QueueRow.SyncKey</dd>
                <dt>الحالة</dt><dd><span class="status @Model.QueueRow.Status">@Model.QueueRow.Status</span></dd>
                <dt>الفرع</dt><dd>@Model.QueueRow.BranchId</dd>
                <dt>PayloadHash</dt><dd class="hash">@Model.QueueRow.PayloadHash</dd>
            </dl>
        }
    </div>
    <div class="sync-card">
        <div class="card-title">فحوصات السلامة</div>
        @foreach (var check in Model.Checks)
        {
            <div class="check-row @(check.IsHardBlocker ? "hard" : "")"><strong>@check.CheckName</strong><span>@check.Status</span><p>@check.Message</p></div>
        }
    </div>
</div>
