@model MyERP.Areas.Sync.ViewModels.DashboardViewModel
@{
    Layout = "~/Areas/Sync/Views/Shared/_SyncLayout.cshtml";
    ViewBag.Title = "مركز التحكم بالمزامنة";
}
<div class="sync-target">قاعدة البيانات: <strong>@Model.TargetDatabase</strong></div>
<div class="sync-grid sync-metrics">
    <div class="sync-card metric pending"><span>قيد الانتظار</span><strong>@Model.PendingCount</strong></div>
    <div class="sync-card metric conflict"><span>تعارض بيانات</span><strong>@Model.ConflictCount</strong></div>
    <div class="sync-card metric failed"><span>فشل</span><strong>@Model.FailedCount</strong></div>
    <div class="sync-card metric applied"><span>تم التطبيق</span><strong>@Model.AppliedCount</strong></div>
    <div class="sync-card metric blocked"><span>محجوب</span><strong>@Model.BlockedCount</strong></div>
</div>
<div class="sync-grid two">
    <div class="sync-card">
        <div class="card-title">مراقبة فروع المزامنة</div>
        <div class="sync-table-wrap">
            <table class="sync-table">
                <thead><tr><th>الفرع</th><th>الحالة</th><th>آخر اتصال</th><th>الإصدار</th><th>قيد الإرسال</th><th>فاشل محلي</th><th>مرفوض</th><th>فشل تحقق</th></tr></thead>
                <tbody>
                @foreach (var row in Model.BranchHeartbeats)
                {
                    var online = row.LastSeenAt.HasValue && (DateTime.Now - row.LastSeenAt.Value).TotalMinutes <= 5;
                    <tr>
                        <td>@row.BranchId</td>
                        <td><span class="status @(online ? "Applied" : "Blocked")">@(online ? "متصل" : "غير متصل")</span></td>
                        <td>@(row.LastSeenAt.HasValue ? row.LastSeenAt.Value.ToString("yyyy-MM-dd HH:mm") : "")</td>
                        <td>@row.AgentVersion / @row.ConfigVersion / @row.PayloadSchemaVersion</td>
                        <td>@row.PendingOutboxCount</td>
                        <td>@row.FailedOutboxCount</td>
                        <td>@row.RejectedPayloadCount</td>
                        <td>@row.AuthFailureCount</td>
                    </tr>
                }
                </tbody>
            </table>
            @if (!Model.BranchHeartbeats.Any())
            {
                <div class="empty-state">لم يتم استقبال نبضات فروع حتى الآن.</div>
            }
        </div>
    </div>
    <div class="sync-card">
        <div class="card-title">أحدث تحميلات الفروع</div>
        <div class="sync-table-wrap">
            <table class="sync-table">
                <thead><tr><th>الوقت</th><th>الفرع</th><th>SyncKey</th><th>الحالة</th><th>الرسالة</th></tr></thead>
                <tbody>
                @foreach (var row in Model.RecentBranchUploads)
                {
                    <tr>
                        <td>@(row.CreatedAt.HasValue ? row.CreatedAt.Value.ToString("yyyy-MM-dd HH:mm") : "")</td>
                        <td>@row.BranchId</td>
                        <td class="mono">@row.SyncKey</td>
                        <td><span class="status @row.Status">@row.Status</span></td>
                        <td>@row.Message</td>
                    </tr>
                }
                </tbody>
            </table>
            @if (!Model.RecentBranchUploads.Any())
            {
                <div class="empty-state">لم يتم استقبال تحميلات من الفروع حتى الآن.</div>
            }
        </div>
    </div>
</div>
<div class="sync-grid two">
    <div class="sync-card">
        <div class="card-title">اتجاه الدُفعات الأخيرة</div>
        <div class="sync-table-wrap">
            <table class="sync-table">
                <thead><tr><th>Batch</th><th>الملف</th><th>الحالة</th><th>تعارض</th><th>فشل</th></tr></thead>
                <tbody>
                @foreach (var row in Model.RecentBatches)
                {
                    <tr>
                        <td>@row.BatchId</td>
                        <td>@row.ProfileName</td>
                        <td><span class="status @row.Status">@row.Status</span></td>
                        <td>@row.ConflictCount</td>
                        <td>@row.FailedCount</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
    <div class="sync-card">
        <div class="card-title">استخدام الملفات التعريفية</div>
        <canvas class="sync-chart" data-chart="profile"></canvas>
        @Html.Partial("~/Areas/Sync/Views/Shared/_ChartBars.cshtml", Model.ProfileUsage)
    </div>
</div>
<div class="sync-grid three">
    <div class="sync-card"><div class="card-title">نشاط الفروع</div>@Html.Partial("~/Areas/Sync/Views/Shared/_ChartBars.cshtml", Model.BranchActivity)</div>
    <div class="sync-card"><div class="card-title">خريطة التعارضات</div>@Html.Partial("~/Areas/Sync/Views/Shared/_ChartBars.cshtml", Model.ConflictTrend)</div>
    <div class="sync-card"><div class="card-title">إحصاءات إعادة المحاولة</div>@Html.Partial("~/Areas/Sync/Views/Shared/_ChartBars.cshtml", Model.RetryStats)</div>
</div>
<div class="sync-grid two">
    <div class="sync-card">
        <div class="card-title">أكثر الفروع احتياجاً للمراجعة</div>
        @Html.Partial("~/Areas/Sync/Views/Shared/_ChartBars.cshtml", Model.ProblemBranches)
    </div>
    <div class="sync-card">
        <div class="card-title">أحدث العمليات الحساسة</div>
        <div class="timeline">
            @foreach (var item in Model.RecentDangerousOperations)
            {
                <div class="timeline-row">
                    <span>@(item.CreatedAt.HasValue ? item.CreatedAt.Value.ToString("yyyy-MM-dd HH:mm") : "")</span>
                    <strong>@item.Operation</strong>
                    <em>@item.UserName</em>
                </div>
            }
            @if (!Model.RecentDangerousOperations.Any())
            {
                <div class="empty-state">لا توجد عمليات حساسة مسجلة.</div>
            }
        </div>
    </div>
</div>
<script src="~/Areas/Sync/Scripts/sync-dashboard.js"></script>
