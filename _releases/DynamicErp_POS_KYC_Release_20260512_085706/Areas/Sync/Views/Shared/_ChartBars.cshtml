@model IEnumerable<MyERP.Areas.Sync.ViewModels.ChartPoint>
@{
    var points = Model == null ? new System.Collections.Generic.List<MyERP.Areas.Sync.ViewModels.ChartPoint>() : Model.ToList();
    var max = points.Count == 0 ? 0 : points.Max(x => x.Value);
}
<div class="chart-bars">
    @foreach (var point in points)
    {
        var width = max <= 0 ? 0 : Convert.ToInt32((point.Value / max) * 100);
        <div class="bar-row">
            <span>@point.Label</span>
            <div class="bar-track"><i style="width:@width%"></i></div>
            <strong>@point.Value</strong>
        </div>
    }
    @if (!points.Any())
    {
        <div class="empty-state">لا توجد بيانات كافية للعرض.</div>
    }
</div>
