    function CalculateTotals() {
        var total = 0;
        $('.TotalAfterDiscount').each(function () {
            total += $(this).inputmask('unmaskedvalue') * 1;
        });
        $('#Total').val(total);
        if ($('#DiscountValue').val()) {
            total -= $('#DiscountValue').inputmask('unmaskedvalue');
        }
        $('#NetTotal').val(total);

        if ($('#hasTaxes').prop('checked')) {
            $('#SalesTaxes').val(total * taxPercentage);
            total += $('#SalesTaxes').inputmask('unmaskedvalue') * 1;
        }
        $('#TotalAfterTaxes').val(total);

    }

    function appendCustomerOptions(refill) {
        return getCustomers(refill).then(function () {
