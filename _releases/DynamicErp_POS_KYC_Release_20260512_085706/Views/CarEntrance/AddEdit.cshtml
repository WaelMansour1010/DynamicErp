    function addCarSalesInvoice(n) {
        let valid = true;
        if ($(".form-control:invalid").length > 0) {
            $('.form-horizontal').addClass('was-validated');
            $('html, body').animate({
                scrollTop: $(".form-control:invalid").eq(0).offset().top - 80
            }, 500);
            console.log($(".form-control:invalid"));
            valid = false;
        }

        if ($('#Id').val()) {
            let CarEntranceId = $('#Id').val();
            if (valid) {
                Swal.fire({
                    title: '@MyERP.Properties.Resources.AreYouSureYouWantToCreateSalesInvoice',
                    text: " ",
                    icon: 'info',
                    showCancelButton: true,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    cancelButtonText: '@MyERP.Properties.Resources.Cancel',
                    confirmButtonColor: '#3085d6',
                    cancelButtonColor: '#d33',
                    reverseButtons: true
                }).then((result) => {
                    if (result.isConfirmed) {
                        $('#preloader, #status').fadeIn();
                        $.ajax({
                            type: "POST", contentType: "application/json",
                            url: "/CarSalesInvoice/Add",
                            data: JSON.stringify({
                                CarEntranceId: $('#Id').val(),
                            }),
                            success: function (r) {
                                if (r.success == "true") {
                                    Swal.fire({
                                        title: '@MyERP.Properties.Resources.Created',
                                        text: " ",
                                        icon: 'success',
                                        showCancelButton: false,
                                        confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                        confirmButtonColor: '#3085d6'
                                    });
                                    $('#preloader, #status').fadeOut();
                                    let id = r.id;
                                    window.location.replace("/CarSalesInvoice/AddEdit/" + id);
                                }
                                else {
                                    $('#preloader, #status').fadeOut();
                                    Swal.fire({
                                        title: '@MyERP.Properties.Resources.NotCreated',
                                        text: " ",
                                        icon: 'error',
                                        showCancelButton: false,
                                        confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                        confirmButtonColor: '#3085d6'
                                    });
                                }
                            },
                            error: function (r) {
                                $('#preloader, #status').fadeOut();
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.AnErrorOccurredTryAgain',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                            }
                        });
                    }
                    else { result.dismiss; }
                });
            }
        }
    }

