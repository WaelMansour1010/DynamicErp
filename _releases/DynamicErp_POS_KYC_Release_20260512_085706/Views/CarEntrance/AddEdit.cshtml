        if (serviceName != "@MyERP.Properties.Resources.Select")
        {
            let service = search(serviceName, Services);
            $(ServiceNameInput).closest('tr').find('.price').val(service.Price);
            $(ServiceNameInput).closest('tr').find('.TotalAfterDiscount').val($(ServiceNameInput).closest('tr').find('.price').val());
            if (service.TypeId == 0)
                $(ServiceNameInput).closest('tr').find('.CarServiceTypeId').text("@MyERP.Properties.Resources.Service").trigger('change');
            else
                $(ServiceNameInput).closest('tr').find('.CarServiceTypeId').text("@MyERP.Properties.Resources.Addition").trigger('change');


            $(ServiceNameInput).closest('tr').find('.serviceId').val(service.Id);

            addToCarEntranceDetails();

            CalculateTotals();
        }

    });



