    $(document).on('change', '.DiscountPercentage', function () {

        let DisountPercentageInput = $(this);
        let price = DisountPercentageInput.closest('tr').find('.price').val();
        let discountValue;
        if (DisountPercentageInput.val() > 0)
            discountValue = DisountPercentageInput.val() * DisountPercentageInput.closest('tr').find('.price').val() / 100;
        else
            discountValue = DisountPercentageInput.val() * DisountPercentageInput.closest('tr').find('.price').val();
        DisountPercentageInput.closest('tr').find('.DiscountValue').val(discountValue);
        let totalAfterDiscount = price - discountValue;
        DisountPercentageInput.closest('tr').find('.TotalAfterDiscount').val(totalAfterDiscount);

        CalculateTotals();
    });

    $(document).on('change', '.DiscountValue', function () {

        let DisountValueInput = $(this);
        let price = DisountValueInput.closest('tr').find('.price').val();
        let discountPercentage;
        discountPercentage = DisountValueInput.val() / price * 100;
        DisountValueInput.closest('tr').find('.DiscountPercentage').val(discountPercentage);
        let totalAfterDiscount = price - DisountValueInput.val();
        DisountValueInput.closest('tr').find('.TotalAfterDiscount').val(totalAfterDiscount);

        CalculateTotals();
    });

    $(document).on('change', '#VoucherDiscountPercentage', function () {
        let VoucherDiscountPercentageInput = $(this);
        let total = $('#Total').val();
        $('#DiscountValue').val(total * VoucherDiscountPercentageInput.val() / 100);
        CalculateTotals();
    });

    $(document).on('change', '#DiscountValue', function () {
        let VoucherDiscountValueInput = $(this);
        let total = $('#Total').val();
        let result = Math.round(VoucherDiscountValueInput.val() / total * 100);
