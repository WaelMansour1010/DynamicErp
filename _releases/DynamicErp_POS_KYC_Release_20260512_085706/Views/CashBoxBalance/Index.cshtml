
@{
    UICulture = Session["lang"] != null?Session["lang"].ToString():"ar";

    ViewBag.Title = MyERP.Properties.Resources.CashBoxBalance;
}
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
           
            <h4 class="page-title">@MyERP.Properties.Resources.CashBoxBalance</h4>
        </div>
    </div>
</div>
<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal" role="form">
                        <div class="form-group row">
                            <div class="col-xs-12 col-sm-12 col-lg-12">
                                <label for="DepartmentId" class="col-sm-1 control-label">@MyERP.Properties.Resources.SearchWithBranch:</label>
                                <div class="col-sm-5">
                                    @Html.DropDownList("DepartmentId", null, @MyERP.Properties.Resources.All, htmlAttributes: new { @class = "form-control" })
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-12">
                    <div class="table-responsive">
                        <table class="table table-striped table-centered mb-0">
                            <thead>
                                <tr>
                                    <th>
                                        @MyERP.Properties.Resources.Code
                                    </th>
                                    <th>
                                        @MyERP.Properties.Resources.ArName
                                    </th>
                                    <th>
                                        @MyERP.Properties.Resources.EnName
                                    </th>

                                    <th>
                                        @MyERP.Properties.Resources.Account
                                    </th>
                                    <th>
                                        @MyERP.Properties.Resources.Balance
                                    </th>

                                </tr>
                            </thead>
                            <tbody id="cashboxes">
                                @foreach (var item in @ViewBag.CashBoxesList)
                                {

                                    <tr>
                                        <td>
                                            @item.Code
                                        </td>
                                        <td>
                                            @item.ArName
                                        </td>
                                        <td>
                                            @item.EnName
                                        </td>
                                        <td>
                                            @item.Account
                                        </td>
                                        <td class="balance">
                                            @item.Balance
                                        </td>

                                    </tr>
                                }
                                <tr>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td>
                                        @MyERP.Properties.Resources.Total:
                                    </td>
                                    <td class="balance tabledit-edit-mode">
                                        <input type="text" class="form-control tabledit-input form-control-sm" id="TotalBalances" />

                                    </td>
                                </tr>

                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

    <script>
        $(document).ready(function () {
            let totalBalances = 0;
            $('.balance').each(function () {
                totalBalances += $(this).text() * 1;
            });
            $('#TotalBalances').val(totalBalances);
        });
        $(document).on('change', '#DepartmentId', function departmentChange() {
            window.location = '/CashBoxBalance/Index?depId=' + $('#DepartmentId').val();
        });
    </script>
