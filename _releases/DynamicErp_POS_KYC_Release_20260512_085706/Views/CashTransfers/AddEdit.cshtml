                                                @Html.DropDownList("CashBoxIdTo", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "CashBoxIdTo form-control" })
                                                @Html.ValidationMessageFor(model => model.CashBoxIdTo, "", new { @class = "text-danger" })
                                            </div>
                                        </div>

                                        <div class="form-group row">
                                            <label for="BankIdTo" class="BankIdTo control-label col-sm-4">@MyERP.Properties.Resources.Bank</label>
                                            <div class="BankIdTo col-sm-8">
                                                @Html.DropDownList("BankIdTo", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "BankIdTo form-control" })
                                                @Html.ValidationMessageFor(model => model.BankIdTo, "", new { @class = "text-danger" })
                                            </div>
                                        </div>

                                        <div class="form-group row">
                                            <label for="BankAccountIdTo" class="BankAccountIdTo control-label col-sm-4">@MyERP.Properties.Resources.Account</label>
