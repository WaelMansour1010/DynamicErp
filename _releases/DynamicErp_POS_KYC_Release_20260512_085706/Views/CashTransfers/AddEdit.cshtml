@model MyERP.Models.CashTransfer


@{
    UICulture = Session["lang"] != null?Session["lang"].ToString():"ar";

    ViewBag.Title = MyERP.Properties.Resources.CashTransfer;
}
<script src="~/Scripts/SaveAndNew.js"></script>

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                @if (Model != null)
                {
                    if (Model.IsDeleted == false)
                    {
                        if (ViewBag.Previous > 0)
                        {
                <a href="@Url.Action("AddEdit", new { id = ViewBag.First })" class="btn btn-info">@MyERP.Properties.Resources.First</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Previous })" class=" btn btn-info">&#8250;</a>
                        }
                        if (ViewBag.Next > 0)
                        {
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Next })" class="btn btn-info">&#8249;</a>
                            <a href="@Url.Action("AddEdit", new { id = ViewBag.Last })" class="btn btn-info">@MyERP.Properties.Resources.Last</a>
                        }
                    }
                }
            <a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
            </div>
            <h4 class="page-title">@MyERP.Properties.Resources.CashTransfer :</h4>
        </div>
    </div>
</div>
<div class="row">
    <div class="col-12">
        <div class="card-box">
            <form action="/CashTransfers/AddEdit" class="form-horizontal needs-validation" novalidate method="post" @*onsubmit="BtnDisabled()" id="form"*@>
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">
                                <div class="form-group row">
                                    @Html.AntiForgeryToken()

                                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                    @Html.HiddenFor(model => model.TransferTypeId)
                                    @if (Model != null)
                                    {
                                        @Html.HiddenFor(model => model.Id)
                                        @Html.HiddenFor(model => model.IsActive)
                                        @Html.HiddenFor(model => model.IsLinked)
                                        @Html.HiddenFor(model => model.IsPosted)
                                        @Html.HiddenFor(model => model.UserId)
                                        @Html.HiddenFor(model => model.Image)
                                        @Html.HiddenFor(model => model.IsDeleted)
                                    }
                                    <label class=" col-sm-2 control-label" for="DocumentNumber">@MyERP.Properties.Resources.DocNo</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.DocumentNumber, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly", placeholder = @MyERP.Properties.Resources.DocNo, @required = "required", hidden = "hidden" } })
                                        <input id="DocumentNumbers" class="form-control" placeholder=@MyERP.Properties.Resources.Code required readonly />

                                    </div>

                                    @*<label for="DepartmentId" class="control-label col-sm-1">الفرع</label>
                                        <div class="col-sm-4">
                                            @Html.DropDownList("DepartmentId", null, "إختر", htmlAttributes: new { @class = "form-control", @required = "required" })
                                            <div class="invalid-feedback">
                                                الفرع مطلوب
                                            </div>
                                        </div>*@
                                </div>

                                @*<div class="form-group row">
                                        <label class="col-sm-1 control-label " for="Date">التاريخ</label>
                                        <div class="col-sm-4">
                                            <input id="Date" name="Date" class="form-control" type="datetime-local" value="@ViewBag.Date" required />
                                            <div class="invalid-feedback">
                                                التاريخ مطلوب
                                            </div>
                                        </div>
                                        <label class="col-sm-1 control-label " for="TotalMoneyAmount">القيمة</label>
                                        <div class="col-sm-4">
                                            @Html.EditorFor(model => model.TotalMoneyAmount, new { htmlAttributes = new { @class = "form-control money", placeholder = "القيمة", @required = "required" } })
                                            @Html.ValidationMessageFor(model => model.TotalMoneyAmount, "", new { @class = "text-danger" })
                                            <div class="invalid-feedback">
                                                القيمة مطلوب
                                            </div>
                                        </div>
                                    </div>*@

                                <!-- ------ -->

                                @*<div class="form-group row">
                                    <label class="col-sm-1 control-label " for="Date">التاريخ</label>
                                    <div class="col-sm-4">
                                        <input id="Date" name="Date" class="form-control" type="datetime-local" value="@ViewBag.Date" required />
                                        <div class="invalid-feedback">
                                            التاريخ مطلوب
                                        </div>
                                    </div>
                                </div>*@

                            <div class="form-group row">
                                <label class="col-sm-2 control-label " for="TotalMoneyAmount">@MyERP.Properties.Resources.Value</label>
                                <div class="col-sm-4">
                                    @Html.EditorFor(model => model.TotalMoneyAmount, new { htmlAttributes = new { @class = "form-control money", placeholder = @MyERP.Properties.Resources.Value, @required = "required" } })
                                    @Html.ValidationMessageFor(model => model.TotalMoneyAmount, "", new { @class = "text-danger" })
                                    <div class="invalid-feedback">
                                        @MyERP.Properties.Resources.Required
                                    </div>
                                </div>
                                <label class="col-sm-2 control-label " for="Date">@MyERP.Properties.Resources.Date</label>
                                <div class="col-sm-4">
                                    <input id="Date" name="Date" class="form-control" type="datetime-local" value="@ViewBag.Date" required />
                                    <div class="invalid-feedback">
                                        @MyERP.Properties.Resources.Required
                                    </div>
                                </div>
                            </div>

