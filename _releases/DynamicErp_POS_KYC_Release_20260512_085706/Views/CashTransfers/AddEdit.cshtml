    function cashBoxByDepartmentTo() {
        $.get('/Helper/CashBoxByDepartment/' + $('#DepartmentIdTo').val()).done(function (r) {
            $('#CashBoxIdTo').empty();
            for (var i = 0; i < r.length; i++) {
                $('#CashBoxIdTo').append($('<option>', {
                    value: r[i].Id,
                    text: r[i].ArName
                }));
            }
        });
    }
        function cashBoxByDepartmentFrom() {
        $.get('/Helper/CashBoxByDepartment/' + $('#DepartmentId').val()).done(function (r) {
            $('#CashBoxIdFrom').empty();
            for (var i = 0; i < r.length; i++) {
                $('#CashBoxIdFrom').append($('<option>', {
                    value: r[i].Id,
                    text: r[i].ArName
                }));
            }
        });
    }

    $(document).on('change', '#DepartmentIdTo', function () {
        if ($('#DepartmentIdTo').val()) {
             cashBoxByDepartmentTo();
        }
