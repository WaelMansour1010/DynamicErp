                                                @Html.DropDownList("BankAccountIdTo", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "BankAccountIdTo form-control" })
                                                @Html.ValidationMessageFor(model => model.BankAccountIdTo, "", new { @class = "text-danger" })
                                            </div>
                                        </div>
                                    </div>

                                </div>
                                @if (Model != null && Model.Id > 0 && Model.SystemPageId != null)
                                {
                                    <div class="form-group row">
                                        <label class="control-label col-sm-1" for="SystemPage">@MyERP.Properties.Resources.MainDoc</label>
                                        <div class="col-sm-5">
                                            <input id="SystemPage" class="form-control" type="text" readonly value="@Model.SystemPage.ArName" />
                                        </div>
                                        <label class="control-label col-sm-1">@MyERP.Properties.Resources.MainDocNo</label>
                                        <div class="col-sm-5">
                                            <input class="form-control" type="text" readonly value="@ViewBag.SourceDocNo" />
                                        </div>
                                    </div>
                                }
                                <div class="form-group row">
                                    <label class="control-label col-sm-2" for="Notes">@MyERP.Properties.Resources.Notes</label>
                                    <div class="col-sm-4">
                                        <textarea id="Notes" name="Notes" class="form-control" rows="5" cols="5">@if (Model != null) { @Model.Notes; }</textarea>
                                        @Html.ValidationMessageFor(model => model.Notes, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-offset-2">
                            <input id="new" name="newBtn" hidden />
                            @if (Model == null)
                            {
                        <button type="submit" id="Report" class="btn btn-success">
                            @MyERP.Properties.Resources.SaveAndPrint
                        </button>
                        <button type="submit" id="newbtn" class="btn btn-success">
                            @MyERP.Properties.Resources.SaveAndNew
                        </button>
                        <button type="submit" id="save" class="btn btn-success">
                            @MyERP.Properties.Resources.Save
                        </button>
                        <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                            }
                            else if (Model.IsDeleted == false)
                            {
                        <button type="submit" id="Report" class="btn btn-success" @Html.Raw(Model.SystemPage != null ? "disabled" : "")>
                            @MyERP.Properties.Resources.SaveAndPrint
                        </button>
                        <button type="submit" id="save" class="btn btn-success" @Html.Raw(Model.SystemPage != null ? "disabled" : "")>
                            @MyERP.Properties.Resources.Save
                        </button>
                        <a class="btn btn-success" target="_blank" href="@Url.Action("CashTransferDetails","Report",new { id=Model.Id})" role="button">@MyERP.Properties.Resources.Print</a>

                        <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                        <a href="javascript:void(0);" class="btn btn-danger" @Html.Raw(Model.SystemPage != null ? "hidden" : "") onclick="DeleteFunc(@Model.Id)" role="button">@MyERP.Properties.Resources.Delete</a>
                            }
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

