<script>


    if ($('#Id').val() > 0) {
        if ($('#TransferTypeId').val() == 1) {
            $("input[name='from'][value='bank']").attr('checked', 'checked');
            $("input[name='to'][value='bank']").attr('checked', 'checked');
        } else if ($('#TransferTypeId').val() == 2) {
            $("input[name='from'][value='bank']").attr('checked', 'checked');
            $("input[name='to'][value='cashbox']").attr('checked', 'checked');
        } else if ($('#TransferTypeId').val() == 3) {
            $("input[name='from'][value='cashbox']").attr('checked', 'checked');
            $("input[name='to'][value='cashbox']").attr('checked', 'checked');
        } else if ($('#TransferTypeId').val() == 4) {
            $("input[name='from'][value='cashbox']").attr('checked', 'checked');
            $("input[name='to'][value='bank']").attr('checked', 'checked');
        }
    }

    function SetFromTo() {
        var from = $("input[name='from']:checked").val();
        var to = $("input[name='to']:checked").val();

        if (from == 'bank') {
            $('.CashBoxIdFrom').hide();
            $('.BankIdFrom').show();
            $('.BankAccountIdFrom').show();
        } else if (from == 'cashbox') {
            $('.BankIdFrom').hide();
            $('.BankAccountIdFrom').hide();
            $('.CashBoxIdFrom').show();
        }

        if (to == 'bank') {
            $('.CashBoxIdTo').hide();
            $('.BankIdTo').show();
            $('.BankAccountIdTo').show();
        } else if (to == 'cashbox') {
            $('.BankIdTo').hide();
            $('.BankAccountIdTo').hide();
            $('.CashBoxIdTo').show();
        }

        if (from == 'bank' && to == 'bank') {
            $('#TransferTypeId').val(1);
        } else if (from == 'bank' && to == 'cashbox') {
            $('#TransferTypeId').val(2);
        } else if (from == 'cashbox' && to == 'cashbox') {
            $('#TransferTypeId').val(3);
        } else if (from == 'cashbox' && to == 'bank') {
            $('#TransferTypeId').val(4);
        }

    }



    SetFromTo();

    $("input[name='to']").on('change', function () {
        SetFromTo();
    });

    $("input[name='from']").on('change', function () {
        SetFromTo();
    });

    function BankAccountsByBankId(fromOrTo) {
        if (fromOrTo == 'from') {
            var accountsFrom = $.get('/CashTransfers/BankAccountsByBankId?id=' + $('#BankIdFrom').val())
                .done(function (r) {
                    if (accountsFrom != undefined) {
                        accountsFrom = accountsFrom.responseJSON;
                        $('#BankAccountIdFrom').empty();
                        for (var i = 0; i < accountsFrom.length; i++) {
                            $('#BankAccountIdFrom').append($('<option>', {
                                value: accountsFrom[i].Id,
                                text: accountsFrom[i].AccountNumber
                            }));

                        }
                    }
                });
        }
        else if (fromOrTo == 'to') {
            var accountsTo = $.get('/CashTransfers/BankAccountsByBankId?id=' + $('#BankIdTo').val())
                .done(function (r) {
                    if (accountsTo != undefined) {
                        accountsTo = accountsTo.responseJSON;
                        $('#BankAccountIdTo').empty();
                        for (var i = 0; i < accountsTo.length; i++) {
                            $('#BankAccountIdTo').append($('<option>', {
                                value: accountsTo[i].Id,
                                text: accountsTo[i].AccountNumber
                            }));
                        }
                    }
                });
        }
    }

