    //function BankAccountsByBankId() {
    //    $('#BankAccountIdFrom').empty();
    //    $('#BankAccountIdTo').empty();
    //    var accountsFrom = requestData('/CashTransfers/BankAccountsByBankId?id=' + $('#BankIdFrom').val())
    //        .done(function () {
