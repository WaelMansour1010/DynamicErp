
@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = @MyERP.Properties.Resources.CompetitionResult;
    Layout = "~/Views/Shared/_ActivityLayout.cshtml";
}
<script src="~/Scripts/SaveAndNew.js"></script>

<div class="row">
    <div class="col-12">
        <div class="page-title-box">

            <div class="text-center w-75 m-auto" style="padding-top: 2%;padding-bottom: 2%;">
                <span>
                    <img src="@ViewBag.logo" alt="" height="200" width="200" />
                </span>
            </div>

            <div class="hed page-title">@MyERP.Properties.Resources.CompetitionResult :</div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="form-horizontal needs-validation" role="form">
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">

                                <div class="form-group row">
                                    <label for="NoOfDays" class="control-label col-sm-2">@MyERP.Properties.Resources.NoOfCorrectAnswers</label>
                                    <div class="col-sm-4">
                                        <input id="NoOfCorrectAnswers" class="form-control" type="text" />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <div class="col-sm-offset-2">
                                        <button onclick="CompetitionResult(this,null);" class="btn btn-success">
                                            <i class="fa fa-search"></i>
                                        </button>
                                    </div>
                                </div>

                                <!----------------------------------------------------------------------------------------------------------------------------------------->

                                <br />

                                <div class="row">
                                    <div class="col-12">
                                        <div class="table-responsive">
                                            <table class="table table-striped table-centered mb-0">
                                                <thead>
                                                    <tr>
                                                        <th>
                                                            #
                                                        </th>
                                                        <th>
                                                            @MyERP.Properties.Resources.Name
                                                        </th>
                                                        <th>
                                                            @MyERP.Properties.Resources.Mobile
                                                        </th>
                                                        <th>
                                                            @MyERP.Properties.Resources.NoOfCorrectAnswers
                                                        </th>
                                                    </tr>
                                                </thead>
                                                <tbody id="Result">
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>


                            </div>
                        </div>
                    </div>


                </div>

                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">

                                <div class="form-group row">
                                    <label for="NoOfCompetitors" class="control-label col-sm-2">@MyERP.Properties.Resources.NoOfCompetitors</label>
                                    <div class="col-sm-4">
                                        <input id="NoOfCompetitors" class="form-control" type="text" />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <div class="col-sm-offset-2">
                                        <button onclick="CompetitionResult(null,this);" class="btn btn-success">
                                            <i class="fa fa-search"></i>
                                        </button>
                                    </div>
                                </div>

                                <!----------------------------------------------------------------------------------------------------------------------------------------->

                                <br />

                                <div class="row">
                                    <div class="col-12">
                                        <div class="table-responsive">
                                            <table class="table table-striped table-centered mb-0">
                                                <thead>
                                                    <tr>
                                                        <th>
                                                            #
                                                        </th>
                                                        <th>
                                                            @MyERP.Properties.Resources.Name
                                                        </th>
                                                        <th>
                                                            @MyERP.Properties.Resources.Mobile
                                                        </th>
                                                        <th>
                                                            @MyERP.Properties.Resources.NoOfCorrectAnswers
                                                        </th>
                                                    </tr>
                                                </thead>
                                                <tbody id="FilteredResult">
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>


                            </div>
                        </div>
                    </div>


                </div>

                <br />

                <!---------------------------------------------- Saves Buttons ----------------------------------------------------------->
                <div class="row">
                    <div class="col-sm-offset-2">
                        <button onclick="addEdit();" class="btn btn-success" id="save">
                            @MyERP.Properties.Resources.Save
                        </button>
                        <button onclick="Delete();" class="btn btn-success">
                            @MyERP.Properties.Resources.Delete
                        </button>
                    </div>
                </div>
                <!----------------------------------------------------------------------------------------------------------------------------------------->

            </div>
        </div>
    </div>
</div>



<script>
    //--------------- Variables Declarations -------------------//

    //*********************************************************//
    //--------------- Ready Function -------------------//
    $(document).ready(function () {
        if ($('#Id').val() == 0) {
        }
    });

    //*********************************************************//
    //--------------- Event Functions -------------------//

    //*********************************************************//
    //--------------- Other Functions -------------------//
    function convertToJavaScriptDate(value) {
        if (value === null)
            return null;
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        return ((dt.getMonth() + 1 + "/" + dt.getDate() + "/" + dt.getFullYear()));
        // return (dt)
    }
    function zeroPadded(val) {
        if (val >= 10)
            return val;
        else
            return '0' + val;
    }
    function CompetitionResult(Ans, Comp) {
        var Answer = $(Ans).closest('.form-group').find('#NoOfCorrectAnswers').val();
        var Competitor = $(Comp).closest('.form-group').find('#NoOfCompetitors').val();
        if (Competitor == undefined) {
            $("#Result").empty();
            $("#FilteredResult").empty();
            $('#NoOfCompetitors').val('');
            $('#preloader, #status').fadeIn();
            $.get('/CompetitorAnswer/CompetitionResult?NoOfCorrectAnswers=' + $('#NoOfCorrectAnswers').val() + '&NoOfCompetitors=' + null).done(function (r) {
                console.log(r)
                for (var i = 0; i < r.length; i++) {
                    r[i].Name = r[i].Name != null ? r[i].Name : "";
                    r[i].Mobile = r[i].Mobile != null ? r[i].Mobile : "";
                    var tr = '<tr class="ResultTr"><td><label class="control-label Number">' +
                        (i + 1) + '</label></td><td><input class="CompetitorId" hidden value="' + r[i].CompetitorId +'"/><input class="IsSelected" hidden type="checkbox"/><label class="control-label">' +
                        r[i].Name + '</label></td><td><label class="control-label Mobile">' +
                        r[i].Mobile + '</label></td><td><label class="control-label NoOfCorrectAnswers">' +
                        r[i].NoOfCorrectAnswers + '</label></td></tr>';
                    $("#Result").append(tr);
                }
            });
            $('#preloader, #status').fadeOut();
        }
        else if (Answer == undefined) {
            $("#FilteredResult").empty();
            $('#preloader, #status').fadeIn();
            $('.ResultTr').css('background-color', '');
            $.get('/CompetitorAnswer/CompetitionResult?NoOfCorrectAnswers=' + $('#NoOfCorrectAnswers').val() + '&NoOfCompetitors=' + $('#NoOfCompetitors').val()).done(function (r) {
                for (var i = 0; i < r.length; i++) {
                    r[i].Name = r[i].Name != null ? r[i].Name : "";
                    r[i].Mobile = r[i].Mobile != null ? r[i].Mobile : "";
                    var tr = '<tr><td><label class="control-label Number">' +
                        (i + 1) + '</label></td><td><input class="CompetitorId" hidden value="' +
                        r[i].CompetitorId + '"/><input class="IsSelected" hidden type="checkbox"/><label class="control-label">' +
                        r[i].Name + '</label></td><td><label class="control-label Mobile">' +
                        r[i].Mobile + '</label></td><td><label class="control-label NoOfCorrectAnswers">' +
                        r[i].NoOfCorrectAnswers + '</label></td></tr>';
                    $("#FilteredResult").append(tr);

                    $('#Result tr').each(function () {
                        var td = $(this);
                        if (r[i].Mobile === td.find('.Mobile').text()) {
                            td.css('background-color', 'lightpink');
                            td.find('.IsSelected').prop('checked',true);
                        }
                    });

                }

            });

            $('#preloader, #status').fadeOut();
        }
    }

//***********************************************************************************************************************************//
                function addEdit(n) {
        let valid = true;
        if ($('.form-horizontal').first().find('.form-control:invalid').length > 0) {
            $('.form-horizontal').first().addClass('was-validated');
            $('html, body').animate({
                scrollTop: $('.form-horizontal').first().find(".form-control:invalid").eq(0).offset().top - 100
            }, 500);
            valid = false;
            console.log($(".form-control:invalid"));
        }
                var CompetitionResults = [];
            if (valid) {
                $('#Result tr').each(function () {
                    var td = $(this);
                    var CompetitionResult = {
                        Number: td.find('.Number').text(),
                        NoOfCorrectAnswers: td.find('.NoOfCorrectAnswers').text(),
                        CompetitorId: td.find('.CompetitorId').val(),
                        IsDeleted: false,
                        IsActive: true,
                        IsSelected: td.find('.IsSelected').prop('checked'),
                    };
                        CompetitionResults.push(CompetitionResult);
                    
                });
            }
                if (CompetitionResults.length == 0) {
                Swal.fire({
                    title: '@MyERP.Properties.Resources.AllDetailsRequired',
                    text: " ",
                    icon: 'info',
                    showCancelButton: false,
                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                    confirmButtonColor: '#3085d6'
                });
                valid = false;
            }
            
        if (valid) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.AreYouSureYouWantToSave',
                text: " ",
                icon: 'info',
                showCancelButton: true,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                cancelButtonText: '@MyERP.Properties.Resources.Cancel',
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    $('#preloader, #status').fadeIn();
                    $('#newbtn').prop('disabled', true);
                    $('#save').prop('disabled', true);
                    $.ajax({
                        type: "POST", contentType: "application/json",
                        url: "/CompetitorAnswer/CompetitionResult",
                        data: JSON.stringify(CompetitionResults),
                        success: function (r) {
                            if (r.success == true) {
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.Saved',
                                    text: " ",
                                    icon: 'success',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });

                                window.location.replace("/CompetitorAnswer/CompetitionResult");

                            }
                            else {
                                Swal.fire({
                                    title: '@MyERP.Properties.Resources.NotSaved !',
                                    text: " ",
                                    icon: 'error',
                                    showCancelButton: false,
                                    confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                    confirmButtonColor: '#3085d6'
                                });
                            }
                            $('#preloader, #status').fadeOut();
                            $('#newbtn').prop('disabled', false);
                            $('#save').prop('disabled', false);
                        },
                        error: function (r) {
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.NotSaved !',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                            $('#preloader, #status').fadeOut();
                            $('#newbtn').prop('disabled', false);
                            $('#save').prop('disabled', false);
                        }
                    });
                }
                else { result.dismiss; }
            });
        }
    }

</script>