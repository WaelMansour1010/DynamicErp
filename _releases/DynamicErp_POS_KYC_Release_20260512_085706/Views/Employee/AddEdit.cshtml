<script>
    var EnterEmployeeCodeManually = '@ViewBag.EnterEmployeeCodeManually';

    function zeroPadded(val) {
        if (val >= 10)
            return val;
        else
            return '0' + val;
    }
    function setCodeNum() {
        var doc = $.get('/Employee/SetCodeNum?FieldsCodingId=' + $('#FieldsCodingId').val()).done(function (r) {
            $('#Code').val(r);
        });
    }

    $('#FieldsCodingId').on('change', function () {
        if (!$('#Id').val()) {
            if (EnterEmployeeCodeManually != 'True') {
                setCodeNum();
            }
        }
    });
    // disable gives Null with form Submit so we have to reverse it in submin
    $("form").submit(function () {
        $("#FieldsCodingId").prop('disabled', false);
    });

    $(document).ready(function () {

            $('#img').on('change', function () {

                $('#oImg').val($('#img').val());
            });

        if ($('#Id').val() > 0) {
            $('#FieldsCodingId').prop('disabled', true);
        $('#Birthdate').val('@ViewBag.Birthdate');
        $('#HireDate').val('@ViewBag.HireDate');
        $('#ResidenceReleaseDate').val('@ViewBag.ResidenceReleaseDate');
        $('#ResidenceExpiryDate').val('@ViewBag.ResidenceExpiryDate');
        $('#NationalExpiryDate').val('@ViewBag.NationalExpiryDate');
        $('#IndustrialSafetyExpiryDate').val('@ViewBag.IndustrialSafetyExpiryDate');
        $('#WorkLicenseExpiryDate').val('@ViewBag.WorkLicenseExpiryDate');
        $('#WorkLicenseReleaseDate').val('@ViewBag.WorkLicenseReleaseDate');
        $('#DrivingLicenseExpiryDate').val('@ViewBag.DrivingLicenseExpiryDate');
        $('#DrivingLicenseReleaseDate').val('@ViewBag.DrivingLicenseReleaseDate');
        $('#PassportReleaseDate').val('@ViewBag.PassportReleaseDate');
        $('#PassportExpiryDate').val('@ViewBag.PassportExpiryDate');
    }
    else
        {
            if (EnterEmployeeCodeManually != 'True') {
                setCodeNum();
            }
        var d = new Date();
        $('#HireDate').val(d.getFullYear() + "-" + zeroPadded(d.getMonth() + 1) + "-" + zeroPadded(d.getDate()) + "T" + zeroPadded(d.getHours()) + ":" + zeroPadded(d.getMinutes()));
        $('#Birthdate').val(d.getFullYear() + "-" + zeroPadded(d.getMonth() + 1) + "-" + zeroPadded(d.getDate()) + "T" + zeroPadded(d.getHours()) + ":" + zeroPadded(d.getMinutes()));
         $('#DrivingLicenseExpiryDate').val(d.getFullYear() + "-" + zeroPadded(d.getMonth() + 1) + "-" + zeroPadded(d.getDate()) + "T" + zeroPadded(d.getHours()) + ":" + zeroPadded(d.getMinutes()));
        $('#DrivingLicenseReleaseDate').val(d.getFullYear() + "-" + zeroPadded(d.getMonth() + 1) + "-" + zeroPadded(d.getDate()) + "T" + zeroPadded(d.getHours()) + ":" + zeroPadded(d.getMinutes()));
        $('#WorkLicenseExpiryDate').val(d.getFullYear() + "-" + zeroPadded(d.getMonth() + 1) + "-" + zeroPadded(d.getDate()) + "T" + zeroPadded(d.getHours()) + ":" + zeroPadded(d.getMinutes()));
        $('#WorkLicenseReleaseDate').val(d.getFullYear() + "-" + zeroPadded(d.getMonth() + 1) + "-" + zeroPadded(d.getDate()) + "T" + zeroPadded(d.getHours()) + ":" + zeroPadded(d.getMinutes()));
        $('#ResidenceExpiryDate').val(d.getFullYear() + "-" + zeroPadded(d.getMonth() + 1) + "-" + zeroPadded(d.getDate()) + "T" + zeroPadded(d.getHours()) + ":" + zeroPadded(d.getMinutes()));
        $('#ResidenceReleaseDate').val(d.getFullYear() + "-" + zeroPadded(d.getMonth() + 1) + "-" + zeroPadded(d.getDate()) + "T" + zeroPadded(d.getHours()) + ":" + zeroPadded(d.getMinutes()));
        $('#IndustrialSafetyExpiryDate').val(d.getFullYear() + "-" + zeroPadded(d.getMonth() + 1) + "-" + zeroPadded(d.getDate()) + "T" + zeroPadded(d.getHours()) + ":" + zeroPadded(d.getMinutes()));
        $('#PassportExpiryDate').val(d.getFullYear() + "-" + zeroPadded(d.getMonth() + 1) + "-" + zeroPadded(d.getDate()) + "T" + zeroPadded(d.getHours()) + ":" + zeroPadded(d.getMinutes()));
        $('#PassportReleaseDate').val(d.getFullYear() + "-" + zeroPadded(d.getMonth() + 1) + "-" + zeroPadded(d.getDate()) + "T" + zeroPadded(d.getHours()) + ":" + zeroPadded(d.getMinutes()));
        $('#NationalExpiryDate').val(d.getFullYear() + "-" + zeroPadded(d.getMonth() + 1) + "-" + zeroPadded(d.getDate()) + "T" + zeroPadded(d.getHours()) + ":" + zeroPadded(d.getMinutes()));

        }
        $('.Gregorian').each(function () {
            var Hijry = new Intl.DateTimeFormat('ar-sa').format(new Date($(this).val())).toString();
            $('#Hijry' + $(this).attr('id') + '').val(Hijry);
        });

    });

    $('#Birthdate').change(function () {
            var date = new Date();
            var CurrentYear = date.getFullYear();
            var BD = $('#Birthdate').val();
            var NewDate = new Date(BD);
            var BirthYear = NewDate.getFullYear();
            var Diff = CurrentYear - BirthYear;
            $('#Age').val(Diff);
    });

    $('.Gregorian').on('change',function () {

        var Hijry = new Intl.DateTimeFormat('ar-sa').format(new Date($(this).val())).toString();
        $('#Hijry'+$(this).attr('id')+'').val(Hijry);

    });



    //--------------------------------------------------//

        $(".photo").change(function () {
            $(".imgold").addClass("hidden");
        });
        function readURL(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();

                reader.onload = function (e) {
                    $(".imgnew").removeClass("hidden");

                    $('#blah')
                        .attr('src', e.target.result)

                };

                reader.readAsDataURL(input.files[0]);
            }
    }
        function Delete(id) {
        if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToDelete')) {
            $('#preloader, #status').fadeIn();
            $.ajax(
                {
                    url: '/Employee/Delete',
                    type: 'POST',
                    data: {
                        "Id": id,
                    },
                    error: function (e) {
                        $('#preloader, #status').fadeOut();
                    },
                    success: function (r) {
                        if (r == 'true') {
                            window.location.replace('/Employee');
                        }
                    }
                });
        }
    }


</script>