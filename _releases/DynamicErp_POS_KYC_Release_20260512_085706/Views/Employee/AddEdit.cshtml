                                    {
                                        <a class="btn btn-success" target="_blank" href="/Report/EmployeesContract/@Model.EmployeeContracts.Where(a => a.EmployeeId == Model.Id).FirstOrDefault().Id" role="button">@MyERP.Properties.Resources.PrintContract</a>
