    function AddNewRow(e,s) {
        var keycode = (e.keyCode ? e.keyCode : e.which);
        if (keycode == '13' && $('#EmployeeExperiences .Experience:last').val()) {
            let tr = '<tr><td class="col-sm-6"><input class="Experience form-control" type="text" onkeypress="AddNewRow(event,this)" /></td><td><button type="button" class="btn btn-danger" onclick="deleteElement(this)">@MyERP.Properties.Resources.Delete</button></td></tr>';
            $('#EmployeeExperiences').append(tr);
            $('#EmployeeExperiences .Experience:last').focus();
        }

    }
    function deleteElement(e,s) {
        let tr = $(e).closest('tr');
        if ($(tr).index() == 0 && $(tr).closest('tbody').children('tr').length == 1) {
            $(tr).find("input").val('');
            $(tr).find("label").text('');
            $(tr).find('input, select').removeAttr('required');
            $(tr).find('select').empty();
            if (s == "remove") {
                $(tr).remove();
            }
        }
        else if ($(tr).index() < $(tr).closest('tbody').children('tr').length - 1) {
            e.parentNode.parentNode.parentNode.removeChild(e.parentNode.parentNode);
            if (s == "remove") {
                $(tr).remove();
            }
        }
        else if ($(tr).index() == $(tr).closest('tbody').children('tr').length - 1) {
            $(tr).find("input").val('');
            $(tr).find('input, select').removeAttr('required');
            $(tr).find('select').empty();
            $(tr).find("label").text('');
            if (s == "remove") {
                $(tr).remove();
            }
        }

    }

    function GetJobRequestDetailsByEmployeeId() {
        $.get('/Employee/GetJobRequestDetailsByEmployeeId?id=' + $('#Id').val()).done(function (r) {
            for (var i = 0; i < r.length; i++) {
                var JobRequestDate;
                JobRequestDate = r[i].JobRequestDate == null ? "" : convertToJavaScriptDate(r[i].JobRequestDate);
                let tr = '<tr><td>' + r[i].CompanyName + '</td><td>' + r[i].JobName + '</td><td>' + r[i].CompanyJobRequestNo + '</td><td>' + JobRequestDate + '</td><td>' + r[i].JobStatusName + '</td><td><a href = "/CompanyJobRequest/AddEdit/' + r[i].CompanyJobRequestId + '" target="_blank" ><i class="mdi mdi-eye"></i></a></td > <td><a href ="https://api.whatsapp.com/send?phone=+2 ' + r[i].EmployeeMobile + '&text=تم ترشيحك لوظيفة: ' + r[i].JobName + ', فى شركة: ' + r[i].CompanyName + ', برجاء الإتصال بالمسئول: ' + r[i].Interviewer+', على رقم: ' + r[i].CompanyNumber+' وترتيب موعد مقابلة " target="_blank"> <i class="fab fa-whatsapp"></i></a></td></tr>';
                $('#RequestStatus').append(tr);
            }
        });
    }

