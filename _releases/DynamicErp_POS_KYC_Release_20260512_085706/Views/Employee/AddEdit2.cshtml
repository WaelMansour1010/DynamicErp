<script>

    //--------------- Variables Declarations -------------------//
    let remove = "remove";
    var Imgdata = "";
    var Filedata = "";
    var Employees = [];
    //*********************************************************//
    //--------------- Ready Function -------------------//
    $(document).ready(function () {
        if ($('#Id').val() > 0) {
            GetJobRequestDetailsByEmployeeId();
            $('#Birthdate').val('@ViewBag.Birthdate');
            $('#ApplicationDate').val('@ViewBag.ApplicationDate');
        }
        else {
            setCodeNum();
            var d = new Date();
            $('#ApplicationDate').val(d.getFullYear() + "-" + zeroPadded(d.getMonth() + 1) + "-" + zeroPadded(d.getDate()) + "T" + zeroPadded(d.getHours()) + ":" + zeroPadded(d.getMinutes()));
            $('#Birthdate').val(d.getFullYear() + "-" + zeroPadded(d.getMonth() + 1) + "-" + zeroPadded(d.getDate()) + "T" + zeroPadded(d.getHours()) + ":" + zeroPadded(d.getMinutes()));
        }
        GetAllEmployees();
    });
    //*********************************************************//
    //--------------- Event Functions -------------------//
    $('#NationalId').on('change', function () {
        let employee = Employees.filter(function (i) {return i.NationalId == $('#NationalId').val();})/*[0].Id*/;
        if (employee.length > 0) {
            let employeeId = employee[0].Id
            alert("@MyERP.Properties.Resources.NationalNoExistsBefore");
            window.location.replace("/Employee/AddEdit2/" + employeeId);
        }
    });
    //*********************************************************//
    //--------------- Other Functions -------------------//
    function GetAllEmployees() {
        $.get("/Helper/GetAllEmployees").done(function (r) {
            Employees = r;
        })
    }
    function previewImage() {
        var reader = new FileReader();
        reader.addEventListener("load", function () {

            $("#gallery").html('<img style="max-width: 200px;max-height: 200px;margin-left: 2%;margin-bottom: 2%;" src="' + reader.result + '" alt="" /><i class="fas fa-trash-alt" style="cursor:pointer;" onclick="DeleteIMG(\'' + reader.result + '\');$(this).prev().remove();$(this).remove();"></i>');
            $("#Image").val(reader.result);
            Imgdata = reader.result;
        }, false);

        for (var i = 0; i < $("#BrowseImage")[0].files.length; i++) {
            if ($("#BrowseImage")[0].files[i]) {
                reader.readAsDataURL($("#BrowseImage")[0].files[i]);
            }
        }
    }
