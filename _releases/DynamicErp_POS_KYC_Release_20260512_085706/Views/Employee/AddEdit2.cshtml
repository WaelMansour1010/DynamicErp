    function Delete(id) {
        if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToDelete')) {
            $('#preloader, #status').fadeIn();
            $.ajax(
                {
                    url: '/Employee/Delete',
                    type: 'POST',
                    data: {
                        "Id": id,
                    },
                    error: function (e) {
                        alert("@MyERP.Properties.Resources.DeleteDoesNotSucceeded");
                        $('#preloader, #status').fadeOut();
                    },
                    success: function (r) {
                        if (r == 'true') {
                            alert("@MyERP.Properties.Resources.Deleted");
                            window.location.replace('/Employee');
                        }
                        else {
                            alert("@MyERP.Properties.Resources.DeleteDoesNotSucceeded");
                            $('#preloader, #status').fadeOut();
                        }
                    }
                });
        }
    }

    function addEdit(n) {
        if ($(".form-control:invalid").length > 0) {
            console.log($(".form-control:invalid"));
            $('.form-horizontal').addClass('was-validated');
            $('html, body').animate({
                scrollTop: $(".form-control:invalid").eq(0).offset().top - 100
            }, 500);
        }
        else {
            var employeeJobs = [];
            $('#EmployeeJobs tr').each(function () {
                var td = $(this);
                if (td.find('.EmpJobId').val()) {
                    var employeeJob = {
                        EmployeeId: $('#Id').val(),
                        JobId: td.find('.EmpJobId').val()
                    };
                    employeeJobs.push(employeeJob);
                }
            });
            var employeeExperiences = [];
            $('#EmployeeExperiences tr').each(function () {
                var td = $(this);
                if (td.find('.Experience').val()) {
                    var employeeExperience = {
                        EmployeeId: $('#Id').val(),
                        Experience: td.find('.Experience').val()
                    };
                    employeeExperiences.push(employeeExperience);
                }
            });
            var employeeQualifications = [];
            $('#EmployeeQualifications tr').each(function () {
                var td = $(this);
                if (td.find('.EmpQualificationId').val()) {
                    var employeeQualification = {
                        EmployeeId: $('#Id').val(),
                        QualificationId: td.find('.EmpQualificationId').val()
                    };
                    employeeQualifications.push(employeeQualification);
                }
            });
            var employee =
            {
                Id: $('#Id').val(),
                Code: $('#Code').val(),
                ArName: $('#ArName').val(),
                Qualification: $('#Qualification').val(),
                GraduationYear: $('#GraduationYear').val(),
                MobileNumber: $('#MobileNumber').val(),
                PhoneNumber: $('#PhoneNumber').val(),
                EmployeeAddress: $('#EmployeeAddress').val(),
                ApplicantWorkStatusId: $('#ApplicantWorkStatusId').val(),
                ApplicationDate: $('#ApplicationDate').val(),
                Birthdate: $('#Birthdate').val(),
                Email: $('#Email').val(),
                ExpectedSalary: $('#ExpectedSalary').inputmask('unmaskedvalue'),
                GenderId: $('#GenderId').val(),
                ChurchId: $('#ChurchId').val(),
                MaritalStatusId: $('#MaritalStatusId').val(),
                NationalId: $('#NationalId').val(),
                Image: Imgdata,
                CV: Filedata,
                IsActive: true,
                IsDeleted: false,
                EmployeeJobs: employeeJobs,
                EmployeeExperiences: employeeExperiences,
                EmployeeQualifications: employeeQualifications,
                AreaId: $('#AreaId').val(),
                PassportId: $('#PassportId').val(),
                MobileNumber2: $('#MobileNumber2').val(),


            };
            if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToSave')) {
                $.ajax({
                    type: "POST",
                    url: "/Employee/AddEdit2",
                    data: employee,
                    success: function (r) {
                        if (r.success == "true") {
                            if (n == "new") {
                                window.location.replace("/Employee/AddEdit2");
                            } else {
                                window.location.replace("/Employee");
                            }
                        }
                        else {
                            alert('@MyERP.Properties.Resources.NotSaved');
                            $('#preloader, #status').fadeOut();
                        }
                    },
                    error: function (r) {
                        $('#preloader, #status').fadeOut();
                        alert('@MyERP.Properties.Resources.NotSaved');
                    }
                });
            }
        }
    }

