    function previewFile() {
        var reader = new FileReader();
        reader.addEventListener("load", function () {
            $("#gallery1").html('<input type="file" style="max-width: 200px;max-height: 200px;margin-left: 2%;margin-bottom: 2%;" src="' + reader.result + '" alt="" /><i class="fas fa-trash-alt" style="cursor:pointer;" onclick="DeleteIMG(\'' + reader.result + '\');$(this).prev().remove();$(this).remove();"></i>');
            $("#CV").val(reader.result);
            Filedata = reader.result;
        }, false);
        for (var i = 0; i < $("#BrowseFile")[0].files.length; i++) {
            if ($("#BrowseFile")[0].files[i]) {
                reader.readAsDataURL($("#BrowseFile")[0].files[i]);
            }
        }
    }

    function zeroPadded(val) {
        if (val >= 10)
            return val;
        else
            return '0' + val;
    }
    //for date Converting
    function convertToJavaScriptDate(value) {
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        return (dt.getMonth() + 1) + "/" + dt.getDate() + "/" + dt.getFullYear();
    }
