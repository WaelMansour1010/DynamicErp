@model MyERP.Models.EmployeeMonthlyAllocation

@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";

    ViewBag.Title = MyERP.Properties.Resources.EmployeeMonthlyAllocation;
}
<script src="~/Scripts/SaveAndNew.js"></script>

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                @if (Model != null)
                {
                    if (Model.IsDeleted == false)
                    {
                        if (ViewBag.Previous > 0)
                        {
                            <a href="@Url.Action("AddEdit",new {id= ViewBag.First })" class="btn btn-info">@MyERP.Properties.Resources.First</a>
                            <a href="@Url.Action("AddEdit",new { id=ViewBag.Previous })" class=" btn btn-info">&#8250;</a>
                        }
                        if (ViewBag.Next > 0)
                        {
                            <a href="@Url.Action("AddEdit",new { id=ViewBag.Next })" class="btn btn-info">&#8249;</a>
                            <a href="@Url.Action("AddEdit",new {id=ViewBag.Last })" class="btn btn-info">@MyERP.Properties.Resources.Last</a>
                        }
                    }
                }
                <a class="btn btn-info" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
            </div>
            <div class="hed page-title">@MyERP.Properties.Resources.EmployeeMonthlyAllocation :</div>
        </div>
    </div>
</div>
<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="form-horizontal needs-validation" role="form">

                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">
                                <div class="form-group row">
                                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                    @Html.AntiForgeryToken()
                                    @if (Model != null)
                                    {
                                        @Html.HiddenFor(model => model.Id)
                                        @Html.HiddenFor(model => model.UserId)
                                        @Html.HiddenFor(model => model.Image)
                                        @Html.HiddenFor(model => model.IsDeleted)
                                    }
                                    <label class=" col-sm-2 control-label" for="DocumentNumber">@MyERP.Properties.Resources.DocNo</label>
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.DocumentNumber, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly", placeholder = @MyERP.Properties.Resources.DocNo, hidden = "hidden" } })
                                        <input id="DocumentNumbers" class="form-control" placeholder=@MyERP.Properties.Resources.DocNo required readonly />

                                    </div>
                                    <label for="DepartmentId" class="control-label col-sm-2">@MyERP.Properties.Resources.Department</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownListFor(model => model.DepartmentId, null, null, htmlAttributes: new { @class = "form-control", @required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>

                                <div class="form-group row">
                                    <label for="AllocationTypeId" class="control-label col-sm-2">@MyERP.Properties.Resources.AllocationType</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownListFor(model => model.AllocationTypeId, null, null, htmlAttributes: new { @class = "form-control", @required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                    <label class="col-sm-2 control-label " for="VoucherDate">@MyERP.Properties.Resources.VoucherDate</label>
                                    <div class="col-sm-4">
                                        <input type="datetime-local" name="VoucherDate" id="VoucherDate" class="form-control" value="@ViewBag.VoucherDate" required />
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class=" col-sm-2 control-label" for="Year">@MyERP.Properties.Resources.Year</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("Year", null, htmlAttributes: new { @class = "form-control", required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>

                                    <label class=" col-sm-2 control-label" for="Month">@MyERP.Properties.Resources.Month</label>
                                    <div class="col-sm-4">
                                        @Html.DropDownList("Month", null, htmlAttributes: new { @class = "form-control", required = "required" })
                                        <div class="invalid-feedback">
                                            @MyERP.Properties.Resources.Required
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="control-label col-sm-2" for="Notes">@MyERP.Properties.Resources.Notes</label>
                                    <div class="col-sm-4">
                                        <textarea id="Notes" name="Notes" class="form-control" rows="5" cols="5">@if (Model != null) { @Model.Notes; }</textarea>
                                        @Html.ValidationMessageFor(model => model.Notes, "", new { @class = "text-danger" })
                                    </div>
                                    <div class="col-sm-6">
                                        <button onclick="GetEmployeeMonthlyAllocation();" class="btn btn-success">
                                            <i class="fas fa-search"></i>
                                        </button>
                                    </div>
                                </div>


                                <!--Details Table-->
                                <div class="row">
                                    <div class="col-12">
                                        <div class="form-horizontal needs-validation" role="form">
                                            <div class="card">
                                                <div class="card-body">
                                                    <div class="header-title">
                                                        @MyERP.Properties.Resources.Details
                                                    </div>
                                                    <div class="table-responsive">
                                                        <table class="table table-centered mb-0">
                                                            <thead>
                                                                <tr>
                                                                    <td>
                                                                        @MyERP.Properties.Resources.Employee
                                                                    </td>
                                                                    <td>
                                                                        @MyERP.Properties.Resources.Value
                                                                    </td>
                                                                    <td>
                                                                        @MyERP.Properties.Resources.Notes
                                                                    </td>
                                                                </tr>
                                                            </thead>
                                                            <tbody id="EmployeeMonthlyAllocationDetails">
                                                                @if (Model != null)
                                                                {
                                                                    foreach (var item in Model.EmployeeMonthlyAllocationDetails)
                                                                    {
                                                                        <tr>
                                                                            <td class="tabledit-edit-mode">
                                                                                <input hidden class="EmployeeId" value="@item.EmployeeId" required />
                                                                                <label class="col-form-label">@item.Employee.ArName</label>
                                                                            </td>

                                                                            <td class="tabledit-edit-mode">
                                                                                <input type="number" step="any" class="Value form-control tabledit-input form-control-sm" value="@item.Value" disabled readonly />
                                                                            </td>

                                                                            <td class="tabledit-edit-mode">
                                                                                <input type="text" class="Notes form-control tabledit-input form-control-sm" value="@item.Notes" @*required*@ />
                                                                            </td>
                                                                        </tr>
                                                                    }
                                                                }

                                                            </tbody>
                                                        </table>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!--End Of Details Table-->

                            </div>
                        </div>

                        <!--**********************************************************************-->

                        <div class="row">
                            <div class="col-sm-offset-2">
                                @if (Model == null)
                                {
                                    <button onclick="addEdit('new');" class="btn btn-success" id="newbtn">
                                        @MyERP.Properties.Resources.SaveAndNew
                                    </button>
                                    <button onclick="addEdit();" class="btn btn-success" id="save">
                                        @MyERP.Properties.Resources.Save
                                    </button>
                                    <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                                }
                                else if (Model.IsDeleted == false)
                                {
                                    <button onclick="addEdit();" class="btn btn-success" id="save">
                                        @MyERP.Properties.Resources.Save
                                    </button>
                                    <a class="btn btn-danger" href="@Url.Action("Index")" role="button">@MyERP.Properties.Resources.Back</a>
                                    <a href="javascript:void(0);" class="btn btn-danger" onclick="Delete(@Model.Id)" role="button">@MyERP.Properties.Resources.Delete</a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (Model != null)
{
    if (ViewBag.JE != null)
    {
        <div class="card">
            <div class="card-body">
                <h5 class="header-title">@MyERP.Properties.Resources.JournalEntries</h5>
                <div class="form-horizontal">
                    <div class="form-group row">
                        <label for="inputtext3" class="col-sm-2 control-label">@MyERP.Properties.Resources.VoucherNo</label>
                        <div class="col-sm-4">
                            <input type="text" class="form-control" name="txtDocNo" value="@ViewBag.JE.DocumentNumber" id="txtDocNo" placeholder=@MyERP.Properties.Resources.VoucherNo disabled>
                        </div>
                        <label for="inputtext3" class="col-sm-2 control-label">@MyERP.Properties.Resources.Branch</label>
                        <div class="col-sm-4">
                            @Html.DropDownList("DepartmentId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", id = "DepartmentId", @required = "required", @disabled = "disabled" })
                        </div>
                    </div>
                    
                    <div class="card">
                        <div class="card-body">
                            <h5 class="header-title"> @MyERP.Properties.Resources.JournalEntryDetails</h5>
                            <div class="table-responsive">
                                <table class="table table-centered mb-0">
                                    <thead>
                                        <tr>
                                            <th>@MyERP.Properties.Resources.Account</th>
                                            <th>@MyERP.Properties.Resources.Explanation</th>
                                            <th>@MyERP.Properties.Resources.Debit</th>
                                            <th>@MyERP.Properties.Resources.Credit</th>                                           
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model.Id > 0)
                                        {

                                            foreach (var jED in ViewBag.JEDetails)
                                            {
                                        <tr>
                                            <td>
                                                @if (jED.AccountId != null)
                                                {
                                                    <label>@jED.ChartOfAccount.ArName</label>
                                                    <input type='number' class='AccountId' value="@jED.AccountId" hidden>
                                                }
                                            </td>
                                            <td>
                                                <label>@jED.Notes</label>
                                                <input type='text' class='txtNotes' value="@jED.Notes" hidden>
                                            </td>
                                            <td>
                                                <label>@jED.Debit</label>
                                                <input type='text' class='txtDebit' value="@jED.Debit" hidden>
                                            </td>
                                            <td>
                                                <label>@jED.Credit</label>
                                                <input type='text' class='txtCredit ' value="@jED.Credit" hidden>
                                            </td>
                                        </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
}

<script>
    //---------------------- Variable Declaration -----------------------//
    //********************************************************************//

    //----------------------  Ready Finction -----------------------//
    $(document).ready(function () {
        $.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
            $("input[type|='datetime-local']")/*.not('#TransactionDate')*/.prop('min', r.PeriodStart).prop('max', r.PeriodEnd);
            // $('#VoucherDate').val('@ViewBag.VoucherDate');
        });
        if (!$('#Id').val()) {
            setDocNum();
        }
        else {
            var code = $('#DocumentNumber').val();
            $('#DocumentNumbers').val(code.replaceAll("-", ""))
            $("#DepartmentId").prop('disabled', true);
            $("#VoucherDate").prop('disabled', true);
        }
        PreviousEmployeeMonthlyAllocation();

    });
    //********************************************************************//

    //----------------------  Event Functions -----------------------//
    $(document).on('change', '#DepartmentId', function () {
        if ($('#DepartmentId').val()) {
            setDocNum();
        }
    });

    $(document).on('change', '#Month,#Year,#AllocationTypeId', function () {
        PreviousEmployeeMonthlyAllocation();
    });
    $('#VoucherDate').on('change', function () {
        setDocNum();
    });
    //********************************************************************//

     //----------------------  Other Functions -----------------------//
    function setDocNum() {
        if ($('#DepartmentId').val()) {
            $.get('/EmployeeMonthlyAllocation/SetDocNum?id=' + $('#DepartmentId').val() + '&VoucherDate=' + $('#VoucherDate').val()).done(function (r) {
                $('#DocumentNumber').val(r);
                $('#DocumentNumbers').val(r.replaceAll("-", ""));
            });
        }
    }
    function convertToJavaScriptDate(value) {
        if (value === null)
            return null;
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        return ((dt.getMonth() + 1 + "/" + dt.getDate() + "/" + dt.getFullYear()));
    }

    function GetEmployeeMonthlyAllocation() {
        $('#EmployeeMonthlyAllocationDetails').empty()
        $('#preloader, #status').fadeIn();

        $.get('/EmployeeMonthlyAllocation/GetEmployeeMonthlyAllocation?departmentId=' + $('#DepartmentId').val() + '&allocationType=' + $('#AllocationTypeId').val())
            .done(function (r) {
                // console.log(r, "Rr")
                if (r.length > 0) {
                    let tr;
                    for (var i = 0; i < r.length; i++) {
                        r[i].SumSalaryItemPerMonth = r[i].SumSalaryItemPerMonth != null ? r[i].SumSalaryItemPerMonth : 0;
                        tr += '<tr><td class="tabledit-edit-mode"><input hidden  class="EmployeeId" value="' + r[i].EmployeeId + '" required /><label class="col-form-label">' +
                            r[i].EmployeeName + '</label></td><td class="tabledit-edit-mode"><input type="number" step="any" class="Value form-control tabledit-input form-control-sm" value="' +
                            r[i].SumSalaryItemPerMonth + '" disabled readonly /></td><td class="tabledit-edit-mode"><input type="text" class="Notes form-control tabledit-input form-control-sm" value=""  /></td></tr>';
                    }
                    PreviousEmployeeMonthlyAllocation();
                    if (previousAllocation.length > 0) {
                        Swal.fire({
                            title: '@MyERP.Properties.Resources.EmployeeMonthlyAllocationHasBeenCalculatedBefore',
                            text: " ",
                            icon: 'info',
                            showCancelButton: false,
                            confirmButtonText: '@MyERP.Properties.Resources.Ok',
                            confirmButtonColor: '#3085d6'
                        });
                    }
                    else { $('#EmployeeMonthlyAllocationDetails').append(tr); }
                }
                else {
                    Swal.fire({
                        title: '@MyERP.Properties.Resources.NoDataFound',
                        text: " ",
                        icon: 'info',
                        showCancelButton: false,
                        confirmButtonText: '@MyERP.Properties.Resources.Ok',
                        confirmButtonColor: '#3085d6'
                    });
                }
            })//.done(function () { PreviousEmployeeMonthlyAllocation()})
        $('#preloader, #status').fadeOut();
    }

    var previousAllocation = [];
    function PreviousEmployeeMonthlyAllocation() {
        $.get('/EmployeeMonthlyAllocation/PreviousEmployeeMonthlyAllocation?allocationType=' + $('#AllocationTypeId').val() + '&month=' + $('#Month').val() + '&year=' + $('#Year').val())
            .done(function (r) {
                previousAllocation = r;
                //console.log(r"previousAllocation : ",previousAllocation)
            });
    }
   //------------------------------------------------------------------------------------------//
    function Delete(id) {
        Swal.fire({
            title: '@MyERP.Properties.Resources.AreYouSureYouWantToDelete',
            text: " ",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: '@MyERP.Properties.Resources.Ok',
            cancelButtonText: '@MyERP.Properties.Resources.Cancel',
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                $('#preloader, #status').fadeIn();
                $.ajax({
                    url: '/EmployeeMonthlyAllocation/Delete',
                    type: 'POST',
                    data: {
                        "Id": id,
                    },
                    error: function (e) {
                        $('#preloader, #status').fadeOut();
                        Swal.fire({
                            title: '@MyERP.Properties.Resources.DeleteDoesNotSucceeded',
                            text: " ",
                            icon: 'error',
                            showCancelButton: false,
                            confirmButtonText: '@MyERP.Properties.Resources.Ok',
                            confirmButtonColor: '#3085d6'
                        });
                    },
                    success: function (r) {
                        if (r == 'true') {
                            window.location.replace('/EmployeeMonthlyAllocation');
                        } else {
                            Swal.fire({
                                title: '@MyERP.Properties.Resources.DeleteDoesNotSucceeded',
                                text: " ",
                                icon: 'error',
                                showCancelButton: false,
                                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                                confirmButtonColor: '#3085d6'
                            });
                            $('#preloader, #status').fadeOut();
                        }
                    }
                });
            }
            else { result.dismiss; }
        });
    }

    function addEdit(n) {
        PreviousEmployeeMonthlyAllocation();
        let valid = true;
        if ($(".form-control:invalid").length > 0) {
            $('.form-horizontal').addClass('was-validated');
            $('html, body').animate({
                scrollTop: $(".form-control:invalid").eq(0).offset().top - 80
            }, 500);
            console.log($(".form-control:invalid"));
            valid = false;
        }

        if (previousAllocation.length > 0) {
            valid = false;
            Swal.fire({
        title: '@MyERP.Properties.Resources.EmployeeMonthlyAllocationHasBeenCalculatedBefore',
        text: " ",
        icon: 'info',
        showCancelButton: false,
        confirmButtonText: '@MyERP.Properties.Resources.Ok',
        confirmButtonColor: '#3085d6'
    });
        }

        var employeeMonthlyAllocationDetails = [];

        if (valid) {
            $('#EmployeeMonthlyAllocationDetails tr').each(function () {
                var td = $(this);
                var employeeMonthlyAllocationDetail = {
                    MainDocId: $('#Id').val(),
                    EmployeeId: td.find('.EmployeeId').val(),
                    Value: td.find('.Value').inputmask('unmaskedvalue'),
                    IsDeleted: false,
                    Notes: td.find('.Notes').val(),
                };
                employeeMonthlyAllocationDetails.push(employeeMonthlyAllocationDetail);
            });
        }

        if (valid) {
            var employeeMonthlyAllocation = {
                Id: $('#Id').val(),
                DocumentNumber: $('#DocumentNumber').val(),
                DepartmentId: $('#DepartmentId').val(),
                VoucherDate: $('#VoucherDate').val(),
                Month: $('#Month').val(),
                Year: $('#Year').val(),
                AllocationTypeId: $('#AllocationTypeId').val(),
                IsDeleted: false,
                Notes: $('#Notes').val(),
                Image: $('#Image').val(),
                EmployeeMonthlyAllocationDetails: employeeMonthlyAllocationDetails
            }
        }

        if ($('#EmployeeMonthlyAllocationDetails tr').length == 0) {
            Swal.fire({
        title: '@MyERP.Properties.Resources.AllDetailsRequired',
        text: " ",
        icon: 'info',
        showCancelButton: false,
        confirmButtonText: '@MyERP.Properties.Resources.Ok',
        confirmButtonColor: '#3085d6'
    });
            valid = false;
        }

        if (valid == true) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.AreYouSureYouWantToSave',
                text: " ",
                icon: 'info',
                showCancelButton: true,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                cancelButtonText: '@MyERP.Properties.Resources.Cancel',
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    $('#preloader, #status').fadeIn();
                    $('#SaveAndNew').prop('disabled', true);
                    $('#Save').prop('disabled', true);
                    $.ajax({
                        type: "POST", contentType: "application/json",
                        url: "/EmployeeMonthlyAllocation/AddEdit",
                        data:
                            JSON.stringify({ employeeMonthlyAllocation }),
                        success: function (r) {
                            if (r.success == "true") {
                                Swal.fire({
    title: '@MyERP.Properties.Resources.Saved',
    text: " ",
    icon: 'success',
    showCancelButton: false,
    confirmButtonText: '@MyERP.Properties.Resources.Ok',
    confirmButtonColor: '#3085d6'
});
                                if (n == 'new') {
                                    window.location.replace("/EmployeeMonthlyAllocation/AddEdit");
                                }
                                else {
                                    window.location.replace("/EmployeeMonthlyAllocation");
                                }
                            } else {
                                $('#preloader, #status').fadeOut();
                                $('#SaveAndNew').prop('disabled', false);
                                $('#Save').prop('disabled', false);
Swal.fire({
    title: '@MyERP.Properties.Resources.NotSaved !',
    text: " ",
    icon: 'error',
    showCancelButton: false,
    confirmButtonText: '@MyERP.Properties.Resources.Ok',
    confirmButtonColor: '#3085d6'
});                            }
                        },
                        error: function (r) {
                            $('#preloader, #status').fadeOut();
                            $('#SaveAndNew').prop('disabled', false);
                            $('#Save').prop('disabled', false);
Swal.fire({
    title: '@MyERP.Properties.Resources.NotSaved !',
    text: " ",
    icon: 'error',
    showCancelButton: false,
    confirmButtonText: '@MyERP.Properties.Resources.Ok',
    confirmButtonColor: '#3085d6'
});                        }
                    });
                }
                else { result.dismiss; }
            });
        }
    }
</script>