                                <h3 class="mb-3"><a href="rooms.html">@item.ArName</a></h3>
                                <p class="pt-1"><a href="/RoomType/RoomDetails?Id=@item.Id" class="btn-custom px-3 py-2 rounded">@MyERP.Properties.Resources.ViewDetails <span class="icon-long-arrow-right"></span></a></p>
