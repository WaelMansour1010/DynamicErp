@model IEnumerable<MyERP.Models.Item>
@{
    if (System.Web.Configuration.WebConfigurationManager.AppSettings["ECommerce"] == "true")
    {
        Layout = "~/Views/Shared/_EcommerceLayout.cshtml";
    }
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = MyERP.Properties.Resources.Items;
}
<link rel="stylesheet" href="https://kendo.cdn.telerik.com/2018.2.516/styles/kendo.common-material.min.css" />
<link rel="stylesheet" href="https://kendo.cdn.telerik.com/2018.2.516/styles/kendo.material.min.css" />
<link rel="stylesheet" href="https://kendo.cdn.telerik.com/2018.2.516/styles/kendo.material.mobile.min.css" />
<script src="https://kendo.cdn.telerik.com/2018.2.516/js/kendo.all.min.js"></script>

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <a class="btn btn-info" href="@Url.Action("AddEdit")" role="button" style="float:left; margin-right:4px">@MyERP.Properties.Resources.AddNew</a>
                @if (System.Web.Configuration.WebConfigurationManager.AppSettings["ProjectName"] == "Kimo")
                {
                    <a class="btn btn-info" href="@Url.Action("ImportItems")" role="button" style="float:left; margin-right:4px">@MyERP.Properties.Resources.ImportingAndModifyingQuantitiesOfItems</a>
                    @*<button class="btn btn-info" role="button" style="float:left;" onclick="UpdateBestSeller()">تحديث الأكثر مبيعاً</button>*@
                }
                @*<a class="btn btn-info" href="@Url.Action("AdjustPrice")" role="button" style="float:left; margin-right:4px">تعديل اسعار مجموعة الاصناف</a>*@
            </div>
            <h4 class="page-title">@MyERP.Properties.Resources.Items</h4>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal" role="form">
                        <div class="form-group row">
                            <div class="col-xs-12 col-sm-6 col-lg-3">
                                <input type="text" class="form-control searchtxt" value="@Html.Raw(ViewBag.searchWord)" placeholder=@MyERP.Properties.Resources.Search>
                            </div>
                            <div class="col-xs-12 col-sm-3 col-lg-3">
                                @Html.DropDownList("ItemGroupId", null, @MyERP.Properties.Resources.ItemGroups, htmlAttributes: new { @class = "form-control", required = "required" })
                            </div>
                            <div class="col-xs-12 col-sm-3 col-lg-3">
                                @Html.DropDownList("DepartmentId", null, @MyERP.Properties.Resources.Department, htmlAttributes: new { @class = "form-control", required = "required" })
                            </div>
                            <div class="col-xs-12 col-sm-3 col-lg-3">
                                <button type="button" class="btn btn-success btnSearch" onclick="searchWord = $('.searchtxt').val(); paging();">
                                    <i class="fa fa-search"></i>
                                </button>
                                <a class="btn btn-info" href="/Item/Index" role="button"><i class="fe-refresh-ccw"></i></a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <div class="col-sm-6">
                    <button class="btn btn-success" id="treeCollapse"> @MyERP.Properties.Resources.Menu</button>

                    <button class="btn btn-success" id="treeExpand"> @MyERP.Properties.Resources.Tree</button>
                </div>
            </div>


            <!-------------------- Kendo Tree List --------------------------->
            <div class="row" id="treelist">
                <div class="col-12">
                    <div class="card-box">
                        <div class="row">
                            <div class="col-12">
                                <div @*id="treelist"*@></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!----------------End of  Kendo Tree List --------------------->



            <div class="row">
                <div class="col-12">
                    <div class="table-responsive">
                        <table class="table table-striped table-centered mb-0">
                            <thead>
                                <tr>
                                    <th>
                                        @MyERP.Properties.Resources.Code
                                    </th>

                                    <th>
                                        @MyERP.Properties.Resources.ArName
                                    </th>

                                    <th>
                                        @MyERP.Properties.Resources.EnName
                                    </th>
                                    <th>@MyERP.Properties.Resources.Group</th>
                                    <th>
                                        @MyERP.Properties.Resources.DemandLimit
                                    </th>

                                    <th>
                                        @MyERP.Properties.Resources.Active
                                    </th>
                                    <th>
                                        @MyERP.Properties.Resources.Edit
                                    </th>
                                    <th>
                                        @MyERP.Properties.Resources.Delete
                                    </th>
                                    @*<th>
                                            تفاصيل
                                        </th>*@
                                    <th>
                                        @MyERP.Properties.Resources.ItemMovement
                                    </th>
                                    <th>
                                        @if (ViewBag.UseExpiryDateForItems != null && ViewBag.UseExpiryDateForItems == true)
                                        {

                                            @MyERP.Properties.Resources.Patches
                                        }
                                    </th>
                                    <th> @MyERP.Properties.Resources.PrintBarcode </th>

                                </tr>
                            </thead>
                            <tbody id="ItemsTable">
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.Code)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.ArName)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.EnName)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.ItemGroup.ArName)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.OrderLimit)
                                        </td>
                                        <td>
                                            <input type="checkbox" data-plugin="switchery" data-color="#00b19d" data-secondary-color="#ED5565" data-size="small" @Html.Raw(item.IsActive == true ? "checked" : "") onchange="ActivateDeactivate(@item.Id)" />
                                        </td>
                                        <td>
                                            <a href="@Url.Action("AddEdit","Item",new { id=item.Id })" onclick="$('#preloader, #status').fadeIn();">
                                                <i class="fa fa-edit"></i>
                                            </a>
                                        </td>

                                        <td>
                                            <a href="javascript:void(0);" onclick="DeleteFunc(@item.Id)">
                                                <i class="fas fa-trash-alt"></i>
                                            </a>
                                        </td>
                                        @*<td>
                                                <button class="btn btn-info" data-toggle="modal" data-target="#itemDetails" onclick="showItemDetials(@item.Id)">تفاصيل</button>
                                            </td>*@

                                        <td>
                                            <a href="@Url.Action("ItemTransaction","Report",new { ItemId=item.Id})" role="button" class="btn btn-info" target="_blank">@MyERP.Properties.Resources.ItemMovement</a>
                                        </td>
                                        <td>
                                            @if (ViewBag.UseExpiryDateForItems != null && ViewBag.UseExpiryDateForItems == true && item.HasExpiry != null && item.HasExpiry.HasValue == true && item.HasExpiry == true)
                                            {
                                                <button class="btn btn-info js-show-item-patches" data-item-id=@item.Id>@MyERP.Properties.Resources.Patches</button>
                                            }
                                        </td>

                                        <td>
                                            @*<a href="@Url.Action("Barcode",new { ItemId=item.Id,barcode="",name=item.ArName})" role="button" class="btn btn-info" target="_blank">طباعة</a>*@
                                            <a role="button" href="javascript:void(0);" onclick="EncodeId(@item.Id)">
                                                <i class="remixicon-printer-fill"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Patch Modal-->
<div id="patchModal" class="modal fade bs-example-modal-lg" tabindex="-1" role="dialog" aria-labelledby="myLargeModalLabel" data-backdrop="false" style="background-color: rgba(0, 0, 0, 0.5);">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
            </div>
            <div class="modal-body">

                <div class="row">
                    <div class="col-sm-12">
                        <table class="table table-condensed">
                            <thead>
                                <tr>
                                    <th>@MyERP.Properties.Resources.PatchCode</th>
                                    <th>@MyERP.Properties.Resources.ExpirationDate</th>
                                    <th>@MyERP.Properties.Resources.Qty</th>
                                </tr>
                            </thead>
                            <tbody id="item-patches"></tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" onclick=" $('.bs-example-modal-lg').modal('hide');" data-dismiss="modal">@MyERP.Properties.Resources.Close</button>
            </div>
        </div>

    </div>
</div>
<div id="itemDetails" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" style="display: none;" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title" id="myModalLabel">@MyERP.Properties.Resources.ItemDetails</h4>
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">×</button>
            </div>
            <div class="modal-body" id="itemDetailsBody">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light waves-effect" data-dismiss="modal">@MyERP.Properties.Resources.Close</button>
            </div>
        </div><!-- /.modal-content -->
    </div><!-- /.modal-dialog -->
</div>

@*<div style="text-align:center;margin-bottom: 50px;">

        <select id="ShowByPage" class="form-control" style="width:70px;float:left;" onchange="paging()">
            <option value="10">10</option>
            <option value="30">30</option>
            <option value="50">50</option>
            <option value="100">100</option>
