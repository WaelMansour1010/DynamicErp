<div style="text-align:center;margin-bottom: 50px;">

    <div class="form-group row">
        <div class="col-sm-4">
            <select id="ShowByPage" class="form-control" style="width:70px;float:left;" onchange="paging()">
                <option value="10">10</option>
                <option value="30">30</option>
                <option value="50">50</option>
                <option value="100">100</option>
                <option value="200">200</option>
                <option value="@ViewBag.Count">@MyERP.Properties.Resources.All</option>
            </select>
            <span style="font-size:12px;float:right;"> @MyERP.Properties.Resources.NoOfResults : <span id="RowsCount">@ViewBag.Count</span></span>
        </div>
        <div class="col-sm-2">
            <lablel class="col-sm-8"> @MyERP.Properties.Resources.PageNo: </lablel>
        </div>
        <div class="col-sm-2">
            <select id="pagination" class="pagination form-control" style="width:70px;float:left;">
            </select>
        </div>
    </div>
</div>



<script>
//------------------------------- Kendo Tree List ------------------------------//
    function GetItemsWithItemGroup() {

        $("#treelist").kendoTreeList({
            dataSource: {
                transport: {
                    read: {
                        url: "/Item/GetItemsWithItemGroup",
                        dataType: "json",
                    },
                },
                schema: {
                    model: {
                        id: "Id",
                        parentId: "ParentItemGroupId",
                        fields: {
                            ParentItemGroupId: { field: "ParentItemGroupId", nullable: true },
                            Code: { field: "Code", nullable: true },
                            ArName: { field: "ArName", nullable: true },
                            EnName: { field: "EnName", nullable: true },
                           // ArType: { field: "ArType", nullable: true }
                        },
                        expanded: true
                    }
                }
            },
            columns: [{
                field: "Code", title:"@MyERP.Properties.Resources.Code", width: 160, headerAttributes: {
                    style: "text-align: right; color:black;"
                } },
                {
                    field: "ArName", title: "@MyERP.Properties.Resources.ArName", width: 160, headerAttributes: {
                        style: "text-align: right; color:black;"
                    } },
                {
                    field: "EnName", title: "@MyERP.Properties.Resources.EnName", width: 160, headerAttributes: {
                        style: "text-align: right; color:black;"
                    }
                }
                @*,
                {
                    field: "ArType", title: "@MyERP.Properties.Resources.ArType", width: 160, headerAttributes: {
                        style: "text-align: right; color:black;"
                    }
                }*@
            ]
        });

    }
    $('#treeExpand').click(function () {
        $('#treelist').empty();
        GetItemsWithItemGroup();
        $('#treelist').show();
    });

    $('#treeCollapse').click(function () {
        $('#treelist').hide();
    });
   //------------------------------- End Of Kendo Tree List ------------------------------//

   let UseExpiryDateForItems = '@ViewBag.UseExpiryDateForItems';
    var pageNo = 1;
    var searchWord = '@Html.Raw(ViewBag.searchWord)';

    $('#ShowByPage').val(@ViewBag.wantedRowsNo);

    function paging() {

        var link = '/Item/Index?pageIndex=' + pageNo + '&wantedRowsNo=' + $('#ShowByPage').val() + '&searchWord=' + searchWord + '&itemGroupId=' + $('#ItemGroupId').val() + '&departmentId=' + $('#DepartmentId').val();
        window.location.replace(link);
    }

    function setPages() {
        var count =@ViewBag.Count;
        for (var i = 0; i < Math.ceil(count / $('#ShowByPage').val()); i++)
           // $('.pagination').append('<li class="pageNo page-item" id="pg' + (i + 1) + '"><a class="page-link" href="javascript:void(0);" onclick="pageNo=' + (i + 1) + '; paging();">' + (i + 1) + '</a></li>');
    $('#pagination').append('<option onchange="pageNo=' + (i + 1) + '; paging();" id="pg' + (i + 1) + '">' + (i + 1) + '</option>');
    }

    setPages();
   $('#pg' +@ViewBag.PageIndex).attr('selected', 'selected')

    $('#pagination').on('change', function () {
        pageNo = $('#pagination').val();
         paging();

    })
  //  $('#pg' +ViewBag.PageIndex).addClass('disabled active');

            function DeleteFunc(id) {
                if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToDelete')) {
                    $('#preloader, #status').fadeIn();
                    $.ajax(
                        {
                            url: '/Item/Delete',
                            type: 'POST',
                            data: {
                                "Id": id,
                            },
                            error: function (e) {
                                $('#preloader, #status').fadeOut();
                            },
                            success: function (r) {
                                $('#preloader, #status').fadeOut();
                                if (r == 'true') {
                                    window.location.reload();
                                }
                                else if (r == 'False') {
                                    $('#preloader, #status').fadeOut();
                                    alert('@MyERP.Properties.Resources.DeleteDoesNotSucceededBecauseItemUsedInOtherTransactions');
                                    window.location.reload();
                                }
                            }
                        });
                }
            }

    function ActivateDeactivate(id) {
        $('#preloader, #status').fadeIn();
        $.ajax({
            url: '/Item/ActivateDeactivate',
            type: 'POST',
            data: {
                "Id": id,
            },
            error: function (e) {
                alert('@MyERP.Properties.Resources.TheActivationStateNotChanged'+'!');
                $('#preloader, #status').fadeOut();
            },
            success: function (r) {
                $('#preloader, #status').fadeOut();
                if (r == 'true') {
                    alert('@MyERP.Properties.Resources.TheActivationStateHasChanged'+'!')
                }
            }
        });
    }

    //stop the function becuase no departmentId in view -- when add department it can be working
    function showItemDetials(itemId) {
        $('#itemDetailsBody').empty();
            $('#itemDetailsBody').append('<div class="d-flex align-items-center"><div class="spinner-border ml-auto" role="status" aria-hidden="true"></div></div>');
            $.get('/Item/GetItemQuantityInEachWarehouse?itemId=' + itemId + '&depId=28' ).done(function (r) {
                $('#itemDetailsBody').empty().append(r);
            });

    }

    $(document).on('click', '.js-show-item-patches', function () {
        var button = $(this);
        var itemId = button.attr('data-item-id');
        showPatchModal(itemId,true);
    });

    // Patch modal
    function showPatchModal(itemId,getZeroQunatity) {
        $('#patchModal').modal('show');
        let itemPatches = [];
        //let itemId = $(item).closest('tr').find('.item-id').val();

        $.get('/Helper/PatchesByItemId?itemId=' + itemId + '&getZeroQunatity=' + getZeroQunatity).done(function (r) {
            itemPatches = r;
            let tr = '';

            for (var i = 0; i < itemPatches.length; i++) {
                tr += ('<tr><td>' + (itemPatches[i].PatchCode ? itemPatches[i].PatchCode : '') + '</td><td><input hidden class="itemId" value="' + itemId + '" /><input hidden class="itemPatchId" value="' + itemPatches[i].PatchId + '" /><label class="itemPatchExpireDate">' + (itemPatches[i].ExpiryDate != null ? convertToJavaScriptDate(itemPatches[i].ExpiryDate) : '') + '</label></td ><td>' + itemPatches[i].Qty + '</td></tr > ');
            }

            $('#item-patches').empty().append(tr);
            $('#pleasewait').fadeOut();
        });
    }
    //------------------- ConvertDate-------------
    function convertToJavaScriptDate(value) {
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        return ((dt.getMonth() + 1 + "/" + dt.getDate() + "/" + dt.getFullYear()));
        // return (dt)
    }

    function EncodeId(id, mobile) {
        $.get('/Helper/EncodeId?id=' + id).done(function (r) {
            var report = "/Report/PrintItemsBarcode?id=" + r + "&print=True";
            window.open(report, "_blank");
        });
    }

</script>
