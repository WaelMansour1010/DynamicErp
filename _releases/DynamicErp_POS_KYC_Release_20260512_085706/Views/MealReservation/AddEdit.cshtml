<script>

    //--------------- Variables Declarations -------------------//
    let ItemOptions = '';
    let MealOptions = '';
    let sum = 0;
    //*********************************************************//
    //--------------- Ready Function -------------------//
    $(document).ready(function () {
        $.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
            $("input[type|='datetime-local']").prop('min', r.PeriodStart).prop('max', r.PeriodEnd);
        });

        $('#VoucherDate').val('@ViewBag.VoucherDate');
        getItems();
        getMeals();
        if ($('#Id').val()) {
            var code = $('#DocumentNumber').val();
            $('#DocumentNumbers').val(code.replaceAll("-", ""));
            $("#DepartmentId").prop('disabled', true);
            $("#VoucherDate").prop('disabled', true);

            $('.ItemId').not(':last').each(function () {
                let selectedItem = $(this).val();
                $(this).empty().append(ItemOptions).val(selectedItem);
            });
            $('.MealId').not(':last').each(function () {
                let MealselectedItem = $(this).val();
                $(this).empty().append(MealOptions).val(MealselectedItem);
            });
        }
        else {
            SetDocNum();
            cashBoxByDepartment();
        }
    });
    //*********************************************************//
   //--------------- Event Functions -------------------//

    $(document).on('change', '.Price,.Number', function (e) {
        appendMealReservationDetails();
        CalculateTotals();
        var price = parseFloat($(this).closest('tr').find('.Price').inputmask('unmaskedvalue'));
        var number = $(this).closest('tr').find('.Number').val();
        var total = price * number;
        $(this).closest('tr').find('.Total').val(total)
    });
    $('#Discount').on('change', function () {
        CalculateTotals();
    });

    $(document).on('change', "#DepartmentId", function () {
        SetDocNum();
        cashBoxByDepartment();
    });

    $(document).on('change', '#VoucherDate', function () {
        if (!$('#Id').val()) {
            SetDocNum();
        }
    });
    $(document).on('change', "#Paid", function () {
        CalculateTotals();
    });
    //*********************************************************//
    //--------------- Other Functions -------------------//
     function cashBoxByDepartment() {
        $.get('/Helper/CashBoxByDepartment/' + $('#DepartmentId').val()).done(function (r) {
            $('#CashBoxId').empty();
          //  $('#CashBoxId').append('<option value>'+'@MyERP.Properties.Resources.Select' +'</option>');
            for (var i = 0; i < r.length; i++) {
                $('#CashBoxId').append($('<option>', {
                    value: r[i].Id,
                    text: r[i].ArName
                }));
            }
        });
    }

    function CalculateTotals() {
        sum = 0;
        $('#MealReservationDetails tr').each(function () {
            var td = $(this);
            if (td.find('.Price').val() > 0) {
                sum += (td.find('.Price').inputmask('unmaskedvalue') * td.find('.Number').val());
                var Discount = $('#Discount').inputmask('unmaskedvalue') > 0 ? $('#Discount').inputmask('unmaskedvalue') : 0;
                $('#Total').val(sum);
                var TotalAfterDiscount = sum - Discount;
                $('#TotalAfterDiscount').val(TotalAfterDiscount);
                var Paid = $('#Paid').inputmask('unmaskedvalue');
                var Remain = TotalAfterDiscount - Paid;
                $('#Remain').val(Remain);
            }
        });
    }
    function appendMealReservationDetails() {
        if ($('#MealReservationDetails .form-control:invalid').length > 0) {
            $('#MealReservationDetails').closest('.form-horizontal').addClass('was-validated');
            $('html, body').animate({
                scrollTop: $("#MealReservationDetails").find(".form-control:invalid").eq(0).offset().top - 100
            }, 500);
        } else if ($('#MealReservationDetails .ItemId:last').val() && $('#MealReservationDetails .MealId:last').val()) {
            let tr = '<tr><td class="tabledit-edit-mode"><select class="MealId form-control tabledit-input form-control-sm" required></select></td><td class="tabledit-edit-mode"><select class="ItemId form-control tabledit-input form-control-sm" required></select></td><td class="tabledit-edit-mode"><input type="text" class="Number form-control tabledit-input form-control-sm" required /></td><td class="tabledit-edit-mode"><input type="text" class="money Price form-control tabledit-input form-control-sm" required /></td><td class="tabledit-edit-mode"><input type="text" class="money Total form-control tabledit-input form-control-sm" disabled /></td><td><a href="javascript:void(0);" onclick="deleteElement(this)"><i class="fas fa-trash-alt"></i></a></td></tr>';
            if (!ItemOptions.length) {
                getItems();
            }
            if (!MealOptions.length) {
                getMeals();
            }
            $('#MealReservationDetails').append(tr);
            $('.ItemId').last().append(ItemOptions).select2();
            $('.MealId').last().append(MealOptions).select2();
            $('#MealReservationDetails input[type=number]').removeProp('oninput').prop('type', 'text').inputmask({
                alias: 'numeric', autoGroup: true, digits: 2, digitsOptional: false, 'allowMinus': false, 'placeholder': '0'
            });
        }
    }
    function getItems() {
        ItemOptions = '';
        ItemOptions = '<option value="0">' + '@MyERP.Properties.Resources.Select' + '</option>';
        $('.ItemId').last().find('option').each(function (r) {
            ItemOptions += '<option value="' + $(this).val() + '">' + $(this).text() + '</option>';
        });
    }
    function getMeals() {
        MealOptions = '';
        MealOptions = '<option value="0">' + '@MyERP.Properties.Resources.Select' + '</option>';
        $('.MealId').last().find('option').each(function (r) {
            MealOptions += '<option value="' + $(this).val() + '">' + $(this).text() + '</option>';
        });
    }
    function SetDocNum() {
        var doc = $.get('/MealReservation/SetDocNum?id=' + $('#DepartmentId').val() + '&VoucherDate=' + $('#VoucherDate').val()).done(function (r) {
            $('#DocumentNumber').val(r);
            $('#DocumentNumbers').val(r.replaceAll("-", ""));
        });
    }
    function zeroPadded(val) {
        if (val >= 10)
            return val;
        else
            return '0' + val;
    }
    function deleteElement(e) {
        let tr = $(e).closest('tr');
        if ($(tr).index() == 0 && $(tr).closest('tbody').children('tr').length == 1) {
            $(tr).find("input").val('');
            $(tr).find("label").text('');
            $(tr).find('input, select').removeAttr('required');
            // $(tr).find('select').empty();
            $(tr).find('select').prop('selectedIndex', 0);
            $(tr).find('select').select2();
        }
        else if ($(tr).index() < $(tr).closest('tbody').children('tr').length - 1) {
            e.parentNode.parentNode.parentNode.removeChild(e.parentNode.parentNode);
            $('#TotalAfterDiscount').val(0);
            $('#Total').val(0);
            $('#Discount').val(0);
        }
        else if ($(tr).index() == $(tr).closest('tbody').children('tr').length - 1) {
            $(tr).find("input").val('');
            $(tr).find('input, select').removeAttr('required');
           // $(tr).find('select').empty();
            $(tr).find('select').prop('selectedIndex', 0);
            $(tr).find('select').select2();
            $(tr).find("label").text('');
        }
        CalculateTotals();
    }
    //*********************************************************//
    function addEdit(n) {
        let valid = true;
        if ($('.form-horizontal').first().find('.form-control:invalid').length > 0) {
            $('.form-horizontal').first().addClass('was-validated');
            $('html, body').animate({
                scrollTop: $('.form-horizontal').first().find(".form-control:invalid").eq(0).offset().top - 100
            }, 500);
            valid = false;
            console.log($(".form-control:invalid"));
        }
        var MealReservationDetails = [];
        if (valid) {
            $('#MealReservationDetails tr').each(function () {
                var td = $(this);
                if (td.find('.Price').val() > 0) {
                    // let itemId = items.filter(function (i) { return i.ItemPriceId == td.find('.item').val(); })[0].Id;
                    var MealReservationDetail = {
                        MainDocId: $('#Id').val(),
                        ItemId: td.find('.ItemId').val(),
                        MealId: td.find('.MealId').val(),
                        Number: td.find('.Number').val(),
                        Price: td.find('.Price').inputmask('unmaskedvalue'),
                        Total: td.find('.Total').inputmask('unmaskedvalue'),
                        IsActive: true,
                        IsDeleted: false,
                    };
                    MealReservationDetails.push(MealReservationDetail);
                }
            });
        }
        var MealReservation = {
            Id: $('#Id').val(),
            DocumentNumber: $('#DocumentNumber').val(),
            VoucherDate: $('#VoucherDate').val(),
            Total: $('#Total').inputmask('unmaskedvalue'),
            Discount: $('#Discount').inputmask('unmaskedvalue'),
            TotalAfterDiscount: $('#TotalAfterDiscount').inputmask('unmaskedvalue'),
            CustomerId: $('#CustomerId').val(),
            UserId: $('#UserId').val(),
            IsDeleted: $('#IsDeleted').val(),
            IsActive: $('#IsActive').val(),
            Notes: $('#Notes').val(),
            Image: $('#Image').val(),
            CurrencyId: $('#CurrencyId').val(),
            CurrencyEquivalent: $('#CurrencyEquivalent').val(),
            DepartmentId: $('#DepartmentId').val(),
            CashBoxId: $('#CashBoxId').val(),
            Paid: $('#Paid').inputmask('unmaskedvalue'),
            Remain: $('#Remain').inputmask('unmaskedvalue'),
            MealReservationDetails: MealReservationDetails
        }
        if (valid) {
            Swal.fire({
                title: '@MyERP.Properties.Resources.AreYouSureYouWantToSave',
                text: " ",
                icon: 'info',
                showCancelButton: true,
                confirmButtonText: '@MyERP.Properties.Resources.Ok',
                cancelButtonText: '@MyERP.Properties.Resources.Cancel',
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {

                    $('#preloader, #status').fadeIn();
                    $('#newbtn').prop('disabled', true);
