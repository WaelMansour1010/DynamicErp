@model IEnumerable<MyERP.Models.OrderRequest>

<script src="~/js/DeleteFunctionForAddEditView.js"></script>
@{
    ViewBag.Title = "الطلبات المحتملة";
}

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <a class="btn btn-info" href="@Url.Action("AddEdit")" role="button" style="float:left;">إضافة جديد</a>
            </div>
            <div class="hed page-title">الطلبات المحتملة </div>
        </div>
    </div>
</div>
<div class="card-box">
    <div class="row">
        <div class="col-12">
            <div class="form-horizontal" role="form">
                <div class="form-group row">
                    <div class="col-xs-12 col-sm-6 col-lg-3">
                        <input type="text" class="form-control searchtxt" value="@Html.Raw(ViewBag.searchWord)" placeholder="بحث">
                    </div>
                    <div class="col-xs-12 col-sm-3 col-lg-3">
                        <button type="button" class="btn btn-success btnSearch" onclick="searchWord = $('.searchtxt').val(); paging();">
                            <i class="fa fa-search"></i>
                        </button>
                        <button type="button" class="btn btn-info btnSearch" onclick="pageNo = 1; searchWord=''; paging();">
                            <i class="fe-refresh-ccw"></i>
                        </button>
                        <button type="button" class="btn btn-info" onclick="showEmpDDL()">
                            تعيين موظف
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6">
        <br />
        <div class="col-sm-3">
            <span> مفتوح: </span><input id="open"
                                        name="status"
                                        type="radio"
                                        value="false" />
        </div>
        <div class="col-sm-3">
            <span> مغلق:</span><input id="close"
                                      name="status"
                                      type="radio"
                                      value="true" />
        </div>
    </div>


    <div class="form-group assignEmployee" hidden>
        <div class="col-sm-12">
            @Html.DropDownList("EmployeeId", null, "اختر", htmlAttributes: new { @class = "form-control" })
            <button type="button" class="btn btn-success" onclick="assignEmployee()">
                حفظ
            </button>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="table-responsive">
                <table class="table table-striped table-centered mb-0">
                    <thead>
                        <tr>
                            <th>رقم الطلب</th>
                            <th>اسم العميل </th>


                            <th> رقم تليفون العميل</th>

                            <th> الموظف</th>
                            <th>الخدمة المطلوبة</th>

                            <th>تعديل</th>
                            <th>حذف</th>
                            <th>تعيين</th>
                        </tr>
                    </thead>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @Html.DisplayFor(modelItem => item.OrderNumber)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.CustomerName)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.CustomerPhone)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Employee.ArName)
                            </td>

                            <td>
                                @Html.DisplayFor(modelItem => item.Service)
                            </td>

                            <td>
                                <a href="@Url.Action("AddEdit", "OrderRequest", new {id = item.Id})" onclick="$('#preloader, #status').fadeIn();">
                                    <i class="fa fa-edit"></i>
                                </a>
                            </td>
                            <td>
                                <a href="javascript:void(0);" onclick="Delete(@item.Id,'OrderRequest')">
                                    <i class="fas fa-trash-alt"></i>
                                </a>

                            </td>
                            <td>
                                <input type="hidden" class="Id" value="@item.Id" />
                                <input type="checkbox" class="assign" />
                            </td>
                        </tr>
                    }

                </table>
            </div>
        </div>
    </div>
</div>
<div style="text-align:center;margin-bottom: 50px;">

    <div class="form-group row">
        <div class="col-sm-4">
            <select id="ShowByPage" class="form-control" style="width:70px;float:left;" onchange="paging()">
                <option value="10">10</option>
                <option value="30">30</option>
                <option value="50">50</option>
                <option value="100">100</option>
                <option value="200">200</option>
                <option value="@ViewBag.Count">الكل</option>
            </select>
            <span style="font-size:12px;float:right;"> عدد النتائج : <span id="RowsCount">@ViewBag.Count</span></span>
        </div>
        <div class="col-sm-2">
            <lablel class="col-sm-8"> رقم الصفحة: </lablel>
        </div>
        <div class="col-sm-2">
            <select id="pagination" class="pagination form-control" style="width:70px;float:left;">
            </select>
        </div>
    </div>
</div>

<script>
    var pageNo = 1;
    var searchWord = '@Html.Raw(ViewBag.searchWord)';

    $('#ShowByPage').val(@ViewBag.wantedRowsNo);

    function paging() {

        var link = '/orderRequest/Index?' + 'pageIndex=' + pageNo + '&wantedRowsNo=' + $('#ShowByPage').val() + '&searchWord=' + searchWord;
        window.location.replace(link);
    }

    function setPages() {
        var count =@ViewBag.Count;
        for (var i = 0; i < Math.ceil(count / $('#ShowByPage').val()); i++)
            $('#pagination').append('<option onchange="pageNo=' + (i + 1) + '; paging();" id="pg' + (i + 1) + '">' + (i + 1) + '</option>');
    }

    setPages();
   $('#pg' +@ViewBag.PageIndex).attr('selected', 'selected')

    $('#pagination').on('change', function () {
        pageNo = $('#pagination').val();
         paging();
    })

    function ActivateAndDeactivate(id) {
        $.ajax({
            url: '/OrderRequest/ActivateDeactivate',
            type: 'POST',
            data: {
                "Id": id,
            },
            error: function (e) {
                console.log(e.responseText);
            },
            success: function (r) {
                if (r == 'true') {
                    alert('تم تغير حالة التنشيط!')
                }
            }
        });
    }

    function showEmpDDL() {
        if ($('.assign:checked').length > 0) {
            $('.assignEmployee').show();
        }
    }

    function assignEmployee() {
        if ($('#EmployeeId').val() && $('.assign:checked').length > 0) {
            $('#preloader, #status').fadeIn();
            var ids = [];
            $('.assign:checked').each(function () {
                ids.push($(this).closest('td').find('.Id').val());
                console.log($(this).closest('td').find('.Id').val());
            });

            $.ajax({
                url: '/OrderRequest/AssignEmployee',
                type: 'POST',
                data: {
                    "ids": ids,
                    "empId": $('#EmployeeId').val()
                },
                error: function (e) {
                    $('#preloader, #status').fadeOut();
                    alert('لم يتم الحفظ!');
                },
                success: function (r) {
                    $('#preloader, #status').fadeOut();
                    if (r == 'true') {
                        alert('تم الحفظ!');
                        window.location.reload();
                    } else {
                        alert('لم يتم الحفظ!');
                    }
                }
            });
        }
    }


    $(function(){
        $('input[type="radio"]').click(function(){
            if ($(this).is(':checked'))
            {


                $('#ShowByPage').val(@ViewBag.wantedRowsNo);




                var link = '/orderRequest/Index?' + 'pageIndex=' + pageNo + '&wantedRowsNo=' + $('#ShowByPage').val() + '&searchWord=' + $(this).val();
                window.location.replace(link);
                var count =@ViewBag.Count;
                for (var i = 0; i < Math.ceil(count / $('#ShowByPage').val()); i++)
                    $('.pagination').append('<li class="pageNo" id="pg' + (i + 1) + '"><a href="javascript:void(0);" onclick="pageNo=' + (i + 1) + '; paging();">' + (i + 1) + '</a></li>');

            }

        });
    });
</script>

