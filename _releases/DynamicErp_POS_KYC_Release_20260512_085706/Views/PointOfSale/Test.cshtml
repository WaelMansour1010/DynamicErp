                cursor += lineSpace;

                DrawCenterText('#100'); DrawRightText(':الطلب');
                cursor += lineSpace;
                DrawLeftText('26/1/2023 12:00:00'); DrawRightText(':وقت الطباعة');
                cursor += lineSpace;

                context.fillRect(0, cursor - 2, receiptWidth, 2);     // Underline

                DrawLeftText('استلام');
                cursor += lineSpace;
                DrawCenterText('#110170'); DrawRightText(':فاتورة');
                cursor += lineSpace;
                DrawRightText('20/1/2023 10:00:00');
                cursor += lineSpace;
                DrawLeftText('المنشئ:'); DrawRightText('Mohammed abdullah');
                cursor += lineSpace;
                //DrawCenterText('Thank you for your coming.'); cursor += lineSpace;
                //DrawCenterText("We hope you'll visit again."); cursor += lineSpace;

                cursor += lineSpace;
                context.fillRect(0, cursor - 2, receiptWidth, 2);     // Underline
                DrawLeftText('الصنف'); DrawCenterText('الكمية'); DrawRightText('السعر'); cursor += lineSpace;
                context.fillRect(0, cursor - 2, receiptWidth, 2);     // Underline

               @if (Model != null && Model.SalesInvoiceDetails != null)
               {
                   foreach (var item in Model.SalesInvoiceDetails)
                   {
                <text>
                DrawLeftText('@item.Item.ArName'); DrawCenterText('@item.Qty'); DrawRightText('@item.Price'); cursor += lineSpace;
                DrawLeftText('@item.Item.EnName');
                cursor += lineSpace;
                context.fillRect(0, cursor - 2, receiptWidth, 1);     // Underline
                </text>
                       }
                   }

                /*DrawLeftText('تفاح'); DrawCenterText('3'); DrawRightText('$20.00'); cursor += lineSpace;
                DrawLeftText('Apple');
                cursor += lineSpace;
                context.fillRect(0, cursor - 2, receiptWidth, 1);     // Underline

                DrawLeftText('موز'); DrawCenterText('1'); DrawRightText('$30.00'); cursor += lineSpace;
                DrawLeftText('Banana');
                cursor += lineSpace;
                context.fillRect(0, cursor - 2, receiptWidth, 1);     // Underline

                DrawLeftText('عنب'); DrawCenterText('2'); DrawRightText('$40.00'); cursor += lineSpace;
                DrawLeftText('Grape');
                cursor += lineSpace;
                context.fillRect(0, cursor - 2, receiptWidth, 1);     // Underline

                DrawLeftText('ليمون'); DrawCenterText('4'); DrawRightText('$50.00'); cursor += lineSpace;
                DrawLeftText('Lemon');
                cursor += lineSpace;
                context.fillRect(0, cursor - 2, receiptWidth, 1);     // Underline

                DrawLeftText('برتقال'); DrawCenterText('6'); DrawRightText('$60.00'); cursor += lineSpace;
                DrawLeftText('Orange');
                cursor += lineSpace;
                */
                context.fillRect(0, cursor - 2, receiptWidth, 2);     // Underline
                DrawLeftText('Subtotal'); DrawCenterText('@Model.SalesInvoiceDetails.Select(a=>a.ItemId).Count()'); DrawRightText('@Model.NetTotal'); cursor += lineSpace;
                context.fillRect(0, cursor - 2, receiptWidth, 2);     // Underline

                cursor += lineSpace;

                DrawLeftText('المجموع الفرعي:'); DrawRightText('@Model.Total'); cursor += lineSpace;
                DrawLeftText('رسم تقديم التبغ 100 %'); DrawRightText('@Model.SmokingTax'); cursor += lineSpace;
                DrawLeftText('ضريبة القيمة المضافة 15 %'); DrawRightText('@Model.SalesTaxes'); cursor += lineSpace;
                DrawLeftText('الإجمالي:'); DrawRightText('@Model.TotalAfterTaxes'); cursor += lineSpace;
                DrawLeftText('المدفوع:'); DrawRightText('@Model.Paid'); cursor += lineSpace;

                context.fillRect(0, cursor - 2, receiptWidth, 2);     // Underline
                DrawLeftText('عدد المنتجات:'); DrawCenterText('@Model.SalesInvoiceDetails.Select(a=>a.ItemId).Count()'); cursor += lineSpace;
                context.fillRect(0, cursor - 2, receiptWidth, 2);     // Underline

                DrawCenterText('جميع أسعار المنتجات شاملة الضريبة'); cursor += lineSpace;
                DrawCenterText("طريق تركى الأول - حي المحمدية"); cursor += lineSpace;

                context.fillRect(0, cursor - 2, receiptWidth, 2);     // Underline
                cursor += lineSpace;

                $('#qrcode').qrcode("https://www.google.com.eg/");

                // var _canvas = $('#qrcode canvas');

                // var img = _canvas.get(0).toDataURL("image/png");
                // var image0 = new Image();
                // image0.src = img;//'/assets/StarWebPrint/img/StarLogo1.jpg' + '?' + new Date().getTime();
                // console.log("_canvas : ", _canvas, " .. img : ", img, " .... image0 : ", image0);


                // //var preview = document.getElementById("img_preview");
                // //preview.appendChild(image0);

                // image0.onload = function () {
                //     //context.drawImage(image, canvas.width - image.width * logoScale, 0, image.width * logoScale, image.height * logoScale);
                //     context.drawImage(image0, (canvas.width - image.width * logoScale) / 2, 0, image.width * logoScale, image.height * logoScale);

                // }

                //// //or
                //// //var img = $(canvas)[0].toDataURL("image/png");
                //// document.write('<img src="' + img + '"/>');



                //DrawLeftText('Total'); DrawRightText('$210.00'); cursor += lineSpace;
                //cursor += lineSpace;
                //DrawLeftText('Received'); DrawRightText('$300.00'); cursor += lineSpace;
                //DrawLeftText('Change'); DrawRightText('$90.00'); cursor += lineSpace;

                //      alert('Cursor:' + cursor + ', ' + 'Canvas:' + canvas.height);

                var image = new Image();
                image.src = '/assets/StarWebPrint/img/StarLogo1.jpg' + '?' + new Date().getTime();
                image.onload = function () {
                    //context.drawImage(image, canvas.width - image.width * logoScale, 0, image.width * logoScale, image.height * logoScale);
                    context.drawImage(image, (canvas.width - image.width * logoScale) / 2, 0, image.width * logoScale, image.height * logoScale);
