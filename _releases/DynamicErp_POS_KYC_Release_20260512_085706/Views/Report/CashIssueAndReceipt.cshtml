
@{
    if (ViewBag.ShowReport == true)
    {
        Layout = null;
    }
    else
    {
        Layout = "~/Views/Shared/_Layout.cshtml";
    }
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";
    ViewBag.Title = MyERP.Properties.Resources.ReceiptAndIssueTransactionsToCashBoxInAPeriod;
}


<meta name="viewport" content="width=device-width" />
<title> @MyERP.Properties.Resources.ReceiptAndIssueTransactionsToCashBoxInAPeriod </title>
@if (ViewBag.ShowReport == true)
{
    @Html.DevExpress().GetStyleSheets(
            new StyleSheet { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
            new StyleSheet { ExtensionSuite = ExtensionSuite.Editors },
            new StyleSheet { ExtensionSuite = ExtensionSuite.Report }
        )

    @Html.DevExpress().GetScripts(
            new Script { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
            new Script { ExtensionSuite = ExtensionSuite.Editors },
            new Script { ExtensionSuite = ExtensionSuite.Report })

    <div>

        @Html.DevExpress().WebDocumentViewer(settings =>
   {
       settings.Name = "WebDocumentViewer2";
   }).Bind(new DevExpress.XtraReports.Web.CachedReportSourceWeb(new CashIssueAndReceipt_Report(ViewBag.DepartmentId, ViewBag.CashBoxId, ViewBag.dateFrom, ViewBag.dateTo, ViewBag.ActivityId, ViewBag.CompanyId, ViewBag.PropertyId, ViewBag.PropertyUnitId))).GetHtml()

    </div>
}
else
{
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <div class="row">
                    <div class="col-12">
                        <div class="form-horizontal needs-validation" role="form">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="header-title">
                                        @MyERP.Properties.Resources.ReceiptAndIssueTransactionsToCashBoxInAPeriod
                                    </h5>
                                    <div class="form-group row">
                                        <label class=" col-sm-1 control-label" for="ArName">@MyERP.Properties.Resources.Department</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("DepartmentId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", required = "required" })
                                        </div>
                                        <label class=" col-sm-1 control-label" for="ArName">@MyERP.Properties.Resources.CashBox</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("CashBoxId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new { @class = "form-control", required = "required" })
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label for="DateFrom" class="control-label col-sm-1">@MyERP.Properties.Resources.FromDate</label>
                                        <div class="col-sm-5">
                                            <input id="DateFrom" name="DateFrom" class="form-control" type="date" required />
                                        </div>
                                        <label for="DateTo" class="control-label col-sm-1">@MyERP.Properties.Resources.ToDate</label>
                                        <div class="col-sm-5">
                                            <input id="DateTo" name="DateTo" class="form-control" type="date" required />
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class=" col-sm-1 control-label">@MyERP.Properties.Resources.Activity</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("ActivityId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                        <label class=" col-sm-1 control-label">@MyERP.Properties.Resources.Company</label>
                                        <div class="col-sm-5">
                                            @Html.DropDownList("CompanyId", null, @MyERP.Properties.Resources.Select, htmlAttributes: new
                                       {
                                           @class = "form-control"
                                       })
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-offset-2">
                        <button class="btn btn-success" onclick="DownloadReport()">
                            @MyERP.Properties.Resources.ShowReport
                        </button>
                        <button class="btn btn-success" onclick="ShowData()">
                            @MyERP.Properties.Resources.ShowData
                        </button>
                        <button class="btn btn-success" onclick="ShowReport()">
                            @MyERP.Properties.Resources.ShowDesign
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!--------------------------------ShowData Table --------------------------------------->
<div class="row" id="AllTable" style="display:none">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal needs-validation" role="form">
                        <div class="card">
                            <div class="card-body">
                                <h5 class="header-title">
                                    @MyERP.Properties.Resources.ReportData
                                </h5>

                                <div class="table-responsive">
                                    <table class="table table-striped table-centered mb-0">
                                        <thead>
                                            <tr>
                                                <th>
                                                    @MyERP.Properties.Resources.DocNo
                                                </th>
                                                <th>
                                                    @MyERP.Properties.Resources.Transaction
                                                </th>
                                                <th>
                                                    @MyERP.Properties.Resources.Amount
                                                </th>
                                                <th>
                                                    @MyERP.Properties.Resources.SourceType
                                                </th>
                                                <th>
                                                    @MyERP.Properties.Resources.SourceName
                                                </th>
                                                <th>
                                                    @MyERP.Properties.Resources.Date
                                                </th>
                                                <th>
                                                    @MyERP.Properties.Resources.CashBox
                                                </th>
                                                <th>
                                                    @MyERP.Properties.Resources.Department
                                                </th>
                                                <th>
                                                    @MyERP.Properties.Resources.Notes
                                                </th>
                                            </tr>
                                        </thead>
                                        <tbody id="ShowDataTable"></tbody>
                                    </table>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
        </div>
    </div>
</div>

    <!--***********************************************************************************************-->
}
<script>
    var pageNo = 1;
        $('#ShowByPage').val('@ViewBag.wantedRowsNo');

        function JsDate(val) {
        var date = new Date(val);
        var dd = date.getDate();
        var mm = date.getMonth() + 1; //January is 0!
        var yyyy = date.getFullYear();

        if (dd < 10) {
            dd = '0' + dd;
        }

        if (mm < 10) {
            mm = '0' + mm;
        }

        return date = yyyy + '-' + mm + '-' + dd;
    }
    $(document).ready(function () {
        $.get('/Helper/GetOpenPeriodBeginningEnding').done(function (r) {
            var from = JsDate(r.PeriodStart);
            var to = JsDate(r.PeriodEnd);
            $('#DateFrom').prop('min', from);
            $('#DateFrom').prop('max', to);
            $('#DateFrom').val(from);
            $('#DateTo').prop('min', from);
            $('#DateTo').prop('max', to);
            $('#DateTo').val(to);
        });
    });


    function ShowReport() {
        window.open("/Report/CashIssueAndReceipt?departmentId=" + $('#DepartmentId').val() + "&cashBoxId=" + $('#CashBoxId').val() + "&dateFrom=" + $('#DateFrom').val() + "&dateTo=" + $('#DateTo').val()+ '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val() + '&showReport=' + true+'&print='+false, "blank");
    }
    function DownloadReport() {
        window.open("/Report/CashIssueAndReceipt?departmentId=" + $('#DepartmentId').val() + "&cashBoxId=" + $('#CashBoxId').val() + "&dateFrom=" + $('#DateFrom').val() + "&dateTo=" + $('#DateTo').val()+ '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val() + '&showReport=' + false + '&print=' + true, "blank");
    }

    function ShowData() {
        $('#ShowDataTable').empty();
        $('#preloader, #status').fadeIn();

        $.get('/Helper/GetCashIssueAndReceipt?departmentId=' + $('#DepartmentId').val() + '&cashBoxId=' + $('#CashBoxId').val() + '&dateFrom=' + $('#DateFrom').val() + '&dateTo=' + $('#DateTo').val()+ '&ActivityId=' + $('#ActivityId').val() + '&CompanyId=' + $('#CompanyId').val()).done(function (r) {
            $('#AllTable').show();
            for (var i = 0; i < r.length; i++) {

                r[i].Date = r[i].Date == null ? "" : convertToJavaScriptDate(r[i].Date);
                r[i].Department = r[i].Department == null ? "" : r[i].Department;
                r[i].CashBox = r[i].CashBox == null ? "" : r[i].CashBox;
                r[i].SourceName = r[i].SourceName == null ? "" : r[i].SourceName;
                r[i].SourceType = r[i].SourceType == null ? "" : r[i].SourceType;
                r[i].MoneyAmount = r[i].MoneyAmount == null ? 0 : r[i].MoneyAmount;
                r[i].DocumentNumber = r[i].DocumentNumber == null ? "" : r[i].DocumentNumber;
                r[i].VoucherType = r[i].VoucherType == null ? "" : r[i].VoucherType;
                r[i].Notes = r[i].Notes == null ? "" : r[i].Notes;

                let tr = '<tr><td ><label class="control-label">' +
                    r[i].DocumentNumber + '</label></td><td><label class="control-label">' +
                    r[i].VoucherType + '</label></td><td><label class="control-label">' +
                    r[i].MoneyAmount + '</label></td><td><label class="control-label">' +
                    r[i].SourceType + '</label></td><td><label class="control-label">' +
                    r[i].SourceName + '</label></td><td><label class="control-label">' +
                    r[i].Date + '</label></td><td><label class="control-label">' +
                    r[i].CashBox + '</label></td><td><label class="control-label">' +
                    r[i].Department + '</label></td><td><label class="control-label">' +
                    r[i].Notes + '</label></td></tr>';
                $('#ShowDataTable').append(tr);
            }
            $('#preloader, #status').fadeOut();
        });
    }

    function convertToJavaScriptDate(value) {
        if (value === null)
            return null;
        var pattern = /Date\(([^)]+)\)/;
        var results = pattern.exec(value);
        var dt = new Date(parseFloat(results[1]));
        return ((dt.getMonth() + 1 + "/" + dt.getDate() + "/" + dt.getFullYear()));
    }

</script>