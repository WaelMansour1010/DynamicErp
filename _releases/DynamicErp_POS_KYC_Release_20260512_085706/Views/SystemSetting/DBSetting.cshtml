
@{
    UICulture = Session["lang"] != null ? Session["lang"].ToString() : "ar";

    ViewBag.Title = MyERP.Properties.Resources.DataBaseInitialization;
    }

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="hed page-title">@MyERP.Properties.Resources.DataBaseInitialization</div>
        </div>
    </div>
</div>
<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="form-horizontal" role="form">
                        <div class="form-group row">
                            <div class="col-xs-12 col-sm-3 col-lg-4">
                                <button type="button" class="btn btn-info" id="1" onclick="InitializeDataBase(this)">
                                    @MyERP.Properties.Resources.DataBaseFullInitialization
                                </button>
                            </div>
                            <div class="col-xs-12 col-sm-3 col-lg-4">
                                <button type="button" class="btn btn-info" id="2" onclick="InitializeDataBase(this)">
                                    @MyERP.Properties.Resources.DataBaseInitializationButKeepingChartOfAccounts
                                </button>
                            </div>
                            <div class="col-xs-12 col-sm-3 col-lg-4">
                                <button type="button" class="btn btn-info" id="3" onclick="InitializeDataBase(this)">
                                    @MyERP.Properties.Resources.DataBaseTransactionsInitializationButKeepingMasterFiles
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>




<script>

    function InitializeDataBase(n) {
        let type = parseInt($(n).attr('id'));
        console.log(type);

        if (confirm('@MyERP.Properties.Resources.AreYouSureYouWantToInitializeDataBase')) {

            $('#preloader, #status').fadeIn();
            $.ajax({
                type: "POST", contentType: "application/json",
                url: "/SystemSetting/InitializeDataBase",
                data: JSON.stringify({
                    type: type,
                }),
                success: function (r) {
                    if (r.success == "true") {
                        alert("@MyERP.Properties.Resources.DataBaseInitializationSucceeded");
                        $('#preloader, #status').fadeOut();
                        window.location.replace("/LogOut/Index");
                    }
                    else {
                        $('#preloader, #status').fadeOut();
                        alert('@MyERP.Properties.Resources.AnErrorOccurredTryAgain')
                    }
                },
                error: function (r) {
                    $('#preloader, #status').fadeOut();
                    alert('@MyERP.Properties.Resources.DataBaseInitializationFailed')
                }
            });
        }
    }

</script>