@model IEnumerable<MyERP.Models.GetServiceCategory_Result>

@foreach (var item in Model)
{
    <tr>
        <td class="col-sm-8">
            <input class="ServiceId" type="hidden" value="@item.ServiceCategoryId" />
            @Html.DisplayFor(modelItem => item.ServiceCategoryArName)
        </td>

        <td class="col-sm-4">
            @if (item.Choosen == 1)
            {

                <input type="checkbox" class="Choosen" checked />

            }
            else
            {
                <input type="checkbox" class="Choosen" />
            }
        </td>

    </tr>
}


