@model IEnumerable<MyERP.Models.Technicians_Balance_Result>

@{
    ViewBag.Title = "كشف حساب الفنيين";
}

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="hed page-title">كشف حساب الفنيين</div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card-box">
            <div class="row">
                <div class="col-12">
                    <div class="table-responsive">
                        <table class="table table-striped table-centered mb-0">
                            <thead>
                                <tr>
                                <tr>
                                    <th>اسم الفني</th>
                                    <th>المدفوع</th>
                                    <th>المستحق</th>
                                    <th>الرصيد</th>

                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.ArName)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.Paid)
                                        </td>

                                        <td>
                                            @Html.DisplayFor(modelItem => item.Fees)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.Balance)
                                        </td>

                                    </tr>
                                }
                            </tbody>
                        </table>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>