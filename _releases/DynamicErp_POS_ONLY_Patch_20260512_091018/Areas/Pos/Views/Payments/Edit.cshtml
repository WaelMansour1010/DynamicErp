@model MyERP.Areas.MainErp.ViewModels.Payments.PaymentVoucherEditViewModel
@{
    Layout = null;
    ViewBag.Title = Model.Title;
    var saveAction = Model.NoteType == 5 ? "SaveVoucher" : "Save";
    var paymentMethods = new[]
    {
        new SelectListItem { Value = "0", Text = "نقدي" },
        new SelectListItem { Value = "1", Text = "شيك" },
        new SelectListItem { Value = "2", Text = "تحويل بنكي" },
        new SelectListItem { Value = "3", Text = "شيك آجل" },
        new SelectListItem { Value = "4", Text = "تسوية حساب" },
        new SelectListItem { Value = "5", Text = "دفع آجل" }
    };
    var voucherTypes = Model.NoteType == 4
        ? new[]
        {
            new SelectListItem { Value = "0", Text = "قبض نقدي" },
            new SelectListItem { Value = "1", Text = "قبض شيك" },
            new SelectListItem { Value = "2", Text = "تحويل بنكي" },
            new SelectListItem { Value = "3", Text = "قبض من عميل" },
            new SelectListItem { Value = "4", Text = "قبض من مورد" },
            new SelectListItem { Value = "5", Text = "قبض آخر" }
        }
        : new[]
        {
            new SelectListItem { Value = "0", Text = "صرف نقدي" },
            new SelectListItem { Value = "1", Text = "صرف شيك" },
            new SelectListItem { Value = "2", Text = "تحويل بنكي" },
            new SelectListItem { Value = "3", Text = "صرف لمورد" },
            new SelectListItem { Value = "4", Text = "صرف لعميل" },
            new SelectListItem { Value = "5", Text = "مصروف عام" }
        };
    var receiptClasses = new[]
    {
        new SelectListItem { Value = "0", Text = "بدون تصنيف" },
        new SelectListItem { Value = "1", Text = "سكني" },
        new SelectListItem { Value = "2", Text = "تجاري" },
        new SelectListItem { Value = "3", Text = "إداري" },
        new SelectListItem { Value = "7", Text = "خاص" }
    };
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title</title>
    <link href="@Url.Content("~/Areas/Pos/Content/pos-transaction.css")" rel="stylesheet" />
    @Html.Partial("~/Areas/Pos/Views/Shared/_VoucherScreenStyles.cshtml")
</head>
<body>
<div class="pos-page voucher-pos-page">
    <section class="pos-panel voucher-pos-panel voucher-details-page">
        <header class="voucher-page-header">
            <div>
                <span class="voucher-eyebrow">@Model.ScreenName</span>
                <h2>@Model.Title</h2>
                <p>حفظ فعلي من خلال stored procedure مع إنشاء القيد المحاسبي المتوازن.</p>
            </div>
            <div class="voucher-header-actions">
                <a class="secondary-action voucher-ghost-action" href="@Url.Action(Model.BackAction, Model.BackController, new { area = "Pos" })">رجوع</a>
            </div>
        </header>

        @if (!string.IsNullOrWhiteSpace(Model.Warning))
        {
            <div class="voucher-empty voucher-error">@Model.Warning</div>
        }

        @using (Html.BeginForm(saveAction, Model.BackController, new { area = "Pos" }, FormMethod.Post, new { @class = "voucher-edit-form" }))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(x => x.NoteId)
            @Html.HiddenFor(x => x.NoteType)

            <div class="voucher-section-stack">
                <section class="voucher-section">
                    <h3>بيانات السند</h3>
                    <div class="voucher-form-grid">
                        <label><span>التاريخ</span>@Html.TextBoxFor(x => x.NoteDate, "{0:yyyy-MM-dd}", new { type = "date", required = "required" })</label>
                        <label><span>رقم يدوي</span>@Html.TextBoxFor(x => x.ManualNo)</label>
                        <label><span>مرجع / أمر</span>@Html.TextBoxFor(x => x.OrderNo)</label>
                        <label><span>الفرع</span>@Html.DropDownListFor(x => x.BranchId, new SelectList(Model.Branches, "Value", "Text", Model.BranchId), "اختر الفرع")</label>
                        <label><span>حساب الطرف</span>@Html.DropDownListFor(x => x.PartyAccountCode, new SelectList(Model.Accounts, "Value", "Text", Model.PartyAccountCode), "اختر الحساب", new { required = "required" })</label>
                        <label><span>اسم الطرف</span>@Html.TextBoxFor(x => x.PartyDisplay)</label>
                        <label><span>الخزنة</span>@Html.DropDownListFor(x => x.BoxId, new SelectList(Model.Boxes, "Value", "Text", Model.BoxId), "بدون خزنة")</label>
                        <label><span>البنك</span>@Html.DropDownListFor(x => x.BankId, new SelectList(Model.Banks, "Value", "Text", Model.BankId), "بدون بنك")</label>
                        <label><span>طريقة الدفع</span>@Html.DropDownListFor(x => x.PaymentMethod, new SelectList(paymentMethods, "Value", "Text", Model.PaymentMethod), "اختر طريقة الدفع")</label>
                        <label><span>نوع السند</span>@Html.DropDownListFor(x => x.CashingType, new SelectList(voucherTypes, "Value", "Text", Model.CashingType), "اختر نوع السند")</label>
                        <label><span>تصنيف إضافي</span>@Html.DropDownListFor(x => x.ReceiptClass, new SelectList(receiptClasses, "Value", "Text", Model.ReceiptClass), "بدون تصنيف")</label>
                        <label><span>رقم الشيك</span>@Html.TextBoxFor(x => x.ChequeNumber)</label>
                        <label><span>تاريخ الشيك</span>@Html.TextBoxFor(x => x.ChequeDueDate, "{0:yyyy-MM-dd}", new { type = "date" })</label>
                        <label><span>المبلغ</span>@Html.TextBoxFor(x => x.Amount, new { type = "number", step = "0.01", required = "required", min = "0.01" })</label>
                        <label><span>الضريبة</span>@Html.TextBoxFor(x => x.Vat, new { type = "number", step = "0.01", min = "0" })</label>
                        <label class="voucher-check"><span>شامل الضريبة</span>@Html.CheckBoxFor(x => x.IncludeVat)</label>
                    </div>
                </section>

                <section class="voucher-section">
                    <h3>البيان</h3>
                    <div class="voucher-form-grid is-wide">
                        <label><span>البيان</span>@Html.TextAreaFor(x => x.Remark, 3, 40, null)</label>
                        <label><span>وصف الدفع</span>@Html.TextAreaFor(x => x.PayDescription, 3, 40, null)</label>
                        <label><span>وصف إضافي</span>@Html.TextAreaFor(x => x.PayDescription2, 3, 40, null)</label>
                    </div>
                </section>
            </div>

            <div class="voucher-action-row">
                <button type="submit" class="primary-action voucher-primary-action">حفظ السند</button>
                @if (Model.NoteId.HasValue)
                {
                    <a class="secondary-action voucher-ghost-action" href="@Url.Action("Details", Model.BackController, new { area = "Pos", id = Model.NoteId.Value })">إلغاء</a>
                }
            </div>
        }
    </section>
</div>
</body>
</html>
